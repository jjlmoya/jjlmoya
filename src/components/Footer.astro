---
interface Props {
    className?: string;
}

const { className = "" } = Astro.props;
---

<footer class={`py-8 text-center text-sm opacity-60 transition-colors duration-300 ${className}`}>
    <p>&copy; {new Date().getFullYear()} Juan José López Moya</p>
    <p style="margin-top: 0.35rem; font-size: 0.75rem;">
        <a
            href="https://creativecommons.org/licenses/by-nc/4.0/"
            target="_blank"
            rel="license noopener noreferrer"
            style="text-decoration: underline; text-underline-offset: 3px;"
        >Licencia CC BY-NC 4.0</a>
    </p>
</footer>
