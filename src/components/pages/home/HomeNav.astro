---
interface Props {
  links: Array<{ label: string; href: string }>;
  variant?: 'light' | 'dark';
}

const { links, variant = 'light' } = Astro.props;
---

<nav class={`home-nav home-nav--${variant}`}>
  {
    links.map((link) => (
      <a href={link.href} class="home-nav__link">
        {link.label}
      </a>
    ))
  }
</nav>

<style>
  .home-nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .home-nav__link {
    text-decoration: none;
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    position: relative;
    padding-bottom: 0.25rem;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .home-nav__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    transition: width 0.3s ease;
  }

  .home-nav__link:hover::after {
    width: 100%;
  }

  .home-nav--light .home-nav__link {
    color: #4b5563;
  }

  .home-nav--light .home-nav__link::after {
    background-color: #1a1a1a;
  }

  .home-nav--light .home-nav__link:hover {
    color: #1a1a1a;
  }

  .home-nav--dark .home-nav__link {
    color: #cbd5e1;
  }

  .home-nav--dark .home-nav__link::after {
    background-color: #22d3ee;
  }

  .home-nav--dark .home-nav__link:hover {
    color: #22d3ee;
  }

  @media (min-width: 768px) {
    .home-nav__link {
      font-size: 1.25rem;
    }
  }
</style>
