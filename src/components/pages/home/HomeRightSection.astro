---
import HomeNav from './HomeNav.astro';
import HeaderKitty from '../../HeaderKitty.astro';

interface Props {
  links: Array<{ label: string; href: string }>;
}

const { links } = Astro.props;
---

<section class="home-right">
  <p class="home-right__label">Game Indie Studio</p>
  <h2 class="home-right__title">
    <HeaderKitty />
    <span class="home-right__title-text">Game</span><span class="home-right__title-bob">Bob</span>
  </h2>
  <HomeNav links={links} variant="dark" />
</section>

<style>
  .home-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: center;
    background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
    color: #ffffff;
    padding: 2rem;
  }

  .home-right__label {
    font-size: 0.7rem;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .home-right__title {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -0.06em;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .home-right__title {
    position: relative;
  }

  .home-right__title-text {
    color: #ffffff;
    position: relative;
    z-index: 1;
  }
  .home-right__title-bob {
    color: #1ddabc;
    text-shadow: 0 0 30px rgba(29, 218, 188, 0.3);
    position: relative;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .home-right__title { font-size: 3.125rem; }
  }

  @media (min-width: 768px) {
    .home-right {
      width: 50%;
      padding-right: 3rem;
      padding-left: 2rem;
    }

    .home-right__label { font-size: 0.875rem; margin-bottom: 2rem; }
    .home-right__title { font-size: 3.75rem; margin-bottom: 1.5rem; }
  }

  @media (min-width: 1024px) {
    .home-right__title { font-size: 4.5rem; }
  }
</style>