---
import HomeNav from './HomeNav.astro';
import GameBobLogo from '../../GameBobLogo.astro';

interface Props {
  links: Array<{ label: string; href: string }>;
}

const { links } = Astro.props;
---

<section class="home-right">
  <div class="home-right__content">
    <p class="home-right__label">Game Indie Studio</p>
    <h2 class="home-right__title">
      <span class="home-right__title-game">Game</span><span class="home-right__title-bob">Bob</span>
    </h2>
    <div class="home-right__logo">
      <GameBobLogo />
    </div>
    <HomeNav links={links} variant="dark" />
  </div>
</section>

<style>
  .home-right {
    width: 100%;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
    color: #ffffff;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .home-right::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
      45deg,
      rgba(34, 211, 238, 0.05) 1px,
      transparent 1px
    );
    background-size: 40px 40px;
    pointer-events: none;
  }

  .home-right__content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 28rem;
  }

  @media (min-width: 768px) {
    .home-right {
      width: 50%;
      height: 100%;
      min-height: auto;
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
      justify-content: flex-end;
      padding-right: 3rem;
      padding-left: 2rem;
    }

    .home-right__content {
      align-items: flex-end;
      text-align: right;
    }
  }

  .home-right__label {
    font-size: 0.75rem;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .home-right__label {
      font-size: 0.875rem;
      margin-bottom: 2rem;
    }
  }

  .home-right__title {
    font-size: 2.25rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    line-height: 1;
  }

  @media (min-width: 640px) {
    .home-right__title {
      font-size: 3.125rem;
    }
  }

  @media (min-width: 768px) {
    .home-right__title {
      font-size: 3.75rem;
      margin-bottom: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .home-right__title {
      font-size: 4.5rem;
    }
  }

  .home-right__title-game {
    color: #ffffff;
  }

  .home-right__title-bob {
    color: #1ddabc;
  }

  .home-right__logo {
    width: 4rem;
    margin-bottom: 2rem;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }

  .home-right__logo:hover {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .home-right__logo {
      width: 6rem;
      margin-bottom: 2.5rem;
    }
  }
</style>
