---
import HomeLeftSection from './HomeLeftSection.astro';
import HomeRightSection from './HomeRightSection.astro';

const linksLeft = [
    { label: "proyectos", href: "/proyectos/" },
    { label: "apps", href: "/apps/" },
    { label: "utilidades", href: "/utilidades/" },
    { label: "conceptos", href: "/conceptos/" },
    { label: "charlas", href: "/charlas/" },
];

const linksRight = [
    { label: "inicio", href: "/gamebob/" },
    { label: "prototipos", href: "/gamebob/prototipos/" },
    { label: "mecánicas", href: "/gamebob/mecanicas/" },
    { label: "roadmap", href: "/gamebob/roadmap/" },
    { label: "post mortem", href: "/gamebob/post-mortem/" },
];
---

<div class="home-container">
    <h1 class="sr-only">jjlmoya - Portfolio & GameBob Studio</h1>
    <HomeLeftSection links={linksLeft} />
    <HomeRightSection links={linksRight} />
</div>

<style>
    .home-container {
        display: flex;
        flex-direction: column;
        width: 100%;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .home-container {
            flex-direction: row;
            height: 100vh;
        }
    }
</style>
