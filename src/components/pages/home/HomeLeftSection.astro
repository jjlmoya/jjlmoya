---
import HomeNav from "./HomeNav.astro";

interface Props {
    links: Array<{ label: string; href: string }>;
}

const { links } = Astro.props;
---

<section class="home-left">
    <div class="home-left__content">
        <h2 class="home-left__title">jjlmoya</h2>
        <p class="home-left__subtitle">Desarrollador creativo</p>
        <HomeNav links={links} variant="light" />
    </div>
</section>

<style>
    .home-left {
        width: 100%;
        min-height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        color: #1a1a1a;
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }

    .home-left::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url("/assets/textures/concrete-wall.webp");
        opacity: 0.02;
        pointer-events: none;
        mix-blend-mode: multiply;
    }

    .home-left__content {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 28rem;
    }

    @media (min-width: 768px) {
        .home-left {
            width: 50%;
            height: 100%;
            min-height: auto;
            justify-content: flex-start;
            padding-left: 3rem;
            padding-right: 2rem;
        }

        .home-left__content {
            align-items: flex-start;
        }
    }

    .home-left__title {
        font-size: 3rem;
        font-weight: 900;
        letter-spacing: -0.03em;
        margin-bottom: 2rem;
        line-height: 1;
    }

    @media (min-width: 640px) {
        .home-left__title {
            font-size: 3.75rem;
        }
    }

    @media (min-width: 768px) {
        .home-left__title {
            font-size: 4.5rem;
        }
    }

    @media (min-width: 1024px) {
        .home-left__title {
            font-size: 5.5rem;
        }
    }

    .home-left__subtitle {
        font-size: 0.875rem;
        color: #6b7280;
        margin-bottom: 2rem;
        font-weight: 300;
    }

    @media (min-width: 768px) {
        .home-left__subtitle {
            font-size: 1rem;
        }
    }
</style>
