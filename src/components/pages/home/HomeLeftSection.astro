---
import HomeNav from "./HomeNav.astro";

interface Props {
    links: Array<{ label: string; href: string }>;
}

const { links } = Astro.props;
---

<section class="home-left">
    <h2 class="home-left__title">jjlmoya</h2>
    <p class="home-left__subtitle">Desarrollador creativo</p>
    <HomeNav links={links} variant="light" />
</section>

<style>
    .home-left {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        color: #1a1a1a;
        padding: 2rem;
    }

    .home-left__title {
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        line-height: 1;
    }

    .home-left__subtitle {
        font-size: 0.8rem;
        color: #6b7280;
        margin-bottom: 1.5rem;
        font-weight: 300;
    }

    @media (min-width: 640px) {
        .home-left__title { font-size: 3rem; }
    }

    @media (min-width: 640px) {
        .home-left__title { font-size: 3.75rem; }
    }

    @media (min-width: 768px) {
        .home-left {
            flex: 1;
            width: 50%;
            padding-left: 3rem;
            padding-right: 2rem;
        }

        .home-left__title { font-size: 4.5rem; }
        .home-left__subtitle { font-size: 1rem; }
    }

        .home-left {
            --nav-align: flex-start;
        }
        .home-left__title { font-size: 4.5rem; }
        .home-left__subtitle { font-size: 1rem; }
    }

    @media (min-width: 1024px) {
        .home-left__title { font-size: 5.5rem; }
    }
</style>