---
import ShareableQuote from "../../ShareableQuote.astro";
---

<section
    id="raquis"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-rachis"
>
    <div
        class="wheat-container wheat-container--wide wheat-grid wheat-grid--cols-2 wheat-items-center wheat-gap-8 wheat-gap-16@md"
    >
        <div class="wheat-rachis-visual wheat-flex wheat-items-center wheat-justify-center wheat-rounded wheat-overflow-hidden wheat-border">
            <div class="wheat-absolute wheat-inset-0 wheat-rachis-visual-bg"></div>

            <div class="wheat-relative wheat-rachis-stem">
                <div class="wheat-absolute wheat-rachis-joint wheat-rachis-joint--top"></div>
                <div class="wheat-absolute wheat-rachis-joint wheat-rachis-joint--bottom"></div>
                <div class="wheat-absolute wheat-rachis-pulse wheat-rounded-full"></div>
                <div class="wheat-absolute wheat-rachis-dot wheat-rounded-full"></div>
            </div>

            <div class="wheat-absolute wheat-rachis-caption">
                <p class="wheat-text-xs wheat-tracking-widest wheat-uppercase">
                    El Raquis
                </p>
            </div>
        </div>

        <div class="wheat-space-y-12 wheat-space-y-16@md">
            <div class="wheat-space-y-4 wheat-space-y-6@md">
                <span class="trigo-chapter wheat-rachis-chapter wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase">
                    La Estructura Invisible
                </span>
                <h2 class="wheat-text-3xl wheat-text-4xl@md wheat-font-bold wheat-rachis-title">
                    Un accidente microscópico
                </h2>
                <p class="wheat-text-base wheat-text-lg@md wheat-leading-relaxed wheat-rachis-desc">
                    La historia de la civilización descansa sobre un detalle biológico: <strong class="wheat-font-bold wheat-rachis-strong">El Raquis</strong>. En el trigo salvaje, es quebradizo para dispersar la semilla. En el trigo doméstico, es duro; la semilla espera al hombre.
                </p>
                <p class="wheat-text-base wheat-text-lg@md wheat-leading-relaxed wheat-rachis-desc">
                    Ese milímetro de biología creó la "necesidad del trabajo". El trigo ya no podía nacer solo. Nosotros ya no podíamos comer sin sembrar. <ShareableQuote
                        quote="Se firmó un contrato de sangre: nosotros le damos la vida, él nos da la energía."
                    />
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-rachis {
        color: #e7e5e4;
    }
    .wheat-rachis-visual {
        height: 40vh;
        background-color: #0c0a09;
        border-color: rgba(146, 64, 14, 0.2);
        position: relative;
    }
    @media (min-width: 768px) {
        .wheat-rachis-visual {
            height: 80vh;
            position: sticky;
            top: 2.5rem;
        }
        .wheat-gap-16\@md {
            gap: 4rem;
        }
        .wheat-space-y-6\@md > * + * {
            margin-top: 1.5rem;
        }
        .wheat-space-y-16\@md > * + * {
            margin-top: 4rem;
        }
    }
    .wheat-rachis-visual-bg {
        background: radial-gradient(circle at center, #292524, #0c0a09);
    }
    .wheat-rachis-stem {
        width: 0.5rem;
        height: 12rem;
        background-color: #57534e;
        border-radius: 9999px;
    }
    @media (min-width: 768px) {
        .wheat-rachis-stem {
            height: 16rem;
        }
    }
    .wheat-rachis-joint {
        left: 50%;
        transform: translateX(-50%);
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
    }
    @media (min-width: 768px) {
        .wheat-rachis-joint {
            width: 3rem;
            height: 3rem;
        }
    }
    .wheat-rachis-joint--top {
        top: 0;
        border-bottom: 4px solid #a8a29e;
        transform: translateX(-50%) rotate(45deg);
    }
    .wheat-rachis-joint--bottom {
        bottom: 0;
        border-top: 4px solid #a8a29e;
        transform: translateX(-50%) rotate(-45deg);
    }
    .wheat-rachis-pulse {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 1.5rem;
        height: 1.5rem;
        background-color: rgba(120, 53, 4, 0.5);
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        filter: blur(4px);
    }
    @media (min-width: 768px) {
        .wheat-rachis-pulse {
            width: 2rem;
            height: 2rem;
        }
    }
    .wheat-rachis-dot {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 0.375rem;
        height: 0.375rem;
        background-color: #f59e0b;
    }
    @media (min-width: 768px) {
        .wheat-rachis-dot {
            width: 0.5rem;
            height: 0.5rem;
        }
    }
    .wheat-rachis-caption {
        bottom: 1rem;
        width: 100%;
        text-align: center;
        box-sizing: border-box;
        padding: 0 1rem;
    }
    @media (min-width: 768px) {
        .wheat-rachis-caption {
            bottom: 2rem;
        }
    }
    .wheat-rachis-caption p {
        color: rgba(245, 158, 11, 0.8);
    }
    .wheat-rachis-chapter {
        color: #a8a29e;
    }
    .wheat-rachis-title {
        color: #e7e5e4;
    }
    .wheat-rachis-desc {
        color: #d6d3d1;
    }
    .wheat-rachis-strong {
        color: #ffffff;
    }
    @keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
        50% {
            opacity: .5;
            transform: translate(-50%, -50%) scale(.85);
        }
    }
</style>
