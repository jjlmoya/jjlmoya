---
const sections = [
    { id: "positive-documentation", label: "Referencias", theme: "emerald" },
    { id: "dilema-luz", label: "Elige tu Bando", theme: "emerald" },
    { id: "positive-expansion", label: "IX. La Expansión", theme: "emerald" },
    { id: "positive-knowledge", label: "VIII. La Ciencia", theme: "emerald" },
    { id: "positive-specialization", label: "VII. El Genio", theme: "emerald" },
    { id: "positive-law", label: "VI. La Ley", theme: "emerald" },
    { id: "positive-beer", label: "V. La Fiesta", theme: "emerald" },
    { id: "positive-trade", label: "IV. El Comercio", theme: "emerald" },
    { id: "positive-writing", label: "III. La Escritura", theme: "emerald" },
    { id: "positive-city", label: "II. La Ciudad", theme: "emerald" },
    { id: "positive-security", label: "I. La Seguridad", theme: "emerald" },
    { id: "intro", label: "Inicio", theme: "neutral" },
    { id: "tiempo-profundo", label: "I. Tiempo Profundo", theme: "amber" },
    { id: "raquis", label: "II. El Raquis", theme: "amber" },
    { id: "trampa", label: "III. La Trampa", theme: "amber" },
    { id: "rutina", label: "IV. La Rutina", theme: "amber" },
    { id: "cuerpos-rotos", label: "V. Cuerpos Rotos", theme: "amber" },
    { id: "calorias-cazador", label: "VI. Calorías (Cazador)", theme: "amber" },
    { id: "calorias-agricultor", label: "VII. Calorías (Agricultor)", theme: "amber" },
    { id: "excedente", label: "VIII. El Excedente", theme: "amber" },
    { id: "contrato-social", label: "IX. Contrato Social", theme: "amber" },
    { id: "demografia", label: "X. Demografía", theme: "amber" },
    { id: "jornada-laboral", label: "XI. Jornada Laboral", theme: "amber" },
    { id: "mapa-moderno", label: "XII. Mapa Moderno", theme: "amber" },
    { id: "futuro", label: "XIII. El Futuro", theme: "amber" },
    { id: "epilogo", label: "Epílogo", theme: "neutral" },
    { id: "documentacion", label: "Referencias", theme: "neutral" },
    { id: "dilema-sombra", label: "Elige tu Bando", theme: "neutral" },
];
---

<nav
    class="wheat-fixed wheat-toc wheat-flex wheat-flex-col wheat-gap-4"
    aria-label="Table of Contents"
>
    {
        sections.map((section) => (
            <a
                href={`#${section.id}`}
                class="group wheat-flex wheat-items-center wheat-justify-end wheat-gap-3 wheat-toc-link"
                aria-label={`Ir a ${section.label}`}
                data-theme={section.theme}
            >
                <span
                    class:list={[
                        "wheat-text-xs wheat-uppercase wheat-tracking-widest wheat-toc-label",
                        section.theme === "emerald"
                            ? "wheat-toc-label--emerald"
                            : section.theme === "amber"
                              ? "wheat-toc-label--amber"
                              : "wheat-toc-label--neutral",
                    ]}
                >
                    {section.label}
                </span>
                <div class:list={["wheat-toc-dot", section.theme]} />
            </a>
        ))
    }
</nav>

<button
    id="toc-mobile-toggle"
    class="wheat-fixed wheat-toc-mobile-btn wheat-rounded-full wheat-flex wheat-items-center wheat-justify-center"
    aria-label="Abrir índice"
>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="wheat-toc-mobile-icon"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
    </svg>
</button>

<div
    id="toc-mobile-menu"
    class="wheat-fixed wheat-toc-mobile-menu wheat-flex wheat-flex-col translate-y-full"
>
    <div class="wheat-flex wheat-justify-end wheat-p-6">
        <button id="toc-mobile-close" class="wheat-toc-mobile-close wheat-p-2">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="wheat-toc-mobile-close-icon"
            >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"
                ></path>
            </svg>
        </button>
    </div>
    <div class="wheat-flex-1 wheat-overflow-y-auto wheat-px-6 wheat-pb-12">
        <h3 class="wheat-toc-mobile-title wheat-text-xs wheat-uppercase wheat-tracking-widest wheat-mb-8 wheat-pb-4">
            Índice de Contenidos
        </h3>
        <nav class="wheat-flex wheat-flex-col wheat-gap-6">
            {
                sections.map((section) => (
                    <a
                        href={`#${section.id}`}
                        class="toc-mobile-link wheat-text-lg wheat-font-serif wheat-flex wheat-items-center wheat-gap-4 wheat-toc-mobile-link"
                        data-target={section.id}
                    >
                        <span
                            class:list={[
                                "wheat-toc-mobile-dot wheat-rounded-full",
                                section.theme === "emerald"
                                    ? "wheat-toc-mobile-dot--emerald"
                                    : section.theme === "amber"
                                      ? "wheat-toc-mobile-dot--amber"
                                      : "wheat-toc-mobile-dot--neutral"
                            ]}
                        />
                        {section.label}
                    </a>
                ))
            }
        </nav>
    </div>
</div>

<script>
    const observerOptions = {
        root: null,
        rootMargin: "-50% 0px",
        threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                const id = entry.target.id;
                const link = document.querySelector(`a[href="#${id}"]`);
                const navDot = link?.querySelector(".wheat-toc-dot");

                if (!link || !navDot) return;

                document.querySelectorAll(".wheat-toc-dot").forEach((dot) => {
                    dot.classList.remove("active");
                });

                navDot.classList.add("active");
            }
        });
    }, observerOptions);

    document.querySelectorAll("section[id]").forEach((section) => {
        observer.observe(section);
    });

    const toggleBtn = document.getElementById("toc-mobile-toggle");
    const closeBtn = document.getElementById("toc-mobile-close");
    const menu = document.getElementById("toc-mobile-menu");
    const links = document.querySelectorAll(".toc-mobile-link");

    function toggleMenu() {
        menu?.classList.toggle("translate-y-full");
        document.body.classList.toggle("overflow-hidden");
    }

    toggleBtn?.addEventListener("click", toggleMenu);
    closeBtn?.addEventListener("click", toggleMenu);

    links.forEach((link) => {
        link.addEventListener("click", toggleMenu);
    });
</script>

<style>
    .wheat-toc {
        position: fixed;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        z-index: 50;
        display: none;
    }
    @media (min-width: 1024px) {
        .wheat-toc {
            display: flex;
        }
    }
    .wheat-toc-link {
        text-decoration: none;
    }
    .wheat-toc-label {
        font-size: 10px;
        opacity: 0;
        transform: translateX(-0.5rem);
        transition: all 0.3s;
        background-color: rgba(0, 0, 0, 0.5);
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
    }
    .group:hover .wheat-toc-label {
        opacity: 1;
        transform: translateX(0);
    }
    .wheat-toc-label--emerald {
        color: #34d399;
    }
    .wheat-toc-label--amber {
        color: #fbbf24;
    }
    .wheat-toc-label--neutral {
        color: #a8a29e;
    }
    .wheat-toc-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        border: 1px solid #44403c;
        background-color: #292524;
        transition: all 0.3s;
    }
    .group:hover .wheat-toc-dot {
        transform: scale(1.25);
    }
    .group:hover .wheat-toc-dot.emerald, .wheat-toc-dot.emerald.active {
        background-color: #10b981;
        border-color: #10b981;
        transform: scale(1.25);
    }
    .group:hover .wheat-toc-dot.amber, .wheat-toc-dot.amber.active {
        background-color: #f59e0b;
        border-color: #f59e0b;
        transform: scale(1.25);
    }
    .group:hover .wheat-toc-dot.neutral, .wheat-toc-dot.neutral.active {
        background-color: #78716c;
        border-color: #78716c;
        transform: scale(1.25);
    }

    .wheat-toc-mobile-btn {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 50;
        width: 3rem;
        height: 3rem;
        background-color: rgba(28, 25, 23, 0.8);
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
        border: 1px solid #44403c;
        color: #f59e0b;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        cursor: pointer;
        transition: transform 0.2s;
    }
    @media (min-width: 1024px) {
        .wheat-toc-mobile-btn {
            display: none;
        }
    }
    .wheat-toc-mobile-btn:hover {
        transform: scale(1.05);
    }
    .wheat-toc-mobile-icon {
        width: 1.5rem;
        height: 1.5rem;
    }

    .wheat-toc-mobile-menu {
        position: fixed;
        inset: 0;
        z-index: 60;
        background-color: rgba(12, 10, 9, 0.95);
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
        transition: transform 0.3s;
    }
    @media (min-width: 1024px) {
        .wheat-toc-mobile-menu {
            display: none;
        }
    }
    .wheat-toc-mobile-close {
        background: none;
        border: none;
        color: #a8a29e;
        cursor: pointer;
    }
    .wheat-toc-mobile-close:hover {
        color: #ffffff;
    }
    .wheat-toc-mobile-close-icon {
        width: 2rem;
        height: 2rem;
    }
    .wheat-toc-mobile-title {
        color: #f59e0b;
        font-weight: bold;
        border-bottom: 1px solid #292524;
    }
    .wheat-toc-mobile-link {
        text-decoration: none;
        color: #d6d3d1;
        transition: color 0.2s;
    }
    .wheat-toc-mobile-link:hover {
        color: #f59e0b;
    }
    .wheat-toc-mobile-dot {
        width: 0.375rem;
        height: 0.375rem;
    }
    .wheat-toc-mobile-dot--emerald { background-color: #10b981; }
    .wheat-toc-mobile-dot--amber { background-color: #f59e0b; }
    .wheat-toc-mobile-dot--neutral { background-color: #78716c; }
</style>
