---
interface Props {
    farmerText: string;
    hunterText: string;
}

const { farmerText, hunterText } = Astro.props;
---

<div class="wheat-grid wheat-grid--cols-2 wheat-my-12 wheat-max-w-4xl wheat-mx-auto wheat-dialogue">
    <div class="wheat-relative wheat-dialogue-card wheat-dialogue-card--farmer wheat-p-6 wheat-rounded-lg wheat-transition-colors">
        <div class="wheat-absolute wheat-dialogue-badge wheat-dialogue-badge--farmer wheat-px-2 wheat-text-xs wheat-font-bold wheat-uppercase wheat-tracking-widest wheat-rounded">
            El Agricultor
        </div>
        <p class="wheat-dialogue-text wheat-dialogue-text--farmer wheat-text-sm wheat-text-base@md wheat-italic wheat-leading-relaxed">
            "{farmerText}"
        </p>
    </div>

    <div class="wheat-relative wheat-dialogue-card wheat-dialogue-card--hunter wheat-p-6 wheat-rounded-lg wheat-transition-colors">
        <div class="wheat-absolute wheat-dialogue-badge wheat-dialogue-badge--hunter wheat-px-2 wheat-text-xs wheat-font-bold wheat-uppercase wheat-tracking-widest wheat-rounded">
            El Cazador
        </div>
        <p class="wheat-dialogue-text wheat-dialogue-text--hunter wheat-text-sm wheat-text-base@md wheat-italic wheat-leading-relaxed">
            "{hunterText}"
        </p>
    </div>
</div>

<style>
    .wheat-dialogue-card {
        background-color: #1c1917;
        border-style: solid;
        border-width: 0;
    }
    .wheat-dialogue-card:hover {
        background-color: #292524;
    }
    .wheat-dialogue-card--farmer {
        border-left-width: 4px;
        border-color: rgba(245, 158, 11, 0.5);
    }
    .wheat-dialogue-card--hunter {
        border-left-width: 4px;
        border-color: rgba(120, 113, 108, 0.5);
    }
    @media (min-width: 768px) {
        .wheat-dialogue-card--hunter {
            border-left-width: 0;
            border-right-width: 4px;
            text-align: right;
        }
    }
    .wheat-dialogue-badge {
        top: -0.75rem;
        background-color: #0c0a09;
        border: 1px solid;
    }
    .wheat-dialogue-badge--farmer {
        left: 1rem;
        color: #f59e0b;
        border-color: rgba(146, 64, 14, 0.3);
    }
    .wheat-dialogue-badge--hunter {
        left: 1rem;
        color: #78716c;
        border-color: #292524;
    }
    @media (min-width: 768px) {
        .wheat-dialogue-badge--hunter {
            left: auto;
            right: 1rem;
        }
    }
    .wheat-dialogue-text--farmer {
        color: #d6d3d1;
    }
    .wheat-dialogue-text--hunter {
        color: #a8a29e;
    }
    @media (min-width: 768px) {
        .wheat-text-base\@md {
            font-size: 1rem;
        }
    }
</style>
