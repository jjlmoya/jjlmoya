---
import ShareableQuote from "../../ShareableQuote.astro";
---

<section
    id="positive-specialization"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-flex-col wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-pos-spec"
>
    <div class="wheat-w-full wheat-max-w-6xl wheat-mx-auto wheat-px-4 wheat-px-6@md wheat-flex wheat-flex-col wheat-h-full wheat-justify-center">
        <div class="wheat-text-center wheat-mb-8 wheat-mb-16@md">
            <span class="wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase wheat-block wheat-mb-4 trigo-positive-chapter">
                El Genio
            </span>
            <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-pos-spec-title wheat-mb-6">
                El Nacimiento del Genio
            </h2>
            <p class="wheat-text-lg wheat-pos-spec-desc wheat-max-w-2xl wheat-mx-auto">
                <ShareableQuote
                    quote="En una tribu de cazadores, todos cazan. En una ciudad de trigo, uno cultiva y nueve pueden soñar."
                />
            </p>
        </div>

        <div class="wheat-pos-spec-cards-container wheat-mb-8 wheat-mb-12@md">
            <div class="wheat-relative wheat-pos-spec-card-wrapper wheat-group">
                <div class="wheat-absolute wheat-inset-0 wheat-pos-spec-card-glow"></div>
                <div class="wheat-relative wheat-pos-spec-card wheat-p-6 wheat-p-8@md wheat-rounded-xl wheat-border wheat-flex wheat-flex-col wheat-justify-between">
                    <div class="wheat-flex wheat-flex-col wheat-items-center wheat-text-center wheat-space-y-4">
                        <div class="wheat-pos-spec-icon-wrapper wheat-rounded-full wheat-flex wheat-items-center wheat-justify-center">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="wheat-pos-spec-icon"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="wheat-text-xl wheat-text-2xl@md wheat-font-bold wheat-pos-spec-card-title wheat-mb-2">
                                El Artesano
                            </h3>
                            <div class="wheat-pos-spec-card-divider wheat-mx-auto wheat-mb-4"></div>
                            <p class="wheat-text-sm wheat-pos-spec-card-desc wheat-leading-relaxed">
                                Liberado de la búsqueda de comida, las manos pudieron perfeccionar
                                la arcilla, el metal y la tela. Nació el concepto de "maestro".
                            </p>
                        </div>
                    </div>
                    <div class="wheat-pt-4 wheat-pos-spec-card-footer wheat-mt-4">
                        <div class="wheat-text-xs wheat-pos-spec-card-tags wheat-uppercase wheat-tracking-widest">
                            Cerámica • Metalurgia • Textiles
                        </div>
                    </div>
                </div>
            </div>

            <div class="wheat-relative wheat-pos-spec-card-wrapper wheat-group">
                <div class="wheat-absolute wheat-inset-0 wheat-pos-spec-card-glow"></div>
                <div class="wheat-relative wheat-pos-spec-card wheat-p-6 wheat-p-8@md wheat-rounded-xl wheat-border wheat-flex wheat-flex-col wheat-justify-between">
                    <div class="wheat-flex wheat-flex-col wheat-items-center wheat-text-center wheat-space-y-4">
                        <div class="wheat-pos-spec-icon-wrapper wheat-rounded-full wheat-flex wheat-items-center wheat-justify-center">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="wheat-pos-spec-icon"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="wheat-text-xl wheat-text-2xl@md wheat-font-bold wheat-pos-spec-card-title wheat-mb-2">
                                El Sanador
                            </h3>
                            <div class="wheat-pos-spec-card-divider wheat-mx-auto wheat-mb-4"></div>
                            <p class="wheat-text-sm wheat-pos-spec-card-desc wheat-leading-relaxed">
                                El tiempo libre permitió la observación. Entendimos las plantas no
                                solo como comida, sino como medicina. Nació la farmacología.
                            </p>
                        </div>
                    </div>
                    <div class="wheat-pt-4 wheat-pos-spec-card-footer wheat-mt-4">
                        <div class="wheat-text-xs wheat-pos-spec-card-tags wheat-uppercase wheat-tracking-widest">
                            Herbolaria • Cirugía • Diagnóstico
                        </div>
                    </div>
                </div>
            </div>

            <div class="wheat-relative wheat-pos-spec-card-wrapper wheat-group">
                <div class="wheat-absolute wheat-inset-0 wheat-pos-spec-card-glow"></div>
                <div class="wheat-relative wheat-pos-spec-card wheat-p-6 wheat-p-8@md wheat-rounded-xl wheat-border wheat-flex wheat-flex-col wheat-justify-between">
                    <div class="wheat-flex wheat-flex-col wheat-items-center wheat-text-center wheat-space-y-4">
                        <div class="wheat-pos-spec-icon-wrapper wheat-rounded-full wheat-flex wheat-items-center wheat-justify-center">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="wheat-pos-spec-icon"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="wheat-text-xl wheat-text-2xl@md wheat-font-bold wheat-pos-spec-card-title wheat-mb-2">
                                El Astrónomo
                            </h3>
                            <div class="wheat-pos-spec-card-divider wheat-mx-auto wheat-mb-4"></div>
                            <p class="wheat-text-sm wheat-pos-spec-card-desc wheat-leading-relaxed">
                                Necesitábamos predecir las cosechas. Así que miramos arriba y
                                mapeamos las estrellas. Inventamos el calendario y las matemáticas.
                            </p>
                        </div>
                    </div>
                    <div class="wheat-pt-4 wheat-pos-spec-card-footer wheat-mt-4">
                        <div class="wheat-text-xs wheat-pos-spec-card-tags wheat-uppercase wheat-tracking-widest">
                            Astronomía • Calendario • Geometría
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="wheat-relative wheat-max-w-4xl wheat-mx-auto wheat-w-full">
            <div class="wheat-absolute wheat-inset-0 wheat-pos-spec-radial-glow"></div>
            <div class="wheat-relative wheat-pos-spec-compare-card wheat-p-6 wheat-p-8@md wheat-rounded-xl wheat-border wheat-text-center">
                <div class="wheat-flex wheat-flex-col wheat-flex-row@md wheat-items-center wheat-justify-center wheat-gap-6 wheat-gap-12@md wheat-mb-4 wheat-mb-6@md">
                    <div class="wheat-text-center">
                        <div class="wheat-text-4xl wheat-text-5xl@md wheat-font-bold wheat-pos-spec-compare-val wheat-pos-spec-compare-val--before wheat-mb-2">100%</div>
                        <div class="wheat-text-xs wheat-pos-spec-compare-label wheat-uppercase wheat-tracking-wider">Cazadores</div>
                        <div class="wheat-text-xs wheat-pos-spec-compare-sub wheat-mt-1">Antes del trigo</div>
                    </div>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="2"
                        stroke="currentColor"
                        class="wheat-pos-spec-compare-arrow"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
                    </svg>
                    <div class="wheat-text-center">
                        <div class="wheat-text-4xl wheat-text-5xl@md wheat-font-bold wheat-pos-spec-compare-val wheat-pos-spec-compare-val--after wheat-mb-2">10%</div>
                        <div class="wheat-text-xs wheat-pos-spec-compare-label wheat-uppercase wheat-tracking-wider">
                            Agricultores
                        </div>
                        <div class="wheat-text-xs wheat-pos-spec-compare-sub wheat-pos-spec-compare-sub--after wheat-mt-1">Después del trigo</div>
                    </div>
                </div>
                <p class="wheat-text-sm wheat-pos-spec-compare-text wheat-max-w-2xl wheat-mx-auto">
                    El excedente liberó al 90% de la población para dedicarse a la innovación, el
                    arte y la ciencia. Por primera vez, la humanidad pudo especializarse.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-pos-spec {
        color: #e7e5e4;
        border-bottom: 1px solid rgba(16, 185, 129, 0.1);
    }
    .wheat-pos-spec-title {
        color: #e7e5e4;
    }
    .wheat-pos-spec-desc {
        color: #a8a29e;
    }
    .wheat-pos-spec-cards-container {
        display: flex;
        flex-direction: row;
        gap: 1rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding-bottom: 1rem;
        margin-left: -1rem;
        margin-right: -1rem;
        padding-left: 1rem;
        padding-right: 1rem;
    }
    .wheat-pos-spec-cards-container::-webkit-scrollbar {
        display: none;
    }
    .wheat-pos-spec-card-wrapper {
        min-width: 85vw;
        scroll-snap-align: center;
    }
    .wheat-pos-spec-card-glow {
        background: linear-gradient(to bottom right, rgba(16, 185, 129, 0.1), transparent);
        border-radius: 0.75rem;
        opacity: 0;
        transition: opacity 0.5s;
    }
    .wheat-pos-spec-card-wrapper:hover .wheat-pos-spec-card-glow {
        opacity: 1;
    }
    .wheat-pos-spec-card {
        background: linear-gradient(to bottom right, #1c1917, #0c0a09);
        border-color: rgba(16, 185, 129, 0.2);
        transition: all 0.3s;
        height: 100%;
        box-sizing: border-box;
    }
    .wheat-pos-spec-card-wrapper:hover .wheat-pos-spec-card {
        border-color: rgba(16, 185, 129, 0.4);
    }
    .wheat-pos-spec-icon-wrapper {
        width: 4rem;
        height: 4rem;
        background: linear-gradient(to bottom right, rgba(16, 185, 129, 0.4), rgba(6, 78, 59, 0.2));
        transition: transform 0.3s;
    }
    .wheat-pos-spec-card-wrapper:hover .wheat-pos-spec-icon-wrapper {
        transform: scale(1.1);
    }
    .wheat-pos-spec-icon {
        width: 2rem;
        height: 2rem;
        color: #10b981;
    }
    .wheat-pos-spec-card-title {
        color: #e7e5e4;
    }
    .wheat-pos-spec-card-divider {
        width: 3rem;
        height: 4px;
        background: linear-gradient(to right, transparent, rgba(16, 185, 129, 0.5), transparent);
    }
    .wheat-pos-spec-card-desc {
        color: #a8a29e;
    }
    .wheat-pos-spec-card-footer {
        border-top: 1px solid rgba(16, 185, 129, 0.2);
    }
    .wheat-pos-spec-card-tags {
        color: rgba(16, 185, 129, 0.6);
    }
    .wheat-pos-spec-radial-glow {
        background: linear-gradient(to right, rgba(16, 185, 129, 0.05), rgba(16, 185, 129, 0.1), rgba(16, 185, 129, 0.05));
        filter: blur(24px);
    }
    .wheat-pos-spec-compare-card {
        background-color: #0c0a09;
        border-color: rgba(16, 185, 129, 0.3);
    }
    .wheat-pos-spec-compare-val {
        line-height: 1;
    }
    .wheat-pos-spec-compare-val--before {
        color: #57534e;
    }
    .wheat-pos-spec-compare-val--after {
        color: #10b981;
    }
    .wheat-pos-spec-compare-label {
        color: #a8a29e;
    }
    .wheat-pos-spec-compare-sub {
        color: #57534e;
    }
    .wheat-pos-spec-compare-sub--after {
        color: #065f46;
    }
    .wheat-pos-spec-compare-arrow {
        width: 2rem;
        height: 2rem;
        color: rgba(16, 185, 129, 0.5);
        transform: rotate(90deg);
    }
    .wheat-pos-spec-compare-text {
        color: #78716c;
    }
    @media (min-width: 768px) {
        .wheat-pos-spec-cards-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            overflow-x: visible;
            padding-bottom: 0;
            margin-left: 0;
            margin-right: 0;
            padding-left: 0;
            padding-right: 0;
        }
        .wheat-pos-spec-card-wrapper {
            min-width: 0;
        }
        .wheat-pos-spec-icon-wrapper {
            width: 5rem;
            height: 5rem;
        }
        .wheat-pos-spec-icon {
            width: 2.5rem;
            height: 2.5rem;
        }
        .wheat-pos-spec-card-divider {
            width: 4rem;
        }
        .wheat-pos-spec-compare-arrow {
            transform: rotate(0deg);
        }
        .wheat-flex-row\@md {
            flex-direction: row;
        }
        .wheat-gap-12\@md {
            gap: 3rem;
        }
        .wheat-mb-6\@md {
            margin-bottom: 1.5rem;
        }
        .wheat-mb-16\@md {
            margin-bottom: 4rem;
        }
        .wheat-mb-12\@md {
            margin-bottom: 3rem;
        }
        .wheat-px-6\@md {
            padding-left: 1.5rem;
            padding-right: 1.5rem;
        }
    }
</style>
