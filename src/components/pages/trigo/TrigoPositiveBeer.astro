---
import ShareableQuote from "../../ShareableQuote.astro";
---

<section
    id="positive-beer"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-pos-beer"
>
    <div class="wheat-container wheat-container--narrow wheat-px-6 wheat-grid wheat-grid--cols-2 wheat-items-center wheat-gap-12">
        <div class="wheat-relative wheat-pos-beer-visual wheat-rounded-lg wheat-border wheat-p-8 wheat-flex wheat-items-center wheat-justify-center wheat-overflow-hidden">
            <div class="wheat-absolute wheat-inset-0 wheat-pos-beer-radial-glow"></div>

            <div class="wheat-absolute wheat-inset-0 wheat-overflow-hidden wheat-pos-beer-bubbles">
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--1"></div>
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--2"></div>
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--3"></div>
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--4"></div>
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--5"></div>
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--6"></div>
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--7"></div>
                <div class="wheat-pos-beer-bubble wheat-pos-beer-bubble--8"></div>
            </div>

            <div class="wheat-relative wheat-pos-beer-core wheat-flex wheat-flex-col wheat-items-center wheat-gap-6">
                <div class="wheat-relative">
                    <div class="wheat-absolute wheat-inset-0 wheat-pos-beer-blur-glow wheat-rounded-full"></div>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        class="wheat-pos-beer-icon wheat-relative"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"
                        ></path>
                    </svg>
                </div>
                <div class="wheat-text-center wheat-space-y-2">
                    <div class="wheat-pos-beer-formula wheat-text-5xl wheat-font-bold wheat-tracking-tight">C₂H₅OH</div>
                    <div class="wheat-pos-beer-formula-sub wheat-text-xs wheat-uppercase">Etanol</div>
                </div>
            </div>
        </div>

        <div class="wheat-pos-beer-content wheat-space-y-6">
            <span class="wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase wheat-block trigo-positive-chapter">
                La Fiesta
            </span>
            <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-pos-beer-title">La Alegría Líquida</h2>
            <p class="wheat-text-lg wheat-pos-beer-desc-primary wheat-leading-relaxed">
                Hay una teoría seria que dice que <ShareableQuote
                    quote="no domesticamos el trigo para hacer pan, sino para hacer cerveza."
                />
            </p>
            <p class="wheat-text-base wheat-pos-beer-desc-secondary wheat-leading-relaxed">
                La fermentación nos dio una bebida segura (libre de bacterias) y rica en calorías.
                Pero más importante: nos dio la fiesta, el ritual y la cohesión social. La cerveza
                suavizó las fricciones de vivir juntos en grandes grupos.
            </p>
        </div>
    </div>
</section>

<style>
    .wheat-pos-beer {
        color: #e7e5e4;
        border-bottom: 1px solid rgba(16, 185, 129, 0.1);
    }
    .wheat-pos-beer-visual {
        height: 400px;
        background: linear-gradient(to bottom, rgba(120, 53, 4, 0.1), #0c0a09);
        border-color: rgba(120, 53, 4, 0.3);
    }
    .wheat-pos-beer-radial-glow {
        background: radial-gradient(circle at 50% 120%, rgba(120, 53, 4, 0.2), transparent, transparent);
    }
    .wheat-pos-beer-bubbles {
        opacity: 0.6;
    }
    .wheat-pos-beer-bubble {
        position: absolute;
        background-color: rgba(245, 158, 11, 0.3);
        border-radius: 50%;
        animation: float 3.5s ease-in-out infinite;
    }
    .wheat-pos-beer-bubble--1 {
        bottom: 2rem;
        left: 15%;
        width: 0.75rem;
        height: 0.75rem;
        animation-duration: 3s;
    }
    .wheat-pos-beer-bubble--2 {
        bottom: 3rem;
        left: 25%;
        width: 0.5rem;
        height: 0.5rem;
        animation-duration: 4s;
        animation-delay: 0.5s;
    }
    .wheat-pos-beer-bubble--3 {
        bottom: 1.5rem;
        left: 35%;
        width: 1rem;
        height: 1rem;
        animation-duration: 3.5s;
        animation-delay: 1s;
    }
    .wheat-pos-beer-bubble--4 {
        bottom: 2.5rem;
        left: 45%;
        width: 0.5rem;
        height: 0.5rem;
        animation-duration: 4.5s;
        animation-delay: 1.5s;
    }
    .wheat-pos-beer-bubble--5 {
        bottom: 3.5rem;
        left: 55%;
        width: 0.75rem;
        height: 0.75rem;
        animation-duration: 3.8s;
        animation-delay: 0.8s;
    }
    .wheat-pos-beer-bubble--6 {
        bottom: 2rem;
        left: 65%;
        width: 0.5rem;
        height: 0.5rem;
        animation-duration: 4.2s;
        animation-delay: 1.2s;
    }
    .wheat-pos-beer-bubble--7 {
        bottom: 4rem;
        left: 75%;
        width: 0.75rem;
        height: 0.75rem;
        animation-duration: 3.3s;
        animation-delay: 0.3s;
    }
    .wheat-pos-beer-bubble--8 {
        bottom: 2.5rem;
        left: 85%;
        width: 0.5rem;
        height: 0.5rem;
        animation-duration: 4.8s;
        animation-delay: 1.8s;
    }
    .wheat-pos-beer-core {
        z-index: 10;
    }
    .wheat-pos-beer-blur-glow {
        background-color: rgba(245, 158, 11, 0.2);
        filter: blur(24px);
    }
    .wheat-pos-beer-icon {
        width: 8rem;
        height: 8rem;
        color: rgba(245, 158, 11, 0.6);
    }
    .wheat-pos-beer-formula {
        color: rgba(245, 158, 11, 0.8);
    }
    .wheat-pos-beer-formula-sub {
        color: rgba(245, 158, 11, 0.4);
        letter-spacing: 0.3em;
    }
    .wheat-pos-beer-title {
        color: #e7e5e4;
    }
    .wheat-pos-beer-desc-primary {
        color: #d6d3d1;
    }
    .wheat-pos-beer-desc-secondary {
        color: #a8a29e;
    }
    @keyframes float {
        0%, 100% {
            transform: translateY(0) scale(1);
            opacity: 0;
        }
        10% {
            opacity: 1;
        }
        90% {
            opacity: 0.8;
        }
        100% {
            transform: translateY(-400px) scale(0.5);
            opacity: 0;
        }
    }
    @media (min-width: 768px) {
        .wheat-pos-beer-content {
            order: 2;
        }
        .wheat-pos-beer-visual {
            order: 1;
        }
        .wheat-space-y-6 > * + * {
            margin-top: 1.5rem;
        }
    }
</style>
