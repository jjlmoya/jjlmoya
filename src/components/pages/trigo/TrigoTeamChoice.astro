---
interface Props {
    id?: string;
}

const { id = "dilema-final" } = Astro.props;
---

<section
    id={id}
    class="wheat-relative wheat-font-serif wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-choice"
>
    <div class="wheat-container wheat-container--narrow wheat-text-center wheat-w-full">
        <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-choice-title wheat-mb-12">Elige tu bando</h2>

        <div class="wheat-grid wheat-grid--cols-2 wheat-choice-grid">
            <button
                type="button"
                data-share-btn
                data-share-text="He visto la trampa. El trigo nos domesticó. Elijo la libertad de la sombra. #HistoriaDelTrigo #TeamSombra"
                class="group wheat-relative wheat-overflow-hidden wheat-choice-btn wheat-choice-btn--shadow wheat-p-8 wheat-w-full"
            >
                <div class="wheat-absolute wheat-inset-0 wheat-choice-btn-gradient wheat-choice-btn-gradient--shadow"></div>

                <div class="wheat-relative wheat-flex wheat-flex-col wheat-items-center wheat-gap-4">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="wheat-choice-icon wheat-choice-icon--shadow"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
                        ></path>
                    </svg>
                    <h3 class="wheat-text-2xl wheat-font-bold wheat-choice-btn-title wheat-choice-btn-title--shadow">
                        Team Sombra
                    </h3>
                    <p class="wheat-text-sm wheat-choice-btn-desc">
                        "La agricultura fue una trampa. Prefiero la libertad."
                    </p>
                    <span class="wheat-choice-badge wheat-choice-badge--shadow wheat-text-xs wheat-font-bold wheat-uppercase wheat-tracking-widest">
                        Unirse a la Sombra
                    </span>
                </div>
            </button>

            <button
                type="button"
                data-share-btn
                data-share-text="El coste fue alto, pero la civilización merece la pena. Elijo la luz del progreso. #HistoriaDelTrigo #TeamLuz"
                class="group wheat-relative wheat-overflow-hidden wheat-choice-btn wheat-choice-btn--light wheat-p-8 wheat-w-full"
            >
                <div class="wheat-absolute wheat-inset-0 wheat-choice-btn-gradient wheat-choice-btn-gradient--light"></div>

                <div class="wheat-relative wheat-flex wheat-flex-col wheat-items-center wheat-gap-4">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="wheat-choice-icon wheat-choice-icon--light"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
                        ></path>
                    </svg>
                    <h3 class="wheat-text-2xl wheat-font-bold wheat-choice-btn-title wheat-choice-btn-title--light">
                        Team Luz
                    </h3>
                    <p class="wheat-text-sm wheat-choice-btn-desc">
                        "La civilización merece la pena. Prefiero el progreso."
                    </p>
                    <span class="wheat-choice-badge wheat-choice-badge--light wheat-text-xs wheat-font-bold wheat-uppercase wheat-tracking-widest">
                        Unirse a la Luz
                    </span>
                </div>
            </button>
        </div>
    </div>
</section>

<script>
    import "../../../utils/share";
</script>

<style>
    .wheat-choice {
        color: #e7e5e4;
        background-color: #0c0a09;
        border-top: 1px solid rgba(146, 64, 14, 0.1);
        min-height: 50vh;
    }
    .wheat-choice-title {
        color: #e7e5e4;
    }
    .wheat-choice-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .wheat-choice-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    .wheat-choice-btn {
        background-color: rgba(28, 25, 23, 0.5);
        border: 1px solid #292524;
        border-radius: 0.75rem;
        cursor: pointer;
        transition: all 0.3s;
        text-align: left;
    }
    .wheat-choice-btn:hover {
        background-color: #1c1917;
    }
    .wheat-choice-btn--shadow:hover {
        border-color: rgba(120, 113, 108, 0.5);
    }
    .wheat-choice-btn--light:hover {
        border-color: rgba(245, 158, 11, 0.5);
    }
    .wheat-choice-btn-gradient {
        opacity: 0;
        transition: opacity 0.3s;
    }
    .wheat-choice-btn:hover .wheat-choice-btn-gradient {
        opacity: 1;
    }
    .wheat-choice-btn-gradient--shadow {
        background: linear-gradient(to bottom right, rgba(87, 83, 78, 0.1), transparent);
    }
    .wheat-choice-btn-gradient--light {
        background: linear-gradient(to bottom right, rgba(146, 64, 14, 0.1), transparent);
    }
    .wheat-choice-icon {
        width: 3rem;
        height: 3rem;
        transition: color 0.3s;
    }
    .wheat-choice-icon--shadow {
        color: #a8a29e;
    }
    .wheat-choice-btn--shadow:hover .wheat-choice-icon--shadow {
        color: #e7e5e4;
    }
    .wheat-choice-icon--light {
        color: #f59e0b;
    }
    .wheat-choice-btn--light:hover .wheat-choice-icon--light {
        color: #fbbf24;
    }
    .wheat-choice-btn-title {
        transition: color 0.3s;
    }
    .wheat-choice-btn-title--shadow {
        color: #a8a29e;
    }
    .wheat-choice-btn--shadow:hover .wheat-choice-btn-title--shadow {
        color: #e7e5e4;
    }
    .wheat-choice-btn-title--light {
        color: #f59e0b;
    }
    .wheat-choice-btn--light:hover .wheat-choice-btn-title--light {
        color: #fbbf24;
    }
    .wheat-choice-btn-desc {
        color: #78716c;
        transition: color 0.3s;
    }
    .wheat-choice-btn:hover .wheat-choice-btn-desc {
        color: #a8a29e;
    }
    .wheat-choice-badge {
        margin-top: 1rem;
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        transition: all 0.3s;
    }
    .wheat-choice-badge--shadow {
        background-color: rgba(120, 113, 108, 0.1);
        color: #78716c;
    }
    .wheat-choice-btn--shadow:hover .wheat-choice-badge--shadow {
        background-color: #78716c;
        color: #0c0a09;
    }
    .wheat-choice-badge--light {
        background-color: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
    }
    .wheat-choice-btn--light:hover .wheat-choice-badge--light {
        background-color: #f59e0b;
        color: #0c0a09;
    }
</style>
