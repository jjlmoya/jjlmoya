---
import TrigoSlide from "./TrigoSlide.astro";
import TrigoCharacterSVG from "./TrigoCharacterSVG.astro";
---

<div id="trigo-story" class="wheat-relative wheat-w-full wheat-h-screen wheat-story">
    <div class="wheat-absolute wheat-story-buttons">
        <button
            id="prev-slide"
            class="wheat-story-btn wheat-story-btn--prev"
        >
            ← Anterior
        </button>
        <button
            id="next-slide"
            class="wheat-story-btn wheat-story-btn--next"
        >
            Siguiente →
        </button>
    </div>

    <div class="wheat-absolute wheat-story-progress-container">
        <div id="progress-bar" class="wheat-story-progress-bar"></div>
    </div>

    <TrigoSlide theme="neutral" active={true}>
        <div class="wheat-flex wheat-flex-col wheat-items-center wheat-justify-center wheat-h-full wheat-text-center wheat-space-y-8">
            <h1 class="wheat-text-6xl wheat-text-8xl@md wheat-font-bold wheat-tracking-tighter wheat-story-title">
                TRIGO
            </h1>
            <p class="wheat-text-xl wheat-text-2xl@md wheat-story-desc wheat-max-w-2xl">
                Una conversación eterna entre dos viejos amigos sobre el precio de la civilización.
            </p>
            <div class="wheat-flex wheat-gap-12 wheat-mt-12 wheat-story-intro-characters">
                <div class="wheat-flex wheat-flex-col wheat-items-center wheat-gap-4">
                    <div class="wheat-story-avatar wheat-story-avatar--hunter">
                        <TrigoCharacterSVG role="hunter" />
                    </div>
                    <span class="wheat-text-xs wheat-uppercase wheat-tracking-widest wheat-story-avatar-label">El Cazador</span>
                </div>
                <div class="wheat-flex wheat-flex-col wheat-items-center wheat-gap-4">
                    <div class="wheat-story-avatar wheat-story-avatar--gatherer">
                        <TrigoCharacterSVG role="gatherer" />
                    </div>
                    <span class="wheat-text-xs wheat-uppercase wheat-tracking-widest wheat-story-avatar-label wheat-story-avatar-label--gatherer">El Recolector</span>
                </div>
            </div>
        </div>
    </TrigoSlide>

    <TrigoSlide theme="hunter">
        <div class="wheat-grid wheat-grid--cols-2 wheat-items-center wheat-h-full wheat-story-grid">
            <div class="wheat-story-content-col wheat-space-y-6">
                <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-8">
                    <div class="wheat-story-avatar wheat-story-avatar--small wheat-story-avatar--hunter">
                        <TrigoCharacterSVG role="hunter" />
                    </div>
                    <div class="wheat-story-bubble wheat-story-bubble--hunter">
                        <p class="wheat-text-lg wheat-italic">
                            "¿Recuerdas cómo era antes? Todo esto... era nuestro jardín. Sin vallas.
                            Sin dueños."
                        </p>
                    </div>
                </div>

                <h2 class="wheat-text-4xl wheat-font-bold wheat-story-slide-title">200.000 Años de Libertad</h2>
                <p class="wheat-text-lg wheat-leading-relaxed wheat-story-text">
                    Durante el 99% de nuestra historia, fuimos nómadas. El mundo no nos pertenecía;
                    nosotros pertenecíamos al mundo. Cazábamos, recolectábamos, y seguíamos
                    adelante. La vida era peligrosa, sí, pero era <strong>ligera</strong>.
                </p>
                <div class="wheat-story-fact wheat-story-fact--hunter wheat-p-4">
                    <p class="wheat-text-sm wheat-font-mono">
                        DATO: Un cazador-recolector trabajaba una media de 3-5 horas al día. El
                        resto era ocio y socialización.
                    </p>
                </div>
            </div>
            <div class="wheat-story-visual-col wheat-story-visual-col--hunter">
                <div class="wheat-absolute wheat-inset-0 wheat-story-visual-gradient--hunter"></div>
                <div class="wheat-absolute wheat-story-visual-ground--hunter"></div>
            </div>
        </div>
    </TrigoSlide>

    <TrigoSlide theme="gatherer">
        <div class="wheat-grid wheat-grid--cols-2 wheat-items-center wheat-h-full wheat-story-grid">
            <div class="wheat-story-visual-col wheat-story-visual-col--gatherer">
                <div class="wheat-story-mutation-line">
                    <div class="wheat-absolute wheat-story-mutation-pulse"></div>
                    <div class="wheat-absolute wheat-story-mutation-dot"></div>
                </div>
                <div class="wheat-absolute wheat-story-mutation-label">
                    Mutación Genética
                </div>
            </div>

            <div class="wheat-story-content-col wheat-space-y-6 wheat-text-right">
                <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-8 wheat-justify-end">
                    <div class="wheat-story-bubble wheat-story-bubble--gatherer">
                        <p class="wheat-text-lg wheat-italic">
                            "Era un jardín cruel, amigo mío. Frío. Hambre. Pero esta pequeña
                            espiga... nos ofreció un trato."
                        </p>
                    </div>
                    <div class="wheat-story-avatar wheat-story-avatar--small wheat-story-avatar--gatherer">
                        <TrigoCharacterSVG role="gatherer" />
                    </div>
                </div>

                <h2 class="wheat-text-4xl wheat-font-bold wheat-story-slide-title wheat-story-slide-title--gatherer">El Raquis Duro</h2>
                <p class="wheat-text-lg wheat-leading-relaxed wheat-story-text">
                    Fue un accidente milagroso. Una mutación endureció el tallo del trigo. La
                    semilla ya no caía al suelo; esperaba nuestra mano.
                    <br /><br />
                    No fue una trampa, fue <strong>certeza</strong>. Comida segura para mañana.
                    ¿Quién rechazaría la garantía de vivir un día más?
                </p>
            </div>
        </div>
    </TrigoSlide>

    <TrigoSlide theme="hunter">
        <div class="wheat-grid wheat-grid--cols-2 wheat-items-center wheat-h-full wheat-story-grid">
            <div class="wheat-story-content-col wheat-space-y-6">
                <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-8">
                    <div class="wheat-story-avatar wheat-story-avatar--small wheat-story-avatar--hunter">
                        <TrigoCharacterSVG role="hunter" />
                    </div>
                    <div class="wheat-story-bubble wheat-story-bubble--hunter">
                        <p class="wheat-text-lg wheat-italic">
                            "¿Garantía? Lo llamaste progreso, yo lo llamo esclavitud. Mira tus
                            rodillas. Mira tu espalda."
                        </p>
                    </div>
                </div>

                <h2 class="wheat-text-4xl wheat-font-bold wheat-story-slide-title">La Rutina Agónica</h2>
                <p class="wheat-text-lg wheat-leading-relaxed wheat-story-text">
                    El trigo exigía servicio total. Limpiar, regar, y sobre todo, <strong>moler</strong>. Cambiamos la variedad del bosque por la monotonía de la piedra de moler. Hora tras hora, día tras día.
                </p>
                <div class="wheat-story-fact wheat-story-fact--agony wheat-p-4">
                    <p class="wheat-text-sm wheat-font-mono">
                        PATOLOGÍA: Las mujeres neolíticas tenían deformaciones severas en rodillas y
                        dedos por pasar 6-8 horas diarias moliendo grano.
                    </p>
                </div>
            </div>
            <div class="wheat-story-visual-col wheat-story-visual-col--agony">
                <div class="wheat-story-grinding-stone animate-spin-slow"></div>
            </div>
        </div>
    </TrigoSlide>

    <TrigoSlide theme="gatherer">
        <div class="wheat-grid wheat-grid--cols-2 wheat-items-center wheat-h-full wheat-story-grid">
            <div class="wheat-story-visual-col wheat-story-visual-col--surplus">
                <div class="wheat-story-silo wheat-flex wheat-flex-col wheat-items-center wheat-gap-1">
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--1"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--2"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--3"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--4"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--5"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--6"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--7"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--8"></div>
                    <div class="wheat-story-silo-layer wheat-story-silo-layer--active"></div>
                </div>
            </div>

            <div class="wheat-story-content-col wheat-space-y-6 wheat-text-right">
                <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-8 wheat-justify-end">
                    <div class="wheat-story-bubble wheat-story-bubble--gatherer">
                        <p class="wheat-text-lg wheat-italic">
                            "Mis rodillas duelen, pero mis hijos sobreviven al invierno. El silo
                            está lleno."
                        </p>
                    </div>
                    <div class="wheat-story-avatar wheat-story-avatar--small wheat-story-avatar--gatherer">
                        <TrigoCharacterSVG role="gatherer" />
                    </div>
                </div>

                <h2 class="wheat-text-4xl wheat-font-bold wheat-story-slide-title wheat-story-slide-title--gatherer">El Excedente</h2>
                <p class="wheat-text-lg wheat-leading-relaxed wheat-story-text">
                    El trigo se puede almacenar. Eso lo cambia todo.
                    <br />
                    El excedente nos permitió planificar. Construir muros. Crear leyes. Inventar la escritura
                    para contar el grano.
                    <br /><br />
                    <span class="wheat-story-highlight">La civilización es hija del granero.</span>
                </p>
            </div>
        </div>
    </TrigoSlide>

    <TrigoSlide theme="hunter">
        <div class="wheat-grid wheat-grid--cols-2 wheat-items-center wheat-h-full wheat-story-grid">
            <div class="wheat-story-content-col wheat-space-y-6">
                <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-8">
                    <div class="wheat-story-avatar wheat-story-avatar--small wheat-story-avatar--hunter">
                        <TrigoCharacterSVG role="hunter" />
                    </div>
                    <div class="wheat-story-bubble wheat-story-bubble--hunter">
                        <p class="wheat-text-lg wheat-italic">
                            "¿Civilización? Nos hicimos pequeños, débiles y enfermos. Cambiamos
                            calidad por cantidad."
                        </p>
                    </div>
                </div>

                <h2 class="wheat-text-4xl wheat-font-bold wheat-story-slide-title">Cuerpos Rotos</h2>
                <p class="wheat-text-lg wheat-leading-relaxed wheat-story-text">
                    La dieta del trigo fue un desastre bio-lógico. Perdimos 15cm de altura. Nuestros
                    dientes se llenaron de caries. Las epidemias arrasaron nuestras ciudades
                    hacinadas.
                </p>
                <div class="wheat-grid wheat-grid--cols-2 wheat-gap-4 wheat-mt-4">
                    <div class="wheat-story-stat-card">
                        <h4 class="wheat-story-stat-card-label">Cazador</h4>
                        <p class="wheat-text-2xl wheat-font-bold wheat-story-stat-card-val">176 cm</p>
                        <p class="wheat-text-xs wheat-story-stat-card-sub">Sin caries</p>
                    </div>
                    <div class="wheat-story-stat-card wheat-story-stat-card--farmer">
                        <h4 class="wheat-story-stat-card-label wheat-story-stat-card-label--farmer">Agricultor</h4>
                        <p class="wheat-text-2xl wheat-font-bold wheat-story-stat-card-val wheat-story-stat-card-val--farmer">161 cm</p>
                        <p class="wheat-text-xs wheat-story-stat-card-sub wheat-story-stat-card-sub--farmer">Anemia crónica</p>
                    </div>
                </div>
            </div>
            <div class="wheat-story-visual-col wheat-story-visual-col--compare">
                <div class="wheat-flex wheat-items-end wheat-gap-8 wheat-h-full wheat-story-compare-container">
                    <div class="wheat-story-compare-bar wheat-story-compare-bar--hunter">
                        <div class="wheat-story-compare-label">Cazador</div>
                    </div>
                    <div class="wheat-story-compare-bar wheat-story-compare-bar--farmer">
                        <div class="wheat-story-compare-label wheat-story-compare-label--farmer">Agricultor</div>
                        <div class="wheat-story-compare-pulse"></div>
                    </div>
                </div>
            </div>
        </div>
    </TrigoSlide>

    <TrigoSlide theme="gatherer">
        <div class="wheat-grid wheat-grid--cols-2 wheat-items-center wheat-h-full wheat-story-grid">
            <div class="wheat-story-visual-col wheat-story-visual-col--chart">
                <svg class="wheat-w-full wheat-h-full wheat-story-svg-chart" preserveAspectRatio="none">
                    <path
                        d="M0,200 L100,198 L200,195 L300,190 C350,180 400,50 450,0"
                        fill="none"
                        stroke="#f59e0b"
                        stroke-width="4"></path>
                </svg>
            </div>

            <div class="wheat-story-content-col wheat-space-y-6 wheat-text-right">
                <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-8 wheat-justify-end">
                    <div class="wheat-story-bubble wheat-story-bubble--gatherer">
                        <p class="wheat-text-lg wheat-italic">
                            "Quizás somos más débiles solos... pero juntos somos imparables. Ganamos
                            la guerra de la vida."
                        </p>
                    </div>
                    <div class="wheat-story-avatar wheat-story-avatar--small wheat-story-avatar--gatherer">
                        <TrigoCharacterSVG role="gatherer" />
                    </div>
                </div>

                <h2 class="wheat-text-4xl wheat-font-bold wheat-story-slide-title wheat-story-slide-title--gatherer">El Éxito de la Especie</h2>
                <p class="wheat-text-lg wheat-leading-relaxed wheat-story-text">
                    La evolución no mide la felicidad individual. Mide copias de ADN.
                    <br />
                    El trigo nos permitió multiplicar nuestra población por mil. Llenamos la Tierra.
                    Construimos imperios.
                    <br /><br />
                    Mantuvimos a más gente con vida, aunque fuera en peores condiciones. <strong class="wheat-story-highlight">Esa es la victoria del trigo.</strong>
                </p>
            </div>
        </div>
    </TrigoSlide>

    <TrigoSlide theme="neutral">
        <div class="wheat-flex wheat-flex-col wheat-items-center wheat-justify-center wheat-h-full wheat-text-center wheat-space-y-12 wheat-max-w-4xl wheat-mx-auto">
            <h2 class="wheat-text-4xl wheat-text-6xl@md wheat-font-bold wheat-story-end-title">¿Quién domesticó a quién?</h2>

            <div class="wheat-grid wheat-grid--cols-2 wheat-w-full">
                <div class="wheat-flex wheat-flex-col wheat-items-center wheat-gap-4 wheat-story-choice-card">
                    <div class="wheat-story-avatar wheat-story-avatar--large wheat-story-avatar--hunter">
                        <TrigoCharacterSVG role="hunter" />
                    </div>
                    <p class="wheat-story-choice-text">"Perdimos el paraíso."</p>
                </div>
                <div class="wheat-flex wheat-flex-col wheat-items-center wheat-gap-4 wheat-story-choice-card wheat-story-choice-card--gatherer">
                    <div class="wheat-story-avatar wheat-story-avatar--large wheat-story-avatar--gatherer">
                        <TrigoCharacterSVG role="gatherer" />
                    </div>
                    <p class="wheat-story-choice-text wheat-story-choice-text--gatherer">"Ganamos el futuro."</p>
                </div>
            </div>

            <div class="wheat-mt-12 wheat-p-8 wheat-story-footer">
                <p class="wheat-text-sm wheat-font-mono">
                    DOCUMENTACIÓN Y REFERENCIAS<br />
                    Yuval Noah Harari - Sapiens<br />
                    James C. Scott - Against the Grain<br />
                    Cohen & Armelagos - Paleopathology at the Origins of Agriculture
                </p>
            </div>
        </div>
    </TrigoSlide>
</div>

<script>
    const slides = document.querySelectorAll("#trigo-story .wheat-slide");
    const prevBtn = document.getElementById("prev-slide");
    const nextBtn = document.getElementById("next-slide");
    const progressBar = document.getElementById("progress-bar");
    let currentSlide = 0;
    const totalSlides = slides.length;

    function updateSlides() {
        slides.forEach((slide, index) => {
            if (index === currentSlide) {
                slide.classList.add("active");
            } else {
                slide.classList.remove("active");
            }
        });

        if (progressBar) {
            const progress = ((currentSlide + 1) / totalSlides) * 100;
            progressBar.style.width = `${progress}%`;
        }

        if (prevBtn) (prevBtn as HTMLButtonElement).disabled = currentSlide === 0;
        if (nextBtn) {
            if (currentSlide === totalSlides - 1) {
                nextBtn.innerText = "Reiniciar";
            } else {
                nextBtn.innerText = "Siguiente →";
            }
        }
    }

    prevBtn?.addEventListener("click", () => {
        if (currentSlide > 0) {
            currentSlide--;
            updateSlides();
        }
    });

    nextBtn?.addEventListener("click", () => {
        if (currentSlide < totalSlides - 1) {
            currentSlide++;
        } else {
            currentSlide = 0;
        }
        updateSlides();
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight" || e.key === "Space") {
            if (currentSlide < totalSlides - 1) {
                currentSlide++;
                updateSlides();
            }
        } else if (e.key === "ArrowLeft") {
            if (currentSlide > 0) {
                currentSlide--;
                updateSlides();
            }
        }
    });

    updateSlides();
</script>

<style>
    .wheat-story {
        background-color: #000000;
    }
    .wheat-story-buttons {
        bottom: 2rem;
        right: 2rem;
        z-index: 50;
        display: flex;
        gap: 1rem;
    }
    .wheat-story-btn {
        padding: 0.75rem 1.5rem;
        border-radius: 9999px;
        color: #ffffff;
        cursor: pointer;
        font-family: sans-serif;
        border: none;
        background-color: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
        transition: background-color 0.2s;
    }
    .wheat-story-btn:hover {
        background-color: rgba(255, 255, 255, 0.2);
    }
    .wheat-story-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }
    .wheat-story-btn--next {
        font-weight: bold;
        background-color: rgba(255, 255, 255, 0.2);
    }
    .wheat-story-btn--next:hover {
        background-color: rgba(255, 255, 255, 0.3);
    }
    .wheat-story-progress-container {
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background-color: rgba(255, 255, 255, 0.1);
        z-index: 50;
    }
    .wheat-story-progress-bar {
        height: 100%;
        background-color: #f59e0b;
        transition: width 0.5s;
        width: 0;
    }
    .wheat-story-title {
        color: #f59e0b;
    }
    .wheat-story-desc {
        color: #a8a29e;
    }
    .wheat-story-intro-characters {
        opacity: 0.8;
    }
    .wheat-story-avatar {
        width: 6rem;
        height: 6rem;
        border-radius: 50%;
        background-color: #292524;
        border: 2px solid #57534e;
        overflow: hidden;
        box-sizing: border-box;
    }
    .wheat-story-avatar--gatherer {
        border-color: #78350f;
    }
    .wheat-story-avatar-label {
        color: #78716c;
    }
    .wheat-story-avatar-label--gatherer {
        color: #b45309;
    }
    .wheat-story-avatar--small {
        width: 5rem;
        height: 5rem;
        flex-shrink: 0;
    }
    .wheat-story-avatar--large {
        width: 8rem;
        height: 8rem;
        border-width: 4px;
    }
    .wheat-story-avatar--hunter {
        border-color: #57534e;
    }
    .wheat-story-bubble {
        padding: 1rem;
        border-radius: 0 0.75rem 0.75rem 0.75rem;
        border: 1px solid;
    }
    .wheat-story-bubble--hunter {
        background-color: #292524;
        border-color: #44403c;
    }
    .wheat-story-bubble--hunter p {
        color: #d6d3d1;
    }
    .wheat-story-bubble--gatherer {
        border-radius: 0.75rem 0 0.75rem 0.75rem;
        background-color: rgba(120, 53, 4, 0.3);
        border-color: rgba(120, 53, 4, 0.5);
    }
    .wheat-story-bubble--gatherer p {
        color: #fde68a;
    }
    .wheat-story-slide-title {
        color: #e7e5e4;
    }
    .wheat-story-slide-title--gatherer {
        color: #fde68a;
    }
    .wheat-story-text {
        color: #a8a29e;
    }
    .wheat-story-fact {
        border-left: 4px solid;
    }
    .wheat-story-fact--hunter {
        border-color: #57534e;
        background-color: rgba(41, 37, 36, 0.5);
    }
    .wheat-story-fact--hunter p {
        color: #78716c;
    }
    .wheat-story-fact--agony {
        border-color: #7f1d1d;
        background-color: rgba(127, 29, 29, 0.1);
    }
    .wheat-story-fact--agony p {
        color: #fca5a5;
    }
    .wheat-story-visual-col {
        border-radius: 0.5rem;
        overflow: hidden;
        position: relative;
        box-sizing: border-box;
    }
    .wheat-story-visual-col--hunter {
        height: 16rem;
        background-color: #1c1917;
        border: 1px solid #292524;
    }
    .wheat-story-visual-gradient--hunter {
        background: linear-gradient(to bottom, #292524, #000000);
    }
    .wheat-story-visual-ground--hunter {
        bottom: 0;
        width: 100%;
        height: 33.333333%;
        background-color: #0c0a09;
        border-top-left-radius: 50%;
        border-top-right-radius: 50%;
        transform: scale(1.5);
    }
    .wheat-story-visual-col--gatherer {
        height: 16rem;
        background-color: #1c1917;
        border: 1px solid rgba(120, 53, 4, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .wheat-story-mutation-line {
        position: relative;
        width: 8px;
        height: 16rem;
        background-color: #57534e;
        border-radius: 9999px;
    }
    .wheat-story-mutation-pulse {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 2rem;
        height: 2rem;
        background-color: #f59e0b;
        border-radius: 50%;
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        filter: blur(4px);
    }
    .wheat-story-mutation-dot {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 8px;
        height: 8px;
        background-color: #ffffff;
        border-radius: 50%;
    }
    .wheat-story-mutation-label {
        position: absolute;
        bottom: 1rem;
        color: rgba(245, 158, 11, 0.5);
        font-size: 12px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
    }
    .wheat-story-visual-col--agony {
        height: 16rem;
        background-color: #1c1917;
        border: 1px solid #292524;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .wheat-story-grinding-stone {
        width: 8rem;
        height: 8rem;
