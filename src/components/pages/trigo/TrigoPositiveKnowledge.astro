---

---

<section
    id="positive-knowledge"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-pos-knowledge"
>
    <div class="wheat-container wheat-container--narrow wheat-px-6 wheat-grid wheat-grid--cols-2 wheat-items-center wheat-gap-12">
        <div class="wheat-pos-knowledge-content wheat-space-y-6">
            <span class="wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase wheat-block trigo-positive-chapter">
                La Ciencia
            </span>
            <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-pos-knowledge-title">La Ciencia del Tiempo</h2>
            <p class="wheat-text-lg wheat-pos-knowledge-desc-primary wheat-leading-relaxed">
                El cazador vive en el presente eterno. El agricultor necesita predecir el futuro.
            </p>
            <p class="wheat-text-base wheat-pos-knowledge-desc-secondary wheat-leading-relaxed">
                Para saber cuándo sembrar, tuvimos que entender los ciclos del sol y la luna.
                Inventamos la astronomía, las matemáticas y la geometría para medir los campos. El
                trigo fue el padre de la ciencia abstracta.
            </p>
        </div>

        <div class="wheat-relative wheat-pos-knowledge-visual wheat-rounded-lg wheat-border wheat-flex wheat-items-center wheat-justify-center">
            <div class="wheat-pos-knowledge-circle">
                <div class="wheat-pos-knowledge-marker wheat-absolute"></div>
                <div class="wheat-pos-knowledge-circle-inner-1 wheat-absolute"></div>
                <div class="wheat-pos-knowledge-circle-inner-2 wheat-absolute"></div>
                <div class="wheat-absolute wheat-inset-0 wheat-flex wheat-items-center wheat-justify-center">
                    <div class="wheat-pos-knowledge-core-dot"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-pos-knowledge {
        color: #e7e5e4;
        border-bottom: 1px solid rgba(16, 185, 129, 0.1);
    }
    .wheat-pos-knowledge-title {
        color: #e7e5e4;
    }
    .wheat-pos-knowledge-desc-primary {
        color: #d6d3d1;
    }
    .wheat-pos-knowledge-desc-secondary {
        color: #a8a29e;
    }
    .wheat-pos-knowledge-visual {
        height: 400px;
        background-color: #0c0a09;
        border-color: rgba(16, 185, 129, 0.2);
    }
    .wheat-pos-knowledge-circle {
        width: 16rem;
        height: 16rem;
        border-radius: 50%;
        border: 1px solid rgba(16, 185, 129, 0.2);
        position: relative;
        animation: spin 20s linear infinite;
    }
    .wheat-pos-knowledge-marker {
        top: 0;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 1rem;
        height: 1rem;
        background-color: #10b981;
        border-radius: 50%;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.5);
    }
    .wheat-pos-knowledge-circle-inner-1 {
        inset: 1rem;
        border-radius: 50%;
        border: 1px solid rgba(16, 185, 129, 0.1);
    }
    .wheat-pos-knowledge-circle-inner-2 {
        inset: 3rem;
        border-radius: 50%;
        border: 1px solid rgba(16, 185, 129, 0.1);
    }
    .wheat-pos-knowledge-core-dot {
        width: 0.5rem;
        height: 0.5rem;
        background-color: #064e3b;
        border-radius: 50%;
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    @media (min-width: 768px) {
        .wheat-space-y-6 > * + * {
            margin-top: 1.5rem;
        }
    }
</style>
