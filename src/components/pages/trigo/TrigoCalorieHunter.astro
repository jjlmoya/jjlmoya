---

---

<section
    id="calorias-cazador"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-calorie-hunter"
>
    <div class="wheat-container wheat-container--narrow">
        <div class="wheat-text-center wheat-mb-16">
            <span class="trigo-chapter wheat-calorie-chapter wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase wheat-block wheat-mb-4">
                La Trampa Energética
            </span>
            <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-mb-6 wheat-calorie-title">Calorías vs. Libertad</h2>
            <p class="wheat-calorie-desc wheat-max-w-2xl wheat-mx-auto">
                El cazador trabajaba menos y comía mejor. El agricultor trabajaba más y comía peor.
                ¿Por qué cambiamos?
            </p>
        </div>

        <div class="wheat-calorie-card wheat-p-8 wheat-rounded-lg wheat-mx-auto">
            <div class="wheat-space-y-4">
                <h3 class="wheat-text-xl wheat-font-bold wheat-calorie-card-title">
                    La Libertad del Cazador
                </h3>
                <div class="wheat-space-y-6">
                    <div>
                        <div class="wheat-flex wheat-justify-between wheat-text-sm wheat-mb-1">
                            <span class="wheat-calorie-label">Horas de trabajo/día</span>
                            <span class="wheat-font-bold wheat-calorie-val">4 horas</span>
                        </div>
                        <div class="wheat-w-full wheat-calorie-bar-bg wheat-rounded-full">
                            <div class="wheat-calorie-bar-fill wheat-calorie-bar-fill--hunter-work"></div>
                        </div>
                    </div>
                    <div>
                        <div class="wheat-flex wheat-justify-between wheat-text-sm wheat-mb-1">
                            <span class="wheat-calorie-label">Calidad Nutricional</span>
                            <span class="wheat-font-bold wheat-calorie-val">Alta (Variada)</span>
                        </div>
                        <div class="wheat-w-full wheat-calorie-bar-bg wheat-rounded-full">
                            <div class="wheat-calorie-bar-fill wheat-calorie-bar-fill--hunter-nut"></div>
                        </div>
                    </div>
                    <div>
                        <div class="wheat-flex wheat-justify-between wheat-text-sm wheat-mb-1">
                            <span class="wheat-calorie-label">Densidad Poblacional</span>
                            <span class="wheat-font-bold wheat-calorie-val">Baja (0.1/km²)</span>
                        </div>
                        <div class="wheat-w-full wheat-calorie-bar-bg wheat-rounded-full">
                            <div class="wheat-calorie-bar-fill wheat-calorie-bar-fill--hunter-pop"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-calorie-hunter {
        color: #e7e5e4;
        border-top: 1px solid rgba(120, 53, 4, 0.1);
    }
    .wheat-calorie-chapter {
        color: rgba(217, 119, 6, 0.6);
    }
    .wheat-calorie-title {
        color: #e7e5e4;
    }
    .wheat-calorie-desc {
        color: #a8a29e;
    }
    .wheat-calorie-card {
        background-color: #0c0a09;
        border: 1px solid rgba(120, 53, 4, 0.1);
        max-width: 42rem;
    }
    .wheat-calorie-card-title {
        color: rgba(34, 197, 94, 0.8);
    }
    .wheat-calorie-label {
        color: #a8a29e;
    }
    .wheat-calorie-val {
        color: #e7e5e4;
    }
    .wheat-calorie-bar-bg {
        background-color: #292524;
        height: 0.5rem;
        overflow: hidden;
    }
    .wheat-calorie-bar-fill {
        background-color: rgba(34, 197, 94, 0.5);
        height: 100%;
    }
    .wheat-calorie-bar-fill--hunter-work {
        width: 30%;
    }
    .wheat-calorie-bar-fill--hunter-nut {
        width: 90%;
    }
    .wheat-calorie-bar-fill--hunter-pop {
        width: 5%;
    }
    @media (min-width: 768px) {
        .wheat-space-y-6 > * + * {
            margin-top: 1.5rem;
        }
    }
</style>
