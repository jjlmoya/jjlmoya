---

---

<section
    id="intro"
    class="wheat-h-screen wheat-flex wheat-flex-col wheat-items-center wheat-justify-center wheat-relative wheat-overflow-hidden wheat-px-4 wheat-header"
>
    <div class="wheat-absolute wheat-inset-0 wheat-opacity-10 wheat-pointer-events-none wheat-header-overlay"></div>

    <div class="wheat-absolute wheat-header-glow"></div>

    <div class="wheat-absolute wheat-header-arrow-top wheat-flex wheat-flex-col wheat-items-center wheat-gap-3">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="wheat-header-arrow-icon"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18"></path>
        </svg>
        <span class="wheat-text-xs wheat-text-sm@md wheat-uppercase wheat-tracking-widest wheat-font-bold">La Luz</span>
    </div>

    <h1 class="wheat-text-5xl wheat-text-8xl@md wheat-font-serif wheat-font-bold wheat-tracking-tighter wheat-mb-4 wheat-text-center wheat-header-title">
        La Historia del Trigo
    </h1>
    <p class="wheat-text-sm wheat-text-2xl@md wheat-font-light wheat-tracking-widest wheat-uppercase wheat-text-center wheat-header-subtitle">
        Detalles: Luces y Sombras
    </p>

    <div class="wheat-absolute wheat-header-arrow-bottom wheat-flex wheat-flex-col wheat-items-center wheat-gap-3">
        <span class="wheat-text-xs wheat-text-sm@md wheat-uppercase wheat-tracking-widest wheat-font-bold">La Sombra</span>
        <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="wheat-header-arrow-icon"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path>
        </svg>
    </div>
</section>

<style>
    .wheat-header {
        color: #e7e5e4;
    }
    .wheat-header-overlay {
        mix-blend-overlay;
    }
    .wheat-header-glow {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 500px;
        height: 500px;
        background-color: rgba(120, 53, 4, 0.2);
        filter: blur(120px);
        border-radius: 50%;
        pointer-events: none;
    }
    .wheat-header-arrow-top {
        top: 5rem;
        animation: bounce 2s infinite;
        color: #10b981;
    }
    .wheat-header-arrow-bottom {
        bottom: 5rem;
        animation: bounce 2s infinite;
        color: #f59e0b;
    }
    .wheat-header-arrow-icon {
        width: 2.5rem;
        height: 2.5rem;
    }
    @media (min-width: 768px) {
        .wheat-header-arrow-top {
            top: 6rem;
        }
        .wheat-header-arrow-bottom {
            bottom: 6rem;
        }
        .wheat-header-arrow-icon {
            width: 3rem;
            height: 3rem;
        }
    }
    .wheat-header-title {
        z-index: 10;
        line-height: 1.1;
        color: #f59e0b;
    }
    .wheat-header-subtitle {
        color: #a8a29e;
        z-index: 10;
    }
    @keyframes bounce {
        0%, 100% {
            transform: translate(-50%, 0);
        }
        50% {
            transform: translate(-50%, -10px);
        }
    }
    .wheat-header-arrow-top, .wheat-header-arrow-bottom {
        left: 50%;
        transform: translateX(-50%);
    }
</style>
