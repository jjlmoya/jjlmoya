---

---

<section
    id="positive-expansion"
    class="wheat-relative wheat-font-serif wheat-min-h-screen wheat-flex wheat-items-center wheat-justify-center wheat-py-12 wheat-py-24@md wheat-pos-expansion"
>
    <div class="wheat-container wheat-px-6">
        <div class="wheat-text-center wheat-mb-12">
            <span class="wheat-text-xs wheat-text-sm@md wheat-tracking-widest wheat-uppercase wheat-block wheat-mb-4 trigo-positive-chapter">
                La Expansión
            </span>
            <h2 class="wheat-text-3xl wheat-text-5xl@md wheat-font-bold wheat-pos-expansion-title wheat-mb-6">La Especie Imparable</h2>
            <p class="wheat-text-lg wheat-pos-expansion-desc wheat-max-w-3xl wheat-mx-auto">
                Gracias a la densidad calórica del trigo, pudimos habitar lugares donde la caza era
                escasa. Conquistamos desiertos, montañas y tundras.
            </p>
        </div>

        <div class="wheat-pos-expansion-grid wheat-mb-12">
            <div class="wheat-relative wheat-pos-expansion-visual-col">
                <div class="wheat-absolute wheat-inset-0 wheat-pos-expansion-radial-glow"></div>

                <div class="wheat-relative wheat-pos-expansion-svg-wrapper">
                    <svg viewBox="0 0 400 300" class="wheat-pos-expansion-svg">
                        <defs>
                            <linearGradient
                                id="populationGradient"
                                x1="0%"
                                y1="0%"
                                x2="0%"
                                y2="100%"
                            >
                                <stop offset="0%" style="stop-color:#10b981;stop-opacity:0.8"></stop>
                                <stop offset="100%" style="stop-color:#059669;stop-opacity:0.3"></stop>
                            </linearGradient>
                        </defs>

                        <line
                            x1="50"
                            y1="250"
                            x2="350"
                            y2="250"
                            stroke="#78716c"
                            stroke-width="1"
                            opacity="0.3"
                        ></line>
                        <line
                            x1="50"
                            y1="200"
                            x2="350"
                            y2="200"
                            stroke="#78716c"
                            stroke-width="1"
                            opacity="0.2"
                        ></line>
                        <line
                            x1="50"
                            y1="150"
                            x2="350"
                            y2="150"
                            stroke="#78716c"
                            stroke-width="1"
                            opacity="0.2"
                        ></line>
                        <line
                            x1="50"
                            y1="100"
                            x2="350"
                            y2="100"
                            stroke="#78716c"
                            stroke-width="1"
                            opacity="0.2"
                        ></line>
                        <line
                            x1="50"
                            y1="50"
                            x2="350"
                            y2="50"
                            stroke="#78716c"
                            stroke-width="1"
                            opacity="0.2"
                        ></line>

                        <line x1="50" y1="30" x2="50" y2="250" stroke="#a8a29e" stroke-width="2"></line>

                        <line x1="50" y1="250" x2="350" y2="250" stroke="#a8a29e" stroke-width="2"></line>

                        <path
                            d="M 50 240 Q 100 235, 150 220 T 250 150 T 350 50"
                            fill="none"
                            stroke="url(#populationGradient)"
                            stroke-width="3"
                        >
                            <animate
                                attributeName="stroke-dasharray"
                                from="0,1000"
                                to="1000,0"
                                dur="2s"
                                fill="freeze"
                            ></animate>
                        </path>

                        <path
                            d="M 50 240 Q 100 235, 150 220 T 250 150 T 350 50 L 350 250 L 50 250 Z"
                            fill="url(#populationGradient)"
                            opacity="0.2"
                        ></path>

                        <circle cx="50" cy="240" r="4" fill="#10b981">
                            <animate
                                attributeName="r"
                                values="4;6;4"
                                dur="2s"
                                repeatCount="indefinite"
                            ></animate>
                        </circle>
                        <circle cx="150" cy="220" r="4" fill="#10b981">
                            <animate
                                attributeName="r"
                                values="4;6;4"
                                dur="2s"
                                begin="0.5s"
                                repeatCount="indefinite"
                            ></animate>
                        </circle>
                        <circle cx="250" cy="150" r="4" fill="#10b981">
                            <animate
                                attributeName="r"
                                values="4;6;4"
                                dur="2s"
                                begin="1s"
                                repeatCount="indefinite"
                            ></animate>
                        </circle>
                        <circle cx="350" cy="50" r="4" fill="#10b981">
                            <animate
                                attributeName="r"
                                values="4;6;4"
                                dur="2s"
                                begin="1.5s"
                                repeatCount="indefinite"
                            ></animate>
                        </circle>

                        <text x="50" y="270" text-anchor="middle" fill="#a8a29e" font-size="10">10,000 a.C.</text>
                        <text x="150" y="270" text-anchor="middle" fill="#a8a29e" font-size="10">8,000 a.C.</text>
                        <text x="250" y="270" text-anchor="middle" fill="#a8a29e" font-size="10">5,000 a.C.</text>
                        <text x="350" y="270" text-anchor="middle" fill="#a8a29e" font-size="10">3,000 a.C.</text>

                        <text x="30" y="255" text-anchor="end" fill="#a8a29e" font-size="10">1M</text>
                        <text x="30" y="155" text-anchor="end" fill="#a8a29e" font-size="10">5M</text>
                        <text x="30" y="55" text-anchor="end" fill="#a8a29e" font-size="10">50M</text>

                        <text
                            x="200"
                            y="20"
                            text-anchor="middle"
                            fill="#10b981"
                            font-size="12"
                            font-weight="bold"
                        >Crecimiento Poblacional</text>
                    </svg>
                </div>
            </div>

            <div class="wheat-pos-expansion-cards wheat-space-y-6">
                <div class="wheat-pos-expansion-card wheat-p-6 wheat-rounded-lg wheat-border">
                    <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-4">
                        <div class="wheat-pos-expansion-card-icon-wrapper wheat-rounded-full">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="wheat-pos-expansion-card-icon"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <div class="wheat-pos-expansion-card-val wheat-text-2xl wheat-font-bold">7 Continentes</div>
                            <div class="wheat-pos-expansion-card-label wheat-text-xs wheat-uppercase wheat-tracking-wider">
                                Habitados
                            </div>
                        </div>
                    </div>
                    <p class="wheat-pos-expansion-card-text wheat-text-sm">
                        El trigo permitió asentamientos permanentes en todos los climas habitables
                        del planeta.
                    </p>
                </div>

                <div class="wheat-pos-expansion-card wheat-p-6 wheat-rounded-lg wheat-border">
                    <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-4">
                        <div class="wheat-pos-expansion-card-icon-wrapper wheat-rounded-full">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="wheat-pos-expansion-card-icon"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <div class="wheat-pos-expansion-card-val wheat-text-2xl wheat-font-bold">×50</div>
                            <div class="wheat-pos-expansion-card-label wheat-text-xs wheat-uppercase wheat-tracking-wider">
                                Crecimiento
                            </div>
                        </div>
                    </div>
                    <p class="wheat-pos-expansion-card-text wheat-text-sm">
                        La población humana se multiplicó por 50 en los primeros 7,000 años de
                        agricultura.
                    </p>
                </div>

                <div class="wheat-pos-expansion-card wheat-p-6 wheat-rounded-lg wheat-border">
                    <div class="wheat-flex wheat-items-center wheat-gap-4 wheat-mb-4">
                        <div class="wheat-pos-expansion-card-icon-wrapper wheat-rounded-full">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="wheat-pos-expansion-card-icon"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <div class="wheat-pos-expansion-card-val wheat-text-2xl wheat-font-bold">∞</div>
                            <div class="wheat-pos-expansion-card-label wheat-text-xs wheat-uppercase wheat-tracking-wider">
                                Potencial
                            </div>
                        </div>
                    </div>
                    <p class="wheat-pos-expansion-card-text wheat-text-sm">
                        Sin límites geográficos, la humanidad se convirtió en una especie
                        verdaderamente global.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .wheat-pos-expansion {
        color: #e7e5e4;
        border-bottom: 1px solid rgba(16, 185, 129, 0.1);
    }
    .wheat-pos-expansion-title {
        color: #e7e5e4;
    }
    .wheat-pos-expansion-desc {
        color: #a8a29e;
    }
    .wheat-pos-expansion-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: 2rem;
    }
    .wheat-pos-expansion-visual-col {
        height: 400px;
    }
    .wheat-pos-expansion-radial-glow {
        background: radial-gradient(circle at center, rgba(16, 185, 129, 0.1), transparent, transparent);
    }
    .wheat-pos-expansion-svg-wrapper {
        height: 100%;
    }
    .wheat-pos-expansion-svg {
        width: 100%;
        height: 100%;
    }
    .wheat-pos-expansion-card {
        background: linear-gradient(to bottom right, #1c1917, #0c0a09);
        border-color: rgba(16, 185, 129, 0.2);
    }
    .wheat-pos-expansion-card-icon-wrapper {
        width: 3rem;
        height: 3rem;
        background-color: rgba(16, 185, 129, 0.1);
        flex-shrink: 0;
    }
    .wheat-pos-expansion-card-icon {
        width: 1.5rem;
        height: 1.5rem;
        color: #10b981;
    }
    .wheat-pos-expansion-card-val {
        color: #10b981;
    }
    .wheat-pos-expansion-card-label {
        color: #a8a29e;
    }
    .wheat-pos-expansion-card-text {
        color: #a8a29e;
    }
    @media (min-width: 768px) {
        .wheat-pos-expansion-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .wheat-space-y-6 > * + * {
            margin-top: 1.5rem;
        }
    }
</style>
