---
interface Props {
    theme: "hunter" | "gatherer" | "neutral";
    active?: boolean;
}

const { theme, active = false } = Astro.props;
---

<div
    class:list={[
        "wheat-absolute wheat-inset-0 wheat-w-full wheat-h-full wheat-flex wheat-flex-col wheat-overflow-hidden wheat-slide",
        theme,
        active ? "active" : ""
    ]}
>
    {
        theme === "hunter" && (
            <div class="wheat-absolute wheat-inset-0 wheat-opacity-5 wheat-pointer-events-none">
                <svg width="100%" height="100%">
                    <filter id="noise">
                        <feTurbulence
                            type="fractalNoise"
                            baseFrequency="0.8"
                            numOctaves="3"
                            stitchTiles="stitch"
                        />
                    </filter>
                    <rect width="100%" height="100%" filter="url(#noise)" />
                </svg>
            </div>
        )
    }

    {
        theme === "gatherer" && (
            <div class="wheat-absolute wheat-inset-0 wheat-opacity-5 wheat-pointer-events-none wheat-slide-gatherer-pattern" />
        )
    }

    <div class="wheat-relative wheat-w-full wheat-h-full wheat-flex wheat-flex-col wheat-p-6 wheat-p-12@md wheat-slide-container wheat-mx-auto">
        <slot />
    </div>
</div>

<style>
    .wheat-slide {
        transition: opacity 0.5s;
        opacity: 0;
        z-index: 0;
        pointer-events: none;
    }
    .wheat-slide.active {
        opacity: 1;
        z-index: 10;
        pointer-events: auto;
    }
    .wheat-slide.hunter {
        background-color: #1c1917;
        color: #d6d3d1;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        border-color: #292524;
    }
    .wheat-slide.gatherer {
        background-color: #0c0a09;
        color: #e7e5e4;
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        border-color: rgba(146, 64, 14, 0.3);
    }
    .wheat-slide.neutral {
        background-color: #000000;
        color: #ffffff;
    }
    .wheat-slide-gatherer-pattern {
        background-image: radial-gradient(#f59e0b 1px, transparent 1px);
        background-size: 40px 40px;
    }
    .wheat-slide-container {
        z-index: 10;
        max-width: 80rem;
        box-sizing: border-box;
    }
    @media (min-width: 768px) {
        .wheat-p-12\@md {
            padding: 3rem;
        }
    }
</style>
