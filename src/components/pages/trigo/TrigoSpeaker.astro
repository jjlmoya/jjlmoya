---
import TrigoCharacterSVG from "./TrigoCharacterSVG.astro";

interface Props {
    role: "hunter" | "gatherer";
    title: string;
}

const { role, title } = Astro.props;

const isHunter = role === "hunter";
const label = isHunter ? "EL CAZADOR" : "EL RECOLECTOR";
---

<div class:list={["wheat-flex wheat-flex-col wheat-mb-8 wheat-mb-12@md wheat-speaker", role]}>
    <div class="wheat-flex wheat-items-end wheat-gap-4 wheat-mb-4 wheat-speaker-header">
        <div class="wheat-relative wheat-speaker-avatar wheat-overflow-hidden wheat-rounded-full">
            <TrigoCharacterSVG role={role} />
        </div>

        <div class="wheat-flex wheat-flex-col wheat-mb-2 wheat-speaker-info">
            <span class="wheat-text-xs wheat-font-bold wheat-tracking-widest wheat-uppercase wheat-mb-1 wheat-speaker-label">{label}</span>
            <div class="wheat-speaker-bar"></div>
        </div>
    </div>

    <h2 class="wheat-text-2xl wheat-text-4xl@md wheat-font-bold wheat-speaker-title">
        "{title}"
    </h2>
</div>

<style>
    .wheat-speaker {
        color: #e7e5e4;
    }
    .wheat-speaker-avatar {
        width: 6rem;
        height: 6rem;
        border: 4px solid #1c1917;
        background-color: #292524;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        box-sizing: border-box;
    }
    @media (min-width: 768px) {
        .wheat-speaker-avatar {
            width: 8rem;
            height: 8rem;
        }
        .wheat-mb-12\@md {
            margin-bottom: 3rem;
        }
    }
    .wheat-speaker-bar {
        width: 3rem;
        height: 2px;
    }
    .wheat-speaker.hunter {
        align-items: flex-start;
    }
    .wheat-speaker.hunter .wheat-speaker-header {
        flex-direction: row;
    }
    .wheat-speaker.hunter .wheat-speaker-info {
        align-items: flex-start;
    }
    .wheat-speaker.hunter .wheat-speaker-label {
        color: #a8a29e;
    }
    .wheat-speaker.hunter .wheat-speaker-bar {
        background-color: #44403c;
    }
    .wheat-speaker.hunter .wheat-speaker-title {
        text-align: left;
    }

    .wheat-speaker.gatherer {
        align-items: flex-end;
    }
    .wheat-speaker.gatherer .wheat-speaker-header {
        flex-direction: row-reverse;
    }
    .wheat-speaker.gatherer .wheat-speaker-info {
        align-items: flex-end;
    }
    .wheat-speaker.gatherer .wheat-speaker-label {
        color: #f59e0b;
    }
    .wheat-speaker.gatherer .wheat-speaker-bar {
        background-color: #b45309;
    }
    .wheat-speaker.gatherer .wheat-speaker-title {
        text-align: right;
    }
    .wheat-speaker-title {
        max-width: 42rem;
        line-height: 1.25;
    }
</style>
