---
import "./CharlasHero.css";
---

<section class="ch-hero">
    <div class="ch-hero-grid"></div>

    <div class="ch-hero-content">
        <span class="ch-hero-version"> v.2026 </span>
        <h1 class="ch-hero-title">
            Escenario
            <span class="ch-hero-stroke">Código</span>
            <span class="ch-hero-gradient">Obra</span>
        </h1>
    </div>

    <div class="ch-hero-footer">
        <div class="ch-hero-footer-main">
            <p class="ch-hero-footer-text">
                Charlas que van más allá de la sintaxis. Reflexiones sobre ingeniería, producto y la
                responsabilidad de crear software que importa.
            </p>
        </div>
    </div>
</section>
