---
const topics = [
    {
        id: "01",
        title: "Ingeniería de Producto",
        description:
            "Cómo la tecnología habilita el negocio. Decisiones técnicas con impacto real que sobreviven al hype.",
        tags: ["Producto", "Negocio", "Impacto"],
    },
    {
        id: "02",
        title: "Código Creativo",
        description:
            "Cuando la programación se convierte en expresión. Visuales, interactividad y experiencias memorables.",
        tags: ["Arte Generativo", "Diseño", "Expresión"],
    },
    {
        id: "03",
        title: "Vida Indie",
        description:
            "La realidad de lanzar productos propios. Marketing, diseño y desarrollo desde las trincheras.",
        tags: ["Indie Dev", "Marketing", "Realidad"],
    },
    {
        id: "04",
        title: "IA & Herramientas",
        description:
            "Potenciando el flujo de trabajo sin perder el control. El desarrollador aumentado.",
        tags: ["IA", "Productividad", "Futuro"],
    },
];
import "./CharlasTopics.css";
---

<section class="cht-section">
    <div class="cht-container">
        <div class="cht-header">
            <h2 class="cht-title">Temáticas</h2>
            <span class="cht-subtitle">Disponible 2026</span>
        </div>

        <div class="cht-grid">
            {
                topics.map((topic) => (
                    <article class="cht-article">
                        <div class="cht-row">
                            <div class="cht-col-id">
                                <span class="cht-id">
                                    /{topic.id}
                                </span>
                            </div>
                            <div class="cht-col-title">
                                <h3 class="cht-topic-title">
                                    {topic.title}
                                </h3>
                            </div>
                            <div class="cht-col-desc">
                                <p class="cht-desc">
                                    {topic.description}
                                </p>
                            </div>
                            <div class="cht-col-tags">
                                {topic.tags.map((tag) => (
                                    <span class="cht-tag">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
