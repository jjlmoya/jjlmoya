---
import "./CharlasContact.css";
---

<section class="chc-section">
    <div class="chc-container">
        <div class="chc-header">
            <h2 class="chc-title">
                Contacto
            </h2>
            <p class="chc-subtitle">
                ¿Tienes un evento en mente? Hablemos.
            </p>
        </div>

        <form id="contact-form" class="chc-form">
            <div class="chc-grid">
                <div class="chc-field">
                    <input
                        type="text"
                        name="name"
                        id="name"
                        required
                        class="chc-input"
                        placeholder=" "
                    />
                    <label
                        for="name"
                        class="chc-label"
                    >
                        NOMBRE / ORGANIZACIÓN
                    </label>
                </div>

                <div class="chc-field">
                    <input
                        type="email"
                        name="email"
                        id="email"
                        required
                        class="chc-input"
                        placeholder=" "
                    />
                    <label
                        for="email"
                        class="chc-label"
                    >
                        EMAIL DE CONTACTO
                    </label>
                </div>
            </div>

            <div class="chc-field">
                <textarea
                    name="message"
                    id="message"
                    rows="4"
                    required
                    class="chc-textarea"
                    placeholder=" "></textarea>
                <label
                    for="message"
                    class="chc-label"
                >
                    DETALLES DEL EVENTO
                </label>
            </div>

            <div class="chc-footer">
                <button
                    type="submit"
                    id="submit-btn"
                    class="chc-submit-btn"
                >
                    <span
                        id="btn-text"
                        class="chc-btn-text"
                        >Enviar Propuesta</span
                    >
                </button>
                <p id="form-status" class="chc-form-status hidden"></p>
            </div>
        </form>

        <script>
            const _k =
                "aHR0cHM6Ly9zY3JpcHQuZ29vZ2xlLmNvbS9tYWNyb3Mvcy9BS2Z5Y2J6MTNwcmZyaWRzN2J1OHZTd3hFdzB6RXZOSGp3T2pBVGhMaGQ5MExGUkdqWk1ycUt0VTZnMk5zazVndHVVbE5uTEI5QS9leGVj";

            const form = document.getElementById("contact-form") as HTMLFormElement;
            const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
            const btnText = document.getElementById("btn-text") as HTMLSpanElement;
            const status = document.getElementById("form-status") as HTMLParagraphElement;

            if (form) {
                form.addEventListener("submit", async (e) => {
                    e.preventDefault();

                    submitBtn.disabled = true;
                    const originalText = btnText.innerText;
                    btnText.innerText = "ENVIANDO...";
                    status.classList.add("hidden");
                    status.className = "chc-form-status hidden";

                    const formData = new FormData(form);

                    try {
                        await fetch(atob(_k), {
                            method: "POST",
                            body: formData,
                            mode: "no-cors",
                        });

                        form.reset();
                        status.innerText = "¡Mensaje enviado correctamente!";
                        status.classList.remove("hidden");
                        status.classList.add("chc-status-success");
                    } catch (error) {
                        console.error("Error:", error);
                        status.innerText =
                            "Hubo un error al enviar el mensaje. Por favor, inténtalo de nuevo.";
                        status.classList.remove("hidden");
                        status.classList.add("chc-status-error");
                    } finally {
                        submitBtn.disabled = false;
                        btnText.innerText = originalText;
                    }
                });
            }
        </script>
    </div>
</section>
