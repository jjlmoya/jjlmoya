---

<div class="cases-wrapper">
    <h2 class="cases-title">
        Desde la barra del bar te digo...
    </h2>
    <p class="cases-subtitle">
        (el cuñado que a veces tiene razón)
    </p>
    <div
        id="cases-container"
        class="cases-container"
    >
        {
            cases.map((item) => {
                const theme = caseThemes[item.color] || { bg: "#ffffff", text: "#1e293b", border: "#cbd5e1" };
                return (
                    <div
                        class="case-card"
                        style={`--bg-color: ${theme.bg}; --text-color: ${theme.text}; --border-color: ${theme.border};`}
                    >
                        <div class="case-icon-badge">
                            <Icon name={item.icon} class="case-icon-svg" />
                        </div>

                        <div class="case-meta">
                            <div class="case-year">
                                {item.year}
                            </div>
                            <div class="case-price">
                                {item.price}
                            </div>
                        </div>

                        <h3 class="case-title-text">{item.title}</h3>

                        <p
                            class="case-description"
                            set:html={item.description}
                        />

                        <div class="case-card-footer">
                            <button
                                class="case-share-btn"
                                data-share-btn
                                data-share-text={`En ${item.year}, ${item.title} costaba ${item.price}. ${item.description.replace(/<[^>]*>?/gm, "")} #Inflacion`}
                            >
                                <Icon name="mdi:share-variant" class="case-share-icon" />
                                Compartir
                            </button>
                        </div>
                    </div>
                );
            })
        }
    </div>
</div>

<script>
    const slider = document.getElementById("cases-container");
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;

    if (slider) {
        slider.addEventListener("mousedown", (e) => {
            isDown = true;
            slider.classList.add("active");
            startX = e.pageX - slider.offsetLeft;
            scrollLeft = slider.scrollLeft;
        });

        slider.addEventListener("mouseleave", () => {
            isDown = false;
            slider.classList.remove("active");
        });

        slider.addEventListener("mouseup", () => {
            isDown = false;
            slider.classList.remove("active");
        });

        slider.addEventListener("mousemove", (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - slider.offsetLeft;
            const walk = (x - startX) * 2;
            slider.scrollLeft = scrollLeft - walk;
        });
    }
</script>

<style>
    .cases-wrapper {
        width: 100%;
        max-width: 56rem;
        margin: 3rem auto;
    }
    .cases-title {
        font-size: clamp(1.5rem, 5vw, 1.875rem);
        font-weight: 900;
        text-align: center;
        margin-bottom: 0.5rem;
        color: #1e293b;
        text-transform: uppercase;
        letter-spacing: -0.025em;
        transform: rotate(-1deg);
        line-height: 1.2;
    }
    .cases-subtitle {
        text-align: center;
        color: #64748b;
        font-family: monospace;
        font-size: 0.875rem;
        margin-bottom: 2rem;
        font-style: italic;
        transform: rotate(-1deg);
    }
    .cases-container {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        gap: 1rem;
        padding: 2rem 1rem 1.5rem 1rem;
        margin: 0 -1rem;
        cursor: grab;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .cases-container::-webkit-scrollbar {
        display: none;
    }
    .cases-container.active {
        cursor: grabbing;
        scroll-snap-type: none;
    }
    .case-card {
        flex: 0 0 auto;
        width: 85vw;
        max-width: 24rem;
        scroll-snap-align: center;
        position: relative;
        padding: 1.5rem;
        border-radius: 1rem;
        border: 2px solid var(--border-color);
        background-color: var(--bg-color);
        color: var(--text-color);
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        transition: box-shadow 0.2s;
        user-select: none;
    }
    .case-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }
    .case-icon-badge {
        position: absolute;
        top: -1rem;
        right: -1rem;
        width: 3rem;
        height: 3rem;
        background-color: #ffffff;
        border-radius: 50%;
        border: 2px solid currentColor;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        transition: transform 0.2s;
    }
    .case-card:hover .case-icon-badge {
        transform: scale(1.1);
    }
    .case-icon-svg {
        width: 1.5rem;
        height: 1.5rem;
        color: inherit;
    }
    .case-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
        padding-right: 2rem;
    }
    .case-year {
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.6;
    }
    .case-price {
        font-family: monospace;
        font-size: 0.875rem;
        font-weight: bold;
        background-color: rgba(255, 255, 255, 0.6);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
    }
    .case-title-text {
        font-size: 1.25rem;
        font-weight: 900;
        margin-bottom: 0.75rem;
        line-height: 1.25;
        padding-right: 1.5rem;
    }
    .case-description {
        font-size: 0.875rem;
        line-height: 1.6;
        opacity: 0.9;
        margin-bottom: 1rem;
    }
    .case-card-footer {
        display: flex;
        justify-content: flex-end;
    }
    .case-share-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0.6;
        background: none;
        border: none;
        cursor: pointer;
        transition: opacity 0.2s;
        color: inherit;
        padding: 0;
    }
    .case-share-btn:hover {
        opacity: 1;
    }
    .case-share-icon {
        width: 1rem;
        height: 1rem;
        color: inherit;
    }
</style>
