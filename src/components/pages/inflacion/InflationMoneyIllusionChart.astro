        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
    }
    .chart-card-title {
        font-size: 1.25rem;
        font-weight: bold;
        color: #ffffff;
        text-align: center;
        margin-bottom: 0.5rem;
    }
    .chart-card-subtitle {
        color: #cbd5e1;
        text-align: center;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
    }
    .text-highlight-green {
        color: #34d399;
        font-weight: bold;
    }
    .text-highlight-rose {
        color: #fb7185;
        font-weight: bold;
    }
    .text-highlight-white {
        color: #ffffff;
        font-style: normal;
        font-weight: 500;
    }
    .chart-canvas-wrapper {
        position: relative;
        width: 100%;
        height: 300px;
    }
    @media (min-width: 768px) {
        .chart-canvas-wrapper {
            height: 400px;
        }
    }
    .chart-legend-box {
        font-size: 0.875rem;
        color: #94a3b8;
        text-align: center;
        margin-top: 1.5rem;
        font-style: italic;
        background-color: rgba(0, 0, 0, 0.2);
        padding: 1rem;
        border-radius: 0.5rem;
        line-height: 1.5;
    }
    .chart-author-note {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        max-width: 42rem;
        margin-left: auto;
        margin-right: auto;
    }
    .chart-author-note-title {
        font-size: 0.625rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #64748b;
        text-align: center;
        margin-bottom: 0.5rem;
        font-weight: bold;
    }
    .chart-author-note-body {
        font-size: 0.875rem;
        color: #94a3b8;
        text-align: center;
        font-style: italic;
        line-height: 1.625;
    }
</style>
