---
import { Icon } from "astro-icon/components";

const comparisons = [
    {
        title: "Piso en Propiedad",
        shareTitle: "un piso",
        icon: "mdi:home-city",
        then: { year: 1985, effort: "3 años", effortValue: 30, salary: "9.000€", cost: "27.000€" },
        now: {
            year: 2025,
            effort: "11.5 años",
            effortValue: 100,
            salary: "25.000€",
            cost: "287.000€",
        },
    },
    {
        title: "Coche Nuevo",
        shareTitle: "un coche nuevo",
        icon: "mdi:car-sports",
        then: { year: 1985, effort: "6 meses", effortValue: 25, salary: "9.000€", cost: "4.500€" },
        now: {
            year: 2025,
            effort: "11.5 meses",
            effortValue: 48,
            salary: "25.000€",
            cost: "24.000€",
        },
    },
    {
        title: "Entrada de Cine",
        shareTitle: "una entrada de cine",
        icon: "mdi:ticket-confirmation",
        then: { year: 1980, effort: "20 min", effortValue: 15, salary: "4€/h", cost: "1,50€" },
        now: { year: 2025, effort: "45 min", effortValue: 35, salary: "12€/h", cost: "9,00€" },
    },
    {
        title: "Litro de Aceite",
        shareTitle: "un litro de aceite",
        icon: "mdi:oil",
        then: { year: 2000, effort: "12 min", effortValue: 10, salary: "6€/h", cost: "1,20€" },
        now: { year: 2025, effort: "50 min", effortValue: 45, salary: "12€/h", cost: "10,00€" },
    },
    {
        title: "Alquiler Mensual",
        shareTitle: "un mes de alquiler",
        icon: "mdi:key-variant",
        then: { year: 1995, effort: "5 días", effortValue: 20, salary: "14.000€", cost: "250€" },
        now: { year: 2025, effort: "14 días", effortValue: 65, salary: "25.000€", cost: "950€" },
    },
    {
        title: "Abono Festival",
        shareTitle: "un abono de festival",
        icon: "mdi:speaker-wireless",
        then: { year: 1998, effort: "6 horas", effortValue: 8, salary: "5€/h", cost: "30€" },
        now: { year: 2025, effort: "2.5 días", effortValue: 35, salary: "12€/h", cost: "240€" },
    },
    {
        title: "Carro Semanal",
        shareTitle: "la compra semanal",
        icon: "mdi:cart-variant",
        then: { year: 2000, effort: "4 horas", effortValue: 10, salary: "6€/h", cost: "24€" },
        now: { year: 2025, effort: "1.5 días", effortValue: 25, salary: "12€/h", cost: "120€" },
    },
    {
        title: "Factura Luz/Gas",
        shareTitle: "la factura de la luz",
        icon: "mdi:lightning-bolt",
        then: { year: 1990, effort: "3 horas", effortValue: 5, salary: "4€/h", cost: "12€" },
        now: { year: 2025, effort: "10 horas", effortValue: 18, salary: "12€/h", cost: "120€" },
    },
];
---

<section class="inf-effort-section" id="effort-calculator">
    <div class="inf-effort-header">
        <div class="inf-effort-header-text">
            <h3 class="inf-effort-header-title">Tu Realidad</h3>
            <p class="inf-effort-header-subtitle">Ajusta el salario para ver tu esfuerzo real</p>
        </div>

        <div class="inf-salary-input-container">
            <div class="inf-input-relative">
                <span class="inf-currency-symbol">€</span>
                <input
                    type="number"
                    id="user-salary"
                    value="25000"
                    class="inf-salary-input"
                    step="1000"
                />
            </div>
            <span class="inf-salary-input-label">/año</span>
        </div>

        <button
            id="reset-salary"
            class="inf-reset-btn"
        >
            Usar media española
        </button>
    </div>

    <div class="inf-comparisons-grid">
        {
            comparisons.map((item) => (
                <div
                    class="inf-comparison-card"
                    data-base-effort={item.now.effortValue}
                    data-cost={item.now.cost.replace(".", "").replace("€", "").replace(",", ".")}
                >
                    <div class="inf-comparison-card-inner">
                        <div class="inf-comparison-card-header">
                            <div class="inf-comparison-card-title-group">
                                <div class="inf-comparison-icon-container">
                                    <Icon name={item.icon} class="inf-comparison-icon" />
                                </div>
                                <h3 class="inf-comparison-title">
                                    {item.title}
                                </h3>
                            </div>

                            <button
                                class="inf-comparison-share-btn"
                                title="Compartir este dato"
                                data-share-btn
                                data-share-title={item.shareTitle}
                                data-then-year={item.then.year}
                                data-then-effort={item.then.effort}
                                data-now-year={item.now.year}
                                data-now-effort={item.now.effort}
                                data-share-text={`En ${item.then.year}, comprar ${item.shareTitle} costaba ${item.then.effort} de trabajo. Hoy me cuesta ${item.now.effort}. #Inflacion`}
                            >
                                <Icon name="mdi:share-variant" class="inf-share-icon" />
                            </button>
                        </div>

                        <div class="inf-comparison-grid-layout">
                            <div class="inf-vertical-divider" />

                            <div class="inf-comparison-col-then">
                                <div class="inf-comparison-col-header">
                                    <span class="inf-year-text-then">
                                        {item.then.year}
                                    </span>
                                    <span class="inf-col-badge-then">
                                        La "Buena" Época
                                    </span>
                                </div>

                                <div class="inf-bar-container">
                                    <div
                                        class="inf-progress-bar-then"
                                        style={`width: ${item.then.effortValue}%`}
                                    />
                                    <div class="inf-progress-bar-text-container">
                                        <div class="inf-progress-bar-content">
                                            <span class="inf-effort-value-text">
                                                {item.then.effort}
                                            </span>
                                            <span class="inf-effort-unit">
                                                de trabajo
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="inf-col-footer">
                                    <span>
                                        Sueldo:{" "}
                                        <span class="inf-highlight-grey">{item.then.salary}</span>
                                    </span>
                                    <span>
                                        Coste: <span class="inf-highlight-grey">{item.then.cost}</span>
                                    </span>
                                </div>
                            </div>

                            <div class="inf-comparison-col-now">
                                <div class="inf-comparison-col-header">
                                    <span class="inf-year-text-now">
                                        {item.now.year}
                                    </span>
                                    <span class="inf-col-badge-now">
                                        La Cruda Realidad
                                    </span>
                                </div>

                                <div class="inf-bar-container-interactive">
                                    <div
                                        class="inf-progress-bar-now"
                                        style={`width: ${item.now.effortValue}%`}
                                    />
                                    <div class="inf-progress-bar-text-container">
                                        <div class="inf-progress-bar-content">
                                            <span class="inf-effort-value-text inf-effort-text-interactive">
                                                {item.now.effort}
                                            </span>
                                            <span class="inf-effort-unit">
                                                de trabajo
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="inf-col-footer">
                                    <span>
                                        Sueldo:{" "}
                                        <span class="inf-user-salary-display">
                                            {item.now.salary}
                                        </span>
                                    </span>
                                    <span>
                                        Coste: <span class="inf-highlight-grey">{item.now.cost}</span>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>

    <div class="inf-disclaimer-footer-container">
        <p class="inf-disclaimer-footer">
            * Datos aproximados ajustados a salarios medios
        </p>
    </div>
</section>

<script>
    const salaryInput = document.getElementById("user-salary") as HTMLInputElement;
    const resetButton = document.getElementById("reset-salary");
    const cards = document.querySelectorAll(".inf-comparison-card");
    const salaryDisplays = document.querySelectorAll(".inf-user-salary-display");

    const DEFAULT_SALARY = 25000;
    const WORK_HOURS_YEAR = 1760;

    function formatEffort(years: number): string {
        if (years < 1) {
            const months = years * 12;
            if (months < 1) {
                const days = months * 30;
                if (days < 1) {
                    const hours = days * 8;
                    if (hours < 1) {
                        return Math.round(hours * 60) + " min";
                    }
                    return Math.round(hours) + " hora/s";
                }
                return Math.round(days) + " día/s";
            }
            return months.toFixed(1) + " mes/es";
        }
        return years.toFixed(1) + " año/s";
    }

    function updateCalculations() {
        const salary = parseFloat(salaryInput?.value) || DEFAULT_SALARY;
        const hourlyRate = salary / WORK_HOURS_YEAR;

        salaryDisplays.forEach((display) => {
            const card = display.closest(".inf-comparison-card");
            const titleElement = card?.querySelector(".inf-comparison-title");
            const titleText = titleElement ? (titleElement as HTMLElement).innerText : "";
            const isHourlyContext = titleText.includes("Cine") || titleText.includes("Aceite");

            if (isHourlyContext) {
                display.textContent = `${hourlyRate.toFixed(2)}€/h`;
                display.classList.add("inf-text-rose");
            } else {
                display.textContent = `${salary.toLocaleString()}€/año`;
                display.classList.add("inf-text-rose");
            }
        });

        cards.forEach((card) => {
            const costStr = (card as HTMLElement).dataset.cost || "0";
            const cost = parseFloat(costStr);
            const effortBar = card.querySelector(".inf-progress-bar-now") as HTMLElement;
            const effortText = card.querySelector(".inf-effort-text-interactive") as HTMLElement;
            const shareBtn = card.querySelector(".inf-comparison-share-btn") as HTMLElement;

            let yearsEffort = cost / salary;
            let effortLabel = formatEffort(yearsEffort);

            const isSmallItem = cost < 100;
            if (isSmallItem) {
                const hoursEffort = cost / hourlyRate;
                yearsEffort = hoursEffort / WORK_HOURS_YEAR;
                effortLabel = formatEffort(yearsEffort);
            }

            if (effortText) effortText.textContent = effortLabel;

            if (shareBtn) {
                const data = shareBtn.dataset;

                const shareText = `En ${data.thenYear}, comprar ${data.shareTitle} costaba ${data.thenEffort} de trabajo. Hoy me cuesta ${effortLabel}. #Inflacion`;
                shareBtn.setAttribute("data-share-text", shareText);
            }

            const baseEffortValue = parseFloat((card as HTMLElement).dataset.baseEffort || "50");
            const baseSalary = DEFAULT_SALARY;
            let newWidth = baseEffortValue * (baseSalary / salary);
            newWidth = Math.min(newWidth, 100);

            if (effortBar) effortBar.style.width = `${newWidth}%`;
        });
    }

    salaryInput?.addEventListener("input", updateCalculations);

    resetButton?.addEventListener("click", () => {
        if (salaryInput) salaryInput.value = DEFAULT_SALARY.toString();
        updateCalculations();
        salaryDisplays.forEach((d) => d.classList.remove("inf-text-rose"));
    });

    updateCalculations();
</script>

<style>
    .inf-effort-section {
        max-width: 64rem;
        margin: 0 auto 6rem auto;
        padding: 0 1rem;
    }
    .inf-effort-header {
        margin-bottom: 3rem;
        background-color: rgba(15, 23, 42, 0.5);
        padding: 1.5rem;
        border-radius: 1rem;
        border: 1px solid #1e293b;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        backdrop-filter: blur(4px);
    }
    @media (min-width: 768px) {
        .inf-effort-header {
            flex-direction: row;
        }
    }
    .inf-effort-header-text {
        text-align: center;
    }
    @media (min-width: 768px) {
        .inf-effort-header-text {
            text-align: left;
        }
    }
    .inf-effort-header-title {
        color: #e2e8f0;
        font-weight: bold;
        font-size: 1.125rem;
        margin-bottom: 0.25rem;
    }
    .inf-effort-header-subtitle {
        color: #64748b;
        font-size: 0.875rem;
    }
    .inf-salary-input-container {
        display: flex;
        align-items: center;
        gap: 1rem;
        background-color: #020617;
        padding: 0.5rem;
        border-radius: 0.75rem;
        border: 1px solid #1e293b;
        box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
    }
    .inf-input-relative {
        position: relative;
    }
    .inf-currency-symbol {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #64748b;
    }
    .inf-salary-input {
        background: transparent;
        color: #ffffff;
        font-family: monospace;
        font-size: 1.25rem;
        width: 8rem;
        padding-left: 2rem;
        border: none;
        outline: none;
        text-align: right;
    }
    .inf-salary-input-label {
        color: #64748b;
        font-size: 0.875rem;
        font-family: monospace;
        padding-right: 0.5rem;
    }
    .inf-reset-btn {
        font-size: 0.75rem;
        color: #64748b;
        background: none;
        border: none;
        text-decoration: underline dotted;
        cursor: pointer;
        transition: color 0.2s;
    }
    .inf-reset-btn:hover {
        color: #34d399;
    }
    .inf-comparisons-grid {
        display: grid;
        gap: 0.5rem;
    }
    .inf-comparison-card {
        width: 100%;
    }
    .inf-comparison-card-inner {
        position: relative;
        background-color: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(4px);
        border-radius: 0.75rem;
        border: 1px solid #1e293b;
        padding: 1.5rem;
    }
    @media (min-width: 768px) {
        .inf-comparison-card-inner {
            padding: 2rem;
        }
    }
    .inf-comparison-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        border-b: 1px solid #1e293b;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #1e293b;
    }
    .inf-comparison-card-title-group {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .inf-comparison-icon-container {
        width: 3rem;
        height: 3rem;
        background-color: #1e293b;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #e2e8f0;
        box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
        border: 1px solid #334155;
    }
    .inf-comparison-icon {
        width: 1.5rem;
        height: 1.5rem;
    }
    .inf-comparison-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: #ffffff;
        letter-spacing: -0.025em;
    }
    .inf-comparison-share-btn {
        padding: 0.5rem;
        border-radius: 50%;
        background: none;
        border: none;
        color: #64748b;
        cursor: pointer;
        transition: color 0.2s, background-color 0.2s;
    }
    .inf-comparison-share-btn:hover {
        background-color: #1e293b;
        color: #ffffff;
    }
    .inf-share-icon {
        width: 1.25rem;
        height: 1.25rem;
    }
    .inf-comparison-grid-layout {
        display: grid;
        gap: 3rem;
        position: relative;
    }
    @media (min-width: 768px) {
        .inf-comparison-grid-layout {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
    .inf-vertical-divider {
        display: none;
    }
    @media (min-width: 768px) {
        .inf-vertical-divider {
            display: block;
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 1px;
            background-color: #1e293b;
            transform: translateX(-50%);
        }
    }
    .inf-comparison-col-then {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        opacity: 0.7;
        filter: grayscale(100%);
        transition: opacity 0.7s, filter 0.7s;
    }
    .inf-comparison-card:hover .inf-comparison-col-then {
        opacity: 1;
        filter: grayscale(0%);
    }
    .inf-comparison-col-now {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .inf-comparison-col-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 0.5rem;
    }
    .inf-year-text-then {
        font-size: 2.25rem;
        font-weight: 900;
        color: #34d399;
        letter-spacing: -0.05em;
        line-height: 1;
    }
    .inf-year-text-now {
        font-size: 2.25rem;
        font-weight: 900;
        color: #f43f5e;
        letter-spacing: -0.05em;
        line-height: 1;
    }
    .inf-col-badge-then {
        font-size: 0.75rem;
        font-family: monospace;
        color: rgba(52, 211, 153, 0.6);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.25rem;
    }
    .inf-col-badge-now {
        font-size: 0.75rem;
        font-family: monospace;
        color: rgba(244, 63, 94, 0.6);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.25rem;
    }
    .inf-bar-container {
        position: relative;
        height: 4rem;
        background-color: #020617;
        border-radius: 0.5rem;
        border: 1px solid #1e293b;
        overflow: hidden;
    }
    .inf-bar-container-interactive {
        position: relative;
        height: 4rem;
        background-color: #020617;
        border-radius: 0.5rem;
        border: 1px solid #1e293b;
        overflow: hidden;
        transition: border-color 0.2s;
    }
    .inf-comparison-card:hover .inf-bar-container-interactive {
        border-color: #334155;
    }
    .inf-progress-bar-then {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        background-color: rgba(16, 185, 129, 0.2);
        border-right: 2px solid #10b981;
        box-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
    }
    .inf-progress-bar-now {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        background-color: rgba(244, 63, 94, 0.2);
        border-right: 2px solid #f43f5e;
        box-shadow: 0 0 20px rgba(244, 63, 94, 0.3);
        transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .inf-progress-bar-text-container {
        position: relative;
        z-index: 10;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 1rem;
    }
    .inf-progress-bar-content {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }
    .inf-effort-value-text {
        color: #ffffff;
        font-weight: bold;
        font-size: 1.125rem;
    }
    .inf-effort-unit {
        font-size: 0.75rem;
        color: #64748b;
        font-family: monospace;
    }
    .inf-col-footer {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        font-family: monospace;
        color: #64748b;
        padding-top: 0.5rem;
    }
    .inf-highlight-grey {
        color: #cbd5e1;
    }
    .inf-user-salary-display {
        color: #cbd5e1;
        transition: color 0.3s;
    }
    .inf-text-rose {
        color: #fb7185 !important;
    }
    .inf-disclaimer-footer-container {
        margin-top: 3rem;
        text-align: center;
    }
    .inf-disclaimer-footer {
        font-size: 0.75rem;
        color: #475569;
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
</style>
