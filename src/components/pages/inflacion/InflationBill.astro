---

<div class="inf-bill-card">
    <div class="inf-bill-badge">
        BILLETE DE 100€
    </div>

    <div
        id="items-container"
        class="inf-items-container"
    >
    </div>

    <div class="inf-bill-footer">
        <div class="inf-bill-footer-left">
            <div class="inf-bill-label">Año</div>
            <div id="year-display" class="inf-year-val">2025</div>
        </div>
        <div class="inf-bill-footer-right">
            <div class="inf-bill-label">Valor equivalente hoy</div>
            <div id="value-display" class="inf-value-val">
                100€
            </div>
        </div>
    </div>
</div>

<style>
    .inf-bill-card {
        background-color: #ffffff;
        border: 4px solid #000000;
        padding: 2rem;
        box-shadow: 8px 8px 0px 0px #000000;
        margin-bottom: 3rem;
        position: relative;
    }
    .inf-bill-badge {
        position: absolute;
        top: -1.5rem;
        left: 50%;
        transform: translateX(-50%) rotate(-2deg);
        background-color: #16a34a;
        color: #ffffff;
        padding: 0.25rem 1rem;
        font-weight: bold;
        border: 2px solid #000000;
    }
    .inf-items-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        min-height: 300px;
        align-content: flex-start;
        justify-content: center;
        padding: 1rem;
    }
    .inf-bill-footer {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 2px dashed #d1d5db;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }
    .inf-bill-footer-left {
        text-align: left;
    }
    .inf-bill-footer-right {
        text-align: right;
    }
    .inf-bill-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #6b7280;
    }
    .inf-year-val {
        font-size: 3rem;
        font-weight: 900;
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }
    .inf-value-val {
        font-size: 1.875rem;
        font-weight: bold;
        color: #16a34a;
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }
</style>
