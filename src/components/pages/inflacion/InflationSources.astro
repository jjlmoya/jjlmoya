---
import { Icon } from "astro-icon/components";

const sources = [
    {
        name: "INE (Instituto Nacional de Estadística)",
        description: "Series históricas del IPC y Encuesta de Presupuestos Familiares.",
        url: "https://www.ine.es/dyngs/INEbase/es/operacion.htm?c=Estadistica_C&cid=1254736176802&menu=ultiDatos&idp=1254735976607",
        icon: "mdi:chart-box-outline",
    },
    {
        name: "Banco de España",
        description: "Informes anuales y estadísticas sobre salarios medios y coste de la vida.",
        url: "https://www.bde.es/wbe/es/estadisticas/temas/economia-empleo/precios-costes-laborales/",
        icon: "mdi:bank-outline",
    },
    {
        name: "Hemeroteca Digital",
        description:
            "Recopilación de precios en anuncios y noticias de prensa histórica (ABC, La Vanguardia).",
        url: "https://www.bne.es/es/catalogos/hemeroteca-digital",
        icon: "mdi:newspaper-variant-outline",
    },
    {
        name: "Ministerio de Vivienda",
        description: "Estadísticas sobre el precio del m² y esfuerzo de acceso a la vivienda.",
        url: "https://www.mivau.gob.es/",
        icon: "mdi:home-analytics",
    },
];
---

<section class="sources-section">
    <div class="sources-overlay"></div>

    <div class="sources-wrapper">
        <div class="sources-header">
            <div class="sources-label-container">
                <span class="sources-label">Documentación</span>
            </div>
            <h2 class="sources-title">
                Fuentes y Referencias
            </h2>
            <p class="sources-subtitle">
                "La memoria es frágil, pero los datos permanecen." — Recopilación de las fuentes
                utilizadas para los cálculos y comparativas.
            </p>
        </div>

        <div class="sources-grid">
            {
                sources.map((source) => (
                    <a
                        href={source.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="source-link-card"
                    >
                        <div class="source-icon-container">
                            <Icon name={source.icon} class="source-icon" />
                        </div>
                        <div>
                            <h3 class="source-card-title">
                                {source.name}
                            </h3>
                            <p class="source-card-desc">
                                {source.description}
                            </p>
                        </div>
                    </a>
                ))
            }
        </div>

        <div class="report-card">
            <div class="report-bg-icon">
                <Icon name="mdi:file-certificate" class="report-bg-icon-svg" />
            </div>

            <div class="report-header">
                <h3 class="report-title">
                    Anexo I: Informe Macroeconómico
                </h3>
                <p class="report-subtitle">
                    Análisis comparativo de la evolución de precios y poder adquisitivo en España
                    (1980-2025).
                </p>
            </div>

            <div class="report-section">
                <div class="section-header">
                    <h4 class="section-title">
                        <span class="section-tag">TABLA A.1</span>
                        Evolución del Coste de la Vida
                    </h4>
                    <span class="section-ref">Ref: INE / Hemeroteca / Ministerios</span>
                </div>

                <div class="table-wrapper">
                    <table class="data-table">
                        <thead class="data-table-thead">
                            <tr>
                                <th class="data-table-th">Concepto</th>
                                <th class="data-table-th th-center">Año</th>
                                <th class="data-table-th th-right">Precio Histórico</th>
                                <th class="data-table-th th-right">Precio 2025</th>
                                <th class="data-table-th th-right">Var. %</th>
                                <th class="data-table-th th-center">Fuente</th>
                            </tr>
                        </thead>
                        <tbody class="data-table-tbody">
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Vivienda (Piso 80m²)</td>
                                <td class="data-table-td td-center">1985</td>
                                <td class="data-table-td td-right">27.000€ <span class="price-original-sub">(4.5M ptas)</span></td>
                                <td class="data-table-td td-right">287.000€</td>
                                <td class="data-table-td td-right td-alert-negative">+963%</td>
                                <td class="data-table-td td-center">
                                    <a
                                        href="https://www.mivau.gob.es/"
                                        target="_blank"
                                        class="table-link">M. Vivienda</a>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Salario Mínimo (SMI)</td>
                                <td class="data-table-td td-center">1980</td>
                                <td class="data-table-td td-right">154€ <span class="price-original-sub">(25.620 ptas)</span></td>
                                <td class="data-table-td td-right">1.134€</td>
                                <td class="data-table-td td-right td-alert-positive">+636%</td>
                                <td class="data-table-td td-center">
                                    <a
                                        href="https://www.boe.es/buscar/doc.php?id=BOE-A-2024-2088"
                                        target="_blank"
                                        class="table-link">BOE (SMI '24)</a>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Pan (Barra 250g)</td>
                                <td class="data-table-td td-center">1985</td>
                                <td class="data-table-td td-right">0,12€ <span class="price-original-sub">(20 ptas)</span></td>
                                <td class="data-table-td td-right">1,20€</td>
                                <td class="data-table-td td-right td-alert-negative">+900%</td>
                                <td class="data-table-td td-center">
                                    <a
                                        href="https://www.ine.es/dyngs/INEbase/es/operacion.htm?c=Estadistica_C&cid=1254736176802&menu=ultiDatos&idp=1254735976607"
                                        target="_blank"
                                        class="table-link">INE (IPC)</a>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Gasolina (Litro)</td>
                                <td class="data-table-td td-center">1980</td>
                                <td class="data-table-td td-right">0,27€ <span class="price-original-sub">(45 ptas)</span></td>
                                <td class="data-table-td td-right">1,65€</td>
                                <td class="data-table-td td-right td-alert-negative">+511%</td>
                                <td class="data-table-td td-center">
                                    <a
                                        href="https://www.miteco.gob.es/es/energia/hidrocarburos-nuevos-combustibles/petroleo/informes/informes-anuales.html"
                                        target="_blank"
                                        class="table-link">M. Energía</a>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Cine (Entrada)</td>
                                <td class="data-table-td td-center">1980</td>
                                <td class="data-table-td td-right">1,20€ <span class="price-original-sub">(200 ptas)</span></td>
                                <td class="data-table-td td-right">9,00€</td>
                                <td class="data-table-td td-right td-alert-negative">+650%</td>
                                <td class="data-table-td td-center">
                                    <span
                                        class="table-help-text"
                                        title="Hemeroteca ABC / La Vanguardia">Hemeroteca</span>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Coche Utilitario</td>
                                <td class="data-table-td td-center">1985</td>
                                <td class="data-table-td td-right">4.500€ <span class="price-original-sub">(750k ptas)</span></td>
                                <td class="data-table-td td-right">24.000€</td>
                                <td class="data-table-td td-right td-alert-negative">+433%</td>
                                <td class="data-table-td td-center">
                                    <span
                                        class="table-help-text"
                                        title="Revistas Motor Clásico / Autopista">Revistas</span>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Periódico</td>
                                <td class="data-table-td td-center">1985</td>
                                <td class="data-table-td td-right">0,27€ <span class="price-original-sub">(45 ptas)</span></td>
                                <td class="data-table-td td-right">1,80€</td>
                                <td class="data-table-td td-right td-alert-negative">+566%</td>
                                <td class="data-table-td td-center">
                                    <span class="text-disabled font-sans">Hemeroteca</span>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Aceite Oliva (1L)</td>
                                <td class="data-table-td td-center">2000</td>
                                <td class="data-table-td td-right">1,20€ <span class="price-original-sub">(200 ptas)</span></td>
                                <td class="data-table-td td-right">10,00€</td>
                                <td class="data-table-td td-right td-alert-negative">+733%</td>
                                <td class="data-table-td td-center">
                                    <a
                                        href="https://www.ine.es/dyngs/INEbase/es/operacion.htm?c=Estadistica_C&cid=1254736176802&menu=ultiDatos&idp=1254735976607"
                                        target="_blank"
                                        class="table-link">INE (IPC)</a>
                                </td>
                            </tr>
                            <tr class="data-table-row">
                                <td class="data-table-td td-bold">Café (Bar)</td>
                                <td class="data-table-td td-center">1990</td>
                                <td class="data-table-td td-right">0,48€ <span class="price-original-sub">(80 ptas)</span></td>
                                <td class="data-table-td td-right">1,50€</td>
                                <td class="data-table-td td-right td-alert-negative">+212%</td>
                                <td class="data-table-td td-center">
                                    <span class="text-disabled font-sans">Hostelería</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="report-layout-bottom">
                <div class="salarial-evolution-box">
                    <h4 class="section-title">
                        <span class="section-tag">TABLA A.2</span>
                        Evolución Salarial
                    </h4>
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead class="data-table-thead">
                                <tr>
                                    <th class="data-table-th">Año</th>
                                    <th class="data-table-th th-right">Salario Medio <span class="price-original-sub font-sans">Anual</span></th>
                                    <th class="data-table-th th-right">SMI <span class="price-original-sub font-sans">Mensual 14p</span></th>
                                    <th class="data-table-th th-right">SMI <span class="price-original-sub font-sans">Anual Total</span></th>
                                </tr>
                            </thead>
                            <tbody class="data-table-tbody">
                                <tr class="data-table-row">
                                    <td class="data-table-td td-bold">1980</td>
                                    <td class="data-table-td td-right">~7.000€</td>
                                    <td class="data-table-td td-right">154€</td>
                                    <td class="data-table-td td-right">2.156€</td>
                                </tr>
                                <tr class="data-table-row">
                                    <td class="data-table-td td-bold">1990</td>
                                    <td class="data-table-td td-right">~11.000€</td>
                                    <td class="data-table-td td-right">300€</td>
                                    <td class="data-table-td td-right">4.200€</td>
                                </tr>
                                <tr class="data-table-row">
                                    <td class="data-table-td td-bold">2000</td>
                                    <td class="data-table-td td-right">16.500€</td>
                                    <td class="data-table-td td-right">424€</td>
                                    <td class="data-table-td td-right">5.936€</td>
                                </tr>
                                <tr class="data-table-row">
                                    <td class="data-table-td td-bold">2010</td>
                                    <td class="data-table-td td-right">22.700€</td>
                                    <td class="data-table-td td-right">633€</td>
                                    <td class="data-table-td td-right">8.866€</td>
                                </tr>
                                <tr class="data-table-row">
                                    <td class="data-table-td td-bold">2020</td>
                                    <td class="data-table-td td-right">24.300€</td>
                                    <td class="data-table-td td-right">950€</td>
                                    <td class="data-table-td td-right">13.300€</td>
                                </tr>
                                <tr class="data-table-row">
                                    <td class="data-table-td td-bold">2024</td>
                                    <td class="data-table-td td-right">28.500€*</td>
                                    <td class="data-table-td td-right">1.134€</td>
                                    <td class="data-table-td td-right">15.876€</td>
                                </tr>
                                <tr class="data-table-row row-projected">
                                    <td class="data-table-td td-bold">2025 (Proj.)</td>
                                    <td class="data-table-td td-right">~29.500€*</td>
                                    <td class="data-table-td td-right">~1.184€*</td>
                                    <td class="data-table-td td-right">~16.576€*</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="methodology-box">
                    <div class="methodology-content">
                        <h4 class="methodology-title">
                            <Icon name="mdi:scale-balance" class="methodology-icon" />
                            Nota Metodológica
                        </h4>
                        <p class="methodology-text">
                            Los datos presentados en este informe han sido normalizados a Euros
                            corrientes para facilitar la comparación, utilizando el tipo de cambio
                            fijo (1€ = 166,386 ptas).
                        </p>
                        <p class="methodology-text">
                            <strong>Importante:</strong> La columna "Var. %" refleja el incremento nominal
                            del precio. Para entender la pérdida real de poder adquisitivo, se debe contrastar
                            con la evolución salarial (Tabla A.2). Mientras que algunos bienes básicos
                            han subido un 900%, los salarios medios apenas se han triplicado en el mismo
                            periodo.
                        </p>
                    </div>
                    <div class="methodology-footer">
                        <p class="methodology-footer-text">
                            Fuentes: INE (Series históricas IPC), Banco de España (Boletines
                            estadísticos), Ministerio de Vivienda (Series de precios m²), BOE
                            (Decretos SMI) y Hemerotecas digitales (ABC, La Vanguardia, El País).
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .sources-section {
        background-color: #e8e4d9;
        color: #292524;
        padding: 6rem 0;
        position: relative;
        overflow: hidden;
        border-top: 8px solid #d6d3d1;
    }
    .sources-overlay {
        position: absolute;
        inset: 0;
        opacity: 0.4;
        mix-blend-mode: multiply;
        pointer-events: none;
    }
    .sources-wrapper {
        max-width: 56rem;
        margin: 0 auto;
        padding: 0 1.5rem;
        position: relative;
        z-index: 10;
    }
    .sources-header {
        text-align: center;
        margin-bottom: 4rem;
    }
    .sources-label-container {
        display: inline-block;
        border: 2px solid #292524;
        padding: 0.25rem 1rem;
        margin-bottom: 1rem;
        transform: rotate(-2deg);
    }
    .sources-label {
        font-family: monospace;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.75rem;
    }
    .sources-title {
        font-size: clamp(2rem, 6vw, 3rem);
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        font-weight: bold;
        color: #1c1917;
        margin-bottom: 1rem;
        line-height: 1.1;
    }
    .sources-subtitle {
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        font-style: italic;
        color: #57534e;
        max-width: 42rem;
        margin: 0 auto;
        line-height: 1.5;
    }
    .sources-grid {
        display: grid;
        gap: 1.5rem;
    }
    @media (min-width: 768px) {
        .sources-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
    .source-link-card {
        display: flex;
        align-items: start;
        gap: 1rem;
        background-color: rgba(255, 255, 255, 0.5);
        padding: 1.5rem;
        border-radius: 0.125rem;
        border: 1px solid #d6d3d1;
        text-decoration: none;
        color: inherit;
        transition: background-color 0.3s, border-color 0.3s, box-shadow 0.3s;
    }
    .source-link-card:hover {
        background-color: #ffffff;
        border-color: #292524;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .source-icon-container {
        padding: 0.75rem;
        background-color: #e7e5e4;
        color: #44403c;
        border-radius: 0.125rem;
        transition: background-color 0.3s, color 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .source-link-card:hover .source-icon-container {
        background-color: #292524;
        color: #ffffff;
    }
    .source-icon {
        width: 1.5rem;
        height: 1.5rem;
    }
    .source-card-title {
        font-weight: bold;
        font-size: 1.125rem;
        color: #1c1917;
        margin: 0 0 0.25rem 0;
        line-height: 1.2;
    }
    .source-link-card:hover .source-card-title {
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-decoration-color: #a8a29e;
        text-underline-offset: 4px;
    }
    .source-card-desc {
        font-size: 0.875rem;
        color: #57534e;
        line-height: 1.5;
        margin: 0;
    }

    .report-card {
        margin-top: 6rem;
        background-color: #ffffff;
        padding: 1rem;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        border: 1px solid #e7e5e4;
        position: relative;
    }
    @media (min-width: 768px) {
        .report-card {
            padding: 3rem;
        }
    }
    .report-bg-icon {
        display: none;
    }
    @media (min-width: 768px) {
        .report-bg-icon {
            display: block;
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            opacity: 0.1;
            transform: rotate(12deg);
            pointer-events: none;
        }
    }
    .report-bg-icon-svg {
        width: 12rem;
        height: 12rem;
        color: #1c1917;
    }
    .report-header {
        border-bottom: 4px solid #292524;
        padding-bottom: 1.5rem;
        margin-bottom: 3rem;
    }
    .report-title {
        font-size: clamp(1.5rem, 5vw, 2.25rem);
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        font-weight: bold;
        color: #1c1917;
        margin: 0 0 0.5rem 0;
    }
    .report-subtitle {
        color: #57534e;
        font-style: italic;
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.125rem;
        margin: 0;
    }
    .report-section {
        margin-bottom: 4rem;
    }
    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }
    .section-title {
        font-weight: bold;
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        color: #292524;
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        margin: 0;
    }
    .section-tag {
        background-color: #292524;
        color: #ffffff;
        padding: 0.25rem 0.75rem;
        font-size: 0.875rem;
        font-family: monospace;
        margin-right: 0.75rem;
    }
    .section-ref {
        font-size: 0.75rem;
        font-family: monospace;
        color: #78716c;
        display: none;
    }
    @media (min-width: 768px) {
        .section-ref {
            display: block;
        }
    }
    .table-wrapper {
        overflow-x: auto;
        border: 1px solid #d6d3d1;
    }
    .data-table {
        width: 100%;
        font-size: 0.875rem;
        text-align: left;
        border-collapse: collapse;
    }
    .data-table-thead {
        background-color: #f5f5f4;
        color: #1c1917;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        font-family: monospace;
    }
    .data-table-th {
        padding: 0.5rem;
        border-bottom: 2px solid #d6d3d1;
        border-right: 1px solid #e7e5e4;
    }
    @media (min-width: 768px) {
        .data-table-th {
            padding: 0.75rem 1rem;
        }
    }
    .data-table-th.th-center {
        text-align: center;
        width: 5rem;
    }
    .data-table-th.th-right {
        text-align: right;
    }
    .data-table-tbody {
        font-family: monospace;
        color: #44403c;
    }
    .data-table-row {
        border-bottom: 1px solid #e7e5e4;
        transition: background-color 0.2s;
    }
    .data-table-row:hover {
        background-color: rgba(254, 243, 199, 0.5);
    }
    .data-table-td {
        padding: 0.5rem;
        border-right: 1px solid #e7e5e4;
        vertical-align: middle;
    }
    @media (min-width: 768px) {
        .data-table-td {
            padding: 0.75rem 1rem;
        }
    }
    .data-table-td.td-bold {
        font-weight: bold;
    }
    .data-table-td.td-center {
        text-align: center;
    }
    .data-table-td.td-right {
        text-align: right;
    }
    .price-original-sub {
        font-size: 0.625rem;
        color: #a8a29e;
        display: block;
    }
    .data-table-td.td-alert-negative {
        font-weight: bold;
        color: #b91c1c;
        background-color: #fef2f2;
    }
    .data-table-td.td-alert-positive {
        font-weight: bold;
        color: #15803d;
        background-color: #f0fdf4;
    }
    .table-link {
        color: #2563eb;
        text-decoration: none;
    }
    .table-link:hover {
        text-decoration: underline;
    }
    .table-help-text {
        color: #a8a29e;
        cursor: help;
    }
    .text-disabled {
        color: #a8a29e;
    }

    .report-layout-bottom {
        display: grid;
        gap: 3rem;
    }
    @media (min-width: 1024px) {
        .report-layout-bottom {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
    .salarial-evolution-box {
        display: flex;
        flex-direction: column;
    }
    .row-projected {
        background-color: #fffbeb;
        font-weight: bold;
