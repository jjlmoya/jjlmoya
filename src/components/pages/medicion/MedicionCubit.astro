---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-10">
        <svg class="med-w-full med-h-full">
            <pattern
                id="hieroglyphs"
                x="0"
                y="0"
                width="100"
                height="100"
                patternUnits="userSpaceOnUse"
            >
                <path d="M 20 20 L 20 40 L 40 40" fill="none" stroke="#fde047" stroke-width="2"
                ></path>
                <circle cx="60" cy="60" r="5" fill="none" stroke="#fde047" stroke-width="2"
                ></circle>
                <path d="M 80 20 Q 90 40 80 60" fill="none" stroke="#fde047" stroke-width="2"
                ></path>
            </pattern>
            <rect width="100%" height="100%" fill="url(#hieroglyphs)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Brazo del Faraón</span
                >
                <h2 class="med-title med-title-local">El Codo Real</h2>

                <p class="med-description med-description-local">
                    ¿Cómo construyes una pirámide perfecta con miles de obreros? Necesitas una sola
                    verdad. Un solo patrón.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Muerte por Olvido</h3>
                    <p class="med-card-text med-card-text-local">
                        El "Codo Real" (52.3 cm) se guardaba en granito negro. Cada luna llena, los
                        arquitectos debían calibrar sus varas de madera contra el patrón maestro.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Olvidar calibrar se castigaba con la muerte. Gracias a esa obsesión, la Gran
                        Pirámide tiene un error de menos del 0.05%.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <rect
                            x="50"
                            y="100"
                            width="300"
                            height="40"
                            fill="#1a1a1a"
                            stroke="#422006"
                            stroke-width="2"
                            rx="2"></rect>

                        <g stroke="#fde047" stroke-width="1">
                            {
                                Array.from({ length: 7 }).map((_, i) => (
                                    <line
                                        x1={50 + i * (300 / 7)}
                                        y1="100"
                                        x2={50 + i * (300 / 7)}
                                        y2="120"
                                    />
                                ))
                            }

                            {
                                Array.from({ length: 4 }).map((_, i) => (
                                    <line
                                        x1={50 + i * (300 / 7 / 4)}
                                        y1="100"
                                        x2={50 + i * (300 / 7 / 4)}
                                        y2="110"
                                    />
                                ))
                            }
                        </g>

                        <g class="animate-calibrate">
                            <rect
                                x="50"
                                y="160"
                                width="300"
                                height="30"
                                fill="#a16207"
                                stroke="#713f12"
                                stroke-width="1"
                                rx="1"></rect>
                            <text x="200" y="180" text-anchor="middle" fill="#422006" font-size="10"
                                >VARA DE OBRA</text
                            >
                        </g>

                        <line
                            x1="50"
                            y1="140"
                            x2="50"
                            y2="160"
                            stroke="#ef4444"
                            stroke-width="1"
                            stroke-dasharray="2 2"
                            opacity="0"
                        >
                            <animate
                                attributeName="opacity"
                                values="0; 1; 0"
                                dur="2s"
                                repeatCount="indefinite"></animate>
                        </line>
                        <line
                            x1="350"
                            y1="140"
                            x2="350"
                            y2="160"
                            stroke="#ef4444"
                            stroke-width="1"
                            stroke-dasharray="2 2"
                            opacity="0"
                        >
                            <animate
                                attributeName="opacity"
                                values="0; 1; 0"
                                dur="2s"
                                repeatCount="indefinite"></animate>
                        </line>

                        <text x="200" y="80" text-anchor="middle" fill="#fde047" font-size="20"
                            >𓂣</text
                        >
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #422006;
        color: #fde047;
    }

    .med-tag-local {
        color: #ca8a04;
        border-color: #854d0e;
    }

    .med-title-local {
        color: #fef08a;
    }

    .med-description-local {
        color: #fde047;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #fef08a;
    }

    .med-card-text-local {
        color: #fde047;
    }

    .med-card-note-local {
        color: #ca8a04;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #713f12 50%, transparent);
        border-color: #a16207;
    }

    @keyframes calibrate {
        0% {
            transform: translateY(20px);
            opacity: 0;
        }
        20% {
            transform: translateY(0);
            opacity: 1;
        }
        80% {
            transform: translateY(0);
            opacity: 1;
        }
        100% {
            transform: translateY(20px);
            opacity: 0;
        }
    }
    .animate-calibrate {
        animation: calibrate 4s ease-in-out infinite;
    }
</style>
