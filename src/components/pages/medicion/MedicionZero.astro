---

---

<section
    class="med-section med-section-local"
>
    <div class="med-background">
        <div
            class="med-glow-radial med-glow-radial-local"
        >
        </div>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >Sunya</span
                >
                <h2 class="med-title med-title-local">
                    La Medida de la Nada
                </h2>

                <p class="med-description med-description-local">
                    ¿Cómo mides lo que no existe? Durante siglos, el vacío era aterrador. Los
                    romanos no tenían número para la nada.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">El Cero</h3>
                    <p class="med-card-text med-card-text-local">
                        En la India (Brahmagupta) y en América (Mayas), se atrevieron a darle forma
                        al vacío. El cero no es solo "nada", es un marcador de posición.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Sin el cero, no hay matemáticas modernas, ni cálculo, ni código binario. Es
                        la medida más importante de todas.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 400" class="w-full h-full overflow-visible">
                        <g opacity="0.2">
                            {
                                Array.from({ length: 20 }).map(() => (
                                    <text
                                        x={Math.random() * 400}
                                        y={Math.random() * 400}
                                        font-size={Math.random() * 30 + 10}
                                        fill="#525252"
                                        class="animate-float"
                                        style={`animation-duration: ${Math.random() * 5 + 5}s`}
                                    >
                                        {Math.floor(Math.random() * 9) + 1}
                                    </text>
                                ))
                            }
                        </g>

                        <g transform="translate(200, 200)">
                            <circle
                                cx="0"
                                cy="0"
                                r="80"
                                fill="none"
                                stroke="#262626"
                                stroke-width="1"
                            >
                                <animate
                                    attributeName="r"
                                    values="80; 90; 80"
                                    dur="4s"
                                    repeatCount="indefinite"></animate>
                                <animate
                                    attributeName="opacity"
                                    values="0.5; 0; 0.5"
                                    dur="4s"
                                    repeatCount="indefinite"></animate>
                            </circle>

                            <ellipse
                                cx="0"
                                cy="0"
                                rx="60"
                                ry="80"
                                fill="none"
                                stroke="#e5e5e5"
                                stroke-width="2"
                                class="animate-pulse-border"></ellipse>

                            <ellipse cx="0" cy="0" rx="50" ry="70" fill="#000000"></ellipse>

                            <circle cx="0" cy="0" r="2" fill="#fff">
                                <animate
                                    attributeName="r"
                                    values="2; 4; 2"
                                    dur="2s"
                                    repeatCount="indefinite"></animate>
                                <animate
                                    attributeName="opacity"
                                    values="1; 0.5; 1"
                                    dur="2s"
                                    repeatCount="indefinite"></animate>
                            </circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #000000;
        color: #e5e5e5;
    }

    .med-glow-radial-local {
        background-color: rgba(23, 23, 23, 0.2);
    }

    .med-tag-local {
        color: #737373;
        border-color: #404040;
    }

    .med-title-local {
        color: #ffffff;
    }

    .med-description-local {
        color: #a3a3a3;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #171717 50%, transparent);
        border-color: #262626;
    }

    .med-card-title-local {
        color: #e5e5e5;
    }

    .med-card-text-local {
        color: #a3a3a3;
    }

    .med-card-note-local {
        color: #737373;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes float {
        0% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-20px);
        }
        100% {
            transform: translateY(0);
        }
    }
    .animate-float {
        animation: float ease-in-out infinite;
    }

    @keyframes pulseBorder {
        0% {
            stroke-width: 2;
            stroke-opacity: 1;
        }
        50% {
            stroke-width: 4;
            stroke-opacity: 0.5;
        }
        100% {
            stroke-width: 2;
            stroke-opacity: 1;
        }
    }
    .animate-pulse-border {
        animation: pulseBorder 3s ease-in-out infinite;
    }
</style>
