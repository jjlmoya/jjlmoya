---

---

<section
    class="med-section med-section-local"
>
    <div class="med-background med-background-local animate-flicker"></div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >Quemando el Tiempo</span
                >
                <h2 class="med-title med-title-local">
                    El Reloj de Fuego
                </h2>

                <p class="med-description med-description-local">
                    Antes de los engranajes, el tiempo se consumía. Para saber la hora en la
                    oscuridad, encendías una vela.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Las Velas del Rey Alfredo</h3>
                    <p class="med-card-text med-card-text-local">
                        En el siglo IX, el Rey Alfredo el Grande usaba velas de 12 pulgadas marcadas
                        cada pulgada. Cada vela duraba exactamente 4 horas.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        "Quedan dos pulgadas para el amanecer."
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 100 300" class="w-full h-full overflow-visible">
                        <path fill="#ffedd5" d="M 30 300 L 70 300 L 70 50 L 30 50 Z">
                            <animate
                                attributeName="d"
                                values="M 30 300 L 70 300 L 70 50 L 30 50 Z; M 30 300 L 70 300 L 70 250 L 30 250 Z"
                                dur="20s"
                                repeatCount="indefinite"></animate>
                        </path>

                        <g stroke="#fdba74" stroke-width="1">
                            {
                                Array.from({ length: 12 }).map((_, i) => (
                                    <line x1="30" y1={50 + i * 20} x2="70" y2={50 + i * 20} />
                                ))
                            }
                        </g>

                        <line x1="50" y1="50" x2="50" y2="40" stroke="#78350f" stroke-width="2">
                            <animate
                                attributeName="y1"
                                values="50; 250"
                                dur="20s"
                                repeatCount="indefinite"></animate>
                            <animate
                                attributeName="y2"
                                values="40; 240"
                                dur="20s"
                                repeatCount="indefinite"></animate>
                        </line>

                        <g>
                            <path
                                d="M 50 40 Q 60 40 60 25 Q 60 5 50 0 Q 40 5 40 25 Q 40 40 50 40"
                                fill="#fbbf24"
                                class="animate-flame"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="translate"
                                    values="0 0; 0 200"
                                    dur="20s"
                                    repeatCount="indefinite"></animateTransform>
                            </path>
                            <path
                                d="M 50 35 Q 55 35 55 25 Q 55 15 50 10 Q 45 15 45 25 Q 45 35 50 35"
                                fill="#ef4444"
                                class="animate-flame-inner"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="translate"
                                    values="0 0; 0 200"
                                    dur="20s"
                                    repeatCount="indefinite"></animateTransform>
                            </path>
                        </g>

                        <circle cx="50" cy="25" r="40" fill="url(#glowGradient)" opacity="0.4">
                            <animateTransform
                                attributeName="transform"
                                type="translate"
                                values="0 0; 0 200"
                                dur="20s"
                                repeatCount="indefinite"></animateTransform>
                            <animate
                                attributeName="r"
                                values="40; 45; 38; 42; 40"
                                dur="0.5s"
                                repeatCount="indefinite"></animate>
                        </circle>

                        <defs>
                            <radialGradient id="glowGradient">
                                <stop offset="0%" stop-color="#fbbf24" stop-opacity="1"></stop>
                                <stop offset="100%" stop-color="#fbbf24" stop-opacity="0"></stop>
                            </radialGradient>
                        </defs>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1a0a00;
        color: #fed7aa;
    }

    .med-background-local {
        background-color: rgba(0, 0, 0, 0.2);
    }

    .med-tag-local {
        color: #fb923c;
        border-color: #c2410c;
    }

    .med-title-local {
        color: #ffedd5;
    }

    .med-description-local {
        color: #fed7aa;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #431407 40%, transparent);
        border-color: color-mix(in srgb, #9a3412 30%, transparent);
    }

    .med-card-title-local {
        color: #fdba74;
    }

    .med-card-text-local {
        color: #ffedd5;
    }

    .med-card-note-local {
        color: #fb923c;
    }

    .med-visual-column-local {
        height: 500px;
        align-items: flex-end;
        padding-bottom: 3rem;
    }

    @keyframes flicker {
        0%,
        100% {
            opacity: 0.1;
        }
        50% {
            opacity: 0.2;
        }
        25% {
            opacity: 0.15;
        }
        75% {
            opacity: 0.05;
        }
    }
    .animate-flicker {
        animation: flicker 0.2s infinite;
    }

    .animate-flame {
        animation: flameWaver 0.5s ease-in-out infinite alternate;
        transform-origin: 50px 40px;
    }

    @keyframes flameWaver {
        0% {
            transform: scale(1) rotate(-2deg);
        }
        100% {
            transform: scale(1.1) rotate(2deg);
        }
    }

    .med-visual-sizer { position: relative; width: 8rem; height: 24rem; display: flex; justify-content: center; }
</style>
