---

---

<section
    class="med-section med-section-local"
>
    <div class="med-container med-container--xwide">
        <div class="med-grid-cols-1 med-grid-cols-2\@md med-gap-16 med-items-center">
            <div class="med-space-y-8">
                <h2
                    class="med-text-5xl med-font-bold med-tracking-tighter glitch-text"
                    data-text="YO, EL DATO"
                >
                    YO, EL DATO
                </h2>
                <p class="med-text-xl medicion-qs-body">
                    Mientras la ciencia miraba hacia las constantes universales, nosotros giramos el
                    microscopio hacia adentro.
                </p>
                <p class="med-text-lg medicion-qs-body-muted">
                    Hoy llevamos relojes que no solo dan la hora, sino que nos dicen si hemos
                    dormido "bien". Medimos nuestra valía social en "likes". Medimos nuestra
                    productividad en "commits".
                </p>
                <p class="med-text-lg medicion-qs-emphasis med-font-bold med-border-l-4 medicion-qs-border med-pl-4">
                    Si no se puede medir, no existe.
                </p>
            </div>

            <div class="med-grid-cols-2 med-gap-4">
                <div
                    class="medicion-qs-card group"
                >
                    <div class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest">Pasos</div>
                    <div
                        class="med-text-3xl med-font-bold medicion-qs-card-value"
                    >
                        8,432
                    </div>
                    <div class="med-w-full medicion-qs-bar-bg med-mt-4 med-rounded-full med-overflow-hidden">
                        <div class="medicion-qs-bar-fill medicion-qs-bar--70"></div>
                    </div>
                </div>

                <div
                    class="medicion-qs-card group"
                >
                    <div class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest">
                        Calorías
                    </div>
                    <div
                        class="med-text-3xl med-font-bold medicion-qs-card-value"
                    >
                        2,150
                    </div>
                    <div class="med-w-full medicion-qs-bar-bg med-mt-4 med-rounded-full med-overflow-hidden">
                        <div class="medicion-qs-bar-fill medicion-qs-bar--85"></div>
                    </div>
                </div>

                <div
                    class="medicion-qs-card group"
                >
                    <div class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest">
                        Pantalla
                    </div>
                    <div
                        class="med-text-3xl med-font-bold medicion-qs-card-value"
                    >
                        6h 12m
                    </div>
                    <div class="medicion-meta-label medicion-qs-negative med-mt-2">▲ 12% vs ayer</div>
                </div>

                <div
                    class="medicion-qs-card group"
                >
                    <div class="med-text-xs medicion-qs-card-label med-mb-2 med-uppercase med-tracking-widest">Sueño</div>
                    <div
                        class="med-text-3xl med-font-bold medicion-qs-card-value"
                    >
                        1h 45m
                    </div>
                    <div class="medicion-meta-label medicion-qs-positive med-mt-2">Profundo</div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #000000;
        color: #ffffff;
    }

    .medicion-qs-body {
        color: #a3a3a3;
        line-height: 1.625;
    }

    .medicion-qs-body-muted {
        color: #737373;
    }

    .medicion-qs-emphasis {
        color: #ffffff;
    }

    .medicion-qs-border {
        border-color: #ffffff;
    }

    .medicion-qs-card {
        background-color: #171717;
        padding: 1.5rem;
        border-radius: 0.25rem;
        border: 1px solid #262626;
        transition: all 0.3s;
    }
    .medicion-qs-card:hover {
        border-color: #525252;
    }

    .medicion-qs-card-label {
        color: #737373;
    }

    .medicion-qs-card-value {
        color: #ffffff;
        transition: color 0.3s;
    }
    .group:hover .medicion-qs-card-value {
        color: #22d3ee;
    }

    .medicion-qs-bar-bg {
        background-color: #262626;
        height: 4px;
        border-radius: 9999px;
        overflow: hidden;
    }

    .medicion-qs-bar-fill {
        height: 100%;
        background-color: #22d3ee;
    }

    .medicion-qs-bar--70 {
        width: 70%;
    }

    .medicion-qs-bar--85 {
        width: 85%;
    }

    .medicion-meta-label { font-size: 10px; }
    .medicion-qs-negative {
        color: #ef4444;
    }

    .medicion-qs-positive {
        color: #22c55e;
    }

    .glitch-text {
        position: relative;
    }

    .glitch-text::before,
    .glitch-text::after {
        content: attr(data-text);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .glitch-text::before {
        left: 2px;
        text-shadow: -1px 0 red;
        clip: rect(24px, 550px, 90px, 0);
        animation: glitch-anim-2 3s infinite linear alternate-reverse;
    }

    .glitch-text::after {
        left: -2px;
        text-shadow: -1px 0 blue;
        clip: rect(85px, 550px, 140px, 0);
        animation: glitch-anim 2.5s infinite linear alternate-reverse;
    }

    @keyframes glitch-anim {
        0% {
            clip: rect(12px, 9999px, 5px, 0);
        }
        20% {
            clip: rect(109px, 9999px, 86px, 0);
        }
        40% {
            clip: rect(35px, 9999px, 15px, 0);
        }
        60% {
            clip: rect(68px, 9999px, 10px, 0);
        }
        80% {
            clip: rect(12px, 9999px, 95px, 0);
        }
        100% {
            clip: rect(45px, 9999px, 66px, 0);
        }
    }

    @keyframes glitch-anim-2 {
        0% {
            clip: rect(65px, 9999px, 100px, 0);
        }
        20% {
            clip: rect(12px, 9999px, 5px, 0);
        }
        40% {
            clip: rect(89px, 9999px, 45px, 0);
        }
        60% {
            clip: rect(2px, 9999px, 15px, 0);
        }
        80% {
            clip: rect(45px, 9999px, 66px, 0);
        }
        100% {
            clip: rect(12px, 9999px, 85px, 0);
        }
    }
</style>
