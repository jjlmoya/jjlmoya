---

---

<section
    class="med-section med-section-local"
>
    <div
        class="med-absolute med-inset-0 med-pointer-events-none med-opacity-20" style="background: radial-gradient(circle at center,#333 0%,#000 100%)"
    >
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Huella Dactilar de la Luz</span
                >
                <h2 class="med-title med-title-local">Espectroscopía</h2>

                <p class="med-description med-description-local">
                    Newton no solo descubrió el arcoíris, descubrió una regla para medir de qué
                    están hechas las cosas sin tocarlas.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Midiendo lo Intocable</h3>
                    <p class="med-card-text med-card-text-local">
                        Cada elemento químico emite o absorbe luz en longitudes de onda precisas. El
                        espectro es un código de barras universal.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Gracias a esto, podemos medir la composición de una estrella a millones de
                        años luz o detectar veneno en la sangre.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <path
                            d="M 150 200 L 250 200 L 200 100 Z"
                            fill="rgba(255,255,255,0.1)"
                            stroke="rgba(255,255,255,0.5)"
                            stroke-width="2"></path>

                        <line
                            x1="0"
                            y1="170"
                            x2="175"
                            y2="150"
                            stroke="white"
                            stroke-width="3"
                            class="animate-light-beam"></line>

                        <line
                            x1="175"
                            y1="150"
                            x2="225"
                            y2="150"
                            stroke="white"
                            stroke-width="2"
                            opacity="0.8"></line>

                        <g class="animate-spectrum-reveal">
                            <path
                                d="M 225 150 L 400 120"
                                stroke="#ef4444"
                                stroke-width="4"
                                opacity="0.8"></path>

                            <path
                                d="M 225 150 L 400 135"
                                stroke="#f97316"
                                stroke-width="4"
                                opacity="0.8"></path>

                            <path
                                d="M 225 150 L 400 150"
                                stroke="#eab308"
                                stroke-width="4"
                                opacity="0.8"></path>

                            <path
                                d="M 225 150 L 400 165"
                                stroke="#22c55e"
                                stroke-width="4"
                                opacity="0.8"></path>

                            <path
                                d="M 225 150 L 400 180"
                                stroke="#3b82f6"
                                stroke-width="4"
                                opacity="0.8"></path>

                            <path
                                d="M 225 150 L 400 195"
                                stroke="#a855f7"
                                stroke-width="4"
                                opacity="0.8"></path>
                        </g>

                        <g fill="white" opacity="0.2">
                            {
                                Array.from({ length: 20 }).map(() => (
                                    <circle
                                        cx={Math.random() * 400}
                                        cy={Math.random() * 300}
                                        r={Math.random() * 1.5}
                                    />
                                ))
                            }
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #000000;
        color: #e5e5e5;
    }

    .med-tag-local {
        color: #d4d4d4;
        border-color: #525252;
    }

    .med-title-local {
        color: #ffffff;
    }

    .med-description-local {
        color: #a3a3a3;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #e5e5e5;
    }

    .med-card-text-local {
        color: #d4d4d4;
    }

    .med-card-note-local {
        color: #a3a3a3;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #171717 50%, transparent);
        border-color: #404040;
    }

    @keyframes lightBeam {
        0% {
            stroke-dasharray: 200;
            stroke-dashoffset: 200;
            opacity: 0;
        }
        50% {
            stroke-dasharray: 200;
            stroke-dashoffset: 0;
            opacity: 1;
        }
        100% {
            stroke-dasharray: 200;
            stroke-dashoffset: 0;
            opacity: 1;
        }
    }
    .animate-light-beam {
        animation: lightBeam 4s ease-out infinite;
    }

    @keyframes spectrumReveal {
        0% {
            opacity: 0;
        }
        40% {
            opacity: 0;
        }
        60% {
            opacity: 1;
        }
        100% {
            opacity: 1;
        }
    }
    .animate-spectrum-reveal {
        animation: spectrumReveal 4s ease-out infinite;
    }
</style>
