---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-overflow-hidden">
        {
            Array.from({ length: 30 }).map(() => (
                <div
                    class="med-absolute med-rounded-full animate-particle" style="width: 0.25rem; height: 0.25rem; background-color: #bef264;"
                    style={`
                    left: ${Math.random() * 100}%; 
                    top: ${Math.random() * 100}%; 
                    animation-duration: ${Math.random() * 0.5 + 0.2}s;
                    animation-delay: ${Math.random() * 5}s;
                 `}
                />
            ))
        }
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Click de la Muerte</span
                >
                <h2 class="med-title med-title-local">
                    El Contador Geiger
                </h2>

                <p class="med-description med-description-local">
                    La radiación es el asesino perfecto: inodoro, incoloro, silencioso. No podíamos
                    protegernos de lo que no podíamos percibir.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Ionización Audible</h3>
                    <p class="med-card-text med-card-text-local">
                        Hans Geiger y Walther Müller crearon un tubo lleno de gas inerte con un
                        cable de alto voltaje. Cuando una partícula radiactiva entra, ioniza el gas
                        y cierra el circuito por un instante.
                    </p>
                    <p class="med-mt-4 med-text-sm med-font-mono" style="color: #84cc16;">CLICK. CLICK-CLICK. CLICK.</p>
                    <p class="med-text-xs med-mt-1" style="color: #d9f99d;">
                        El sonido de lo invisible chocando con la realidad.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 300 200" class="med-w-full med-h-full med-overflow-visible">
                        <rect
                            x="50"
                            y="80"
                            width="200"
                            height="40"
                            rx="5"
                            fill="#262626"
                            stroke="#525252"
                            stroke-width="2"></rect>
                        <line
                            x1="50"
                            y1="100"
                            x2="250"
                            y2="100"
                            stroke="#a3e635"
                            stroke-width="1"
                            stroke-dasharray="2 2"
                            opacity="0.3"></line>

                        <path
                            d="M 50 100 C 20 100 20 150 50 180"
                            fill="none"
                            stroke="#171717"
                            stroke-width="4"></path>

                        <rect
                            x="50"
                            y="150"
                            width="100"
                            height="60"
                            rx="2"
                            fill="#facc15"
                            stroke="#ca8a04"
                            stroke-width="2"></rect>

                        <path
                            d="M 60 190 A 30 30 0 0 1 140 190"
                            fill="none"
                            stroke="#000"
                            stroke-width="1"></path>
                        <line
                            x1="100"
                            y1="190"
                            x2="100"
                            y2="170"
                            stroke="#dc2626"
                            stroke-width="2"
                            class="animate-needle-twitch"></line>

                        <g>
                            <circle cx="300" cy="90" r="2" fill="#fff" class="animate-particle-hit"
                            ></circle>
                            <circle
                                cx="320"
                                cy="110"
                                r="2"
                                fill="#fff"
                                class="animate-particle-hit"
                                style="animation-delay: 1.2s"></circle>
                            <circle
                                cx="280"
                                cy="100"
                                r="2"
                                fill="#fff"
                                class="animate-particle-hit"
                                style="animation-delay: 2.5s"></circle>
                        </g>

                        <circle
                            cx="150"
                            cy="100"
                            r="10"
                            fill="#a3e635"
                            opacity="0"
                            class="animate-flash"></circle>
                        <circle
                            cx="150"
                            cy="100"
                            r="10"
                            fill="#a3e635"
                            opacity="0"
                            class="animate-flash"
                            style="animation-delay: 1.2s"></circle>
                        <circle
                            cx="150"
                            cy="100"
                            r="10"
                            fill="#a3e635"
                            opacity="0"
                            class="animate-flash"
                            style="animation-delay: 2.5s"></circle>

                        <g transform="translate(160, 160)" opacity="0">
                            <circle r="10" fill="none" stroke="#a3e635" stroke-width="2"></circle>
                            <circle r="20" fill="none" stroke="#a3e635" stroke-width="1"></circle>
                            <animate
                                attributeName="opacity"
                                values="0;1;0"
                                dur="0.2s"
                                begin="0.5s; 1.7s; 3.0s"></animate>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1a1a1a;
        color: #a3e635;
    }

    .med-tag-local {
        color: #84cc16;
        border-color: #4d7c0f;
    }

    .med-title-local {
        color: #ecfccb;
    }

    .med-description-local {
        color: #d9f99d;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #bef264;
    }

    .med-card-text-local {
        color: #ecfccb;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #3f6212 50%, transparent);
        border-color: #65a30d;
    }

    @keyframes particle {
        0% {
            opacity: 0;
            transform: scale(0);
        }
        50% {
            opacity: 1;
        }
        100% {
            opacity: 0;
            transform: scale(2);
        }
    }
    .animate-particle {
        animation-iteration-count: infinite;
        animation-timing-function: linear;
    }

    @keyframes particleHit {
        0% {
            transform: translateX(0);
            opacity: 1;
        }
        40% {
            transform: translateX(-150px);
            opacity: 1;
        }
        41% {
            opacity: 0;
        }
        100% {
            opacity: 0;
        }
    }
    .animate-particle-hit {
        animation: particleHit 3s linear infinite;
    }

    @keyframes flash {
        0%,
        40% {
            opacity: 0;
            transform: scale(0.5);
        }
        41% {
            opacity: 0.8;
            transform: scale(1.5);
        }
        45% {
            opacity: 0;
            transform: scale(0.5);
        }
        100% {
            opacity: 0;
        }
    }
    .animate-flash {
        animation: flash 3s linear infinite;
    }

    @keyframes needleTwitch {
        0%,
        40% {
            transform: rotate(0deg);
        }
        41% {
            transform: rotate(45deg);
        }
        45% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(0deg);
        }
    }
    .animate-needle-twitch {
        transform-origin: 100px 190px;
        animation: needleTwitch 3s linear infinite;
    }

    .med-visual-sizer { position: relative; width: 20rem; height: 100%; display: flex; align-items: center; justify-content: center; }
</style>
