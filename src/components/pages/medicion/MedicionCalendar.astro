---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-10">
        <svg class="med-w-full med-h-full">
            <filter id="roughPaper">
                <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="5" result="noise"
                ></feTurbulence>
                <feDiffuseLighting in="noise" lighting-color="#d6d3d1" surfaceScale="2">
                    <feDistantLight azimuth="45" elevation="60"></feDistantLight>
                </feDiffuseLighting>
            </filter>
            <rect width="100%" height="100%" fill="#1c1917" filter="url(#roughPaper)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Eterno Retorno</span
                >
                <h2 class="med-title med-title-local">
                    El Tiempo Circular
                </h2>

                <p class="med-description med-description-local">
                    Para nosotros, el tiempo es una flecha que avanza. Para los antiguos, era una
                    rueda que giraba. Medir no era contar segundos, era predecir cuándo volverían
                    los dioses.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Rueda Calendárica</h3>
                    <p class="med-card-text med-card-text-local">
                        Mayas y Aztecas engranaban dos ciclos como engranajes de una máquina
                        cósmica: el <em>Tzolk'in</em> sagrado (260 días) y el <em>Haab'</em> solar (365
                        días).
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Solo cada 52 años, las ruedas volvían a su posición inicial. Ese día, el
                        fuego se apagaba y el mundo contenía el aliento.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <defs>
                            <radialGradient id="stoneGrad" cx="0.5" cy="0.5" r="0.5">
                                <stop offset="0%" stop-color="#57534e"></stop>
                                <stop offset="100%" stop-color="#292524"></stop>
                            </radialGradient>
                            <filter id="shadow">
                                <feDropShadow dx="2" dy="2" stdDeviation="2" flood-opacity="0.5"
                                ></feDropShadow>
                            </filter>
                        </defs>

                        <g transform="translate(100, 150)">
                            <g class="animate-spin-gear-left">
                                <circle
                                    r="57"
                                    fill="url(#stoneGrad)"
                                    stroke="#78716c"
                                    stroke-width="2"
                                    filter="url(#shadow)"></circle>

                                {
                                    Array.from({ length: 13 }).map((_, i) => (
                                        <g transform={`rotate(${i * (360 / 13)})`}>
                                            <path
                                                d="M 55 -8 L 73 -5 L 73 5 L 55 8 Z"
                                                fill="#44403c"
                                                stroke="#78716c"
                                                stroke-width="1"
                                            />

                                            <circle cx="45" cy="0" r="3" fill="#d6d3d1" />
                                        </g>
                                    ))
                                }

                                <text
                                    x="0"
                                    y="5"
                                    text-anchor="middle"
                                    fill="#a8a29e"
                                    font-size="10"
                                    font-weight="bold">TZOLK'IN</text
                                >
                            </g>
                        </g>

                        <g transform="translate(265, 150)">
                            <g class="animate-spin-gear-right" style="transform-origin: 0 0;">
                                <circle
                                    r="92"
                                    fill="url(#stoneGrad)"
                                    stroke="#78716c"
                                    stroke-width="2"
                                    filter="url(#shadow)"></circle>

                                {
                                    Array.from({ length: 20 }).map((_, i) => (
                                        <g transform={`rotate(${i * 18})`}>
                                            <path
                                                d="M 90 -8 L 108 -5 L 108 5 L 90 8 Z"
                                                fill="#44403c"
                                                stroke="#78716c"
                                                stroke-width="1"
                                            />

                                            <rect
                                                x="80"
                                                y="-3"
                                                width="6"
                                                height="6"
                                                fill="#d6d3d1"
                                            />
                                        </g>
                                    ))
                                }

                                <text
                                    x="0"
                                    y="5"
                                    text-anchor="middle"
                                    fill="#a8a29e"
                                    font-size="10"
                                    font-weight="bold">HAAB'</text
                                >
                            </g>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1c1917;
        color: #e7e5e4;
    }

    .med-tag-local {
        color: #a8a29e;
        border-color: #57534e;
    }

    .med-title-local {
        color: #f5f5f4;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #e7e5e4;
    }

    .med-card-text-local {
        color: #a8a29e;
    }

    .med-card-note-local {
        color: #d6d3d1;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #292524 50%, transparent);
        border-color: #44403c;
    }

    @keyframes spinCW {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
    .animate-spin-gear-left {
        animation: spinCW 20s linear infinite;
    }

    @keyframes spinCCW {
        from {
            transform: rotate(9deg);
        }
        to {
            transform: rotate(-351deg);
        }
    }
    .animate-spin-gear-right {
        animation: spinCCW 30.77s linear infinite;
    }
</style>
