<section
    class="med-section med-section-local"
>
    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <h2 class="med-text-4xl medicion-coast-title">
                    La Paradoja de la Costa
                </h2>

                <p class="med-text-lg medicion-coast-body">
                    ¿Cuánto mide la costa de Gran Bretaña? La respuesta depende de tu regla.
                </p>
                <p class="med-text-lg medicion-coast-body">
                    Si mides con una regla de 100km, obtienes un número. Si usas una de 1m, el
                    número crece. Si mides cada grano de arena, la longitud tiende al infinito.
                </p>

                <div class="med-space-y-4 med-mt-8">
                    <div class="medicion-coast-card">
                        <p class="med-text-sm medicion-coast-card-text">
                            <strong>Fractales:</strong> La geometría de la naturaleza es rugosa. La precisión
                            absoluta en la medición de formas naturales es una ilusión.
                        </p>
                    </div>
                </div>
            </div>

            <div class="med-w-full medicion-coast-visual-col med-flex med-flex-col med-items-center med-justify-center">
                <div
                    class="med-relative med-w-full medicion-coast-visual-box"
                >
                    <canvas id="coastline-canvas" class="med-w-full med-h-full medicion-coast-canvas"></canvas>

                    <div class="med-absolute med-bottom-4 med-left-4 med-right-4 med-flex med-justify-between med-items-end">
                        <div
                            class="medicion-coast-panel"
                        >
                            <div class="medicion-coast-panel-label med-uppercase med-tracking-widest med-mb-1">
                                Tamaño de Regla
                            </div>
                            <div id="ruler-size" class="med-text-lg med-font-mono med-font-bold medicion-coast-panel-value">
                                --
                            </div>
                        </div>
                        <div
                            class="medicion-coast-panel medicion-coast-panel--right"
                        >
                            <div class="medicion-coast-panel-label med-uppercase med-tracking-widest med-mb-1">
                                Longitud Total
                            </div>
                            <div
                                id="measured-length"
                                class="med-text-lg med-font-mono med-font-bold medicion-coast-panel-value--accent"
                            >
                                --
                            </div>
                        </div>
                    </div>
                </div>
                <p class="med-text-xs med-font-mono med-text-center medicion-coast-caption">
                    Simulación: Midiendo una isla fractal con distinta precisión
                </p>
            </div>
        </div>
    </div>
</section>

<script>
    const canvas = document.getElementById("coastline-canvas") as HTMLCanvasElement;
    const rulerEl = document.getElementById("ruler-size");
    const lengthEl = document.getElementById("measured-length");

    if (canvas && rulerEl && lengthEl) {
        const ctx = canvas.getContext("2d");
        if (!ctx) throw new Error("Canvas context not found");

        const width = canvas.offsetWidth;
        const height = canvas.offsetHeight;

        const dpr = window.devicePixelRatio || 1;
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        ctx.scale(dpr, dpr);

        const center = { x: width / 2, y: height / 2 };
        const radius = Math.min(width, height) * 0.35;
        const totalPoints = 360;

        interface Point {
            x: number;
            y: number;
        }
        const points: Point[] = [];

        for (let i = 0; i < totalPoints; i++) {
            const angle = (i / totalPoints) * Math.PI * 2;
            let r = radius;

            r += Math.sin(angle * 3) * 20;
            r += Math.cos(angle * 7) * 15;
            r += Math.sin(angle * 13) * 8;
            r += Math.cos(angle * 29) * 4;
            r += Math.sin(angle * 53) * 2;

            points.push({
                x: center.x + Math.cos(angle) * r,
                y: center.y + Math.sin(angle) * r,
            });
        }
        points.push(points[0]);

        const resolutions = [
            { step: 40, label: "Muy Grande" },
            { step: 20, label: "Grande" },
            { step: 10, label: "Media" },
            { step: 5, label: "Fina" },
            { step: 1, label: "Atómica" },
        ];
        let currentResIndex = 0;

        function draw() {
            if (!ctx) return;

            ctx.clearRect(0, 0, width, height);

            ctx.beginPath();
            ctx.strokeStyle = "rgba(34, 211, 238, 0.1)";
            ctx.lineWidth = 1;
            ctx.moveTo(points[0].x, points[0].y);
            for (let i = 1; i < points.length; i++) {
                ctx.lineTo(points[i].x, points[i].y);
            }
            ctx.stroke();

            const res = resolutions[currentResIndex];
            const step = res.step;
            let measuredLen = 0;

            ctx.beginPath();
            ctx.strokeStyle = "#22d3ee";
            ctx.lineWidth = 2;

            let currentIdx = 0;
            const measurePoints: Point[] = [];
            measurePoints.push(points[0]);

            ctx.moveTo(points[0].x, points[0].y);

            while (currentIdx < points.length - 1) {
                let nextIdx = currentIdx + step;
                if (nextIdx >= points.length - 1) nextIdx = points.length - 1;

                const p1 = points[currentIdx];
                const p2 = points[nextIdx];

                ctx.lineTo(p2.x, p2.y);

                const dist = Math.sqrt(Math.pow(p2.x - p1.x, 2) + Math.pow(p2.y - p1.y, 2));
                measuredLen += dist;

                measurePoints.push(p2);
                currentIdx = nextIdx;
                if (currentIdx >= points.length - 1) break;
            }
            ctx.stroke();

            ctx.fillStyle = "#fff";
            measurePoints.forEach((p) => {
                ctx.beginPath();
                ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
                ctx.fill();
            });

            if (rulerEl) rulerEl.innerText = res.label;

            const displayLen = Math.floor(measuredLen * 1.5);
            if (lengthEl) lengthEl.innerText = displayLen.toLocaleString() + " km";

            currentResIndex = (currentResIndex + 1) % resolutions.length;
        }

        draw();

        setInterval(draw, 1500);
    }
</script>

<style>
    .med-section-local {
        background: linear-gradient(to bottom, #021a1a, #000000);
        color: #e0f2fe;
    }

    .medicion-coast-title {
        font-family: Georgia, "Times New Roman", serif;
        font-style: italic;
        color: #a5f3fc;
    }

    .medicion-coast-body {
        line-height: 1.625;
        font-family: Georgia, "Times New Roman", serif;
        color: rgba(207, 250, 254, 0.8);
    }

    .medicion-coast-card {
        background-color: rgba(0, 80, 80, 0.2);
        padding: 1.5rem;
        border-radius: 0.125rem;
        border-left: 2px solid rgba(6, 182, 212, 0.5);
    }

    .medicion-coast-card-text {
        color: rgba(207, 250, 254, 0.9);
        line-height: 1.625;
    }

    .medicion-coast-visual-col {
        width: 100%;
    }
    @media (min-width: 768px) {
        .medicion-coast-visual-col {
            width: 50%;
        }
    }

    .medicion-coast-visual-box {
        position: relative;
        aspect-ratio: 1;
        max-width: 28rem;
        background-color: rgba(38, 38, 38, 0.5);
        border-radius: 0.75rem;
        border: 1px solid rgba(21, 94, 117, 0.3);
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(21, 94, 117, 0.1);
    }

    .medicion-coast-canvas {
        opacity: 0.8;
    }

    .medicion-coast-panel {
        background-color: rgba(0, 0, 0, 0.8);
        -webkit-backdrop-filter: blur(12px);
        backdrop-filter: blur(12px);
        padding: 0.75rem;
        border-radius: 0.25rem;
        border: 1px solid rgba(6, 182, 212, 0.2);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .medicion-coast-panel--right {
        text-align: right;
    }

    .medicion-coast-panel-label {
        font-size: 10px;
        color: #22d3ee;
    }

    .medicion-coast-panel-value {
        color: #ffffff;
    }

    .medicion-coast-panel-value--accent {
        color: #a5f3fc;
    }

    .medicion-coast-caption {
        color: rgba(6, 182, 212, 0.4);
        margin-top: 1rem;
    }
</style>
