---

---

<section
    class="med-section med-section-local"
>
    <div class="med-clepsydra-overlay">
        {
            Array.from({ length: 10 }).map((_, i) => (
                <div
                    class="med-clepsydra-drip animate-drip"
                    style={`left: ${i * 10 + 5}%; top: -10%; height: 20px; animation-duration: ${Math.random() * 2 + 2}s; animation-delay: ${Math.random() * 2}s;`}
                />
            ))
        }
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Tiempo Líquido</span
                >
                <h2 class="med-title med-title-local">La Clepsidra</h2>

                <p class="med-description med-description-local">
                    Cuando el sol se ponía, los relojes de sol morían. Para medir la noche, los
                    antiguos egipcios y griegos dejaron que el tiempo fluyera.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">El Ladrón de Agua</h3>
                    <p class="med-card-text med-card-text-local">
                        Un recipiente con un agujero preciso en el fondo. A medida que el nivel del
                        agua bajaba, revelaba marcas en el interior que indicaban las horas pasadas.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Platón usó una para despertar a sus alumnos: el primer despertador de la
                        historia.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 200 400" class="med-visual-svg">
                        <g transform="translate(50, 50)">
                            <path
                                d="M 0 0 L 10 150 L 45 150 L 45 160 L 55 160 L 55 150 L 90 150 L 100 0"
                                fill="none"
                                stroke="#bae6fd"
                                stroke-width="2"></path>

                            <path
                                d="M 5 10 L 95 10 L 90 150 L 10 150 Z"
                                fill="#0ea5e9"
                                opacity="0.6"
                            >
                                <animate
                                    attributeName="d"
                                    values="M 5 10 L 95 10 L 90 150 L 10 150 Z; M 10 150 L 90 150 L 90 150 L 10 150 Z"
                                    dur="10s"
                                    repeatCount="indefinite"></animate>
                            </path>

                            {
                                Array.from({ length: 6 }).map((_, i) => (
                                    <line
                                        x1="20"
                                        y1={30 + i * 20}
                                        x2="30"
                                        y2={30 + i * 20}
                                        stroke="#bae6fd"
                                        stroke-width="1"
                                        opacity="0.5"
                                    />
                                ))
                            }
                        </g>

                        <g transform="translate(100, 210)">
                            <circle cx="0" cy="0" r="3" fill="#38bdf8" class="animate-water-drop"
                            ></circle>
                            <circle
                                cx="0"
                                cy="0"
                                r="3"
                                fill="#38bdf8"
                                class="animate-water-drop"
                                style="animation-delay: 0.5s"></circle>
                            <circle
                                cx="0"
                                cy="0"
                                r="3"
                                fill="#38bdf8"
                                class="animate-water-drop"
                                style="animation-delay: 1s"></circle>
                        </g>

                        <g transform="translate(50, 250)">
                            <path
                                d="M 10 0 L 10 100 Q 10 120 30 120 L 70 120 Q 90 120 90 100 L 90 0"
                                fill="none"
                                stroke="#bae6fd"
                                stroke-width="2"></path>

                            <path
                                d="M 10 120 L 90 120 L 90 120 L 10 120 Z"
                                fill="#0ea5e9"
                                opacity="0.6"
                            >
                                <animate
                                    attributeName="d"
                                    values="M 10 120 L 90 120 L 90 120 L 10 120 Z; M 10 120 L 90 120 L 90 20 L 10 20 Z"
                                    dur="10s"
                                    repeatCount="indefinite"></animate>
                            </path>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #0c4a6e;
        color: #e0f2fe;
    }

    .med-tag-local {
        color: #38bdf8;
        border-color: #0369a1;
    }

    .med-title-local {
        color: #f0f9ff;
    }

    .med-description-local {
        color: #bae6fd;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #7dd3fc;
    }

    .med-card-text-local {
        color: #e0f2fe;
    }

    .med-card-note-local {
        color: #38bdf8;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #075985 50%, transparent);
        border-color: #0ea5e9;
    }

    @keyframes drip {
        0% {
            transform: translateY(0);
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
        100% {
            transform: translateY(100vh);
            opacity: 0;
        }
    }
    .animate-drip {
        animation-timing-function: linear;
        animation-iteration-count: infinite;
    }

    @keyframes waterDrop {
        0% {
            transform: translateY(0);
            opacity: 1;
        }
        100% {
            transform: translateY(40px);
            opacity: 0;
        }
    }
    .animate-water-drop {
        animation: waterDrop 1s linear infinite;
    }

    .med-clepsydra-drip {
        position: absolute;
        width: 1px;
        background-color: #7dd3fc;
    }

    .med-clepsydra-overlay {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.2;
    }

    .med-visual-svg {
        width: 100%;
        height: 100%;
        overflow: visible;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 100%; display: flex; align-items: center; justify-content: center; }
</style>
