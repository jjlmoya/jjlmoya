---

---

<section
    class="med-section med-section-local"
>
    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Tiempo Elástico</span
                >
                <h2 class="med-title med-title-local">
                    La Hora Desigual
                </h2>

                <p class="med-description med-description-local">
                    Hoy vivimos esclavos del "tic-tac" mecánico, donde cada segundo es idéntico al
                    anterior. Pero durante milenios, el tiempo era orgánico.
                </p>

                <div class="med-space-y-6 med-mt-8">
                    <div class="med-card-bg-local med-p-6 med-rounded-sm med-border-l-2 med-card-border-local">
                        <h3 class="med-card-title-local med-font-bold med-mb-2">La Hora Romana</h3>
                        <p class="med-card-text med-card-text-local">
                            Una "hora" se definía simplemente como 1/12 del tiempo de luz solar.
                        </p>
                        <ul class="med-list med-list-local">
                            <li class="med-flex med-justify-between med-border-b med-card-item-border med-pb-1">
                                <span>Invierno</span>
                                <span>1 hora = ~45 minutos actuales</span>
                            </li>
                            <li class="med-flex med-justify-between med-pt-1">
                                <span>Verano</span>
                                <span>1 hora = ~75 minutos actuales</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <p class="med-text-sm med-card-note-text med-italic">
                    El tiempo se estiraba y encogía con las estaciones. Nadie llegaba "tarde" porque
                    la tarde misma era flexible.
                </p>
            </div>

            <div class="med-visual-column">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 200 200" class="med-w-full med-h-full med-drop-shadow-local">
                        <circle
                            cx="100"
                            cy="100"
                            r="90"
                            fill="#1e293b"
                            stroke="#334155"
                            stroke-width="2"></circle>

                        <path
                            d="M 30 100 Q 100 30 170 100"
                            fill="none"
                            stroke="#475569"
                            stroke-width="1"
                            stroke-dasharray="4 4"
                            opacity="0.5"></path>
                        <path
                            d="M 50 100 Q 100 60 150 100"
                            fill="none"
                            stroke="#475569"
                            stroke-width="1"
                            stroke-dasharray="4 4"
                            opacity="0.5"></path>

                        <g stroke="#64748b" stroke-width="1">
                            {
                                Array.from({ length: 13 }).map((_, i) => (
                                    <line
                                        x1="100"
                                        y1="100"
                                        x2="100"
                                        y2="20"
                                        transform={`rotate(${(i - 6) * 15} 100 100)`}
                                        opacity="0.5"
                                    />
                                ))
                            }
                        </g>

                        <g>
                            <path fill="#0f172a" opacity="0.8">
                                <animate
                                    attributeName="d"
                                    values="M 100 100 L 40 100 L 100 100; M 100 100 L 100 20 L 100 100; M 100 100 L 160 100 L 100 100"
                                    dur="10s"
                                    repeatCount="indefinite"
                                    calcMode="spline"
                                    keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"></animate>
                            </path>

                            <line
                                x1="100"
                                y1="100"
                                x2="100"
                                y2="20"
                                stroke="#020617"
                                stroke-width="4"
                                stroke-linecap="round"
                                opacity="0.9"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    values="-80 100 100; 0 100 100; 80 100 100"
                                    dur="10s"
                                    repeatCount="indefinite"
                                    calcMode="spline"
                                    keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"></animateTransform>
                                <animate
                                    attributeName="y2"
                                    values="20; 40; 20"
                                    dur="10s"
                                    repeatCount="indefinite"></animate>
                            </line>
                        </g>

                        <circle
                            cx="100"
                            cy="100"
                            r="6"
                            fill="#e2e8f0"
                            stroke="#475569"
                            stroke-width="2"></circle>

                        <g>
                            <circle cx="100" cy="15" r="8" fill="#fbbf24">
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    values="-80 100 100; 0 100 100; 80 100 100"
                                    dur="10s"
                                    repeatCount="indefinite"
                                    calcMode="spline"
                                    keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"></animateTransform>
                            </circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>


<style>
    .med-section-local {
        background-color: #0f172a;
        color: #cbd5e1;
    }

    .med-tag-local {
        color: #94a3b8;
        border-color: #94a3b8;
    }

    .med-title-local {
        color: #f1f5f9;
    }

    .med-description-local {
        color: #cbd5e1;
        opacity: 0.9;
    }

    .med-card-text-local {
        color: #cbd5e1;
    }

    .med-list-local {
        color: #94a3b8;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 16rem; }
    @media (min-width: 768px) { .med-visual-sizer { width: 20rem; height: 20rem; } }

    .med-card-bg-local { background-color: #1e293b; }
    .med-card-border-local { border-color: rgba(99, 102, 241, 0.5); }
    .med-card-title-local { color: rgba(199, 210, 254, 0.8); }
    .med-card-item-border { border-color: #334155; }
    .med-card-note-text { color: #64748b; }
    .med-drop-shadow-local { filter: drop-shadow(0 25px 25px rgba(0,0,0,0.15)); }
</style>
