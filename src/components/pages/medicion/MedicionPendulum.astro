---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none medicion-pendulum-bg">
        <svg class="med-w-full med-h-full">
            <pattern
                id="floorTiles"
                x="0"
                y="0"
                width="40"
                height="40"
                patternUnits="userSpaceOnUse"
            >
                <rect width="40" height="40" fill="none" stroke="#3f3f46" stroke-width="1"></rect>
                <circle cx="20" cy="20" r="1" fill="#52525b"></circle>
            </pattern>
            <rect width="100%" height="100%" fill="url(#floorTiles)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Testigo Silencioso</span
                >
                <h2 class="med-title med-title-local">
                    El Péndulo de Foucault
                </h2>

                <p class="med-description med-description-local">
                    "Sin embargo, se mueve". Galileo lo dijo, pero Foucault lo demostró sin mirar al
                    cielo. Colgó una bola de latón de 28 kilos en el Panteón de París y esperó.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Tierra Gira Debajo</h3>
                    <p class="med-card-text med-card-text-local">
                        El péndulo mantiene su plano de oscilación fijo en el espacio. Es el suelo
                        el que gira bajo él.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Poco a poco, la oscilación parece rotar, derribando los pines colocados en
                        círculo. Es la prueba visual de que vivimos en un carrusel planetario.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 400" class="med-w-full med-h-full med-overflow-visible">
                        <g transform="translate(200, 320) scale(1, 0.4)">
                            <g class="animate-spin-floor">
                                <circle r="140" fill="none" stroke="#52525b" stroke-width="2"
                                ></circle>
                                <path
                                    d="M 0 -140 L 0 140 M -140 0 L 140 0"
                                    stroke="#3f3f46"
                                    stroke-width="1"></path>
                                <circle
                                    r="130"
                                    fill="none"
                                    stroke="#3f3f46"
                                    stroke-width="1"
                                    stroke-dasharray="4 4"></circle>

                                {
                                    Array.from({ length: 12 }).map((_, i) => (
                                        <g transform={`rotate(${i * 30}) translate(0, -130)`}>
                                            <rect
                                                x="-3"
                                                y="-10"
                                                width="6"
                                                height="20"
                                                fill="#ef4444"
                                            />
                                        </g>
                                    ))
                                }
                            </g>
                        </g>

                        <g transform="translate(200, 0)">
                            <g class="animate-swing-pendulum">
                                <line
                                    x1="0"
                                    y1="0"
                                    x2="0"
                                    y2="300"
                                    stroke="#d4d4d8"
                                    stroke-width="1"></line>

                                <circle cx="0" cy="300" r="12" fill="#fbbf24">
                                    <circle cx="-3" cy="-3" r="4" fill="white" opacity="0.5"
                                    ></circle>
                                </circle>
                            </g>
                        </g>

                        <path
                            d="M 100 320 Q 200 350 300 320"
                            fill="none"
                            stroke="#fbbf24"
                            stroke-width="2"
                            opacity="0.2"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #18181b;
        color: #e4e4e7;
    }

    .med-tag-local {
        color: #a1a1aa;
        border-color: #52525b;
    }

    .med-title-local {
        color: #f4f4f5;
    }

    .med-description-local {
        color: #d4d4d8;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #e4e4e7;
    }

    .med-card-text-local {
        color: #a1a1aa;
    }

    .med-card-note-local {
        color: #d4d4d8;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #27272a 50%, transparent);
        border-color: #3f3f46;
    }

    .medicion-pendulum-bg {
        opacity: 0.2;
    }

    @keyframes swingPendulum {
        0% {
            transform: rotate(15deg);
            animation-timing-function: ease-in-out;
        }
        50% {
            transform: rotate(-15deg);
            animation-timing-function: ease-in-out;
        }
        100% {
            transform: rotate(15deg);
            animation-timing-function: ease-in-out;
        }
    }
    .animate-swing-pendulum {
        animation: swingPendulum 3s infinite;
        transform-origin: 0 0;
    }

    @keyframes spinFloor {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
    .animate-spin-floor {
        animation: spinFloor 60s linear infinite;
    }
</style>
