---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-10">
        <svg class="med-w-full med-h-full">
            <pattern
                id="scalePattern"
                x="0"
                y="0"
                width="40"
                height="40"
                patternUnits="userSpaceOnUse"
            >
                <path
                    d="M 20 0 L 40 20 L 20 40 L 0 20 Z"
                    fill="none"
                    stroke="#a1a1aa"
                    stroke-width="1"></path>
            </pattern>
            <rect width="100%" height="100%" fill="url(#scalePattern)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Juicio del Peso</span
                >
                <h2 class="med-title med-title-local">La Balanza</h2>

                <p class="med-description med-description-local">
                    Antes de definir el "kilo", definimos la igualdad. La balanza no mide cuánto
                    pesa algo, sino si pesa lo mismo que otra cosa.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Semillas y Justicia</h3>
                    <p class="med-card-text med-card-text-local">
                        En Babilonia y Egipto, usaban semillas de algarrobo (quilates) o granos de
                        trigo como contrapesos.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Era el instrumento de los mercados y de los dioses: Anubis pesaba el corazón
                        del muerto contra la pluma de la verdad.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <g transform="translate(200, 250)">
                            <path d="M -40 0 L 40 0 L 20 -150 L -20 -150 Z" fill="#52525b"></path>
                            <rect x="-5" y="-200" width="10" height="200" fill="#71717a"></rect>
                            <circle cx="0" cy="-190" r="5" fill="#d4d4d8"></circle>
                        </g>

                        <g transform="translate(200, 60)" class="animate-balance-tip">
                            <rect x="-120" y="-5" width="240" height="10" rx="2" fill="#a1a1aa"
                            ></rect>

                            <line
                                x1="-110"
                                y1="0"
                                x2="-110"
                                y2="80"
                                stroke="#71717a"
                                stroke-width="1"></line>
                            <line
                                x1="-110"
                                y1="80"
                                x2="-130"
                                y2="120"
                                stroke="#71717a"
                                stroke-width="1"></line>
                            <line
                                x1="-110"
                                y1="80"
                                x2="-90"
                                y2="120"
                                stroke="#71717a"
                                stroke-width="1"></line>

                            <path
                                d="M -130 120 Q -110 140 -90 120"
                                fill="none"
                                stroke="#a1a1aa"
                                stroke-width="2"></path>

                            <path
                                d="M -110 120 Q -120 100 -110 90 Q -100 100 -110 120"
                                fill="#fff"
                                opacity="0.8"
                                transform="rotate(-10 -110 120)"></path>

                            <line x1="110" y1="0" x2="110" y2="80" stroke="#71717a" stroke-width="1"
                            ></line>
                            <line
                                x1="110"
                                y1="80"
                                x2="90"
                                y2="120"
                                stroke="#71717a"
                                stroke-width="1"></line>
                            <line
                                x1="110"
                                y1="80"
                                x2="130"
                                y2="120"
                                stroke="#71717a"
                                stroke-width="1"></line>

                            <path
                                d="M 90 120 Q 110 140 130 120"
                                fill="none"
                                stroke="#a1a1aa"
                                stroke-width="2"></path>

                            <path d="M 110 125 L 105 115 L 115 115 Z" fill="#ef4444"></path>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #27272a;
        color: #e4e4e7;
    }

    .med-tag-local {
        color: #a1a1aa;
        border-color: #52525b;
    }

    .med-title-local {
        color: #f4f4f5;
    }

    .med-description-local {
        color: #d4d4d8;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #3f3f46 50%, transparent);
        border-color: #52525b;
    }

    .med-card-title-local {
        color: #e4e4e7;
    }

    .med-card-text-local {
        color: #d4d4d8;
    }

    .med-card-note-local {
        color: #a1a1aa;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes balanceTip {
        0% {
            transform: translate(200px, 60px) rotate(0deg);
        }
        25% {
            transform: translate(200px, 60px) rotate(5deg);
        }
        75% {
            transform: translate(200px, 60px) rotate(-5deg);
        }
        100% {
            transform: translate(200px, 60px) rotate(0deg);
        }
    }
    .animate-balance-tip {
        animation: balanceTip 6s ease-in-out infinite;
    }
</style>
