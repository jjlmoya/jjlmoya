---

---

<section
    class="med-section med-section-local"
>
    <div class="med-background med-background-local">
        <svg class="med-w-full med-h-full">
            <filter id="turbulence">
                <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="3" result="noise"
                ></feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="20"></feDisplacementMap>
            </filter>
            <rect width="100%" height="100%" fill="#155e75" filter="url(#turbulence)" opacity="0.5">
                <animate
                    attributeName="opacity"
                    values="0.3; 0.5; 0.3"
                    dur="5s"
                    repeatCount="indefinite"></animate>
            </rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Fraude Real</span
                >
                <h2 class="med-title med-title-local">¡Eureka!</h2>

                <p class="med-description med-description-local">
                    El Rey Hierón II sospechaba que su corona no era de oro puro, sino que el
                    orfebre había robado parte y la había mezclado con plata. Pero, ¿cómo medir el
                    interior de un objeto sin destruirlo?
                </p>

                <div
                    class="med-card med-card-local med-card--left-border"
                >
                    <h3 class="med-card-title med-card-title-local">El Volumen Desplazado</h3>
                    <p class="med-card-text med-card-text-local">
                        Arquímedes se dio cuenta al entrar en su bañera: su cuerpo empujaba el agua.
                        El volumen de agua derramada era igual al volumen de su cuerpo.
                    </p>
                    <p class="med-mt-4 med-text-sm med-leading-relaxed" style="color: #cffafe;">
                        Si la corona desplazaba más agua que un lingote de oro del mismo peso,
                        significaba que era menos densa (tenía plata). El orfebre fue ejecutado.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg
                        viewBox="0 0 200 300"
                        class="med-w-full med-h-full med-overflow-visible" style="filter: drop-shadow(0 25px 25px rgba(0,0,0,0.15));"
                    >
                        <path
                            d="M 20 20 L 20 280 L 180 280 L 180 20"
                            fill="none"
                            stroke="#67e8f9"
                            stroke-width="2"
                            opacity="0.5"></path>

                        <path
                            d="M 25 275 L 175 275 L 175 100 L 25 100 Z"
                            fill="#0e7490"
                            opacity="0.6"
                            class="animate-water-rise"></path>

                        <g transform="translate(100, 50)" class="animate-crown-drop">
                            <path
                                d="M -30 0 L -30 40 L 30 40 L 30 0 L 15 20 L 0 0 L -15 20 Z"
                                fill="#fbbf24"
                                stroke="#b45309"
                                stroke-width="2"></path>
                            <circle cx="-15" cy="30" r="3" fill="#fef3c7"></circle>
                            <circle cx="15" cy="30" r="3" fill="#fef3c7"></circle>
                            <circle cx="0" cy="25" r="4" fill="#ef4444"></circle>
                        </g>

                        <g class="animate-splash">
                            <circle cx="50" cy="100" r="2" fill="#a5f3fc"></circle>
                            <circle cx="150" cy="90" r="3" fill="#a5f3fc"></circle>
                            <circle cx="40" cy="110" r="2" fill="#a5f3fc"></circle>
                        </g>

                        <line x1="180" y1="100" x2="190" y2="100" stroke="#22d3ee" stroke-width="1"
                        ></line>
                        <text x="195" y="103" fill="#22d3ee" font-size="8">GOLD</text>

                        <line
                            x1="180"
                            y1="80"
                            x2="190"
                            y2="80"
                            stroke="#ef4444"
                            stroke-width="1"
                            opacity="0"
                            class="animate-fake-line"></line>
                        <text
                            x="195"
                            y="83"
                            fill="#ef4444"
                            font-size="8"
                            opacity="0"
                            class="animate-fake-text">FAKE</text
                        >
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #083344;
        color: #cffafe;
    }

    .med-background-local {
        opacity: 0.2;
    }

    .med-tag-local {
        color: #22d3ee;
        border-color: #0e7490;
    }

    .med-title-local {
        color: #ecfeff;
    }

    .med-description-local {
        color: #cffafe;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #67e8f9;
    }

    .med-card-text-local {
        color: #cffafe;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #164e63 50%, transparent);
        border-color: #06b6d4;
    }

    @keyframes crownDrop {
        0% {
            transform: translate(100px, 0);
        }
        40% {
            transform: translate(100px, 200px);
        }
        100% {
            transform: translate(100px, 200px);
        }
    }
    .animate-crown-drop {
        animation: crownDrop 4s ease-in-out infinite;
    }

    @keyframes waterRise {
        0% {
            d: path("M 25 275 L 175 275 L 175 150 L 25 150 Z");
        }
        40% {
            d: path("M 25 275 L 175 275 L 175 80 L 25 80 Z");
        }
        100% {
            d: path("M 25 275 L 175 275 L 175 80 L 25 80 Z");
        }
    }
    .animate-water-rise {
        animation: waterRise 4s ease-in-out infinite;
    }

    @keyframes splash {
        0%,
        35% {
            opacity: 0;
            transform: translateY(0);
        }
        40% {
            opacity: 1;
            transform: translateY(-20px);
        }
        60% {
            opacity: 0;
            transform: translateY(-10px);
        }
        100% {
            opacity: 0;
        }
    }
    .animate-splash circle {
        animation: splash 4s ease-in-out infinite;
    }

    @keyframes fadeIn {
        0%,
        40% {
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
        100% {
            opacity: 1;
        }
    }
    .animate-fake-line,
    .animate-fake-text {
        animation: fadeIn 4s ease-in-out infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 20rem; display: flex; align-items: flex-end; justify-content: center; }
</style>
