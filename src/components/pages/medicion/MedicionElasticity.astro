---

---

<section
    class="med-section med-section-local"
>
    <div
        class="med-absolute med-inset-0 med-opacity-10"
        style="background-image: radial-gradient(#d6d3d1 1px, transparent 1px); background-size: 20px 20px;"
    >
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Fuerza Invisible</span
                >
                <h2 class="med-title med-title-local">
                    Ut Tensio, Sic Vis
                </h2>

                <p class="med-description med-description-local">
                    "Como la extensión, así la fuerza". Robert Hooke descubrió en 1660 que la
                    naturaleza es elástica.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Constante Elástica (k)</h3>
                    <p class="med-card-text med-card-text-local">
                        Hooke nos dio la fórmula: <strong>F = -kx</strong>. Ahora no solo sabíamos
                        que se estiraba, podíamos medir exactamente <em>cuánto</em> se resistía un material.
                    </p>
                    <p class="med-mt-4 med-text-sm med-leading-relaxed" style="color: #e7e5e4;">
                        Medimos la rigidez en <strong>Newtons por metro (N/m)</strong>. Esta
                        linealidad permitió crear balanzas precisas y el volante regulador de los
                        relojes.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 100 400" class="med-w-full med-h-full med-overflow-visible">
                        <rect x="30" y="0" width="40" height="10" fill="#57534e"></rect>

                        <path
                            fill="none"
                            stroke="#d6d3d1"
                            stroke-width="4"
                            stroke-linecap="round"
                            class="animate-spring-stretch"></path>

                        <g class="animate-weight-bob">
                            <rect
                                x="25"
                                y="0"
                                width="50"
                                height="50"
                                rx="5"
                                fill="#44403c"
                                stroke="#a8a29e"
                                stroke-width="2"></rect>
                            <text
                                x="50"
                                y="30"
                                text-anchor="middle"
                                fill="#d6d3d1"
                                font-size="12"
                                font-weight="bold">10N</text
                            >
                        </g>

                        <g transform="translate(80, 0)">
                            <line x1="0" y1="0" x2="0" y2="400" stroke="#57534e" stroke-width="1"
                            ></line>
                            {
                                Array.from({ length: 20 }).map((_, i) => (
                                    <line
                                        x1="0"
                                        y1={i * 20}
                                        x2={i % 5 === 0 ? 10 : 5}
                                        y2={i * 20}
                                        stroke="#78716c"
                                        stroke-width="1"
                                    />
                                ))
                            }

                            <path
                                d="M -5 0 L -15 -5 L -15 5 Z"
                                fill="#ef4444"
                                class="animate-indicator"></path>

                            <text
                                x="10"
                                y="200"
                                fill="#a8a29e"
                                font-size="10"
                                transform="rotate(90 10 200)">Δx (m)</text
                            >
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1c1917;
        color: #e7e5e4;
    }

    .med-tag-local {
        color: #a8a29e;
        border-color: #57534e;
    }

    .med-title-local {
        color: #f5f5f4;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #292524 50%, transparent);
        border-color: #44403c;
    }

    .med-card-title-local {
        color: #d6d3d1;
    }

    .med-card-text-local {
        color: #e7e5e4;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes springStretch {
        0% {
            d: path(
                "M 50 10 L 70 20 L 30 30 L 70 40 L 30 50 L 70 60 L 30 70 L 70 80 L 30 90 L 50 100"
            );
        }
        50% {
            d: path(
                "M 50 10 L 70 30 L 30 50 L 70 70 L 30 90 L 70 110 L 30 130 L 70 150 L 30 170 L 50 190"
            );
        }
        100% {
            d: path(
                "M 50 10 L 70 20 L 30 30 L 70 40 L 30 50 L 70 60 L 30 70 L 70 80 L 30 90 L 50 100"
            );
        }
    }
    .animate-spring-stretch {
        animation: springStretch 2s ease-in-out infinite;
    }

    @keyframes weightBob {
        0% {
            transform: translateY(100px);
        }
        50% {
            transform: translateY(190px);
        }
        100% {
            transform: translateY(100px);
        }
    }
    .animate-weight-bob {
        animation: weightBob 2s ease-in-out infinite;
    }

    @keyframes indicatorMove {
        0% {
            transform: translateY(125px);
        }
        50% {
            transform: translateY(215px);
        }
        100% {
            transform: translateY(125px);
        }
    }
    .animate-indicator {
        animation: indicatorMove 2s ease-in-out infinite;
    }

    .med-visual-sizer { position: relative; width: 12rem; height: 100%; display: flex; justify-content: center; }
</style>
