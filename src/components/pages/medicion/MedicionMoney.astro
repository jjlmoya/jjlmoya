---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-5">
        <div class="med-absolute med-text-9xl med-font-serif" style="top: 2.5rem; left: 2.5rem;">$</div>
        <div class="med-absolute med-text-9xl med-font-serif" style="bottom: 5rem; right: 5rem;">€</div>
        <div class="med-absolute med-text-9xl med-font-serif" style="top: 10rem; right: 10rem;">£</div>
        <div class="med-absolute med-text-9xl med-font-serif" style="bottom: 10rem; left: 10rem;">¥</div>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Medida del Deseo</span
                >
                <h2 class="med-title med-title-local">El Dinero</h2>

                <p class="med-description med-description-local">
                    No mide átomos ni segundos. Mide confianza. Es una alucinación compartida que
                    nos permite colaborar con extraños.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Del Oro al Bit</h3>
                    <p class="med-card-text med-card-text-local">
                        Empezamos pesando metales. Luego usamos papel que representaba metal. Ahora
                        movemos dígitos en servidores. La materia ha desaparecido, solo queda el
                        valor puro.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Es la métrica más universal y la única capaz de convertir el tiempo de un
                        hombre en la cena de otro.
                    </p>
                </div>
            </div>

            <div class="med-w-full med-w-1\/2\@md med-flex med-justify-center med-relative perspective-1000" style="height: 400px;">
                <div class="med-visual-sizer coin-wrapper">
                    <div class="coin animate-spin-3d">
                        {
                            Array.from({ length: 16 }).map((_, i) => {
                                const zOffset = (i - 7.5) * 1.5;
                                const isFace = i === 0 || i === 15;
                                const brightness = isFace ? 1 : 0.7;

                                return (
                                        <div
                                            class="med-absolute med-inset-0 coin-layer"
                                        style={`--z: ${zOffset}px; --brightness: ${brightness};`}
                                    >
                                        <svg viewBox="0 0 200 200" class="med-w-full med-h-full">
                                            <defs>
                                                <linearGradient
                                                    id={`goldGrad${i}`}
                                                    x1="0%"
                                                    y1="0%"
                                                    x2="100%"
                                                    y2="100%"
                                                >
                                                    <stop offset="0%" stop-color="#fcd34d" />
                                                    <stop offset="50%" stop-color="#d97706" />
                                                    <stop offset="100%" stop-color="#b45309" />
                                                </linearGradient>
                                            </defs>

                                            <circle
                                                cx="100"
                                                cy="100"
                                                r="95"
                                                fill={`url(#goldGrad${i})`}
                                                stroke="#78350f"
                                                stroke-width={isFace ? 2 : 0}
                                            />

                                            {isFace && (
                                                <g>
                                                    <circle
                                                        cx="100"
                                                        cy="100"
                                                        r="85"
                                                        fill="none"
                                                        stroke="#78350f"
                                                        stroke-width="1"
                                                        opacity="0.5"
                                                    />
                                                    <circle
                                                        cx="100"
                                                        cy="100"
                                                        r="80"
                                                        fill="none"
                                                        stroke="#78350f"
                                                        stroke-width="3"
                                                        stroke-dasharray="1 5"
                                                        opacity="0.3"
                                                    />

                                                    <g transform="translate(100, 100)">
                                                        {Array.from({ length: 12 }).map((_, j) => (
                                                            <path
                                                                d="M 0 -60 L 10 -20 L 0 -15 L -10 -20 Z"
                                                                fill="#78350f"
                                                                opacity="0.8"
                                                                transform={`rotate(${j * 30})`}
                                                            />
                                                        ))}

                                                        <circle
                                                            cx="0"
                                                            cy="0"
                                                            r="25"
                                                            fill="#78350f"
                                                            opacity="0.9"
                                                        />
                                                        <circle
                                                            cx="0"
                                                            cy="0"
                                                            r="15"
                                                            fill="#fcd34d"
                                                            opacity="0.4"
                                                        />
                                                    </g>
                                                </g>
                                            )}
                                        </svg>
                                    </div>
                                );
                            })
                        }
                    </div>

                    <div class="med-absolute med-inset-0 med-pointer-events-none animate-digital-pulse med-z-20">
                        <svg viewBox="0 0 400 400" class="med-w-full med-h-full">
                            <g transform="translate(100, 100) scale(0.5)">
                                <circle
                                    cx="200"
                                    cy="200"
                                    r="140"
                                    fill="none"
                                    stroke="#4ade80"
                                    stroke-width="2"
                                    opacity="0.3"
                                    stroke-dasharray="20 10"></circle>
                                <circle cx="200" cy="80" r="8" fill="#4ade80"></circle>
                                <circle cx="320" cy="200" r="8" fill="#4ade80"></circle>
                                <circle cx="200" cy="320" r="8" fill="#4ade80"></circle>
                                <circle cx="80" cy="200" r="8" fill="#4ade80"></circle>
                                <line
                                    x1="200"
                                    y1="80"
                                    x2="320"
                                    y2="200"
                                    stroke="#4ade80"
                                    stroke-width="2"
                                    opacity="0.3"></line>
                                <line
                                    x1="320"
                                    y1="200"
                                    x2="200"
                                    y2="320"
                                    stroke="#4ade80"
                                    stroke-width="2"
                                    opacity="0.3"></line>
                                <line
                                    x1="200"
                                    y1="320"
                                    x2="80"
                                    y2="200"
                                    stroke="#4ade80"
                                    stroke-width="2"
                                    opacity="0.3"></line>
                                <line
                                    x1="80"
                                    y1="200"
                                    x2="200"
                                    y2="80"
                                    stroke="#4ade80"
                                    stroke-width="2"
                                    opacity="0.3"></line>
                            </g>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #022c22;
        color: #ecfccb;
    }

    .med-tag-local {
        color: #84cc16;
        border-color: #3f6212;
    }

    .med-title-local {
        color: #f7fee7;
    }

    .med-description-local {
        color: #d9f99d;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #ecfccb;
    }

    .med-card-text-local {
        color: #bef264;
    }

    .med-card-note-local {
        color: #84cc16;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #064e3b 50%, transparent);
        border-color: #65a30d;
    }

    .perspective-1000 {
        perspective: 1000px;
    }

    .coin-wrapper {
        transform-style: preserve-3d;
    }

    .coin {
        position: relative;
        width: 100%;
        height: 100%;
        transform-style: preserve-3d;
    }

    .coin-layer {
        backface-visibility: visible;
        transform: translateZ(var(--z));
        filter: brightness(var(--brightness));
    }

    @keyframes spin3d {
        0% {
            transform: rotateY(0deg) rotateX(10deg);
        }
        100% {
            transform: rotateY(360deg) rotateX(10deg);
        }
    }
    .animate-spin-3d {
        animation: spin3d 6s linear infinite;
    }

    @keyframes digitalPulse {
        0% {
            opacity: 0;
            transform: scale(1);
        }
        50% {
            opacity: 1;
            transform: scale(1.1);
        }
        100% {
            opacity: 0;
            transform: scale(1.2);
        }
    }
    .animate-digital-pulse {
        animation: digitalPulse 4s ease-in-out infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 16rem; display: flex; align-items: center; justify-content: center; }
</style>
