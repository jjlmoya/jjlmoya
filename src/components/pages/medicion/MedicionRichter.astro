---

---

<section
    class="med-section med-section-local"
>
    <div
        class="med-absolute med-inset-0 medicion-richter-grid"
        style="background-image: linear-gradient(#4b5563 1px, transparent 1px), linear-gradient(90deg, #4b5563 1px, transparent 1px); background-size: 40px 40px;"
    >
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Tierra Tiembla</span
                >
                <h2 class="med-text-4xl med-font-bold med-tracking-tight medicion-richter-title">
                    La Escala Richter
                </h2>

                <p class="med-text-lg medicion-richter-body">
                    La tierra se mueve constantemente, pero solo sentimos lo catastrófico. Charles
                    Richter quería medir la energía liberada, no solo el daño visible.
                </p>

                <div class="med-card med-card-local">
                    <h3 class="med-font-bold med-mb-2 medicion-richter-card-title">Logaritmos de Destrucción</h3>
                    <p class="med-card-text med-card-text-local">
                        Como el sonido, los terremotos crecen exponencialmente. Un terremoto de
                        magnitud 5 es <strong>10 veces</strong> más fuerte que uno de 4. Y libera <strong
                            >32 veces</strong
                        > más energía.
                    </p>
                    <div class="med-mt-4 medicion-richter-bar-bg med-overflow-hidden">
                        <div class="medicion-richter-bar-fill animate-quake-bar"></div>
                    </div>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div
                    class="med-relative med-w-full med-h-full medicion-richter-visual"
                >
                    <svg viewBox="0 0 400 200" class="med-w-full med-h-full">
                        <defs>
                            <clipPath id="paperClip">
                                <rect x="0" y="0" width="350" height="200"></rect>
                            </clipPath>

                            <path
                                id="waveSegment"
                                d="M 0 100 
                                     L 20 100 
                                     L 30 95 L 40 105 L 50 100 
                                     L 80 100 
                                     L 90 50 L 100 150 L 110 100 
                                     L 200 100"
                                fill="none"
                                stroke="#ef4444"
                                stroke-width="2"
                                stroke-linejoin="round"></path>
                        </defs>

                        <g clip-path="url(#paperClip)">
                            <g class="animate-scroll-paper">
                                {
                                    Array.from({ length: 20 }).map((_, i) => (
                                        <line
                                            x1={i * 40}
                                            y1="0"
                                            x2={i * 40}
                                            y2="200"
                                            stroke="#1f2937"
                                            stroke-width="1"
                                        />
                                    ))
                                }
                                <line
                                    x1="0"
                                    y1="100"
                                    x2="800"
                                    y2="100"
                                    stroke="#1f2937"
                                    stroke-width="1"></line>

                                <use href="#waveSegment" x="-250"></use>
                                <use href="#waveSegment" x="-50"></use>
                                <use href="#waveSegment" x="150"></use>
                                <use href="#waveSegment" x="350"></use>
                                <use href="#waveSegment" x="550"></use>
                            </g>
                        </g>

                        <rect
                            x="350"
                            y="10"
                            width="40"
                            height="180"
                            rx="5"
                            fill="#374151"
                            stroke="#4b5563"></rect>
                        <line x1="370" y1="10" x2="370" y2="190" stroke="#1f2937" stroke-width="2"
                        ></line>

                        <g>
                            <circle cx="370" cy="100" r="5" fill="#9ca3af"></circle>

                            <line
                                x1="370"
                                y1="100"
                                x2="350"
                                y2="100"
                                stroke="#9ca3af"
                                stroke-width="3"
                                class="animate-needle-arm"></line>

                            <circle
                                cx="350"
                                cy="100"
                                r="3"
                                fill="#ef4444"
                                class="animate-needle-tip"></circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1f2937;
        color: #e5e7eb;
    }

    .med-tag-local {
        color: #9ca3af;
        border-color: #4b5563;
    }

    .med-card-text-local {
        color: #d1d5db;
    }

    .med-visual-column-local {
        height: 300px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #374151 50%, transparent);
        border-color: #4b5563;
    }

    .medicion-richter-grid {
        opacity: 0.1;
    }

    .medicion-richter-title {
        color: #ffffff;
    }

    .medicion-richter-body {
        color: #d1d5db;
        line-height: 1.625;
    }

    .medicion-richter-card-title {
        color: #ffffff;
    }

    .medicion-richter-bar-bg {
        height: 4px;
        width: 100%;
        background-color: #4b5563;
        border-radius: 9999px;
        overflow: hidden;
    }

    .medicion-richter-bar-fill {
        height: 100%;
    }

    .medicion-richter-visual {
        background-color: #111827;
        border: 1px solid #374151;
        border-radius: 0.5rem;
        overflow: hidden;
        display: flex;
        align-items: center;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    @keyframes quakeBar {
        0%,
        90% {
            width: 1%;
            background-color: #22c55e;
        }
        92% {
            width: 40%;
            background-color: #eab308;
        }
        95% {
            width: 90%;
            background-color: #ef4444;
        }
        100% {
            width: 1%;
            background-color: #22c55e;
        }
    }
    .animate-quake-bar {
        animation: quakeBar 4s infinite;
    }

    @keyframes scrollPaper {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-200px);
        }
    }
    .animate-scroll-paper {
        animation: scrollPaper 2s linear infinite;
    }

    @keyframes needleVertical {
        0% {
            transform: translateY(0);
        }
        10% {
            transform: translateY(0);
        }
        15% {
            transform: translateY(-5px);
        }
        20% {
            transform: translateY(5px);
        }
        25% {
            transform: translateY(0);
        }
        40% {
            transform: translateY(0);
        }
        45% {
            transform: translateY(-50px);
        }
        50% {
            transform: translateY(50px);
        }
        55% {
            transform: translateY(0);
        }
        100% {
            transform: translateY(0);
        }
    }
    .animate-needle-tip {
        animation: needleVertical 2s linear infinite;
    }
    .animate-needle-arm {
        animation: needleVertical 2s linear infinite;
        transform-box: fill-box;
    }
</style>
