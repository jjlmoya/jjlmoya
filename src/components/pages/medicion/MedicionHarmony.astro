---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-10">
        <svg class="med-w-full med-h-full">
            <pattern
                id="wavePattern"
                x="0"
                y="0"
                width="100"
                height="20"
                patternUnits="userSpaceOnUse"
            >
                <path d="M 0 10 Q 25 0 50 10 T 100 10" fill="none" stroke="#6366f1" stroke-width="1"
                ></path>
            </pattern>
            <rect width="100%" height="100%" fill="url(#wavePattern)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Alma de los Números</span
                >
                <h2 class="med-title med-title-local">La Armonía</h2>

                <p class="med-description med-description-local">
                    ¿Por qué algo nos parece bello? Pitágoras descubrió que la belleza no es una
                    opinión, es una proporción.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Música de las Esferas</h3>
                    <p class="med-card-text med-card-text-local">
                        Al dividir una cuerda tensa por la mitad (1:2), suena la misma nota, pero
                        más aguda (Octava). Si la divides en 2:3, obtienes la Quinta Perfecta.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        El universo no estaba hecho de fuego o aire, sino de números. Medir la
                        cuerda era medir el alma del cosmos.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <rect x="0" y="140" width="400" height="20" fill="#4b5563"></rect>

                        <path d="M 20 140 L 30 120 L 40 140 Z" fill="#9ca3af"></path>

                        <path d="M 360 140 L 370 120 L 380 140 Z" fill="#9ca3af"></path>

                        <g>
                            <path
                                d="M 30 120 Q 200 80 370 120"
                                fill="none"
                                stroke="#818cf8"
                                stroke-width="2"
                                opacity="0.3"
                            >
                                <animate
                                    attributeName="d"
                                    values="M 30 120 Q 200 80 370 120; M 30 120 Q 200 160 370 120; M 30 120 Q 200 80 370 120"
                                    dur="0.1s"
                                    repeatCount="indefinite"></animate>
                            </path>

                            <path
                                d="M 30 120 Q 115 100 200 120 T 370 120"
                                fill="none"
                                stroke="#c084fc"
                                stroke-width="3"
                                class="animate-vibrate-octave"></path>
                        </g>

                        <g transform="translate(200, 140)">
                            <path d="M -10 0 L 0 -20 L 10 0 Z" fill="#fbbf24"></path>
                            <text x="0" y="20" text-anchor="middle" fill="#fbbf24" font-size="12"
                                >1:2</text
                            >
                        </g>

                        <g transform="translate(0, 200)" font-size="10" fill="#6b7280">
                            <text x="30" y="0">0</text>
                            <text x="200" y="0" text-anchor="middle" fill="#fbbf24"
                                >1/2 (OCTAVA)</text
                            >
                            <text x="370" y="0" text-anchor="end">1</text>
                        </g>

                        <g>
                            <text x="100" y="100" fill="#818cf8" font-size="20" opacity="0"
                                >♪
                                <animate
                                    attributeName="y"
                                    values="100; 50"
                                    dur="2s"
                                    repeatCount="indefinite"></animate>
                                <animate
                                    attributeName="opacity"
                                    values="0; 1; 0"
                                    dur="2s"
                                    repeatCount="indefinite"></animate>
                            </text>
                            <text x="300" y="120" fill="#c084fc" font-size="24" opacity="0"
                                >♫
                                <animate
                                    attributeName="y"
                                    values="120; 60"
                                    dur="2.5s"
                                    begin="1s"
                                    repeatCount="indefinite"></animate>
                                <animate
                                    attributeName="opacity"
                                    values="0; 1; 0"
                                    dur="2.5s"
                                    begin="1s"
                                    repeatCount="indefinite"></animate>
                            </text>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #111827;
        color: #e5e7eb;
    }

    .med-tag-local {
        color: #818cf8;
        border-color: #4338ca;
    }

    .med-title-local {
        color: #e0e7ff;
    }

    .med-description-local {
        color: #c7d2fe;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #a5b4fc;
    }

    .med-card-text-local {
        color: #e0e7ff;
    }

    .med-card-note-local {
        color: #818cf8;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #1e1b4b 50%, transparent);
        border-color: #4f46e5;
    }

    @keyframes vibrateOctave {
        0% {
            d: path("M 30 120 Q 115 100 200 120 T 370 120");
        }
        50% {
            d: path("M 30 120 Q 115 140 200 120 T 370 120");
        }
        100% {
            d: path("M 30 120 Q 115 100 200 120 T 370 120");
        }
    }
    .animate-vibrate-octave {
        animation: vibrateOctave 0.05s linear infinite;
    }
</style>
