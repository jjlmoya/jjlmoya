---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-30">
        <div
            class="med-absolute med-top-0 animate-spin-slow" style="left: 50%; transform: translateX(-50%); width: 150%; height: 150%; background: conic-gradient(from 180deg,transparent 0deg,#fdba74 20deg,transparent 40deg);"
        >
        </div>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Sombra del Mundo</span
                >
                <h2 class="med-title med-title-local">
                    El Palo y la Tierra
                </h2>

                <p class="med-description med-description-local">
                    Hace 2.200 años, Eratóstenes midió el tamaño de la Tierra sin salir de Egipto.
                    Solo necesitó un palo, un pozo y un camello.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">7 Grados de Diferencia</h3>
                    <p class="med-card-text med-card-text-local">
                        En Siena, el sol de mediodía iluminaba el fondo de un pozo (0° sombra). A la
                        misma hora en Alejandría, un obelisco proyectaba una sombra de 7.2°.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Por geometría simple, si la sombra es de 7.2° (1/50 de un círculo), la
                        distancia entre las ciudades es 1/50 de la Tierra.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-hidden med-rounded-lg">
                        <defs>
                            <linearGradient id="earthGradient" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#fdba74"></stop>
                                <stop offset="100%" stop-color="#7c2d12"></stop>
                            </linearGradient>
                            <linearGradient id="rayGradient" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.6"></stop>
                                <stop offset="100%" stop-color="#fbbf24" stop-opacity="0"></stop>
                            </linearGradient>
                            <clipPath id="earthClip">
                                <rect x="0" y="0" width="400" height="300"></rect>
                            </clipPath>
                        </defs>

                        <g clip-path="url(#earthClip)">
                            <circle cx="150" cy="800" r="600" fill="url(#earthGradient)"></circle>
                        </g>

                        <g stroke="url(#rayGradient)" stroke-width="1.5">
                            {
                                Array.from({ length: 20 }).map((_, i) => (
                                    <line x1={i * 25} y1="-50" x2={i * 25} y2="250" />
                                ))
                            }
                        </g>

                        <g transform="translate(150, 200)">
                            <rect x="-12" y="0" width="24" height="8" fill="#7c2d12"></rect>
                            <rect x="-8" y="0" width="16" height="8" fill="#431407"></rect>

                            <line
                                x1="0"
                                y1="-100"
                                x2="0"
                                y2="8"
                                stroke="#fbbf24"
                                stroke-width="3"
                                stroke-opacity="0.8"></line>

                            <text
                                x="0"
                                y="25"
                                text-anchor="middle"
                                fill="#7c2d12"
                                font-size="10"
                                font-weight="bold">SIENA</text
                            >
                            <text x="0" y="35" text-anchor="middle" fill="#ea580c" font-size="9"
                                >0°</text
                            >
                        </g>

                        <g transform="translate(355, 236) rotate(20)">
                            <path d="M -4 0 L 0 -50 L 4 0 Z" fill="#7c2d12"></path>

                            <path d="M 0 0 L 18 0" stroke="#431407" stroke-width="3" opacity="0.5"
                            ></path>

                            <line
                                x1="0"
                                y1="-70"
                                x2="0"
                                y2="0"
                                stroke="#fbbf24"
                                stroke-width="1"
                                stroke-dasharray="3 3"
                                transform="rotate(-20)"></line>

                            <path
                                d="M 0 -30 Q 4 -30 6 -24"
                                fill="none"
                                stroke="#ea580c"
                                stroke-width="2"></path>
                            <text
                                x="12"
                                y="-30"
                                fill="#ea580c"
                                font-size="12"
                                font-weight="bold"
                                transform="rotate(-20)">7.2°</text
                            >

                            <text x="0" y="20" text-anchor="middle" fill="#7c2d12" font-size="10"
                                >ALEJANDRÍA</text
                            >
                        </g>

                        <path
                            d="M 150 180 Q 252 160 355 216"
                            fill="none"
                            stroke="#ea580c"
                            stroke-width="2"
                            stroke-dasharray="4 4"></path>
                        <rect
                            x="230"
                            y="170"
                            width="80"
                            height="16"
                            fill="#fff7ed"
                            rx="4"
                            opacity="0.9"></rect>
                        <text
                            x="270"
                            y="181"
                            text-anchor="middle"
                            fill="#ea580c"
                            font-size="10"
                            font-weight="bold">5000 ESTADIOS</text
                        >
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #fff7ed;
        color: #7c2d12;
    }

    .med-tag-local {
        color: #ea580c;
        border-color: #9a3412;
    }

    .med-title-local {
        color: #431407;
    }

    .med-description-local {
        color: #9a3412;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #ffedd5 50%, transparent);
        border-color: #fdba74;
    }

    .med-card-title-local {
        color: #c2410c;
    }

    .med-card-text-local {
        color: #7c2d12;
    }

    .med-card-note-local {
        color: #ea580c;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes spinSlow {
        from {
            transform: translate(-50%, 0) rotate(0deg);
        }
        to {
            transform: translate(-50%, 0) rotate(360deg);
        }
    }
    .animate-spin-slow {
        animation: spinSlow 60s linear infinite;
    }
</style>
