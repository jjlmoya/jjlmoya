---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-10">
        <svg class="med-w-full med-h-full">
            <pattern
                id="piPattern"
                x="0"
                y="0"
                width="60"
                height="60"
                patternUnits="userSpaceOnUse"
            >
                <circle cx="30" cy="30" r="2" fill="#5eead4"></circle>
                <path d="M 0 30 L 60 30 M 30 0 L 30 60" stroke="#2dd4bf" stroke-width="0.5"></path>
            </pattern>
            <rect width="100%" height="100%" fill="#115e59" filter="url(#piPattern)"></rect>
        </svg>
    </div>

    <div class="med-container med-container--xwide">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Límite Inalcanzable</span
                >
                <h2 class="med-title med-title-local">
                    La Paradoja de Pi
                </h2>

                <p class="med-description med-description-local">
                    ¿Cuántas veces cabe el diámetro en su circunferencia? Tres veces, y un poco más.
                    Ese "poco más" es un abismo infinito.
                </p>

                <div class="med-grid-cols-1 med-grid-cols-2@md med-gap-4 med-mt-6">
                    <div
                        class="med-card-teal med-p-4 med-rounded-sm med-border med-transition med-duration-300"
                    >
                        <h3 class="med-text-teal-50 med-font-bold med-mb-1 med-text-lg">3.14159...</h3>
                        <p class="med-text-xs med-text-teal-200 med-leading-relaxed">
                            No solo es infinito, es irracional. Ninguna fracción 22/7 puede
                            contenerlo. Es una verdad que no se puede escribir.
                        </p>
                    </div>

                    <div
                        class="med-card-teal med-p-4 med-rounded-sm med-border med-transition med-duration-300"
                    >
                        <h3 class="med-text-teal-50 med-font-bold med-mb-1 med-text-lg">Exhaustión</h3>
                        <p class="med-text-xs med-text-teal-200 med-leading-relaxed">
                            Arquímedes atrapó al círculo entre polígonos. 96 lados le dieron 3.14.
                            Pero el círculo siempre escapa entre los vértices.
                        </p>
                    </div>

                    <div
                        class="med-card-teal med-p-4 med-rounded-sm med-border med-transition med-duration-300 med-col-span-2"
                    >
                        <h3 class="med-text-teal-50 med-font-bold med-mb-1 med-text-lg">Trascendente</h3>
                        <p class="med-text-xs med-text-teal-200 med-leading-relaxed">
                            Pi no es la raíz de ninguna ecuación algebraica simple. Es un número que
                            existe fuera de las reglas básicas del álgebra, un recordatorio de que
                            el universo es más complejo que nuestras fórmulas.
                        </p>
                    </div>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 400" class="med-w-full med-h-full med-overflow-visible">
                        <circle
                            cx="200"
                            cy="200"
                            r="150"
                            fill="none"
                            stroke="#5eead4"
                            stroke-width="1"
                            opacity="0.2"></circle>

                        <circle cx="200" cy="200" r="3" fill="#f0fdfa"></circle>

                        <g transform="translate(200, 200)">
                            <polygon
                                points="0,-150 150,0 0,150 -150,0"
                                fill="none"
                                stroke="#f0fdfa"
                                stroke-width="2"
                                class="polygon-anim"
                                style="animation-delay: 0s;"></polygon>

                            <polygon
                                points="150,0 75,129.9 -75,129.9 -150,0 -75,-129.9 75,-129.9"
                                fill="none"
                                stroke="#f0fdfa"
                                stroke-width="2"
                                class="polygon-anim"
                                style="animation-delay: 2s;"></polygon>

                            <polygon
                                points="150,0 129.9,75 75,129.9 0,150 -75,129.9 -129.9,75 -150,0 -129.9,-75 -75,-129.9 0,-150 75,-129.9 129.9,-75"
                                fill="none"
                                stroke="#f0fdfa"
                                stroke-width="2"
                                class="polygon-anim"
                                style="animation-delay: 4s;"></polygon>

                            <circle
                                r="150"
                                fill="none"
                                stroke="#2dd4bf"
                                stroke-width="3"
                                class="polygon-anim"
                                style="animation-delay: 6s;"></circle>
                        </g>

                        <text
                            x="200"
                            y="380"
                            text-anchor="middle"
                            class="med-text-sm med-font-mono med-svg-fill med-tracking-widest med-uppercase"
                        >
                            <tspan class="text-anim" style="animation-delay: 0s;">n = 4</tspan>
                            <tspan class="text-anim" style="animation-delay: 2s;">n = 6</tspan>
                            <tspan class="text-anim" style="animation-delay: 4s;">n = 12</tspan>
                            <tspan class="text-anim" style="animation-delay: 6s;">n = ∞</tspan>
                        </text>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #022c22;
        color: #ccfbf1;
    }

    .med-tag-local {
        color: #5eead4;
        border-color: #2dd4bf;
    }

    .med-title-local {
        color: #f0fdfa;
    }

    .med-description-local {
        color: #ccfbf1;
        opacity: 0.9;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-teal { background-color: rgba(19, 78, 74, 0.6); border-color: rgba(45, 212, 191, 0.3); backdrop-filter: blur(4px); }
    .med-card-teal:hover { transform: translateY(-0.25rem); }
    .med-text-teal-50 { color: #f0fdfa; }
    .med-text-teal-200 { color: #99f6e4; }
    .med-svg-fill { fill: #5eead4; }

    .polygon-anim,
    .text-anim {
        animation-name: sequenceFade;
        animation-duration: 8s;
        animation-iteration-count: infinite;
        opacity: 0;
    }

    @keyframes sequenceFade {
        0%,
        20% {
            opacity: 1;
        }
        25%,
        100% {
            opacity: 0;
        }
    }

    .polygon-anim:nth-child(1),
    .text-anim:nth-child(1) {
        animation-delay: 0s;
    }
    .polygon-anim:nth-child(2),
    .text-anim:nth-child(2) {
        animation-delay: 2s;
    }
    .polygon-anim:nth-child(3),
    .text-anim:nth-child(3) {
        animation-delay: 4s;
    }
    .polygon-anim:nth-child(4),
    .text-anim:nth-child(4) {
        animation-delay: 6s;
    }
</style>
