---

---

<section
    class="med-section med-section-local"
>
    <div class="med-background med-background-local">
        <div
            class="med-nilo-bg animate-tide"
        >
        </div>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Medida de la Vida</span
                >
                <h2 class="med-title med-title-local">El Nilómetro</h2>

                <p class="med-description med-description-local">
                    En el Antiguo Egipto, medir no era solo curiosidad; era supervivencia. Cada año,
                    el Nilo decidía el destino del imperio.
                </p>

                <div
                    class="med-card med-card--left-border med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Escala del Faraón</h3>
                    <p class="med-card-text med-card-text-local">
                        Construyeron pozos con columnas graduadas para medir la crecida del río. El
                        nivel del agua dictaba los impuestos del año siguiente.
                    </p>
                    <ul class="med-list med-list-local">
                        <li class="med-list-item">
                            <div class="med-dot med-dot--red"></div>
                            <span>12 Codos: Hambre (Sequía)</span>
                        </li>
                        <li class="med-list-item">
                            <div class="med-dot med-dot--green"></div>
                            <span>14 Codos: Abundancia (Impuestos altos)</span>
                        </li>
                        <li class="med-list-item">
                            <div class="med-dot med-dot--red"></div>
                            <span>16 Codos: Desastre (Inundación)</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div
                    class="med-pozo med-pozo-local"
                >
                    <div
                        class="med-pozo-inner med-pozo-inner-local"
                    >
                        {
                            Array.from({ length: 16 }).map((_, i) => (
                                <div class="med-nilo-mark">
                                    <span class="med-nilo-mark-label">
                                        {16 - i}
                                    </span>
                                </div>
                            ))
                        }
                    </div>

                    <div
                        class="med-flood-level med-flood-level-local animate-flood"
                    >
                        <div class="med-nilo-line"></div>
                        <div class="med-nilo-line-2"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #0c1218;
        color: #a8b3cf;
    }

    .med-background-local {
        opacity: 0.2;
    }

    .med-tag-local {
        color: #60a5fa;
        border-color: #1e40af;
    }

    .med-title-local {
        color: #e0f2fe;
    }

    .med-description-local {
        color: #cbd5e1;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #172554 40%, transparent);
        border-left-color: #3b82f6;
    }

    .med-card-title-local {
        color: #93c5fd;
    }

    .med-card-text-local {
        color: #dbeafe;
    }

    .med-list-local {
        color: #60a5fa;
    }

    .med-visual-column-local {
        height: 500px;
    }

    .med-pozo-local {
        background-color: #0f172a;
        border-left: 2px solid #1e293b;
        border-right: 2px solid #1e293b;
    }

    .med-pozo-inner-local {
        background-color: #1e293b;
        border-left: 1px solid #334155;
        border-right: 1px solid #334155;
    }

    .med-flood-level-local {
        background-color: color-mix(in srgb, #1d4ed8 60%, transparent);
        border-top: 1px solid #60a5fa;
    }

    @keyframes flood {
        0% {
            height: 20%;
        }
        50% {
            height: 85%;
        }
        70% {
            height: 60%;
        }
        100% {
            height: 20%;
        }
    }
    .animate-flood {
        animation: flood 10s ease-in-out infinite;
    }

    @keyframes tide {
        0%,
        100% {
            transform: translateY(10px);
        }
        50% {
            transform: translateY(-10px);
        }
    }
    .animate-tide {
        animation: tide 5s ease-in-out infinite;
    }

    .med-nilo-bg {
        position: absolute;
        bottom: 0;
        width: 100%;
        height: 50%;
        background: linear-gradient(to top, #1e3a8a, transparent);
    }

    .med-nilo-mark {
        width: 100%;
        height: 1px;
        background-color: #475569;
        position: relative;
    }

    .med-nilo-mark-label {
        position: absolute;
        right: 100%;
        margin-right: 0.5rem;
        font-size: 8px;
        font-family: monospace;
        color: #64748b;
        transform: translateY(-50%);
    }

    .med-nilo-line {
        position: absolute;
        top: 0.5rem;
        left: 0;
        width: 100%;
        height: 1px;
        background-color: rgba(255,255,255,0.2);
    }

    .med-nilo-line-2 {
        position: absolute;
        top: 1rem;
        left: 0;
        width: 100%;
        height: 1px;
        background-color: rgba(255,255,255,0.1);
    }
</style>
