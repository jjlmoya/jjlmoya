---

---

<section
    class="medicion-heisenberg-section"
>
    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <h2 class="med-title med-title-local">
                    El Principio de Incertidumbre
                </h2>

                <p class="med-text-lg medicion-heisenberg-body">
                    En el reino cuántico, la medición deja de ser un acto pasivo. Para "ver" un
                    electrón, debes golpearlo con un fotón.
                </p>
                <p class="med-text-lg medicion-heisenberg-body">
                    El acto de medir altera lo medido. No puedes conocer la posición y la velocidad
                    al mismo tiempo con precisión absoluta.
                </p>

                <div class="med-space-y-4 med-mt-8">
                    <div class="medicion-heisenberg-card">
                        <p class="med-text-sm medicion-heisenberg-card-text">
                            <strong>Heisenberg:</strong> La naturaleza tiene un límite fundamental de
                            resolución. El universo no es infinitamente nítido; es borroso en su base.
                        </p>
                    </div>
                </div>
            </div>

            <div class="med-w-full medicion-heisenberg-visual-col med-flex med-justify-center">
                <div
                    class="med-relative medicion-heisenberg-circle group"
                >
                    <div
                        class="med-absolute med-inset-0 medicion-heisenberg-glow"
                    >
                    </div>

                    <div
                        class="medicion-heisenberg-particle"
                        id="quantum-particle"
                    >
                    </div>

                    <div
                        class="med-absolute med-bottom-8 med-font-mono med-uppercase med-tracking-widest medicion-heisenberg-label"
                    >
                        Intentando localizar...
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const container = document.querySelector(".group");
    const particle = document.getElementById("quantum-particle");

    if (container && particle) {
        container.addEventListener("mousemove", () => {
            const jitterX = (Math.random() - 0.5) * 50;
            const jitterY = (Math.random() - 0.5) * 50;

            particle.style.transform = `translate(${jitterX}px, ${jitterY}px)`;
        });

        container.addEventListener("mouseleave", () => {
            particle.style.transform = `translate(0, 0)`;
        });
    }
</script>


<style>
    .medicion-heisenberg-section {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-top: 8rem;
        padding-bottom: 8rem;
        background-color: #0a0a0a;
        color: #e5e5e5;
    }

    .med-title-local {
        color: #ffffff;
    }

    .medicion-heisenberg-body {
        line-height: 1.625;
        font-family: Georgia, "Times New Roman", serif;
        color: #a3a3a3;
    }

    .medicion-heisenberg-card {
        background-color: #171717;
        padding: 1.5rem;
        border-radius: 0.125rem;
        border-left: 2px solid rgba(168, 85, 247, 0.5);
    }

    .medicion-heisenberg-card-text {
        color: #d4d4d4;
        line-height: 1.625;
    }

    .medicion-heisenberg-visual-col {
        width: 100%;
    }
    @media (min-width: 768px) {
        .medicion-heisenberg-visual-col {
            width: 50%;
        }
    }

    .medicion-heisenberg-circle {
        position: relative;
        width: 16rem;
        height: 16rem;
        background-color: #000000;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #262626;
        overflow: hidden;
    }
    @media (min-width: 768px) {
        .medicion-heisenberg-circle {
            width: 20rem;
            height: 20rem;
        }
    }

    .medicion-heisenberg-glow {
        background: radial-gradient(circle at center, rgba(168, 85, 247, 0.4), transparent 70%);
        filter: blur(24px);
        transition: all 0.3s;
    }
    .group:hover .medicion-heisenberg-glow {
        transform: scale(1.5);
        opacity: 0.5;
    }

    .medicion-heisenberg-particle {
        width: 1rem;
        height: 1rem;
        background-color: #ffffff;
        border-radius: 9999px;
        box-shadow: 0 0 20px rgba(255, 255, 255, 0.8);
        transition: all 0.075s ease-out;
    }

    .medicion-heisenberg-label {
        font-size: 10px;
        color: #525252;
    }
</style>
