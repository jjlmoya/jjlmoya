---

---

<section
    class="medicion-interactive-section"
>
    <div class="med-container med-container--xwide">
        <div class="med-text-center med-mb-16 med-space-y-4">
            <h2
                class="med-text-4xl med-font-bold medicion-interactive-title"
            >
                Tu Huella Digital
            </h2>
            <p class="medicion-interactive-desc med-mx-auto med-text-lg">
                Hemos estado midiendo tu comportamiento mientras leías sobre la medición. Aquí están
                tus estadísticas de sesión.
            </p>
        </div>

        <div class="med-grid-cols-1 med-grid-cols-2\@md medicion-interactive-grid med-gap-4 med-mb-12">
            <div
                class="medicion-interactive-card medicion-interactive-card--wide group"
            >
                <div
                    class="med-absolute med-inset-0 medicion-interactive-glow--cyan"
                >
                </div>
                <div class="med-relative medicion-interactive-card-content">
                    <div class="med-flex med-items-baseline med-gap-2 med-mb-2">
                        <span class="med-text-xs med-font-mono med-uppercase med-tracking-widest medicion-interactive-stat-label--cyan"
                            >Distancia Recorrida</span
                        >
                    </div>
                    <div class="med-flex med-items-baseline med-gap-4">
                        <span
                            id="stat-pixels"
                            class="med-text-4xl med-font-bold med-font-mono medicion-interactive-stat-value">0</span
                        >
                        <span class="med-font-mono medicion-interactive-stat-unit">px</span>
                    </div>
                    <div
                        class="med-mt-4 med-flex med-items-center med-gap-4 med-text-sm med-font-mono medicion-interactive-stat-meta"
                    >
                        <div class="med-flex-1">
                            <span id="stat-meters" class="med-font-bold medicion-interactive-stat-em">0.00</span> m
                        </div>
                        <div class="medicion-interactive-divider"></div>
                        <div class="med-flex-1 med-text-right">
                            <span id="stat-scale" class="medicion-interactive-stat-accent">Microscópico</span>
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="medicion-interactive-card group"
            >
                <div
                    class="med-absolute med-inset-0 medicion-interactive-glow--purple"
                >
                </div>
                <div class="med-relative medicion-interactive-card-content">
                    <span class="med-text-xs med-font-mono med-uppercase med-tracking-widest medicion-interactive-stat-label--purple"
                        >Tiempo de Vida</span
                    >
                    <div class="med-mt-2 med-flex med-items-baseline med-gap-2">
                        <span id="stat-time" class="med-text-4xl med-font-bold med-font-mono medicion-interactive-stat-value"
                            >00:00</span
                        >
                    </div>
                    <p class="med-text-xs medicion-interactive-stat-hint med-mt-2">Invertido en esta página</p>
                </div>
            </div>

            <div
                class="medicion-interactive-card group"
            >
                <div
                    class="med-absolute med-inset-0 medicion-interactive-glow--emerald"
                >
                </div>
                <div class="med-relative medicion-interactive-card-content">
                    <span class="med-text-xs med-font-mono med-uppercase med-tracking-widest medicion-interactive-stat-label--emerald"
                        >Velocidad</span
                    >
                    <div class="med-mt-2 med-flex med-items-baseline med-gap-2">
                        <span id="stat-speed" class="med-text-4xl med-font-bold med-font-mono medicion-interactive-stat-value"
                            >0</span
                        >
                        <span class="med-text-sm medicion-interactive-stat-hint">px/s</span>
                    </div>
                    <p class="med-text-xs medicion-interactive-stat-hint med-mt-2">Ritmo de consumo</p>
                </div>
            </div>

            <div
                class="medicion-interactive-card medicion-interactive-card--wide-lg group"
            >
                <div
                    class="med-absolute med-inset-0 medicion-interactive-glow--orange"
                >
                </div>
                <div
                    class="med-relative medicion-interactive-card-content-row"
                >
                    <div>
                        <span class="med-text-xs med-font-mono med-uppercase med-tracking-widest medicion-interactive-stat-label--orange"
                            >Tu Obsesión</span
                        >
                        <h3
                            id="stat-obsession-title"
                            class="med-text-2xl med-font-serif med-italic medicion-interactive-stat-title med-mt-2"
                        >
                            Calculando...
                        </h3>
                        <p class="med-text-sm medicion-interactive-stat-hint med-mt-1">
                            La sección que más ha capturado tu atención.
                        </p>
                    </div>
                    <div class="med-text-right">
                        <span
                            id="stat-obsession-time"
                            class="med-text-4xl med-font-bold med-font-mono medicion-interactive-stat-time">0s</span
                        >
                        <p class="med-text-xs medicion-interactive-stat-hint med-uppercase med-tracking-widest med-mt-1">
                            Dedicados
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="medicion-interactive-card group"
            >
                <div
                    class="med-absolute med-inset-0 medicion-interactive-glow--yellow"
                >
                </div>
                <div class="med-relative medicion-interactive-card-content">
                    <span class="med-text-xs med-font-mono med-uppercase med-tracking-widest medicion-interactive-stat-label--yellow"
                        >Eventos</span
                    >
                    <div class="med-grid-cols-2 med-gap-4 med-mt-4">
                        <div>
                            <div id="stat-clicks" class="med-text-2xl med-font-bold med-font-mono medicion-interactive-stat-value">
                                0
                            </div>
                            <div class="medicion-meta-label medicion-interactive-stat-hint med-uppercase">Clicks</div>
                        </div>
                        <div>
                            <div id="stat-scrolls" class="med-text-2xl med-font-bold med-font-mono medicion-interactive-stat-value">
                                0
                            </div>
                            <div class="medicion-meta-label medicion-interactive-stat-hint med-uppercase">Swipes</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="med-text-center">
            <p class="med-text-sm med-mb-8 med-font-mono medicion-interactive-quote">
                "Lo que no se mide, no se puede mejorar." — Lord Kelvin <br />
                <span class="med-text-xs medicion-interactive-quote-sub"
                    >(Pero lo que se mide demasiado, pierde su alma)</span
                >
            </p>

            <a
                href="/conceptos/"
                class="medicion-interactive-cta"
            >
                Volver a Conceptos
            </a>
        </div>
    </div>
</section>

<script>
    const pixelsEl = document.getElementById("stat-pixels");
    const metersEl = document.getElementById("stat-meters");
    const scaleEl = document.getElementById("stat-scale");
    const timeEl = document.getElementById("stat-time");
    const speedEl = document.getElementById("stat-speed");
    const obsessionTitleEl = document.getElementById("stat-obsession-title");
    const obsessionTimeEl = document.getElementById("stat-obsession-time");
    const clicksEl = document.getElementById("stat-clicks");
    const scrollsEl = document.getElementById("stat-scrolls");

    const startTime = Date.now();
    let totalClicks = 0;
    let totalScrollEvents = 0;
    let maxScrollY = 0;

    const sectionTimes = new Map<string, number>();
    let currentSectionId: string | null = null;
    let lastSectionEnterTime = Date.now();

    const PIXEL_TO_METER = 0.0002645833;

    function formatTime(ms: number) {
        const seconds = Math.floor(ms / 1000);
        const m = Math.floor(seconds / 60);
        const s = seconds % 60;
        return `${m.toString().padStart(2, "0")}:${s.toString().padStart(2, "0")}`;
    }

    function getScaleLabel(meters: number) {
        if (meters < 0.01) return "Microscópico";
        if (meters < 0.1) return "Insecto";
        if (meters < 0.5) return "Manual";
        if (meters < 1.5) return "Humano";
        if (meters < 3.0) return "Habitación";
        if (meters < 10.0) return "Arquitectónico";
        return "Geográfico";
    }

    const observer = new IntersectionObserver(
        (entries: IntersectionObserverEntry[]) => {
            const now = Date.now();

            if (currentSectionId) {
                const timeSpent = now - lastSectionEnterTime;
                const currentTotal = sectionTimes.get(currentSectionId) || 0;
                sectionTimes.set(currentSectionId, currentTotal + timeSpent);
            }

            let maxRatio = 0;
            let bestEntry: IntersectionObserverEntry | null = null;

            entries.forEach((entry) => {
                if (entry.isIntersecting && entry.intersectionRatio > maxRatio) {
                    maxRatio = entry.intersectionRatio;
                    bestEntry = entry;
                }
            });

            if (bestEntry) {
                const target = (bestEntry as IntersectionObserverEntry).target;
                const title =
                    target.querySelector("h2")?.textContent || target.id || "Introducción";

                currentSectionId = title;
                lastSectionEnterTime = now;
            }
        },
        { threshold: [0.2, 0.5, 0.8] }
    );

    document.querySelectorAll("main > section").forEach((section) => {
        observer.observe(section);
    });

    window.addEventListener("click", () => {
        totalClicks++;
        if (clicksEl) clicksEl.innerText = totalClicks.toString();
    });

    let scrollTimeout: number | null = null;
    window.addEventListener("scroll", () => {
        const scrollY = window.scrollY;
        maxScrollY = Math.max(maxScrollY, scrollY);

        if (!scrollTimeout) {
            totalScrollEvents++;
            if (scrollsEl) scrollsEl.innerText = totalScrollEvents.toString();
            scrollTimeout = window.setTimeout(() => {
                scrollTimeout = null;
            }, 100);
        }

        updateRealtimeStats();
    });

    function updateRealtimeStats() {
        const now = Date.now();
        const elapsedSeconds = (now - startTime) / 1000;

        const scrollY = window.scrollY;
        const meters = scrollY * PIXEL_TO_METER;

        if (pixelsEl) pixelsEl.innerText = Math.floor(scrollY).toLocaleString();
        if (metersEl) metersEl.innerText = meters.toFixed(2);
        if (scaleEl) scaleEl.innerText = getScaleLabel(meters);

        if (timeEl) timeEl.innerText = formatTime(now - startTime);

        const speed = elapsedSeconds > 0 ? Math.floor(scrollY / elapsedSeconds) : 0;
        if (speedEl) speedEl.innerText = speed.toString();

        if (currentSectionId) {
            const timeSpent = now - lastSectionEnterTime;
            const currentTotal = sectionTimes.get(currentSectionId) || 0;

            const tempMap = new Map(sectionTimes);
            tempMap.set(currentSectionId, currentTotal + timeSpent);

            let maxTime = 0;
            let maxTitle = "Analizando...";

            tempMap.forEach((time, title) => {
                if (
                    time > maxTime &&
                    !title.includes("Escala Cósmica") &&
                    !title.includes("Huella")
                ) {
                    maxTime = time;
                    maxTitle = title;
                }
            });

            if (obsessionTitleEl)
                obsessionTitleEl.innerText =
                    maxTitle.length > 30 ? maxTitle.substring(0, 30) + "..." : maxTitle;
            if (obsessionTimeEl) obsessionTimeEl.innerText = (maxTime / 1000).toFixed(1) + "s";
        }
    }

    const header = document.querySelector(".med-text-center");

    const modalHTML = `
        <div id="registry-modal" class="medicion-modal-overlay">
            <div class="medicion-modal-backdrop" id="modal-backdrop"></div>
            <div id="modal-content" class="medicion-modal-content">
                <button id="modal-close" class="medicion-modal-close">
                    <svg xmlns="http://www.w3.org/2000/svg" class="medicion-modal-close-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
                
                <h3 class="medicion-modal-title">Registro de Permanencia</h3>
                <p class="medicion-modal-subtitle">Tu evolución en el sistema según tu frecuencia de interacción.</p>

                <div class="medicion-modal-list" id="levels-list">

                </div>
                
                <div class="medicion-modal-footer">
                    <p class="medicion-modal-id">ID ÚNICO: <span id="modal-user-id" class="medicion-modal-id-value">...</span></p>
                </div>
            </div>
        </div>
    `;
    document.body.insertAdjacentHTML("beforeend", modalHTML);

    const levels = [
        {
            count: 10000,
            name: "SINGULARIDAD",
            borderClass: "medicion-level-white",
            textClass: "medicion-level-white",
            glow: "rgba(255, 255, 255, 0.5)",
        },
        {
            count: 5000,
            name: "VIGILANTE",
            borderClass: "medicion-level-fuchsia",
            textClass: "medicion-level-fuchsia",
            glow: "rgba(217, 70, 239, 0.4)",
        },
        {
            count: 1000,
            name: "DIVINIDAD DIGITAL",
            borderClass: "medicion-level-emerald",
            textClass: "medicion-level-emerald",
            glow: "rgba(52, 211, 153, 0.3)",
        },
        {
            count: 500,
            name: "ARQUITECTO",
            borderClass: "medicion-level-rose",
            textClass: "medicion-level-rose",
            glow: "rgba(244, 63, 94, 0.3)",
        },
        {
            count: 100,
            name: "HABITANTE",
            borderClass: "medicion-level-amber",
            textClass: "medicion-level-amber",
            glow: "rgba(251, 191, 36, 0.3)",
        },
        {
            count: 50,
            name: "VIAJERO FRECUENTE",
            borderClass: "medicion-level-purple",
            textClass: "medicion-level-purple",
            glow: "rgba(168, 85, 247, 0.3)",
        },
        {
            count: 10,
            name: "EXPLORADOR",
            borderClass: "medicion-level-cyan",
            textClass: "medicion-level-cyan",
            glow: "rgba(6, 182, 212, 0.3)",
        },
        {
            count: 0,
            name: "OBSERVADOR",
            borderClass: "medicion-level-neutral",
            textClass: "medicion-level-neutral",
            glow: "transparent",
        },
    ];

    function updateFootprintVisuals() {
        const STORAGE_KEY = "jjlmoya_footprint_v5";
        let visits = 0;
        let userId = "Desconocido";
        try {
            const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
            visits = data.visits || 0;
            userId = data.id || "Desconocido";
        } catch (e) {}

        const currentLevel = levels.find((l) => visits >= l.count) || levels[levels.length - 1];

        const cards = document.querySelectorAll(".medicion-interactive-card");
        cards.forEach((card) => {
            if (currentLevel.count > 0) {
                card.classList.add(currentLevel.borderClass);
                (card as HTMLElement).style.boxShadow = `0 0 30px ${currentLevel.glow}`;
            }
        });

        if (header && !document.getElementById("level-badge")) {
            const container = document.createElement("div");
            container.className = "med-flex med-flex-col med-items-center med-gap-4 med-mt-6";

            const badge = document.createElement("div");
            badge.id = "level-badge";
            badge.className = `med-inline-block med-px-4 med-py-1 med-rounded-full med-border ${currentLevel.borderClass} med-text-xs med-font-mono med-font-bold med-uppercase med-tracking-widest medicion-interactive-badge`;
            badge.style.color = currentLevel.glow
                .replace("0.3)", "1)")
                .replace("0.4)", "1)")
                .replace("0.5)", "1)");
            badge.style.boxShadow = `0 0 15px ${currentLevel.glow}`;
            badge.innerText = `Nivel: ${currentLevel.name} (${visits} visitas)`;

            const btn = document.createElement("button");
            btn.innerText = "Ver Registro de Permanencia";
            btn.className =
                "med-text-xs medicion-interactive-btn";
            btn.onclick = openModal;

            container.appendChild(badge);
            container.appendChild(btn);
            header.appendChild(container);
        }

        const modalId = document.getElementById("modal-user-id");
        if (modalId) modalId.innerText = userId;

        const list = document.getElementById("levels-list");
        if (list) {
            list.innerHTML = levels
                .map((l) => {
                    const isReached = visits >= l.count;
                    const isCurrent = currentLevel.name === l.name;
                    const opacity = isReached ? "" : "medicion-interactive-locked";
                    const border = isCurrent ? `medicion-level-active ${l.borderClass}` : "";
                    const bg = isCurrent ? "medicion-interactive-current-bg" : "";

                    return `
                    <div class="med-flex med-items-center med-justify-between med-p-3 medicion-interactive-level-row ${border} ${bg} ${opacity}">
                        <div class="med-flex med-items-center med-gap-3">
                            <div class="medicion-interactive-level-dot ${l.textClass}"></div>
                            <span class="med-font-mono med-text-sm med-font-bold ${l.textClass}">${l.name}</span>
                        </div>
                        <span class="med-text-xs medicion-interactive-stat-hint med-font-mono">${l.count}+</span>
                    </div>
                `;
                })
                .join("");
        }

        const modalContent = document.getElementById("modal-content");
        if (modalContent && currentLevel.count > 0) {
            modalContent.className = `medicion-modal-content ${currentLevel.borderClass}`;
            modalContent.style.boxShadow = `0 0 40px ${currentLevel.glow}`;
        }
    }

    const modal = document.getElementById("registry-modal");
    const modalContent = document.getElementById("modal-content");
    const backdrop = document.getElementById("modal-backdrop");
    const closeBtn = document.getElementById("modal-close");

    function openModal() {
        if (!modal) return;
        modal.classList.remove("med-opacity-0", "med-pointer-events-none");
        modalContent?.classList.remove("scale-95");
        modalContent?.classList.add("scale-100");
        document.body.style.overflow = "hidden";

        updateFootprintVisuals();
    }

    function closeModal() {
        if (!modal) return;
        modal.classList.add("med-opacity-0", "med-pointer-events-none");
        modalContent?.classList.remove("scale-100");
        modalContent?.classList.add("scale-95");
        document.body.style.overflow = "";
    }

    backdrop?.addEventListener("click", closeModal);
    closeBtn?.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });

    setTimeout(updateFootprintVisuals, 100);
</script>

<style>
    .medicion-interactive-section {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        padding-top: 5rem;
        padding-bottom: 5rem;
        background-color: #0a0a0a;
        color: #ffffff;
    }

    .medicion-interactive-title {
        color: #ffffff;
    }

    .medicion-interactive-desc {
        color: #a3a3a3;
        max-width: 42rem;
    }

    .medicion-interactive-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: 1rem;
    }
    @media (min-width: 768px) {
        .medicion-interactive-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .medicion-interactive-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .medicion-interactive-card {
        background-color: rgba(23, 23, 23, 0.5);
        border-radius: 1rem;
        padding: 1.5rem;
        border: 1px solid #262626;
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s;
    }
    .group:hover .medicion-interactive-card {
        border-color: #404040;
    }

    .medicion-interactive-card--wide {
        grid-column: span 1;
    }
    @media (min-width: 768px) {
        .medicion-interactive-card--wide {
            grid-column: span 2;
        }
    }
    @media (min-width: 1024px) {
        .medicion-interactive-card--wide {
            grid-column: span 2;
        }
    }

    .medicion-interactive-card--wide-lg {
        grid-column: span 1;
    }
    @media (min-width: 768px) {
        .medicion-interactive-card--wide-lg {
            grid-column: span 2;
        }
    }
    @media (min-width: 1024px) {
        .medicion-interactive-card--wide-lg {
            grid-column: span 3;
        }
    }

    .medicion-interactive-glow--cyan {
        background: linear-gradient(to right, rgba(6, 182, 212, 0.1), rgba(59, 130, 246, 0.1));
        opacity: 0;
        transition: opacity 0.5s;
    }
    .group:hover .medicion-interactive-glow--cyan {
        opacity: 1;
    }

    .medicion-interactive-glow--purple {
        background: linear-gradient(to bottom right, rgba(168, 85, 247, 0.1), rgba(236, 72, 153, 0.1));
        opacity: 0;
        transition: opacity 0.5s;
    }
    .group:hover .medicion-interactive-glow--purple {
        opacity: 1;
    }

    .medicion-interactive-glow--emerald {
        background: linear-gradient(to bottom right, rgba(16, 185, 129, 0.1), rgba(34, 197, 94, 0.1));
        opacity: 0;
        transition: opacity 0.5s;
    }
    .group:hover .medicion-interactive-glow--emerald {
        opacity: 1;
    }

    .medicion-interactive-glow--orange {
        background: linear-gradient(to right, rgba(249, 115, 22, 0.1), rgba(239, 68, 68, 0.1));
        opacity: 0;
        transition: opacity 0.5s;
    }
    .group:hover .medicion-interactive-glow--orange {
        opacity: 1;
    }

    .medicion-interactive-glow--yellow {
        background: linear-gradient(to bottom right, rgba(234, 179, 8, 0.1), rgba(245, 158, 11, 0.1));
        opacity: 0;
        transition: opacity 0.5s;
    }
    .group:hover .medicion-interactive-glow--yellow {
        opacity: 1;
    }

    .medicion-interactive-card-content {
        position: relative;
        z-index: 10;
    }

    .medicion-interactive-card-content-row {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
    }
    @media (min-width: 768px) {
        .medicion-interactive-card-content-row {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }
    .medicion-interactive-card-content-row > * + * {
        margin-top: 1.5rem;
    }
    @media (min-width: 768px) {
        .medicion-interactive-card-content-row > * + * {
            margin-top: 0;
            margin-left: 1.5rem;
        }
    }

    .medicion-interactive-stat-label--cyan {
        color: #22d3ee;
    }

    .medicion-interactive-stat-label--purple {
        color: #c084fc;
    }

    .medicion-interactive-stat-label--emerald {
        color: #34d399;
    }

    .medicion-interactive-stat-label--orange {
        color: #fb923c;
    }

    .medicion-interactive-stat-label--yellow {
        color: #facc15;
    }

    .medicion-interactive-stat-value {
        color: #ffffff;
    }

    .medicion-interactive-stat-unit {
        color: #737373;
    }

    .medicion-interactive-stat-meta {
        color: #a3a3a3;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 1rem;
    }

    .medicion-interactive-stat-em {
        color: #ffffff;
    }

    .medicion-interactive-stat-accent {
        color: #a5f3fc;
    }

    .medicion-interactive-divider {
        width: 1px;
        height: 1rem;
        background-color: rgba(255, 255, 255, 0.1);
    }

    .medicion-interactive-stat-hint {
        color: #737373;
    }

    .medicion-interactive-stat-title {
        color: #ffffff;
    }

    .medicion-interactive-stat-time {
        color: #fed7aa;
    }

    .medicion-interactive-quote {
