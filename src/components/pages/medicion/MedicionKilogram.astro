---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-20">
        <svg class="med-w-full med-h-full">
            <defs>
                <linearGradient id="metalGrad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#374151"></stop>
                    <stop offset="50%" stop-color="#1f2937"></stop>
                    <stop offset="100%" stop-color="#111827"></stop>
                </linearGradient>
            </defs>
            <rect width="100%" height="100%" fill="url(#metalGrad)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Objeto Sagrado</span
                >
                <h2 class="med-title med-title-local">Le Grand K</h2>

                <p class="med-description med-description-local">
                    Durante 130 años, el "kilogramo" no fue una idea. Fue un objeto. Un cilindro de
                    platino e iridio guardado bajo tres campanas de cristal en París.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Fragilidad de la Materia</h3>
                    <p class="med-card-text med-card-text-local">
                        Si alguien estornudaba sobre él, el universo entero "perdía" peso. Si perdía
                        un átomo, todo lo demás tenía que redefinirse.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        En 2019 lo jubilamos. Ahora el kilo se define por la constante de Planck.
                        Pasamos de adorar un ídolo de metal a adorar una constante matemática.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <defs>
                            <linearGradient id="glassShine" x1="0" y1="0" x2="1" y2="0">
                                <stop offset="0%" stop-color="rgba(255,255,255,0.1)"></stop>
                                <stop offset="50%" stop-color="rgba(255,255,255,0.4)"></stop>
                                <stop offset="100%" stop-color="rgba(255,255,255,0.1)"></stop>
                            </linearGradient>
                            <linearGradient id="platinum" x1="0" y1="0" x2="1" y2="0">
                                <stop offset="0%" stop-color="#9ca3af"></stop>
                                <stop offset="50%" stop-color="#f3f4f6"></stop>
                                <stop offset="100%" stop-color="#6b7280"></stop>
                            </linearGradient>
                        </defs>

                        <ellipse
                            cx="200"
                            cy="250"
                            rx="100"
                            ry="20"
                            fill="#1f2937"
                            stroke="#374151"
                            stroke-width="2"></ellipse>

                        <path
                            d="M 120 250 L 120 100 Q 120 20 200 20 Q 280 20 280 100 L 280 250"
                            fill="url(#glassShine)"
                            stroke="#e5e7eb"
                            stroke-width="1"
                            opacity="0.3"></path>

                        <path
                            d="M 140 250 L 140 120 Q 140 50 200 50 Q 260 50 260 120 L 260 250"
                            fill="none"
                            stroke="#e5e7eb"
                            stroke-width="1"
                            opacity="0.2"></path>

                        <g transform="translate(200, 220)">
                            <path d="M -20 0 L -20 -40 L 20 -40 L 20 0" fill="url(#platinum)"
                            ></path>

                            <ellipse cx="0" cy="-40" rx="20" ry="5" fill="#e5e7eb"></ellipse>

                            <path d="M -20 0 Q 0 10 20 0" fill="url(#platinum)"></path>

                            <circle
                                cx="0"
                                cy="-20"
                                r="30"
                                fill="white"
                                opacity="0.1"
                                class="animate-pulse-halo"></circle>
                        </g>

                        <path
                            d="M 120 250 L 130 260 L 270 260 L 280 250"
                            fill="url(#glassShine)"
                            opacity="0.1"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #111827;
        color: #e5e7eb;
    }

    .med-tag-local {
        color: #9ca3af;
        border-color: #4b5563;
    }

    .med-title-local {
        color: #f3f4f6;
    }

    .med-description-local {
        color: #d1d5db;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #e5e7eb;
    }

    .med-card-text-local {
        color: #9ca3af;
    }

    .med-card-note-local {
        color: #d1d5db;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #1f2937 50%, transparent);
        border-color: #374151;
    }

    @keyframes pulseHalo {
        0% {
            opacity: 0.1;
            transform: scale(1);
        }
        50% {
            opacity: 0.3;
            transform: scale(1.2);
        }
        100% {
            opacity: 0.1;
            transform: scale(1);
        }
    }
    .animate-pulse-halo {
        animation: pulseHalo 4s ease-in-out infinite;
    }
</style>
