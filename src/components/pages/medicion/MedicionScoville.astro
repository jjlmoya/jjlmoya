---

---

<section
    class="med-section med-section-local"
>
    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >Dolor Cuantificado</span
                >
                <h2 class="med-title med-title-local">
                    La Escala Scoville
                </h2>

                <p class="med-description med-description-local">
                    ¿Cómo mides el fuego en la boca? El picante no es temperatura, es dolor químico.
                    En 1912, Wilbur Scoville inventó una forma de medirlo.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Dilución del Azúcar</h3>
                    <p class="med-card-text med-card-text-local">
                        Originalmente, era una prueba de cata humana. ¿Cuántas veces tienes que
                        diluir el extracto del pimiento en agua azucarada hasta que ya no queme?
                    </p>
                    <ul class="med-list med-list-local">
                        <li class="med-flex med-justify-between medicion-scoville-border med-pb-1">
                            <span>Pimiento Morrón</span>
                            <span>0 SHU</span>
                        </li>
                        <li class="med-flex med-justify-between medicion-scoville-border med-pb-1">
                            <span>Jalapeño</span>
                            <span>5,000 SHU</span>
                        </li>
                        <li class="med-flex med-justify-between medicion-scoville-border med-pb-1">
                            <span>Habanero</span>
                            <span>300,000 SHU</span>
                        </li>
                        <li class="med-flex med-justify-between med-pt-1 med-font-bold medicion-scoville-em">
                            <span>Carolina Reaper</span>
                            <span>2,200,000 SHU</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="med-visual-column">
                <div class="med-visual-sizer">
                    <svg
                        viewBox="0 0 200 200"
                        class="med-w-full med-h-full medicion-scoville-svg med-overflow-visible"
                    >
                        <path
                            d="M 20 100 A 80 80 0 1 1 180 100"
                            fill="none"
                            stroke="#7f1d1d"
                            stroke-width="10"
                            stroke-linecap="round"></path>

                        <defs>
                            <linearGradient id="gaugeGradient" x1="0" y1="0" x2="1" y2="0">
                                <stop offset="0%" stop-color="#fca5a5"></stop>
                                <stop offset="50%" stop-color="#ef4444"></stop>
                                <stop offset="100%" stop-color="#7f1d1d"></stop>
                            </linearGradient>
                        </defs>
                        <path
                            d="M 20 100 A 80 80 0 1 1 180 100"
                            fill="none"
                            stroke="url(#gaugeGradient)"
                            stroke-width="10"
                            stroke-linecap="round"
                            stroke-dasharray="251"
                            stroke-dashoffset="0"
                            class="animate-gauge-fill"></path>

                        <g transform="translate(100, 100) scale(0.8)">
                            <path
                                d="M -30 -40 C -50 -40 -60 -10 -50 40 C -40 80 0 100 0 120 C 0 100 40 80 50 40 C 60 -10 50 -40 30 -40 Q 0 -30 -30 -40 Z"
                                fill="#ef4444"
                                stroke="#991b1b"
                                stroke-width="2"
                            >
                                <animate
                                    attributeName="fill"
                                    values="#ef4444; #b91c1c; #ef4444"
                                    dur="2s"
                                    repeatCount="indefinite"></animate>
                            </path>

                            <path
                                d="M -10 -45 Q 0 -60 20 -55 L 15 -45"
                                fill="none"
                                stroke="#166534"
                                stroke-width="4"
                                stroke-linecap="round"></path>
                        </g>

                        <g class="animate-fire-rise">
                            <circle cx="80" cy="140" r="2" fill="#fbbf24" opacity="0"></circle>
                            <circle
                                cx="120"
                                cy="140"
                                r="3"
                                fill="#fbbf24"
                                opacity="0"
                                style="animation-delay: 0.5s"></circle>
                            <circle
                                cx="100"
                                cy="160"
                                r="2"
                                fill="#fbbf24"
                                opacity="0"
                                style="animation-delay: 1s"></circle>
                        </g>

                        <g transform="translate(100, 100)">
                            <line
                                x1="0"
                                y1="0"
                                x2="-70"
                                y2="0"
                                stroke="#fff"
                                stroke-width="3"
                                stroke-linecap="round"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    values="0; 180; 160; 180; 0"
                                    dur="5s"
                                    repeatCount="indefinite"></animateTransform>
                            </line>
                            <circle cx="0" cy="0" r="5" fill="#fff"></circle>
                        </g>

                        <text
                            x="100"
                            y="160"
                            text-anchor="middle"
                            fill="#fecaca"
                            font-size="12"
                            font-weight="bold"
                        >
                            <animate
                                attributeName="opacity"
                                values="0.5; 1; 0.5"
                                dur="1s"
                                repeatCount="indefinite"></animate>
                            WARNING: HOT
                        </text>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #450a0a;
        color: #fecaca;
    }

    .med-tag-local {
        color: #f87171;
        border-color: #991b1b;
    }

    .med-title-local {
        color: #fef2f2;
    }

    .med-description-local {
        color: #fecaca;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #7f1d1d 40%, transparent);
        border-color: color-mix(in srgb, #ef4444 30%, transparent);
    }

    .med-card-title-local {
        color: #fca5a5;
    }

    .med-card-text-local {
        color: #fecaca;
    }

    .med-list-local {
        color: #f87171;
    }

    .medicion-scoville-border {
        border-bottom: 1px solid #991b1b;
    }

    .medicion-scoville-em {
        color: #ffffff;
    }

    .medicion-scoville-svg {
        filter: drop-shadow(0 20px 13px rgba(0,0,0,0.2));
    }

    @keyframes gaugeFill {
        0%,
        100% {
            stroke-dashoffset: 251;
        }
        50% {
            stroke-dashoffset: 0;
        }
    }
    .animate-gauge-fill {
        animation: gaugeFill 5s ease-in-out infinite;
    }

    @keyframes fireRise {
        0% {
            transform: translateY(0);
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
        100% {
            transform: translateY(-50px);
            opacity: 0;
        }
    }
    .animate-fire-rise circle {
        animation: fireRise 2s linear infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 20rem; display: flex; align-items: center; justify-content: center; }
</style>
