---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-opacity-10 med-pointer-events-none">
        <svg class="med-w-full med-h-full">
            <pattern
                id="fieldPattern"
                x="0"
                y="0"
                width="50"
                height="50"
                patternUnits="userSpaceOnUse"
            >
                <path
                    d="M 10 25 L 40 25 M 35 20 L 40 25 L 35 30"
                    stroke="#6366f1"
                    stroke-width="1"
                    fill="none"
                    opacity="0.5"></path>
            </pattern>
            <rect width="100%" height="100%" fill="url(#fieldPattern)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Aguja Magnética</span
                >
                <h2 class="med-title med-title-local">
                    El Galvanómetro
                </h2>

                <p class="med-description med-description-local">
                    Sabíamos generar chispas, pero no sabíamos *cuánta* electricidad fluía. No
                    podíamos pesarla ni medirla con una regla.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Convertir Flujo en Ángulo</h3>
                    <p class="med-card-text med-card-text-local">
                        André-Marie Ampère descubrió que la electricidad crea magnetismo. Si pasas
                        corriente por una bobina alrededor de una brújula, la aguja se mueve.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Cuanta más corriente, más se desvía la aguja. Por primera vez, lo invisible
                        se tradujo en un número en un dial.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg
                        viewBox="0 0 300 300"
                        class="med-w-full med-h-full med-overflow-visible" style="filter: drop-shadow(0 0 30px rgba(99,102,241,0.3))"
                    >
                        <g transform="translate(150, 150)">
                            {
                                Array.from({ length: 12 }).map((_, i) => (
                                    <ellipse
                                        cx="0"
                                        cy="0"
                                        rx="120"
                                        ry={60 + i * 2}
                                        fill="none"
                                        stroke="#b45309"
                                        stroke-width="2"
                                        transform={`rotate(${i * 5})`}
                                        opacity="0.8"
                                    />
                                ))
                            }
                        </g>

                        <path
                            d="M 50 150 A 100 100 0 0 1 250 150"
                            fill="none"
                            stroke="#e0e7ff"
                            stroke-width="2"></path>
                        <g stroke="#e0e7ff" stroke-width="1">
                            {
                                Array.from({ length: 11 }).map((_, i) => {
                                    const angle = 180 + i * 18;
                                    const r1 = 90;
                                    const r2 = 100;
                                    const x1 = 150 + r1 * Math.cos((angle * Math.PI) / 180);
                                    const y1 = 150 + r1 * Math.sin((angle * Math.PI) / 180);
                                    const x2 = 150 + r2 * Math.cos((angle * Math.PI) / 180);
                                    const y2 = 150 + r2 * Math.sin((angle * Math.PI) / 180);
                                    return <line x1={x1} y1={y1} x2={x2} y2={y2} />;
                                })
                            }
                        </g>

                        <g transform="translate(150, 150)">
                            <g class="animate-needle-deflect">
                                <polygon points="-5,-20 0,-100 5,-20 0,20" fill="#ef4444"></polygon>
                                <circle
                                    cx="0"
                                    cy="0"
                                    r="8"
                                    fill="#4b5563"
                                    stroke="#e0e7ff"
                                    stroke-width="1"></circle>
                            </g>
                        </g>

                        <circle cx="30" cy="250" r="4" fill="#fbbf24" class="animate-electron-flow"
                        ></circle>
                        <circle
                            cx="270"
                            cy="250"
                            r="4"
                            fill="#fbbf24"
                            class="animate-electron-flow"
                            style="animation-delay: 1s"></circle>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1e1b4b;
        color: #e0e7ff;
    }

    .med-tag-local {
        color: #818cf8;
        border-color: #4338ca;
    }

    .med-title-local {
        color: #e0e7ff;
    }

    .med-description-local {
        color: #c7d2fe;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #a5b4fc;
    }

    .med-card-text-local {
        color: #e0e7ff;
    }

    .med-card-note-local {
        color: #818cf8;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #312e81 50%, transparent);
        border-color: #4f46e5;
    }

    @keyframes needleDeflect {
        0% {
            transform: rotate(-45deg);
        }
        20% {
            transform: rotate(45deg);
        }
        40% {
            transform: rotate(30deg);
        }
        60% {
            transform: rotate(40deg);
        }
        80% {
            transform: rotate(35deg);
        }
        100% {
            transform: rotate(-45deg);
        }
    }
    .animate-needle-deflect {
        animation: needleDeflect 4s ease-in-out infinite;
    }

    @keyframes electronFlow {
        0% {
            opacity: 0;
            transform: scale(1);
        }
        50% {
            opacity: 1;
        }
        100% {
            opacity: 0;
            transform: scale(2);
        }
    }
    .animate-electron-flow {
        animation: electronFlow 1s linear infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 100%; display: flex; align-items: center; justify-content: center; }
</style>
