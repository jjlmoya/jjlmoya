---

---

<section
    class="med-section med-section-local"
>
    <div class="med-astrolabe-bg">
        <svg class="med-w-full med-h-full">
            <pattern
                id="starMap"
                x="0"
                y="0"
                width="200"
                height="200"
                patternUnits="userSpaceOnUse"
            >
                <circle cx="20" cy="20" r="1" fill="#fcd34d"></circle>
                <circle cx="150" cy="40" r="1.5" fill="#fcd34d"></circle>
                <circle cx="80" cy="120" r="1" fill="#fcd34d"></circle>
                <path
                    d="M 20 20 L 80 120 L 150 40"
                    stroke="#fcd34d"
                    stroke-width="0.5"
                    stroke-dasharray="2 2"></path>
            </pattern>
            <rect width="100%" height="100%" fill="url(#starMap)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Universo de Bolsillo</span
                >
                <h2 class="med-title med-title-local">El Astrolabio</h2>

                <p class="med-description med-description-local">
                    Antes de los relojes mecánicos y el GPS, llevábamos el cielo en la mano. Una
                    computadora analógica de latón para capturar las estrellas.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Red de Araña</h3>
                    <p class="med-card-text med-card-text-local">
                        La "Rete" giratoria representaba las estrellas fijas. Las placas debajo, el
                        horizonte local.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Midiendo la altura de una estrella, podías saber la hora, tu latitud y el
                        destino. Era magia geométrica: bajar el cosmos a la escala humana.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 400" class="med-w-full med-h-full med-overflow-visible">
                        <defs>
                            <linearGradient id="brassGrad" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0%" stop-color="#fcd34d"></stop>
                                <stop offset="50%" stop-color="#b45309"></stop>
                                <stop offset="100%" stop-color="#78350f"></stop>
                            </linearGradient>
                            <filter id="brassGlow">
                                <feDropShadow
                                    dx="0"
                                    dy="0"
                                    stdDeviation="5"
                                    flood-color="#fbbf24"
                                    flood-opacity="0.3"></feDropShadow>
                            </filter>
                        </defs>

                        <circle
                            cx="200"
                            cy="200"
                            r="140"
                            fill="#292524"
                            stroke="url(#brassGrad)"
                            stroke-width="8"></circle>

                        <g opacity="0.3">
                            <circle
                                cx="200"
                                cy="200"
                                r="120"
                                fill="none"
                                stroke="#b45309"
                                stroke-width="1"></circle>

                            <path
                                d="M 80 200 Q 200 100 320 200"
                                fill="none"
                                stroke="#b45309"
                                stroke-width="1"></path>
                            <path
                                d="M 80 200 Q 200 300 320 200"
                                fill="none"
                                stroke="#b45309"
                                stroke-width="1"></path>
                            <line
                                x1="200"
                                y1="80"
                                x2="200"
                                y2="320"
                                stroke="#b45309"
                                stroke-width="1"></line>
                            <line
                                x1="80"
                                y1="200"
                                x2="320"
                                y2="200"
                                stroke="#b45309"
                                stroke-width="1"></line>
                        </g>

                        <g class="animate-spin-rete">
                            <path
                                d="M 200 60 A 140 140 0 0 1 340 200 A 140 140 0 0 1 200 340 A 140 140 0 0 1 60 200 A 140 140 0 0 1 200 60"
                                fill="none"
                                stroke="#fbbf24"
                                stroke-width="2"
                                stroke-dasharray="10 5"></path>

                            <g fill="#fbbf24">
                                <path d="M 200 60 L 205 80 L 195 80 Z"></path>

                                <path d="M 340 200 L 320 205 L 320 195 Z"></path>
                                <path d="M 200 340 L 195 320 L 205 320 Z"></path>
                                <path d="M 60 200 L 80 195 L 80 205 Z"></path>

                                <circle cx="250" cy="150" r="3"></circle>
                                <circle cx="150" cy="250" r="3"></circle>
                                <circle cx="280" cy="280" r="3"></circle>
                            </g>

                            <path
                                d="M 200 100 Q 250 150 200 200 Q 150 250 200 300"
                                fill="none"
                                stroke="#fbbf24"
                                stroke-width="2"></path>
                            <path
                                d="M 100 200 Q 150 150 200 200 Q 250 250 300 200"
                                fill="none"
                                stroke="#fbbf24"
                                stroke-width="2"></path>
                        </g>

                        <g class="animate-spin-rule">
                            <rect
                                x="195"
                                y="60"
                                width="10"
                                height="280"
                                fill="#b45309"
                                opacity="0.8"></rect>
                            <line
                                x1="200"
                                y1="60"
                                x2="200"
                                y2="340"
                                stroke="#fcd34d"
                                stroke-width="1"></line>
                        </g>

                        <circle
                            cx="200"
                            cy="200"
                            r="8"
                            fill="url(#brassGrad)"
                            stroke="#fff"
                            stroke-width="1"></circle>

                        <g transform="translate(200, 40)">
                            <path d="M -20 20 L -20 0 Q 0 -20 20 0 L 20 20 Z" fill="url(#brassGrad)"
                            ></path>
                            <circle
                                cx="0"
                                cy="0"
                                r="8"
                                fill="none"
                                stroke="#292524"
                                stroke-width="2"></circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #0c0a09;
        color: #fcd34d;
    }

    .med-tag-local {
        color: #d97706;
        border-color: #92400e;
    }

    .med-title-local {
        color: #fbbf24;
    }

    .med-description-local {
        color: #fcd34d;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #fbbf24;
    }

    .med-card-text-local {
        color: #fde68a;
    }

    .med-card-note-local {
        color: #d97706;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #451a03 50%, transparent);
        border-color: #b45309;
    }
    .med-astrolabe-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.2;
    }

    @keyframes spinRete {
        from {
            transform: rotate(0deg);
            transform-origin: 200px 200px;
        }
        to {
            transform: rotate(360deg);
            transform-origin: 200px 200px;
        }
    }
    .animate-spin-rete {
        animation: spinRete 60s linear infinite;
    }

    @keyframes spinRule {
        0% {
            transform: rotate(0deg);
            transform-origin: 200px 200px;
        }
        50% {
            transform: rotate(45deg);
            transform-origin: 200px 200px;
        }
        100% {
            transform: rotate(0deg);
            transform-origin: 200px 200px;
        }
    }
    .animate-spin-rule {
        animation: spinRule 10s ease-in-out infinite;
    }
</style>
