---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-10">
        <svg class="med-w-full med-h-full">
            <pattern id="veins" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
                <path
                    d="M 0 50 Q 25 25 50 50 T 100 50"
                    fill="none"
                    stroke="#ef4444"
                    stroke-width="1"></path>
                <path
                    d="M 50 0 Q 75 25 50 50 T 50 100"
                    fill="none"
                    stroke="#ef4444"
                    stroke-width="1"></path>
            </pattern>
            <rect width="100%" height="100%" fill="#7f1d1d" filter="url(#veins)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Reloj de Sangre</span
                >
                <h2 class="med-title med-title-local">El Pulso</h2>

                <p class="med-description med-description-local">
                    Antes de medir el tiempo con precisión, el cuerpo era el reloj. Herófilo de
                    Alejandría usó una clepsidra portátil para medir los latidos de sus pacientes.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">El Ritmo de la Vida</h3>
                    <p class="med-card-text med-card-text-local">
                        Descubrió que el pulso no solo indicaba la velocidad del corazón, sino su
                        fuerza y ritmo. Fue la primera vez que convertimos la vida en un número.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        La música y la medicina comparten la misma unidad: el tempo.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <defs>
                            <pattern
                                id="ecgGrid"
                                width="20"
                                height="20"
                                patternUnits="userSpaceOnUse"
                            >
                                <rect
                                    width="20"
                                    height="20"
                                    fill="none"
                                    stroke="#ef4444"
                                    stroke-width="0.5"
                                    opacity="0.2"></rect>
                            </pattern>
                        </defs>
                        <rect
                            x="0"
                            y="50"
                            width="400"
                            height="200"
                            fill="url(#ecgGrid)"
                            opacity="0.3"></rect>
                        <line x1="0" y1="150" x2="400" y2="150" stroke="#7f1d1d" stroke-width="1"
                        ></line>

                        <g transform="translate(200, 150)">
                            <path
                                d="M 0 20 Q -40 -20 -20 -50 Q 0 -40 0 -20 Q 0 -40 20 -50 Q 40 -20 0 20"
                                fill="#ef4444"
                                opacity="0.2"
                                class="animate-heartbeat-bg"></path>

                            <path
                                id="pulsePath"
                                d="M -150 0 L -40 0 L -30 -30 L -20 30 L -10 0 L 10 0 L 20 -80 L 30 40 L 40 0 L 150 0"
                                fill="none"
                                stroke="#fecaca"
                                stroke-width="3"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                pathLength="1"
                                stroke-dasharray="1"
                                stroke-dashoffset="1"
                                class="animate-draw-pulse"></path>
                        </g>

                        <g transform="translate(350, 250)" opacity="0.5">
                            <path
                                d="M -10 0 L 10 0 L 5 20 L -5 20 Z"
                                fill="none"
                                stroke="#fca5a5"
                                stroke-width="1"></path>
                            <circle cx="0" cy="25" r="2" fill="#fca5a5" class="animate-drop"
                            ></circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #450a0a;
        color: #fecaca;
    }

    .med-tag-local {
        color: #f87171;
        border-color: #991b1b;
    }

    .med-title-local {
        color: #fee2e2;
    }

    .med-description-local {
        color: #fca5a5;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #7f1d1d 40%, transparent);
        border-color: color-mix(in srgb, #ef4444 30%, transparent);
    }

    .med-card-title-local {
        color: #fecaca;
    }

    .med-card-text-local {
        color: #fca5a5;
    }

    .med-card-note-local {
        color: #f87171;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes heartbeatBg {
        0% {
            transform: scale(1);
            opacity: 0.2;
        }
        35% {
            transform: scale(1);
            opacity: 0.2;
        }
        40% {
            transform: scale(1.1);
            opacity: 0.3;
        }
        45% {
            transform: scale(1);
            opacity: 0.2;
        }
        56% {
            transform: scale(1.4);
            opacity: 0.5;
        }
        70% {
            transform: scale(1);
            opacity: 0.2;
        }
        100% {
            transform: scale(1);
            opacity: 0.2;
        }
    }
    .animate-heartbeat-bg {
        animation: heartbeatBg 2s linear infinite;
    }

    @keyframes drawPulse {
        0% {
            stroke-dashoffset: 1;
            opacity: 1;
        }
        90% {
            stroke-dashoffset: 0;
            opacity: 1;
        }
        100% {
            stroke-dashoffset: 0;
            opacity: 0;
        }
    }
    .animate-draw-pulse {
        animation: drawPulse 2s linear infinite;
    }

    @keyframes drop {
        0% {
            transform: translateY(0);
            opacity: 1;
        }
        100% {
            transform: translateY(10px);
            opacity: 0;
        }
    }
    .animate-drop {
        animation: drop 1s linear infinite;
    }
</style>
