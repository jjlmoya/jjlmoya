---

---

<section
    class="med-section med-section-local"
>
    <div class="med-background">
        {
            Array.from({ length: 50 }).map(() => (
                <div
                    class="med-star-dot"
                    style={`left: ${Math.random() * 100}%; top: ${Math.random() * 100}%; width: ${Math.random() * 2}px; height: ${Math.random() * 2}px;`}
                />
            ))
        }
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Sonido de la Luz</span
                >
                <h2 class="med-title med-title-local">
                    El Efecto Doppler
                </h2>

                <p class="med-description med-description-local">
                    Si una ambulancia se acerca, suena aguda. Si se aleja, grave. Christian Doppler
                    vio que esto también pasa con la luz.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Corrimiento al Rojo</h3>
                    <p class="med-card-text med-card-text-local">
                        Cuando una estrella se aleja de nosotros, sus ondas de luz se estiran hacia
                        el rojo.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Midiendo este cambio de color, Hubble descubrió que el universo no está
                        quieto: está explotando hacia afuera. Medimos la velocidad de la creación
                        misma.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-visual-svg">
                        <circle
                            cx="50"
                            cy="150"
                            r="10"
                            fill="#3b82f6"
                            stroke="#60a5fa"
                            stroke-width="2"></circle>
                        <text x="50" y="180" text-anchor="middle" fill="#60a5fa" font-size="10"
                            >OBSERVADOR</text
                        >

                        <g class="animate-move-source">
                            <circle
                                cx="0"
                                cy="0"
                                r="15"
                                fill="#fbbf24"
                                stroke="#f59e0b"
                                stroke-width="2"></circle>

                            <path
                                d="M -20 -20 Q -40 0 -20 20"
                                fill="none"
                                stroke="#ef4444"
                                stroke-width="2"
                                opacity="0.8"
                            >
                                <animate
                                    attributeName="d"
                                    values="M -20 -20 Q -40 0 -20 20; M -60 -40 Q -100 0 -60 40"
                                    dur="1s"
                                    repeatCount="indefinite"></animate>
                                <animate
                                    attributeName="opacity"
                                    values="0.8; 0"
                                    dur="1s"
                                    repeatCount="indefinite"></animate>
                            </path>
                            <path
                                d="M -20 -20 Q -40 0 -20 20"
                                fill="none"
                                stroke="#ef4444"
                                stroke-width="2"
                                opacity="0.8"
                            >
                                <animate
                                    attributeName="d"
                                    values="M -20 -20 Q -40 0 -20 20; M -60 -40 Q -100 0 -60 40"
                                    dur="1s"
                                    begin="0.5s"
                                    repeatCount="indefinite"></animate>
                                <animate
                                    attributeName="opacity"
                                    values="0.8; 0"
                                    dur="1s"
                                    begin="0.5s"
                                    repeatCount="indefinite"></animate>
                            </path>

                            <path
                                d="M 20 -10 Q 30 0 20 10"
                                fill="none"
                                stroke="#3b82f6"
                                stroke-width="2"
                                opacity="0.8"
                            >
                                <animate
                                    attributeName="d"
                                    values="M 20 -10 Q 30 0 20 10; M 30 -15 Q 45 0 30 15"
                                    dur="0.5s"
                                    repeatCount="indefinite"></animate>
                                <animate
                                    attributeName="opacity"
                                    values="0.8; 0"
                                    dur="0.5s"
                                    repeatCount="indefinite"></animate>
                            </path>
                        </g>

                        <g transform="translate(100, 250)">
                            <rect x="0" y="0" width="200" height="20" fill="url(#spectrum)" rx="2"
                            ></rect>

                            <g class="animate-shift-lines">
                                <line x1="40" y1="0" x2="40" y2="20" stroke="black" stroke-width="2"
                                ></line>
                                <line
                                    x1="150"
                                    y1="0"
                                    x2="150"
                                    y2="20"
                                    stroke="black"
                                    stroke-width="2"></line>
                                <line
                                    x1="180"
                                    y1="0"
                                    x2="180"
                                    y2="20"
                                    stroke="black"
                                    stroke-width="2"></line>
                            </g>
                            <text x="100" y="35" text-anchor="middle" fill="#94a3b8" font-size="10"
                                >ESPECTRO (REDSHIFT)</text
                            >
                        </g>

                        <defs>
                            <linearGradient id="spectrum" x1="0" y1="0" x2="1" y2="0">
                                <stop offset="0%" stop-color="#3b82f6"></stop>

                                <stop offset="50%" stop-color="#22c55e"></stop>
                                <stop offset="100%" stop-color="#ef4444"></stop>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #020617;
        color: #e2e8f0;
    }

    .med-tag-local {
        color: #38bdf8;
        border-color: #0ea5e9;
    }

    .med-title-local {
        color: #f0f9ff;
    }

    .med-description-local {
        color: #bae6fd;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #0f172a 50%, transparent);
        border-color: #1e293b;
    }

    .med-card-title-local {
        color: #7dd3fc;
    }

    .med-card-text-local {
        color: #e2e8f0;
    }

    .med-card-note-local {
        color: #38bdf8;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes moveSource {
        0% {
            transform: translate(150px, 150px);
        }
        50% {
            transform: translate(300px, 150px);
        }
        100% {
            transform: translate(150px, 150px);
        }
    }
    .animate-move-source {
        animation: moveSource 4s ease-in-out infinite;
    }

    @keyframes shiftLines {
        0% {
            transform: translateX(0);
        }
        50% {
            transform: translateX(15px);
        }
        100% {
            transform: translateX(0);
        }
    }
    .animate-shift-lines {
        animation: shiftLines 4s ease-in-out infinite;
    }

    .med-star-dot {
        position: absolute;
        border-radius: 9999px;
        background-color: white;
        opacity: 0.5;
    }

    .med-visual-svg {
        width: 100%;
        height: 100%;
        overflow: visible;
    }
</style>
