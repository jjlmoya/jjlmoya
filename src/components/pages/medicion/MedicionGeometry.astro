---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-20">
        <svg class="med-w-full med-h-full" preserveAspectRatio="none">
            <filter id="noise">
                <feTurbulence type="fractalNoise" baseFrequency="0.05" numOctaves="3" result="noise"
                ></feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="20"></feDisplacementMap>
            </filter>
            <rect width="100%" height="100%" fill="#573e32" filter="url(#noise)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Orden del Caos</span
                >
                <h2 class="med-title med-title-local">Geo-metría</h2>

                <p class="med-description med-description-local">
                    Cada año, el Nilo borraba todas las fronteras. El mundo volvía al caos
                    primordial. ¿De quién es esta tierra si las marcas han desaparecido bajo el
                    lodo?
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Los Estiradores de Cuerda</h3>
                    <p class="med-card-text med-card-text-local">
                        Los <em>Harpedonaptae</em> bajaban con cuerdas anudadas. Sabían un secreto sagrado:
                        3 nudos, 4 nudos y 5 nudos forman un ángulo perfecto.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Con ese triángulo, imponían de nuevo la cuadrícula sobre el barro. Medir era
                        un acto divino: crear orden donde no lo había.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <g stroke="#573e32" stroke-width="2" opacity="0.5">
                            <path d="M 0 50 Q 100 0 200 80 T 400 50" fill="none"></path>
                            <path d="M 0 150 Q 150 200 300 120 T 400 180" fill="none"></path>
                            <path d="M 0 250 Q 80 220 180 280 T 400 240" fill="none"></path>
                        </g>

                        <g transform="translate(100, 50) scale(1.2)">
                            <path
                                d="M 0 160 L 120 160 L 0 0 Z"
                                fill="none"
                                stroke="#e7e5e4"
                                stroke-width="3"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="animate-draw-rope"></path>

                            <circle cx="0" cy="40" r="4" fill="#fbbf24"></circle>
                            <circle cx="0" cy="80" r="4" fill="#fbbf24"></circle>
                            <circle cx="0" cy="120" r="4" fill="#fbbf24"></circle>

                            <circle cx="40" cy="160" r="4" fill="#fbbf24"></circle>
                            <circle cx="80" cy="160" r="4" fill="#fbbf24"></circle>

                            <circle cx="96" cy="128" r="4" fill="#fbbf24"></circle>
                            <circle cx="72" cy="96" r="4" fill="#fbbf24"></circle>
                            <circle cx="48" cy="64" r="4" fill="#fbbf24"></circle>
                            <circle cx="24" cy="32" r="4" fill="#fbbf24"></circle>

                            <circle cx="0" cy="0" r="6" fill="#d97706"></circle>
                            <circle cx="0" cy="160" r="6" fill="#d97706"></circle>
                            <circle cx="120" cy="160" r="6" fill="#d97706"></circle>

                            <path
                                d="M 0 140 L 20 140 L 20 160"
                                fill="none"
                                stroke="#d97706"
                                stroke-width="2"
                                opacity="0.8"></path>
                        </g>

                        <g stroke="#e7e5e4" stroke-width="1" stroke-dasharray="4 4" opacity="0.3">
                            <line x1="100" y1="0" x2="100" y2="300" class="animate-grid-reveal"
                            ></line>
                            <line
                                x1="244"
                                y1="0"
                                x2="244"
                                y2="300"
                                class="animate-grid-reveal"
                                style="animation-delay: 0.5s"></line>
                            <line
                                x1="0"
                                y1="242"
                                x2="400"
                                y2="242"
                                class="animate-grid-reveal"
                                style="animation-delay: 1s"></line>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #271c19;
        color: #d6d3d1;
    }

    .med-tag-local {
        color: #a8a29e;
        border-color: #57534e;
    }

    .med-title-local {
        color: #e7e5e4;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #d6d3d1;
    }

    .med-card-text-local {
        color: #a8a29e;
    }

    .med-card-note-local {
        color: #e7e5e4;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #442f26 50%, transparent);
        border-color: #78350f;
    }

    @keyframes drawRope {
        from {
            stroke-dasharray: 1000;
            stroke-dashoffset: 1000;
        }
        to {
            stroke-dasharray: 1000;
            stroke-dashoffset: 0;
        }
    }
    .animate-draw-rope {
        animation: drawRope 4s ease-out forwards;
    }

    @keyframes gridReveal {
        from {
            opacity: 0;
        }
        to {
            opacity: 0.3;
        }
    }
    .animate-grid-reveal {
        animation: gridReveal 2s ease-in forwards;
    }
</style>
