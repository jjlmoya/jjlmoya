---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-opacity-30">
        <div
            class="med-absolute med-bottom-0 med-left-0 med-right-0 animate-wave-slow" style="height: 16rem; background: linear-gradient(to top, #0c4a6e, transparent);"
        >
        </div>
        <div
            class="med-absolute med-left-0 med-right-0 animate-wave-fast med-opacity-70" style="bottom: -20px; height: 16rem; background: linear-gradient(to top, #075985, transparent);"
        >
        </div>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >Vida o Muerte</span
                >
                <h2 class="med-title med-title-local">El Reloj del Mar</h2>

                <p class="med-description med-description-local">
                    Saber la latitud (norte-sur) era fácil: mirabas las estrellas. Pero la longitud
                    (este-oeste) era el mayor misterio de la navegación.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Tiempo = Distancia</h3>
                    <p class="med-card-text med-card-text-local">
                        Si sabes qué hora es en Londres y qué hora es en tu barco (por el sol),
                        sabes cuán lejos estás. Pero los relojes de péndulo no funcionan en un barco
                        que se mueve.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        John Harrison dedicó su vida a construir un reloj que desafiara al mar.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 200 200" class="med-w-full med-h-full" style="filter: drop-shadow(0 25px 25px rgba(0,0,0,0.15))">
                        <circle
                            cx="100"
                            cy="100"
                            r="95"
                            fill="#1e293b"
                            stroke="#ca8a04"
                            stroke-width="8"></circle>
                        <circle
                            cx="100"
                            cy="100"
                            r="88"
                            fill="none"
                            stroke="#fef08a"
                            stroke-width="1"
                            opacity="0.5"></circle>

                        <circle cx="100" cy="100" r="85" fill="#fefce8" opacity="0.95"></circle>

                        <g stroke="black" stroke-width="2" stroke-linecap="round">
                            {
                                Array.from({ length: 12 }).map((_, i) => (
                                    <line
                                        x1="100"
                                        y1="25"
                                        x2="100"
                                        y2="35"
                                        transform={`rotate(${i * 30} 100 100)`}
                                    />
                                ))
                            }
                        </g>
                        <g stroke="black" stroke-width="1" opacity="0.5">
                            {
                                Array.from({ length: 60 }).map((_, i) => (
                                    <line
                                        x1="100"
                                        y1="25"
                                        x2="100"
                                        y2="28"
                                        transform={`rotate(${i * 6} 100 100)`}
                                    />
                                ))
                            }
                        </g>

                        <g>
                            <line
                                x1="100"
                                y1="100"
                                x2="100"
                                y2="50"
                                stroke="black"
                                stroke-width="4"
                                stroke-linecap="round"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    from="0 100 100"
                                    to="360 100 100"
                                    dur="60s"
                                    repeatCount="indefinite"></animateTransform>
                            </line>

                            <line
                                x1="100"
                                y1="100"
                                x2="100"
                                y2="35"
                                stroke="black"
                                stroke-width="2"
                                stroke-linecap="round"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    from="0 100 100"
                                    to="360 100 100"
                                    dur="5s"
                                    repeatCount="indefinite"></animateTransform>
                            </line>

                            <line
                                x1="100"
                                y1="110"
                                x2="100"
                                y2="30"
                                stroke="#dc2626"
                                stroke-width="1"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    from="0 100 100"
                                    to="360 100 100"
                                    dur="1s"
                                    repeatCount="indefinite"></animateTransform>
                            </line>

                            <circle
                                cx="100"
                                cy="100"
                                r="3"
                                fill="#ca8a04"
                                stroke="black"
                                stroke-width="1"></circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #082f49;
        color: #e0f2fe;
    }

    .med-tag-local {
        color: #7dd3fc;
        border-color: #0ea5e9;
    }

    .med-title-local {
        color: #ffffff;
    }

    .med-description-local {
        color: #bae6fd;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #38bdf8;
    }

    .med-card-text-local {
        color: #e0f2fe;
    }

    .med-card-note-local {
        color: #7dd3fc;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #0c4a6e 50%, transparent);
        border-color: #38bdf8;
    }

    @keyframes waveSlow {
        0%,
        100% {
            transform: translateY(0) scaleY(1);
        }
        50% {
            transform: translateY(-20px) scaleY(1.1);
        }
    }
    .animate-wave-slow {
        animation: waveSlow 8s ease-in-out infinite;
    }

    @keyframes waveFast {
        0%,
        100% {
            transform: translateY(0) scaleY(1);
        }
        50% {
            transform: translateY(-15px) scaleY(1.2);
        }
    }
    .animate-wave-fast {
        animation: waveFast 5s ease-in-out infinite reverse;
    }

    @keyframes floatShip {
        0%,
        100% {
            transform: rotate(-5deg) translateY(0);
        }
        50% {
            transform: rotate(5deg) translateY(-10px);
        }
    }
    .animate-float-ship {
        animation: floatShip 4s ease-in-out infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 16rem; }
</style>
