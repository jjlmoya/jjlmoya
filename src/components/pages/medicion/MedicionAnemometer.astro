---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-overflow-hidden">
        {
            Array.from({ length: 15 }).map(() => (
                <div
                    class="med-absolute med-h-px medicion-anemometer-wind-line"
                    style={`top: ${Math.random() * 100}%; width: ${Math.random() * 50 + 20}%; animation-duration: ${Math.random() * 2 + 1}s; animation-delay: ${Math.random()}s;`}
                />
            ))
        }
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >Cazando la Brisa</span
                >
                <h2 class="med-title med-title-local">El Anemómetro</h2>

                <p class="med-description med-description-local">
                    El viento es invisible y caótico. Puedes sentirlo, pero no puedes verlo. ¿Cómo
                    mides la velocidad de algo que no puedes tocar?
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Atrapar y Girar</h3>
                    <p class="med-card-text med-card-text-local">
                        John Thomas Romney Robinson inventó en 1846 el anemómetro de cazoletas. La
                        idea es simple: convertir el movimiento lineal del viento en movimiento
                        rotatorio.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Contando las vueltas por minuto, sabemos exactamente a qué velocidad viaja
                        el aire.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 300 300" class="med-w-full med-h-full med-overflow-visible">
                        <rect x="145" y="150" width="10" height="150" fill="#4b5563"></rect>

                        <g transform="translate(150, 150)" class="animate-spin-wind">
                            <line x1="-100" y1="0" x2="100" y2="0" stroke="#9ca3af" stroke-width="4"
                            ></line>
                            <line x1="0" y1="-100" x2="0" y2="100" stroke="#9ca3af" stroke-width="4"
                            ></line>

                            <path
                                d="M 100 -20 A 20 20 0 0 1 100 20 L 120 20 L 120 -20 Z"
                                fill="#ef4444"
                                transform="rotate(0)"></path>

                            <path
                                d="M -20 100 A 20 20 0 0 1 20 100 L 20 120 L -20 120 Z"
                                fill="#3b82f6"
                                transform="rotate(0)"></path>

                            <path
                                d="M -100 -20 A 20 20 0 0 0 -100 20 L -120 20 L -120 -20 Z"
                                fill="#eab308"
                                transform="rotate(0)"></path>

                            <path
                                d="M -20 -100 A 20 20 0 0 0 20 -100 L 20 -120 L -20 -120 Z"
                                fill="#22c55e"
                                transform="rotate(0)"></path>

                            <circle
                                cx="0"
                                cy="0"
                                r="10"
                                fill="#1f2937"
                                stroke="#9ca3af"
                                stroke-width="2"></circle>
                        </g>

                        <g opacity="0.5">
                            <path
                                d="M -50 100 L 50 100"
                                stroke="white"
                                stroke-width="1"
                                stroke-dasharray="5 5"
                                class="animate-wind-stream"></path>
                            <path
                                d="M -50 180 L 100 180"
                                stroke="white"
                                stroke-width="1"
                                stroke-dasharray="5 5"
                                class="animate-wind-stream"
                                style="animation-delay: 0.5s"></path>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #374151;
        color: #f3f4f6;
    }

    .med-tag-local {
        color: #9ca3af;
        border-color: #6b7280;
    }

    .med-title-local {
        color: #ffffff;
    }

    .med-description-local {
        color: #e5e7eb;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #d1d5db;
    }

    .med-card-text-local {
        color: #f3f4f6;
    }

    .med-card-note-local {
        color: #9ca3af;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #1f2937 50%, transparent);
        border-color: #4b5563;
    }

    .medicion-anemometer-wind-line {
        background-color: #9ca3af;
        opacity: 0.2;
        animation: windLine linear infinite;
    }

    @keyframes windLine {
        from {
            transform: translateX(-100%);
        }
        to {
            transform: translateX(200%);
        }
    }
    .animate-wind-line {
        animation: windLine linear infinite;
    }

    @keyframes spinWind {
        from {
            transform: translate(150px, 150px) rotate(0deg);
        }
        to {
            transform: translate(150px, 150px) rotate(360deg);
        }
    }
    .animate-spin-wind {
        animation: spinWind 2s linear infinite;
    }

    @keyframes windStream {
        from {
            stroke-dashoffset: 10;
            opacity: 0;
        }
        to {
            stroke-dashoffset: -10;
            opacity: 1;
        }
    }
    .animate-wind-stream {
        animation: windStream 1s linear infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 100%; display: flex; align-items: center; justify-content: center; }
</style>
