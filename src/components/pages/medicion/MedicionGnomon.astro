---

---

<section
    class="med-section med-section-local"
>
    <div
        class="med-absolute med-inset-0 med-pointer-events-none med-opacity-50"
        style="background: linear-gradient(to bottom, #0284c7, #e0f2fe);"
    >
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Sombra del Tiempo</span
                >
                <h2 class="med-title med-title-local">El Gnomon</h2>

                <p class="med-description med-description-local">
                    Antes de los engranajes, el tiempo era geometría. Un simple palo clavado en la
                    tierra fue el primer instrumento científico de la humanidad.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">El Sol Escribe</h3>
                    <p class="med-card-text med-card-text-local">
                        La longitud de la sombra te dice la hora. Su dirección, el norte. Su cambio
                        durante el año, las estaciones y los solsticios.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        No necesitaban baterías. Solo necesitaban que el cielo no se cayera.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <path
                            d="M 50 200 L 350 200 L 300 250 L 0 250 Z"
                            fill="#e0f2fe"
                            stroke="#bae6fd"
                            stroke-width="1"></path>

                        <g stroke="#94a3b8" stroke-width="1" fill="none" opacity="0.5">
                            <path d="M 200 200 L 150 240"></path>
                            <path d="M 200 200 L 200 240"></path>
                            <path d="M 200 200 L 250 240"></path>
                        </g>

                        <line
                            x1="200"
                            y1="200"
                            x2="200"
                            y2="100"
                            stroke="#0c4a6e"
                            stroke-width="4"
                            stroke-linecap="round"></line>

                        <g class="animate-sun-arc">
                            <circle
                                cx="0"
                                cy="0"
                                r="15"
                                fill="#fbbf24"
                                stroke="#f59e0b"
                                stroke-width="2"></circle>

                            <g stroke="#fbbf24" stroke-width="2">
                                <line x1="0" y1="-20" x2="0" y2="-25"></line>
                                <line x1="0" y1="20" x2="0" y2="25"></line>
                                <line x1="-20" y1="0" x2="-25" y2="0"></line>
                                <line x1="20" y1="0" x2="25" y2="0"></line>
                            </g>
                        </g>

                        <line
                            x1="200"
                            y1="200"
                            x2="200"
                            y2="200"
                            stroke="#000"
                            stroke-width="4"
                            opacity="0.3"
                            stroke-linecap="round"
                            class="animate-shadow-cast"></line>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #0ea5e9;
        color: #f0f9ff;
    }

    .med-tag-local {
        color: #0369a1;
        border-color: #0284c7;
    }

    .med-title-local {
        color: #0c4a6e;
    }

    .med-description-local {
        color: #075985;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #0c4a6e;
    }

    .med-card-text-local {
        color: #0369a1;
    }

    .med-card-note-local {
        color: #0284c7;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #bae6fd 50%, transparent);
        border-color: #7dd3fc;
    }

    @keyframes sunArc {
        0% {
            transform: translate(50px, 150px);
        }
        50% {
            transform: translate(200px, 50px);
        }
        100% {
            transform: translate(350px, 150px);
        }
    }
    .animate-sun-arc {
        animation: sunArc 5s ease-in-out infinite;
    }

    @keyframes shadowCast {
        0% {
            x2: 300px;
            y2: 220px;
            opacity: 0.3;
        }
        50% {
            x2: 200px;
            y2: 210px;
            opacity: 0.5;
        }
        100% {
            x2: 100px;
            y2: 220px;
            opacity: 0.3;
        }
    }
    .animate-shadow-cast {
        animation: shadowCast 5s ease-in-out infinite;
    }
</style>
