---

---

<section
    class="med-section med-section-local"
>
    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-decimal-tag"
                    >La Utopía Fallida</span
                >
                <h2 class="med-decimal-title">El Tiempo Decimal</h2>

                <p class="med-decimal-desc">
                    Embriagados de lógica, los revolucionarios franceses intentaron rediseñar el
                    tiempo mismo. Si el metro se divide en 10, ¿por qué no el día?
                </p>

                <div class="med-decimal-card">
                    <div class="med-decimal-row">
                        <span class="med-decimal-label">1 Día</span>
                        <span class="med-decimal-value">10 Horas</span>
                    </div>
                    <div class="med-decimal-row">
                        <span class="med-decimal-label">1 Hora</span>
                        <span class="med-decimal-value">100 Minutos</span>
                    </div>
                    <div class="med-decimal-row med-decimal-row--last">
                        <span class="med-decimal-label">1 Minuto</span>
                        <span class="med-decimal-value">100 Segundos</span>
                    </div>
                </div>

                <p class="med-decimal-note">
                    Fue un desastre absoluto. Los relojes tuvieron que ser refabricados. La gente no
                    sabía cuándo comer o dormir. Duró menos de 2 años. La naturaleza humana rechazó
                    la perfección matemática.
                </p>
            </div>

            <div class="med-decimal-visual-col">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 200 200" class="med-decimal-visual-svg">
                        <circle
                            cx="100"
                            cy="100"
                            r="98"
                            fill="#262626"
                            stroke="#404040"
                            stroke-width="4"></circle>

                        <circle cx="100" cy="100" r="90" fill="#171717"></circle>

                        <g>
                            {
                                Array.from({ length: 10 }).map((_, i) => (
                                    <g transform={`rotate(${i * 36} 100 100)`}>
                                        <line
                                            x1="100"
                                            y1="15"
                                            x2="100"
                                            y2="25"
                                            stroke="#22d3ee"
                                            stroke-width="2"
                                        />
                                        <text
                                            x="100"
                                            y="40"
                                            fill="#22d3ee"
                                            font-size="14"
                                            text-anchor="middle"
                                            transform={`rotate(${-i * 36} 100 40)`}
                                        >
                                            {i === 0 ? 10 : i}
                                        </text>
                                    </g>
                                ))
                            }
                        </g>

                        <g>
                            <line
                                x1="100"
                                y1="100"
                                x2="100"
                                y2="45"
                                stroke="white"
                                stroke-width="3"
                                stroke-linecap="round"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    from="0 100 100"
                                    to="360 100 100"
                                    dur="20s"
                                    repeatCount="indefinite"></animateTransform>
                            </line>

                            <line
                                x1="100"
                                y1="100"
                                x2="100"
                                y2="25"
                                stroke="#22d3ee"
                                stroke-width="1.5"
                                stroke-linecap="round"
                            >
                                <animateTransform
                                    attributeName="transform"
                                    type="rotate"
                                    from="0 100 100"
                                    to="360 100 100"
                                    dur="2s"
                                    repeatCount="indefinite"></animateTransform>
                            </line>

                            <circle
                                cx="100"
                                cy="100"
                                r="4"
                                fill="#404040"
                                stroke="#171717"
                                stroke-width="1"></circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-decimal-tag {
        color: #06b6d4;
        font-family: monospace;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border-bottom: 1px solid #164e63;
        padding-bottom: 0.5rem;
    }
    .med-decimal-title {
        font-size: 2.25rem;
        font-weight: 700;
        letter-spacing: -0.025em;
    }
    @media (min-width: 768px) {
        .med-decimal-title {
            font-size: 3rem;
        }
    }
    .med-decimal-desc {
        font-size: 1.125rem;
        color: #a3a3a3;
        line-height: 1.625;
    }
    .med-decimal-card {
        background-color: rgba(115,115,115,0.5);
        padding: 1.5rem;
        border-radius: 0.25rem;
        border: 1px solid #404040;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .med-decimal-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #404040;
        padding-bottom: 0.5rem;
    }
    .med-decimal-row--last {
        border-bottom: none;
        padding-bottom: 0;
    }
    .med-decimal-label {
        color: #22d3ee;
        font-weight: 700;
    }
    .med-decimal-value {
        font-family: monospace;
    }
    .med-decimal-note {
        font-size: 0.875rem;
        color: #737373;
        font-style: italic;
    }
    .med-decimal-visual-col {
        width: 100%;
        display: flex;
        justify-content: center;
    }
    @media (min-width: 768px) {
        .med-decimal-visual-col {
            width: 50%;
        }
    }
    .med-decimal-visual-svg {
        width: 100%;
        height: 100%;
        filter: drop-shadow(0 25px 25px rgba(0,0,0,0.15));
    }
</style>
