---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none medicion-carbon-noise">
        <svg class="med-w-full med-h-full">
            <filter id="noiseFossil">
                <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3"></feTurbulence>
            </filter>
            <rect width="100%" height="100%" fill="#57534e" filter="url(#noiseFossil)"></rect>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Reloj de la Muerte</span
                >
                <h2 class="med-title med-title-local">Carbono-14</h2>

                <p class="med-description med-description-local">
                    Mientras vivimos, respiramos el tiempo. Cuando morimos, el reloj empieza a
                    correr hacia atrás.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Vida Media: 5.730 Años</h3>
                    <p class="med-card-text med-card-text-local">
                        El Carbono-14 es inestable. Cada 5.730 años, la mitad de sus átomos
                        desaparecen.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        Contando los átomos que quedan en un hueso, podemos saber exactamente cuándo
                        dejó de respirar su dueño. Es la medida de la historia profunda.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <path
                            d="M 100 150 Q 80 120 60 140 Q 40 160 60 180 Q 80 200 100 170 L 300 170 Q 320 200 340 180 Q 360 160 340 140 Q 320 120 300 150 Z"
                            fill="#44403c"
                            stroke="#57534e"
                            stroke-width="2"></path>

                        <g>
                            {
                                Array.from({ length: 100 }).map(() => (
                                    <circle
                                        cx={80 + Math.random() * 240}
                                        cy={130 + Math.random() * 40}
                                        r={2}
                                        fill="#fbbf24"
                                        class="animate-decay"
                                        style={`animation-delay: ${Math.random() * 5}s`}
                                    />
                                ))
                            }
                        </g>

                        <g transform="translate(50, 250)">
                            <line x1="0" y1="0" x2="300" y2="0" stroke="#78716c" stroke-width="1"
                            ></line>
                            <line x1="0" y1="0" x2="0" y2="-100" stroke="#78716c" stroke-width="1"
                            ></line>

                            <path
                                d="M 0 -100 Q 50 -50 100 -50 T 300 -12"
                                fill="none"
                                stroke="#fbbf24"
                                stroke-width="2"
                                stroke-dasharray="4 4"
                                opacity="0.5"></path>

                            <circle r="4" fill="#ef4444">
                                <animateMotion
                                    dur="5s"
                                    repeatCount="indefinite"
                                    path="M 0 -100 Q 50 -50 100 -50 T 300 -12"></animateMotion>
                            </circle>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #1c1917;
        color: #e7e5e4;
    }

    .med-tag-local {
        color: #a8a29e;
        border-color: #57534e;
    }

    .med-title-local {
        color: #f5f5f4;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #e7e5e4;
    }

    .med-card-text-local {
        color: #a8a29e;
    }

    .med-card-note-local {
        color: #d6d3d1;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #292524 50%, transparent);
        border-color: #44403c;
    }

    .medicion-carbon-noise {
        opacity: 0.1;
    }

    @keyframes decay {
        0% {
            opacity: 1;
            fill: #fbbf24;
        }
        90% {
            opacity: 1;
            fill: #fbbf24;
        }
        95% {
            opacity: 0.5;
            fill: #57534e;
        }
        100% {
            opacity: 0;
        }
    }
    .animate-decay {
        animation: decay 5s linear infinite;
    }
</style>
