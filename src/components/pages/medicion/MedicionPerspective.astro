---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none med-opacity-20">
        <svg class="med-w-full med-h-full" preserveAspectRatio="none">
            <defs>
                <pattern
                    id="perspectiveGrid"
                    x="0"
                    y="0"
                    width="100"
                    height="100"
                    patternUnits="userSpaceOnUse"
                >
                    <path
                        d="M 0 0 L 100 0 M 0 0 L 0 100"
                        fill="none"
                        stroke="#a8a29e"
                        stroke-width="0.5"></path>
                </pattern>
            </defs>
        </svg>

        <div
            class="med-absolute med-inset-0" style="background: radial-gradient(circle at center,transparent 0%,#2c241b 100%)"
        >
        </div>
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Ventana de Alberti</span
                >
                <h2 class="med-title med-title-local">
                    La Perspectiva
                </h2>

                <p class="med-description med-description-local">
                    El mundo es tridimensional, pero nuestros lienzos son planos. Durante siglos, el
                    arte fue plano. Hasta que aprendimos a medir la profundidad.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">El Punto de Fuga</h3>
                    <p class="med-card-text med-card-text-local">
                        Brunelleschi y Alberti matematizaron la visión. Todas las líneas paralelas
                        convergen en un solo punto en el infinito.
                    </p>
                    <p class="med-card-note med-card-note-local">
                        No medían objetos, medían el espacio entre ellos. Fue la primera realidad
                        virtual: engañar al ojo con geometría.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 300" class="med-w-full med-h-full med-overflow-visible">
                        <circle cx="200" cy="150" r="2" fill="#ef4444" z-index="10"></circle>

                        <line x1="0" y1="150" x2="400" y2="150" stroke="#78716c" stroke-width="1"
                        ></line>

                        <g stroke="#57534e" stroke-width="1" opacity="0.5">
                            {
                                Array.from({ length: 11 }).map((_, i) => (
                                    <line x1={i * 40} y1="300" x2="200" y2="150" />
                                ))
                            }
                        </g>

                        <g stroke="#57534e" stroke-width="1" opacity="0.2">
                            {
                                Array.from({ length: 5 }).map((_, i) => (
                                    <line x1={i * 100} y1="0" x2="200" y2="150" />
                                ))
                            }
                        </g>

                        <g stroke="#57534e" stroke-width="1" opacity="0.5">
                            <line x1="0" y1="280" x2="400" y2="280"></line>
                            <line x1="40" y1="240" x2="360" y2="240"></line>
                            <line x1="80" y1="210" x2="320" y2="210"></line>
                            <line x1="110" y1="190" x2="290" y2="190"></line>
                            <line x1="130" y1="175" x2="270" y2="175"></line>
                        </g>

                        <g transform="translate(100, 200)" class="animate-draw-cube">
                            <rect
                                x="0"
                                y="0"
                                width="40"
                                height="40"
                                fill="none"
                                stroke="#e7e5e4"
                                stroke-width="2"></rect>
                        </g>

                        <g stroke="#e7e5e4" stroke-width="1" stroke-dasharray="2 2" opacity="0.5">
                            <line x1="100" y1="200" x2="200" y2="150"></line>

                            <line x1="140" y1="200" x2="200" y2="150"></line>
                        </g>

                        <rect
                            x="50"
                            y="50"
                            width="300"
                            height="200"
                            fill="none"
                            stroke="#d6d3d1"
                            stroke-width="4"></rect>
                        <text x="200" y="40" text-anchor="middle" fill="#78716c" font-size="10"
                            >PICTURA</text
                        >
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #2c241b;
        color: #e7e5e4;
    }

    .med-tag-local {
        color: #d6d3d1;
        border-color: #78716c;
    }

    .med-title-local {
        color: #f5f5f4;
    }

    .med-description-local {
        color: #d6d3d1;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #44403c 50%, transparent);
        border-color: #57534e;
    }

    .med-card-title-local {
        color: #e7e5e4;
    }

    .med-card-text-local {
        color: #a8a29e;
    }

    .med-card-note-local {
        color: #d6d3d1;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes drawCube {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
    .animate-draw-cube {
        animation: drawCube 2s ease-in forwards;
    }
</style>
