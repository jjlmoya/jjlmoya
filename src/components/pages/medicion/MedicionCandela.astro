---

---

<section
    class="med-section med-section-local"
>
    <div class="med-background">
        <div
            class="med-absolute med-top-50 med-left-50 med-opacity-10 animate-spin-slow med-translate-x-half med-translate-y-half"
            style="width: 200%; height: 200%; background: conic-gradient(from 0deg, transparent 0deg, #fef08a 10deg, transparent 20deg);"
        >
        </div>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >Brillo Estándar</span
                >
                <h2 class="med-title med-title-local">La Candela</h2>

                <p class="med-description med-description-local">
                    ¿Cómo de brillante es una luz? Durante siglos, la respuesta fue literal: "Brilla
                    como una vela". Pero no todas las velas son iguales.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">De la Ballena al Átomo</h3>
                    <p class="med-card-text med-card-text-local">
                        Originalmente, la unidad era una vela de esperma de ballena de un sexto de
                        libra, quemando a 120 granos por hora.
                    </p>
                    <p class="med-mt-4 med-text-sm med-leading-relaxed" style="color: #fef08a;">
                        Hoy, la <strong>Candela</strong> es una de las 7 unidades base del sistema internacional,
                        definida por la radiación monocromática de frecuencia 540×10¹² Hz.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 200 300" class="med-w-full med-h-full med-overflow-visible">
                        <g transform="translate(50, 200)">
                            <rect x="-10" y="0" width="20" height="60" fill="#fef3c7"></rect>
                            <path
                                d="M 0 0 Q 5 -20 0 -40 Q -5 -20 0 0"
                                fill="#fbbf24"
                                class="animate-flame"></path>
                            <text x="0" y="80" text-anchor="middle" fill="#fde047" font-size="10"
                                >1860</text
                            >
                        </g>

                        <path
                            d="M 80 200 L 120 200"
                            stroke="#fef08a"
                            stroke-width="1"
                            stroke-dasharray="4 4"></path>
                        <text x="100" y="190" text-anchor="middle" fill="#fef08a" font-size="8"
                            >VS</text
                        >

                        <g transform="translate(150, 200)">
                            <circle
                                cx="0"
                                cy="-20"
                                r="20"
                                fill="#fef9c3"
                                fill-opacity="0.2"
                                stroke="#fef08a"
                                stroke-width="1"></circle>
                            <path
                                d="M -5 -20 L 5 -20 M 0 -25 L 0 -15"
                                stroke="#fef08a"
                                stroke-width="2"
                                class="animate-pulse-light"></path>
                            <rect x="-8" y="0" width="16" height="20" fill="#525252"></rect>
                            <text x="0" y="80" text-anchor="middle" fill="#fde047" font-size="10"
                                >SI UNIT</text
                            >
                        </g>

                        <g transform="translate(100, 100)" opacity="0.5">
                            {
                                Array.from({ length: 8 }).map((_, i) => (
                                    <line
                                        x1="0"
                                        y1="0"
                                        x2="0"
                                        y2="-40"
                                        stroke="#fef08a"
                                        stroke-width="2"
                                        transform={`rotate(${i * 45})`}
                                    >
                                        <animate
                                            attributeName="stroke-opacity"
                                            values="0;1;0"
                                            dur="2s"
                                            begin={`${i * 0.2}s`}
                                            repeatCount="indefinite"
                                        />
                                    </line>
                                ))
                            }
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #2a2a2a;
        color: #fef08a;
    }

    .med-tag-local {
        color: #fde047;
        border-color: #ca8a04;
    }

    .med-title-local {
        color: #ffffff;
    }

    .med-description-local {
        color: #fef9c3;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #fde047;
    }

    .med-card-text-local {
        color: #fef08a;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #422006 50%, transparent);
        border-color: #eab308;
    }

    @keyframes spinSlow {
        from {
            transform: translate(-50%, -50%) rotate(0deg);
        }
        to {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }
    .animate-spin-slow {
        animation: spinSlow 20s linear infinite;
    }

    @keyframes flame {
        0%,
        100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.1) rotate(2deg);
        }
    }
    .animate-flame {
        transform-origin: center bottom;
        animation: flame 0.5s ease-in-out infinite;
    }

    @keyframes pulseLight {
        0%,
        100% {
            opacity: 0.5;
        }
        50% {
            opacity: 1;
        }
    }
    .animate-pulse-light {
        animation: pulseLight 0.1s linear infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 100%; display: flex; align-items: center; justify-content: center; }
</style>
