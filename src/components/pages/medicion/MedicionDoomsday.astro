---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none medicion-doomsday-noise">
        <svg class="med-w-full med-h-full">
            <filter id="noiseSignal">
                <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3"></feTurbulence>
                <feColorMatrix type="saturate" values="0"></feColorMatrix>
            </filter>
            <rect width="100%" height="100%" fill="#000" filter="url(#noiseSignal)"></rect>
        </svg>
    </div>

    <div class="med-absolute med-inset-0 medicion-doomsday-pulse med-pointer-events-none"></div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >Extinción Inminente</span
                >
                <h2 class="med-title med-title-local">
                    El Reloj del Juicio Final
                </h2>

                <p class="med-description med-description-local">
                    No mide el tiempo, mide nuestra estupidez. Creado en 1947 por los padres de la
                    bomba atómica para advertirnos de nuestra propia tecnología.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="medicion-doomsday-splat med-font-bold med-mb-2 med-text-xl">90 Segundos</h3>
                    <p class="med-card-text med-card-text-local">
                        Es lo más cerca que hemos estado nunca de la medianoche. Amenaza nuclear.
                        Cambio climático. Inteligencia Artificial.
                    </p>
                    <p class="med-mt-4 med-text-sm med-font-bold med-italic med-tracking-wide medicion-doomsday-warning">
                        CUANDO EL RELOJ MARQUE LAS 12, NO HABRÁ NADIE PARA OÍRLO.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg
                        viewBox="0 0 400 400"
                        class="med-w-full med-h-full med-overflow-hidden medicion-doomsday-svg"
                    >
                        <defs>
                            <filter id="glowRed">
                                <feGaussianBlur stdDeviation="2" result="coloredBlur"
                                ></feGaussianBlur>
                                <feMerge>
                                    <feMergeNode in="coloredBlur"></feMergeNode>
                                    <feMergeNode in="SourceGraphic"></feMergeNode>
                                </feMerge>
                            </filter>
                        </defs>

                        <g transform="translate(380, 380)">
                            <path
                                d="M 0 0 L -350 0 A 350 350 0 0 1 0 -350 Z"
                                fill="#2b0505"
                                stroke="#7f1d1d"
                                stroke-width="2"></path>

                            <path
                                d="M 0 0 L -181 -300 A 350 350 0 0 1 0 -350 Z"
                                fill="#ef4444"
                                opacity="0.1"></path>

                            <g stroke="#7f1d1d" stroke-width="2">
                                <line
                                    x1="0"
                                    y1="-350"
                                    x2="0"
                                    y2="-320"
                                    stroke="#ef4444"
                                    stroke-width="4"
                                    filter="url(#glowRed)"></line>

                                {
                                    Array.from({ length: 15 }).map((_, i) => (
                                        <line
                                            x1="0"
                                            y1="-340"
                                            x2="0"
                                            y2="-350"
                                            transform={`rotate(${(i + 1) * -6})`}
                                            stroke={i < 2 ? "#ef4444" : "#7f1d1d"}
                                            stroke-width={i < 2 ? 3 : 1}
                                        />
                                    ))
                                }
                            </g>

                            <path d="M -8 0 L 0 -200 L 8 0 Z" fill="#5c1c1c"></path>

                            <g class="animate-doom-tick">
                                <path
                                    d="M -6 0 L 0 -330 L 6 0 Z"
                                    fill="#ef4444"
                                    filter="url(#glowRed)"></path>

                                <line
                                    x1="0"
                                    y1="0"
                                    x2="0"
                                    y2="-330"
                                    stroke="#fee2e2"
                                    stroke-width="1"
                                    opacity="0.5"></line>
                            </g>

                            <circle
                                cx="0"
                                cy="0"
                                r="12"
                                fill="#7f1d1d"
                                stroke="#ef4444"
                                stroke-width="2"></circle>
                        </g>

                        <text
                            x="20"
                            y="40"
                            fill="#ef4444"
                            font-size="14"
                            font-weight="bold"
                            opacity="0.8"
                        >
                            TIEMPO RESTANTE:
                        </text>
                        <text
                            x="20"
                            y="70"
                            fill="#fff"
                            font-size="32"
                            font-weight="bold"
                            class="animate-glitch-text"
                        >
                            90s
                        </text>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #2b0505;
        color: #fecaca;
    }

    .med-tag-local {
        color: #ef4444;
        border-color: #7f1d1d;
    }

    .med-title-local {
        color: #ffffff;
    }

    .med-description-local {
        color: #fca5a5;
        opacity: 0.9;
    }

    .med-card-text-local {
        color: #fca5a5;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #450a0a 50%, transparent);
        border-color: #ef4444;
    }

    .medicion-doomsday-noise {
        opacity: 0.2;
    }

    .medicion-doomsday-pulse {
        background-color: rgba(127, 29, 29, 0.1);
        animation: pulseDanger 2s ease-in-out infinite;
    }

    .medicion-doomsday-svg {
        border-radius: 0.5rem;
        border: 1px solid #7f1d1d;
        background-color: #1a0505;
    }

    .medicion-doomsday-splat {
        color: #fecaca;
    }

    .medicion-doomsday-warning {
        color: #ef4444;
        letter-spacing: 0.025em;
    }

    @keyframes doomTick {
        0% {
            transform: rotate(-45deg);
        }
        80% {
            transform: rotate(-2deg);
        }
        85% {
            transform: rotate(-2.5deg);
        }
        90% {
            transform: rotate(-1.5deg);
        }
        100% {
            transform: rotate(-2deg);
        }
    }
    .animate-doom-tick {
        animation: doomTick 10s cubic-bezier(0.1, 0.7, 1, 0.1) infinite;
    }

    @keyframes pulseDanger {
        0%,
        100% {
            opacity: 0;
        }
        50% {
            opacity: 0.3;
        }
    }
    .animate-pulse-danger {
        animation: pulseDanger 2s ease-in-out infinite;
    }

    @keyframes glitchText {
        0% {
            transform: translate(0);
        }
        20% {
            transform: translate(-2px, 2px);
        }
        40% {
            transform: translate(-2px, -2px);
        }
        60% {
            transform: translate(2px, 2px);
        }
        80% {
            transform: translate(2px, -2px);
        }
        100% {
            transform: translate(0);
        }
    }
    .animate-glitch-text {
        animation: glitchText 0.2s steps(2) infinite;
    }
</style>
