---

---

<section
    class="med-section med-section-local"
>
    <div class="med-background">
        {
            Array.from({ length: 100 }).map(() => (
                <div
                    class="med-star-dot animate-twinkle"
                    style={`
                    left: ${Math.random() * 100}%; 
                    top: ${Math.random() * 100}%; 
                    width: ${Math.random() * 2 + 1}px; 
                    height: ${Math.random() * 2 + 1}px; 
                    opacity: ${Math.random()};
                    animation-duration: ${Math.random() * 3 + 2}s;
                 `}
                />
            ))
        }
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Escalera al Cielo</span
                >
                <h2 class="med-title med-title-local">El Paralaje</h2>

                <p class="med-description med-description-local">
                    Durante milenios, las estrellas fueron un telón de fondo fijo e inalcanzable.
                    ¿Cómo mides la distancia a algo que no puedes tocar ni triangular desde el
                    suelo?
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">El Guiño de la Tierra</h3>
                    <p class="med-card-text med-card-text-local">
                        En 1838, Friedrich Bessel usó la órbita de la Tierra como regla. Miró una
                        estrella (61 Cygni) en enero y luego en julio.
                    </p>
                    <p class="med-parallax-text">
                        La estrella parecía moverse mínimamente contra el fondo lejano. Ese ángulo
                        infinitesimal reveló una distancia aterradora: 10 años luz. El universo
                        acababa de volverse gigante.
                    </p>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-wrapper">
                    <svg viewBox="0 0 400 400" class="med-visual-svg">
                        <circle cx="200" cy="350" r="20" fill="#fbbf24" class="med-blur-sm"></circle>

                        <ellipse
                            cx="200"
                            cy="350"
                            rx="100"
                            ry="30"
                            fill="none"
                            stroke="#334155"
                            stroke-width="1"
                            stroke-dasharray="4 4"></ellipse>

                        <circle r="8" fill="#3b82f6">
                            <animateMotion
                                dur="6s"
                                repeatCount="indefinite"
                                path="M 100 350 A 100 30 0 1 1 300 350 A 100 30 0 1 1 100 350"
                            ></animateMotion>
                        </circle>

                        <g opacity="0.5">
                            <circle cx="50" cy="50" r="1" fill="white"></circle>
                            <circle cx="350" cy="50" r="1" fill="white"></circle>
                            <circle cx="200" cy="20" r="1" fill="white"></circle>
                        </g>

                        <g transform="translate(200, 100)">
                            <circle
                                cx="0"
                                cy="0"
                                r="4"
                                fill="#fff"
                                stroke="#38bdf8"
                                stroke-width="2"
                                class="animate-parallax-star"></circle>
                        </g>

                        <g transform="translate(280, 50)">
                            <circle
                                cx="0"
                                cy="0"
                                r="40"
                                fill="#0f172a"
                                stroke="#38bdf8"
                                stroke-width="2"></circle>
                            <line
                                x1="0"
                                y1="-40"
                                x2="0"
                                y2="40"
                                stroke="#38bdf8"
                                stroke-width="1"
                                opacity="0.5"></line>
                            <line
                                x1="-40"
                                y1="0"
                                x2="40"
                                y2="0"
                                stroke="#38bdf8"
                                stroke-width="1"
                                opacity="0.5"></line>

                            <circle r="3" fill="#fff">
                                <animate
                                    attributeName="cx"
                                    values="10; -10; 10"
                                    dur="6s"
                                    repeatCount="indefinite"></animate>
                            </circle>
                        </g>
                        <text x="280" y="110" text-anchor="middle" fill="#38bdf8" font-size="10"
                            >TELESCOPE VIEW</text
                        >
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #020617;
        color: #e2e8f0;
    }

    .med-tag-local {
        color: #38bdf8;
        border-color: #0ea5e9;
    }

    .med-title-local {
        color: #f0f9ff;
    }

    .med-description-local {
        color: #cbd5e1;
        opacity: 0.9;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #0f172a 50%, transparent);
        border-color: #1e293b;
    }

    .med-card-title-local {
        color: #7dd3fc;
    }

    .med-card-text-local {
        color: #e2e8f0;
    }

    .med-visual-column-local {
        height: 400px;
    }

    @keyframes twinkle {
        0%,
        100% {
            opacity: 0.2;
            transform: scale(1);
        }
        50% {
            opacity: 1;
            transform: scale(1.2);
        }
    }
    .animate-twinkle {
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
    }

    @keyframes parallaxStar {
        0% {
            transform: translateX(20px);
        }
        50% {
            transform: translateX(-20px);
        }
        100% {
            transform: translateX(20px);
        }
    }
    .animate-parallax-star {
        animation: parallaxStar 6s ease-in-out infinite;
    }

    .med-star-dot {
        position: absolute;
        border-radius: 9999px;
        background-color: white;
    }

    .med-parallax-text {
        margin-top: 1rem;
        font-size: 0.875rem;
        color: #e2e8f0;
        line-height: 1.625;
    }

    .med-visual-svg {
        width: 100%;
        height: 100%;
        overflow: visible;
    }

    .med-blur-sm {
        filter: blur(4px);
    }
</style>
