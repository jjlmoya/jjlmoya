---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-flex med-items-center med-justify-center medicion-sound-equalizer med-pointer-events-none">
        <svg class="med-w-full medicion-sound-equalizer-svg" preserveAspectRatio="none">
            <defs>
                <linearGradient id="waveGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#a855f7" stop-opacity="0"></stop>
                    <stop offset="50%" stop-color="#a855f7" stop-opacity="1"></stop>
                    <stop offset="100%" stop-color="#a855f7" stop-opacity="0"></stop>
                </linearGradient>
            </defs>
            <g>
                {
                    Array.from({ length: 40 }).map((_, i) => (
                        <rect
                            x={`${i * 2.5}%`}
                            y="50%"
                            width="1%"
                            height="10%"
                            fill="url(#waveGradient)"
                            class="animate-equalizer-bar"
                            style={`animation-delay: -${Math.random()}s; transform-origin: center;`}
                        />
                    ))
                }
            </g>
        </svg>
    </div>

    <div class="med-container">
        <div class="med-grid med-grid--reverse">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >La Percepción</span
                >
                <h2 class="med-title med-title-local">
                    El Mapa del Silencio
                </h2>

                <p class="med-description med-description-local">
                    Medir la luz o la distancia es físico. Pero, ¿cómo mides lo fuerte que suena
                    algo? El sonido es presión, pero nuestro oído no es lineal.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">La Escala Logarítmica</h3>
                    <p class="med-card-text med-card-text-local">
                        Alexander Graham Bell nos dio el Bel (y el decibelio). No es una suma, es
                        una multiplicación.
                    </p>
                    <ul class="med-list med-list-local">
                        <li class="med-flex med-justify-between medicion-sound-border med-pb-1">
                            <span>10 dB</span>
                            <span>Respiración (x10)</span>
                        </li>
                        <li class="med-flex med-justify-between medicion-sound-border med-pb-1">
                            <span>20 dB</span>
                            <span>Susurro (x100)</span>
                        </li>
                        <li class="med-flex med-justify-between med-pt-1">
                            <span>100 dB</span>
                            <span>Taladro (x10,000,000,000)</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="med-visual-column">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 200 200" class="med-w-full med-h-full med-overflow-visible">
                        <circle
                            cx="100"
                            cy="100"
                            r="40"
                            fill="none"
                            stroke="#a855f7"
                            stroke-width="2"
                            opacity="0.5"
                        >
                            <animate
                                attributeName="r"
                                from="40"
                                to="100"
                                dur="2s"
                                repeatCount="indefinite"></animate>
                            <animate
                                attributeName="opacity"
                                from="0.8"
                                to="0"
                                dur="2s"
                                repeatCount="indefinite"></animate>
                        </circle>
                        <circle
                            cx="100"
                            cy="100"
                            r="40"
                            fill="none"
                            stroke="#a855f7"
                            stroke-width="2"
                            opacity="0.5"
                        >
                            <animate
                                attributeName="r"
                                from="40"
                                to="100"
                                dur="2s"
                                begin="0.6s"
                                repeatCount="indefinite"></animate>
                            <animate
                                attributeName="opacity"
                                from="0.8"
                                to="0"
                                dur="2s"
                                begin="0.6s"
                                repeatCount="indefinite"></animate>
                        </circle>
                        <circle
                            cx="100"
                            cy="100"
                            r="40"
                            fill="none"
                            stroke="#a855f7"
                            stroke-width="2"
                            opacity="0.5"
                        >
                            <animate
                                attributeName="r"
                                from="40"
                                to="100"
                                dur="2s"
                                begin="1.2s"
                                repeatCount="indefinite"></animate>
                            <animate
                                attributeName="opacity"
                                from="0.8"
                                to="0"
                                dur="2s"
                                begin="1.2s"
                                repeatCount="indefinite"></animate>
                        </circle>

                        <circle
                            cx="100"
                            cy="100"
                            r="40"
                            fill="#581c87"
                            stroke="#3b0764"
                            stroke-width="4"
                        >
                            <animate
                                attributeName="r"
                                values="40; 42; 40"
                                dur="0.2s"
                                repeatCount="indefinite"></animate>
                        </circle>

                        <path
                            d="M100 80 L100 120 M90 100 L110 100"
                            stroke="white"
                            stroke-width="2"
                            stroke-linecap="round"></path>

                        <path
                            d="M85 90 L85 110 L95 110 L105 120 L105 80 L95 90 Z"
                            fill="white"
                            stroke="none"
                            transform="translate(-10, 0)"></path>
                        <path
                            d="M115 90 Q120 100 115 110 M120 85 Q130 100 120 115"
                            stroke="white"
                            stroke-width="2"
                            fill="none"
                            stroke-linecap="round"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #2e1065;
        color: #e9d5ff;
    }

    .med-tag-local {
        color: #c084fc;
        border-color: #7e22ce;
    }

    .med-title-local {
        color: #ffffff;
    }

    .med-description-local {
        color: #e9d5ff;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #d8b4fe;
    }

    .med-card-text-local {
        color: #e9d5ff;
    }

    .med-list-local {
        color: #c084fc;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #4c1d95 50%, transparent);
        border-color: #a855f7;
    }

    .medicion-sound-equalizer {
        opacity: 0.2;
    }

    .medicion-sound-equalizer-svg {
        height: 16rem;
    }

    .medicion-sound-border {
        border-bottom: 1px solid #6b21a8;
    }

    .animate-equalizer-bar {
        animation: scaleY 1s ease-in-out infinite alternate;
    }

    @keyframes scaleY {
        0% {
            transform: scaleY(0.2);
        }
        100% {
            transform: scaleY(1.5);
        }
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 16rem; display: flex; align-items: center; justify-content: center; }
</style>
