---

---

<section
    class="med-section med-section-local"
>
    <div class="med-absolute med-inset-0 med-pointer-events-none medicion-ph-bubbles">
        {
            Array.from({ length: 20 }).map(() => (
                <div
                    class="med-absolute med-rounded-full medicion-ph-bubble"
                    style={`left: ${Math.random() * 100}%; bottom: -20px; width: ${Math.random() * 20 + 5}px; height: ${Math.random() * 20 + 5}px; animation-duration: ${Math.random() * 5 + 5}s; animation-delay: ${Math.random() * 5}s;`}
                />
            ))
        }
    </div>

    <div class="med-container">
        <div class="med-grid">
            <div class="med-info-column">
                <span
                    class="med-tag med-tag-local"
                    >El Color Químico</span
                >
                <h2 class="med-title med-title-local">La Escala pH</h2>

                <p class="med-description med-description-local">
                    Antes, para saber si algo era ácido, los químicos lo probaban con la lengua.
                    Muchos murieron. Necesitábamos una forma segura de medir lo invisible.
                </p>

                <div
                    class="med-card med-card-local"
                >
                    <h3 class="med-card-title med-card-title-local">Potencial de Hidrógeno</h3>
                    <p class="med-card-text med-card-text-local">
                        Sörensen inventó en 1909 una escala logarítmica para contar iones de
                        hidrógeno. Pero lo genial fue el papel tornasol: convertir un número atómico
                        en un color visible.
                    </p>
                    <div
                        class="med-mt-4 medicion-ph-bar"
                    >
                    </div>
                    <div class="med-flex med-justify-between medicion-meta-label med-font-mono med-mt-1 medicion-ph-labels">
                        <span>ACID (0)</span>
                        <span>NEUTRAL (7)</span>
                        <span>BASE (14)</span>
                    </div>
                </div>
            </div>

            <div class="med-visual-column med-visual-column-local">
                <div class="med-visual-sizer">
                    <svg viewBox="0 0 200 400" class="med-w-full med-h-full med-overflow-visible">
                        <defs>
                            <linearGradient id="liquidGradient" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="currentColor" stop-opacity="0.8"
                                ></stop>
                                <stop offset="100%" stop-color="currentColor" stop-opacity="0.4"
                                ></stop>
                            </linearGradient>
                        </defs>

                        <g transform="translate(70, 50)">
                            <path
                                d="M 0 0 L 0 250 A 30 30 0 0 0 60 250 L 60 0"
                                fill="#4c1d95"
                                fill-opacity="0.2"
                                stroke="#a78bfa"
                                stroke-width="2"></path>

                            <path
                                d="M 2 150 L 2 250 A 28 28 0 0 0 58 250 L 58 150 Z"
                                class="animate-liquid-color"
                                opacity="0.8"></path>

                            <g class="animate-strip-move">
                                <rect
                                    x="20"
                                    y="-50"
                                    width="20"
                                    height="180"
                                    fill="#f3f4f6"
                                    stroke="#d1d5db"
                                    stroke-width="1"></rect>

                                <rect
                                    x="20"
                                    y="100"
                                    width="20"
                                    height="30"
                                    class="animate-strip-reaction"
                                    opacity="0"></rect>
                            </g>

                            <path
                                d="M 0 0 L 0 250 A 30 30 0 0 0 60 250 L 60 0"
                                fill="none"
                                stroke="#e9d5ff"
                                stroke-width="2"
                                stroke-opacity="0.3"></path>
                            <path
                                d="M 10 20 L 10 240"
                                stroke="white"
                                stroke-width="2"
                                stroke-opacity="0.1"
                                stroke-linecap="round"></path>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .med-section-local {
        background-color: #2e1065;
        color: #e9d5ff;
    }

    .med-tag-local {
        color: #d8b4fe;
        border-color: #7e22ce;
    }

    .med-title-local {
        color: #f3e8ff;
    }

    .med-description-local {
        color: #e9d5ff;
        opacity: 0.9;
    }

    .med-card-title-local {
        color: #c084fc;
    }

    .med-card-text-local {
        color: #e9d5ff;
    }

    .med-visual-column-local {
        height: 400px;
    }

    .med-card-local {
        background-color: color-mix(in srgb, #581c87 50%, transparent);
        border-color: #a855f7;
    }

    .medicion-ph-bubbles {
        opacity: 0.2;
    }

    .medicion-ph-bubble {
        background-color: #a855f7;
        animation: bubble linear infinite;
    }

    .medicion-meta-label { font-size: 10px; }
    .medicion-ph-bar {
        height: 1rem;
        width: 100%;
        border-radius: 9999px;
        background: linear-gradient(to right, #ef4444, #22c55e, #3b82f6);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .medicion-ph-labels {
        color: #d8b4fe;
    }

    @keyframes bubble {
        0% {
            transform: translateY(0) scale(1);
            opacity: 0;
        }
        50% {
            opacity: 0.5;
        }
        100% {
            transform: translateY(-400px) scale(1.5);
            opacity: 0;
        }
    }
    .animate-bubble {
        animation-timing-function: linear;
        animation-iteration-count: infinite;
    }

    @keyframes liquidColor {
        0%,
        30% {
            fill: #ef4444;
        }
        33%,
        63% {
            fill: #22c55e;
        }
        66%,
        100% {
            fill: #3b82f6;
        }
    }
    .animate-liquid-color {
        animation: liquidColor 9s step-end infinite;
    }

    @keyframes stripMove {
        0% {
            transform: translateY(0);
        }
        10% {
            transform: translateY(80px);
        }
        25% {
            transform: translateY(80px);
        }
        35% {
            transform: translateY(0);
        }
        100% {
            transform: translateY(0);
        }
    }
    .animate-strip-move {
        animation: stripMove 3s ease-in-out infinite;
    }

    @keyframes stripColorCycle {
        0%,
        30% {
            fill: #ef4444;
        }
        33%,
        63% {
            fill: #22c55e;
        }
        66%,
        100% {
            fill: #3b82f6;
        }
    }

    @keyframes stripOpacityCycle {
        0% {
            opacity: 0;
        }
        15% {
            opacity: 1;
        }
        90% {
            opacity: 1;
        }
        100% {
            opacity: 0;
        }
    }

    .animate-strip-reaction {
        animation:
            stripColorCycle 9s step-end infinite,
            stripOpacityCycle 3s ease-in-out infinite;
    }

    .med-visual-sizer { position: relative; width: 16rem; height: 100%; display: flex; align-items: center; justify-content: center; }
</style>
