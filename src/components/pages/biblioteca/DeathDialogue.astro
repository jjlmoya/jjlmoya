---
interface Props {
    text: string;
    onComplete?: () => void;
    speed?: number;
    delay?: number;
    autoStart?: boolean;
    mode?: "char" | "word";
}

const { text, speed = 50, delay = 0, autoStart = true, mode = "char" } = Astro.props;
---

<div
    class="dd-container"
    data-auto-start={autoStart.toString()}
    data-speed={speed}
    data-delay={delay}
>
    <p class="dd-text">
        {
            text.split(/<br\s*\/?>/i).map((part, index, array) => (
                <>
                    {mode === "char"
                        ? part
                              .toUpperCase()
                              .split("")
                              .map((char) => (
                                  <span class="dd-unit dd-unit-char dd-hidden">
                                      {char === " " ? "\u00A0" : char}
                                  </span>
                              ))
                        : part
                              .toUpperCase()
                              .split(" ")
                              .map((word, wIndex, wArray) => (
                                  <span class="dd-unit dd-unit-word dd-hidden">
                                      {word}
                                      {wIndex < wArray.length - 1 ? " " : ""}
                                  </span>
                              ))}
                    {index < array.length - 1 && <br />}
                </>
            ))
        }
    </p>
</div>

<script is:inline>
    (() => {
        const init = () => {
            const containers = document.querySelectorAll(".dd-container");

            containers.forEach((container) => {
                if (container.hasAttribute("data-initialized")) return;
                container.setAttribute("data-initialized", "true");

                const units = container.querySelectorAll(".dd-unit");
                const speed = parseInt(container.getAttribute("data-speed") || "50");
                const delay = parseInt(container.getAttribute("data-delay") || "0");
                const autoStart = container.getAttribute("data-auto-start") === "true";

                const startTyping = () => {
                    units.forEach((c) => c.classList.add("dd-hidden"));

                    setTimeout(() => {
                        let i = 0;
                        const revealUnit = () => {
                            if (i < units.length) {
                                units[i].classList.remove("dd-hidden");
                                i++;
                                setTimeout(revealUnit, speed);
                            } else {
                                const event = new CustomEvent("dialogue-complete");
                                container.dispatchEvent(event);
                            }
                        };
                        revealUnit();
                    }, delay);
                };

                if (autoStart) {
                    startTyping();
                }

                container.addEventListener("start-typing", () => {
                    startTyping();
                });
            });
        };

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", init);
        } else {
            init();
        }
    })();
</script>

<style>
    .dd-container {
        font-family: serif;
        font-size: 1.25rem;
        line-height: 1.625;
        letter-spacing: 0.025em;
        color: #e7e5e4;
        max-width: 42rem;
        margin: 0 auto;
        text-align: center;
        min-height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @media (min-width: 768px) {
        .dd-container {
            font-size: 1.5rem;
        }
    }

    .dd-text {
        font-family: "Cinzel", serif;
        font-variant: small-caps;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
        transition: opacity 0.5s;
    }

    .dd-unit {
        transition-property: opacity, filter, transform;
        transition-timing-function: ease-out;
        filter: blur(0);
        transform: scale(1);
        opacity: 1;
    }

    .dd-unit-char {
        transition-duration: 75ms;
    }

    .dd-unit-word {
        transition-duration: 700ms;
    }

    .dd-hidden {
        opacity: 0 !important;
        filter: blur(8px) !important;
        transform: scale(0.95) !important;
    }
</style>
