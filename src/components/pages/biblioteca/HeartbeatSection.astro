---

<section class="hb-section">
    <h2 class="hb-title">
        Latidos
    </h2>
    <div class="hb-shelf">
        <div class="hb-bg-container">
            <svg viewBox="0 0 24 24" class="hb-bg-svg">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
            </svg>
        </div>
        <div class="hb-counter" id="heartbeat-counter">
            0
        </div>
        <div class="hb-label">Latidos totales estimados</div>

        <div class="hb-icon-container">
            <svg viewBox="0 0 24 24" class="hb-icon-svg">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
            </svg>
        </div>
    </div>
</section>

<style>
    .hb-section {
        grid-column: 1 / -1;
    }
    .hb-title {
        font-size: 1.5rem;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
        border-bottom: 1px solid #dcd9d2;
        padding-bottom: 0.5rem;
    }
    .hb-shelf {
        background-color: #e8e5de;
        padding: 3rem;
        box-shadow: inset 0 10px 20px rgba(0, 0, 0, 0.05);
        border-radius: 0.125rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 300px;
        position: relative;
        overflow: hidden;
        border-bottom: 12px solid #dcd9d2;
    }
    .hb-bg-container {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.05;
        pointer-events: none;
    }
    .hb-bg-svg {
        width: 500px;
        height: 500px;
        color: #ef4444;
        fill: currentColor;
    }
    .hb-counter {
        z-index: 10;
        font-size: 10vw;
        font-weight: 900;
        color: #2c2c2c;
        letter-spacing: -0.05em;
        word-break: break-all;
        text-align: center;
        line-height: 1;
    }
    @media (min-width: 768px) {
        .hb-counter {
            font-size: 6rem;
        }
    }
    .hb-label {
        font-size: 1.25rem;
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        font-style: italic;
        opacity: 0.6;
        margin-top: 1rem;
    }
    .hb-icon-container {
        position: absolute;
        bottom: 1rem;
        right: 1rem;
        animation: beat 0.8s infinite ease-in-out;
    }
    .hb-icon-svg {
        width: 3rem;
        height: 3rem;
        color: #dc2626;
        fill: currentColor;
    }

    @keyframes beat {
        0%,
        100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.1);
        }
    }
</style>
