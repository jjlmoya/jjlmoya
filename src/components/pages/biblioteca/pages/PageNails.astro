---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-nails-svg-wrap">
                <svg viewBox="0 0 200 200" class="lb-page-nails-svg">
                    <path
                        d="M60,40 Q80,100 70,160"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        class="animate-scratch"
                    />
                    <path
                        d="M100,30 Q120,100 110,170"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        class="animate-scratch"
                        style="animation-delay: 0.2s"
                    />
                    <path
                        d="M140,40 Q160,100 150,160"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        class="animate-scratch"
                        style="animation-delay: 0.4s"
                    />
                </svg>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-stone">
                Las Uñas
            </h3>

            <div>
                <div class="lb-page-counter-small" id="nails-count">
                    0
                </div>
                <div class="lb-page-counter-label">Metros de Uñas</div>
            </div>

            <p class="lb-page-quote">
                HAN ARAÑADO EL TIEMPO. UNA DEFENSA ANTIGUA QUE AÚN CONSERVÁIS.
            </p>
        </div>
    )
}

<style>
    .lb-page-nails-svg-wrap {
        position: relative;
        width: 16rem;
        height: 16rem;
        display: flex;
        align-items: center;
        justify-content: center;
        max-width: 100%;
        max-height: 100%;
    }

    .lb-page-nails-svg {
        width: 100%;
        height: 100%;
        opacity: 0.3;
        color: #e7e5e4;
    }

    .animate-scratch {
        animation: lb-scratch 2s ease-out infinite;
    }

    @keyframes lb-scratch {
        0% {
            stroke-dasharray: 200;
            stroke-dashoffset: 200;
            opacity: 0;
        }
        20%, 100% {
            stroke-dasharray: 200;
            stroke-dashoffset: 0;
            opacity: 1;
        }
    }
</style>

<script>
    import { calculateGrowthStats } from "../../../../utils/libraryLogic";

    const countEl = document.getElementById("nails-count");

    document.addEventListener("update-life-stats", (e: any) => {
        const { stats } = e.detail;
        if (!countEl || !stats) return;

        const { nailsMeters } = calculateGrowthStats(stats.daysAlive);
        countEl.innerText = nailsMeters.toFixed(2).replace(".", ",");
    });
</script>
