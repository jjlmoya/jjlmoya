---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-breath-wrapper">
                <div class="lb-page-breath-glow-base" />
                <div class="lb-page-breath-center">
                    <div class="lb-page-breath-c1" />
                    <div class="lb-page-breath-c2" />
                    <div class="lb-page-breath-c3" />
                    <div class="lb-page-breath-c4" />
                    <div class="lb-page-breath-orbit">
                        <div class="lb-page-breath-orbit-dot dot-1" />
                        <div class="lb-page-breath-orbit-dot dot-2" />
                        <div class="lb-page-breath-orbit-dot dot-3" />
                    </div>
                </div>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-blue">
                El Aliento
            </h3>

            <div>
                <div class="lb-page-counter-small" id="breath-counter">
                    0
                </div>
                <div class="lb-page-counter-label">Respiraciones</div>
            </div>

            <p class="lb-page-quote">
                TOMÁIS PRESTADO EL AIRE Y LO DEVOLVÉIS. UNA Y OTRA VEZ. MANTENÉIS LA CALDERA
                ENCENDIDA CONTRA EL FRÍO DEL UNIVERSO. BIEN HECHO.
            </p>
        </div>
    )
}

<style>
    .lb-page-breath-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-page-breath-glow-base {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(to bottom, transparent, rgba(30, 58, 138, 0.05), transparent);
        pointer-events: none;
    }

    .lb-page-breath-center {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 16rem;
        height: 16rem;
    }

    .lb-page-breath-c1 {
        width: 4rem;
        height: 4rem;
        background-color: rgba(219, 234, 254, 0.3);
        border-radius: 9999px;
        filter: blur(24px);
        animation: lb-pulse-slow 4s ease-in-out infinite;
        mix-blend-mode: screen;
    }

    .lb-page-breath-c2 {
        position: absolute;
        width: 8rem;
        height: 8rem;
        background-image: linear-gradient(to top right, rgba(165, 243, 252, 0.1), rgba(147, 197, 253, 0.05));
        border-radius: 9999px;
        filter: blur(40px);
        animation: lb-mist-expand 6s ease-in-out infinite;
        mix-blend-mode: screen;
    }

    .lb-page-breath-c3 {
        position: absolute;
        width: 10rem;
        height: 10rem;
        background-color: rgba(219, 234, 254, 0.05);
        border-radius: 9999px;
        filter: blur(64px);
        animation: lb-mist-drift 8s ease-in-out infinite;
        animation-delay: -2s;
        mix-blend-mode: screen;
    }

    .lb-page-breath-c4 {
        position: absolute;
        width: 12rem;
        height: 12rem;
        border: 20px solid rgba(191, 219, 254, 0.05);
        border-radius: 9999px;
        filter: blur(64px);
        animation: lb-mist-fade 5s ease-out infinite;
        mix-blend-mode: screen;
    }

    .lb-page-breath-orbit {
        position: absolute;
        inset: 0;
        width: 16rem;
        height: 16rem;
        animation: lb-spin-super-slow 60s linear infinite;
        opacity: 0.2;
    }

    .lb-page-breath-orbit-dot {
        position: absolute;
        border-radius: 9999px;
    }

    .lb-page-breath-orbit-dot.dot-1 {
        top: 2.5rem;
        left: 50%;
        width: 8px;
        height: 8px;
        background-color: #ffffff;
        filter: blur(2px);
    }

    .lb-page-breath-orbit-dot.dot-2 {
        bottom: 5rem;
        left: 33.333%;
        width: 12px;
        height: 12px;
        background-color: #bfdbfe;
        filter: blur(4px);
    }

    .lb-page-breath-orbit-dot.dot-3 {
        top: 50%;
        right: 2.5rem;
        width: 4px;
        height: 4px;
        background-color: #cffafe;
        filter: blur(1px);
    }

    @keyframes lb-mist-expand {
        0%, 100% {
            transform: scale(1) translate(0, 0);
            opacity: 0.3;
        }
        50% {
            transform: scale(1.5) translate(-10px, -10px);
            opacity: 0.6;
        }
    }

    @keyframes lb-mist-drift {
        0%, 100% {
            transform: scale(1.2) translate(0, 0) rotate(0deg);
            opacity: 0.2;
        }
        50% {
            transform: scale(1.4) translate(15px, 10px) rotate(10deg);
            opacity: 0.4;
        }
    }

    @keyframes lb-mist-fade {
        0% {
            transform: scale(0.8);
            opacity: 0;
        }
        50% {
            opacity: 0.2;
        }
        100% {
            transform: scale(2);
            opacity: 0;
        }
    }

    @keyframes lb-pulse-slow {
        0%, 100% {
            transform: scale(1);
            opacity: 0.5;
        }
        50% {
            transform: scale(1.1);
            opacity: 0.8;
        }
    }

    @keyframes lb-spin-super-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>

<script>
    const counter = document.getElementById("breath-counter");
    let animationFrame: number;

    document.addEventListener("update-life-stats", (e: any) => {
        const { birthdate } = e.detail;
        if (!counter) return;

        const start = () => {
            const now = new Date();
            const msAlive = now.getTime() - new Date(birthdate).getTime();
            const preciseBreaths = msAlive * (16 / 60000);
            counter.innerText = Math.floor(preciseBreaths).toLocaleString();
            animationFrame = requestAnimationFrame(start);
        };

        if (animationFrame) cancelAnimationFrame(animationFrame);
        start();
    });
</script>
