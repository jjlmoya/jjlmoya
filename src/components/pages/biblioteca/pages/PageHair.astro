---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-hair-svg-wrap">
                <svg viewBox="0 0 200 200" class="lb-page-hair-svg">
                    <path
                        d="M100,20 C100,20 120,50 110,100 C100,150 130,180 130,180"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1"
                        class="animate-grow"
                    />
                    <path
                        d="M90,25 C90,25 70,60 80,110 C90,160 60,190 60,190"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1"
                        class="animate-grow"
                        style="animation-delay: 0.5s"
                    />
                    <path
                        d="M110,30 C110,30 140,60 130,120 C120,180 150,190 150,190"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1"
                        class="animate-grow"
                        style="animation-delay: 1s"
                    />
                </svg>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-emerald">
                El Cabello
            </h3>

            <div>
                <div class="lb-page-counter-small" id="hair-count">
                    0
                </div>
                <div class="lb-page-counter-label">
                    Metros de Cabello
                </div>
            </div>

            <p class="lb-page-quote">
                LO CORTÁIS Y VUELVE A SALIR. UNA Y OTRA VEZ. PERSISTENTE.
            </p>
        </div>
    )
}

<style>
    .lb-page-hair-svg-wrap {
        position: relative;
        width: 16rem;
        height: 16rem;
        display: flex;
        align-items: center;
        justify-content: center;
        max-width: 100%;
        max-height: 100%;
    }

    .lb-page-hair-svg {
        width: 100%;
        height: 100%;
        opacity: 0.3;
        color: #e7e5e4;
    }

    .animate-grow {
        animation: lb-grow 4s ease-out infinite;
    }

    @keyframes lb-grow {
        0% {
            stroke-dasharray: 200;
            stroke-dashoffset: 200;
        }
        100% {
            stroke-dasharray: 200;
            stroke-dashoffset: 0;
        }
    }
</style>

<script>
    import { calculateGrowthStats } from "../../../../utils/libraryLogic";

    const countEl = document.getElementById("hair-count");

    document.addEventListener("update-life-stats", (e: any) => {
        const { stats } = e.detail;
        if (!countEl || !stats) return;

        const { hairMeters } = calculateGrowthStats(stats.daysAlive);
        countEl.innerText = hairMeters.toFixed(2).replace(".", ",");
    });
</script>
