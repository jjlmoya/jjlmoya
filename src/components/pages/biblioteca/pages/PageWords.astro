---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-words-wrapper">
                <div class="lb-page-words-bg">
                    <span class="lb-page-words-item item-1">HOLA</span>
                    <span class="lb-page-words-item item-2">ADIÓS</span>
                    <span class="lb-page-words-item item-3">POR QUÉ</span>
                    <span class="lb-page-words-item item-4">TIEMPO</span>
                    <span class="lb-page-words-item item-5">VIDA</span>
                    <span class="lb-page-words-item item-6">MUERTE</span>
                    <span class="lb-page-words-item item-7">AMOR</span>
                </div>

                <div class="lb-page-words-center-wrap">
                    <div class="lb-page-words-float float-1">SÍ</div>
                    <div class="lb-page-words-float float-2">NO</div>
                    <div class="lb-page-words-float float-3">HOY</div>
                    <div class="lb-page-words-float float-4">NUNCA</div>
                    <div class="lb-page-words-float float-5">JAMÁS</div>
                    <div class="lb-page-words-float float-6">QUIZÁS</div>
                    <div class="lb-page-words-float float-7">SIEMPRE</div>
                </div>

                <div class="lb-page-words-overlay">
                    <svg viewBox="0 0 24 24" fill="currentColor" class="lb-page-words-icon">
                        <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM13 17H11V15H13V17ZM13 13H11V7H13V13Z" />
                    </svg>
                </div>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-amber">La Voz</h3>

            <div>
                <div class="lb-page-counter-small" id="words-count">
                    0
                </div>
                <div class="lb-page-counter-label">Palabras Pronunciadas</div>
            </div>

            <p class="lb-page-quote">
                UN CONTINUO RUIDO DE FONDO. HABÉIS PRODUCIDO{" "}
                <span id="words-count-text" class="lb-page-words-highlight">
                    0 PALABRAS
                </span>
                . LA MAYORÍA IRRELEVANTES. PERO ALGUNAS... ALGUNAS FUERON PRECIOSAS.
            </p>
        </div>
    )
}

<style>
    .lb-page-words-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .lb-page-words-bg {
        position: absolute;
        inset: 0;
        display: flex;
        flex-wrap: wrap;
        align-content: center;
        justify-content: center;
        opacity: 0.1;
        user-select: none;
        pointer-events: none;
    }

    .lb-page-words-item {
        font-size: 2.25rem;
        font-weight: 900;
        margin: 1rem;
    }

    .lb-page-words-center-wrap {
        position: relative;
        width: 16rem;
        height: 16rem;
    }

    .lb-page-words-float {
        position: absolute;
        font-weight: 900;
        color: #ffffff;
    }

    .lb-page-words-float.float-1 {
        top: 25%;
        left: 25%;
        font-size: 1.75rem;
        animation: lb-pop-1 4s infinite ease-in-out;
        transform: rotate(-12deg);
    }

    .lb-page-words-float.float-2 {
        top: 50%;
        left: 50%;
        font-size: 2.5rem;
        animation: lb-pop-2 5s infinite ease-in-out;
        transform: rotate(6deg);
    }

    .lb-page-words-float.float-3 {
        bottom: 25%;
        right: 25%;
        font-size: 1.5rem;
        animation: lb-pop-3 6s infinite ease-in-out;
        transform: rotate(-6deg);
    }

    .lb-page-words-float.float-4 {
        top: 33.333%;
        right: 33.333%;
        font-size: 2rem;
        animation: lb-pop-4 4.5s infinite ease-in-out;
        transform: rotate(12deg);
    }

    .lb-page-words-float.float-5 {
        bottom: 33.333%;
        left: 33.333%;
        font-size: 1.2rem;
        animation: lb-pop-5 5.5s infinite ease-in-out;
        transform: rotate(-3deg);
    }

    .lb-page-words-float.float-6 {
        top: 2.5rem;
        right: 2.5rem;
        font-size: 1rem;
        color: rgba(255,255,255,0.5);
        animation: lb-pop-1 7s infinite ease-in-out;
        transform: rotate(45deg);
    }

    .lb-page-words-float.float-7 {
        bottom: 2.5rem;
        left: 2.5rem;
        font-size: 1.75rem;
        color: rgba(255,255,255,0.5);
        animation: lb-pop-3 8s infinite ease-in-out;
        transform: rotate(-12deg);
    }

    .lb-page-words-overlay {
        position: absolute;
        z-index: 10;
    }

    .lb-page-words-icon {
        width: 4.5rem;
        height: 4.5rem;
        color: rgba(255,255,255,0.1);
    }

    .lb-page-words-highlight {
        color: #d97706;
    }

    @keyframes lb-pop-1 {
        0%, 100% { transform: scale(1) rotate(-12deg); opacity: 0.3; }
        50% { transform: scale(1.1) rotate(-8deg); opacity: 0.8; }
    }
    @keyframes lb-pop-2 {
        0%, 100% { transform: scale(1) rotate(6deg); opacity: 0.4; }
        50% { transform: scale(1.15) rotate(10deg); opacity: 0.9; }
    }
    @keyframes lb-pop-3 {
        0%, 100% { transform: scale(1) rotate(-6deg); opacity: 0.3; }
        50% { transform: scale(1.08) rotate(-10deg); opacity: 0.7; }
    }
    @keyframes lb-pop-4 {
        0%, 100% { transform: scale(1) rotate(12deg); opacity: 0.4; }
        50% { transform: scale(1.12) rotate(8deg); opacity: 0.8; }
    }
    @keyframes lb-pop-5 {
        0%, 100% { transform: scale(1) rotate(-3deg); opacity: 0.3; }
        50% { transform: scale(1.1) rotate(-6deg); opacity: 0.6; }
    }
</style>

<script>
    import { calculateWordsStats } from "../../../../utils/libraryLogic";

    const countEl = document.getElementById("words-count");
    const countTextEl = document.getElementById("words-count-text");

    document.addEventListener("update-life-stats", (e: any) => {
        const { stats } = e.detail;
        if (!countEl || !stats) return;

        const { wordsSpoken } = calculateWordsStats(stats.minutesAlive);
        countEl.innerText = Math.floor(wordsSpoken).toLocaleString();
        if (countTextEl) countTextEl.innerText = `${Math.floor(wordsSpoken).toLocaleString()} PALABRAS`;
    });
</script>
