---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="intro-left">
            <div class="intro-star-wrap">
                <svg
                    width="40"
                    height="40"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="intro-star-icon"
                >
                    <path d="M12 2L15 8L21 9L16.5 13.5L18 19.5L12 16.5L6 19.5L7.5 13.5L3 9L9 8L12 2Z" />
                </svg>
            </div>

            <h1 class="intro-title">
                MEMENTO
                <br />
                VIVERE
            </h1>

            <div class="intro-line" />

            <p class="intro-subtitle">
                El Libro de Tu Vida
            </p>

            <div class="intro-footer">
                Edición Única &bull; Volumen I
            </div>
        </div>
    ) : (
        <div class="intro-right">
            <p class="intro-quote">
                UNA VIDA. CURIOSA COSA. UN PRINCIPIO, UN FINAL, Y MUCHO RUIDO EN MEDIO.
            </p>

            <div class="intro-divider" />

            <p class="intro-desc">
                AQUÍ ESTÁ TODO. CADA INSTANTE. CADA SUSPIRO.
                <br />
                NO FALTA NADA.
                <br />
                <span class="intro-desc-highlight">¿OS ATREVÉIS A MIRAR?</span>
            </p>

            <div class="intro-hint">
                Usa las flechas para pasar página
            </div>
        </div>
    )
}

<style>
    .intro-left {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        text-align: center;
        width: 100%;
        border: 4px double #292524;
        padding: 1rem;
    }

    @media (min-width: 768px) {
        .intro-left {
            padding: 2rem;
        }
    }

    .intro-star-wrap {
        margin-bottom: 1.5rem;
        opacity: 0.5;
    }

    @media (min-width: 768px) {
        .intro-star-wrap {
            margin-bottom: 3rem;
        }
    }

    .intro-star-icon {
        color: #78716c;
        width: 2rem;
        height: 2rem;
    }

    @media (min-width: 768px) {
        .intro-star-icon {
            width: 2.5rem;
            height: 2.5rem;
        }
    }

    .intro-title {
        font-family: serif;
        font-size: 1.5rem;
        color: #e7e5e4;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        font-weight: bold;
        line-height: 1.2;
    }

    @media (min-width: 640px) {
        .intro-title {
            font-size: 1.75rem;
        }
    }

    @media (min-width: 768px) {
        .intro-title {
            font-size: 2.5rem;
            letter-spacing: 0.1em;
        }
    }

    .intro-line {
        width: 3rem;
        height: 1px;
        background-color: #78716c;
        margin-top: 0.75rem;
        margin-bottom: 0.75rem;
    }

    @media (min-width: 768px) {
        .intro-line {
            width: 4rem;
            margin-top: 1.5rem;
            margin-bottom: 1.5rem;
        }
    }

    .intro-subtitle {
        font-family: serif;
        color: #a8a29e;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    @media (min-width: 640px) {
        .intro-subtitle {
            font-size: 0.8rem;
        }
    }

    @media (min-width: 768px) {
        .intro-subtitle {
            font-size: 1rem;
            letter-spacing: 0.2em;
        }
    }

    .intro-footer {
        margin-top: auto;
        margin-bottom: 0.5rem;
        font-family: serif;
        color: #57534e;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    @media (min-width: 768px) {
        .intro-footer {
            margin-bottom: 1rem;
            font-size: 0.7rem;
        }
    }

    .intro-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        text-align: center;
        max-width: 26rem;
        margin-left: auto;
        margin-right: auto;
        position: relative;
        z-index: 10;
        word-break: normal;
        hyphens: none;
    }

    .intro-right > * + * {
        margin-top: 1.25rem;
    }

    @media (min-width: 768px) {
        .intro-right > * + * {
            margin-top: 1.75rem;
        }
    }

    .intro-quote {
        font-family: serif;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #e7e5e4;
        font-style: italic;
        text-transform: uppercase;
        letter-spacing: 0.025em;
    }

    @media (min-width: 640px) {
        .intro-quote {
            font-size: 1.05rem;
        }
    }

    @media (min-width: 768px) {
        .intro-quote {
            font-size: 1.25rem;
            letter-spacing: 0.05em;
        }
    }

    .intro-divider {
        width: 100%;
        border-top: 1px solid #292524;
    }

    .intro-desc {
        font-family: serif;
        font-size: 0.7rem;
        color: #a8a29e;
        line-height: 1.7;
        text-transform: uppercase;
        letter-spacing: 0.025em;
    }

    @media (min-width: 640px) {
        .intro-desc {
            font-size: 0.75rem;
        }
    }

    @media (min-width: 768px) {
        .intro-desc {
            font-size: 0.875rem;
            letter-spacing: 0.05em;
        }
    }

    .intro-desc-highlight {
        color: #e7e5e4;
        font-weight: bold;
        margin-top: 0.75rem;
        display: block;
    }

    .intro-hint {
        animation: bounce 1s infinite;
        margin-top: 2rem;
        color: #78716c;
        font-family: serif;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    @media (min-width: 768px) {
        .intro-hint {
            margin-top: 3rem;
            font-size: 0.875rem;
        }
    }

    @keyframes bounce {
        0%, 100% {
            transform: translateY(-25%);
            animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
        }
        50% {
            transform: none;
            animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
        }
    }
</style>
