---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-water-wrapper">
                <div class="lb-page-water-glow" />

                <div class="lb-page-water-glass">
                    <div class="lb-page-water-glass-shine-l" />
                    <div class="lb-page-water-glass-shine-r" />

                    <div class="lb-page-water-fluid">
                        <div class="lb-page-water-wave-1" />
                        <div class="lb-page-water-wave-2" />

                        <div class="lb-page-water-bubbles">
                            <div class="lb-page-water-bubble bubble-1" />
                            <div class="lb-page-water-bubble bubble-2" />
                            <div class="lb-page-water-bubble bubble-3" />
                            <div class="lb-page-water-bubble bubble-4" />
                            <div class="lb-page-water-bubble bubble-5" />
                        </div>
                    </div>

                    <div class="lb-page-water-ice ice-1" />
                    <div class="lb-page-water-ice ice-2" />
                </div>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-blue">La Sed</h3>

            <div>
                <div class="lb-page-counter-small" id="water-count">
                    0
                </div>
                <div class="lb-page-counter-label">Litros Bebidos</div>
            </div>

            <p class="lb-page-quote">
                SOMOS AGUA QUE APRENDIÓ A CAMINAR.{" "}
                <span id="water-bottles" class="lb-page-water-highlight">
                    0 BOTELLAS
                </span>{" "}
                HAN PASADO POR VOSOTROS PARA MANTENER EL BARRO HÚMEDO.
            </p>
        </div>
    )
}

<style>
    .lb-page-water-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-page-water-glow {
        position: absolute;
        width: 16rem;
        height: 16rem;
        background-color: rgba(59, 130, 246, 0.1);
        border-radius: 9999px;
        filter: blur(64px);
        animation: lb-pulse-slow 8s ease-in-out infinite;
    }

    .lb-page-water-glass {
        position: relative;
        width: 8rem;
        height: 14rem;
        border-left: 2px solid rgba(255, 255, 255, 0.2);
        border-right: 2px solid rgba(255, 255, 255, 0.2);
        border-bottom: 4px solid rgba(255, 255, 255, 0.2);
        border-radius: 0 0 1rem 1rem;
        backdrop-filter: blur(4px);
        overflow: hidden;
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
        max-height: 100%;
        max-width: 100%;
    }

    .lb-page-water-glass-shine-l {
        position: absolute;
        top: 0;
        left: 0.5rem;
        width: 4px;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.1);
        z-index: 20;
        border-radius: 9999px;
        filter: blur(1px);
    }

    .lb-page-water-glass-shine-r {
        position: absolute;
        top: 0;
        right: 0.5rem;
        width: 8px;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.05);
        z-index: 20;
        border-radius: 9999px;
        filter: blur(2px);
    }

    .lb-page-water-fluid {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 85%;
        background-image: linear-gradient(to top, rgba(37, 99, 235, 0.6), rgba(96, 165, 250, 0.4));
        z-index: 10;
        transition: all 1s;
    }

    .lb-page-water-wave-1 {
        position: absolute;
        top: -0.75rem;
        left: -50%;
        width: 200%;
        height: 1.5rem;
        background-color: rgba(96, 165, 250, 0.4);
        border-radius: 50%;
        animation: lb-wave-1 6s ease-in-out infinite;
    }

    .lb-page-water-wave-2 {
        position: absolute;
        top: -0.75rem;
        left: -50%;
        width: 200%;
        height: 1.5rem;
        background-color: rgba(147, 197, 253, 0.3);
        border-radius: 50%;
        animation: lb-wave-2 5s ease-in-out infinite;
    }

    .lb-page-water-bubbles {
        position: absolute;
        bottom: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .lb-page-water-bubble {
        position: absolute;
        bottom: -10px;
        background-color: rgba(255, 255, 255, 0.3);
        border-radius: 9999px;
        animation: lb-bubble 4s linear infinite;
    }

    .lb-page-water-bubble.bubble-1 { left: 20%; width: 8px; height: 8px; animation-delay: 0s; }
    .lb-page-water-bubble.bubble-2 { left: 50%; width: 6px; height: 6px; animation-delay: 1s; }
    .lb-page-water-bubble.bubble-3 { left: 80%; width: 10px; height: 10px; animation-delay: 2s; }
    .lb-page-water-bubble.bubble-4 { left: 35%; width: 4px; height: 4px; animation-delay: 0.5s; }
    .lb-page-water-bubble.bubble-5 { left: 65%; width: 8px; height: 8px; animation-delay: 1.5s; }

    .lb-page-water-ice {
        position: absolute;
        background-color: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 0.5rem;
        backdrop-filter: blur(4px);
        z-index: 11;
        animation: lb-float-ice 6s ease-in-out infinite;
    }

    .lb-page-water-ice.ice-1 {
        bottom: 2.5rem;
        left: 1rem;
        width: 2.5rem;
        height: 2.5rem;
        transform: rotate(12deg);
        --r: 12deg;
    }

    .lb-page-water-ice.ice-2 {
        bottom: 5rem;
        right: 1.5rem;
        width: 2rem;
        height: 2rem;
        transform: rotate(-6deg);
        --r: -6deg;
        animation-delay: 1s;
    }

    .lb-page-water-highlight {
        color: #60a5fa;
    }

    @keyframes lb-wave-1 {
        0%, 100% { transform: translateX(0) rotate(0deg); }
        50% { transform: translateX(-25%) rotate(2deg); }
    }

    @keyframes lb-wave-2 {
        0%, 100% { transform: translateX(-25%) rotate(0deg); }
        50% { transform: translateX(0) rotate(-2deg); }
    }

    @keyframes lb-bubble {
        0% { transform: translateY(0) scale(1); opacity: 0; }
        20% { opacity: 1; }
        100% { transform: translateY(-200px) scale(1.2); opacity: 0; }
    }

    @keyframes lb-float-ice {
        0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); }
        50% { transform: translateY(-5px) rotate(calc(var(--r, 0deg) + 5deg)); }
    }

    @keyframes lb-pulse-slow {
        0%, 100% { opacity: 0.1; transform: scale(1); }
        50% { opacity: 0.2; transform: scale(1.1); }
    }
</style>

<script>
    import { calculateWaterStats } from "../../../../utils/libraryLogic";

    const countEl = document.getElementById("water-count");
    const bottlesEl = document.getElementById("water-bottles");

    document.addEventListener("update-life-stats", (e: any) => {
        const { stats } = e.detail;
        if (!countEl || !stats) return;

        const { litersDrunk } = calculateWaterStats(stats.daysAlive);
        const realBottles = Math.floor(litersDrunk / 0.5);

        countEl.innerText = litersDrunk.toLocaleString();
        if (bottlesEl) bottlesEl.innerText = `${realBottles.toLocaleString()} BOTELLAS`;
    });
</script>
