---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-sun-wrapper">
                <div class="lb-page-sun-corona" />
                <div class="lb-page-sun-glow-outer" />

                <div class="lb-page-sun-sphere">
                    <div class="lb-page-sun-solar-flare" />
                    <div class="lb-page-sun-spin-layer">
                        <div class="lb-page-sun-spot-1" />
                        <div class="lb-page-sun-spot-2" />
                        <div class="lb-page-sun-spot-3" />
                    </div>
                </div>

                <div class="lb-page-sun-rays">
                    <div class="lb-page-sun-ray ray-v" />
                    <div class="lb-page-sun-ray ray-h" />
                    <div class="lb-page-sun-ray ray-d1" />
                    <div class="lb-page-sun-ray ray-d2" />
                </div>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-orange">El Sol</h3>

            <div>
                <div class="lb-page-counter-small" id="sun-count">
                    0
                </div>
                <div class="lb-page-counter-label">
                    Amaneceres Vistos
                </div>
            </div>

            <p class="lb-page-quote">
                LA BOLA DE FUEGO GIGANTE GIRA PARA VOSOTROS.{" "}
                <span id="sun-text-count" class="lb-page-sun-highlight">
                    0 VECES
                </span>{" "}
                HA VUELTO A SALIR PARA VER SI SEGUÍAIS AHÍ. QUÉ TOZUDEZ.
            </p>
        </div>
    )
}

<style>
    .lb-page-sun-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-page-sun-corona {
        position: absolute;
        width: 16rem;
        height: 16rem;
        background-color: rgba(217, 119, 6, 0.2);
        border-radius: 9999px;
        filter: blur(64px);
        animation: lb-pulse-slow 4s ease-in-out infinite;
    }

    .lb-page-sun-glow-outer {
        position: absolute;
        width: 12rem;
        height: 12rem;
        background-color: rgba(245, 158, 11, 0.1);
        border-radius: 9999px;
        filter: blur(40px);
        animation: lb-pulse-slower 7s ease-in-out infinite;
    }

    .lb-page-sun-sphere {
        position: relative;
        width: 8rem;
        height: 8rem;
        border-radius: 9999px;
        overflow: hidden;
        box-shadow: 0 0 60px rgba(245, 158, 11, 0.6);
        max-width: 100%;
        max-height: 100%;
    }

    .lb-page-sun-solar-flare {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(to bottom right, #facc15, #f59e0b, #dc2626);
        animation: lb-solar-flare 10s ease-in-out infinite alternate;
    }

    .lb-page-sun-spin-layer {
        position: absolute;
        inset: 0;
        opacity: 0.5;
        mix-blend-mode: overlay;
        animation: lb-spin-slow 30s linear infinite;
    }

    .lb-page-sun-spot-1 {
        position: absolute;
        top: 1rem;
        left: 2rem;
        width: 1rem;
        height: 1rem;
        background-color: rgba(0, 0, 0, 0.2);
        border-radius: 9999px;
        filter: blur(2px);
    }

    .lb-page-sun-spot-2 {
        position: absolute;
        bottom: 1.5rem;
        right: 1.5rem;
        width: 1.5rem;
        height: 1.5rem;
        background-color: rgba(0, 0, 0, 0.1);
        border-radius: 9999px;
        filter: blur(3px);
    }

    .lb-page-sun-spot-3 {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 2rem;
        height: 2rem;
        background-color: rgba(254, 240, 138, 0.4);
        border-radius: 9999px;
        filter: blur(8px);
    }

    .lb-page-sun-rays {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: lb-spin-very-slow 120s linear infinite;
        opacity: 0.4;
    }

    .lb-page-sun-ray {
        position: absolute;
        background-image: linear-gradient(to right, transparent, rgba(251, 191, 36, 0.5), transparent);
        filter: blur(1px);
    }

    .lb-page-sun-ray.ray-v {
        width: 4px;
        height: 12rem;
        background-image: linear-gradient(to bottom, transparent, rgba(251, 191, 36, 0.5), transparent);
    }

    .lb-page-sun-ray.ray-h {
        width: 12rem;
        height: 4px;
    }

    .lb-page-sun-ray.ray-d1 {
        width: 4px;
        height: 10rem;
        background-image: linear-gradient(to bottom, transparent, rgba(253, 224, 71, 0.3), transparent);
        transform: rotate(45deg);
    }

    .lb-page-sun-ray.ray-d2 {
        width: 10rem;
        height: 4px;
        background-image: linear-gradient(to right, transparent, rgba(253, 224, 71, 0.3), transparent);
        transform: rotate(45deg);
    }

    .lb-page-sun-highlight {
        color: #ca8a04;
    }

    @keyframes lb-solar-flare {
        0% { transform: scale(1.2) translate(0, 0); }
        50% { transform: scale(1.3) translate(-5px, -5px); }
        100% { transform: scale(1.2) translate(0, 0); }
    }

    @keyframes lb-spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @keyframes lb-spin-very-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @keyframes lb-pulse-slow {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.1); }
    }

    @keyframes lb-pulse-slower {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.2); }
    }
</style>

<script>
    import { calculateSunStats } from "../../../../utils/libraryLogic";

    const countEl = document.getElementById("sun-count");
    const textCountEl = document.getElementById("sun-text-count");

    document.addEventListener("update-life-stats", (e: any) => {
        const { stats } = e.detail;
        if (!countEl || !stats) return;

        const { sunrises } = calculateSunStats(stats.daysAlive);
        countEl.innerText = Math.floor(sunrises).toLocaleString();
        if (textCountEl) textCountEl.innerText = `${Math.floor(sunrises).toLocaleString()} VECES`;
    });
</script>
