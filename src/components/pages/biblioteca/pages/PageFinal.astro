---
interface Props {
    side: "left" | "right";
}
const { side } = Astro.props;
---

{
    side === "left" ? (
        <div class="lb-page-visual-container">
            <div class="lb-page-final-book-wrap">
                <div class="lb-page-final-book-sheet">
                    <div class="lb-page-final-sheet-shine" />
                    <div class="lb-page-final-question">?</div>
                </div>
            </div>
        </div>
    ) : (
        <div class="lb-page-text-container">
            <h3 class="lb-page-title-colored lb-page-title-stone lb-page-final-title">
                El Final
            </h3>

            <p class="lb-page-quote">
                NO HAY MÁS PÁGINAS ESCRITAS. YO SOLO ME OCUPO DEL FINAL. EL RELLENO ES COSA VUESTRA.
                HACED QUE SEA ENTRETENIDO.
            </p>

            <div class="lb-page-final-foot">
                <p class="lb-page-final-memento">
                    Memento Vivere
                </p>
            </div>
        </div>
    )
}

<style>
    .lb-page-final-book-wrap {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-page-final-book-sheet {
        width: 12rem;
        height: 16rem;
        border: 1px solid #292524;
        background-color: #000000;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lb-page-final-sheet-shine {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(to top right, rgba(255, 255, 255, 0.05), transparent);
        opacity: 0;
        transition: opacity 0.7s;
    }

    .lb-page-final-book-sheet:hover .lb-page-final-sheet-shine {
        opacity: 1;
    }

    .lb-page-final-question {
        color: #292524;
        font-family: serif;
        font-size: 3rem;
        opacity: 0.2;
        user-select: none;
    }

    .lb-page-final-title {
        border-bottom: 1px solid #292524;
        padding-bottom: 0.75rem;
    }

    .lb-page-final-foot {
        padding-top: 1.25rem;
    }

    .lb-page-final-memento {
        font-family: serif;
        font-size: 0.7rem;
        letter-spacing: 0.25em;
        color: #57534e;
        text-transform: uppercase;
    }
</style>
