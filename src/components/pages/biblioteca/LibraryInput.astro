---

<div class="lib-input-container">
    <div class="lib-input-selectors">
        <div class="lib-input-group">
            <label class="lib-input-label">Mes</label>
            <select id="month" class="lib-select lib-select-month">
                <option value="0">Enero</option>
                <option value="1">Febrero</option>
                <option value="2">Marzo</option>
                <option value="3">Abril</option>
                <option value="4">Mayo</option>
                <option value="5">Junio</option>
                <option value="6">Julio</option>
                <option value="7">Agosto</option>
                <option value="8">Septiembre</option>
                <option value="9">Octubre</option>
                <option value="10">Noviembre</option>
                <option value="11">Diciembre</option>
            </select>
        </div>
        <div class="lib-input-group">
            <label class="lib-input-label">Año</label>
            <select id="year" class="lib-select lib-select-year">
            </select>
        </div>
    </div>

    <button id="generate-btn" class="lib-generate-btn">
        Calcular Mi Vida
    </button>
</div>

<script>
    function populateYears() {
        const yearInput = document.getElementById("year") as HTMLSelectElement;
        if (!yearInput) return;

        yearInput.innerHTML = "";

        const currentYear = new Date().getFullYear();
        for (let i = currentYear; i >= 1900; i--) {
            const option = document.createElement("option");
            option.value = i.toString();
            option.text = i.toString();
            yearInput.appendChild(option);
        }
        yearInput.value = "2000";
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", populateYears);
    } else {
        populateYears();
    }
    document.addEventListener("astro:page-load", populateYears);
</script>

<style>
    .lib-input-container {
        margin-top: 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }
    .lib-input-selectors {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }
    .lib-input-group {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .lib-input-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        opacity: 0.5;
        margin-bottom: 0.5rem;
        transition: color 0.2s, opacity 0.2s;
    }
    .lib-input-group:focus-within .lib-input-label {
        color: #2563eb;
        opacity: 1;
    }
    .lib-select {
        height: 4rem;
        font-size: 1.5rem;
        background-color: #ffffff;
        border-radius: 0.75rem;
        box-shadow: 4px 4px 0px 0px rgba(0, 0, 0, 1);
        border: 2px solid #000000;
        outline: none;
        text-align-last: center;
        cursor: pointer;
        appearance: none;
        transition: transform 0.1s, box-shadow 0.1s;
    }
    .lib-select-month {
        width: 10rem;
    }
    .lib-select-year {
        width: 8rem;
    }
    .lib-select:focus {
        transform: translateY(4px);
        box-shadow: 0px 0px 0px 0px rgba(0, 0, 0, 0);
    }
    .lib-generate-btn {
        background-color: #2c2c2c;
        color: #f4f1ea;
        padding: 1rem 3rem;
        font-size: 1.25rem;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.2s;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
        border-radius: 9999px;
        border: none;
        cursor: pointer;
    }
    .lib-generate-btn:hover {
        background-color: #2563eb;
        transform: scale(1.05);
    }
</style>
