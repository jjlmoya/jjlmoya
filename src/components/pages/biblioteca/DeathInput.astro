---
const birthYearStart = 1900;
const birthYearEnd = new Date().getFullYear();
---

<div
    id="death-input-container"
    class="di-container hidden opacity-0"
>
    <div
        id="year-section"
        class="di-year-section"
    >
        <div class="di-slider-wrapper">
            <div class="di-gradient-overlay"></div>
            <div class="di-glow-center"></div>
            <div class="di-border-center"></div>

            <div
                id="year-slider"
                class="di-slider no-scrollbar"
            >
                <div class="di-scroll-spacer" aria-hidden="true"></div>
                {
                    Array.from({ length: birthYearEnd - birthYearStart + 1 }, (_, i) => birthYearStart + i)
                        .reverse()
                        .map((year) => (
                            <div
                                class="year-item di-year-item"
                                data-year={year}
                            >
                                <div class="book-spine di-spine-inactive">
                                    <div class="di-book-spine-overlay" />
                                    <span class="di-book-text di-text-inactive writing-vertical">
                                        {year}
                                    </span>
                                </div>
                            </div>
                        ))
                }
                <div class="di-scroll-spacer" aria-hidden="true"></div>
            </div>
        </div>

        <button
            id="year-confirm-btn"
            class="di-confirm-btn"
        >
            Siguiente
        </button>
    </div>

    <div
        id="month-section"
        class="di-month-section di-hidden-interaction"
    >
        <div class="di-month-grid">
            {
                [
                    "ENE",
                    "FEB",
                    "MAR",
                    "ABR",
                    "MAY",
                    "JUN",
                    "JUL",
                    "AGO",
                    "SEP",
                    "OCT",
                    "NOV",
                    "DIC",
                ].map((month, index) => (
                    <button
                        class="month-btn di-month-btn"
                        data-month={index}
                    >
                        {month}
                    </button>
                ))
            }
        </div>
    </div>
</div>

<script is:inline>
    (() => {
        let selectedYear = null;
        let isDragging = false;
        let startX;
        let scrollLeft;

        const handleShowYearInput = () => {
            const container = document.getElementById("death-input-container");
            if (container) {
                container.classList.remove("hidden");
                container.classList.add("di-grid-display");
                setTimeout(() => {
                    container.classList.remove("opacity-0");
                    const currentYear = new Date().getFullYear();
                    const defaultYear = document.querySelector(`.year-item[data-year="${currentYear}"]`);
                    defaultYear?.scrollIntoView({
                        behavior: "smooth",
                        inline: "center",
                        block: "nearest",
                    });
                }, 100);
            }
        };

        const handleShowMonthInput = () => {
            const monthSection = document.getElementById("month-section");
            if (monthSection) {
                monthSection.classList.remove("di-hidden-interaction");
            }
        };

        if (!window["__deathInputRegistered"]) {
            document.addEventListener("show-death-year-input", handleShowYearInput);
            document.addEventListener("show-death-month-input", handleShowMonthInput);
            window["__deathInputRegistered"] = true;
        }

        const initDeathInput = () => {
            const container = document.getElementById("death-input-container");
            const yearSlider = document.getElementById("year-slider");
            const yearItems = document.querySelectorAll(".year-item");
            const yearConfirmBtn = document.getElementById("year-confirm-btn");
            const yearSection = document.getElementById("year-section");
            const monthSection = document.getElementById("month-section");
            const monthBtns = document.querySelectorAll(".month-btn");

            if (!container) return;

            selectedYear = null;
            isDragging = false;

            if (yearSlider) {
                yearSlider.addEventListener("mousedown", (e) => {
                    isDragging = false;
                    yearSlider.classList.add("di-dragging");
                    startX = e.pageX - yearSlider.offsetLeft;
                    scrollLeft = yearSlider.scrollLeft;
                    yearSlider.style.scrollSnapType = "none";
                });

                yearSlider.addEventListener("mouseleave", () => {
                    yearSlider.classList.remove("di-dragging");
                    yearSlider.style.scrollSnapType = "x mandatory";
                });

                yearSlider.addEventListener("mouseup", () => {
                    yearSlider.classList.remove("di-dragging");
                    yearSlider.style.scrollSnapType = "x mandatory";
                    setTimeout(() => {
                        isDragging = false;
                    }, 50);
                });

                yearSlider.addEventListener("mousemove", (e) => {
                    if (!yearSlider.classList.contains("di-dragging")) return;
                    e.preventDefault();
                    const x = e.pageX - yearSlider.offsetLeft;
                    const walk = (x - startX) * 2;
                    if (Math.abs(walk) > 5) isDragging = true;
                    yearSlider.scrollLeft = scrollLeft - walk;
                });
            }

            yearItems.forEach((item) => {
                item.addEventListener("click", (e) => {
                    if (isDragging) {
                        e.preventDefault();
                        e.stopPropagation();
                        return;
                    }
                    item.scrollIntoView({
                        behavior: "smooth",
                        inline: "center",
                        block: "nearest",
                    });
                });
            });

            const updateActiveYear = () => {
                if (!yearSlider) return;

                const sliderRect = yearSlider.getBoundingClientRect();
                const center = sliderRect.left + sliderRect.width / 2;

                let closestItem = null;
                let minDiff = Infinity;

                yearItems.forEach((item) => {
                    const el = item;
                    const rect = el.getBoundingClientRect();
                    const itemCenter = rect.left + rect.width / 2;
                    const diff = Math.abs(center - itemCenter);

                    const spine = el.querySelector(".book-spine");
                    const text = el.querySelector(".di-book-text");

                    if (spine) {
                        spine.classList.add("di-spine-inactive");
                        spine.classList.remove("di-spine-active");
                    }
                    if (text) {
                        text.classList.add("di-text-inactive");
                        text.classList.remove("di-text-active");
                    }

                    if (diff < minDiff) {
                        minDiff = diff;
                        closestItem = el;
                    }
                });

                if (closestItem) {
                    const el = closestItem;
                    const spine = el.querySelector(".book-spine");
                    const text = el.querySelector(".di-book-text");

                    if (spine) {
                        spine.classList.remove("di-spine-inactive");
                        spine.classList.add("di-spine-active");
                    }
                    if (text) {
                        text.classList.remove("di-text-inactive");
                        text.classList.add("di-text-active");
                    }

                    selectedYear = parseInt(el.dataset.year || "0");
                }
            };

            if (yearSlider) {
                yearSlider.addEventListener("scroll", () => {
                    window.requestAnimationFrame(updateActiveYear);
                });

                setTimeout(updateActiveYear, 500);
            }

            const handleConfirmYear = () => {
                if (selectedYear) {
                    const event = new CustomEvent("year-selected", { detail: { year: selectedYear } });
                    document.dispatchEvent(event);

                    if (yearSection) {
                        yearSection.classList.add("di-hidden-interaction");
                    }
                }
            };

            if (yearConfirmBtn) {
                yearConfirmBtn.addEventListener(
                    "touchstart",
                    (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        handleConfirmYear();
                    },
                    { passive: false }
                );

                yearConfirmBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    handleConfirmYear();
                });
            }

            const handleMonthSelect = (btn) => {
                const month = parseInt(btn.dataset.month || "0");

                const event = new CustomEvent("birthdate-selected", {
                    detail: { year: selectedYear, month },
                });
                document.dispatchEvent(event);

                if (container) container.classList.add("di-opacity-0");
                setTimeout(() => {
                    if (container) {
                        container.classList.add("hidden");
                        container.classList.remove("di-grid-display");
                    }
                }, 1000);
            };

            monthBtns.forEach((btn) => {
                btn.addEventListener(
                    "touchstart",
                    (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        handleMonthSelect(btn);
                    },
                    { passive: false }
                );

                btn.addEventListener("click", (e) => {
                    e.preventDefault();
                    handleMonthSelect(btn);
                });
            });
        };

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initDeathInput);
        } else {
            initDeathInput();
        }
    })();
</script>

<style>
    .di-container {
        display: none;
        grid-template-columns: 1fr;
        justify-items: center;
        margin-top: 2rem;
        transition: opacity 1s;
        max-width: 48rem;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    .di-grid-display {
        display: grid !important;
    }

    .di-opacity-0 {
        opacity: 0 !important;
    }

    .di-year-section {
        grid-column-start: 1;
        grid-row-start: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        transition: opacity 0.5s;
        z-index: 20;
        width: 100%;
    }

    .di-slider-wrapper {
        position: relative;
        width: 100%;
    }

    .di-gradient-overlay {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 20;
        background: radial-gradient(circle at center, transparent 20%, rgba(12, 10, 9, 0.4) 40%, rgba(12, 10, 9, 0.9) 80%);
    }

    .di-glow-center {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 10rem;
        background-color: rgba(249, 115, 22, 0.1);
        filter: blur(24px);
        z-index: 10;
        pointer-events: none;
    }

    .di-border-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 5rem;
        height: 14rem;
        border-left: 1px solid rgba(249, 115, 22, 0.2);
        border-right: 1px solid rgba(249, 115, 22, 0.2);
        background-color: rgba(249, 115, 22, 0.05);
        z-index: 10;
        pointer-events: none;
        border-radius: 0.5rem;
        filter: blur(1px);
    }

    .di-slider {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        width: 100%;
        padding: 3rem 0;
        gap: 1rem;
        align-items: center;
        height: 20rem;
        user-select: none;
        cursor: grab;
    }

    .di-scroll-spacer {
        min-width: calc(50% - 2rem);
        flex-shrink: 0;
        height: 1px;
        pointer-events: none;
    }

    .di-slider.di-dragging {
        cursor: grabbing;
    }

    .di-year-item {
        scroll-snap-align: center;
        flex-shrink: 0;
        transition: all 0.5s;
        user-select: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 3rem;
        cursor: pointer;
    }

    .di-spine-inactive {
        background-color: #3e2723;
        background-image:
            linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.03) 0%,
                transparent 5%,
                rgba(0, 0, 0, 0.3) 50%,
                transparent 95%,
                rgba(255, 255, 255, 0.03) 100%
            ),
            repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0, 0, 0, 0.1) 4px,
                transparent 6px
            );
        border-left: 1px solid #5d4037;
        border-right: 1px solid #281814;
        border-top: 1px solid #5d4037;
        box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.8);
        height: 10rem;
        opacity: 0.5;
        border-radius: 0.125rem;
        position: relative;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        transition: all 0.5s;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        pointer-events: none;
        width: 100%;
    }

    .di-spine-active {
        background-color: #6d4c41;
        background-image:
            linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.1) 0%,
                transparent 20%,
                rgba(0, 0, 0, 0.1) 50%,
                transparent 80%,
                rgba(255, 255, 255, 0.1) 100%
            ),
            repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0, 0, 0, 0.05) 4px,
                transparent 6px
            );
        border-left: 1px solid #8d6e63;
        border-right: 1px solid #3e2723;
        border-top: 1px solid #8d6e63;
        box-shadow:
            0 0 30px rgba(249, 115, 22, 0.4),
            inset 0 0 5px rgba(0, 0, 0, 0.3);
        height: 16rem;
        z-index: 10;
        border-radius: 0.125rem;
        position: relative;
        transition: all 0.5s;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        pointer-events: none;
        width: 100%;
    }

    .di-book-spine-overlay {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(to right, rgba(0, 0, 0, 0.4) 0%, transparent 100%);
        pointer-events: none;
    }

    .di-book-text {
        font-family: Georgia, Cambria, "Times New Roman", Times, serif;
        transition: color 0.3s;
        rotate: 180deg;
        letter-spacing: 0.1em;
    }

    .di-text-inactive {
        color: rgba(231, 229, 228, 0.6);
        font-size: 1.125rem;
    }

    .di-text-active {
        color: #e7e5e4;
        font-weight: bold;
        font-size: 1.5rem;
        filter: drop-shadow(0 10px 8px rgba(0, 0, 0, 0.5));
    }

    .di-confirm-btn {
        z-index: 30;
        margin-top: 1rem;
        color: #e7e5e4;
        border: 1px solid rgba(231, 229, 228, 0.3);
        padding: 0.75rem 3rem;
        border-radius: 0.125rem;
        background-color: #1c1917;
        font-family: serif;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.875rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        transition: all 0.2s;
        cursor: pointer;
        touch-action: none;
        -webkit-tap-highlight-color: transparent;
    }

    .di-confirm-btn:hover {
        background-color: #e7e5e4;
        color: #0c0a09;
        border-color: #e7e5e4;
    }

    .di-confirm-btn:active {
        transform: scale(0.95);
    }

    .di-month-section {
        grid-column-start: 1;
        grid-row-start: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        width: 100%;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.5s;
        z-index: 10;
    }

    .di-hidden-interaction {
        opacity: 0 !important;
        pointer-events: none !important;
    }

    :not(.di-hidden-interaction).di-month-section {
        opacity: 1;
        pointer-events: auto;
    }

    .di-month-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        width: 100%;
        max-width: 42rem;
    }

    @media (min-width: 768px) {
        .di-month-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
        }
    }

    .di-month-btn {
        color: rgba(231, 229, 228, 0.6);
        background: none;
        transition: all 0.2s;
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
        padding-left: 1rem;
        padding-right: 1rem;
        border-radius: 0.125rem;
        font-family: serif;
        font-size: 1.125rem;
        border: 1px solid rgba(231, 229, 228, 0.2);
        cursor: pointer;
        touch-action: none;
        -webkit-tap-highlight-color: transparent;
    }

    .di-month-btn:hover {
        color: #0c0a09;
        background-color: #e7e5e4;
        border-color: #e7e5e4;
        transform: scale(1.05);
    }

    .di-month-btn:active {
        transform: scale(0.95);
    }

    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    .writing-vertical {
        writing-mode: vertical-rl;
        text-orientation: mixed;
    }
</style>
