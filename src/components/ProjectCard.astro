---
import "./ProjectCard.css";

interface Props {
    title: string;
    description: string;
    url: string;
    color: string;
}

const { title, description, url, color } = Astro.props as Props;

const faviconUrl = `https://www.google.com/s2/favicons?domain=${url}&sz=64`;
---

<a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="project-card"
>
    <div class={`project-card-gradient ${color}`}></div>
    <div class="project-card-body">
        <div class="project-card-header">
            <img
                src={faviconUrl}
                alt="favicon"
                class="project-card-favicon"
            />
            <h3 class="project-card-title">{title}</h3>
        </div>
        <p class="project-card-description">{description}</p>
        <span class="project-card-cta">Visitar sitio</span>
    </div>
</a>
