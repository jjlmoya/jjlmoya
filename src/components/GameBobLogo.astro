---
import HeaderKitty from "./HeaderKitty.astro";
---

<div class="gamebob-logo">
    <HeaderKitty />
    <span class="gamebob-logo__game">Game</span><span class="gamebob-logo__bob">Bob</span>
</div>

<style>
    .gamebob-logo {
        position: relative;
        display: inline-flex;
        align-items: center;
        font-weight: 900;
        letter-spacing: -0.06em;
        line-height: 1;
    }

    .gamebob-logo__game {
        color: inherit;
        position: relative;
        z-index: 1;
    }

    .gamebob-logo__bob {
        color: #1ddabc;
        text-shadow: 0 0 30px rgba(29, 218, 188, 0.3);
        position: relative;
        z-index: 1;
    }
</style>