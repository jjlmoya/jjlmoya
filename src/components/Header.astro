---
import HeaderLight from "./HeaderLight.astro";
import HeaderDark from "./HeaderDark.astro";
import "./Header.css";

interface Props {
    className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`header-wrapper ${className}`}>
    <div class="header-light-container">
        <HeaderLight />
    </div>
    <div class="header-dark-container">
        <HeaderDark />
    </div>
</div>

<script>
    function setupHeader() {
        const body = document.body;
        const html = document.documentElement;

        const setupMenuForContainer = (
            toggleBtnSelector: string,
            linksSelector: string,
            overlaySelector: string
        ) => {
            const toggleBtns = document.querySelectorAll(toggleBtnSelector);
            const overlay = document.querySelector(overlaySelector);
            const links = document.querySelectorAll(linksSelector);

            toggleBtns.forEach((btn) => {
                const newBtn = btn.cloneNode(true);
                btn.parentNode?.replaceChild(newBtn, btn);

                newBtn.addEventListener("click", (e) => {
                    e.stopPropagation();
                    body.classList.toggle("menu-open");
                    html.classList.toggle("menu-open");
                    overlay?.classList.toggle("menu-open");
                    (newBtn as HTMLElement).classList.toggle("menu-open");
                });
            });

            links.forEach((link) => {
                link.addEventListener("click", () => {
                    body.classList.remove("menu-open");
                    html.classList.remove("menu-open");
                    overlay?.classList.remove("menu-open");
                });
            });
        };

        setupMenuForContainer(".menu-toggle-button-light", ".menu-link-light", ".mobile-overlay-light");
        setupMenuForContainer(".menu-toggle-button-dark", ".menu-link-dark", ".mobile-overlay-dark");

        const searchBtns = document.querySelectorAll(".search-button-light, .search-button-dark");
        searchBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                document.dispatchEvent(new CustomEvent("open-search"));
            });
        });
    }

    setupHeader();

    document.addEventListener("DOMContentLoaded", setupHeader);
    document.addEventListener("astro:after-swap", setupHeader);
</script>
