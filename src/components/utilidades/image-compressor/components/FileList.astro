---

---

<div id="file-list-container" class="file-list-container hidden">
    <div class="list-header">
        <h3>Archivos Procesados</h3>
        <div class="list-stats">
            <span id="total-savings">Ahorro total: 0 MB</span>
        </div>
    </div>
    <ul id="file-list" class="file-list"></ul>
    <div class="global-actions">
        <button id="download-all" class="primary-btn">Descargar Todas</button>
    </div>
</div>

<template id="file-item-template">
    <li class="file-item">
        <div class="file-preview-col">
            <div class="preview-img-wrapper">
                <img class="preview-img" alt="Preview" />
            </div>
            <div class="file-info">
                <span class="filename" title=""></span>
                <span class="orig-size"></span>
            </div>
        </div>

        <div class="status-col">
            <div class="compression-arrow">
                <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6 stroke-current">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
            </div>
        </div>

        <div class="result-col">
            <div class="savings-pill">
                <span class="new-size"></span>
                <span class="savings-pct"></span>
            </div>
            <div class="item-actions">
                <button class="icon-btn edit-btn" title="Ajustar esta imagen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        ><circle cx="12" cy="12" r="3"></circle><path
                            d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"
                        ></path></svg
                    >
                </button>
                <a class="icon-btn download-btn" title="Descargar" download>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        ><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M12 4v12M8 12l4 4 4-4"
                        ></path></svg
                    >
                </a>
            </div>
        </div>

        <div class="inline-editor hidden">
            <div class="editor-controls">
                <div class="editor-group">
                    <label>Calidad: <span class="local-q-val">80</span>%</label>
                    <input type="range" class="local-quality" min="10" max="100" value="80" />
                </div>
                <div class="editor-group">
                    <label>Ancho Máx (px):</label>
                    <input type="number" class="local-width" placeholder="Original" />
                </div>
            </div>
            <div class="editor-actions">
                <button class="editor-close">Cerrar</button>
            </div>
        </div>
    </li>
</template>
