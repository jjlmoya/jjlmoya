<div id="drop-zone" class="drop-zone">
    <label for="image-input" class="file-label">
        <span class="upload-icon">
            <svg viewBox="0 0 24 24" fill="none" class="w-12 h-12 stroke-current">
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
            </svg>
        </span>
        <span class="upload-text">Suelta tus imágenes aquí</span>
        <span class="upload-subtext">¡Soporta múltiples archivos a la vez!</span>
        <span class="upload-btn">Explorar archivos</span>
    </label>
    <input type="file" id="image-input" accept="image/jpeg, image/png, image/webp" multiple />
</div>
