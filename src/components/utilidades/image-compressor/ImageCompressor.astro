---
import "./ImageCompressor.css";
import GlobalSettings from "./components/GlobalSettings.astro";
import DropZone from "./components/DropZone.astro";
import FileList from "./components/FileList.astro";
---

<section class="compressor-dashboard animate-in">
    <GlobalSettings />
    <DropZone />
    <FileList />
</section>

<script>
    import type { QueueItem } from "./logic/compressor";
    import { formatBytes, generateId, processImage } from "./logic/compressor";
    import JSZip from "jszip";

    const dropZone = document.getElementById("drop-zone");
    const fileInput = document.getElementById("image-input") as HTMLInputElement;
    const fileListContainer = document.getElementById("file-list-container");
    const fileList = document.getElementById("file-list");
    const globalQuality = document.getElementById("global-quality") as HTMLInputElement;
    const globalQVal = document.getElementById("global-q-val");
    const globalWebpToggle = document.getElementById("global-webp-toggle") as HTMLInputElement;
    const totalSavingsTxt = document.getElementById("total-savings");
    const downloadAllBtn = document.getElementById("download-all") as HTMLButtonElement;
    const template = document.getElementById("file-item-template") as HTMLTemplateElement;

    const queue: Map<string, QueueItem> = new Map();
    let totalOriginalSize = 0;
    let totalCompressedSize = 0;

    globalQuality?.addEventListener("input", (e) => {
        if (globalQVal) globalQVal.textContent = (e.target as HTMLInputElement).value;
    });

    async function handleFiles(files: FileList | File[]) {
        if (!files.length) return;
        if (fileListContainer) fileListContainer.classList.remove("hidden");

        const itemsToAdd: QueueItem[] = [];

        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            if (!file.type.startsWith("image/")) continue;

            const id = generateId();
            const item: QueueItem = {
                id,
                file,
                originalSize: file.size,
                newSize: 0,
                compressedDataUrl: "",
                originalWidth: 0,
                originalHeight: 0,
                settings: {
                    quality: parseInt(globalQuality.value),
                    width: null,
                    convertToWebp: globalWebpToggle?.checked ?? true,
                },
                isOriginalSelected: false,
            };
            itemsToAdd.push(item);
            queue.set(id, item);
            totalOriginalSize += file.size;
        }

        renderNewItems(itemsToAdd);

        for (const item of itemsToAdd) {
            await processImage(item, updateItemUI);
        }
        updateTotals();
    }

    function renderNewItems(items: QueueItem[]) {
        if (!fileList || !template) return;

        items.forEach((item) => {
            const clone = template.content.cloneNode(true) as DocumentFragment;
            const li = clone.querySelector("li") as HTMLLIElement;
            li.dataset.id = item.id;

            li.querySelector(".filename")!.textContent = item.file.name;
            li.querySelector(".orig-size")!.textContent = formatBytes(item.originalSize);

            const localQ = li.querySelector(".local-quality") as HTMLInputElement;
            const localQVal = li.querySelector(".local-q-val") as HTMLSpanElement;
            const localWidth = li.querySelector(".local-width") as HTMLInputElement;

            localQ.value = item.settings.quality.toString();
            localQVal.textContent = item.settings.quality.toString();

            const editBtn = li.querySelector(".edit-btn");
            const editor = li.querySelector(".inline-editor");
            const closeEditorBtn = li.querySelector(".editor-close");

            editBtn?.addEventListener("click", () => editor?.classList.toggle("hidden"));
            closeEditorBtn?.addEventListener("click", () => editor?.classList.add("hidden"));

            const reprocess = () => {
                item.settings.quality = parseInt(localQ.value);
                item.settings.width = localWidth.value ? parseInt(localWidth.value) : null;
                processImage(item, updateItemUI).then(() => updateTotals());
            };

            localQ.addEventListener("input", (e) => {
                localQVal.textContent = (e.target as HTMLInputElement).value;
            });
            localQ.addEventListener("change", reprocess);
            localWidth.addEventListener("change", reprocess);

            fileList.appendChild(li);
        });
    }

    function updateItemUI(item: QueueItem, originalSrc: string) {
        if (!fileList) return;
        const li = fileList.querySelector(`li[data-id="${item.id}"]`) as HTMLLIElement;
        if (!li) return;

        const previewImg = li.querySelector(".preview-img") as HTMLImageElement;
        previewImg.src = originalSrc;

        const newSizeTxt = li.querySelector(".new-size") as HTMLSpanElement;
        const savingsPct = li.querySelector(".savings-pct") as HTMLSpanElement;
        const pill = li.querySelector(".savings-pill") as HTMLDivElement;
        const downloadBtn = li.querySelector(".download-btn") as HTMLAnchorElement;
        const localWidth = li.querySelector(".local-width") as HTMLInputElement;

        if (item.error) {
            savingsPct.textContent = "Error";
            savingsPct.style.color = "#ef4444";
            newSizeTxt.textContent = item.error;
            newSizeTxt.style.fontSize = "0.85rem";
            pill.className = "savings-pill negative";
            downloadBtn.style.display = "none";
            return;
        }

        if (!localWidth.placeholder || localWidth.placeholder === "Original") {
            localWidth.placeholder = item.originalWidth.toString();
        }

        newSizeTxt.textContent = formatBytes(item.newSize);

        const savings = ((item.originalSize - item.newSize) / item.originalSize) * 100;
        if (item.isOriginalSelected) {
            savingsPct.textContent = "Óptima";
            pill.className = "savings-pill";
            newSizeTxt.innerHTML = `<span style="opacity:0.5; font-size: 0.8em; text-decoration: line-through;">${formatBytes(item.originalSize)}</span> -`;
        } else if (savings < 0) {
            savingsPct.textContent = `+${Math.abs(savings).toFixed(1)}%`;
            pill.className = "savings-pill negative";
        } else {
            savingsPct.textContent = `-${savings.toFixed(1)}%`;
            pill.className = "savings-pill";
        }

        downloadBtn.href = item.compressedDataUrl;
        const targetFormat = item.settings.convertToWebp ? "image/webp" : item.file.type;
        const ext = targetFormat.split("/")[1] || "jpeg";
        const baseName =
            item.file.name.substring(0, item.file.name.lastIndexOf(".")) || item.file.name;
        downloadBtn.download = `${baseName}.${ext}`;
    }

    function updateTotals() {
        totalCompressedSize = Array.from(queue.values()).reduce(
            (sum, item) => sum + item.newSize,
            0
        );
        const saved = totalOriginalSize - totalCompressedSize;
        if (totalSavingsTxt) {
            if (saved > 0) {
                totalSavingsTxt.textContent = `Ahorro total: ${formatBytes(saved)}`;
                totalSavingsTxt.style.color = "#10b981";
            } else {
                totalSavingsTxt.textContent = `Sin ahorro total`;
                totalSavingsTxt.style.color = "#ef4444";
            }
        }
    }

    dropZone?.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropZone.classList.add("dragover");
    });
    dropZone?.addEventListener("dragleave", () => {
        dropZone.classList.remove("dragover");
    });
    dropZone?.addEventListener("drop", (e) => {
        e.preventDefault();
        dropZone.classList.remove("dragover");
        if (e.dataTransfer?.files.length) {
            handleFiles(e.dataTransfer.files);
        }
    });
    fileInput?.addEventListener("change", (e) => {
        const target = e.target as HTMLInputElement;
        if (target.files?.length) {
            handleFiles(target.files);
        }
    });

    downloadAllBtn?.addEventListener("click", async () => {
        const originalText = downloadAllBtn.textContent;
        downloadAllBtn.textContent = "Comprimiendo ZIP...";
        downloadAllBtn.disabled = true;

        try {
            const zip = new JSZip();

            queue.forEach((item) => {
                if (!item.compressedDataUrl) return;

                const targetFormat = item.settings.convertToWebp ? "image/webp" : item.file.type;
                const ext = targetFormat.split("/")[1] || "jpeg";
                const baseName =
                    item.file.name.substring(0, item.file.name.lastIndexOf(".")) || item.file.name;
                const fileName = `${baseName}.${ext}`;

                const base64Data = item.compressedDataUrl.split(",")[1];
                if (base64Data) {
                    zip.file(fileName, base64Data, { base64: true });
                }
            });

            const content = await zip.generateAsync({ type: "blob" });

            const url = window.URL.createObjectURL(content);
            const a = document.createElement("a");
            a.href = url;
            a.download = "imagenes_optimizadas.zip";
            document.body.appendChild(a);
            a.click();

            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        } catch (error) {
            console.error("Error generating zip:", error);
        } finally {
            downloadAllBtn.textContent = originalText;
            downloadAllBtn.disabled = false;
        }
    });
</script>
