---
import "./NauticalSpeedConverter.css";

const beaufortData = [
  { force: 0, kn: "0", kmh: "0", ms: "0", desc: "Calma", sea: "Mar como un espejo", effect: "El humo sube verticalmente" },
  { force: 1, kn: "1-3", kmh: "1-5", ms: "0.3-1.5", desc: "Ventolina", sea: "Rizos como escamas de pescado", effect: "El humo indica la dirección del viento" },
  { force: 2, kn: "4-6", kmh: "6-11", ms: "1.6-3.3", desc: "Flojito (Brisa muy débil)", sea: "Pequeñas olas que no rompen", effect: "Se mueven las hojas de los árboles, se siente el viento en la cara" },
  { force: 3, kn: "7-10", knMin: 7, kmh: "12-19", ms: "3.4-5.4", desc: "Flojo (Brisa débil)", sea: "Ovejas blancas dispersas", effect: "Se mueven los arbustos, las banderas se ondean" },
  { force: 4, kn: "11-16", knMin: 11, kmh: "20-28", ms: "5.5-7.9", desc: "Bonancible (Brisa moderada)", sea: "Olas pequeñas, frecuentes borreguillos", effect: "Se levanta polvo y papeles sueltos, se mueven las copas de los árboles" },
  { force: 5, kn: "17-21", knMin: 17, kmh: "29-38", ms: "8.0-10.7", desc: "Fresquito (Brisa fresca)", sea: "Olas moderadas, muchos borreguillos", effect: "Se mueven los árboles grandes, dificultad para usar el paraguas" },
  { force: 6, kn: "22-27", knMin: 22, kmh: "39-49", ms: "10.8-13.8", desc: "Fresco (Brisa fuerte)", sea: "Olas grandes, crestas de espuma blanca", effect: "Silban los cables de alta tensión, dificultad para caminar contra el viento" },
  { force: 7, kn: "28-33", knMin: 28, kmh: "50-61", ms: "13.9-17.1", desc: "Frescachón (Viento fuerte)", sea: "Mar gruesa, la espuma se arrastra en hileras", effect: "Se mueven los árboles grandes, dificultad para caminar" },
  { force: 8, kn: "34-40", knMin: 34, kmh: "62-74", ms: "17.2-20.7", desc: "Temporal (Viento duro)", sea: "Olas de gran altura, rompientes en crestas", effect: "Se rompen las copas de los árboles, gran dificultad para caminar" },
  { force: 9, kn: "41-47", knMin: 41, kmh: "75-88", ms: "20.8-24.4", desc: "Temporal fuerte (Muy duro)", sea: "Olas muy altas, visibilidad reducida", effect: "Daños en edificios, se vuelan las tejas" },
  { force: 10, kn: "48-55", knMin: 48, kmh: "89-102", ms: "24.5-28.4", desc: "Temporal duro (Temporal)", sea: "Olas excepcionalmente altas, mar blanca", effect: "Árboles arrancados, daños estructurales importantes" },
  { force: 11, kn: "56-63", knMin: 56, kmh: "103-117", ms: "28.5-32.6", desc: "Temporal muy duro (Borrasca)", sea: "Olas enormes, espuma cubre el mar", effect: "Devastación amplia" },
  { force: 12, kn: "64+", knMin: 64, kmh: "118+", ms: "32.7+", desc: "Huracán", sea: "Aire lleno de espuma y rociones", effect: "Catástrofe total" }
];
---

<div id="nautical-speed-converter-root" class="nautical-speed-converter">
  <div class="unified-card">
    <div class="converter-header">
      <div class="input-grid">
        <div class="input-group">
          <label for="val-kn">Nudos (kt)</label>
          <div class="input-wrapper">
            <iconify-icon icon="mdi:speedometer"></iconify-icon>
            <input type="number" id="val-kn" class="elegant-input" placeholder="0.0" step="0.1" autocomplete="off" />
          </div>
        </div>
        <div class="input-group">
          <label for="val-kmh">Km/h</label>
          <div class="input-wrapper">
             <iconify-icon icon="mdi:car"></iconify-icon>
            <input type="number" id="val-kmh" class="elegant-input" placeholder="0.0" step="0.1" autocomplete="off" />
          </div>
        </div>
        <div class="input-group">
          <label for="val-ms">m/s</label>
          <div class="input-wrapper">
            <iconify-icon icon="mdi:wind-power"></iconify-icon>
            <input type="number" id="val-ms" class="elegant-input" placeholder="0.0" step="0.1" autocomplete="off" />
          </div>
        </div>
        <div class="input-group">
          <label for="val-mph">mph</label>
          <div class="input-wrapper">
            <iconify-icon icon="mdi:map-marker-distance"></iconify-icon>
            <input type="number" id="val-mph" class="elegant-input" placeholder="0.0" step="0.1" autocomplete="off" />
          </div>
        </div>
      </div>

      <div class="beaufort-summary" id="beaufort-result">
        <div class="summary-top">
          <div id="f-num" class="force-circle">0</div>
          <div class="force-text-box">
            <h2 id="f-desc" class="force-name">Calma</h2>
            <p id="f-effect" class="force-detail">El humo sube verticalmente.</p>
          </div>
        </div>
        
        <div class="sea-state-box">
            <div class="sea-icon">
                <iconify-icon icon="mdi:waves"></iconify-icon>
            </div>
            <div class="sea-text">
                <span class="label">Estado del Mar</span>
                <p id="f-sea">Mar como un espejo.</p>
            </div>
        </div>
      </div>
    </div>

    <div class="table-container">
      <h3><iconify-icon icon="mdi:format-list-numbered"></iconify-icon> Referencia Rápida Escala Beaufort</h3>
      <div class="scroll-area">
        <table class="beaufort-table" id="b-table">
          <thead>
            <tr>
              <th>Fuerza</th>
              <th>Descripción</th>
              <th>Nudos</th>
              <th>Efecto Visual</th>
            </tr>
          </thead>
          <tbody>
            {beaufortData.map(b => (
              <tr data-force={b.force} class="clickable-row">
                <td><span class="force-tag">F{b.force}</span></td>
                <td><strong>{b.desc}</strong></td>
                <td>{b.kn}</td>
                <td class="table-sea-desc">{b.sea}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ beaufortData }}>
  const inputKn = document.getElementById('val-kn');
  const inputKmh = document.getElementById('val-kmh');
  const inputMs = document.getElementById('val-ms');
  const inputMph = document.getElementById('val-mph');
  const forceNum = document.getElementById('f-num');
  const forceDesc = document.getElementById('f-desc');
  const forceEffect = document.getElementById('f-effect');
  const forceSea = document.getElementById('f-sea');
  const tableRows = document.querySelectorAll('.clickable-row');

  const FACTORS = {
    kn: 1,
    kmh: 1.852,
    ms: 0.514444,
    mph: 1.15078
  };

  function updateAllExcept(sourceId, baseKn) {
    if (sourceId !== 'val-kn') inputKn.value = baseKn.toFixed(1);
    if (sourceId !== 'val-kmh') inputKmh.value = (baseKn * FACTORS.kmh).toFixed(1);
    if (sourceId !== 'val-ms') inputMs.value = (baseKn * FACTORS.ms).toFixed(1);
    if (sourceId !== 'val-mph') inputMph.value = (baseKn * FACTORS.mph).toFixed(1);

    updateBeaufort(baseKn);
  }

  function updateBeaufort(kn) {
    let force = 0;
    if (kn < 1) force = 0;
    else if (kn < 4) force = 1;
    else if (kn < 7) force = 2;
    else if (kn < 11) force = 3;
    else if (kn < 17) force = 4;
    else if (kn < 22) force = 5;
    else if (kn < 28) force = 6;
    else if (kn < 34) force = 7;
    else if (kn < 41) force = 8;
    else if (kn < 48) force = 9;
    else if (kn < 56) force = 10;
    else if (kn < 64) force = 11;
    else force = 12;

    const data = beaufortData[force];
    forceNum.textContent = force;
    forceDesc.textContent = data.desc;
    forceEffect.textContent = data.effect;
    forceSea.textContent = data.sea;

    tableRows.forEach(row => {
      row.classList.remove('active');
      if (parseInt(row.getAttribute('data-force')) === force) {
        row.classList.add('active');
      }
    });
  }

  inputKn.addEventListener('input', (e) => updateAllExcept('val-kn', parseFloat(e.target.value) || 0));
  inputKmh.addEventListener('input', (e) => updateAllExcept('val-kmh', (parseFloat(e.target.value) || 0) / FACTORS.kmh));
  inputMs.addEventListener('input', (e) => updateAllExcept('val-ms', (parseFloat(e.target.value) || 0) / FACTORS.ms));
  inputMph.addEventListener('input', (e) => updateAllExcept('val-mph', (parseFloat(e.target.value) || 0) / FACTORS.mph));

  tableRows.forEach(row => {
    row.addEventListener('click', () => {
      const f = parseInt(row.getAttribute('data-force'));
      const data = beaufortData[f];
      const targetKn = f === 12 ? 65 : (parseFloat(data.knMin) || 0);
      inputKn.value = targetKn;
      updateAllExcept('val-kn', targetKn);
    });
  });

  updateAllExcept('val-kn', 0);
</script>
