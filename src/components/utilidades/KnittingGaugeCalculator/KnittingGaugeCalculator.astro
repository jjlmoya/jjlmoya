---
import "./KnittingGaugeCalculator.css";
---

<div class="knitting-gauge-card" id="knitting-gauge-app">
  <aside class="gauge-sidebar">
    <div class="config-section">
      <h3>Tensión Original</h3>
      <div class="input-grid">
        <div class="gauge-field">
          <label>Puntos <span class="label-sub">(Ancho)</span></label>
          <div class="stepper-container">
            <button class="stepper-btn" data-step="-0.5" data-for="pattern-sts">−</button>
            <input type="number" id="pattern-sts" class="gauge-input" value="20" step="0.5" />
            <button class="stepper-btn" data-step="0.5" data-for="pattern-sts">+</button>
          </div>
        </div>
        <div class="gauge-field">
          <label>Vueltas <span class="label-sub">(Largo)</span></label>
          <div class="stepper-container">
            <button class="stepper-btn" data-step="-0.5" data-for="pattern-rows">−</button>
            <input type="number" id="pattern-rows" class="gauge-input" value="28" step="0.5" />
            <button class="stepper-btn" data-step="0.5" data-for="pattern-rows">+</button>
          </div>
        </div>
      </div>
      <div class="gauge-field">
        <label>Unidad de Medida</label>
        <select id="gauge-unit" class="gauge-select">
          <option value="10">10 x 10 cm (Estándar EU)</option>
          <option value="10.16">4 x 4 pulgadas (Estándar US)</option>
        </select>
      </div>
    </div>

    <div class="config-section">
      <h3>Tu Muestra Actual</h3>
      <div class="input-grid">
        <div class="gauge-field">
          <label>Puntos <span class="label-sub">(Ancho)</span></label>
          <div class="stepper-container">
            <button class="stepper-btn" data-step="-0.5" data-for="my-sts">−</button>
            <input type="number" id="my-sts" class="gauge-input" value="22" step="0.5" />
            <button class="stepper-btn" data-step="0.5" data-for="my-sts">+</button>
          </div>
        </div>
        <div class="gauge-field">
          <label>Vueltas <span class="label-sub">(Largo)</span></label>
          <div class="stepper-container">
            <button class="stepper-btn" data-step="-0.5" data-for="my-rows">−</button>
            <input type="number" id="my-rows" class="gauge-input" value="30" step="0.5" />
            <button class="stepper-btn" data-step="0.5" data-for="my-rows">+</button>
          </div>
        </div>
      </div>
      <div class="input-grid">
        <div class="gauge-field">
          <label>Aguja (mm)</label>
          <input type="number" id="my-needle" class="gauge-input" value="4.0" step="0.25" style="border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: rgba(255,255,255,0.6);" />
        </div>
        <div class="gauge-field">
            <label>Peso (g) <span class="label-sub">opcional</span></label>
            <input type="number" id="sample-weight" class="gauge-input" placeholder="Ej: 5" style="border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: rgba(255,255,255,0.6);" />
        </div>
      </div>
    </div>

    <div class="config-section">
      <h3>Estructura del Proyecto</h3>
      <div class="input-grid">
        <div class="gauge-field">
          <label>Puntos Patrón</label>
          <input type="number" id="target-sts" class="gauge-input" value="100" style="border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: rgba(255,255,255,0.6);" />
        </div>
        <div class="gauge-field">
          <label>Vueltas Patrón</label>
          <input type="number" id="target-rows" class="gauge-input" value="140" style="border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: rgba(255,255,255,0.6);" />
        </div>
      </div>
      <div class="gauge-field">
        <label>Múltiplos <span class="label-sub">Ej: 10 + 2</span></label>
        <input type="text" id="pattern-multiples" class="gauge-input" placeholder="Múltiplo + Borde" style="border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; background: rgba(255,255,255,0.6);" />
      </div>
    </div>

    <div class="btn-group">
      <button id="btn-clear" class="ui-btn ui-btn-secondary">Limpiar</button>
      <button id="btn-share" class="ui-btn ui-btn-primary">Compartir</button>
    </div>
  </aside>

  <main class="gauge-main">
    <div class="top-display">
      <div class="visualizer-container">
        <div id="gauge-visual-swatch" class="knit-swatch"></div>
      </div>
      
      <div class="main-stat">
        <h2>Puntos sugeridos a montar</h2>
        <div class="val" id="res-total-sts">110</div>
        <div class="val-detail" id="res-multiples-note"></div>
        <div id="res-danger-info" class="alert-card err"></div>
      </div>
    </div>

    <div class="metrics-grid">
      <div class="metric-item">
          <span class="sl">Nuevas Vueltas <i class="info-icon" data-tooltip="Número de vueltas necesarias para igualar el largo del patrón original con tu tensión actual.">info</i></span>
          <div class="sv" id="res-total-rows">150</div>
      </div>
      <div class="metric-item">
          <span class="sl">Factor Escala <i class="info-icon" data-tooltip="Relación de tamaño entre tu tejido y el patrón. Un valor negativo indica que tu tejido es más denso.">info</i></span>
          <div class="sv" id="res-scale-factor">+10%</div>
      </div>
      <div class="metric-item">
          <span class="sl">Sugerencia <i class="info-icon" data-tooltip="Recomendación técnica para ajustar tu tensión sin tener que recalcular cada punto del patrón.">info</i></span>
          <div class="sv" id="res-size-suggestion" style="font-size: 1rem; line-height: 1.2;">Sube Talla</div>
      </div>
    </div>

    <div id="yarn-estimate-box" class="yarn-calc-extra">
      <p style="margin: 0; font-weight: 700; color: var(--gauge-primary);">Estimación de Lana para el Proyecto</p>
      <p style="margin: 0.5rem 0 0 0;" id="yarn-result">Gramos estimados: <strong>--</strong></p>
    </div>

    <div id="res-multiples-info" class="alert-card warn"></div>
  </main>
</div>

<script>
    const inputIdsList = [
        'pattern-sts', 'pattern-rows', 'my-sts', 'my-rows', 
        'target-sts', 'target-rows', 'pattern-multiples', 
        'gauge-unit', 'my-needle', 'sample-weight'
    ] as const;
    type InputIdType = typeof inputIdsList[number];
    
    const elementsRef: Record<InputIdType, HTMLInputElement | HTMLSelectElement | null> = {
        'pattern-sts': document.getElementById('pattern-sts') as HTMLInputElement,
        'pattern-rows': document.getElementById('pattern-rows') as HTMLInputElement,
        'my-sts': document.getElementById('my-sts') as HTMLInputElement,
        'my-rows': document.getElementById('my-rows') as HTMLInputElement,
        'target-sts': document.getElementById('target-sts') as HTMLInputElement,
        'target-rows': document.getElementById('target-rows') as HTMLInputElement,
        'pattern-multiples': document.getElementById('pattern-multiples') as HTMLInputElement,
        'gauge-unit': document.getElementById('gauge-unit') as HTMLSelectElement,
        'my-needle': document.getElementById('my-needle') as HTMLInputElement,
        'sample-weight': document.getElementById('sample-weight') as HTMLInputElement,
    };
    
    const resultsRef = {
        totalSts: document.getElementById('res-total-sts'),
        totalRows: document.getElementById('res-total-rows'),
        scaleFactor: document.getElementById('res-scale-factor'),
        sizeSuggestion: document.getElementById('res-size-suggestion'),
        multiplesInfo: document.getElementById('res-multiples-info'),
        multiplesNote: document.getElementById('res-multiples-note'),
        dangerInfo: document.getElementById('res-danger-info'),
        visualSwatch: document.getElementById('gauge-visual-swatch'),
        yarnBox: document.getElementById('yarn-estimate-box'),
        yarnResult: document.getElementById('yarn-result')
    };

    let previousUnit = '10';

    function handleUnitConversion() {
        const currentUnitSelect = elementsRef['gauge-unit']?.value || '10';
        if (currentUnitSelect === previousUnit) return;
        
        const unitScaleRatio = parseFloat(currentUnitSelect) / parseFloat(previousUnit);
        
        ['pattern-sts', 'pattern-rows', 'my-sts', 'my-rows'].forEach((idVal: any) => {
            const domEl = elementsRef[idVal as InputIdType] as HTMLInputElement;
            if (domEl && domEl.value) {
                domEl.value = (parseFloat(domEl.value) * unitScaleRatio).toFixed(1);
            }
        });
        
        previousUnit = currentUnitSelect;
        calculateGauge();
    }

    function parseStitchMultiples(strIn: string): { bP: number, oP: number } {
        if (!strIn) return { bP: 0, oP: 0 };
        const matchDigits = strIn.replace(/\s+/g, '').match(/(\d+)(?:\+(\d+))?/);
        if (!matchDigits) return { bP: 0, oP: 0 };
        return {
            bP: parseInt(matchDigits[1]) || 0,
            oP: parseInt(matchDigits[2]) || 0
        };
    }

    function calculateGauge() {
        const pStsVal = parseFloat(elementsRef['pattern-sts']?.value || '20');
        const pRowsVal = parseFloat(elementsRef['pattern-rows']?.value || '28');
        const mStsVal = parseFloat(elementsRef['my-sts']?.value || '20');
        const mRowsVal = parseFloat(elementsRef['my-rows']?.value || '28');
        const targetStsVal = parseFloat(elementsRef['target-sts']?.value || '100');
        const targetRowsVal = parseFloat(elementsRef['target-rows']?.value || '140');
        const weightVal = parseFloat(elementsRef['sample-weight']?.value || '');
        const currentNeedleVal = parseFloat(elementsRef['my-needle']?.value || '4.0');

        if (!pStsVal || !mStsVal) return;

        const stsScaleRatio = mStsVal / pStsVal;
        const rowScaleRatio = mRowsVal / pRowsVal;
        
        const calculatedTotalSts = targetStsVal * stsScaleRatio;
        let finalRoundedSts = Math.round(calculatedTotalSts);
        
        const patternObj = parseStitchMultiples(elementsRef['pattern-multiples']?.value || '');
        if (patternObj.bP > 0) {
            const initialX = finalRoundedSts;
            const baseVal = patternObj.bP;
            const offsetVal = patternObj.oP;
            
            const lowTarget = Math.floor((initialX - offsetVal) / baseVal) * baseVal + offsetVal;
            const highTarget = Math.ceil((initialX - offsetVal) / baseVal) * baseVal + offsetVal;
            
            const optimalSts = Math.abs(initialX - lowTarget) < Math.abs(initialX - highTarget) ? lowTarget : highTarget;
            
            if (resultsRef.multiplesNote) {
                const multiLabelStr = offsetVal > 0 ? `${baseVal}+${offsetVal}` : `${baseVal}`;
                resultsRef.multiplesNote.textContent = `Ajustado de ${finalRoundedSts} puntos (Múlt. ${multiLabelStr})`;
                resultsRef.multiplesNote.style.display = 'block';
            }
            finalRoundedSts = optimalSts;
        } else if (resultsRef.multiplesNote) {
            resultsRef.multiplesNote.style.display = 'none';
        }

        if (resultsRef.totalSts) resultsRef.totalSts.textContent = finalRoundedSts.toString();

        if (resultsRef.totalRows) {
            const finalRoundedRows = Math.round(targetRowsVal * rowScaleRatio);
            resultsRef.totalRows.textContent = finalRoundedRows.toString();
        }

        const exactScaleDiff = (pStsVal / mStsVal - 1) * 100;
        if (resultsRef.scaleFactor) {
            resultsRef.scaleFactor.textContent = `${exactScaleDiff >= 0 ? '+' : ''}${exactScaleDiff.toFixed(1)}%`;
        }

        if (resultsRef.sizeSuggestion) {
            if (Math.abs(exactScaleDiff) < 2) {
                resultsRef.sizeSuggestion.textContent = "Ideal";
                resultsRef.sizeSuggestion.style.color = "#10b981";
            } else if (exactScaleDiff > 0) {
                const nStep = Math.ceil(exactScaleDiff / 5) * 0.25;
                resultsRef.sizeSuggestion.innerHTML = `Baja Aguja<br><small style="opacity: 0.7; font-weight: 400">Usa aguja ${Math.max(2, currentNeedleVal - nStep)}mm o talla inferior.</small>`;
                resultsRef.sizeSuggestion.style.color = "#B06161";
            } else {
                const nStep = Math.ceil(Math.abs(exactScaleDiff) / 5) * 0.25;
                resultsRef.sizeSuggestion.innerHTML = `Sube Aguja<br><small style="opacity: 0.7; font-weight: 400">Usa aguja ${currentNeedleVal + nStep}mm o talla superior.</small>`;
                resultsRef.sizeSuggestion.style.color = "#ef4444";
            }
        }

        if (resultsRef.visualSwatch) {
            const visualScaleVal = Math.min(Math.max(pStsVal / mStsVal, 0.5), 1.3);
            resultsRef.visualSwatch.style.transform = `scale(${visualScaleVal})`;
            const densityConstant = 12;
            const updatedDensity = densityConstant * stsScaleRatio;
            resultsRef.visualSwatch.style.backgroundSize = `${updatedDensity}px ${updatedDensity}px`;
        }

        if (weightVal > 0 && resultsRef.yarnBox && resultsRef.yarnResult) {
            resultsRef.yarnBox.style.display = 'block';
            const totalProjectScale = (targetStsVal / pStsVal) * (targetRowsVal / pRowsVal);
            const totalEstimatedGrams = weightVal * totalProjectScale;
            resultsRef.yarnResult.innerHTML = `Lana estimada: <strong>${Math.ceil(totalEstimatedGrams)}g</strong> <small>(+${Math.ceil(totalEstimatedGrams * 0.1)}g de seguridad)</small>`;
        } else if (resultsRef.yarnBox) {
            resultsRef.yarnBox.style.display = 'none';
        }

        if (resultsRef.dangerInfo) {
            if (Math.abs(exactScaleDiff) > 25) {
                resultsRef.dangerInfo.style.display = 'block';
                resultsRef.dangerInfo.textContent = "Diferencia extrema (>25%). La caída y estructura de la prenda se verán alteradas.";
            } else {
                resultsRef.dangerInfo.style.display = 'none';
            }
        }

        updateAppUrl();
    }

    function updateAppUrl() {
        const urlParamsObj = new URLSearchParams();
        inputIdsList.forEach(idKey => {
            const curVal = elementsRef[idKey]?.value;
            if (curVal) urlParamsObj.set(idKey, curVal);
        });
        const nextUrl = `${window.location.pathname}?${urlParamsObj.toString()}`;
        window.history.replaceState({}, '', nextUrl);
    }

    document.querySelectorAll('.stepper-btn').forEach(btnDom => {
        btnDom.addEventListener('click', (ev) => {
            const domTarget = ev.currentTarget as HTMLButtonElement;
            const domId = domTarget.getAttribute('data-for') as InputIdType;
            const deltaStep = parseFloat(domTarget.getAttribute('data-step') || '1');
            const inputReference = elementsRef[domId] as HTMLInputElement;
            if (inputReference) {
                inputReference.value = (parseFloat(inputReference.value || '0') + deltaStep).toString();
                calculateGauge();
            }
        });
    });

    elementsRef['gauge-unit']?.addEventListener('change', handleUnitConversion);

    inputIdsList.forEach(idField => {
        elementsRef[idField]?.addEventListener('input', calculateGauge);
    });

    document.getElementById('btn-clear')?.addEventListener('click', () => {
        inputIdsList.forEach(idElem => {
            if (idElem === 'gauge-unit') return;
            const elementDom = elementsRef[idElem];
            if (elementDom) elementDom.value = (elementDom.id.includes('sts') || elementDom.id.includes('rows')) ? '20' : '';
        });
        calculateGauge();
    });

    document.getElementById('btn-share')?.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        const buttonRef = document.getElementById('btn-share');
        if (buttonRef) {
            const txtOrig = buttonRef.textContent;
            buttonRef.textContent = '¡Copiado!';
            setTimeout(() => { if (buttonRef) buttonRef.textContent = txtOrig; }, 2000);
        }
    });

    const queryParams = new URLSearchParams(window.location.search);
    queryParams.forEach((qVal, qKey) => {
        const qEl = elementsRef[qKey as InputIdType];
        if (qEl) qEl.value = qVal;
    });

    calculateGauge();
</script>
