---
import { Icon } from "astro-icon/components";
import "./ConcreteCalculator.css";
---

<div class="concrete-calculator-container">
    <div class="converter-card animate-in fade-in slide-in-from-bottom duration-700">
        <div class="mix-selector">
            <button class="mix-btn active" data-type="H200" title="Ideal para cimientos y soleras">
                <Icon name="mdi:mortar-pestle-plus" />
                <span>Hormigón Estándar</span>
            </button>
            <button class="mix-btn" data-type="M40" title="Para muros y tabiques">
                <Icon name="mdi:wall" />
                <span>Mortero de Albañilería</span>
            </button>
            <button class="mix-btn" data-type="M80" title="Para suelos y revocos fuertes">
                <Icon name="mdi:floor-plan" />
                <span>Recrecidos Fuertes</span>
            </button>
        </div>

        <div class="volume-control">
            <div class="calc-mode-selector">
                <button class="mode-btn active" data-mode="dims">
                    <Icon name="mdi:ruler" />
                    <span>Por Medidas</span>
                </button>
                <button class="mode-btn" data-mode="direct">
                    <Icon name="mdi:cube-outline" />
                    <span>m³ Directos</span>
                </button>
            </div>

            <div class="dimensions-helper active" id="mode-dims">
                <div class="dim-inputs">
                    <div class="dim-field">
                        <label for="dim-length">Largo</label>
                        <div class="dim-input-wrapper">
                            <input type="number" id="dim-length" value="5" step="0.5" />
                            <span class="dim-unit">m</span>
                        </div>
                    </div>
                    <div class="dim-field">
                        <label for="dim-width">Ancho</label>
                        <div class="dim-input-wrapper">
                            <input type="number" id="dim-width" value="3" step="0.5" />
                            <span class="dim-unit">m</span>
                        </div>
                    </div>
                    <div class="dim-field">
                        <label for="dim-thickness">Grosor</label>
                        <div class="dim-input-wrapper">
                            <input type="number" id="dim-thickness" value="10" step="1" />
                            <span class="dim-unit">cm</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="direct-volume-input" id="mode-direct">
                <div class="input-header">
                    <label for="volume">Volumen Total (m³)</label>
                </div>
                <div class="volume-input-wrapper">
                    <input type="number" id="volume" value="1.5" step="0.1" min="0" />
                    <span class="unit-tag">m³</span>
                </div>
            </div>

            <div class="binder-selector">
                <div class="binder-option active" data-binder="cement">
                    <div class="binder-circle"><div class="binder-inner"></div></div>
                    <span class="binder-label">Cemento</span>
                </div>
                <div class="binder-option" data-binder="lime">
                    <div class="binder-circle"><div class="binder-inner"></div></div>
                    <span class="binder-label">Cal</span>
                </div>
            </div>

            <div class="volume-display-summary">
                <span class="summary-label">Total a rellenar:</span>
                <div class="summary-value-wrapper">
                    <span class="summary-value" id="summary-vol">1.50</span>
                    <span class="summary-unit">m³</span>
                </div>
            </div>
        </div>

        <div class="results-grid">
            <div class="result-card">
                <Icon name="mdi:cube-outline" id="res-binder-icon" />
                <div class="result-info">
                    <span class="result-value" id="res-cement">0</span>
                    <span class="result-unit">Sacos (25kg)</span>
                </div>
                <span class="result-label" id="res-binder-label">Cemento Portland</span>
            </div>
            <div class="result-card">
                <Icon name="mdi:shovel" />
                <div class="result-info">
                    <span class="result-value" id="res-sand">0</span>
                    <span class="result-unit">Paladas</span>
                </div>
                <span class="result-label">Arena / Áridos</span>
            </div>
            <div class="result-card">
                <Icon name="mdi:water-outline" />
                <div class="result-info">
                    <span class="result-value" id="res-water">0</span>
                    <span class="result-unit">Litros</span>
                </div>
                <span class="result-label">Agua Potable</span>
            </div>
        </div>

        <div class="proportions-banner">
            <div class="proportion-header">
                <Icon name="mdi:information-outline" />
                <span>Proporciones de la Mezcla Seleccionada</span>
            </div>
            <div class="proportion-bar">
                <div class="bar-segment segment-cement" id="prop-cement" style="width: 20%;"></div>
                <div class="bar-segment segment-sand" id="prop-sand" style="width: 40%;"></div>
                <div class="bar-segment segment-gravel" id="prop-gravel" style="width: 40%;"></div>
            </div>
            <div class="proportion-labels">
                <div class="prop-label">
                    <span class="dot segment-cement"></span>
                    <span id="prop-binder-label">Cemento</span>
                </div>
                <div class="prop-label"><span class="dot segment-sand"></span> Arena</div>
                <div class="prop-label" id="label-gravel">
                    <span class="dot segment-gravel"></span> Grava
                </div>
            </div>
        </div>

        <div class="info-banner">
            <Icon name="mdi:alert-circle-outline" />
            <p id="mix-advice">
                Para un hormigón fuerte, usa 1 parte de cemento por cada 2.5 de arena y 3 de grava.
            </p>
        </div>

        <div class="price-summary-card">
            <span class="price-label">Presupuesto Estimado</span>
            <div class="price-value-wrapper">
                <span class="price-value" id="res-total-price">0</span>
                <span class="price-unit">€</span>
            </div>

            <div class="price-inputs-grid">
                <div class="price-input-field">
                    <label for="price-binder"
                        >Saco <span class="binder-type-label">Cemento</span> (25kg)</label
                    >
                    <div class="editable-price-wrapper">
                        <input
                            type="number"
                            id="price-binder"
                            class="editable-price"
                            value="5.50"
                            step="0.1"
                        />
                        <span class="editable-unit">€</span>
                    </div>
                </div>
                <div class="price-input-field">
                    <label for="price-sand">Arena (m³)</label>
                    <div class="editable-price-wrapper">
                        <input
                            type="number"
                            id="price-sand"
                            class="editable-price"
                            value="35.00"
                            step="1"
                        />
                        <span class="editable-unit">€</span>
                    </div>
                </div>
            </div>

            <p class="price-disclaimer">
                Precios de mercado orientativos. Ajusta según tu proveedor local.
            </p>
        </div>
    </div>
</div>

<script>
    interface Dosage {
        cementSacks: number;
        sandPaladas: number;
        gravelPaladas: number;
        waterLitros: number;
        ratio: string;
        advice: string;
        partsLine: { cement: number; sand: number; gravel: number };
    }

    const DOSAGES: Record<string, Dosage> = {
        H200: {
            cementSacks: 14,
            sandPaladas: 180,
            gravelPaladas: 240,
            waterLitros: 180,
            ratio: "1 : 2.5 : 3",
            advice: "Ideal para pilares, soleras y estructuras que soportan carga.",
            partsLine: { cement: 15, sand: 40, gravel: 45 },
        },
        M40: {
            cementSacks: 11,
            sandPaladas: 400,
            gravelPaladas: 0,
            waterLitros: 160,
            ratio: "1 : 4",
            advice: "Perfecto para levantar muros de ladrillo o bloque.",
            partsLine: { cement: 20, sand: 80, gravel: 0 },
        },
        M80: {
            cementSacks: 16,
            sandPaladas: 320,
            gravelPaladas: 0,
            waterLitros: 190,
            ratio: "1 : 3",
            advice: "Usa esto para recrecidos de suelo muy resistentes.",
            partsLine: { cement: 25, sand: 75, gravel: 0 },
        },
    };

    const volumeInput = document.getElementById("volume") as HTMLInputElement | null;
    const summaryVol = document.getElementById("summary-vol");
    const mixBtns = document.querySelectorAll(".mix-btn");
    const modeBtns = document.querySelectorAll(".mode-btn");
    const binderOptions = document.querySelectorAll(".binder-option");

    const resCement = document.getElementById("res-cement");
    const resSand = document.getElementById("res-sand");
    const resWater = document.getElementById("res-water");
    const mixAdvice = document.getElementById("mix-advice");
    const resBinderLabel = document.getElementById("res-binder-label");
    const propBinderLabel = document.getElementById("prop-binder-label");
    const binderTypeLabels = document.querySelectorAll(".binder-type-label");

    const propCement = document.getElementById("prop-cement");
    const propSand = document.getElementById("prop-sand");
    const propGravel = document.getElementById("prop-gravel");
    const labelGravel = document.getElementById("label-gravel");

    const dimLength = document.getElementById("dim-length") as HTMLInputElement | null;
    const dimWidth = document.getElementById("dim-width") as HTMLInputElement | null;
    const dimThickness = document.getElementById("dim-thickness") as HTMLInputElement | null;

    const modeDims = document.getElementById("mode-dims");
    const modeDirect = document.getElementById("mode-direct");

    const priceBinderInput = document.getElementById("price-binder") as HTMLInputElement | null;
    const priceSandInput = document.getElementById("price-sand") as HTMLInputElement | null;
    const resTotalPrice = document.getElementById("res-total-price");

    let currentMix = "H200";
    let currentMode = "dims";
    let currentBinder = "cement";

    function updateVolumeFromDims() {
        if (!dimLength || !dimWidth || !dimThickness || !volumeInput) return;
        const l = parseFloat(dimLength.value) || 0;
        const w = parseFloat(dimWidth.value) || 0;
        const t = parseFloat(dimThickness.value) || 0;
        const vol = (l * w * t) / 100;
        volumeInput.value = vol.toFixed(2);
        calculate();
    }

    function calculate() {
        if (!volumeInput || !resCement || !resSand || !resWater) return;

        const volume = parseFloat(volumeInput.value) || 0;
        if (summaryVol) summaryVol.textContent = volume.toFixed(2);

        const config = DOSAGES[currentMix];
        const totalPaladas = config.sandPaladas + config.gravelPaladas;

        const sacksNeeded = Math.ceil(config.cementSacks * volume);
        resCement.textContent = sacksNeeded.toString();
        resSand.textContent = Math.ceil(totalPaladas * volume).toString();
        resWater.textContent = Math.ceil(config.waterLitros * volume).toString();

        let binderName = "Cemento";
        if (currentBinder === "lime") {
            binderName = "Cal";
            if (resBinderLabel) resBinderLabel.textContent = "Cal Hidráulica";
            if (propBinderLabel) propBinderLabel.textContent = "Cal";
        } else {
            if (resBinderLabel) resBinderLabel.textContent = "Cemento Portland";
            if (propBinderLabel) propBinderLabel.textContent = "Cemento";
        }

        binderTypeLabels.forEach((l) => (l.textContent = binderName));

        const pb = parseFloat(priceBinderInput?.value || "0");
        const ps = parseFloat(priceSandInput?.value || "0");
        const totalP = sacksNeeded * pb + volume * ps;
        if (resTotalPrice) resTotalPrice.textContent = totalP.toFixed(2);

        let advice = config.advice;
        if (currentBinder === "lime") {
            advice = advice.replace("cemento", "cal");
            if (currentMix === "H200")
                advice = "Nota: El hormigón de cal es más flexible pero tarda más en fraguar.";
        }

        if (mixAdvice) mixAdvice.textContent = advice + ` (Proporción: ${config.ratio})`;

        if (propCement) propCement.style.width = config.partsLine.cement + "%";
        if (propSand) propSand.style.width = config.partsLine.sand + "%";
        if (propGravel) {
            propGravel.style.width = config.partsLine.gravel + "%";
            if (labelGravel)
                labelGravel.style.display = config.partsLine.gravel > 0 ? "flex" : "none";
        }
    }

    binderOptions.forEach((opt) => {
        opt.addEventListener("click", () => {
            binderOptions.forEach((o) => o.classList.remove("active"));
            opt.classList.add("active");
            currentBinder = (opt as HTMLElement).dataset.binder || "cement";

            if (priceBinderInput) {
                priceBinderInput.value = currentBinder === "lime" ? "8.50" : "5.50";
            }

            calculate();
        });
    });

    modeBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            modeBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            currentMode = (btn as HTMLElement).dataset.mode || "dims";

            if (currentMode === "dims") {
                modeDims?.classList.add("active");
                modeDirect?.classList.remove("active");
                updateVolumeFromDims();
            } else {
                modeDims?.classList.remove("active");
                modeDirect?.classList.add("active");
                calculate();
            }
        });
    });

    mixBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            mixBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            currentMix = (btn as HTMLElement).dataset.type || "H200";
            calculate();
        });
    });

    dimLength?.addEventListener("input", updateVolumeFromDims);
    dimWidth?.addEventListener("input", updateVolumeFromDims);
    dimThickness?.addEventListener("input", updateVolumeFromDims);
    volumeInput?.addEventListener("input", calculate);
    priceBinderInput?.addEventListener("input", calculate);
    priceSandInput?.addEventListener("input", calculate);

    updateVolumeFromDims();
</script>
