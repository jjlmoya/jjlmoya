---
import "./SVGInputPanel.css";
---

<div class="svg-input-panel glass-card">
    <label for="svg-input-area" class="input-label">Pega tu SVG sucio aquí</label>
    <textarea
        id="svg-input-area"
        class="svg-textarea"
        placeholder={`<svg xmlns="http://www.w3.org/2000/svg" version="1.1" xml:space="preserve" data-name="Figma Export">\n  <metadata>...</metadata>\n  <g id="Layer_1" data-name="Capa 1"></g>\n  <path d="M10 10 L90 90"/>\n</svg>`}
        spellcheck="false"
        autocomplete="off"></textarea>

    <div class="options-row">
        <label class="toggle-label">
            <input type="checkbox" id="opt-remove-ids" class="toggle-input" />
            <span class="toggle-track"></span>
            Eliminar IDs
        </label>
        <label class="toggle-label">
            <input type="checkbox" id="opt-remove-wh" class="toggle-input" checked />
            <span class="toggle-track"></span>
            Quitar width/height
        </label>
        <label class="toggle-label">
            <input type="checkbox" id="opt-minify" class="toggle-input" />
            <span class="toggle-track"></span>
            Minificar
        </label>
    </div>

    <button id="svg-btn-sanitize" class="btn-sanitize">
        <i class="mdi mdi-auto-fix"></i> Limpiar SVG
    </button>

    <p id="svg-error-msg" class="error-msg hidden"></p>
</div>

<script>
    import { sanitizeSVG } from "./svg-sanitizer-engine.ts";
    import type { SanitizeOptions } from "./svg-sanitizer-engine.ts";

    document.getElementById("svg-btn-sanitize")?.addEventListener("click", () => {
        const textarea = document.getElementById("svg-input-area") as HTMLTextAreaElement;
        const errorMsg = document.getElementById("svg-error-msg") as HTMLElement;
        const input = textarea.value.trim();

        errorMsg.classList.add("hidden");

        if (!input) {
            errorMsg.textContent = "Pega un SVG antes de limpiar.";
            errorMsg.classList.remove("hidden");
            return;
        }

        const options: SanitizeOptions = {
            removeIds: (document.getElementById("opt-remove-ids") as HTMLInputElement).checked,
            removeWidthHeight: (document.getElementById("opt-remove-wh") as HTMLInputElement)
                .checked,
            minify: (document.getElementById("opt-minify") as HTMLInputElement).checked,
        };

        try {
            const result = sanitizeSVG(input, options);
            window.dispatchEvent(new CustomEvent("svg:result", { detail: result }));
        } catch (e) {
            const msg = e instanceof Error ? e.message : "Error al procesar el SVG.";
            errorMsg.textContent = msg;
            errorMsg.classList.remove("hidden");
        }
    });
</script>
