---
import "./SVGOutputPanel.css";
---

<div id="svg-output-panel" class="svg-output-panel glass-card hidden">
    <div class="output-header">
        <span class="output-label">SVG limpio</span>
        <div class="output-actions">
            <button id="svg-btn-copy" class="btn-action">
                <i class="mdi mdi-content-copy"></i> Copiar
            </button>
            <button id="svg-btn-download" class="btn-action btn-download">
                <i class="mdi mdi-download"></i> Descargar
            </button>
        </div>
    </div>

    <textarea id="svg-output-area" class="svg-textarea output" readonly spellcheck="false"
    ></textarea>

    <div class="stats-row">
        <div class="stat-chip">
            <span class="chip-value" id="stat-original">--</span>
            <span class="chip-label">Original</span>
        </div>
        <div class="stat-chip green">
            <span class="chip-value" id="stat-cleaned">--</span>
            <span class="chip-label">Limpio</span>
        </div>
        <div class="stat-chip purple">
            <span class="chip-value" id="stat-reduction">--</span>
            <span class="chip-label">Reducción</span>
        </div>
        <div class="stat-chip amber">
            <span class="chip-value" id="stat-elements">--</span>
            <span class="chip-label">Elem. eliminados</span>
        </div>
        <div class="stat-chip rose">
            <span class="chip-value" id="stat-attrs">--</span>
            <span class="chip-label">Attrs. eliminados</span>
        </div>
    </div>
</div>

<script>
    import type { SanitizeResult } from "./svg-sanitizer-engine.ts";

    function fmt(bytes: number): string {
        if (bytes < 1024) return `${bytes} B`;
        return `${(bytes / 1024).toFixed(1)} KB`;
    }

    function set(id: string, val: string) {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
    }

    window.addEventListener("svg:result", (e) => {
        const r = (e as CustomEvent<SanitizeResult>).detail;

        (document.getElementById("svg-output-area") as HTMLTextAreaElement).value = r.svg;

        const pct = Math.round(((r.originalBytes - r.cleanedBytes) / r.originalBytes) * 100);
        set("stat-original", fmt(r.originalBytes));
        set("stat-cleaned", fmt(r.cleanedBytes));
        set("stat-reduction", `${pct}%`);
        set("stat-elements", r.removedElements.toString());
        set("stat-attrs", r.removedAttrs.toString());

        document.getElementById("svg-output-panel")?.classList.remove("hidden");
    });

    document.getElementById("svg-btn-copy")?.addEventListener("click", () => {
        const area = document.getElementById("svg-output-area") as HTMLTextAreaElement;
        navigator.clipboard.writeText(area.value);
        const btn = document.getElementById("svg-btn-copy") as HTMLButtonElement;
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="mdi mdi-check"></i> Copiado';
        btn.classList.add("copied");
        setTimeout(() => {
            btn.innerHTML = orig;
            btn.classList.remove("copied");
        }, 2000);
    });

    document.getElementById("svg-btn-download")?.addEventListener("click", () => {
        const content = (document.getElementById("svg-output-area") as HTMLTextAreaElement).value;
        const blob = new Blob([content], { type: "image/svg+xml" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "optimized.svg";
        a.click();
        URL.revokeObjectURL(a.href);
    });
</script>
