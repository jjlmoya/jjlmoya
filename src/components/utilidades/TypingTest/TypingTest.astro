---
import "./TypingTest.css";
---

<div class="typing">
  <div class="typing-timer">
    <div class="typing-timer__bar" id="timerBar"></div>
    <span class="typing-timer__text" id="timerText">60</span>
  </div>

  <div class="typing-stats-live">
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">Palabras</span>
      <span class="typing-stats-live__value" id="wordCount">0</span>
    </div>
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">WPM</span>
      <span class="typing-stats-live__value" id="wpmLive">0</span>
    </div>
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">Precisión</span>
      <span class="typing-stats-live__value" id="accLive">100%</span>
    </div>
  </div>

  <div class="typing-arena">
    <div class="typing-arena__words">
      <div class="typing-arena__current" id="wordDisplay"></div>
      <div class="typing-arena__next" id="nextWordDisplay"></div>
    </div>
  </div>

  <div class="typing-results" id="resultsScreen">
    <div class="typing-results__overlay"></div>
    <div class="typing-results__podium">
      <h1 class="typing-results__title">¡Tiempo!</h1>

      <div class="typing-results__stats-grid">
        <div class="typing-results__stat">
          <div class="typing-results__label">Palabras</div>
          <div class="typing-results__value" id="finalWords">0</div>
        </div>
        <div class="typing-results__stat typing-results__stat--highlight">
          <div class="typing-results__label">WPM</div>
          <div class="typing-results__value" id="finalWPM">0</div>
        </div>
        <div class="typing-results__stat">
          <div class="typing-results__label">Precisión</div>
          <div class="typing-results__value" id="finalAcc">100%</div>
        </div>
      </div>

      <div class="typing-results__grid" id="resultGrid"></div>

      <div class="typing-results__actions">
        <button class="typing-results__btn typing-results__btn--primary" id="restartBtn">Jugar de nuevo</button>
        <button class="typing-results__btn typing-results__btn--secondary" id="shareBtn">Compartir</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  const WORDS = [
    "casa", "perro", "gato", "sol", "luna", "amor", "risa", "juego", "tiempo", "vida",
    "muerte", "noche", "día", "amigo", "familia", "comer", "beber", "dormir", "soñar", "correr",
    "bailar", "cantar", "saltar", "volar", "nadar", "caminar", "libro", "palabra", "letra", "número",
    "color", "árbol", "flor", "agua", "fuego", "aire", "tierra", "mar", "montaña", "río",
    "cielo", "estrella", "nubes", "viento", "lluvia", "nieve", "hielo", "calor", "frío", "luz",
    "aventura", "misterio", "espacio", "universo", "planeta", "cometa", "constelación", "galaxia",
    "computadora", "pantalla", "sistema", "conexión", "internet", "navegador", "instrumento", "melodía",
    "armonía", "ritmo", "danza", "teatro", "película", "actor", "director", "escena", "personaje", "historia",
    "biblioteca", "novela", "poema", "autor", "escritor", "página", "capítulo", "argumento", "trama", "final",
    "corazón", "cerebro", "mente", "pensamiento", "idea", "concepto", "teoría", "filosofía", "sabiduría", "conocimiento",
    "problema", "solución", "respuesta", "pregunta", "duda", "certeza", "verdad", "mentira", "engaño", "trampa",
    "reina", "rey", "príncipe", "princesa", "caballero", "dragón", "castillo", "reino", "imperio", "trono",
    "barco", "vela", "ancla", "puerto", "playa", "arena", "isla", "océano", "ola", "corriente",
    "volcán", "terremoto", "tormenta", "huracán", "tornado", "avalancha", "erupción", "sequia", "inundación", "granizo",
    "medicina", "doctor", "hospital", "enfermedad", "cura", "remedio", "pastilla", "inyección", "cirugía", "paciente",
    "música", "canción", "ópera", "sinfonía", "compositor", "músico", "violín", "piano", "guitarra", "tambor",
    "comida", "postre", "bebida", "cocina", "chef", "receta", "sabor", "aroma", "textura", "hambre",
    "viaje", "turismo", "destino", "maleta", "pasaporte", "avión", "tren", "coche", "bicicleta", "motocicleta",
    "deporte", "fútbol", "baloncesto", "tenis", "natación", "boxeo", "lucha", "carrera", "salto", "lanzamiento",
    "dinero", "moneda", "billete", "banco", "préstamo", "deuda", "pago", "precio", "venta", "compra",
    "trabajo", "oficio", "profesión", "carrera", "empleo", "jefe", "empleado", "salario", "contrato", "renuncia",
    "escuela", "colegio", "universidad", "profesor", "estudiante", "lección", "examen", "calificación", "diploma", "educación",
    "iglesia", "templo", "religión", "fe", "oración", "santo", "ángel", "demonio", "infierno", "paraíso",
    "esternoclidomastoideo", "electrocardioencefalograma", "hepatomegalia", "cardiomiopatía", "neumonía", "meningitis", "artritis", "diabetes",
    "endocrinología", "otorrinolaringología", "oftalmología", "dermatología", "gastroenterología", "neumología", "reumatología", "hematología",
    "supercalifragilisticoespialidoso", "inconstitucionalidad", "incomparabilidad", "indescriptibilidad", "inmunocomprometido", "infraestructura",
    "tecnología", "inteligencia", "algoritmo", "programa", "código", "error", "bug", "servidor", "cliente", "base",
    "naturaleza", "ecosistema", "biodiversidad", "extinción", "evolución", "adaptación", "depredador", "presa", "herbívoro", "carnívoro",
    "psicología", "psiquiatría", "neurología", "cognición", "emoción", "sentimiento", "memoria", "atención", "percepción", "consciencia",
    "arquitectura", "escultura", "pintura", "dibujo", "arte", "galería", "museo", "exposición", "obra", "lienzo",
    "química", "física", "matemática", "biología", "geología", "astronomía", "meteorología", "oceanografía", "botánica", "zoología",
    "república", "democracia", "monarquía", "dictadura", "gobierno", "política", "elección", "voto", "congreso", "parlamento",
    "ley", "derecho", "justicia", "abogado", "juez", "tribunal", "sentencia", "culpa", "inocencia", "castigo",
    "libertad", "esclavitud", "opresión", "revolución", "guerra", "paz", "tregua", "alianza", "enemigo", "conflicto",
    "lenguaje", "gramática", "sintaxis", "semántica", "vocabulario", "pronunciación", "acento", "dialecto", "idioma", "traducción",
    "alfabeto", "mayúscula", "minúscula", "puntuación", "pausa", "énfasis", "ritmo", "entonación", "cadencia", "musicalidad"
  ];

  const GAME = {
    timeLeft: 60,
    running: false,
    started: false,
    words: [],
    errors: [],
    startTime: 0,
    timerInterval: null,
    currentWord: "",
    nextWord: "",
    typed: "",
    hasErrorInCurrentWord: false
  };

  function getRandomWord() {
    return WORDS[Math.floor(Math.random() * WORDS.length)];
  }

  function startGame() {
    GAME.running = true;
    GAME.started = false;
    GAME.timeLeft = 60;
    GAME.words = [];
    GAME.errors = [];
    GAME.currentWord = getRandomWord();
    GAME.nextWord = getRandomWord();
    GAME.typed = "";
    GAME.hasErrorInCurrentWord = false;

    render();
  }

  function initializeTimer() {
    if (GAME.started) return;
    GAME.started = true;
    GAME.startTime = Date.now();
    startTimer();
  }

  function startTimer() {
    GAME.timerInterval = setInterval(() => {
      if (!GAME.running) {
        clearInterval(GAME.timerInterval);
        return;
      }

      GAME.timeLeft = Math.max(0, 60 - Math.floor((Date.now() - GAME.startTime) / 1000));

      const timerText = document.getElementById("timerText");
      const timerBar = document.getElementById("timerBar");

      if (timerText) timerText.textContent = GAME.timeLeft;
      if (timerBar) timerBar.style.width = (GAME.timeLeft / 60 * 100) + "%";

      if (GAME.timeLeft === 0) {
        clearInterval(GAME.timerInterval);
        endGame();
      }
    }, 100);
  }

  function updateStats() {
    const elapsed = (Date.now() - GAME.startTime) / 1000;
    const wpm = GAME.words.length > 0 ? Math.round((GAME.words.length * 5) / (elapsed / 60)) : 0;
    const acc = GAME.words.length > 0 ? Math.round(((GAME.words.length / (GAME.words.length + GAME.errors.length)) * 100)) : 100;

    document.getElementById("wordCount").textContent = GAME.words.length;
    document.getElementById("wpmLive").textContent = wpm;
    document.getElementById("accLive").textContent = acc + "%";
  }

  function render() {
    const display = document.getElementById("wordDisplay");
    const nextDisplay = document.getElementById("nextWordDisplay");

    if (!display) return;

    const typed = GAME.typed;
    const target = GAME.currentWord;

    let html = "";
    for (let i = 0; i < target.length; i++) {
      const char = target[i];
      let cls = "typing-char";
      if (i < typed.length) {
        cls += typed[i] === char ? " typing-char--ok" : " typing-char--bad";
      } else if (i === typed.length) {
        cls += " typing-char--cur";
      }
      html += `<span class="${cls}">${char}</span>`;
    }
    display.innerHTML = html;

    if (nextDisplay) {
      const progress = typed.length / target.length;
      nextDisplay.textContent = GAME.nextWord;
      nextDisplay.style.opacity = Math.max(0, progress - 0.4) * 1.67;
      nextDisplay.style.transform = `translateX(-50%) scale(0.6) translateY(${Math.max(0, progress - 0.4) * 20}px)`;
    }

    updateStats();
  }

  function completeWord() {
    const display = document.getElementById("wordDisplay");

    if (display) {
      display.classList.add("typing-complete");
      setTimeout(() => {
        display.classList.remove("typing-complete");
      }, 400);
    }

    document.body.style.animation = "none";
    GAME.words.push(GAME.currentWord);
    GAME.currentWord = GAME.nextWord;
    GAME.nextWord = getRandomWord();
    GAME.typed = "";
    GAME.hasErrorInCurrentWord = false;

    render();
  }

  function showError() {
    document.body.style.animation = "none";
    setTimeout(() => {
      document.body.style.animation = "typing-pulse-error 0.2s";
    }, 10);

    GAME.errors.push(true);
    GAME.timeLeft = Math.max(0, GAME.timeLeft - 3);
  }

  function endGame() {
    GAME.running = false;
    const elapsed = (Date.now() - GAME.startTime) / 1000;
    const wpm = GAME.words.length > 0 ? Math.round((GAME.words.length * 5) / (elapsed / 60)) : 0;
    const acc = GAME.words.length > 0 ? Math.round(((GAME.words.length / (GAME.words.length + GAME.errors.length)) * 100)) : 100;

    document.getElementById("finalWords").textContent = GAME.words.length;
    document.getElementById("finalWPM").textContent = wpm;
    document.getElementById("finalAcc").textContent = acc + "%";

    const grid = document.getElementById("resultGrid");
    if (grid) {
      let gridHTML = "";
      for (let i = 0; i < GAME.words.length; i++) {
        gridHTML += "[G]";
      }
      for (let i = 0; i < GAME.errors.length; i++) {
        gridHTML += "[W]";
      }

      let rows = "";
      for (let i = 0; i < gridHTML.length; i += 5) {
        rows += gridHTML.slice(i, i + 5) + "\n";
      }
      grid.textContent = rows;
    }

    const resultsScreen = document.getElementById("resultsScreen");
    if (resultsScreen) resultsScreen.style.display = "flex";
  }

  function init() {
    const restartBtn = document.getElementById("restartBtn");
    const shareBtn = document.getElementById("shareBtn");
    const resultsScreen = document.getElementById("resultsScreen");

    if (restartBtn) {
      restartBtn.addEventListener("click", function() {
        if (resultsScreen) resultsScreen.style.display = "none";
        startGame();
      });
    }

    if (shareBtn) {
      shareBtn.addEventListener("click", function() {
        const text = `Typing Sprint\n\n${document.getElementById("resultGrid").textContent}\n${GAME.words.length} palabras • ${document.getElementById("finalWPM").textContent} • ${document.getElementById("finalAcc").textContent}\n\nIntenta superarme: jjlmoya.es`;
        navigator.clipboard.writeText(text).then(() => {
          shareBtn.textContent = "¡Copiado!";
          setTimeout(() => {
            shareBtn.textContent = "Compartir";
          }, 2000);
        });
      });
    }

    document.addEventListener("keydown", function(e) {
      if (!GAME.running) return;

      const char = e.key.toLowerCase();

      if (!/^[a-záéíóúñ]$/.test(char)) {
        if (char === "backspace") {
          GAME.typed = GAME.typed.slice(0, -1);
          render();
        }
        return;
      }

      if (!GAME.started) {
        initializeTimer();
      }

      const target = GAME.currentWord;

      if (GAME.typed.length < target.length) {
        GAME.typed += char;

        if (GAME.typed === target) {
          completeWord();
        } else {
          let hasError = false;
          for (let i = 0; i < GAME.typed.length; i++) {
            if (GAME.typed[i] !== target[i]) {
              hasError = true;
              break;
            }
          }
          if (hasError && !GAME.hasErrorInCurrentWord) {
            GAME.hasErrorInCurrentWord = true;
            showError();
          } else if (!hasError) {
            document.body.style.animation = "none";
          }
          render();
        }
      }
    });

    startGame();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
