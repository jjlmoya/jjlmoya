---
import { Icon } from "astro-icon/components";
---

<div class="request-tool-section">
    <div class="request-card">
        <div class="request-icon-side">
            <div class="request-icon-container">
                <Icon name="mdi:lightbulb-on" class="request-icon" />
            </div>
        </div>

        <div class="request-main-content">
            <div class="request-text-content">
                <h3 class="request-title">¿Echas en falta alguna utilidad?</h3>
                <p class="request-description">
                    Muchas de las herramientas que ves aquí son peticiones de usuarios. Escucho cada
                    idea para que esta suite siga siendo realmente útil. <strong
                        >Pídela y me pondré manos a la obra.</strong
                    >
                </p>
            </div>

            <div class="request-form-container" id="global-request-form">
                <div class="input-container">
                    <input
                        type="text"
                        id="global-request-input"
                        placeholder="Define la herramienta que necesitas..."
                        class="request-input-field"
                        autocomplete="off"
                    />
                </div>
                <button id="global-request-btn" class="request-action-btn">
                    <span class="btn-text">Enviar propuesta</span>
                    <span class="btn-loading"><div class="spinner"></div></span>
                    <span class="btn-success"><Icon name="mdi:check-bold" class="w-5 h-5" /></span>
                </button>
                <div id="global-request-status" class="request-status-info">
                    <span class="status-success">¡Propuesta recibida! Me pongo con ello.</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .request-tool-section {
        margin: 4rem 0;
        width: 100%;
    }

    .request-card {
        padding: 2rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
        position: relative;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .request-card {
            flex-direction: row;
            padding: 2.5rem;
            gap: 2rem;
            align-items: flex-start;
        }
    }

    :global(.dark) .request-card {
        background: #1e293b;
        border-color: #334155;
    }

    .request-icon-side {
        flex-shrink: 0;
    }

    .request-icon-container {
        width: 3.5rem;
        height: 3.5rem;
        background: #6366f1;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 8px 16px -4px rgba(99, 102, 241, 0.4);
    }

    .request-icon {
        width: 1.75rem;
        height: 1.75rem;
    }

    .request-main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .request-title {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        color: #0f172a;
        letter-spacing: -0.02em;
        line-height: 1.2;
    }

    :global(.dark) .request-title {
        color: #ffffff;
    }

    .request-description {
        color: #64748b;
        line-height: 1.6;
        font-size: 1rem;
        margin: 0;
    }

    :global(.dark) .request-description {
        color: #94a3b8;
    }

    .request-form-container {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        position: relative;
    }

    @media (min-width: 640px) {
        .request-form-container {
            flex-direction: row;
            align-items: stretch;
        }
    }

    .input-container {
        flex: 1;
    }

    .request-input-field {
        width: 100%;
        padding: 0.75rem 1.25rem;
        border-radius: 0.75rem;
        border: 2px solid #e2e8f0;
        background: #f8fafc;
        font-size: 0.95rem;
        outline: none;
        transition: all 0.2s;
        color: #0f172a;
    }

    :global(.dark) .request-input-field {
        background: #0f172a;
        border-color: #334155;
        color: #ffffff;
    }

    .request-input-field:focus {
        border-color: #6366f1;
        background: white;
    }

    :global(.dark) .request-input-field:focus {
        background: #0f172a;
    }

    .request-action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1.5rem;
        background: #6366f1;
        color: white;
        font-weight: 700;
        border-radius: 0.75rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        font-size: 0.95rem;
        min-width: 160px;
        height: 3rem;
    }

    .request-action-btn:hover:not(:disabled) {
        background: #4f46e5;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    }

    .request-action-btn:disabled {
        cursor: default;
    }

    .request-action-btn .btn-loading,
    .request-action-btn .btn-success {
        display: none;
    }

    .request-action-btn.is-loading .btn-text {
        display: none;
    }
    .request-action-btn.is-loading .btn-loading {
        display: flex;
    }

    .request-action-btn.is-success {
        background: #10b981 !important;
        pointer-events: none;
    }

    .request-action-btn.is-success .btn-text {
        display: none;
    }
    .request-action-btn.is-success .btn-success {
        display: flex;
    }

    .spinner {
        width: 1.25rem;
        height: 1.25rem;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: simple-spin 0.8s linear infinite;
    }

    @keyframes simple-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .request-status-info {
        display: none;
        font-size: 0.8rem;
        font-weight: 600;
        position: absolute;
        bottom: -1.5rem;
        left: 0;
    }

    .request-status-info.success {
        display: block;
        color: #10b981;
    }
</style>

<script is:inline>
    (function () {
        function initGlobalRequest() {
            const container = document.getElementById("global-request-form");
            if (!container) return;

            const input = container.querySelector("#global-request-input");
            const btn = container.querySelector("#global-request-btn");
            const status = container.querySelector("#global-request-status");

            if (!btn || !input) return;

            btn.onclick = async () => {
                const query = input.value.trim();
                if (!query) return;

                btn.classList.add("is-loading");
                btn.disabled = true;

                let userId = "Anónimo";
                try {
                    const footprint = localStorage.getItem("jjlmoya_footprint_v5");
                    if (footprint) {
                        const data = JSON.parse(footprint);
                        if (data.id) userId = data.id;
                    }
                } catch (e) {}

                try {
                    await fetch(
                        "https://script.google.com/macros/s/AKfycbySUhlqnbamZCYZjuCJlQD51jmuAnjX6q6jb8XSFo7CRAG3_M_Xb90MWqSB_2zb-OQc/exec",
                        {
                            method: "POST",
                            mode: "no-cors",
                            headers: { "Content-Type": "text/plain" },
                            body: JSON.stringify({
                                type: "utility-request-global",
                                query: query,
                                ua: navigator.userAgent,
                                id: userId,
                                timestamp: new Date().toISOString(),
                            }),
                        }
                    );

                    btn.classList.remove("is-loading");
                    btn.classList.add("is-success");
                    status.className = "request-status-info success";
                    input.value = "";

                    setTimeout(() => {
                        btn.classList.remove("is-success");
                        btn.disabled = false;
                        status.className = "request-status-info";
                    }, 4000);
                } catch (err) {
                    btn.classList.remove("is-loading");
                    btn.disabled = false;
                    alert("No se ha podido enviar la propuesta. ¡Vuelve a intentarlo!");
                }
            };
        }

        initGlobalRequest();
        document.addEventListener("astro:page-load", initGlobalRequest);
    })();
</script>
