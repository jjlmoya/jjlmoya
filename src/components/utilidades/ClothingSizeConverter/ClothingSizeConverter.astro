---
import "./ClothingSizeConverter.css";
---

<div class="clothing-converter-container">
    <div class="converter-card animate-in fade-in slide-in-from-bottom duration-700">
        <div class="category-selector">
            <div class="selector-group">
                <label class="selector-label">Tipo de Prenda</label>
                <div class="button-group">
                    <button class="category-btn active" data-category="camisetas">
                        <i class="mdi mdi-tshirt-crew"></i>
                        <span>Camisetas</span>
                    </button>
                    <button class="category-btn" data-category="pantalones">
                        <i class="mdi mdi-pants"></i>
                        <span>Pantalones</span>
                    </button>
                    <button class="category-btn" data-category="vestidos">
                        <i class="mdi mdi-dress"></i>
                        <span>Vestidos</span>
                    </button>
                    <button class="category-btn" data-category="chaquetas">
                        <i class="mdi mdi-jacket"></i>
                        <span>Chaquetas</span>
                    </button>
                </div>
            </div>

            <div class="selector-group">
                <label class="selector-label">Género</label>
                <div class="button-group">
                    <button class="gender-btn active" data-gender="men">
                        <i class="mdi mdi-human-male"></i>
                        <span>Hombre</span>
                    </button>
                    <button class="gender-btn" data-gender="women">
                        <i class="mdi mdi-human-female"></i>
                        <span>Mujer</span>
                    </button>
                    <button class="gender-btn" data-gender="unisex">
                        <i class="mdi mdi-human-male-female"></i>
                        <span>Unisex</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="input-tabs">
            <button class="tab-btn active" data-tab="by-size">
                <i class="mdi mdi-ruler"></i>
                Por Talla
            </button>
            <button class="tab-btn" data-tab="by-measurements">
                <i class="mdi mdi-tape-measure"></i>
                Por Medidas
            </button>
        </div>

        <div class="tab-content active" id="by-size-tab">
            <div class="control-group">
                <div class="input-field">
                    <label for="region-select">Tu Sistema de Talla</label>
                    <select id="region-select" class="premium-select">
                        <option value="EU">Europa (EU)</option>
                        <option value="US">Estados Unidos (US)</option>
                        <option value="UK">Reino Unido (UK)</option>
                        <option value="IT">Italia (IT)</option>
                    </select>
                </div>

                <div class="input-field">
                    <label for="size-select">Selecciona tu Talla</label>
                    <select id="size-select" class="premium-select"> </select>
                </div>
            </div>

            <div class="results-display">
                <div class="result-card">
                    <span class="result-label" id="label-1">Estados Unidos</span>
                    <span class="result-value" id="val-1">-</span>
                </div>
                <div class="result-card">
                    <span class="result-label" id="label-2">Reino Unido</span>
                    <span class="result-value" id="val-2">-</span>
                </div>
                <div class="result-card">
                    <span class="result-label" id="label-3">Italia</span>
                    <span class="result-value" id="val-3">-</span>
                </div>
            </div>

            <div class="quick-grid-section">
                <h3 class="section-title">Equivalencias Rápidas (EU)</h3>
                <div class="size-grid" id="quick-grid"></div>
            </div>
        </div>

        <div class="tab-content" id="by-measurements-tab">
            <div class="measurements-wrapper">
                <div class="measurements-content">
                    <div class="measurements-inputs-section">
                        <h3 class="section-title" style="margin-bottom: 1.5rem;">
                            Ingresa tus Medidas
                        </h3>
                        <div class="measurements-inputs">
                            <div class="input-field">
                                <label for="chest-input">
                                    <i class="mdi mdi-tape-measure" style="color: #ef4444;"></i>
                                    Pecho (cm)
                                </label>
                                <input
                                    type="number"
                                    id="chest-input"
                                    placeholder="Ej: 95"
                                    min="50"
                                    max="150"
                                    class="measurement-input"
                                />
                            </div>
                            <div class="input-field">
                                <label for="waist-input">
                                    <i class="mdi mdi-tape-measure" style="color: #ef4444;"></i>
                                    Cintura (cm)
                                </label>
                                <input
                                    type="number"
                                    id="waist-input"
                                    placeholder="Ej: 85"
                                    min="40"
                                    max="140"
                                    class="measurement-input"
                                />
                            </div>
                            <div class="input-field">
                                <label for="hip-input">
                                    <i class="mdi mdi-tape-measure" style="color: #ef4444;"></i>
                                    Cadera (cm)
                                </label>
                                <input
                                    type="number"
                                    id="hip-input"
                                    placeholder="Ej: 95"
                                    min="50"
                                    max="150"
                                    class="measurement-input"
                                />
                            </div>
                            <button class="btn-recommend" id="recommend-btn">
                                <i class="mdi mdi-lightbulb-on"></i>
                                Recomendar Talla
                            </button>
                        </div>
                    </div>

                    <div class="measurement-tips">
                        <h4 class="tips-title"><i class="mdi mdi-lightbulb-outline"></i> Tips</h4>
                        <div class="tips-grid">
                            <div class="tip-item">
                                <i class="mdi mdi-shirt"></i>
                                <span>Sobre la ropa</span>
                            </div>
                            <div class="tip-item">
                                <i class="mdi mdi-arrow-expand-horizontal"></i>
                                <span>Recta y paralela</span>
                            </div>
                            <div class="tip-item">
                                <i class="mdi mdi-minus"></i>
                                <span>Sin apretar</span>
                            </div>
                            <div class="tip-item">
                                <i class="mdi mdi-moon-waning-crescent"></i>
                                <span>Al final del día</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="recommendation-box" id="recommendation-box" style="display: none;">
                    <div class="recommendation-header">
                        <i class="mdi mdi-check-circle"></i>
                        <h4>Talla Recomendada</h4>
                    </div>
                    <p id="recommendation-text"></p>
                    <div id="size-details" class="size-details"></div>
                </div>
            </div>
        </div>

        <div class="fit-guide-section">
            <h3 class="section-title">Guía de Ajuste por Marca</h3>
            <div class="fit-grid">
                <button class="fit-card" data-brand="zara" data-fit="regular">
                    <span class="fit-brand">Zara</span>
                    <span class="fit-size">Talla Regular</span>
                </button>
                <button class="fit-card" data-brand="hm" data-fit="large">
                    <span class="fit-brand">H&M</span>
                    <span class="fit-size">Talla Grande</span>
                </button>
                <button class="fit-card" data-brand="asos" data-fit="regular">
                    <span class="fit-brand">ASOS</span>
                    <span class="fit-size">Talla Regular</span>
                </button>
                <button class="fit-card" data-brand="uniqlo" data-fit="small">
                    <span class="fit-brand">Uniqlo</span>
                    <span class="fit-size">Talla Pequeña</span>
                </button>
                <button class="fit-card" data-brand="nike" data-fit="small">
                    <span class="fit-brand">Nike</span>
                    <span class="fit-size">Talla Pequeña</span>
                </button>
                <button class="fit-card" data-brand="adidas" data-fit="regular">
                    <span class="fit-brand">Adidas</span>
                    <span class="fit-size">Talla Regular</span>
                </button>
            </div>
            <div
                class="fit-notification"
                id="fit-notification"
                style="display: none; margin-top: 1.5rem; padding: 1.25rem; background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%); border: 2px solid #0284c7; border-radius: 1rem; color: #0369a1;"
            >
                <strong id="selected-brand"></strong> suele tallar <strong id="fit-type"></strong>.
                Considera <span id="fit-advice"></span> si es tu primera vez comprando en esta marca.
            </div>
            <p class="fit-info" id="fit-info-text">
                <i class="mdi mdi-information-outline"></i>
                Haz clic en una marca para obtener recomendaciones específicas.
            </p>
        </div>

        <div class="comparison-table-section">
            <h3 class="section-title">Tabla de Conversión Completa</h3>
            <div class="table-wrapper">
                <table class="conversion-table" id="conversion-table">
                    <thead>
                        <tr>
                            <th>EU</th>
                            <th>US</th>
                            <th>UK</th>
                            <th>IT</th>
                        </tr>
                    </thead>
                    <tbody id="table-body"> </tbody>
                </table>
            </div>
        </div>

        <div class="info-banner premium">
            <i class="mdi mdi-lightbulb-on"></i>
            <div>
                <strong>Pro Tip:</strong> Las tallas de ropa varían significativamente entre marcas.
                Siempre revisa la tabla específica de la tienda antes de comprar.
            </div>
        </div>
    </div>
</div>

<script>
    type SizeData = Record<string, string>;

    const CAMISETAS_MEN: SizeData[] = [
        { EU: "XS", US: "XS", UK: "XS", IT: "36" },
        { EU: "S", US: "S", UK: "S", IT: "38" },
        { EU: "M", US: "M", UK: "M", IT: "40" },
        { EU: "L", US: "L", UK: "L", IT: "42" },
        { EU: "XL", US: "XL", UK: "XL", IT: "44" },
        { EU: "XXL", US: "XXL", UK: "XXL", IT: "46" },
    ];

    const CAMISETAS_WOMEN: SizeData[] = [
        { EU: "XS", US: "XS", UK: "XS", IT: "32" },
        { EU: "S", US: "S", UK: "S", IT: "34" },
        { EU: "M", US: "M", UK: "M", IT: "36" },
        { EU: "L", US: "L", UK: "L", IT: "38" },
        { EU: "XL", US: "XL", UK: "XL", IT: "40" },
        { EU: "XXL", US: "XXL", UK: "XXL", IT: "42" },
    ];

    const CAMISETAS_UNISEX: SizeData[] = [
        { EU: "XS", US: "XS", UK: "XS", IT: "34" },
        { EU: "S", US: "S", UK: "S", IT: "36" },
        { EU: "M", US: "M", UK: "M", IT: "38" },
        { EU: "L", US: "L", UK: "L", IT: "40" },
        { EU: "XL", US: "XL", UK: "XL", IT: "42" },
        { EU: "XXL", US: "XXL", UK: "XXL", IT: "44" },
    ];

    const PANTALONES_MEN: SizeData[] = [
        { EU: "30", US: "30", UK: "30", IT: "44" },
        { EU: "32", US: "32", UK: "32", IT: "46" },
        { EU: "34", US: "34", UK: "34", IT: "48" },
        { EU: "36", US: "36", UK: "36", IT: "50" },
        { EU: "38", US: "38", UK: "38", IT: "52" },
        { EU: "40", US: "40", UK: "40", IT: "54" },
    ];

    const PANTALONES_WOMEN: SizeData[] = [
        { EU: "32", US: "0", UK: "4", IT: "36" },
        { EU: "34", US: "2", UK: "6", IT: "38" },
        { EU: "36", US: "4", UK: "8", IT: "40" },
        { EU: "38", US: "6", UK: "10", IT: "42" },
        { EU: "40", US: "8", UK: "12", IT: "44" },
        { EU: "42", US: "10", UK: "14", IT: "46" },
    ];

    const VESTIDOS_WOMEN: SizeData[] = [
        { EU: "XS", US: "0-2", UK: "4-6", IT: "32-34" },
        { EU: "S", US: "4-6", UK: "8-10", IT: "36-38" },
        { EU: "M", US: "8-10", UK: "12-14", IT: "40-42" },
        { EU: "L", US: "12-14", UK: "16-18", IT: "44-46" },
        { EU: "XL", US: "16-18", UK: "20-22", IT: "48-50" },
    ];

    const VESTIDOS_MEN: SizeData[] = [
        { EU: "XS", US: "XS", UK: "XS", IT: "36" },
        { EU: "S", US: "S", UK: "S", IT: "38" },
        { EU: "M", US: "M", UK: "M", IT: "40" },
        { EU: "L", US: "L", UK: "L", IT: "42" },
    ];

    const CHAQUETAS_MEN: SizeData[] = [
        { EU: "XS", US: "XS", UK: "XS", IT: "44" },
        { EU: "S", US: "S", UK: "S", IT: "46" },
        { EU: "M", US: "M", UK: "M", IT: "48" },
        { EU: "L", US: "L", UK: "L", IT: "50" },
        { EU: "XL", US: "XL", UK: "XL", IT: "52" },
    ];

    const CHAQUETAS_WOMEN: SizeData[] = [
        { EU: "XS", US: "XS", UK: "XS", IT: "32" },
        { EU: "S", US: "S", UK: "S", IT: "34" },
        { EU: "M", US: "M", UK: "M", IT: "36" },
        { EU: "L", US: "L", UK: "L", IT: "38" },
        { EU: "XL", US: "XL", UK: "XL", IT: "40" },
    ];

    const DATA_MAP: Record<string, Record<string, SizeData[]>> = {
        camisetas: { men: CAMISETAS_MEN, women: CAMISETAS_WOMEN, unisex: CAMISETAS_UNISEX },
        pantalones: { men: PANTALONES_MEN, women: PANTALONES_WOMEN, unisex: [] },
        vestidos: { women: VESTIDOS_WOMEN, men: VESTIDOS_MEN, unisex: [] },
        chaquetas: { men: CHAQUETAS_MEN, women: CHAQUETAS_WOMEN, unisex: [] },
    };

    const categoryBtns = document.querySelectorAll(".category-btn");
    const genderBtns = document.querySelectorAll(".gender-btn");
    const tabBtns = document.querySelectorAll(".tab-btn");
    const regionSelect = document.getElementById("region-select") as HTMLSelectElement | null;
    const sizeSelect = document.getElementById("size-select") as HTMLSelectElement | null;
    const quickGrid = document.getElementById("quick-grid");
    const tableBody = document.getElementById("table-body");
    const recommendBtn = document.getElementById("recommend-btn");
    const recommendationBox = document.getElementById("recommendation-box");
    const recommendationText = document.getElementById("recommendation-text");

    const resultVal1 = document.getElementById("val-1");
    const resultVal2 = document.getElementById("val-2");
    const resultVal3 = document.getElementById("val-3");

    let currentCategory = "camisetas";
    let currentGender = "men";

    function updateControls() {
        if (!regionSelect || !sizeSelect || !quickGrid || !tableBody) return;

        const data = DATA_MAP[currentCategory]?.[currentGender] || [];
        const region = regionSelect.value;

        sizeSelect.innerHTML = "";
        data.forEach((item) => {
            const opt = document.createElement("option");
            opt.value = item[region];
            opt.textContent = item[region];
            sizeSelect.appendChild(opt);
        });

        quickGrid.innerHTML = "";
        data.forEach((item) => {
            const cell = document.createElement("div");
            cell.className = "size-cell";
            cell.textContent = item.EU;
            cell.addEventListener("click", () => {
                regionSelect.value = "EU";
                sizeSelect.value = item.EU;
                calculate();
            });
            quickGrid.appendChild(cell);
        });

        tableBody.innerHTML = "";
        data.forEach((item) => {
            const row = document.createElement("tr");
            row.innerHTML = `
                <td class="eu-cell">${item.EU}</td>
                <td>${item.US}</td>
                <td>${item.UK}</td>
                <td>${item.IT}</td>
            `;
            tableBody.appendChild(row);
        });

        calculate();
    }

    function calculate() {
        if (!regionSelect || !sizeSelect || !resultVal1 || !resultVal2 || !resultVal3) return;

        const region = regionSelect.value;
        const val = sizeSelect.value;
        const data = DATA_MAP[currentCategory]?.[currentGender] || [];

        const match = data.find((item) => item[region] === val);
        if (!match) return;

        document.querySelectorAll(".size-cell").forEach((cell) => {
            cell.classList.toggle("active", cell.textContent === match.EU);
        });

        document.querySelectorAll(".eu-cell").forEach((cell) => {
            cell.classList.toggle("active", cell.textContent === match.EU);
        });

        const mapping: Record<string, string> = {
            EU: "Europa",
            US: "Estados Unidos",
            UK: "Reino Unido",
            IT: "Italia",
        };

        const keys = Object.keys(match).filter((k) => k !== region);

        [resultVal1, resultVal2, resultVal3].forEach((el, i) => {
            const key = keys[i];
            const labelEl = document.getElementById(`label-${i + 1}`);
            if (labelEl) labelEl.textContent = mapping[key] || "-";
            el.textContent = match[key] || "-";
        });
    }

    function recommendSize() {
        const chestInput = document.getElementById("chest-input") as HTMLInputElement;
        const waistInput = document.getElementById("waist-input") as HTMLInputElement;
        const hipInput = document.getElementById("hip-input") as HTMLInputElement;

        const chest = chestInput.value ? parseFloat(chestInput.value) : null;
        const waist = waistInput.value ? parseFloat(waistInput.value) : null;
        const hip = hipInput.value ? parseFloat(hipInput.value) : null;

        if (chest === null || waist === null || hip === null) {
            if (recommendationBox && recommendationText) {
                recommendationBox.style.display = "block";
                recommendationText.innerHTML =
                    '<span style="color: #dc2626;">❌ Por favor completa todas las medidas para obtener una recomendación</span>';
            }
            return;
        }

        const data = DATA_MAP[currentCategory]?.[currentGender] || [];
        if (!data || data.length === 0) {
            if (recommendationBox && recommendationText) {
                recommendationBox.style.display = "block";
                recommendationText.innerHTML =
                    '<span style="color: #dc2626;">No hay datos disponibles para esta categoría</span>';
            }
            return;
        }

        const measurementRanges: Record<
            string,
            Array<{ size: string; chest: number; waist: number; hip: number }>
        > = {
            camisetas: [
                { size: "XS", chest: 84, waist: 76, hip: 84 },
                { size: "S", chest: 92, waist: 84, hip: 92 },
                { size: "M", chest: 100, waist: 92, hip: 100 },
                { size: "L", chest: 108, waist: 100, hip: 108 },
                { size: "XL", chest: 116, waist: 108, hip: 116 },
                { size: "XXL", chest: 124, waist: 116, hip: 124 },
            ],
            pantalones: [
                { size: "30", chest: 80, waist: 76, hip: 89 },
                { size: "32", chest: 85, waist: 81, hip: 94 },
                { size: "34", chest: 90, waist: 86, hip: 99 },
                { size: "36", chest: 95, waist: 91, hip: 104 },
                { size: "38", chest: 100, waist: 96, hip: 109 },
                { size: "40", chest: 105, waist: 101, hip: 114 },
            ],
            vestidos: [
                { size: "XS", chest: 80, waist: 72, hip: 88 },
                { size: "S", chest: 88, waist: 80, hip: 96 },
                { size: "M", chest: 96, waist: 88, hip: 104 },
                { size: "L", chest: 104, waist: 96, hip: 112 },
                { size: "XL", chest: 112, waist: 104, hip: 120 },
            ],
            chaquetas: [
                { size: "XS", chest: 84, waist: 76, hip: 88 },
                { size: "S", chest: 92, waist: 84, hip: 96 },
                { size: "M", chest: 100, waist: 92, hip: 104 },
                { size: "L", chest: 108, waist: 100, hip: 112 },
                { size: "XL", chest: 116, waist: 108, hip: 120 },
            ],
        };

        const ranges = measurementRanges[currentCategory] || [];

        let bestMatch = ranges[0];
        let bestScore = Infinity;

        ranges.forEach((range) => {
            const chestDiff = Math.abs(chest - range.chest);
            const waistDiff = Math.abs(waist - range.waist);
            const hipDiff = Math.abs(hip - range.hip);
            const score = chestDiff + waistDiff + hipDiff;

            if (score < bestScore) {
                bestScore = score;
                bestMatch = range;
            }
        });

        const sizeData = data.find((item) => item.EU === bestMatch.size);

        if (!sizeData) {
            if (recommendationBox && recommendationText) {
                recommendationBox.style.display = "block";
                recommendationText.innerHTML = `<span>Basado en tus medidas: Pecho ${chest}cm, Cintura ${waist}cm, Cadera ${hip}cm</span>`;
            }
            return;
        }

        if (recommendationBox && recommendationText) {
            recommendationBox.style.display = "block";

            recommendationText.innerHTML = `
                <span style="font-weight: 600; display: block; margin-bottom: 0.5rem;">
                    Te recomendamos la talla: <span style="color: #10b981; font-size: 1.2em;">${bestMatch.size}</span>
                </span>
                <span style="font-size: 0.9em; opacity: 0.9;">Basado en tus medidas: Pecho ${chest}cm, Cintura ${waist}cm, Cadera ${hip}cm</span>
            `;

            const sizeDetailsEl = document.getElementById("size-details");
            if (sizeDetailsEl) {
                sizeDetailsEl.innerHTML = `
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(16, 185, 129, 0.3);">
                        <div style="text-align: center;">
                            <span style="font-size: 0.75rem; opacity: 0.7; text-transform: uppercase; display: block; margin-bottom: 0.25rem;">EU</span>
                            <span style="font-weight: 700; color: #10b981;">${sizeData.EU}</span>
                        </div>
                        <div style="text-align: center;">
                            <span style="font-size: 0.75rem; opacity: 0.7; text-transform: uppercase; display: block; margin-bottom: 0.25rem;">US</span>
                            <span style="font-weight: 700; color: #10b981;">${sizeData.US}</span>
                        </div>
                        <div style="text-align: center;">
                            <span style="font-size: 0.75rem; opacity: 0.7; text-transform: uppercase; display: block; margin-bottom: 0.25rem;">UK</span>
                            <span style="font-weight: 700; color: #10b981;">${sizeData.UK}</span>
                        </div>
                    </div>
                `;
            }
        }
    }

    categoryBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            categoryBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            currentCategory = (btn as HTMLElement).dataset.category || "camisetas";
            currentGender = "men";
            genderBtns.forEach((b) => b.classList.remove("active"));
            (genderBtns[0] as HTMLElement).classList.add("active");
            updateControls();
        });
    });

    genderBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            genderBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            currentGender = (btn as HTMLElement).dataset.gender || "men";
            updateControls();
        });
    });

    tabBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const tabName = (btn as HTMLElement).dataset.tab;
            tabBtns.forEach((b) => b.classList.remove("active"));
            document.querySelectorAll(".tab-content").forEach((content) => {
                (content as HTMLElement).classList.remove("active");
            });
            btn.classList.add("active");
            const tabContent = document.getElementById(`${tabName}-tab`);
            if (tabContent) tabContent.classList.add("active");
        });
    });

    regionSelect?.addEventListener("change", updateControls);
    sizeSelect?.addEventListener("change", calculate);
    recommendBtn?.addEventListener("click", recommendSize);

    const fitCards = document.querySelectorAll(".fit-card");
    const fitNotification = document.getElementById("fit-notification");
    const fitInfoText = document.getElementById("fit-info-text");

    const fitAdviceMap: Record<string, string> = {
        small: "subir una talla",
        regular: "mantener tu talla habitual",
        large: "bajar una talla",
    };

    fitCards.forEach((card) => {
        (card as HTMLElement).addEventListener("click", () => {
            fitCards.forEach((c) => (c as HTMLElement).classList.remove("active"));
            (card as HTMLElement).classList.add("active");

            const brand = (card as HTMLElement).dataset.brand;
            const fit = (card as HTMLElement).dataset.fit;

            if (fitNotification && brand && fit) {
                (document.getElementById("selected-brand") as HTMLElement).textContent =
                    brand.charAt(0).toUpperCase() + brand.slice(1);
                (document.getElementById("fit-type") as HTMLElement).textContent =
                    fit === "small" ? "pequeño" : fit === "large" ? "grande" : "regular";
                (document.getElementById("fit-advice") as HTMLElement).textContent =
                    fitAdviceMap[fit] || "mantener tu talla habitual";
                fitNotification.style.display = "block";
                fitNotification.classList.add("animate");

                if (fitInfoText) {
                    fitInfoText.innerHTML = `
                        <i class="mdi mdi-check-circle"></i>
                        ${brand.charAt(0).toUpperCase() + brand.slice(1)} seleccionada. Selecciona otra marca para comparar.
                    `;
                }
            }
        });
    });

    updateControls();
</script>
