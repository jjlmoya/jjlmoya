---
import { Icon } from "astro-icon/components";
import "./ExcelCsvToHtmlTable.css";
---

<div class="excel-html-container">
    <div class="converter-card animate-in fade-in slide-in-from-bottom duration-700">
        <div class="input-grid">
            <div class="input-group">
                <label class="input-label" for="csvInput">Pega tu CSV aquí</label>
                <textarea 
                    id="csvInput" 
                    class="csv-textarea" 
                    placeholder="Nombre,Edad,Ciudad&#10;Juan,25,Madrid&#10;Ana,30,Barcelona"
                ></textarea>
            </div>
            <div class="input-group">
                <label class="input-label">O sube tu archivo (CSV)</label>
                <div class="drop-zone" id="dropZone">
                    <Icon name="mdi:cloud-upload-outline" size={48} />
                    <span>Arrastra y suelta tu archivo aquí</span>
                    <input type="file" id="fileInput" accept=".csv" style="display: none" />
                </div>
            </div>
        </div>

        <div class="options-row">
            <label class="option-item">
                <input type="checkbox" id="hasHeader" checked />
                <span>Primera fila como encabezado</span>
            </label>
            <label class="option-item">
                <input type="checkbox" id="addBorders" />
                <span>Añadir bordes</span>
            </label>
            <label class="option-item">
                <input type="checkbox" id="zebraStripes" checked />
                <span>Filas cebra</span>
            </label>
        </div>
    </div>

    <div class="results-section animate-in fade-in slide-in-from-bottom duration-700 delay-200">
        <div class="result-tabs">
            <button class="tab-btn active" data-tab="preview">Previsualización</button>
            <button class="tab-btn" data-tab="code">Código HTML</button>
        </div>

        <div id="previewTab" class="tab-content">
            <div class="preview-container" id="previewOutput">
                <div class="empty-state">
                    <Icon name="mdi:table-off" size={48} />
                    <p>Introduce datos para ver la tabla</p>
                </div>
            </div>
        </div>

        <div id="codeTab" class="tab-content" style="display: none;">
            <div class="code-container">
                <textarea id="htmlOutput" class="code-textarea" readonly></textarea>
                <button id="copyBtn" class="copy-btn">
                    <Icon name="mdi:content-copy" />
                    Copiar Código
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const csvInput = document.getElementById('csvInput') as HTMLTextAreaElement;
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const hasHeader = document.getElementById('hasHeader') as HTMLInputElement;
    const addBorders = document.getElementById('addBorders') as HTMLInputElement;
    const zebraStripes = document.getElementById('zebraStripes') as HTMLInputElement;
    const previewOutput = document.getElementById('previewOutput');
    const htmlOutput = document.getElementById('htmlOutput') as HTMLTextAreaElement;
    const copyBtn = document.getElementById('copyBtn');
    const tabs = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    function parseCSV(text: string) {
        if (!text.trim()) return [];
        
        const lines = text.trim().split(/\r\n|\n/);
        return lines.map(line => {
            const values: string[] = [];
            let current = '';
            let inQuotes = false;
            
            for (let i = 0; i < line.length; i++) {
                const char = line[i];
                if (char === '"') {
                    inQuotes = !inQuotes;
                } else if (char === ',' && !inQuotes) {
                    values.push(current.trim());
                    current = '';
                } else {
                    current += char;
                }
            }
            values.push(current.trim());
            return values.map(v => v.replace(/^"|"$/g, '').replace(/""/g, '"'));
        });
    }

    function generateHTML(data: string[][]) {
        if (data.length === 0) return '';

        let html = '<table';
        const classes = [];
        if (addBorders.checked) classes.push('bordered');
        if (zebraStripes.checked) classes.push('zebra');
        
        if (classes.length > 0) {
            html += ` class="${classes.join(' ')}"`;
        }
        html += '>\n';

        let startIndex = 0;
        if (hasHeader.checked && data.length > 0) {
            html += '  <thead>\n    <tr>\n';
            data[0].forEach(cell => {
                html += `      <th>${cell}</th>\n`;
            });
            html += '    </tr>\n  </thead>\n';
            startIndex = 1;
        }

        html += '  <tbody>\n';
        for (let i = startIndex; i < data.length; i++) {
            html += '    <tr>\n';
            data[i].forEach(cell => {
                html += `      <td>${cell}</td>\n`;
            });
            html += '    </tr>\n';
        }
        html += '  </tbody>\n</table>';

        return html;
    }

    function update() {
        const text = csvInput.value;
        const data = parseCSV(text);
        const html = generateHTML(data);
        
        if (html) {
            if (previewOutput) previewOutput.innerHTML = html;
            htmlOutput.value = html;
        } else {
            if (previewOutput) {
                previewOutput.innerHTML = `
                    <div class="empty-state">
                        <Icon name="mdi:table-off" size={48} />
                        <p>Introduce datos para ver la tabla</p>
                    </div>
                `;
            }
            htmlOutput.value = '';
        }
    }

    csvInput.addEventListener('input', update);
    [hasHeader, addBorders, zebraStripes].forEach(el => el.addEventListener('change', update));

    dropZone?.addEventListener('click', () => fileInput.click());
    
    dropZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
    });

    dropZone?.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
    });

    dropZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        const file = e.dataTransfer?.files[0];
        if (file) handleFile(file);
    });

    fileInput.addEventListener('change', (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) handleFile(file);
    });

    function handleFile(file: File) {
        const reader = new FileReader();
        reader.onload = (e) => {
            const text = e.target?.result as string;
            csvInput.value = text;
            update();
        };
        reader.readAsText(file);
    }

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            
            const target = (tab as HTMLElement).dataset.tab;
            tabContents.forEach(content => {
                if (content.id === `${target}Tab`) {
                    (content as HTMLElement).style.display = 'block';
                } else {
                    (content as HTMLElement).style.display = 'none';
                }
            });
        });
    });

    copyBtn?.addEventListener('click', () => {
        navigator.clipboard.writeText(htmlOutput.value);
        const originalText = copyBtn.innerHTML;
        copyBtn.innerHTML = '<Icon name="mdi:check" /> ¡Copiado!';
        setTimeout(() => {
            copyBtn.innerHTML = originalText;
        }, 2000);
    });
</script>

<style is:global>
    table.bordered {
        border: 1px solid #e2e8f0;
    }
    table.bordered th, table.bordered td {
        border: 1px solid #e2e8f0;
    }
    :global(.dark) table.bordered, :global(.dark) table.bordered th, :global(.dark) table.bordered td {
        border-color: #334155;
    }
    
    table.zebra tbody tr:nth-child(even) {
        background: #f8fafc;
    }
    :global(.dark) table.zebra tbody tr:nth-child(even) {
        background: rgba(30, 41, 59, 0.5);
    }
</style>
