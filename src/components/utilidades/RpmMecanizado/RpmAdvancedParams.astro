---
import { Icon } from 'astro-icon/components';
---

<div class="mt-2">
  <div class="rpm-adv-toggle" id="adv-trigger">
    <div class="flex items-center gap-2">
      <Icon name="mdi:cog-outline" class="w-5 h-5 text-indigo-500" />
      <span>Parámetros de Avance (Fz)</span>
    </div>
    <Icon name="mdi:chevron-down" id="adv-chevron" class="w-4 h-4 transition-transform" />
  </div>
  <div class="rpm-adv-content" id="adv-body">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="rpm-field-label">Nº de Filos (z)</label>
        <input type="number" id="lips-in" class="input-premium" value="2" min="1" max="12" />
      </div>
      <div>
        <label class="rpm-field-label">Avance/diente (Fz)</label>
        <input type="number" id="fz-in" class="input-premium" placeholder="0.1" step="0.01" value="0.1" />
      </div>
    </div>
  </div>
</div>
