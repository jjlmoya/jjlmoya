---
import { Icon } from 'astro-icon/components';
import './RpmMecanizado.css';
import MaterialSelect from './RpmMaterialSelect.astro';
import ToolToggle from './RpmToolToggle.astro';
import DiameterInput from './RpmDiameterInput.astro';
import AdvancedParams from './RpmAdvancedParams.astro';
import ResultsHero from './RpmResultsHero.astro';
import MachineSettings from './RpmMachineSettings.astro';

const materials = [
  { id: 'steel', vcHss: 25, vcCarbide: 100, icon: 'mdi:hammer', cool: 'mdi:water-outline', coolTxt: 'Taladrina o Aceite', fz: 0.1, name: 'Acero Suave' },
  { id: 'inox', vcHss: 12, vcCarbide: 55, icon: 'mdi:shield', cool: 'mdi:opacity', coolTxt: 'Aceite de Corte EP', fz: 0.05, name: 'Inoxidable' },
  { id: 'alu', vcHss: 120, vcCarbide: 400, icon: 'mdi:airplane', cool: 'mdi:flask-outline', coolTxt: 'Alcohol / Parafina', fz: 0.15, name: 'Aluminio' },
  { id: 'brass', vcHss: 70, vcCarbide: 220, icon: 'mdi:circle', cool: 'mdi:close-circle-outline', coolTxt: 'En seco / Aire', fz: 0.1, name: 'Latón' },
  { id: 'castiron', vcHss: 18, vcCarbide: 80, icon: 'mdi:cube-outline', cool: 'mdi:close-circle-outline', coolTxt: 'En seco', fz: 0.2, name: 'Fundición' },
  { id: 'wood', vcHss: 200, vcCarbide: 500, icon: 'mdi:pine-tree', cool: 'mdi:weather-windy', coolTxt: 'Solo Aspiración', fz: 0.3, name: 'Maderas' },
  { id: 'plastic', vcHss: 50, vcCarbide: 150, icon: 'mdi:flask', cool: 'mdi:weather-windy', coolTxt: 'Chorro de Aire', fz: 0.15, name: 'Plásticos' },
];
---

<div class="rpm-calculator-wrapper">
  <div class="rpm-container-card animate-in-up">
    <div class="rpm-main-grid">
      
      <div class="rpm-left-panel">
        <MaterialSelect materials={materials} />
        <ToolToggle />
        <DiameterInput />


        <div class="flex items-center justify-between p-3 bg-slate-100 dark:bg-slate-800/50 rounded-xl">
          <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Modo Taladro Columna</span>
          <div class="rpm-switch-input" id="limit-toggle"></div>
        </div>

        <AdvancedParams />
      </div>


      <div class="rpm-right-panel">
        <ResultsHero />

        <div class="rpm-results-grid">
          <div class="rpm-data-tile">
            <div class="rpm-tile-icon">
              <Icon name="mdi:information-variant" class="w-6 h-6" />
            </div>
            <div class="rpm-tile-content">
              <span class="rpm-tile-label">Refrigeración</span>
              <span class="rpm-tile-value" id="cool-txt">Taladrina</span>
            </div>
          </div>

          <div class="rpm-data-tile">
            <div class="rpm-tile-icon">
              <Icon name="mdi:speedometer" class="w-6 h-6" />
            </div>
            <div class="rpm-tile-content">
              <span class="rpm-tile-label">Avance Resultante</span>
              <span class="rpm-tile-value" id="feed-txt">-- mm/min</span>
            </div>
          </div>
        </div>

        <MachineSettings />
      </div>

    </div>
  </div>
</div>

<script>
  const materials = [
    { id: 'steel', vcHss: 25, vcCarbide: 100, coolTxt: 'Taladrina o Aceite', fz: 0.1 },
    { id: 'inox', vcHss: 12, vcCarbide: 55, coolTxt: 'Aceite de Corte EP', fz: 0.05 },
    { id: 'alu', vcHss: 120, vcCarbide: 400, coolTxt: 'Alcohol / Parafina', fz: 0.15 },
    { id: 'brass', vcHss: 70, vcCarbide: 220, coolTxt: 'En seco / Aire', fz: 0.1 },
    { id: 'castiron', vcHss: 18, vcCarbide: 80, coolTxt: 'En seco', fz: 0.2 },
    { id: 'wood', vcHss: 200, vcCarbide: 500, coolTxt: 'Solo Aspiración', fz: 0.3 },
    { id: 'plastic', vcHss: 50, vcCarbide: 150, coolTxt: 'Chorro de Aire', fz: 0.15 },
  ];

  let currentMat = 'steel';
  let currentType = 'hss';
  let isLimited = false;
  let currentUnit = 'mm';
  let machineSpeeds: number[] = [];


  const slider = document.getElementById('diam-slider') as HTMLInputElement;
  const diamDisplay = document.getElementById('diam-val-display');
  const unitToggle = document.getElementById('unit-toggle');
  const lipsIn = document.getElementById('lips-in') as HTMLInputElement;
  const fzIn = document.getElementById('fz-in') as HTMLInputElement;
  const rpmOut = document.getElementById('rpm-out');
  const rotVisual = document.getElementById('rot-visual');
  const limitToggle = document.getElementById('limit-toggle');
  const statusBadge = document.getElementById('status-badge');
  const impossWarn = document.getElementById('imposs-warn');
  const coolTxt = document.getElementById('cool-txt');
  const feedOut = document.getElementById('feed-txt');
  const closestBox = document.getElementById('closest-box');
  const closestVal = document.getElementById('closest-val');
  const advTrigger = document.getElementById('adv-trigger');
  const advBody = document.getElementById('adv-body');
  const advChevron = document.getElementById('adv-chevron');

  function calculate() {
    const mat = materials.find(m => m.id === currentMat);
    if (!mat) return;


    let diameter = parseFloat(slider.value);
    if (currentUnit === 'in') diameter = diameter * 25.4;

    const vc = currentType === 'hss' ? mat.vcHss : mat.vcCarbide;
    const rpm = (vc * 1000) / (Math.PI * diameter);
    const idealRpm = Math.round(rpm);
    
    const maxAvailable = machineSpeeds.length > 0 ? Math.max(...machineSpeeds) : 2500;
    
    let displayRpm = idealRpm;
    if (isLimited && idealRpm > maxAvailable) {
      displayRpm = maxAvailable;
      statusBadge?.classList.remove('hidden');
    } else {
      statusBadge?.classList.add('hidden');
    }


    if (idealRpm > 15000) impossWarn?.classList.remove('hidden');
    else impossWarn?.classList.add('hidden');

    if (rpmOut) {
      rpmOut.textContent = displayRpm.toString();
      rpmOut.className = 'rpm-number';
      const currentMax = machineSpeeds.length > 0 ? Math.max(...machineSpeeds) : 2500;
      if (isLimited && idealRpm > currentMax) rpmOut.classList.add('danger');
      else if (idealRpm < 500) rpmOut.classList.add('slow');
      else rpmOut.classList.add('opt');
    }


    if (rotVisual) {
      const dur = Math.max(0.04, 60 / Math.max(1, displayRpm));
      rotVisual.style.animationDuration = `${dur}s`;
      rotVisual.style.animationPlayState = displayRpm > 0 ? 'running' : 'paused';
    }

    if (coolTxt) coolTxt.textContent = `Refrigeración: ${mat.coolTxt}`;
    

    const fz = parseFloat(fzIn.value) || mat.fz;
    const lips = parseInt(lipsIn.value) || 2;
    if (feedOut) {
      feedOut.textContent = `${Math.round(displayRpm * fz * lips)} mm/min`;
    }


    if (machineSpeeds.length > 0 && closestVal && closestBox) {
      const best = machineSpeeds.reduce((p, c) => Math.abs(c - displayRpm) < Math.abs(p - displayRpm) ? c : p);
      closestVal.textContent = `${best} RPM`;
      

      const diffPercent = (Math.abs(best - displayRpm) / displayRpm) * 100;
      if (diffPercent > 20) {
        closestVal.style.color = 'var(--rpm-danger)';
      } else {
        closestVal.style.color = 'var(--rpm-accent)';
      }
      
      closestBox.classList.remove('hidden');
    } else if (closestBox) {
      closestBox.classList.add('hidden');
    }
  }


  document.querySelectorAll('.rpm-mat-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.rpm-mat-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      currentMat = (chip as HTMLElement).dataset.id || 'steel';
      const mat = materials.find(m => m.id === currentMat);
      if (mat) fzIn.value = mat.fz.toString();
      calculate();
    });
  });


  document.querySelectorAll('.rpm-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if ((btn as HTMLElement).id === 'add-speed-btn') return;
      document.querySelectorAll('.rpm-toggle-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentType = (btn as HTMLElement).dataset.type || 'hss';
      calculate();
    });
  });


  unitToggle?.querySelectorAll('.rpm-unit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      unitToggle?.querySelectorAll('.rpm-unit-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const newUnit = (btn as HTMLElement).dataset.unit || 'mm';
      if (newUnit !== currentUnit) {
        let val = parseFloat(slider.value);
        if (newUnit === 'in') {
          val = val / 25.4;
          slider.min = "0.02"; slider.max = "2"; slider.step = "0.01";
        } else {
          val = val * 25.4;
          slider.min = "0.5"; slider.max = "50"; slider.step = "0.5";
        }
        currentUnit = newUnit;
        slider.value = val.toFixed(newUnit === 'in' ? 2 : 1);
        if (diamDisplay) diamDisplay.textContent = `${slider.value} ${currentUnit}`;
      }
      calculate();
    });
  });

  slider.addEventListener('input', () => {
    if (diamDisplay) diamDisplay.textContent = `${slider.value} ${currentUnit}`;
    calculate();
  });

  [lipsIn, fzIn].forEach(i => i.addEventListener('input', calculate));

  limitToggle?.addEventListener('click', () => {
    isLimited = !isLimited;
    limitToggle.classList.toggle('active');
    calculate();
  });

  advTrigger?.addEventListener('click', () => {
    advBody?.classList.toggle('visible');
    advChevron?.classList.toggle('rotate-180');
  });

  const addBtn = document.getElementById('add-speed-btn');
  const speedIn = document.getElementById('fixed-speed-in') as HTMLInputElement;
  const chipsArea = document.getElementById('chips-area');

  const presets: Record<string, number[]> = {
    bridgeport: [120, 200, 450, 600, 800, 1100, 1500, 2000, 2500, 3000],
    chinese: [1000, 2000, 4000, 6000, 8000, 12000, 15000, 20000, 24000]
  };

  document.querySelectorAll('.rpm-preset-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = (btn as HTMLElement).dataset.preset;
      if (type && presets[type]) {
        machineSpeeds = [...presets[type]];
        document.querySelectorAll('.rpm-preset-pill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        renderChips();
        calculate();
      }
    });
  });

  addBtn?.addEventListener('click', () => {
    const val = parseInt(speedIn.value);
    if (!isNaN(val) && val > 0 && !machineSpeeds.includes(val)) {
      machineSpeeds.push(val);
      machineSpeeds.sort((a,b) => a-b);
      renderChips();
      calculate();
    }
    speedIn.value = '';
  });

  function renderChips() {
    if (!chipsArea) return;
    chipsArea.innerHTML = '';
    machineSpeeds.sort((a,b) => a-b).forEach(v => {
      const div = document.createElement('div');
      div.className = 'rpm-speed-tag';
      div.innerHTML = `<span>${v} RPM</span><button>×</button>`;
      div.querySelector('button')?.addEventListener('click', () => {
        machineSpeeds = machineSpeeds.filter(s => s !== v);
        renderChips();
        calculate();
      });
      chipsArea.appendChild(div);
    });
  }


  document.querySelector(`[data-id="${currentMat}"]`)?.classList.add('active');
  calculate();
</script>
