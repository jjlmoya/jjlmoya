---
---

<div class="field-block">
  <div class="flex justify-between items-center mb-2">
    <div class="flex items-center gap-3">
      <label class="rpm-field-label m-0">Diámetro:</label>
      <div class="rpm-unit-toggle" id="unit-toggle">
        <button class="rpm-unit-btn active" data-unit="mm">mm</button>
        <button class="rpm-unit-btn" data-unit="in">pulg</button>
      </div>
    </div>
    <span class="text-2xl font-black text-indigo-600 dark:text-indigo-400" id="diam-val-display">10.0 mm</span>
  </div>
  <div class="rpm-slider-box">
    <input type="range" id="diam-slider" class="rpm-slider-input" min="0.5" max="50" step="0.5" value="10" />
  </div>
</div>
