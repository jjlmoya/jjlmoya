---
import { Icon } from 'astro-icon/components';
---

<div class="rpm-controls-card">
  <div class="rpm-machine-group">
    <span class="rpm-field-label" style="margin-bottom: 0.5rem;">Velocidades de tu Máquina</span>
    
    <div class="rpm-machine-presets-toggle">
      <button class="rpm-preset-pill" data-preset="bridgeport">Standard</button>
      <button class="rpm-preset-pill" data-preset="chinese">CNC</button>
    </div>
    
    <div class="rpm-manual-input-unified">
      <input type="number" id="fixed-speed-in" class="rpm-input-manual" placeholder="Añadir RPM manual..." />
      <button id="add-speed-btn" class="rpm-add-btn">
        <Icon name="mdi:plus" class="w-6 h-6" />
      </button>
    </div>
  </div>

  <div id="chips-area" class="rpm-speed-belt"></div>
  
  <div id="closest-box" class="hidden rpm-match-container">
    <div class="rpm-match-header">
      <Icon name="mdi:check-circle-outline" class="w-4 h-4 text-emerald-500" />
      <span class="rpm-match-label">Ajuste recomendado</span>
    </div>
    <div class="rpm-match-value" id="closest-val">--00</div>
    <p class="rpm-match-hint">Configura el selector de tu máquina a esta posición</p>
  </div>
</div>
