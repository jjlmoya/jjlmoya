---
import { Icon } from 'astro-icon/components';
---

<div class="rpm-hero-display">
  <span class="rpm-unit-label">Velocidad Óptima</span>
  <div class="rpm-number opt" id="rpm-out">0</div>
  <span class="rpm-unit-label">Revoluciones / Minuto</span>
  
  <div class="rpm-rotation-visual" id="rot-visual"></div>
  
  <div class="flex flex-col items-center gap-2 mt-2 min-h-[50px]">
    <div id="status-badge" class="hidden rpm-warning-badge">
      <Icon name="mdi:alert-circle-outline" class="w-4 h-4" />
      <span>Límite de máquina activo</span>
    </div>
    <div id="imposs-warn" class="hidden flex items-center gap-1 text-[10px] font-black text-amber-600 uppercase">
      <Icon name="mdi:alert-outline" class="w-3 h-3" />
      <span>Rango fuera de estándar comercial</span>
    </div>
  </div>
</div>
