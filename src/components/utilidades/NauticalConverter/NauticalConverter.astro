---
import "./NauticalConverter.css";
---

<div id="nautical-converter" class="nautical-converter">
  <button id="contrast-toggle" class="contrast-toggle">Modo Alto Contraste: OFF</button>
  
  <div class="category-tabs" role="tablist">
    <button class="tab-btn active" data-category="distance" role="tab" aria-selected="true" aria-controls="distance-panel">
      <iconify-icon icon="mdi:map-marker-distance"></iconify-icon>
      Millas y Km
    </button>
    <button class="tab-btn" data-category="speed" role="tab" aria-selected="false" aria-controls="speed-panel">
      <iconify-icon icon="mdi:speedometer"></iconify-icon>
      Velocidad
    </button>
    <button class="tab-btn" data-category="depth" role="tab" aria-selected="false" aria-controls="depth-panel">
      <iconify-icon icon="mdi:anchor"></iconify-icon>
      Profundidad
    </button>
    <button class="tab-btn" data-category="pressure" role="tab" aria-selected="false" aria-controls="pressure-panel">
      <iconify-icon icon="mdi:weather-partly-cloudy"></iconify-icon>
      Presión
    </button>
  </div>

  <div id="converter-content" class="section-content">
    
    <div id="distance-grid" class="input-grid category-panel active" role="tabpanel">
      <div class="input-group">
        <label for="nm">Milla Náutica (nm)</label>
        <div class="input-wrapper">
          <input type="number" id="nm" placeholder="0" inputmode="decimal">
          <button class="copy-btn" data-for="nm" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="km">Kilómetros (km)</label>
        <div class="input-wrapper">
          <input type="number" id="km" placeholder="0" inputmode="decimal">
          <button class="copy-btn" data-for="km" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="mi">Milla Terrestre (mi)</label>
        <div class="input-wrapper">
          <input type="number" id="mi" placeholder="0" inputmode="decimal">
          <button class="copy-btn" data-for="mi" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="cable">Cables</label>
        <div class="input-wrapper">
          <input type="number" id="cable" placeholder="0" inputmode="decimal">
          <button class="copy-btn" data-for="cable" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
    </div>

    <div id="speed-grid" class="category-panel" style="display: none;" role="tabpanel">
      <div class="input-grid">
        <div class="input-group">
          <label for="kn">Nudos (kn)</label>
          <div class="input-wrapper">
            <input type="number" id="kn" placeholder="0" inputmode="decimal">
            <button class="copy-btn" data-for="kn" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
          </div>
        </div>
        <div class="input-group">
          <label for="kmh">km/h</label>
          <div class="input-wrapper">
            <input type="number" id="kmh" placeholder="0" inputmode="decimal">
            <button class="copy-btn" data-for="kmh" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
          </div>
        </div>
        <div class="input-group">
          <label for="ms">m/s</label>
          <div class="input-wrapper">
            <input type="number" id="ms" placeholder="0" inputmode="decimal">
            <button class="copy-btn" data-for="ms" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
          </div>
        </div>
        <div class="input-group">
          <label for="mph">mph</label>
          <div class="input-wrapper">
            <input type="number" id="mph" placeholder="0" inputmode="decimal">
            <button class="copy-btn" data-for="mph" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
          </div>
        </div>
      </div>

      <div class="speed-footer">
        <div class="quick-toggles">
          <button class="toggle-btn" data-val="12" data-target="kn">12 kn (Duro)</button>
          <button class="toggle-btn" data-val="15" data-target="kn">15 kn (Fuerte)</button>
          <button class="toggle-btn" data-val="20" data-target="kn">20 kn (Riesgo)</button>
        </div>
        
        <div class="beaufort-card" id="wind-scales">
          <div class="beaufort-header">
            <h3>Estado del Mar y Viento</h3>
            <span class="beaufort-badge" id="beaufort-badge">Fuerza -</span>
          </div>
          <div class="beaufort-body">
            <div class="beaufort-item">
              <span class="label">Escala</span>
              <span class="value" id="beaufort-val">-</span>
            </div>
            <div class="beaufort-item">
              <span class="label">Efecto</span>
              <span class="value" id="sea-effect">-</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="depth-grid" class="input-grid category-panel" style="display: none;" role="tabpanel">
      <div class="input-group">
        <label for="depth-braza">Brazas</label>
        <div class="input-wrapper">
          <input type="number" id="depth-braza" placeholder="0" inputmode="decimal">
          <button class="copy-btn" data-for="depth-braza" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="depth-m">Metros (m)</label>
        <div class="input-wrapper">
          <input type="number" id="depth-m" placeholder="0" inputmode="decimal">
          <button class="copy-btn" data-for="depth-m" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="depth-ft">Pies (ft)</label>
        <div class="input-wrapper">
          <input type="number" id="depth-ft" placeholder="0" inputmode="decimal">
          <button class="copy-btn" data-for="depth-ft" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
    </div>

    <div id="pressure-grid" class="input-grid category-panel" style="display: none;" role="tabpanel">
      <div class="input-group">
        <label for="mbar">mbar / hPa</label>
        <div class="input-wrapper">
          <input type="number" id="mbar" placeholder="1013" inputmode="decimal">
          <button class="copy-btn" data-for="mbar" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="mmhg">mmHg</label>
        <div class="input-wrapper">
          <input type="number" id="mmhg" placeholder="760" inputmode="decimal">
          <button class="copy-btn" data-for="mmhg" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="inhg">inHg</label>
        <div class="input-wrapper">
          <input type="number" id="inhg" placeholder="29.92" inputmode="decimal">
          <button class="copy-btn" data-for="inhg" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
      <div class="input-group">
        <label for="atm">atm</label>
        <div class="input-wrapper">
          <input type="number" id="atm" placeholder="1" inputmode="decimal">
          <button class="copy-btn" data-for="atm" title="Copiar"><iconify-icon icon="mdi:content-copy"></iconify-icon></button>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  interface ContainerMap {
    [key: string]: HTMLElement | null;
  }

  const containers: ContainerMap = {
    distance: document.getElementById('distance-grid'),
    speed: document.getElementById('speed-grid'),
    depth: document.getElementById('depth-grid'),
    pressure: document.getElementById('pressure-grid')
  };

  interface BeaufortItem {
    limit: number;
    name: string;
    sea: string;
  }

  const beaufortScale: BeaufortItem[] = [
    { limit: 1, name: "Calma", sea: "Espejo" },
    { limit: 3, name: "Ventolina", sea: "Rizos" },
    { limit: 6, name: "Flojito", sea: "Olas pequenas" },
    { limit: 10, name: "Flojo", sea: "Ovejas blancas" },
    { limit: 16, name: "Bonancible", sea: "Olas moderadas" },
    { limit: 21, name: "Fresquito", sea: "Olas largas" },
    { limit: 27, name: "Fresco", sea: "Crestas blancas" },
    { limit: 33, name: "Frescachon", sea: "Olas grandes y espuma" },
    { limit: 40, name: "Temporal", sea: "Olas muy altas" },
    { limit: 47, name: "Fuerte temporal", sea: "Mar blanca" },
    { limit: 55, name: "Temporal duro", sea: "Visibilidad reducida" },
    { limit: 63, name: "Temporal muy duro", sea: "Mar totalmente blanca" },
    { limit: Infinity, name: "Huracan", sea: "Aire lleno de espuma" }
  ];

  function updateBeaufort(knots: number): void {
    if (isNaN(knots)) return;
    const level = beaufortScale.findIndex(b => knots <= b.limit);
    const item = level === -1 ? beaufortScale[beaufortScale.length - 1] : beaufortScale[level];
    
    const beaufortEl = document.getElementById('beaufort-val');
    const seaEl = document.getElementById('sea-effect');
    const badgeEl = document.getElementById('beaufort-badge');
    
    const force = level === -1 ? 12 : level;
    
    const cardEl = document.getElementById('wind-scales');
    if (cardEl) {
      if (knots > 0) {
        cardEl.classList.add('visible');
      } else {
        cardEl.classList.remove('visible');
      }
    }

    if (beaufortEl) beaufortEl.textContent = 'Fuerza ' + force + ' - ' + item.name;
    if (seaEl) seaEl.textContent = item.sea;
    if (badgeEl) {
      badgeEl.textContent = 'Fuerza ' + force;
      badgeEl.style.background = getBeaufortColor(force);
    }
  }

  function getBeaufortColor(force: number): string {
    if (force <= 3) return '#4caf50';
    if (force <= 5) return '#8bc34a';
    if (force <= 7) return '#ffc107';
    if (force <= 9) return '#ff9800';
    return '#f44336';
  }

  function setValue(id: string, val: number): void {
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (el && document.activeElement !== el) {
      el.value = Number(val.toFixed(4)).toString();
    }
  }

  function updateDistance(meters: number): void {
    setValue('nm', meters / 1852);
    setValue('km', meters / 1000);
    setValue('mi', meters / 1609.34);
    setValue('cable', meters / 185.2);
  }

  function updateSpeed(knots: number): void {
    setValue('kn', knots);
    setValue('kmh', knots * 1.852);
    setValue('ms', knots * 1.852 / 3.6);
    setValue('mph', knots * 1.852 / 1.60934);
    updateBeaufort(knots);
  }

  function updateDepth(meters: number): void {
    setValue('depth-braza', meters / 1.8288);
    setValue('depth-m', meters);
    setValue('depth-ft', meters / 0.3048);
  }

  function updatePressure(hpa: number): void {
    setValue('mbar', hpa);
    setValue('mmhg', hpa / 1.33322);
    setValue('inhg', hpa / 33.8639);
    setValue('atm', hpa / 1013.25);
  }

  function resetValues(sourceId: string): void {
    const inputs = document.querySelectorAll('.input-wrapper input') as NodeListOf<HTMLInputElement>;
    inputs.forEach(input => {
        if (input.id !== sourceId) {
            input.value = "";
        }
    });
    const beaufortEl = document.getElementById('beaufort-val');
    const seaEl = document.getElementById('sea-effect');
    const cardEl = document.getElementById('wind-scales');
    if (beaufortEl) beaufortEl.textContent = "-";
    if (seaEl) seaEl.textContent = "-";
    if (cardEl) cardEl.classList.remove('visible');
  }

  function convert(id: string, value: string): void {
    if (value === "") {
        resetValues(id);
        return;
    }
    const val = parseFloat(value);
    if (isNaN(val)) return;

    switch(id) {
      case 'nm': updateDistance(val * 1852); break;
      case 'km': updateDistance(val * 1000); break;
      case 'mi': updateDistance(val * 1609.34); break;
      case 'cable': updateDistance(val * 185.2); break;
      case 'kn': updateSpeed(val); break;
      case 'kmh': updateSpeed(val / 1.852); break;
      case 'ms': updateSpeed(val * 3.6 / 1.852); break;
      case 'mph': updateSpeed(val * 1.60934 / 1.852); break;
      case 'depth-braza': updateDepth(val * 1.8288); break;
      case 'depth-m': updateDepth(val); break;
      case 'depth-ft': updateDepth(val * 0.3048); break;
      case 'mbar': updatePressure(val); break;
      case 'mmhg': updatePressure(val * 1.33322); break;
      case 'inhg': updatePressure(val * 33.8639); break;
      case 'atm': updatePressure(val * 1013.25); break;
    }
  }

  const allInputs = document.querySelectorAll('.input-wrapper input') as NodeListOf<HTMLInputElement>;
  allInputs.forEach(input => {
    input.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      convert(target.id, target.value);
    });
  });

  const tabBtns = document.querySelectorAll('.tab-btn') as NodeListOf<HTMLButtonElement>;
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category;
      if (!cat) return;
      
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      Object.entries(containers).forEach(([key, el]) => {
        if (el) {
          if (key === cat) {
            el.style.display = 'grid';
            el.classList.add('active');
          } else {
            el.style.display = 'none';
            el.classList.remove('active');
          }
        }
      });
      
      localStorage.setItem('nautical-last-category', cat);
    });
  });

  const lastCat = localStorage.getItem('nautical-last-category');
  if (lastCat && containers[lastCat]) {
    const targetTab = document.querySelector('.tab-btn[data-category="' + lastCat + '"]') as HTMLButtonElement | null;
    if (targetTab) targetTab.click();
  }

  const toggleBtns = document.querySelectorAll('.toggle-btn') as NodeListOf<HTMLButtonElement>;
  toggleBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target;
      const val = btn.dataset.val;
      if (targetId && val) {
        const target = document.getElementById(targetId) as HTMLInputElement | null;
        if (target) {
          target.value = val;
          convert(target.id, target.value);
        }
      }
    });
  });

  const copyBtns = document.querySelectorAll('.copy-btn') as NodeListOf<HTMLButtonElement>;
  copyBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.for;
      if (!targetId) return;
      const input = document.getElementById(targetId) as HTMLInputElement | null;
      if (input && input.value) {
        navigator.clipboard.writeText(input.value);
        const icon = btn.querySelector('iconify-icon');
        if (icon) {
          const original = icon.getAttribute('icon') || '';
          icon.setAttribute('icon', 'mdi:check');
          setTimeout(() => icon.setAttribute('icon', original), 1500);
        }
      }
    });
  });

  const converterWrap = document.getElementById('nautical-converter');
  const contrastBtn = document.getElementById('contrast-toggle');
  if (converterWrap && contrastBtn) {
    contrastBtn.addEventListener('click', () => {
      const isHigh = converterWrap.classList.toggle('high-contrast');
      contrastBtn.textContent = isHigh ? "Modo Alto Contraste: ON" : "Modo Alto Contraste: OFF";
    });
  }
</script>
