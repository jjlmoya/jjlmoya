---
import "./DuplicateCssRemover.css";
---

<div class="dupcss-container">
    <div class="dupcss-header">
        <h2>Eliminador de CSS Duplicado</h2>
        <p>
            Limpia tus archivos de estilos unificando selectores idénticos y eliminando reglas
            redundantes para optimizar el peso.
        </p>
    </div>

    <div class="dupcss-stats" id="dupcss-stats" style="display: none;">
        <div class="dupcss-stat-item">
            <span class="dupcss-stat-value" id="stat-original">0</span>
            <span class="dupcss-stat-label">Bytes Originales</span>
        </div>
        <div class="dupcss-stat-item">
            <span class="dupcss-stat-value" id="stat-limpio" style="color: var(--dupcss-text);"
                >0</span
            >
            <span class="dupcss-stat-label">Bytes Limpios</span>
        </div>
        <div class="dupcss-stat-item">
            <span class="dupcss-stat-value" id="stat-ahorro">0%</span>
            <span class="dupcss-stat-label">De Ahorro</span>
        </div>
    </div>

    <div class="dupcss-grid">
        <div class="dupcss-form-group">
            <label for="dupcss-input" class="dupcss-label">CSS Sucio / Duplicado</label>
            <textarea
                id="dupcss-input"
                class="dupcss-textarea"
                placeholder=".btn { padding: 10px; color: red; }
.btn { margin: 5px; color: blue; }"
                spellcheck="false"></textarea>
        </div>
        <div class="dupcss-form-group">
            <label for="dupcss-output" class="dupcss-label">
                <span>CSS Limpio</span>
                <button id="dupcss-copy-btn" class="dupcss-copy-btn">Copiar Código</button>
            </label>
            <textarea
                id="dupcss-output"
                class="dupcss-textarea dupcss-output"
                readonly
                placeholder="Aquí aparecerá el CSS optimizado y unificado..."
                spellcheck="false"></textarea>
        </div>
    </div>

    <div class="dupcss-actions">
        <button id="dupcss-clean-btn" class="dupcss-button">🧹 Limpiar y Unificar CSS</button>
    </div>
</div>

<script>
    const input = document.getElementById("dupcss-input") as HTMLTextAreaElement;
    const output = document.getElementById("dupcss-output") as HTMLTextAreaElement;
    const cleanBtn = document.getElementById("dupcss-clean-btn");
    const copyBtn = document.getElementById("dupcss-copy-btn");
    const statsBlock = document.getElementById("dupcss-stats");
    const statOriginal = document.getElementById("stat-original");
    const statLimpio = document.getElementById("stat-limpio");
    const statAhorro = document.getElementById("stat-ahorro");

    function cleanCss(rawCss: string) {
        if (!rawCss.trim()) return "";

        const css = rawCss.replace(/\/\*[\s\S]*?\*\//g, "");

        const ruleRegex = /(?:[^\{\}]+)\s*\{[^\}]+\}/g;
        const matches = css.match(ruleRegex) || [];

        const stylesMap = new Map<string, Map<string, string>>();

        matches.forEach((ruleBlock) => {
            const [head, tail] = ruleBlock.split("{");
            if (!tail) return;

            const selector = head.trim().replace(/\s+/g, " ");
            const propertiesRaw = tail.replace("}", "").trim();

            if (!selector || !propertiesRaw) return;

            if (!stylesMap.has(selector)) {
                stylesMap.set(selector, new Map<string, string>());
            }
            const propMap = stylesMap.get(selector)!;

            const props = propertiesRaw.split(";");
            props.forEach((p) => {
                const parts = p.split(":");
                if (parts.length >= 2) {
                    const key = parts[0].trim();
                    const val = parts.slice(1).join(":").trim();
                    if (key && val) {
                        propMap.set(key, val);
                    }
                }
            });
        });

        let finalCss = "";
        stylesMap.forEach((propMap, selector) => {
            if (propMap.size === 0) return;

            finalCss += `${selector} {\n`;
            propMap.forEach((val, key) => {
                finalCss += `    ${key}: ${val};\n`;
            });
            finalCss += `}\n\n`;
        });

        return finalCss.trim();
    }

    if (cleanBtn && input && output && statsBlock && statOriginal && statLimpio && statAhorro) {
        cleanBtn.addEventListener("click", () => {
            const result = cleanCss(input.value);
            output.value = result;

            if (result) {
                const origBytes = new Blob([input.value]).size;
                const cleanBytes = new Blob([result]).size;
                const saving =
                    origBytes > 0 ? (((origBytes - cleanBytes) / origBytes) * 100).toFixed(1) : "0";

                statOriginal.textContent = origBytes.toString();
                statLimpio.textContent = cleanBytes.toString();
                statAhorro.textContent = `${saving}%`;
                statsBlock.style.display = "flex";
            } else {
                statsBlock.style.display = "none";
            }
        });
    }

    if (copyBtn && output) {
        copyBtn.addEventListener("click", async () => {
            if (!output.value) return;
            try {
                await navigator.clipboard.writeText(output.value);
                const old = copyBtn.textContent;
                copyBtn.textContent = "¡Copiado!";
                setTimeout(() => {
                    copyBtn.textContent = old;
                }, 2000);
            } catch (err) {
                console.error("Failed to copy", err);
            }
        });
    }
</script>
