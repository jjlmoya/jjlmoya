---
import { Icon } from "astro-icon/components";
import "./ScreenDecompressionTime.css";
---

<div class="decomp-container">
    <div class="tool-card">

        <div class="control-panel">
        <div class="slider-container">
            <div class="slider-label">
                <Icon name="mdi:monitor-eye" />
                <span>Horas mirando pantalla</span>
            </div>
            <input
                type="range"
                id="hoursSlider"
                min="0"
                max="16"
                step="0.5"
                value="8"
                class="hour-slider"
                aria-label="Horas de pantalla"
            />
            <div class="slider-display">
                <div class="time-input-group">
                    <input
                        type="number"
                        id="hoursInput"
                        min="0"
                        max="24"
                        step="0.5"
                        value="8"
                        class="time-input"
                    />
                    <span class="time-unit">h</span>
                </div>
                <div class="preset-buttons">
                    <button class="preset-btn" data-hours="2">
                        <span class="preset-label">Poco</span>
                        <span class="preset-hours">2h</span>
                    </button>
                    <button class="preset-btn active" data-hours="8">
                        <span class="preset-label">Normal</span>
                        <span class="preset-hours">8h</span>
                    </button>
                    <button class="preset-btn" data-hours="12">
                        <span class="preset-label">Mucho</span>
                        <span class="preset-hours">12h</span>
                    </button>
                </div>
            </div>
        </div>
    </div>


    <div class="main-result-card">
        <div class="fatigue-meter">
            <div class="fatigue-ring" id="fatigueRing"></div>
            <div class="fatigue-content">
                <div class="fatigue-status" id="fatigueStatus">Moderado</div>
                <div class="fatigue-description" id="fatigueDesc">Tu riesgo ocular</div>
            </div>
        </div>

        <div class="result-display">
            <div class="result-main-number" id="restMinutes">16</div>
            <div class="result-label">minutos de descanso</div>
            <div class="result-subtext" id="breakdownText">por día</div>
        </div>
    </div>


    <div class="stats-grid">
        <div class="stat-card">
            <Icon name="mdi:clock-outline" class="stat-icon" />
            <div class="stat-info">
                <div class="stat-label">Intervalo</div>
                <div class="stat-value" id="intervalValue">20 min</div>
            </div>
        </div>

        <div class="stat-card">
            <Icon name="mdi:eye-circle-outline" class="stat-icon" />
            <div class="stat-info">
                <div class="stat-label">Descansos/día</div>
                <div class="stat-value" id="breaksValue">24</div>
            </div>
        </div>

        <div class="stat-card">
            <Icon name="mdi:ruler" class="stat-icon" />
            <div class="stat-info">
                <div class="stat-label">Distancia ideal</div>
                <div class="stat-value" id="distanceValue">60cm</div>
            </div>
        </div>
    </div>


    <div class="recommendations-cards">
        <div class="rec-card">
            <div class="rec-header">
                <Icon name="mdi:lightbulb-on-outline" />
                <h4>Descansos</h4>
            </div>
            <p id="recText1" class="rec-content"></p>
        </div>

        <div class="rec-card">
            <div class="rec-header">
                <Icon name="mdi:glasses" />
                <h4>Postura</h4>
            </div>
            <p id="recText2" class="rec-content"></p>
        </div>

        <div class="rec-card">
            <div class="rec-header">
                <Icon name="mdi:eye-outline" />
                <h4>Parpadeo</h4>
            </div>
            <p id="recText3" class="rec-content"></p>
        </div>

        <div class="rec-card">
            <div class="rec-header">
                <Icon name="mdi:brightness-5" />
                <h4>Luz Azul</h4>
            </div>
            <p id="recText4" class="rec-content"></p>
        </div>
    </div>


        <div class="timeline-section">
            <h3>Tu Día Visual Ideal</h3>
            <div class="timeline-visual" id="timelineVisual"></div>
            <div class="timeline-legend">
                <div class="legend-item">
                    <div class="legend-dot work"></div>
                    <span>Trabajo</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot rest"></div>
                    <span>Descanso</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot other"></div>
                    <span>Otros</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    interface ScreenState {
        hours: number;
        restMinutes: number;
        fatigueLevel: string;
        fatiguePercent: number;
        breaks: number;
        interval: number;
        distance: string;
    }


    const hoursSlider = document.getElementById("hoursSlider") as HTMLInputElement | null;
    const hoursInput = document.getElementById("hoursInput") as HTMLInputElement | null;
    const presetBtns = document.querySelectorAll(".preset-btn");


    const restMinutesEl = document.getElementById("restMinutes") as HTMLElement | null;
    const breakdownText = document.getElementById("breakdownText") as HTMLElement | null;
    const fatigueStatus = document.getElementById("fatigueStatus") as HTMLElement | null;
    const fatigueDesc = document.getElementById("fatigueDesc") as HTMLElement | null;
    const fatigueRing = document.getElementById("fatigueRing") as HTMLElement | null;
    const intervalValue = document.getElementById("intervalValue") as HTMLElement | null;
    const breaksValue = document.getElementById("breaksValue") as HTMLElement | null;
    const distanceValue = document.getElementById("distanceValue") as HTMLElement | null;


    const recText1 = document.getElementById("recText1") as HTMLElement | null;
    const recText2 = document.getElementById("recText2") as HTMLElement | null;
    const recText3 = document.getElementById("recText3") as HTMLElement | null;
    const recText4 = document.getElementById("recText4") as HTMLElement | null;
    const timelineVisual = document.getElementById("timelineVisual") as HTMLElement | null;

    if (!hoursSlider || !hoursInput || !restMinutesEl) {
        throw new Error("Required elements not found");
    }

    function calculateState(hours: number): ScreenState {
        if (hours < 0) hours = 0;
        if (hours > 24) hours = 24;

        const restMinutes = Math.round(hours * 2);
        const breaks = Math.ceil((hours * 60) / 20);
        const interval = Math.max(15, Math.round(120 / Math.max(1, hours / 4)));

        let fatigueLevel = "Bajo";
        let fatiguePercent = (hours / 12) * 100;

        if (hours <= 2) {
            fatigueLevel = "Bajo";
            fatiguePercent = (hours / 4) * 25;
        } else if (hours <= 4) {
            fatigueLevel = "Bajo";
            fatiguePercent = 25 + ((hours - 2) / 2) * 25;
        } else if (hours <= 8) {
            fatigueLevel = "Moderado";
            fatiguePercent = 50 + ((hours - 4) / 4) * 25;
        } else if (hours <= 12) {
            fatigueLevel = "Alto";
            fatiguePercent = 75 + ((hours - 8) / 4) * 20;
        } else {
            fatigueLevel = "Crítico";
            fatiguePercent = 100;
        }

        const distance = hours <= 4 ? "60cm" : hours <= 8 ? "75cm" : "90cm";

        return {
            hours,
            restMinutes,
            fatigueLevel,
            fatiguePercent: Math.min(fatiguePercent, 100),
            breaks,
            interval,
            distance,
        };
    }

    function updateUI(state: ScreenState) {

        if (restMinutesEl) restMinutesEl.textContent = state.restMinutes.toString();
        if (breakdownText) breakdownText.textContent = `${state.breaks} descansos recomendados`;


        if (fatigueStatus) fatigueStatus.textContent = state.fatigueLevel;
        if (fatigueDesc) fatigueDesc.textContent = "Tu riesgo ocular";


        if (fatigueRing) {
            const angle = (state.fatiguePercent / 100) * 360;
            fatigueRing.style.setProperty(
                "background",
                `conic-gradient(${getColorForFatigue(state.fatigueLevel)} 0deg, ${getColorForFatigue(
                    state.fatigueLevel
                )} ${angle}deg, transparent ${angle}deg)`
            );
        }

        if (intervalValue) intervalValue.textContent = `${state.interval} min`;
        if (breaksValue) breaksValue.textContent = state.breaks.toString();
        if (distanceValue) distanceValue.textContent = state.distance;

        if (recText1) {
            recText1.textContent = `Haz un descanso visual cada ${state.interval} minutos de trabajo continuo.`;
        }

        if (recText2) {
            if (state.hours <= 4) {
                recText2.textContent = "Mantén tu pantalla a 60-70cm. Ajusta la altura para que quede a la altura de los ojos.";
            } else if (state.hours <= 8) {
                recText2.textContent = "Aleja tu pantalla a 70-80cm. Una posición ergonómica reduce la tensión ocular.";
            } else {
                recText2.textContent = "Aumento crítico de distancia a 80-100cm o considera usar un proyector.";
            }
        }

        if (recText3) {
            const blinks = Math.round(10 + state.hours * 2);
            recText3.textContent = `Parpadea conscientemente ${blinks}+ veces por hora. Reduce 66% el parpadeo ante pantallas.`;
        }

        if (recText4) {
            if (state.hours <= 4) {
                recText4.textContent = "Filtro de luz azul básico es suficiente para tu exposición.";
            } else if (state.hours <= 8) {
                recText4.textContent = "Usa gafas de luz azul o aplicaciones como f.lux en horario vespertino.";
            } else {
                recText4.textContent = "Filtro + modo oscuro + gafas son IMPRESCINDIBLES para tu salud visual.";
            }
        }

        if (timelineVisual) {
            updateTimeline(state);
        }
    }

    function getColorForFatigue(level: string): string {
        switch (level) {
            case "Bajo":
                return "#10b981";
            case "Moderado":
                return "#f59e0b";
            case "Alto":
                return "#ef9311";
            case "Crítico":
                return "#dc2626";
            default:
                return "#06b6d4";
        }
    }

    function updateTimeline(state: ScreenState) {
        if (!timelineVisual) return;

        const blocks = [];
        let currentHours = 0;

        while (currentHours < state.hours && blocks.length < 12) {
            blocks.push({ type: "work", duration: 1 });
            blocks.push({ type: "rest", duration: 0.3 });
            currentHours += 1;
        }

        const remainingHours = Math.max(0, 16 - currentHours - blocks.length * 0.3);
        if (remainingHours > 0) {
            blocks.push({ type: "other", duration: remainingHours });
        }

        timelineVisual.innerHTML = blocks
            .map((block) => `<div class="timeline-block ${block.type}" style="flex: ${block.duration};"></div>`)
            .join("");
    }


    hoursSlider.addEventListener("input", () => {
        hoursInput.value = hoursSlider.value;
        const state = calculateState(parseFloat(hoursSlider.value));
        updateUI(state);
        updatePresetButtons(parseFloat(hoursSlider.value));
    });

    hoursInput.addEventListener("input", () => {
        let val = parseFloat(hoursInput.value) || 0;
        if (val < 0) val = 0;
        if (val > 24) val = 24;
        hoursSlider.value = val.toString();
        const state = calculateState(val);
        updateUI(state);
        updatePresetButtons(val);
    });

    presetBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const hours = parseFloat(btn.getAttribute("data-hours") || "8");
            hoursSlider.value = hours.toString();
            hoursInput.value = hours.toString();
            const state = calculateState(hours);
            updateUI(state);
            updatePresetButtons(hours);
        });
    });

    function updatePresetButtons(hours: number) {
        presetBtns.forEach((btn) => {
            const btnHours = parseFloat(btn.getAttribute("data-hours") || "0");
            if (Math.abs(btnHours - hours) < 0.1) {
                btn.classList.add("active");
            } else {
                btn.classList.remove("active");
            }
        });
    }

    updateUI(calculateState(parseFloat(hoursSlider.value)));
</script>

<style>
    .dark .decomp-card {
        background: rgba(30, 41, 59, 0.7);
        border-color: rgba(255, 255, 255, 0.1);
    }

    .result-card {
        border-radius: 1.5rem;
    }

    .recommendation-item {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }

    .rec-icon {
        flex-shrink: 0;
        width: 1.5rem;
        height: 1.5rem;
        color: var(--decomp-primary);
        margin-top: 0.25rem;
    }
</style>

<script>
    interface RecommendationState {
        hours: number;
        restMinutes: number;
        fatigueLevel: "Bajo" | "Moderado" | "Alto" | "Crítico";
        fatiguePercent: number;
    }

    const hoursInput = document.getElementById("hoursInput") as HTMLInputElement | null;
    const restMinutesEl = document.getElementById("restMinutes") as HTMLSpanElement | null;
    const breakdownTextEl = document.getElementById("breakdownText") as HTMLDivElement | null;
    const fatigueLevel = document.getElementById("fatigueLevel") as HTMLSpanElement | null;
    const fatigueFill = document.getElementById("fatigueFill") as HTMLDivElement | null;
    const recText1 = document.getElementById("recText1") as HTMLDivElement | null;
    const recText2 = document.getElementById("recText2") as HTMLDivElement | null;
    const recText3 = document.getElementById("recText3") as HTMLDivElement | null;
    const recText4 = document.getElementById("recText4") as HTMLDivElement | null;
    const scheduleTimeline = document.getElementById("scheduleTimeline") as HTMLDivElement | null;

    if (!hoursInput || !restMinutesEl || !breakdownTextEl || !fatigueLevel || !fatigueFill) {
        throw new Error("Required elements not found");
    }

    function calculateRecommendations(hours: number): RecommendationState {
        if (hours < 0) hours = 0;
        if (hours > 24) hours = 24;

        const restMinutes = Math.round(hours * 2);

        let fatigueLevelVal: "Bajo" | "Moderado" | "Alto" | "Crítico" = "Bajo";
        let fatiguePercent = 0;

        if (hours <= 2) {
            fatigueLevelVal = "Bajo";
            fatiguePercent = (hours / 4) * 25;
        } else if (hours <= 4) {
            fatigueLevelVal = "Bajo";
            fatiguePercent = 25 + ((hours - 2) / 2) * 25;
        } else if (hours <= 8) {
            fatigueLevelVal = "Moderado";
            fatiguePercent = 50 + ((hours - 4) / 4) * 25;
        } else if (hours <= 12) {
            fatigueLevelVal = "Alto";
            fatiguePercent = 75 + ((hours - 8) / 4) * 20;
        } else {
            fatigueLevelVal = "Crítico";
            fatiguePercent = 100;
        }

        return {
            hours,
            restMinutes,
            fatigueLevel: fatigueLevelVal,
            fatiguePercent: Math.min(fatiguePercent, 100),
        };
    }

    function updateUI(state: RecommendationState) {
        if (restMinutesEl) restMinutesEl.textContent = state.restMinutes.toString();

        if (breakdownTextEl) {
            const breaksPerHour = 3;
            const totalBreaks = Math.ceil(state.hours * breaksPerHour);
            breakdownTextEl.innerHTML = `<span class="breakdown-hint">${totalBreaks} descansos de 20 segundos cada uno</span>`;
        }

        if (fatigueLevel) fatigueLevel.textContent = state.fatigueLevel;
        if (fatigueFill) {
            fatigueFill.style.width = `${state.fatiguePercent}%`;

            if (state.fatigueLevel === "Bajo") {
                fatigueFill.style.background = "#10b981";
            } else if (state.fatigueLevel === "Moderado") {
                fatigueFill.style.background = "#f59e0b";
            } else if (state.fatigueLevel === "Alto") {
                fatigueFill.style.background = "#ef9311";
            } else {
                fatigueFill.style.background = "#dc2626";
            }
        }

        if (recText1) {
            const interval = Math.max(15, Math.round(120 / Math.max(1, state.hours / 4)));
            recText1.textContent = `Haz un descanso visual cada ${interval} minutos`;
        }

        if (recText2) {
            if (state.hours <= 4) {
                recText2.textContent = "Distancia normal de 50-70cm está bien";
            } else if (state.hours <= 8) {
                recText2.textContent = "Aumenta a 70-80cm para reducir tensión";
            } else {
                recText2.textContent = "Aleja a 80-100cm o usa proyector";
            }
        }

        if (recText3) {
            const blinks = Math.round(10 + state.hours * 2);
            recText3.textContent = `Parpadea conscientemente ${blinks}+ veces por hora`;
        }

        if (recText4) {
            if (state.hours <= 4) {
                recText4.textContent = "Filtro básico de luz azul es suficiente";
            } else if (state.hours <= 8) {
                recText4.textContent = "Usa gafas de luz azul o f.lux en pantalla";
            } else {
                recText4.textContent = "Filtro de luz azul + modo oscuro IMPRESCINDIBLE";
            }
        }

        if (scheduleTimeline) {
            const workBlocks = Math.ceil(state.hours);
            const restPerBlock = Math.max(2, Math.round(state.restMinutes / Math.max(1, workBlocks)));

            let html = '<div class="timeline">';
            let totalTime = 0;

            for (let i = 0; i < Math.min(workBlocks, 8); i++) {
                html += `<div class="timeline-block work" title="Trabajo ${i + 1}h"></div>`;
                html += `<div class="timeline-block rest" title="Descanso ${restPerBlock}min"></div>`;
                totalTime += 2;
            }

            if (totalTime < 24) {
                html += `<div class="timeline-block sleep" title="Sueño" style="flex: ${24 - totalTime};"></div>`;
            }

            html += '</div>';
            scheduleTimeline.innerHTML = html;
        }
    }

    updateUI(calculateRecommendations(parseFloat(hoursInput.value)));

    hoursInput.addEventListener("input", () => {
        const hours = parseFloat(hoursInput.value) || 0;
        updateUI(calculateRecommendations(hours));
    });

    hoursInput.addEventListener("change", () => {
        const hours = parseFloat(hoursInput.value) || 0;
        updateUI(calculateRecommendations(hours));
    });
</script>
