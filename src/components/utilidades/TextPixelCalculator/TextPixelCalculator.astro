---
import "./TextPixelCalculator.css";
---

<div class="pixel-calculator-container">
    <div class="glass-card animate-in fade-in slide-in-from-bottom duration-700">
        <div class="input-group">
            <label for="input-text" class="label">Texto a Medir</label>
            <div class="textarea-wrapper">
                <textarea
                    id="input-text"
                    placeholder="Escribe o pega aquí el texto que quieres medir..."
                    spellcheck="false">Hola Mundo</textarea
                >
            </div>
        </div>

        <div class="config-grid">
            <div class="input-group">
                <label for="font-family" class="label">Tipografía</label>
                <input
                    type="text"
                    id="font-family"
                    class="text-input"
                    value="Inter, system-ui, sans-serif"
                />
            </div>

            <div class="input-group">
                <label for="font-size" class="label">Tamaño (px)</label>
                <input
                    type="number"
                    id="font-size"
                    class="text-input"
                    value="16"
                    min="1"
                    max="500"
                />
            </div>

            <div class="input-group">
                <label for="font-weight" class="label">Peso (Weight)</label>
                <select id="font-weight" class="text-input">
                    <option value="100">100 - Thin</option>
                    <option value="200">200 - Extra Light</option>
                    <option value="300">300 - Light</option>
                    <option value="400" selected>400 - Regular</option>
                    <option value="500">500 - Medium</option>
                    <option value="600">600 - Semi Bold</option>
                    <option value="700">700 - Bold</option>
                    <option value="800">800 - Extra Bold</option>
                    <option value="900">900 - Black</option>
                </select>
            </div>

            <div class="input-group">
                <label class="control-item">
                    <input type="checkbox" id="font-italic" />
                    <span class="checkbox-custom"></span>
                    <span class="control-text">Itálica</span>
                </label>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-item">
                <span id="pixel-width" class="stat-value">0</span>
                <span class="stat-label">Ancho (Píxeles)</span>
            </div>
            <div class="stat-item">
                <span id="char-count" class="stat-value">0</span>
                <span class="stat-label">Caracteres</span>
            </div>
        </div>
    </div>

    <div class="glass-card animate-in fade-in slide-in-from-bottom duration-700 delay-100">
        <div class="preview-group">
            <label class="label">Vista Previa Visual</label>
            <div class="preview-canvas-wrapper">
                <canvas id="preview-canvas"></canvas>
            </div>
        </div>

        <div class="action-buttons">
            <button id="btn-copy" class="btn btn-primary"> Copiar Ancho </button>
            <button id="btn-reset" class="btn btn-secondary"> Reiniciar </button>
        </div>
    </div>
</div>

<div id="copy-toast" class="copy-toast">¡Ancho copiado al portapapeles!</div>

<script>
    const input = document.getElementById("input-text") as HTMLTextAreaElement | null;
    const fontSize = document.getElementById("font-size") as HTMLInputElement | null;
    const fontWeight = document.getElementById("font-weight") as HTMLSelectElement | null;
    const fontItalic = document.getElementById("font-italic") as HTMLInputElement | null;

    const pixelWidthSpan = document.getElementById("pixel-width");
    const charCountSpan = document.getElementById("char-count");
    const canvas = document.getElementById("preview-canvas") as HTMLCanvasElement | null;
    const btnCopy = document.getElementById("btn-copy");
    const btnReset = document.getElementById("btn-reset");
    const toast = document.getElementById("copy-toast");

    function calculateWidth(): void {
        if (!input || !canvas) return;

        const text = input.value || "";
        const size = fontSize?.value || "16";
        const weight = fontWeight?.value || "400";
        const italic = fontItalic?.checked ? "italic " : "";

        const fontStr = `${italic}${weight} ${size}px`;

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        ctx.font = fontStr;
        const metrics = ctx.measureText(text);
        const width = Math.round(metrics.width * 100) / 100;

        if (pixelWidthSpan) pixelWidthSpan.textContent = width.toString();
        if (charCountSpan) charCountSpan.textContent = text.length.toString();

        drawPreview(text, fontStr, width);
    }

    function drawPreview(text: string, font: string, width: number): void {
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const container = canvas.parentElement;
        if (container) {
            canvas.width = container.clientWidth;
            canvas.height = 150;
        }

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        const isDark = document.documentElement.classList.contains("dark");
        ctx.fillStyle = isDark ? "#ffffff" : "#0f172a";
        ctx.font = font;
        ctx.textBaseline = "middle";

        const x = 20;
        const y = canvas.height / 2;

        ctx.fillText(text, x, y);

        ctx.strokeStyle = "#8b5cf6";
        ctx.setLineDash([5, 5]);
        ctx.beginPath();
        ctx.moveTo(x, y + 30);
        ctx.lineTo(x + width, y + 30);
        ctx.stroke();

        ctx.setLineDash([]);
        ctx.beginPath();
        ctx.moveTo(x, y + 25);
        ctx.lineTo(x, y + 35);
        ctx.moveTo(x + width, y + 25);
        ctx.lineTo(x + width, y + 35);
        ctx.stroke();
    }

    function showToast(): void {
        if (!toast) return;
        toast.classList.add("visible");
        setTimeout(() => toast.classList.remove("visible"), 2000);
    }

    [input, fontSize, fontWeight, fontItalic].forEach((el) => {
        el?.addEventListener("input", calculateWidth);
        el?.addEventListener("change", calculateWidth);
    });

    window.addEventListener("resize", calculateWidth);

    btnCopy?.addEventListener("click", () => {
        if (pixelWidthSpan) {
            navigator.clipboard
                .writeText(pixelWidthSpan.textContent || "0")
                .then(showToast)
                .catch(() => {});
        }
    });

    btnReset?.addEventListener("click", () => {
        if (input) input.value = "Hola Mundo";
        if (fontSize) fontSize.value = "16";
        if (fontWeight) fontWeight.value = "400";
        if (fontItalic) fontItalic.checked = false;
        calculateWidth();
    });

    setTimeout(calculateWidth, 100);
</script>
