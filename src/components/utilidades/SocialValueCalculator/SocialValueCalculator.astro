---
import { Icon } from "astro-icon/components";
import "./SocialValueCalculator.css";
---

<div class="social-calc-container animate-in fade-in slide-in-from-bottom-8 duration-1000">
    <div class="main-dashboard-wrapper glass-surface">
        <header class="dashboard-nav">
            <div class="toggle-control" role="tablist">
                <button
                    class="toggle-item active"
                    data-platform="tiktok"
                    id="btn-tiktok"
                    role="tab"
                >
                    <Icon name="mdi:video-box" class="nav-icon" />
                    <span>TikTok</span>
                </button>
                <div class="toggle-slider"></div>
                <button class="toggle-item" data-platform="instagram" id="btn-instagram" role="tab">
                    <Icon name="mdi:instagram" class="nav-icon" />
                    <span>Instagram</span>
                </button>
            </div>
        </header>

        <div class="dashboard-grid">
            <aside class="metrics-sidebar">
                <div class="section-tag">Parámetros de Auditoría</div>

                <div class="input-inventory">
                    <div class="input-box premium-focus">
                        <label for="followers">
                            <Icon name="mdi:account-group-outline" class="input-icon" />
                            Comunidad (Seguidores)
                        </label>
                        <div class="input-wrapper">
                            <input type="number" id="followers" placeholder="0" min="0" />
                            <div class="input-glow"></div>
                        </div>
                    </div>

                    <div class="input-box premium-focus">
                        <label for="avg-views" id="label-avg-views">
                            <Icon name="mdi:chart-areaspline" class="input-icon" />
                            Impacto Medio (Alcance)
                            <div class="info-trigger" data-tip="views">
                                <Icon name="mdi:information-outline" />
                                <div class="tooltip-box">
                                    Suma las visualizaciones de tus últimos 10 vídeos y divide entre
                                    10 para obtener la media real.
                                </div>
                            </div>
                        </label>
                        <div class="input-wrapper">
                            <input type="number" id="avg-views" placeholder="0" min="0" />
                            <div class="input-glow"></div>
                        </div>
                    </div>

                    <div class="input-box premium-focus">
                        <label for="avg-engagement">
                            <Icon name="mdi:shield-star-outline" class="input-icon" />
                            Fidelidad (Likes + Comm)
                            <div class="info-trigger" data-tip="engagement">
                                <Icon name="mdi:information-outline" />
                                <div class="tooltip-box">
                                    Suma los likes y comentarios totales de tus últimos 10
                                    contenidos y divide entre 10.
                                </div>
                            </div>
                        </label>
                        <div class="input-wrapper">
                            <input type="number" id="avg-engagement" placeholder="0" min="0" />
                            <div class="input-glow"></div>
                        </div>
                    </div>

                    <div class="input-box">
                        <label for="niche">
                            <Icon name="mdi:domain" class="input-icon" />
                            Vertical de Mercado
                        </label>
                        <div class="input-wrapper">
                            <select id="niche">
                                <option value="entertainment">Entretenimiento</option>
                                <option value="finance">Finanzas & Real Estate</option>
                                <option value="tech">Tecnología & SaaS</option>
                                <option value="fitness">Lifestyle & Health</option>
                                <option value="fashion">Moda & Estética</option>
                                <option value="travel">Turismo & Viajes</option>
                                <option value="food">Gastronomía</option>
                                <option value="gaming">Gaming & eSports</option>
                                <option value="home">Reformas & Hogar</option>
                            </select>
                            <Icon name="mdi:chevron-down" class="select-indicator" />
                        </div>
                    </div>
                </div>

                <div class="sidebar-action">
                    <button id="btn-calculate" class="btn-action-primary">
                        Generar Informe de Valor
                        <Icon name="mdi:auto-fix" class="btn-sparkle" />
                    </button>
                </div>
            </aside>

            <main class="results-viewport" id="viewport">
                <div class="empty-results" id="empty-state">
                    <div class="visual-placeholder">
                        <div class="circle-layer layer-1"></div>
                        <div class="circle-layer layer-2"></div>
                        <Icon name="mdi:finance" class="placeholder-icon" />
                    </div>
                    <h3>Análisis de Viabilidad Comercial</h3>
                    <p>
                        Introduce las métricas del perfil para proyectar el valor de mercado actual.
                    </p>
                </div>

                <div class="results-content hidden" id="results-content">
                    <div class="central-valuation">
                        <div class="roi-label">Evaluación de Tarifa Sugerida</div>
                        <div class="valuation-amount" id="result-price">0 €</div>
                        <div class="market-range" id="price-range">Rango: 0 € - 0 €</div>
                    </div>

                    <div class="analytics-cards">
                        <div class="stat-module card-glass">
                            <div class="module-header">
                                <span class="module-title">Calidad de Audiencia</span>
                                <Icon name="mdi:lightning-bolt" class="module-icon color-warning" />
                            </div>
                            <div class="module-value" id="metric-er">0%</div>
                            <div class="module-desc">Engagement Rate</div>
                            <div class="progress-mini">
                                <div class="progress-fill fill-glow" id="er-bar"></div>
                            </div>
                        </div>

                        <div class="stat-module card-glass">
                            <div class="module-header">
                                <span class="module-title">Eficiencia de Inversión</span>
                                <Icon name="mdi:cash-multiple" class="module-icon color-success" />
                            </div>
                            <div class="module-value" id="metric-cpm">0 €</div>
                            <div class="module-desc">CPM Proyectado</div>
                            <div class="progress-mini">
                                <div class="progress-fill fill-success" id="cpm-bar"></div>
                            </div>
                        </div>
                    </div>

                    <div class="valuation-insights">
                        <div class="insight-banner">
                            <Icon name="mdi:alert-circle-outline" class="insight-icon" />
                            <p>
                                Esta valoración se basa en el CPM medio del mercado español (2026).
                            </p>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const getEl = (id: string) => document.getElementById(id);

        const btnTiktok = getEl("btn-tiktok") as HTMLButtonElement | null;
        const btnInstagram = getEl("btn-instagram") as HTMLButtonElement | null;
        const inputFollowers = getEl("followers") as HTMLInputElement | null;
        const inputAvgViews = getEl("avg-views") as HTMLInputElement | null;
        const inputAvgEngagement = getEl("avg-engagement") as HTMLInputElement | null;
        const selectNiche = getEl("niche") as HTMLSelectElement | null;
        const btnCalculate = getEl("btn-calculate") as HTMLButtonElement | null;

        const resultsContent = getEl("results-content");
        const emptyState = getEl("empty-state");
        const resultPrice = getEl("result-price");
        const priceRange = getEl("price-range");
        const metricER = getEl("metric-er");
        const metricCPM = getEl("metric-cpm");
        const erBar = getEl("er-bar");
        const cpmBar = getEl("cpm-bar");
        const labelAvgViews = getEl("label-avg-views");

        let activePlatform: "tiktok" | "instagram" = "tiktok";

        const switchPlatform = (platform: "tiktok" | "instagram") => {
            activePlatform = platform;
            const container = document.querySelector(".toggle-control");
            if (activePlatform === "tiktok") {
                container?.classList.remove("switch");
                btnTiktok?.classList.add("active");
                btnInstagram?.classList.remove("active");
                if (labelAvgViews)
                    labelAvgViews.innerHTML = `<svg width="18" height="18" viewbox="0 0 24 24"><path fill="currentColor" d="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" /></svg> Impacto (Views por Video)`;
            } else {
                container?.classList.add("switch");
                btnInstagram?.classList.add("active");
                btnTiktok?.classList.remove("active");
                if (labelAvgViews)
                    labelAvgViews.innerHTML = `<svg width="18" height="18" viewbox="0 0 24 24"><path fill="currentColor" d="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" /></svg> Alcance (Reach del Perfil)`;
            }
        };

        btnTiktok?.addEventListener("click", () => switchPlatform("tiktok"));
        btnInstagram?.addEventListener("click", () => switchPlatform("instagram"));

        const calculate = () => {
            if (
                !inputFollowers ||
                !inputAvgViews ||
                !inputAvgEngagement ||
                !selectNiche ||
                !resultsContent ||
                !emptyState ||
                !resultPrice ||
                !priceRange ||
                !metricER ||
                !metricCPM
            )
                return;

            const followers = parseFloat(inputFollowers.value) || 0;
            const avgViews = parseFloat(inputAvgViews.value) || 0;
            const avgEngagement = parseFloat(inputAvgEngagement.value) || 0;
            const nicheValue = selectNiche.value;

            if (followers === 0 && avgViews === 0) return;

            const er = followers > 0 ? (avgEngagement / followers) * 100 : 0;

            let baseRate = 0;
            if (activePlatform === "tiktok") {
                baseRate = avgViews * 0.015;
            } else {
                baseRate = followers * 0.006 + avgViews * 0.02;
            }

            const multiByNiche: Record<string, number> = {
                entertainment: 1.0,
                finance: 2.3,
                tech: 1.9,
                fitness: 1.5,
                fashion: 1.3,
                travel: 1.4,
                food: 1.2,
                gaming: 1.25,
                home: 2.1,
            };
            const nicheMult = multiByNiche[nicheValue] || 1.0;

            let qualityScore = 1.0;
            if (er < 2) qualityScore = 0.85;
            else if (er < 5) qualityScore = 1.1;
            else if (er < 10) qualityScore = 1.4;
            else qualityScore = 1.8;

            const finalTariff = baseRate * nicheMult * qualityScore;
            const lowRange = finalTariff * 0.8;
            const highRange = finalTariff * 1.3;

            resultPrice.innerText = `${finalTariff.toLocaleString("es-ES", { maximumFractionDigits: 0 })} €`;
            priceRange.innerText = `Rango sugerido: ${lowRange.toLocaleString("es-ES", { maximumFractionDigits: 0 })} € - ${highRange.toLocaleString("es-ES", { maximumFractionDigits: 0 })} €`;
            metricER.innerText = `${er.toFixed(1)}%`;

            const projectedCPM = avgViews > 0 ? (finalTariff / avgViews) * 1000 : 0;
            metricCPM.innerText = `${projectedCPM.toFixed(2)} €`;

            if (erBar) erBar.style.width = `${Math.min(er * 8, 100)}%`;
            if (cpmBar) cpmBar.style.width = `${Math.min(projectedCPM * 3, 100)}%`;

            emptyState.classList.add("hidden");
            resultsContent.classList.remove("hidden");

            resultsContent.classList.remove("animate-in", "fade-in");
            void (resultsContent as HTMLElement).offsetWidth;
            resultsContent.classList.add("animate-in", "fade-in");
        };

        btnCalculate?.addEventListener("click", calculate);
    });
</script>
