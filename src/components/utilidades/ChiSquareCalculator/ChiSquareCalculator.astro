---
import { Icon } from "astro-icon/components";
import "./ChiSquareCalculator.css";
---

<div class="chi-card" id="chiApp">
    <aside class="chi-sidebar">
        <div class="sidebar-heading">
            <Icon name="mdi:tune-vertical" /> Configuración
        </div>

        <div class="group-section">
            <div class="input-row">
                <label for="tableSize">Tamaño de la Tabla (Filas × Columnas)</label>
                <select id="tableSize">
                    <option value="2x2" selected>2 × 2</option>
                    <option value="2x3">2 × 3</option>
                    <option value="3x2">3 × 2</option>
                    <option value="3x3">3 × 3</option>
                </select>
            </div>
            <div class="input-row" style="margin-top: 0.5rem;">
                <label for="alpha">Nivel de Significancia (<span class="math-sym">α</span>)</label>
                <select id="alpha">
                    <option value="0.10">0.10 (90%)</option>
                    <option value="0.05" selected>0.05 (95%)</option>
                    <option value="0.01">0.01 (99%)</option>
                </select>
            </div>
        </div>
        
        <div style="margin-top: auto; padding: 1.25rem; background: rgba(245, 158, 11, 0.05); border-radius: 1rem; border: 1px dashed rgba(245, 158, 11, 0.2); display: flex; gap: 0.75rem;">
            <Icon name="mdi:information-outline" style="flex-shrink: 0; color: #d97706;" size={20} />
            <p style="font-size: 0.75rem; color: #78350f; line-height: 1.5; margin: 0; font-weight: 500;">
                Calcula automáticamente la frecuencia teórica, el valor <span class="math-sym">χ²</span> y el coeficiente V de Cramer de fuerza de asociación usando inferencia puramente local.
            </p>
        </div>
    </aside>

    <main class="chi-main">
        <div class="table-container">
            <div class="table-title"><Icon name="mdi:table-edit" /> Frecuencias Observadas (Input)</div>
            <table class="contingency-table" id="obsTable">
                <tbody>
                    
                </tbody>
            </table>
        </div>

        <div class="expected-table-area">
            <button class="expected-toggle" id="expectedBtn">
                <Icon name="mdi:chevron-right" id="expectedIcon" /> Ver Frecuencias Esperadas (<span class="math-sym">H₀</span>)
            </button>
            <div class="expected-content" id="expectedContent">
                <p style="font-size: 0.8rem; color: #64748b; margin-bottom: 0.75rem; margin-top: 0;">Estos son los valores que habría en cada celda si no existiera relación alguna entre las dos variables (distribución aleatoria).</p>
                <div class="table-container" style="background: #ffffff;">
                    <table class="contingency-table" id="expTable">
                        <tbody>
                            
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="extremeAlert" style="display: none; background: #fffbeb; border: 1px solid #fde68a; padding: 1rem; border-radius: 0.75rem;">
            <div style="color: #d97706; font-weight: 800; font-size: 0.9rem; margin-bottom: 0.25rem;">⚠️ Advertencia Estadística (Celdas &lt; 5)</div>
            <p style="color: #92400e; font-size: 0.85rem; margin: 0; font-weight: 500;">Hay frecuencias esperadas muy bajas. La aproximación <span class="math-sym">χ²</span> podría no ser fiable. Se sugiere juntar categorías o usar test exacto de Fisher.</p>
        </div>

        <section class="results-grid">
            <div class="stat-block" id="pvalueBlock">
                <div class="stat-title">P-Valor (<span class="math-sym">p</span>)</div>
                <div class="stat-value" id="res-pvalue">0.000</div>
                <div class="stat-desc" id="res-desc">Existe relación significativa</div>
            </div>
            
            <div class="stat-block">
                <div class="stat-title">Estadísticos Globales</div>
                <div style="display: flex; gap: 2rem; justify-content: center; align-items: baseline; margin-top: 0.5rem;">
                    <div>
                        <div style="font-size: 0.75rem; color: #64748b; font-weight: 700;">Chi-Cuadrado (<span class="math-sym">χ²</span>)</div>
                        <div class="secondary-stat" id="res-chi">0.00</div>
                    </div>
                    <div>
                        <div style="font-size: 0.75rem; color: #64748b; font-weight: 700;">Grados (<span class="math-sym">df</span>)</div>
                        <div class="secondary-stat" id="res-df">1</div>
                    </div>
                </div>
                <div style="margin-top: 1rem; padding-top: 0.5rem; border-top: 1px dashed #cbd5e1; width: 100%;">
                    <div style="font-size: 0.75rem; color: #64748b; font-weight: 700;">Fuerza de Relación (V de Cramer)</div>
                    <div style="font-size: 1.25rem; font-weight: 800; color: #0f172a;" id="res-cramer">0.00 <span style="font-size: 0.8rem; color: #475569; font-weight: 500;" id="cramer-text">(Nula)</span></div>
                </div>
            </div>
        </section>

        <section class="visual-section">
            <div class="table-title" style="margin-bottom: 1rem;"><Icon name="mdi:chart-bar" /> Visualización de Residuos (Observado vs Esperado)</div>
            <canvas id="barCanvas"></canvas>
            <div class="heatmap-info">Las celdas de la tabla de input se tiñen según la variación residual.</div>
        </section>

        <section class="text-copy-block">
            <div class="copy-header">
                <Icon name="mdi:text-box-outline" /> <span>Texto para tu informe</span>
            </div>
            <p id="justificationText" class="copy-text">
                Tras analizar un total de N observaciones, encontramos un valor χ²(df) = X. Con un p-valor de P, se concluye que existe dependencia significativa.
            </p>
            <button class="copy-btn" id="copyTextBtn"><Icon name="mdi:content-copy" /> Copiar Texto</button>
        </section>
    </main>
</div>

<script>
    const tableSize = document.getElementById('tableSize') as HTMLSelectElement;
    const alphaInput = document.getElementById('alpha') as HTMLSelectElement;
    const obsTable = document.querySelector('#obsTable tbody') as HTMLTableSectionElement;
    const expTable = document.querySelector('#expTable tbody') as HTMLTableSectionElement;
    const alertBox = document.getElementById('extremeAlert') as HTMLDivElement;
    
    const expectedBtn = document.getElementById('expectedBtn');
    const expectedContent = document.getElementById('expectedContent');
    const expectedIcon = document.getElementById('expectedIcon');

    expectedBtn?.addEventListener('click', () => {
        const isOpen = expectedContent?.classList.toggle('open');
        expectedIcon?.setAttribute('name', isOpen ? 'mdi:chevron-down' : 'mdi:chevron-right');
    });

    const canvas = document.getElementById('barCanvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d');

    let rows = 2;
    let cols = 2;
    let obsData: number[][] = [];

    const normCDF = (x: number): number => {
        const t = 1 / (1 + 0.2316419 * Math.abs(x));
        const d = 0.3989422804 * Math.exp(-x * x / 2);
        const p = d * t * (0.31938153 + t * (-0.356563782 + t * (1.781477937 + t * (-1.821255978 + t * 1.330274429))));
        return x > 0 ? 1 - p : p;
    };

    const chiSquareProb = (chi2: number, df: number): number => {
        if (chi2 <= 0) return 1;
        if (df === 1) return 2 * (1 - normCDF(Math.sqrt(chi2)));
        if (df === 2) return Math.exp(-chi2 / 2);
        if (df === 3) return 2 * (1 - normCDF(Math.sqrt(chi2))) + Math.sqrt((2 * chi2) / Math.PI) * Math.exp(-chi2 / 2);
        if (df === 4) return Math.exp(-chi2 / 2) * (1 + chi2 / 2);
        return 0;
    };

    const generateTables = () => {
        const val = tableSize.value.split('x');
        rows = parseInt(val[0]);
        cols = parseInt(val[1]);

        let hHTML = '<tr class="header-row"><th class="header-col">#</th>';
        for (let j = 0; j < cols; j++) hHTML += `<th>Col ${j+1}</th>`;
        hHTML += '<th class="total-cell">TOTAL</th></tr>';

        let bHTML = hHTML;
        let eHTML = hHTML;

        for (let i = 0; i < rows; i++) {
            bHTML += `<tr><th class="header-col">Fila ${i+1}</th>`;
            eHTML += `<tr><th class="header-col">Fila ${i+1}</th>`;
            for (let j = 0; j < cols; j++) {
                bHTML += `<td><input type="number" class="cell-input" data-r="${i}" data-c="${j}" value="10" min="0" step="1"/></td>`;
                eHTML += `<td id="exp-${i}-${j}">0.0</td>`;
            }
            bHTML += `<td class="total-cell" id="rTot-${i}">0</td></tr>`;
            eHTML += `<td class="total-cell" id="eTot-${i}">0</td></tr>`;
        }

        bHTML += '<tr><th class="total-cell">TOTAL</th>';
        eHTML += '<tr><th class="total-cell">TOTAL</th>';
        for (let j = 0; j < cols; j++) {
            bHTML += `<td class="total-cell" id="cTot-${j}">0</td>`;
            eHTML += `<td class="total-cell" id="ecTot-${j}">0</td>`;
        }
        bHTML += `<td class="total-cell" style="background:#cbd5e1;" id="gTot">0</td></tr>`;
        eHTML += `<td class="total-cell" style="background:#cbd5e1;" id="egTot">0</td></tr>`;

        obsTable.innerHTML = bHTML;
        expTable.innerHTML = eHTML;

        document.querySelectorAll('.cell-input').forEach(inp => {
            inp.addEventListener('input', calculate);
        });

        calculate();
    };

    const drawChart = (obs: number[][], exp: number[][]) => {
        if (!ctx || !canvas) return;
        const dpr = window.devicePixelRatio || 1;
        const cw = canvas.offsetWidth;
        const ch = canvas.offsetHeight;
        canvas.width = Math.round(cw * dpr);
        canvas.height = Math.round(ch * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, cw, ch);

        let maxVal = 0;
        for (let i = 0; i < rows; i++) {
            for (let j = 0; j < cols; j++) {
                if (obs[i][j] > maxVal) maxVal = obs[i][j];
                if (exp[i][j] > maxVal) maxVal = exp[i][j];
            }
        }
        maxVal = maxVal * 1.1 || 10;

        const padL = 30, padR = 20, padT = 20, padB = 40;
        const pw = cw - padL - padR;
        const ph = ch - padT - padB;
        
        ctx.strokeStyle = '#e2e8f0'; ctx.lineWidth = 1;
        ctx.beginPath();
        for (let i = 0; i <= 4; i++) {
            const y = padT + (i/4)*ph;
            ctx.moveTo(padL, y); ctx.lineTo(padL + pw, y);
            ctx.fillStyle = '#94a3b8'; ctx.font = '10px sans-serif'; ctx.textAlign = 'right';
            ctx.fillText(Math.round(maxVal - (i/4)*maxVal).toString(), padL - 8, y + 4);
        }
        ctx.stroke();

        const groupW = pw / cols;
        const barPad = groupW * 0.15;
        const innerW = groupW - barPad * 2;
        const numBars = rows * 2;
        const bw = innerW / numBars;

        const colors = ['#f59e0b', '#3b82f6', '#10b981'];
        
        for (let j = 0; j < cols; j++) {
            const gx = padL + j * groupW + barPad;
            
            ctx.fillStyle = '#64748b'; ctx.font = 'bold 11px sans-serif'; ctx.textAlign = 'center';
            ctx.fillText(`Col ${j+1}`, padL + j * groupW + groupW/2, ch - 20);

            for (let i = 0; i < rows; i++) {
                const oH = (obs[i][j] / maxVal) * ph;
                const eH = (exp[i][j] / maxVal) * ph;

                const oX = gx + (i * 2) * bw;
                const eX = gx + (i * 2 + 1) * bw;

                ctx.fillStyle = colors[i % colors.length];
                ctx.beginPath(); ctx.roundRect(oX, padT + ph - oH, bw*0.9, oH, [3,3,0,0]); ctx.fill();

                ctx.fillStyle = '#cbd5e1';
                ctx.beginPath(); ctx.roundRect(eX, padT + ph - eH, bw*0.9, eH, [3,3,0,0]); ctx.fill();
            }
        }

        ctx.fillStyle = colors[0]; ctx.fillRect(padL, ch - 10, 8, 8);
        ctx.fillStyle = '#64748b'; ctx.textAlign = 'left'; ctx.fillText('Fila Observada', padL + 12, ch - 2);
        
        ctx.fillStyle = '#cbd5e1'; ctx.fillRect(padL + 100, ch - 10, 8, 8);
        ctx.fillStyle = '#64748b'; ctx.fillText('Esperado', padL + 112, ch - 2);
    };

    const calculate = () => {
        obsData = [];
        const rTot = new Array(rows).fill(0);
        const cTot = new Array(cols).fill(0);
        let total = 0;

        for (let i = 0; i < rows; i++) {
            obsData.push([]);
            for (let j = 0; j < cols; j++) {
                const inp = document.querySelector(`input[data-r="${i}"][data-c="${j}"]`) as HTMLInputElement;
                const v = Math.max(0, parseInt(inp.value) || 0);
                obsData[i].push(v);
                rTot[i] += v;
                cTot[j] += v;
                total += v;
            }
            document.getElementById(`rTot-${i}`)!.textContent = rTot[i].toString();
            document.getElementById(`eTot-${i}`)!.textContent = rTot[i].toString();
        }

        for (let j = 0; j < cols; j++) {
            document.getElementById(`cTot-${j}`)!.textContent = cTot[j].toString();
            document.getElementById(`ecTot-${j}`)!.textContent = cTot[j].toString();
        }
        document.getElementById('gTot')!.textContent = total.toString();
        document.getElementById('egTot')!.textContent = total.toString();

        let chi2 = 0;
        const expData: number[][] = [];
        let lowExpCount = 0;

        for (let i = 0; i < rows; i++) {
            expData.push([]);
            for (let j = 0; j < cols; j++) {
                const e = total > 0 ? (rTot[i] * cTot[j]) / total : 0;
                expData[i].push(e);
                document.getElementById(`exp-${i}-${j}`)!.textContent = e.toFixed(1);
                
                if (e > 0) chi2 += Math.pow(obsData[i][j] - e, 2) / e;
                if (e < 5 && e > 0) lowExpCount++;

                const inp = document.querySelector(`input[data-r="${i}"][data-c="${j}"]`) as HTMLInputElement;
                if (e > 0) {
                    const stdRes = (obsData[i][j] - e) / Math.sqrt(e);
                    if (Math.abs(stdRes) > 2) {
                        inp.style.backgroundColor = stdRes > 0 ? 'rgba(16, 185, 129, 0.15)' : 'rgba(239, 68, 68, 0.15)';
                    } else if (Math.abs(stdRes) > 1) {
                        inp.style.backgroundColor = stdRes > 0 ? 'rgba(16, 185, 129, 0.05)' : 'rgba(239, 68, 68, 0.05)';
                    } else {
                        inp.style.backgroundColor = 'transparent';
                    }
                } else {
                    inp.style.backgroundColor = 'transparent';
                }
            }
        }

        alertBox.style.display = lowExpCount > 0 ? 'block' : 'none';

        const df = (rows - 1) * (cols - 1);
        const pValue = chiSquareProb(chi2, df);
        const alpha = parseFloat(alphaInput.value) || 0.05;
        const isSignificant = pValue < alpha;

        const maxDim = Math.min(rows, cols);
        const cramer = total > 0 && maxDim > 1 ? Math.sqrt(chi2 / (total * (maxDim - 1))) : 0;

        let cramerTxt = "Nula";
        if (cramer > 0.5) cramerTxt = "Fuerte";
        else if (cramer > 0.3) cramerTxt = "Moderada";
        else if (cramer > 0.1) cramerTxt = "Débil";

        document.getElementById('res-chi')!.textContent = chi2.toFixed(3);
        document.getElementById('res-df')!.textContent = df.toString();
        document.getElementById('res-cramer')!.innerHTML = `${cramer.toFixed(2)} <span style="font-size: 0.8rem; color: #475569; font-weight: 500;">(${cramerTxt})</span>`;

        const pvalBlock = document.getElementById('pvalueBlock')!;
        pvalBlock.className = 'stat-block ' + (isSignificant ? 'significant' : 'not-significant');
        document.getElementById('res-pvalue')!.textContent = pValue < 0.001 ? '<0.001' : pValue.toFixed(4);
        
        const desc = isSignificant ? 'Hay asociación significativa (dependencia).' : 'No hay evidencia de relación (independencia).';
        document.getElementById('res-desc')!.textContent = desc;

        const justText = `Tras analizar ${total} casos en una tabla ${rows}x${cols}, obtuvimos χ²(${df}) = ${chi2.toFixed(2)}, p = ${pValue.toFixed(4)}. Evaluado al nivel α=${alpha}, se concluye empíricamente que ${isSignificant ? 'EXISTE una asociación fuerte entre las variables (V de Cramer: ' + cramer.toFixed(2) + ')' : 'NO EXISTE asociación estadísticamente significativa'} .`;
        document.getElementById('justificationText')!.textContent = justText;

        drawChart(obsData, expData);
    };

    tableSize.addEventListener('change', generateTables);
    alphaInput.addEventListener('change', calculate);
    window.addEventListener('resize', calculate);

    const copyBtn = document.getElementById('copyTextBtn');
    copyBtn?.addEventListener('click', () => {
        const text = document.getElementById('justificationText')?.textContent || "";
        navigator.clipboard.writeText(text);
        const t = copyBtn.innerHTML;
        copyBtn.innerHTML = '¡Copiado!';
        setTimeout(() => copyBtn.innerHTML = t, 1500);
    });

    generateTables();
</script>
