---
import { Icon } from "astro-icon/components";
import { ALL_APP_DEFINITIONS, type KnownLocale } from "@jjlmoya/apps";

const DEFAULT_THEMES: Record<string, string> = {
    "sauce-lab": "#FF4D4D",
    "fortune-cookie": "#FFD700",
    "lexi-crash": "#4D94FF",
    pizzametrics: "#FFA500",
    vesp: "#00FF9F",
    "day-check": "#B185FF",
    "fast-task": "#00E5FF",
};

const apps = await Promise.all(
    ALL_APP_DEFINITIONS.map(async ({ entry }) => {
        const loader = entry.i18n["es" as KnownLocale] ?? entry.i18n.en;
        const card = await loader!();
        return {
            ...entry,
            ...card,
            bannerText: (card as any).bannerText || "",
            media: {
                icon: `/assets/apps/${entry.id}/icon.webp`,
                showcase: `/assets/apps/${entry.id}/hero.webp`,
            },
            theme: {
                primary: DEFAULT_THEMES[entry.id] || "#6366f1",
            },
        };
    })
);

interface Props {
    appSlug?: string;
    android?: string;
    ios?: string;
}

const { appSlug, android: propAndroid, ios: propIos } = Astro.props;

const app = appSlug ? apps.find((a) => a.slug === appSlug) : null;

const isGeneric = !appSlug && !propAndroid && !propIos;
const android =
    propAndroid ||
    app?.stores.googlePlay ||
    (isGeneric ? "https://play.google.com/store/apps/developer?id=GameBob+Games" : "");
const ios =
    propIos ||
    app?.stores.appStore ||
    (isGeneric ? "https://apps.apple.com/developer/juan-jose-lopez-moya/id1871275518" : "");

const primaryColor = app?.theme.primary || "#6366f1";
---

<div
    class={`alb-bar ${isGeneric ? "alb-bar--generic" : "alb-bar--app"}`}
    style={`--app-primary: ${primaryColor}`}
>
    <div class="alb-glow-wrap">
        <div
            class="alb-glow"
            style="background: var(--app-primary);"
        >
        </div>
        <div class="alb-glow-secondary"></div>
    </div>

    <div class="alb-backdrop"></div>

    <div class="alb-inner">
        <div class="alb-icon-wrapper">
            {
                isGeneric ? (
                    apps.slice(0, 3).map((a, i) => (
                        <div
                            class="alb-stacked-icon"
                            style={`z-index: ${10 - i}; transform: translateY(${(i - 1) * 4}px)`}
                        >
                            <img
                                src={a.media.icon}
                                alt=""
                                class="alb-generic-icon"
                            />
                        </div>
                    ))
                ) : app ? (
                    <div class="alb-app-icon-wrap">
                        <div class="alb-app-icon-glow" />
                        <img
                            src={app.media.icon}
                            alt={app.title}
                            class="alb-app-icon"
                        />
                    </div>
                ) : (
                    <div class="alb-fallback-icon-wrap">
                        <Icon name="mdi:cellphone" class="alb-fallback-icon" />
                    </div>
                )
            }
        </div>

        <div class="alb-text-content">
            <div class="alb-heading-row">
                <h3 class="alb-heading">
                    {
                        isGeneric
                            ? "Mis mejores utilidades, ahora en tu móvil."
                            : app
                              ? `¡${app.title} ahora es una App!`
                              : "¿Prefieres la versión App?"
                    }
                </h3>
                {
                    !isGeneric && (
                        <span class="alb-badge">
                            Nativa
                        </span>
                    )
                }
            </div>
            <p class="alb-subtitle">
                {
                    isGeneric
                        ? "Accede a todas mis herramientas y proyectos de forma rápida, optimizada y en un solo lugar."
                        : app?.bannerText ||
                          "Esta utilidad ahora es una App con muchas más funciones, ¡descárgala ahora!"
                }
            </p>
        </div>

        <div class="alb-buttons">
            {
                android && (
                    <a
                        href={android}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="alb-store-btn"
                        title="Disponible en Google Play"
                    >
                        <Icon name="mdi:google-play" class="alb-store-icon" />
                        <div class="alb-store-text">
                            <span class="alb-store-label">Disponible en</span>
                            <span class="alb-store-name">Google Play</span>
                        </div>
                    </a>
                )
            }
            {
                ios ? (
                    <a
                        href={ios}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="alb-store-btn"
                        title="Consíguelo en el App Store"
                    >
                        <Icon name="mdi:apple" class="alb-store-icon" />
                        <div class="alb-store-text">
                            <span class="alb-store-label">Consíguelo en el</span>
                            <span class="alb-store-name">App Store</span>
                        </div>
                    </a>
                ) : (
                    <div
                        class="alb-store-btn alb-store-btn--disabled"
                        title="Próximamente en el App Store"
                    >
                        <Icon name="mdi:apple" class="alb-store-icon" />
                        <div class="alb-store-text">
                            <span class="alb-store-label">Consíguelo en el</span>
                            <span class="alb-store-name">App Store</span>
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</div>

<style>
    @keyframes alb-pulse-slow {
        0%, 100% {
            opacity: 0.15;
            transform: scale(1);
        }
        50% {
            opacity: 0.25;
            transform: scale(1.1);
        }
    }
    @keyframes alb-shine {
        0% {
            transform: translateX(-100%) skewX(-20deg);
        }
        20%, 100% {
            transform: translateX(200%) skewX(-20deg);
        }
    }

    .alb-bar {
        --alb-bg: #0f172a;
        --alb-text: #ffffff;
        --alb-heading: #ffffff;
        --alb-subtitle: rgba(255, 255, 255, 0.5);
        --alb-border: rgba(255, 255, 255, 0.1);
        --alb-badge-bg: rgba(255, 255, 255, 0.1);
        --alb-badge-text: #ffffff;
        --alb-badge-border: rgba(255, 255, 255, 0.1);
        --alb-glow-opacity: 0.2;
        --alb-backdrop: rgba(0, 0, 0, 0.4);

        width: 100%;
        padding: 1.5rem 1rem 0.5rem;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--alb-border);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        transition: background-color 0.5s, border-color 0.5s;
        background: var(--alb-bg);
    }
    .alb-bar a {
        text-decoration: none;
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.3);
    }
    .alb-bar a:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -8px rgba(0, 0, 0, 0.4);
    }

    .alb-bar--generic {
        --alb-bg: #f8fafc;
        --alb-text: #0f172a;
        --alb-heading: #0f172a;
        --alb-subtitle: #64748b;
        --alb-border: #e2e8f0;
        --alb-badge-bg: #eef2ff;
        --alb-badge-text: #4f46e5;
        --alb-badge-border: #e0e7ff;
        --alb-glow-opacity: 0.05;
        --alb-backdrop: rgba(255, 255, 255, 0.4);
    }
    .dark .alb-bar--generic {
        --alb-bg: #09090b;
        --alb-text: #ffffff;
        --alb-heading: #ffffff;
        --alb-subtitle: #a1a1aa;
        --alb-border: #27272a;
        --alb-badge-bg: rgba(30, 27, 75, 0.3);
        --alb-badge-text: #818cf8;
        --alb-badge-border: rgba(49, 46, 129, 0.5);
        --alb-backdrop: rgba(0, 0, 0, 0.4);
    }

    .alb-glow-wrap {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        color: #000;
    }
    .alb-glow {
        position: absolute;
        top: -50%;
        left: -10%;
        width: 80%;
        height: 200%;
        opacity: var(--alb-glow-opacity);
        filter: blur(80px);
        border-radius: 9999px;
        animation: alb-pulse-slow 8s ease-in-out infinite;
    }
    .alb-glow-secondary {
        position: absolute;
        bottom: -50%;
        right: -10%;
        width: 60%;
        height: 180%;
        background: rgba(59, 130, 246, 0.2);
        filter: blur(100px);
        border-radius: 9999px;
        animation: alb-pulse-slow 8s ease-in-out infinite 4s;
    }

    .alb-backdrop {
        position: absolute;
        inset: 0;
        background: var(--alb-backdrop);
        backdrop-filter: blur(12px);
    }

    .alb-inner {
        max-width: 80rem;
        margin: 0 auto;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: flex-start;
        gap: 0.75rem;
        position: relative;
        z-index: 10;
    }
    @media (min-width: 640px) {
        .alb-inner {
            gap: 1.5rem;
        }
    }
    @media (min-width: 768px) {
        .alb-inner {
            max-width: 56rem;
            justify-content: center;
        }
    }

    .alb-icon-wrapper {
        position: relative;
        flex-shrink: 0;
        display: flex;
    }
    @media (min-width: 640px) {
        .alb-icon-wrapper {
            margin-left: 0;
        }
    }

    .alb-stacked-icon {
        position: relative;
    }

    .alb-generic-icon {
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 0.5rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .dark .alb-generic-icon {
        border-color: rgba(255, 255, 255, 0.1);
    }
    @media (min-width: 640px) {
        .alb-generic-icon {
            width: 2rem;
            height: 2rem;
        }
    }

    .alb-app-icon-wrap {
        position: relative;
    }
    .alb-app-icon-glow {
        position: absolute;
        inset: -0.25rem;
        background: var(--app-primary);
        opacity: 0.3;
        filter: blur(4px);
        border-radius: 0.75rem;
        transition: opacity 0.5s;
    }
    .alb-icon-wrapper:hover .alb-app-icon-glow {
        opacity: 0.5;
    }
    .alb-app-icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.75rem;
        position: relative;
        z-index: 10;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: transform 0.5s;
    }
    .alb-icon-wrapper:hover .alb-app-icon {
        transform: scale(1.05);
    }
    @media (min-width: 640px) {
        .alb-app-icon {
            width: 3rem;
            height: 3rem;
        }
    }

    .alb-fallback-icon-wrap {
        width: 2.5rem;
        height: 2.5rem;
        padding: 0.625rem;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 0.75rem;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    @media (min-width: 640px) {
        .alb-fallback-icon-wrap {
            width: 3rem;
            height: 3rem;
        }
    }
    .alb-fallback-icon {
        width: 100%;
        height: 100%;
        color: #818cf8;
    }

    .alb-text-content {
        min-width: 0;
        padding: 0.125rem 0;
    }
    @media (min-width: 640px) {
        .alb-text-content {
            margin-left: 0;
        }
    }

    .alb-heading-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.125rem;
    }

    .alb-heading {
        font-weight: 900;
        font-size: 0.625rem;
        letter-spacing: -0.025em;
        line-height: 1;
        color: var(--alb-heading);
    }
    @media (min-width: 640px) {
        .alb-heading {
            font-size: 0.875rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    }

    .alb-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.125rem 0.25rem;
        border-radius: 0.25rem;
        font-size: 0.375rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: 1px solid var(--alb-badge-border);
        background: var(--alb-badge-bg);
        color: var(--alb-badge-text);
        backdrop-filter: blur(12px);
        white-space: nowrap;
    }
    @media (min-width: 640px) {
        .alb-badge {
            font-size: 0.5rem;
        }
    }

    .alb-subtitle {
        font-size: 0.5625rem;
        color: var(--alb-subtitle);
        font-weight: 500;
        line-height: 1.25;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        max-width: 24rem;
    }
    @media (min-width: 640px) {
        .alb-subtitle {
            font-size: 0.75rem;
            max-width: 36rem;
        }
    }

    .alb-buttons {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
    }
    @media (min-width: 640px) {
        .alb-buttons {
            gap: 0.75rem;
        }
    }

    .alb-store-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #000;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: background 0.2s, color 0.2s, border-color 0.2s, box-shadow 0.2s;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 9999px;
        cursor: pointer;
    }
    .alb-store-btn:hover {
        background: #18181b;
    }
    @media (min-width: 640px) {
        .alb-store-btn {
            width: auto;
            height: 42px;
            padding: 0 1rem;
            border-radius: 0.5rem;
            gap: 0.5rem;
        }
    }

    .alb-store-btn--disabled {
        border-color: rgba(255, 255, 255, 0.05);
        cursor: not-allowed;
        opacity: 0.1;
        filter: grayscale(1);
    }
    .alb-store-btn--disabled:hover {
        background: #000;
    }

    .alb-store-icon {
        width: 1.25rem;
        height: 1.25rem;
        color: #fff;
    }
    @media (min-width: 640px) {
        .alb-store-icon {
            width: 1.5rem;
            height: 1.5rem;
        }
    }

    .alb-store-text {
        display: none;
    }
    @media (min-width: 640px) {
        .alb-store-text {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            line-height: 1;
        }
    }

    .alb-store-label {
        font-size: 0.625rem;
        text-transform: uppercase;
        font-weight: 500;
        opacity: 0.8;
    }

    .alb-store-name {
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: -0.025em;
    }
</style>
