---
import "./AppLinksBanner.css";
import { Icon } from "astro-icon/components";
import { ALL_APP_DEFINITIONS, type KnownLocale } from "@jjlmoya/apps";

const DEFAULT_THEMES: Record<string, string> = {
    "sauce-lab": "#FF4D4D",
    "fortune-cookie": "#FFD700",
    "lexi-crash": "#4D94FF",
    pizzametrics: "#FFA500",
    vesp: "#00FF9F",
    "day-check": "#B185FF",
    "fast-task": "#00E5FF",
};

const apps = await Promise.all(
    ALL_APP_DEFINITIONS.map(async ({ entry }) => {
        const loader = entry.i18n["es" as KnownLocale] ?? entry.i18n.en;
        const card = await loader!();
        return {
            ...entry,
            ...card,
            bannerText: (card as any).bannerText || "",
            media: {
                icon: `/assets/apps/${entry.id}/icon.webp`,
                showcase: `/assets/apps/${entry.id}/hero.webp`,
            },
            theme: {
                primary: DEFAULT_THEMES[entry.id] || "#6366f1",
            },
        };
    })
);

interface Props {
    appSlug?: string;
    android?: string;
    ios?: string;
}

const { appSlug, android: propAndroid, ios: propIos } = Astro.props;

const app = appSlug ? apps.find((a) => a.slug === appSlug) : null;

const isGeneric = !appSlug && !propAndroid && !propIos;
const android =
    propAndroid ||
    app?.stores.googlePlay ||
    (isGeneric ? "https://play.google.com/store/apps/developer?id=GameBob+Games" : "");
const ios =
    propIos ||
    app?.stores.appStore ||
    (isGeneric ? "https://apps.apple.com/developer/juan-jose-lopez-moya/id1871275518" : "");

const primaryColor = app?.theme.primary || "#6366f1";
---

<div
    class={`alb-bar ${isGeneric ? "alb-bar--generic" : "alb-bar--app"}`}
    style={`--app-primary: ${primaryColor}`}
>
    <div class="alb-glow-wrap">
        <div
            class="alb-glow"
            style="background: var(--app-primary);"
        >
        </div>
        <div class="alb-glow-secondary"></div>
    </div>

    <div class="alb-backdrop"></div>

    <div class="alb-inner">
        <div class="alb-icon-wrapper">
            {
                isGeneric ? (
                    apps.slice(0, 3).map((a, i) => (
                        <div
                            class="alb-stacked-icon"
                            style={`z-index: ${10 - i}`}
                        >
                            <img
                                src={a.media.icon}
                                alt=""
                                class="alb-generic-icon"
                            />
                        </div>
                    ))
                ) : app ? (
                    <div class="alb-app-icon-wrap">
                        <div class="alb-app-icon-glow" />
                        <img
                            src={app.media.icon}
                            alt={app.title}
                            class="alb-app-icon"
                        />
                    </div>
                ) : (
                    <div class="alb-fallback-icon-wrap">
                        <Icon name="mdi:cellphone" class="alb-fallback-icon" />
                    </div>
                )
            }
        </div>

        <div class="alb-text-content">
            <div class="alb-heading-row">
                <h3 class="alb-heading">
                    {
                        isGeneric
                            ? "Mis mejores utilidades, ahora en tu móvil."
                            : app
                              ? `¡${app.title} ahora es una App!`
                              : "¿Prefieres la versión App?"
                    }
                </h3>
                {
                    !isGeneric && (
                        <span class="alb-badge">
                            Nativa
                        </span>
                    )
                }
            </div>
            <p class="alb-subtitle">
                {
                    isGeneric
                        ? "Accede a todas mis herramientas y proyectos de forma rápida, optimizada y en un solo lugar."
                        : app?.bannerText ||
                          "Esta utilidad ahora es una App con muchas más funciones, ¡descárgala ahora!"
                }
            </p>
        </div>

        <div class="alb-buttons">
            {
                android && (
                    <a
                        href={android}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="alb-store-btn"
                        title="Disponible en Google Play"
                    >
                        <Icon name="mdi:google-play" class="alb-store-icon" />
                        <div class="alb-store-text">
                            <span class="alb-store-label">Disponible en</span>
                            <span class="alb-store-name">Google Play</span>
                        </div>
                    </a>
                )
            }
            {
                ios ? (
                    <a
                        href={ios}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="alb-store-btn"
                        title="Consíguelo en el App Store"
                    >
                        <Icon name="mdi:apple" class="alb-store-icon" />
                        <div class="alb-store-text">
                            <span class="alb-store-label">Consíguelo en el</span>
                            <span class="alb-store-name">App Store</span>
                        </div>
                    </a>
                ) : (
                    <div
                        class="alb-store-btn alb-store-btn--disabled"
                        title="Próximamente en el App Store"
                    >
                        <Icon name="mdi:apple" class="alb-store-icon" />
                        <div class="alb-store-text">
                            <span class="alb-store-label">Consíguelo en el</span>
                            <span class="alb-store-name">App Store</span>
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</div>


