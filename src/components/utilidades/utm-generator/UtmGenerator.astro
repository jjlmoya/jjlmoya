---
import "./UtmGenerator.css";
---

<div class="utm-container animate-in">
    <div class="utm-grid">
        <div class="input-group col-span-2 full-width">
            <label for="utm-url">URL del sitio web (p. ej. https://ejemplo.com) *</label>
            <input type="url" id="utm-url" placeholder="https://ejemplo.com" required />
        </div>

        <div class="input-group">
            <label for="utm-source">Fuente de la campaña (p. ej. google, newsletter) *</label>
            <input type="text" id="utm-source" placeholder="google" required />
        </div>

        <div class="input-group">
            <label for="utm-medium">Medio de la campaña (p. ej. cpc, email)</label>
            <input type="text" id="utm-medium" placeholder="cpc" />
        </div>

        <div class="input-group">
            <label for="utm-campaign">Nombre de la campaña (p. ej. oferta_verano)</label>
            <input type="text" id="utm-campaign" placeholder="oferta_verano" />
        </div>

        <div class="input-group">
            <label for="utm-term">Término de la campaña (p. ej. comprar_zapatos)</label>
            <input type="text" id="utm-term" placeholder="comprar_zapatos" />
        </div>

        <div class="input-group">
            <label for="utm-content">Contenido de la campaña (p. ej. banner_superior)</label>
            <input type="text" id="utm-content" placeholder="banner_superior" />
        </div>
    </div>

    <div class="utm-result">
        <div class="result-header">
            <strong>URL Generada:</strong>
            <button id="copy-utm" class="copy-button">Copiar Enlace</button>
        </div>
        <div id="utm-output" class="result-url">
            https://ejemplo.com?utm_source=google&utm_medium=cpc&utm_campaign=oferta_verano
        </div>
    </div>
</div>

<script>
    const inputs = [
        "utm-url",
        "utm-source",
        "utm-medium",
        "utm-campaign",
        "utm-term",
        "utm-content",
    ];
    const output = document.getElementById("utm-output");
    const copyBtn = document.getElementById("copy-utm");

    const updateUrl = () => {
        const values: Record<string, string> = {};
        inputs.forEach((id) => {
            const el = document.getElementById(id) as HTMLInputElement;
            values[id] = el ? el.value.trim() : "";
        });

        if (!output) return;

        if (!values["utm-url"]) {
            output.textContent = "Introduce una URL válida";
            return;
        }

        try {
            const url = new URL(values["utm-url"]);
            const params = new URLSearchParams(url.search);

            if (values["utm-source"]) params.set("utm_source", values["utm-source"]);
            if (values["utm-medium"]) params.set("utm_medium", values["utm-medium"]);
            if (values["utm-campaign"]) params.set("utm_campaign", values["utm-campaign"]);
            if (values["utm-term"]) params.set("utm_term", values["utm-term"]);
            if (values["utm-content"]) params.set("utm_content", values["utm-content"]);

            url.search = params.toString();
            output.textContent = url.toString();
        } catch (e) {
            output.textContent = "URL no válida";
        }
    };

    inputs.forEach((id) => {
        document.getElementById(id)?.addEventListener("input", updateUrl);
    });

    copyBtn?.addEventListener("click", () => {
        if (!output) return;
        const text = output.textContent || "";
        navigator.clipboard.writeText(text).then(() => {
            if (copyBtn) {
                const oldText = copyBtn.textContent;
                copyBtn.textContent = "¡Copiado!";
                setTimeout(() => {
                    if (copyBtn) copyBtn.textContent = oldText;
                }, 2000);
            }
        });
    });

    updateUrl();
</script>
