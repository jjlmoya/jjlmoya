---
import { Icon } from "astro-icon/components";
import "./AmericanKitchenConverter.css";
---

<div class="akc-wrapper">
    <div class="akc-main-card">
        <div class="akc-tabs">
            <button class="akc-tab-btn active" data-tab="cups" aria-label="Tazas a Gramos">
                <Icon name="mdi:cup-outline" class="w-6 h-6" />
                <span>Tazas a Gramos</span>
            </button>
            <button class="akc-tab-btn" data-tab="spoons" aria-label="Cucharas a Gramos">
                <Icon name="mdi:silverware-spoon" class="w-6 h-6" />
                <span>Cucharas a Gramos</span>
            </button>
            <button class="akc-tab-btn" data-tab="temps" aria-label="Temperaturas de Horno">
                <Icon name="mdi:thermometer" class="w-6 h-6" />
                <span>Temperaturas</span>
            </button>
        </div>

        <div class="akc-tab-content active" id="content-cups">
            <div class="akc-step-title">
                <span class="akc-step-number">1</span>
                <span>Selecciona el Ingrediente</span>
            </div>
            <div class="akc-grid">
                <button
                    class="akc-item-card cup-item active"
                    data-density="120"
                    aria-label="Harina"
                >
                    <div class="akc-item-icon">
                        <Icon name="mdi:sack-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Harina</div>
                        <div class="akc-item-sub">120g / cup</div>
                    </div>
                </button>
                <button
                    class="akc-item-card cup-item"
                    data-density="200"
                    aria-label="Azúcar Blanco"
                >
                    <div class="akc-item-icon"><Icon name="mdi:spoon-sugar" class="w-8 h-8" /></div>
                    <div>
                        <div class="akc-item-name">Azúcar Blanco</div>
                        <div class="akc-item-sub">200g / cup</div>
                    </div>
                </button>
                <button
                    class="akc-item-card cup-item"
                    data-density="220"
                    aria-label="Azúcar Moreno"
                >
                    <div class="akc-item-icon">
                        <Icon name="mdi:shaker-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Azúcar Moreno</div>
                        <div class="akc-item-sub">220g / cup</div>
                    </div>
                </button>
                <button class="akc-item-card cup-item" data-density="115" aria-label="Azúcar Glas">
                    <div class="akc-item-icon"><Icon name="mdi:snowflake" class="w-8 h-8" /></div>
                    <div>
                        <div class="akc-item-name">Azúcar Glas</div>
                        <div class="akc-item-sub">115g / cup</div>
                    </div>
                </button>
                <button class="akc-item-card cup-item" data-density="227" aria-label="Mantequilla">
                    <div class="akc-item-icon">
                        <Icon name="mdi:cube-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Mantequilla</div>
                        <div class="akc-item-sub">227g / cup</div>
                    </div>
                </button>
                <button class="akc-item-card cup-item" data-density="85" aria-label="Cacao">
                    <div class="akc-item-icon">
                        <Icon name="mdi:coffee-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Cacao en Polvo</div>
                        <div class="akc-item-sub">85g / cup</div>
                    </div>
                </button>
                <button class="akc-item-card cup-item" data-density="240" aria-label="Líquido">
                    <div class="akc-item-icon">
                        <Icon name="mdi:water-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Líquidos</div>
                        <div class="akc-item-sub">240g / cup</div>
                    </div>
                </button>
                <button class="akc-item-card cup-item" data-density="90" aria-label="Avena">
                    <div class="akc-item-icon">
                        <Icon name="mdi:bowl-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Avena</div>
                        <div class="akc-item-sub">90g / cup</div>
                    </div>
                </button>
            </div>

            <div class="akc-step-title">
                <span class="akc-step-number">2</span>
                <span>¿Cuántas Tazas (Cups)?</span>
            </div>
            <div class="akc-amount-control">
                <div class="akc-stepper">
                    <button class="akc-step-btn" id="cup-minus" aria-label="Restar">-</button>
                    <input
                        type="number"
                        class="akc-step-input"
                        id="cup-input"
                        value="1"
                        min="0"
                        step="0.25"
                        aria-label="Cantidad de Tazas"
                    />
                    <button class="akc-step-btn" id="cup-plus" aria-label="Sumar">+</button>
                </div>
                <div class="akc-quick-amounts">
                    <button class="akc-quick-btn cup-quick" data-val="0.25">1/4 Cup</button>
                    <button class="akc-quick-btn cup-quick" data-val="0.3333">1/3 Cup</button>
                    <button class="akc-quick-btn cup-quick" data-val="0.5">1/2 Cup</button>
                    <button class="akc-quick-btn cup-quick" data-val="1">1 Cup</button>
                </div>
            </div>

            <div class="akc-result-display">
                <div class="akc-result-value" id="cup-result">120</div>
                <div class="akc-result-unit">Gramos</div>
            </div>
        </div>

        <div class="akc-tab-content" id="content-spoons">
            <div class="akc-step-title">
                <span class="akc-step-number">1</span>
                <span>Selecciona la Medida</span>
            </div>
            <div class="akc-toggle">
                <button
                    class="akc-toggle-btn spoon-toggle active"
                    data-multiplier="1"
                    aria-label="Cucharada grande"
                >
                    Cucharada Grande (Tbsp)
                </button>
                <button
                    class="akc-toggle-btn spoon-toggle"
                    data-multiplier="0.3333"
                    aria-label="Cucharadita pequeña"
                >
                    Cucharadita Pequeña (tsp)
                </button>
            </div>

            <div class="akc-step-title">
                <span class="akc-step-number">2</span>
                <span>Selecciona el Ingrediente</span>
            </div>
            <div class="akc-grid">
                <button
                    class="akc-item-card spoon-item active"
                    data-density="15"
                    aria-label="Levadura Química"
                >
                    <div class="akc-item-icon">
                        <Icon name="mdi:flask-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Levadura</div>
                        <div class="akc-item-sub">Polvo Hornear</div>
                    </div>
                </button>
                <button class="akc-item-card spoon-item" data-density="18" aria-label="Sal">
                    <div class="akc-item-icon"><Icon name="mdi:shaker" class="w-8 h-8" /></div>
                    <div>
                        <div class="akc-item-name">Sal Fina</div>
                        <div class="akc-item-sub">Mineral</div>
                    </div>
                </button>
                <button
                    class="akc-item-card spoon-item"
                    data-density="15"
                    aria-label="Azúcar Blanco"
                >
                    <div class="akc-item-icon"><Icon name="mdi:spoon-sugar" class="w-8 h-8" /></div>
                    <div>
                        <div class="akc-item-name">Azúcar Blanco</div>
                        <div class="akc-item-sub">Granulado</div>
                    </div>
                </button>
                <button class="akc-item-card spoon-item" data-density="15" aria-label="Líquido">
                    <div class="akc-item-icon">
                        <Icon name="mdi:water-outline" class="w-8 h-8" />
                    </div>
                    <div>
                        <div class="akc-item-name">Líquidos</div>
                        <div class="akc-item-sub">Agua, Aceite</div>
                    </div>
                </button>
            </div>

            <div class="akc-step-title">
                <span class="akc-step-number">3</span>
                <span>Cantidad</span>
            </div>
            <div class="akc-amount-control">
                <div class="akc-stepper">
                    <button class="akc-step-btn" id="spoon-minus" aria-label="Restar">-</button>
                    <input
                        type="number"
                        class="akc-step-input"
                        id="spoon-input"
                        value="1"
                        min="0"
                        step="0.25"
                        aria-label="Cantidad"
                    />
                    <button class="akc-step-btn" id="spoon-plus" aria-label="Sumar">+</button>
                </div>
                <div class="akc-quick-amounts">
                    <button class="akc-quick-btn spoon-quick" data-val="0.25">1/4</button>
                    <button class="akc-quick-btn spoon-quick" data-val="0.5">1/2</button>
                    <button class="akc-quick-btn spoon-quick" data-val="1">1</button>
                    <button class="akc-quick-btn spoon-quick" data-val="2">2</button>
                </div>
            </div>

            <div class="akc-result-display">
                <div class="akc-result-value" id="spoon-result">15</div>
                <div class="akc-result-unit">Gramos / Mililitros</div>
            </div>
        </div>

        <div class="akc-tab-content" id="content-temps">
            <div class="akc-step-title">
                <span class="akc-step-number"><Icon name="mdi:fire" class="w-5 h-5" /></span>
                <span>Conversión de Horno</span>
            </div>
            <div class="akc-temps-container">
                <div class="akc-temp-box">
                    <div class="akc-temp-label">Fahrenheit (°F)</div>
                    <input
                        type="number"
                        class="akc-temp-input"
                        id="temp-f-input"
                        value="350"
                        aria-label="Fahrenheit"
                    />
                </div>
                <div class="akc-temp-middle">
                    <Icon name="mdi:swap-horizontal" class="w-8 h-8" />
                </div>
                <div class="akc-temp-box">
                    <div class="akc-temp-label">Celsius (°C)</div>
                    <input
                        type="number"
                        class="akc-temp-input"
                        id="temp-c-input"
                        value="177"
                        aria-label="Celsius"
                    />
                </div>
            </div>

            <div class="akc-step-title">
                <span class="akc-step-number"
                    ><Icon name="mdi:book-open-outline" class="w-5 h-5" /></span
                >
                <span>Temperaturas de Receta Frecuentes</span>
            </div>
            <div class="akc-presets">
                <button
                    class="akc-preset-card temp-preset"
                    data-f="275"
                    aria-label="Set 275 Fahrenheit"
                >
                    <div class="akc-preset-temp">275°F</div>
                    <div class="akc-preset-desc">135°C - Secado</div>
                </button>
                <button
                    class="akc-preset-card temp-preset"
                    data-f="325"
                    aria-label="Set 325 Fahrenheit"
                >
                    <div class="akc-preset-temp">325°F</div>
                    <div class="akc-preset-desc">165°C - Bizcocho denso</div>
                </button>
                <button
                    class="akc-preset-card temp-preset"
                    data-f="350"
                    aria-label="Set 350 Fahrenheit"
                >
                    <div class="akc-preset-temp">350°F</div>
                    <div class="akc-preset-desc">175°C - Estándar pasteles</div>
                </button>
                <button
                    class="akc-preset-card temp-preset"
                    data-f="400"
                    aria-label="Set 400 Fahrenheit"
                >
                    <div class="akc-preset-temp">400°F</div>
                    <div class="akc-preset-desc">200°C - Panes / Tartas</div>
                </button>
                <button
                    class="akc-preset-card temp-preset"
                    data-f="425"
                    aria-label="Set 425 Fahrenheit"
                >
                    <div class="akc-preset-temp">425°F</div>
                    <div class="akc-preset-desc">220°C - Pizzas / Hojaldre</div>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function initKitchen() {
        const tabs = document.querySelectorAll(".akc-tab-btn");
        const contents = document.querySelectorAll(".akc-tab-content");

        tabs.forEach((tab) => {
            tab.addEventListener("click", () => {
                const targetId = tab.getAttribute("data-tab");
                if (!targetId) return;

                tabs.forEach((t) => t.classList.remove("active"));
                tab.classList.add("active");

                contents.forEach((c) => {
                    if (c.id === `content-${targetId}`) {
                        c.classList.add("active");
                    } else {
                        c.classList.remove("active");
                    }
                });
            });
        });

        let currentCupDensity = 120;
        const cupItems = document.querySelectorAll(".cup-item");
        const cupInput = document.getElementById("cup-input") as HTMLInputElement | null;
        const cupResult = document.getElementById("cup-result");
        const cupPlus = document.getElementById("cup-plus");
        const cupMinus = document.getElementById("cup-minus");
        const cupQuicks = document.querySelectorAll(".cup-quick");

        function updateCups() {
            if (!cupInput || !cupResult) return;
            let val = parseFloat(cupInput.value);
            if (isNaN(val) || val < 0) val = 0;
            cupResult.textContent = Math.round(val * currentCupDensity).toString();
        }

        cupItems.forEach((item) => {
            item.addEventListener("click", () => {
                cupItems.forEach((i) => i.classList.remove("active"));
                item.classList.add("active");
                const density = item.getAttribute("data-density");
                if (density) {
                    currentCupDensity = parseFloat(density);
                    updateCups();
                }
            });
        });

        if (cupInput) {
            cupInput.addEventListener("input", updateCups);
        }

        if (cupPlus && cupInput) {
            cupPlus.addEventListener("click", () => {
                const current = parseFloat(cupInput.value) || 0;
                cupInput.value = (current + 0.25).toString();
                updateCups();
            });
        }

        if (cupMinus && cupInput) {
            cupMinus.addEventListener("click", () => {
                const current = parseFloat(cupInput.value) || 0;
                const newVal = current - 0.25;
                if (newVal >= 0) {
                    cupInput.value = newVal.toString();
                    updateCups();
                }
            });
        }

        cupQuicks.forEach((btn) => {
            btn.addEventListener("click", () => {
                const val = btn.getAttribute("data-val");
                if (val && cupInput) {
                    cupInput.value = val;
                    updateCups();
                }
            });
        });

        let currentSpoonDensity = 15;
        let currentSpoonMultiplier = 1;

        const spoonItems = document.querySelectorAll(".spoon-item");
        const spoonToggles = document.querySelectorAll(".spoon-toggle");
        const spoonInput = document.getElementById("spoon-input") as HTMLInputElement | null;
        const spoonResult = document.getElementById("spoon-result");
        const spoonPlus = document.getElementById("spoon-plus");
        const spoonMinus = document.getElementById("spoon-minus");
        const spoonQuicks = document.querySelectorAll(".spoon-quick");

        function updateSpoons() {
            if (!spoonInput || !spoonResult) return;
            let val = parseFloat(spoonInput.value);
            if (isNaN(val) || val < 0) val = 0;
            let resultStr = "";
            if (currentSpoonMultiplier === 0.3333) {
                resultStr = ((val * currentSpoonDensity) / 3).toFixed(1).replace(".0", "");
            } else {
                resultStr = (val * currentSpoonDensity).toFixed(1).replace(".0", "");
            }
            spoonResult.textContent = resultStr;
        }

        spoonItems.forEach((item) => {
            item.addEventListener("click", () => {
                spoonItems.forEach((i) => i.classList.remove("active"));
                item.classList.add("active");
                const density = item.getAttribute("data-density");
                if (density) {
                    currentSpoonDensity = parseFloat(density);
                    updateSpoons();
                }
            });
        });

        spoonToggles.forEach((toggle) => {
            toggle.addEventListener("click", () => {
                spoonToggles.forEach((t) => t.classList.remove("active"));
                toggle.classList.add("active");
                const mult = toggle.getAttribute("data-multiplier");
                if (mult) {
                    currentSpoonMultiplier = parseFloat(mult);
                    updateSpoons();
                }
            });
        });

        if (spoonInput) {
            spoonInput.addEventListener("input", updateSpoons);
        }

        if (spoonPlus && spoonInput) {
            spoonPlus.addEventListener("click", () => {
                const current = parseFloat(spoonInput.value) || 0;
                spoonInput.value = (current + 0.25).toString();
                updateSpoons();
            });
        }

        if (spoonMinus && spoonInput) {
            spoonMinus.addEventListener("click", () => {
                const current = parseFloat(spoonInput.value) || 0;
                const newVal = current - 0.25;
                if (newVal >= 0) {
                    spoonInput.value = newVal.toString();
                    updateSpoons();
                }
            });
        }

        spoonQuicks.forEach((btn) => {
            btn.addEventListener("click", () => {
                const val = btn.getAttribute("data-val");
                if (val && spoonInput) {
                    spoonInput.value = val;
                    updateSpoons();
                }
            });
        });

        const tempF = document.getElementById("temp-f-input") as HTMLInputElement | null;
        const tempC = document.getElementById("temp-c-input") as HTMLInputElement | null;
        const tempPresets = document.querySelectorAll(".temp-preset");

        function updateTempFromF() {
            if (!tempF || !tempC) return;
            const f = parseFloat(tempF.value);
            if (isNaN(f)) {
                tempC.value = "";
                return;
            }
            const c = ((f - 32) * 5) / 9;
            tempC.value = Math.round(c).toString();
        }

        function updateTempFromC() {
            if (!tempF || !tempC) return;
            const c = parseFloat(tempC.value);
            if (isNaN(c)) {
                tempF.value = "";
                return;
            }
            const f = (c * 9) / 5 + 32;
            tempF.value = Math.round(f).toString();
        }

        if (tempF) tempF.addEventListener("input", updateTempFromF);
        if (tempC) tempC.addEventListener("input", updateTempFromC);

        tempPresets.forEach((preset) => {
            preset.addEventListener("click", () => {
                const f = preset.getAttribute("data-f");
                if (f && tempF) {
                    tempF.value = f;
                    updateTempFromF();
                }
            });
        });

        updateCups();
        updateSpoons();
    }

    initKitchen();
</script>
