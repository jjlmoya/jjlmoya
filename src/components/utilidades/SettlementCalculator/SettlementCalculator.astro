---
import { Icon } from "astro-icon/components";
import "./SettlementCalculator.css";
---

<div class="settlement-calculator-container">
    <div class="calc-card fade-in">
        <div class="input-grid">
            <div class="input-group">
                <label for="salary-input">Sueldo Bruto Anual</label>
                <div class="input-wrapper">
                    <input
                        type="number"
                        id="salary-input"
                        placeholder="Ej. 24000"
                        min="0"
                        value="24000"
                    />
                    <span class="input-unit">€</span>
                </div>
            </div>

            <div class="input-group">
                <label for="extra-payments">Pagas Extra al año</label>
                <div class="input-wrapper">
                    <select id="extra-payments">
                        <option value="12">12 pagas (Prorrateadas)</option>
                        <option value="14" selected>14 pagas (Estándar)</option>
                    </select>
                </div>
            </div>

            <div class="input-group">
                <label for="start-date">Fecha de Inicio</label>
                <div class="input-wrapper">
                    <input type="date" id="start-date" value="2023-01-01" />
                </div>
            </div>

            <div class="input-group">
                <label for="end-date">Fecha de Fin</label>
                <div class="input-wrapper">
                    <input type="date" id="end-date" value="2025-12-31" />
                </div>
            </div>

            <div class="input-group">
                <label for="vacation-days">Vacaciones No Disfrutadas</label>
                <div class="input-wrapper">
                    <input
                        type="number"
                        id="vacation-days"
                        placeholder="Días pendientes"
                        min="0"
                        value="0"
                    />
                    <span class="input-unit">días</span>
                </div>
            </div>

            <div class="input-group">
                <label for="departure-reason">Motivo de la Salida</label>
                <div class="input-wrapper">
                    <select id="departure-reason">
                        <option value="improcedente">Despido Improcedente (33 días)</option>
                        <option value="objetivo">Despido Objetivo (20 días)</option>
                        <option value="temporal">Fin de Contrato Temporal (12 días)</option>
                        <option value="voluntaria" selected
                            >Baja Voluntaria (Sin indemnización)</option
                        >
                    </select>
                </div>
            </div>
        </div>

        <div class="results-summary" id="results-area">
            <div class="total-header">
                <span class="total-label">Liquidación Total Estimada</span>
                <span class="total-value" id="total-settlement">0,00 €</span>
            </div>

            <div class="breakdown-grid">
                <div class="breakdown-item">
                    <span class="breakdown-label">Indemnización por Despido</span>
                    <span class="breakdown-value" id="val-severance">0,00 €</span>
                </div>
                <div class="breakdown-item">
                    <span class="breakdown-label">Vacaciones no Disfrutadas</span>
                    <span class="breakdown-value" id="val-vacation">0,00 €</span>
                </div>
                <div class="breakdown-item">
                    <span class="breakdown-label">Prorrateo Pagas Extra</span>
                    <span class="breakdown-value" id="val-extras">0,00 €</span>
                </div>
                <div class="breakdown-item">
                    <span class="breakdown-label">Salario del Mes</span>
                    <span class="breakdown-value" id="val-month-salary">0,00 €</span>
                </div>
            </div>

            <div class="info-alert">
                <Icon name="mdi:information-outline" size={24} />
                <p>
                    <strong>Nota Importante:</strong> Este cálculo es una estimación bruta aproximada
                    basada en la legislación española general. El importe final puede variar según convenios
                    colectivos, retenciones de IRPF y Seguridad Social.
                </p>
            </div>
        </div>

        <div class="action-bar">
            <button class="btn-primary" id="copy-summary">
                <Icon name="mdi:content-copy" size={20} />
                Copiar Resumen
            </button>
        </div>
    </div>
</div>

<script>
    const salaryInput = document.getElementById("salary-input") as HTMLInputElement | null;
    const extraPaymentsSelect = document.getElementById(
        "extra-payments"
    ) as HTMLSelectElement | null;
    const startDateInput = document.getElementById("start-date") as HTMLInputElement | null;
    const endDateInput = document.getElementById("end-date") as HTMLInputElement | null;
    const vacationInput = document.getElementById("vacation-days") as HTMLInputElement | null;
    const reasonSelect = document.getElementById("departure-reason") as HTMLSelectElement | null;

    const totalDisplay = document.getElementById("total-settlement");
    const severanceDisplay = document.getElementById("val-severance");
    const vacationDisplay = document.getElementById("val-vacation");
    const extrasDisplay = document.getElementById("val-extras");
    const salaryDisplay = document.getElementById("val-month-salary");
    const copyBtn = document.getElementById("copy-summary");

    function formatCurrency(val: number): string {
        return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
        }).format(val);
    }

    function calculate() {
        if (
            !salaryInput ||
            !extraPaymentsSelect ||
            !startDateInput ||
            !endDateInput ||
            !vacationInput ||
            !reasonSelect
        )
            return;

        const salaryAnual = parseFloat(salaryInput.value) || 0;
        const extraPagas = parseInt(extraPaymentsSelect.value) || 12;
        const vacationDays = parseFloat(vacationInput.value) || 0;
        const reason = reasonSelect.value;

        const start = new Date(startDateInput.value);
        const end = new Date(endDateInput.value);

        if (isNaN(start.getTime()) || isNaN(end.getTime()) || end < start) {
            return;
        }

        const dailySalary = salaryAnual / 365;
        const monthlySalary = salaryAnual / 12;

        const diffTime = Math.abs(end.getTime() - start.getTime());
        const totalDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
        const yearsWorked = totalDays / 365;

        let severanceDaysYear = 0;
        if (reason === "improcedente") severanceDaysYear = 33;
        if (reason === "objetivo") severanceDaysYear = 20;
        if (reason === "temporal") severanceDaysYear = 12;

        let severance = Math.min(
            severanceDaysYear * yearsWorked * dailySalary,
            dailySalary * 365 * 2
        );
        if (reason === "improcedente") {
            const maxSeverance = dailySalary * 24 * 30;
            severance = Math.min(severance, maxSeverance);
        } else if (reason === "objetivo") {
            const maxSeverance = dailySalary * 12 * 30;
            severance = Math.min(severance, maxSeverance);
        }

        const vacationMoney = vacationDays * dailySalary;

        let extraMoney = 0;
        if (extraPagas === 14) {
            extraMoney =
                (monthlySalary / 182.5) * (totalDaysIntoPeriod(startOfYear(end), end) % 182.5);
        }

        const salaryOfMonth = (end.getDate() / 30) * monthlySalary;

        const totalSettlement = severance + vacationMoney + extraMoney + salaryOfMonth;

        if (totalDisplay) totalDisplay.textContent = formatCurrency(totalSettlement);
        if (severanceDisplay) severanceDisplay.textContent = formatCurrency(severance);
        if (vacationDisplay) vacationDisplay.textContent = formatCurrency(vacationMoney);
        if (extrasDisplay) extrasDisplay.textContent = formatCurrency(extraMoney);
        if (salaryDisplay) salaryDisplay.textContent = formatCurrency(salaryOfMonth);

        totalDisplay?.classList.add("animate-pulse-once");
        setTimeout(() => totalDisplay?.classList.remove("animate-pulse-once"), 500);
    }

    function startOfYear(date: Date) {
        return new Date(date.getFullYear(), 0, 1);
    }
    function totalDaysIntoPeriod(start: Date, current: Date) {
        return Math.ceil((current.getTime() - start.getTime()) / (1000 * 60 * 60 * 24)) + 1;
    }

    [
        salaryInput,
        extraPaymentsSelect,
        startDateInput,
        endDateInput,
        vacationInput,
        reasonSelect,
    ].forEach((el) => {
        el?.addEventListener("input", calculate);
    });

    copyBtn?.addEventListener("click", () => {
        const summary = `
Resumen de Liquidación Estimada:
--------------------------------
Total: ${totalDisplay?.textContent}
Indemnización: ${severanceDisplay?.textContent}
Vacaciones: ${vacationDisplay?.textContent}
Pagas Extra: ${extrasDisplay?.textContent}
Salario Mes: ${salaryDisplay?.textContent}

Calculado en jjlmoya.es
        `.trim();

        navigator.clipboard.writeText(summary);

        const originalText = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span style="color: #fff">¡Copiado!</span>';
        setTimeout(() => {
            copyBtn.innerHTML = originalText;
        }, 2000);
    });

    calculate();
</script>
