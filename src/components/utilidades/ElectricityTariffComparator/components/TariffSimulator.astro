---
import { Icon } from "astro-icon/components";
---

<div class="simulator-section panel animate-in fade-in slide-in-from-bottom duration-700 delay-800">
    <h3 class="panel-title">
        <Icon name="mdi:frequently-asked-questions" size={24} />
        Simulador de Escenarios "What-if"
    </h3>

    <div class="simulator-controls">
        <div class="sim-card">
            <div class="sim-header">
                <Icon name="mdi:solar-power-variant-outline" size={24} />
                <span>Autoconsumo Solar</span>
            </div>
            <div class="sim-content">
                <label class="toggle">
                    <input type="checkbox" id="solarToggle" />
                    <span class="slider"></span>
                </label>
                <p>Simular ahorro con placas solares (30% red. consumo)</p>
            </div>
        </div>

        <div class="sim-card">
            <div class="sim-header">
                <Icon name="mdi:clock-fast" size={24} />
                <span>Desplazamiento Valle</span>
            </div>
            <div class="sim-content">
                <input type="range" id="shiftSlider" min="0" max="50" step="5" value="0" />
                <p>Mueve consumo a horas baratas: <strong id="shiftVal">0%</strong></p>
            </div>
        </div>
    </div>
</div>

<style>
    .simulator-section {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 28px;
        padding: 2rem;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
        margin-top: 2rem;
    }

    :global(.dark) .simulator-section {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.05);
    }

    .panel-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.25rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 2rem;
    }

    :global(.dark) .panel-title {
        color: #f1f5f9;
    }

    .simulator-controls {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .sim-card {
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(0, 0, 0, 0.05);
        border-radius: 20px;
        padding: 1.5rem;
    }

    :global(.dark) .sim-card {
        background: rgba(255, 255, 255, 0.03);
        border-color: rgba(255, 255, 255, 0.05);
    }

    .sim-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 800;
        color: #475569;
        margin-bottom: 1rem;
    }

    :global(.dark) .sim-header {
        color: #94a3b8;
    }

    .sim-content p {
        font-size: 0.9rem;
        color: #64748b;
        margin-top: 0.75rem;
    }

    .toggle {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

    .toggle input { opacity: 0; width: 0; height: 0; }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #cbd5e1;
        transition: .4s;
        border-radius: 34px;
    }

    .slider:before {
        position: absolute;
        content: "";
        height: 18px; width: 18px;
        left: 4px; bottom: 4px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }

    input:checked + .slider { background-color: #f59e0b; }
    input:checked + .slider:before { transform: translateX(24px); }

    input[type="range"] {
        width: 100%;
        accent-color: #f59e0b;
    }
</style>
