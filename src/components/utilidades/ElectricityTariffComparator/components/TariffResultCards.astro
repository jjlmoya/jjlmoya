---
import { Icon } from "astro-icon/components";
---

<div class="comparison-grid">
    <div class="tariff-card market-card animate-in fade-in slide-in-from-left duration-700 delay-200">
        <div class="card-header">
            <span class="tariff-type">PVPC (Mercado Regulado)</span>
            <Icon name="mdi:shield-check" size={32} class="text-amber-500" />
        </div>
        
        <div class="price-main">
            <span id="marketTotal" class="total-annual">0€</span>
            <span class="unit">Estimación anual</span>
        </div>

        <div class="price-details">
            <div class="detail-row">
                <span>Potencia (Fijo)</span>
                <span id="marketPowerPrice">0€</span>
            </div>
            <div class="detail-row">
                <span>Consumo (Variable)</span>
                <span id="marketEnergyPrice">0€</span>
            </div>
        </div>

        <div id="marketBadge" class="saving-badge">
            <Icon name="mdi:information-outline" />
            <span>Precio indexado</span>
        </div>
    </div>

    <div class="tariff-card free-card animate-in fade-in slide-in-from-right duration-700 delay-400">
        <div class="card-header">
            <span class="tariff-type">Mercado Libre (Precio Fijo)</span>
            <Icon name="mdi:lightning-bolt" size={32} class="text-sky-500" />
        </div>
        
        <div class="price-main">
            <span id="freeTotal" class="total-annual">0€</span>
            <span class="unit">Estimación anual</span>
        </div>

        <div class="price-details">
            <div class="detail-row">
                <span>Potencia (Fijo)</span>
                <span id="freePowerPrice">0€</span>
            </div>
            <div class="detail-row">
                <span>Consumo (Variable)</span>
                <span id="freeEnergyPrice">0€</span>
            </div>
        </div>

        <div id="freeBadge" class="saving-badge">
            <Icon name="mdi:trending-up" />
            <span>Seguridad de precio</span>
        </div>
    </div>
</div>

<style>
    .comparison-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .comparison-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .tariff-card {
        border-radius: 28px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .tariff-card:hover {
        transform: translateY(-8px);
    }

    .market-card {
        background: linear-gradient(135deg, #fef3c7 0%, #fffbeb 100%);
        border: 1px solid #fde68a;
    }

    :global(.dark) .market-card {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, rgba(245, 158, 11, 0.05) 100%);
        border-color: rgba(245, 158, 11, 0.2);
    }

    .free-card {
        background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
        border: 1px solid #bae6fd;
    }

    :global(.dark) .free-card {
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.1) 0%, rgba(14, 165, 233, 0.05) 100%);
        border-color: rgba(14, 165, 233, 0.2);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .tariff-type {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0.4rem 0.75rem;
        border-radius: 20px;
    }

    .market-card .tariff-type { background: #fbbf24; color: #78350f; }
    .free-card .tariff-type { background: #38bdf8; color: #0c4a6e; }

    .price-main {
        display: flex;
        flex-direction: column;
    }

    .total-annual {
        font-size: 3rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: #0f172a;
    }

    :global(.dark) .total-annual {
        color: #f8fafc;
    }

    .unit {
        font-size: 0.9rem;
        font-weight: 600;
        color: #64748b;
    }

    .price-details {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1.5rem 0;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    :global(.dark) .price-details {
        border-top-color: rgba(255, 255, 255, 0.1);
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.95rem;
        font-weight: 600;
        color: #475569;
    }

    :global(.dark) .detail-row {
        color: #94a3b8;
    }

    .saving-badge {
        align-self: flex-start;
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    :global(.better-option) {
        background: #10b981;
        color: white;
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
    }

    :global(.worse-option) {
        background: #f1f5f9;
        color: #64748b;
    }

    :global(.dark .worse-option) {
        background: #1e293b;
        color: #4b5563;
    }
</style>
