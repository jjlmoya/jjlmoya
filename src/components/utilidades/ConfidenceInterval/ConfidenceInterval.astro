---
import { Icon } from "astro-icon/components";
import "./ConfidenceInterval.css";
---

<div class="confidence-card" id="confidenceApp">
    <aside class="confidence-sidebar">
        <header class="sidebar-heading">
            <Icon name="mdi:chart-scatter-plot" /> Configuración
        </header>

        <div class="tab-nav" id="modeSwitch">
            <button class="tab-btn active" data-mode="raw">Datos Crudos</button>
            <button class="tab-btn" data-mode="stats">Estadísticos</button>
        </div>

        <div id="rawFields" class="input-group">
            <label for="rawData">Pegar Datos (CSV/Excel)</label>
            <div class="textarea-wrapper">
                <textarea id="rawData" placeholder="Ej: 10.5, 12.2, 9.8..."></textarea>
                <button id="clearRawBtn" class="textarea-clear-btn" title="Limpiar datos">
                    <Icon name="mdi:trash-can-outline" size={14} />
                </button>
            </div>
        </div>

        <div id="statsFields" style="display: none; flex-direction: column; gap: 1.5rem;">
            <div class="input-group">
                <label for="meanInp">Media (&mu;)</label>
                <input type="number" id="meanInp" value="100" step="any" />
            </div>
            <div class="input-group">
                <label for="stdInp">Desv. Típica (&sigma;)</label>
                <input type="number" id="stdInp" value="15" step="any" min="0.0001" />
            </div>
            <div class="input-group">
                <label for="nInp">Muestra (n)</label>
                <input type="number" id="nInp" value="50" step="1" min="1" />
            </div>
        </div>

        <div class="input-group">
            <label for="confInp">Nivel de Confianza (%)</label>
            <select id="confInp">
                <option value="0.90">90% — Z* = 1.645</option>
                <option value="0.95" selected>95% — Z* = 1.960</option>
                <option value="0.99">99% — Z* = 2.576</option>
                <option value="custom">Personalizado...</option>
            </select>
        </div>

        <div class="input-group" id="customConfGroup" style="display: none;">
            <label for="customConf">Confianza Personalizada (0-100)</label>
            <input type="number" id="customConf" value="95" step="any" min="0.01" max="99.99" />
        </div>

        <div class="input-group">
            <label for="targetMargin">¿Cuántos datos necesito? — Margen objetivo (E)</label>
            <input type="number" id="targetMargin" placeholder="Ej: 2.5" step="any" min="0.0001" />
            <div id="nRequired" class="n-badge">Introduce E para calcular n mínimo</div>
        </div>

        <div style="margin-top: auto; padding-top: 1rem; border-top: 1px dashed rgba(16, 185, 129, 0.1); font-size: 0.7rem; color: #94a3b8; display: flex; align-items: center; gap: 0.5rem; line-height: 1.4;">
            <Icon name="mdi:shield-lock-outline" size={16} />
            <span>Los datos se analizan localmente bajo el modelo de distribución normal.</span>
        </div>
    </aside>

    <main class="confidence-main">
        <header class="results-grid">
            <div class="res-card">
                <span class="res-label">Intervalo de Confianza</span>
                <span id="intervalVal" class="res-value">[0, 0]</span>
                <span id="intervalSub" style="font-size: 0.8rem; font-weight: 800; color: #94a3b8; margin-top: 5px;">Rango estimado poblacional</span>
            </div>
            <div class="res-card">
                <span class="res-label">Margen de Error (E)</span>
                <span id="errorVal" class="res-value" style="background: linear-gradient(135deg, #0d9488, #0891b2); -webkit-background-clip: text; background-clip: text;">&plusmn; 0.00</span>
                <span id="zValSub" style="font-size: 0.8rem; font-weight: 800; color: #94a3b8; margin-top: 5px;">Basado en Z* calculada</span>
            </div>
        </header>

        <div class="visual-area">
            <canvas id="gaussCanvas"></canvas>
            <div id="errorOverlay" style="position: absolute; inset: 0; background: rgba(255,255,255,0.9); display: none; align-items: center; justify-content: center; z-index: 10; border-radius: 2.5rem;">
                <p style="color: #ef4444; font-weight: 900; font-size: 0.9rem; text-transform: uppercase;">Error: Verifica los datos de entrada</p>
            </div>
        </div>

        <div id="interpretation" class="interpretation-bar">
            Introduce datos para generar el intervalo...
        </div>

        <div id="simpleExplanation" class="simple-explanation" style="display: none;"></div>

        <button id="toggleSimpleBtn" class="simple-toggle-btn" style="display: none;">
            <Icon name="mdi:lightbulb-outline" size={14} /> <span id="toggleSimpleLbl">Ver explicación simple</span>
        </button>

        <footer class="action-row">
            <div class="stats-info" style="display: flex; gap: 1.5rem; font-size: 0.8rem; font-weight: 700; color: #64748b;">
                <div id="calcMean">Media: 0</div>
                <div id="calcStd">Desv: 0</div>
                <div id="calcN">n: 0</div>
            </div>
            <div class="round-btn-group" style="display: flex; gap: 0.75rem;">
                <button id="clearBtn" class="btn-icon-round" title="Limpiar datos">
                    <Icon name="mdi:trash-can-outline" />
                </button>
                <button id="copyBtn" class="btn-icon-round" title="Copiar resultados">
                    <Icon name="mdi:content-copy" />
                </button>
            </div>
        </footer>
    </main>
</div>

<script>
    const meanInp = document.getElementById('meanInp') as HTMLInputElement;
    const stdInp = document.getElementById('stdInp') as HTMLInputElement;
    const nInp = document.getElementById('nInp') as HTMLInputElement;
    const rawInp = document.getElementById('rawData') as HTMLTextAreaElement;
    const confSel = document.getElementById('confInp') as HTMLSelectElement;
    const customConfInp = document.getElementById('customConf') as HTMLInputElement;
    const modeSwitch = document.getElementById('modeSwitch');
    const canvas = document.getElementById('gaussCanvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d');
    const errorOverlay = document.getElementById('errorOverlay');
    const copyBtn = document.getElementById('copyBtn');
    const clearBtn = document.getElementById('clearBtn');
    const clearRawBtn = document.getElementById('clearRawBtn');
    const targetMarginInp = document.getElementById('targetMargin') as HTMLInputElement;
    const toggleSimpleBtn = document.getElementById('toggleSimpleBtn');

    const ui = {
        interval: document.getElementById('intervalVal'),
        error: document.getElementById('errorVal'),
        interp: document.getElementById('interpretation'),
        calcMean: document.getElementById('calcMean'),
        calcStd: document.getElementById('calcStd'),
        calcN: document.getElementById('calcN'),
        zSub: document.getElementById('zValSub'),
        customGroup: document.getElementById('customConfGroup'),
        rawFields: document.getElementById('rawFields'),
        statsFields: document.getElementById('statsFields'),
        simpleExpl: document.getElementById('simpleExplanation'),
        nRequired: document.getElementById('nRequired'),
    };

    let simpleVisible = false;
    let lastConf = 0.95;
    let lastZCrit = 1.96;
    let lastStd = 15;
    let lastLow = 0, lastHigh = 0;

    let currentMode = 'raw';
    const LS_KEY = 'jjlmoya_confidence_interval';

    const invPhi = (p: number): number => {
        const p_prime = p < 0.5 ? p : 1 - p;
        const t = Math.sqrt(-2 * Math.log(p_prime));
        const z = t - (2.515517 + 0.802853 * t + 0.010328 * t * t) / (1 + 1.432788 * t + 0.189269 * t * t + 0.001308 * t * t * t);
        return p < 0.5 ? -z : z;
    };

    const drawGauss = (mean: number, std: number, n: number, zCritical: number) => {
        if (!ctx || !canvas) return;
        const rect = canvas.parentElement!.getBoundingClientRect();
        const dpr = window.devicePixelRatio || 1;
        if (canvas.width !== Math.floor(rect.width * dpr) || canvas.height !== Math.floor(rect.height * dpr)) {
            canvas.width = Math.floor(rect.width * dpr);
            canvas.height = Math.floor(rect.height * dpr);
        }
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const w = rect.width, h = rect.height, pad = 50, bPad = 50;
        ctx.clearRect(0, 0, w, h);

        const se = std / Math.sqrt(n);
        const xMin = mean - 4.5 * se, xMax = mean + 4.5 * se;
        const mapX = (x: number) => pad + (x - xMin) * (w - 2 * pad) / (xMax - xMin);
        const pdf = (x: number) => (1 / (se * Math.sqrt(2 * Math.PI))) * Math.exp(-0.5 * Math.pow((x - mean) / se, 2));
        const maxPdf = pdf(mean);
        const mapY = (y: number) => (h - bPad) - (y * (h - bPad - 20) / maxPdf);

        const v1 = mean - zCritical * se, v2 = mean + zCritical * se;

        ctx.fillStyle = 'rgba(16, 185, 129, 0.12)';
        ctx.beginPath();
        const drawPoints = [];
        const step = (xMax - xMin) / 120;
        for (let x = xMin; x <= xMax; x += step) {
            if (x >= v1 && x <= v2) drawPoints.push(x);
        }
        drawPoints.push(v1); drawPoints.push(v2);
        drawPoints.sort((a,b) => a-b);
        if (drawPoints.length > 0) {
            ctx.moveTo(mapX(drawPoints[0]), mapY(0));
            drawPoints.forEach(x => ctx.lineTo(mapX(x), mapY(pdf(x))));
            ctx.lineTo(mapX(drawPoints[drawPoints.length-1]), mapY(0));
            ctx.closePath(); ctx.fill();
        }

        ctx.strokeStyle = '#10b981'; ctx.lineWidth = 4; ctx.beginPath();
        for (let x = xMin; x <= xMax; x += step) ctx.lineTo(mapX(x), mapY(pdf(x)));
        ctx.stroke();

        ctx.strokeStyle = '#e2e8f0'; ctx.lineWidth = 2; ctx.beginPath();
        ctx.moveTo(pad, h - bPad); ctx.lineTo(w - pad, h - bPad); ctx.stroke();

        const mark = (v: number, label: string, color: string) => {
            const x = mapX(v);
            ctx.strokeStyle = color; ctx.setLineDash([5, 4]); ctx.beginPath();
            ctx.moveTo(x, h - bPad); ctx.lineTo(x, mapY(pdf(v))); ctx.stroke();
            ctx.setLineDash([]);
            ctx.fillStyle = color; ctx.font = 'bold 0.7rem sans-serif'; ctx.textAlign = 'center';
            ctx.fillText(label, x, h - bPad + 20);
            ctx.fillText(v.toFixed(3), x, h - bPad + 32);
        };

        mark(mean, 'Media', '#64748b');
        mark(v1, 'L. Inferior', '#059669');
        mark(v2, 'L. Superior', '#059669');
    };

    const update = () => {
        let m = 0, s = 0, n = 1;
        if (currentMode === 'raw') {
            const data = rawInp.value.split(/[\s,;\t\n]+/).map(v => parseFloat(v)).filter(v => !isNaN(v));
            if (data.length < 2) { errorOverlay!.style.display = 'flex'; return; }
            n = data.length;
            m = data.reduce((a, b) => a + b, 0) / n;
            s = Math.sqrt(data.reduce((a, b) => a + Math.pow(b - m, 2), 0) / (n - 1)) || 0.0001;
        } else {
            m = parseFloat(meanInp.value) || 0;
            s = parseFloat(stdInp.value) || 0.0001;
            n = parseInt(nInp.value) || 1;
        }

        if (n <= 0 || s <= 0) { errorOverlay!.style.display = 'flex'; return; }
        errorOverlay!.style.display = 'none';

        let conf = parseFloat(confSel.value);
        if (confSel.value === 'custom') {
            conf = parseFloat(customConfInp.value) / 100;
        }
        if (isNaN(conf) || conf <= 0 || conf >= 1) conf = 0.95;

        const alpha = 1 - conf;
        const zCrit = Math.abs(invPhi(1 - alpha / 2));
        const marginError = zCrit * (s / Math.sqrt(n));

        ui.interval!.textContent = `[${(m - marginError).toFixed(3)}, ${(m + marginError).toFixed(3)}]`;
        ui.error!.textContent = `\u00b1 ${marginError.toFixed(3)}`;
        ui.zSub!.textContent = `Valor Cr\u00edtico Z* = ${zCrit.toFixed(3)}`;
        ui.calcMean!.textContent = `Media: ${m.toFixed(2)}`;
        ui.calcStd!.textContent = `Desv: ${s.toFixed(2)}`;
        ui.calcN!.textContent = `n: ${n}`;

        const pct = (conf * 100).toFixed(0);
        const low = (m - marginError).toFixed(3), high = (m + marginError).toFixed(3);
        ui.interp!.textContent = `Tenemos una confianza del ${pct}% de que el valor real de la población está entre ${low} y ${high}.`;

        lastConf = conf; lastZCrit = zCrit; lastStd = s;
        lastLow = m - marginError; lastHigh = m + marginError;

        const simpleText = `Si repitiéramos este estudio 100 veces, en ${pct} de ellas el valor real de la población estaría dentro del intervalo [${low}, ${high}].`;
        ui.simpleExpl!.textContent = simpleText;
        toggleSimpleBtn!.style.display = 'flex';
        updateNRequired();

        drawGauss(m, s, n, zCrit);
        
        localStorage.setItem(LS_KEY, JSON.stringify({
            mode: currentMode,
            raw: rawInp.value,
            mean: meanInp.value,
            std: stdInp.value,
            n: nInp.value,
            conf: confSel.value,
            customConf: customConfInp.value
        }));
    };

    const updateNRequired = () => {
        const E = parseFloat(targetMarginInp.value);
        if (!isNaN(E) && E > 0 && lastStd > 0) {
            const n = Math.ceil(Math.pow((lastZCrit * lastStd) / E, 2));
            ui.nRequired!.textContent = `n mínimo necesario: ${n.toLocaleString()} datos`;
            ui.nRequired!.classList.add('n-badge--active');
        } else {
            ui.nRequired!.textContent = 'Introduce E para calcular n mínimo';
            ui.nRequired!.classList.remove('n-badge--active');
        }
    };

    clearRawBtn?.addEventListener('click', () => { rawInp.value = ''; update(); });

    toggleSimpleBtn?.addEventListener('click', () => {
        simpleVisible = !simpleVisible;
        ui.simpleExpl!.style.display = simpleVisible ? 'block' : 'none';
        document.getElementById('toggleSimpleLbl')!.textContent = simpleVisible ? 'Ocultar explicación' : 'Ver explicación simple';
    });

    targetMarginInp.addEventListener('input', updateNRequired);

    const load = () => {
        const saved = localStorage.getItem(LS_KEY);
        if (saved) {
            const data = JSON.parse(saved);
            currentMode = data.mode || 'raw';
            rawInp.value = data.raw || "";
            meanInp.value = data.mean || "100";
            stdInp.value = data.std || "15";
            nInp.value = data.n || "50";
            confSel.value = data.conf || "0.95";
            customConfInp.value = data.customConf || "95";
        } else {
            rawInp.value = "100, 105, 98, 102, 95, 108, 110, 92, 100, 103";
            meanInp.value = "100";
            stdInp.value = "15";
            nInp.value = "50";
        }
        
        modeSwitch?.querySelectorAll('.tab-btn').forEach(b => {
            const mode = (b as HTMLElement).dataset.mode;
            b.classList.toggle('active', mode === currentMode);
        });
        ui.rawFields!.style.display = currentMode === 'raw' ? 'flex' : 'none';
        ui.statsFields!.style.display = currentMode === 'stats' ? 'flex' : 'none';
        ui.customGroup!.style.display = confSel.value === 'custom' ? 'flex' : 'none';
        update();
    };

    modeSwitch?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.tab-btn');
        if (!btn) return;
        modeSwitch.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentMode = (btn as HTMLElement).dataset.mode!;
        ui.rawFields!.style.display = currentMode === 'raw' ? 'flex' : 'none';
        ui.statsFields!.style.display = currentMode === 'stats' ? 'flex' : 'none';
        update();
    });

    confSel.addEventListener('change', () => {
        ui.customGroup!.style.display = confSel.value === 'custom' ? 'flex' : 'none';
        update();
    });

    clearBtn?.addEventListener('click', () => {
        rawInp.value = "";
        meanInp.value = "100";
        stdInp.value = "15";
        nInp.value = "50";
        update();
    });

    [meanInp, stdInp, nInp, rawInp, customConfInp].forEach(el => el.addEventListener('input', update));
    copyBtn?.addEventListener('click', () => {
        const str = `Intervalo: ${ui.interval?.textContent}. Margen: ${ui.error?.textContent}. Confianza: ${confSel.value}. jjlmoya.es`;
        navigator.clipboard.writeText(str);
        const icon = copyBtn.innerHTML; copyBtn.innerHTML = 'Ok!';
        setTimeout(() => copyBtn.innerHTML = icon, 1200);
    });

    window.addEventListener('resize', update);
    load();
</script>
