---
import { Icon } from "astro-icon/components";
import "./PearsonCorrelation.css";
---

<div class="pearson-card" id="pearsonApp">
    <aside class="pearson-sidebar">
        <header class="sidebar-header">
            <h3><Icon name="mdi:database-import" /> Datos CSV</h3>
            <div class="btn-group">
                <button id="loadExample" class="icon-btn" title="Cargar ejemplo">
                    <Icon name="mdi:lightbulb-outline" />
                </button>
                <button id="clearData" class="icon-btn" title="Limpiar">
                    <Icon name="mdi:trash-can-outline" />
                </button>
            </div>
        </header>

        <textarea
            id="dataInput"
            class="data-textarea"
            placeholder="Pega tus datos (X, Y) o arrastra un CSV..."></textarea>

        <div
            class="setting-item"
            style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;"
        >
            <label
                for="decimalSeparator"
                style="font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase;"
                >Sep. Decimal</label
            >
            <select
                id="decimalSeparator"
                style="padding: 0.25rem 0.5rem; border-radius: 0.5rem; border: 1px solid #e2e8f0; font-size: 0.75rem; background: transparent; cursor: pointer;"
            >
                <option value=".">Punto (.)</option>
                <option value=",">Coma (,)</option>
            </select>
        </div>

        <div
            style="margin-top: auto; padding-top: 1rem; border-top: 1px dashed rgba(99, 102, 241, 0.1); font-size: 0.7rem; color: #94a3b8; display: flex; align-items: center; gap: 0.5rem;"
        >
            <Icon name="mdi:shield-check" size={14} />
            <span>Ejecución local privada</span>
        </div>
    </aside>

    <main class="pearson-main">
        <div class="results-top">
            <div class="main-stat-display">
                <div id="rValue" class="r-value-large">-</div>
                <div class="r-label-small">Coeficiente de Pearson (r)</div>
            </div>

            <div class="stats-detail-grid">
                <div class="stat-group">
                    <span class="stat-label">Determinación (r²)</span>
                    <span id="r2Value" class="stat-value">-</span>
                </div>
                <div class="stat-group">
                    <span class="stat-label">Parejas (n)</span>
                    <span id="nValue" class="stat-value">0</span>
                </div>
                <div class="stat-group">
                    <span class="stat-label">Pendiente (m)</span>
                    <span id="slopeValue" class="stat-value">-</span>
                </div>
                <div class="stat-group">
                    <span class="stat-label">Media X | Y</span>
                    <span class="stat-value" style="font-size: 1rem;"
                        ><span id="meanX">-</span> | <span id="meanY">-</span></span
                    >
                </div>
            </div>
        </div>

        <div class="chart-container-inner" id="canvasWrapper">
            <canvas id="scatterPlot"></canvas>
            <div
                id="errorLabel"
                style="position: absolute; inset: 0; background: rgba(255,255,255,0.9); display: none; flex-direction: column; align-items: center; justify-content: center; border-radius: 1.5rem; color: #ef4444; font-weight: 600; font-size: 0.85rem; text-align: center; padding: 2rem;"
            >
                <Icon name="mdi:alert-circle" size={32} />
                <p id="errorMsg">Introduce al menos 2 pares de datos para graficar</p>
            </div>
        </div>

        <div class="actions-row">
            <div
                id="interpretation"
                class="interp-badge"
                style="background: rgba(99, 102, 241, 0.05); color: #64748b;"
            >
                Esperando datos...
            </div>

            <div class="btn-group">
                <div
                    id="regressionEq"
                    style="font-size: 0.75rem; color: #64748b; margin-right: 1rem; align-self: center; display: none;"
                >
                    y = mx + b
                </div>
                <button id="copyResults" class="icon-btn" title="Copiar resultados">
                    <Icon name="mdi:content-copy" />
                </button>
                <button id="downloadChart" class="icon-btn" title="Descargar gráfico">
                    <Icon name="mdi:download" />
                </button>
            </div>
        </div>
    </main>
</div>

<script>
    const dataInput = document.getElementById("dataInput") as HTMLTextAreaElement;
    const decimalSep = document.getElementById("decimalSeparator") as HTMLSelectElement;
    const loadExampleBtn = document.getElementById("loadExample");
    const clearDataBtn = document.getElementById("clearData");
    const downloadChartBtn = document.getElementById("downloadChart");
    const copyResultsBtn = document.getElementById("copyResults");
    const errorLabel = document.getElementById("errorLabel");
    const errorMsg = document.getElementById("errorMsg");
    const canvas = document.getElementById("scatterPlot") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d");
    const regressionEq = document.getElementById("regressionEq");

    const ui = {
        r: document.getElementById("rValue"),
        r2: document.getElementById("r2Value"),
        n: document.getElementById("nValue"),
        slope: document.getElementById("slopeValue"),
        meanX: document.getElementById("meanX"),
        meanY: document.getElementById("meanY"),
        inter: document.getElementById("interpretation"),
    };

    interface Point {
        x: number;
        y: number;
    }

    const EXAMPLE_DATA = "10, 15\n12, 18\n15, 22\n18, 28\n20, 32\n22, 35\n25, 42\n30, 50";

    const cleanValue = (val: string, sep: string): number | null => {
        let cleaned = val.trim().replace(/[\$%€£¥%]/g, "");
        if (sep === ",") {
            cleaned = cleaned.replace(/\./g, "").replace(",", ".");
        } else {
            cleaned = cleaned.replace(/,/g, "");
        }
        const num = parseFloat(cleaned);
        return isNaN(num) ? null : num;
    };

    const parseData = (text: string, sep: string): Point[] => {
        return text.split(/\r?\n/).reduce((acc, line) => {
            const parts = line
                .trim()
                .split(/[\t,;|\s+]+/)
                .filter((p) => p !== "");
            if (parts.length >= 2) {
                const x = cleanValue(parts[0], sep),
                    y = cleanValue(parts[1], sep);
                if (x !== null && y !== null) acc.push({ x, y });
            }
            return acc;
        }, [] as Point[]);
    };

    const calculateStats = (points: Point[]) => {
        const n = points.length;
        if (n < 2) return null;
        const sumX = points.reduce((a, b) => a + b.x, 0),
            sumY = points.reduce((a, b) => a + b.y, 0);
        const meanX = sumX / n,
            meanY = sumY / n;
        let num = 0,
            denX = 0,
            denY = 0;
        points.forEach((p) => {
            const dx = p.x - meanX,
                dy = p.y - meanY;
            num += dx * dy;
            denX += dx * dx;
            denY += dy * dy;
        });
        const r = num / Math.sqrt(denX * denY);
        const m = num / denX,
            b = meanY - m * meanX;
        return { r, r2: r * r, n, m, b, meanX, meanY };
    };

    const drawChart = (points: Point[], stats: any) => {
        if (!ctx || !canvas) return;
        const container = canvas.parentElement!;
        const dpr = window.devicePixelRatio || 1;
        const rect = container.getBoundingClientRect();
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx.scale(dpr, dpr);
        const w = rect.width,
            h = rect.height,
            padding = 30;
        ctx.clearRect(0, 0, w, h);
        if (points.length < 1) return;
        const minX = Math.min(...points.map((p) => p.x)),
            maxX = Math.max(...points.map((p) => p.x));
        const minY = Math.min(...points.map((p) => p.y)),
            maxY = Math.max(...points.map((p) => p.y));
        const rangeX = maxX - minX || 1,
            rangeY = maxY - minY || 1;
        const adjMinX = minX - rangeX * 0.1,
            adjMaxX = maxX + rangeX * 0.1;
        const adjMinY = minY - rangeY * 0.1,
            adjMaxY = maxY + rangeY * 0.1;
        const mapX = (val: number) =>
            padding + ((val - adjMinX) * (w - 2 * padding)) / (adjMaxX - adjMinX);
        const mapY = (val: number) =>
            h - padding - ((val - adjMinY) * (h - 2 * padding)) / (adjMaxY - adjMinY);

        if (stats) {
            ctx.strokeStyle = "rgba(236, 72, 153, 0.4)";
            ctx.lineWidth = 2;
            ctx.setLineDash([5, 5]);
            ctx.beginPath();
            ctx.moveTo(mapX(adjMinX), mapY(stats.m * adjMinX + stats.b));
            ctx.lineTo(mapX(adjMaxX), mapY(stats.m * adjMaxX + stats.b));
            ctx.stroke();
            ctx.setLineDash([]);
        }
        points.forEach((p) => {
            ctx.fillStyle = "#6366f1";
            ctx.beginPath();
            ctx.arc(mapX(p.x), mapY(p.y), 4, 0, Math.PI * 2);
            ctx.fill();
        });
    };

    const updateResults = () => {
        const text = dataInput.value,
            points = parseData(text, decimalSep.value),
            stats = calculateStats(points);
        localStorage.setItem("pearson_data", text);
        if (stats) {
            ui.r!.textContent = stats.r.toFixed(4);
            ui.r2!.textContent = (stats.r2 * 100).toFixed(1) + "%";
            ui.n!.textContent = stats.n.toString();
            ui.slope!.textContent = stats.m.toFixed(2);
            ui.meanX!.textContent = stats.meanX.toFixed(2);
            ui.meanY!.textContent = stats.meanY.toFixed(2);
            regressionEq!.style.display = "block";
            regressionEq!.textContent = `y = ${stats.m.toFixed(2)}x + ${stats.b.toFixed(2)}`;

            const absR = Math.abs(stats.r);
            if (absR >= 0.999) {
                ui.inter!.textContent =
                    stats.r > 0 ? "Correlación positiva perfecta" : "Correlación negativa perfecta";
                ui.inter!.style.background = "#dcfce7";
                ui.inter!.style.color = "#166534";
            } else if (absR >= 0.7) {
                ui.inter!.textContent = "Correlación fuerte";
                ui.inter!.style.background = "#dcfce7";
                ui.inter!.style.color = "#166534";
            } else if (absR >= 0.4) {
                ui.inter!.textContent = "Correlación moderada";
                ui.inter!.style.background = "#fef9c3";
                ui.inter!.style.color = "#854d0e";
            } else {
                ui.inter!.textContent = "Correlación débil/nula";
                ui.inter!.style.background = "#f1f5f9";
                ui.inter!.style.color = "#475569";
            }
            errorLabel!.style.display = "none";
        } else {
            errorLabel!.style.display = text.trim() ? "flex" : "none";
            regressionEq!.style.display = "none";
            Object.values(ui).forEach((n) => {
                if (n?.id !== "nValue") n!.textContent = "-";
            });
        }
        drawChart(points, stats);
    };

    dataInput.addEventListener("input", updateResults);
    decimalSep.addEventListener("change", updateResults);
    loadExampleBtn?.addEventListener("click", () => {
        dataInput.value = EXAMPLE_DATA;
        updateResults();
    });
    clearDataBtn?.addEventListener("click", () => {
        dataInput.value = "";
        updateResults();
    });
    downloadChartBtn?.addEventListener("click", () => {
        const a = document.createElement("a");
        a.download = "pearson.webp";
        a.href = canvas.toDataURL("image/webp");
        a.click();
    });
    copyResultsBtn?.addEventListener("click", () => {
        navigator.clipboard.writeText(
            `R=${ui.r?.textContent}, R²=${ui.r2?.textContent}. ${regressionEq?.textContent}`
        );
        const icon = copyResultsBtn.innerHTML;
        copyResultsBtn.innerHTML =
            '<svg style="width:18px;height:18px" viewBox="0 0 24 24"><path fill="currentColor" d="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" /></svg>';
        setTimeout(() => (copyResultsBtn.innerHTML = icon), 2000);
    });

    const saved = localStorage.getItem("pearson_data");
    if (saved) {
        dataInput.value = saved;
        updateResults();
    }
    window.addEventListener("resize", updateResults);
</script>
