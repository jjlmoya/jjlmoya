---
import "./BinauralWaveTuner.css";
---

<div class="binaural-container">
  <div class="tuner-card">
    <div class="controls-grid">
      <div class="control-group">
        <div class="control-header">
          <span class="control-label">Frecuencia Base</span>
          <div class="value-display" id="baseFreqVal">200<span class="value-unit">Hz</span></div>
        </div>
        <input 
          type="range" 
          id="baseFreq" 
          min="100" 
          max="800" 
          step="1" 
          value="200" 
          aria-label="Frecuencia Base"
        />
      </div>

      <div class="control-group">
        <div class="control-header">
          <span class="control-label">Pulso Binaural</span>
          <div class="value-display" id="beatFreqVal">4.0<span class="value-unit">Hz</span></div>
        </div>
        <input 
          type="range" 
          id="beatFreq" 
          min="0.5" 
          max="40" 
          step="0.1" 
          value="4" 
          aria-label="Frecuencia del Pulso"
        />
      </div>
    </div>

    <div class="presets-container">
      <div class="beat-description" id="beatType">Ondas Theta: Sueño lúcido y creatividad.</div>
      <div class="presets">
        <button class="preset-btn" data-base="174" data-beat="1.5">Delta Sleep</button>
        <button class="preset-btn active" data-base="210" data-beat="4.5">Lucid Dream</button>
        <button class="preset-btn" data-base="396" data-beat="10">Deep Alpha</button>
        <button class="preset-btn" data-base="528" data-beat="20">Active Beta</button>
        <button class="preset-btn" data-base="639" data-beat="40">Super Gamma</button>
      </div>
    </div>

    <div class="main-actions">
      <button id="toggleAudio" class="play-button" aria-label="Reproducir / Pausar">
        <svg id="playIcon" viewBox="0 0 24 24"><path d="M8,5.14V19.14L19,12.14L8,5.14Z" /></svg>
        <svg id="stopIcon" viewBox="0 0 24 24" style="display:none;"><path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M9,9H15V15H9V9Z" /></svg>
      </button>

      <button id="toggleStrobe" class="strobe-toggle">
        Pulso Visual
      </button>
    </div>

    <div class="visualizer-stage">
      <div id="strobeLight" class="strobe-overlay"></div>
      <canvas id="waveCanvas" class="wave-canvas"></canvas>
    </div>

    <div class="warning">
        <strong>Atención: Riesgo de Fotosensibilidad</strong>
        Esta herramienta utiliza destellos lumínicos intensos. No recomendada para personas con antecedentes de epilepsia. Use auriculares para percibir el efecto binaural correctamente. No conduzca bajo su influencia.
    </div>
  </div>
</div>

<script>
  let audioCtx: AudioContext | null = null;
  let oscL: OscillatorNode | null = null;
  let oscR: OscillatorNode | null = null;
  let gainL: GainNode | null = null;
  let gainR: GainNode | null = null;
  let pannerL: StereoPannerNode | null = null;
  let pannerR: StereoPannerNode | null = null;
  let isPlaying = false;
  let isStrobeActive = false;

  const baseInput = document.getElementById("baseFreq") as HTMLInputElement;
  const beatInput = document.getElementById("beatFreq") as HTMLInputElement;
  const baseVal = document.getElementById("baseFreqVal");
  const beatVal = document.getElementById("beatFreqVal");
  const beatType = document.getElementById("beatType");
  const toggleBtn = document.getElementById("toggleAudio");
  const toggleStrobeBtn = document.getElementById("toggleStrobe");
  const strobeLight = document.getElementById("strobeLight");
  const playIcon = document.getElementById("playIcon");
  const stopIcon = document.getElementById("stopIcon");
  const presetBtns = document.querySelectorAll(".preset-btn[data-base]");
  const canvas = document.getElementById("waveCanvas") as HTMLCanvasElement;
  const ctx = canvas?.getContext("2d");

  function updateFrequencyLabels() {
    const base = parseFloat(baseInput.value);
    const beat = parseFloat(beatInput.value);
    if (baseVal) baseVal.innerHTML = `${base}<span class="value-unit">Hz</span>`;
    if (beatVal) beatVal.innerHTML = `${beat.toFixed(1)}<span class="value-unit">Hz</span>`;

    updateBeatTypeLabel(beat);
    updateAudio();
    updateStrobe();
  }

  function updateBeatTypeLabel(beat: number) {
    if (!beatType) return;
    if (beat < 4) {
      beatType.textContent = "Ondas Delta: Regeneración y sueño reparador.";
    } else if (beat < 8) {
      beatType.textContent = "Ondas Theta: Sueños lúcidos y conexión subconsciente.";
    } else if (beat < 14) {
      beatType.textContent = "Ondas Alpha: Relajación consciente y flujo creativo.";
    } else if (beat < 30) {
      beatType.textContent = "Ondas Beta: Enfoque cognitivo y vigilia activa.";
    } else {
      beatType.textContent = "Ondas Gamma: Procesamiento de alto nivel e insight.";
    }
  }

  function initAudio() {
    audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    
    oscL = audioCtx.createOscillator();
    oscR = audioCtx.createOscillator();
    gainL = audioCtx.createGain();
    gainR = audioCtx.createGain();
    pannerL = audioCtx.createStereoPanner();
    pannerR = audioCtx.createStereoPanner();
    
    gainL.gain.value = 0.5;
    gainR.gain.value = 0.5;
    pannerL.pan.value = -1;
    pannerR.pan.value = 1;
    
    oscL.connect(gainL).connect(pannerL).connect(audioCtx.destination);
    oscR.connect(gainR).connect(pannerR).connect(audioCtx.destination);
    oscL.type = "sine";
    oscR.type = "sine";
    
    updateAudio();
    oscL.start();
    oscR.start();
    animate();
  }

  function updateAudio() {
    if (!audioCtx || !oscL || !oscR) return;
    const base = parseFloat(baseInput.value);
    const beat = parseFloat(beatInput.value);
    oscL.frequency.setTargetAtTime(base - (beat / 2), audioCtx.currentTime, 0.1);
    oscR.frequency.setTargetAtTime(base + (beat / 2), audioCtx.currentTime, 0.1);
  }

  function updateStrobe() {
    if (!strobeLight) return;
    if (isStrobeActive) {
      const beat = parseFloat(beatInput.value);
      const duration = 1 / beat;
      strobeLight.style.setProperty("--strobe-duration", `${duration}s`);
      strobeLight.classList.add("strobe-active");
    } else {
      strobeLight.classList.remove("strobe-active");
    }
  }

  function animate() {
    if (!ctx || !canvas) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    const time = Date.now() * 0.002;
    const base = parseFloat(baseInput.value);
    const beat = parseFloat(beatInput.value);
    
    ctx.beginPath();
    ctx.lineWidth = 2;
    ctx.strokeStyle = "rgba(112, 0, 255, 0.8)";
    
    for (let x = 0; x < canvas.width; x++) {
      const y = canvas.height / 2 + Math.sin(x * 0.05 + time * (base / 100)) * 20;
      if (x === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.stroke();

    ctx.beginPath();
    ctx.strokeStyle = "rgba(0, 242, 255, 0.8)";
    for (let x = 0; x < canvas.width; x++) {
      const b = Math.sin(x * 0.02 + time * beat) * 40;
      const y = canvas.height / 2 + Math.sin(x * 0.05 + time * (base / 100)) * (20 + b);
      if (x === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.stroke();
    
    requestAnimationFrame(animate);
  }

  function toggleAudio() {
    if (!isPlaying) {
      if (!audioCtx) {
        initAudio();
      } else if (audioCtx.state === "suspended") {
        audioCtx.resume();
      }
      isPlaying = true;
      toggleBtn?.classList.add("playing");
      if (playIcon) playIcon.style.display = "none";
      if (stopIcon) stopIcon.style.display = "block";
    } else {
      if (audioCtx) audioCtx.suspend();
      isPlaying = false;
      toggleBtn?.classList.remove("playing");
      if (playIcon) playIcon.style.display = "block";
      if (stopIcon) stopIcon.style.display = "none";
    }
  }

  baseInput?.addEventListener("input", updateFrequencyLabels);
  beatInput?.addEventListener("input", updateFrequencyLabels);
  toggleBtn?.addEventListener("click", toggleAudio);

  toggleStrobeBtn?.addEventListener("click", () => {
    isStrobeActive = !isStrobeActive;
    if (toggleStrobeBtn) {
      toggleStrobeBtn.classList.toggle("active", isStrobeActive);
    }
    updateStrobe();
  });

  presetBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      presetBtns.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      const base = btn.getAttribute("data-base");
      const beat = btn.getAttribute("data-beat");
      if (base) baseInput.value = base;
      if (beat) beatInput.value = beat;
      updateFrequencyLabels();
    });
  });

  if (canvas) {
    const resize = () => {
      canvas.width = canvas.parentElement?.clientWidth || 0;
      canvas.height = canvas.parentElement?.clientHeight || 0;
    };
    window.addEventListener("resize", resize);
    resize();
  }
</script>
