---
import "./SslCertificateInspector.css";
---

<div class="ssl-inspector">
    <div id="drop-zone" class="drop-zone">
        <input type="file" id="cert-file" class="file-input" accept=".pem,.crt,.cer,.der" />
        <div class="drop-zone-content">
            <div class="icon-wrapper">
                <span class="i-mdi-certificate"></span>
            </div>
            <h3>Analizar Certificado</h3>
            <p>Arrastra tu archivo .pem, .crt o .cer aquí</p>
            <p><small>(Procesamiento 100% local en tu navegador)</small></p>
        </div>
    </div>

    <div id="error-message" class="error-message"></div>

    <div id="results" class="results-grid">
        <div class="cert-card" id="card-status">
            <div class="card-header">
                <span class="i-mdi-shield-check card-icon"></span>
                <h4>Estado de Validez</h4>
            </div>
            <div class="card-content">
                <div class="data-item">
                    <div id="validez-status"></div>
                </div>
                <div class="data-item">
                    <span class="data-label">Vence el:</span>
                    <span id="expiry-date" class="data-value"></span>
                </div>
                <div class="data-item">
                    <span class="data-label">Emitido el:</span>
                    <span id="issue-date" class="data-value"></span>
                </div>
            </div>
        </div>

        <div class="cert-card" id="card-subject">
            <div class="card-header">
                <span class="i-mdi-account-details card-icon"></span>
                <h4>Sujeto (Propietario)</h4>
            </div>
            <div class="card-content" id="subject-details"></div>
        </div>

        <div class="cert-card" id="card-issuer">
            <div class="card-header">
                <span class="i-mdi-bank card-icon"></span>
                <h4>Emisor (CA)</h4>
            </div>
            <div class="card-content" id="issuer-details"></div>
        </div>

        <div class="cert-card" id="card-fingerprints">
            <div class="card-header">
                <span class="i-mdi-fingerprint card-icon"></span>
                <h4>Huellas Digitales</h4>
            </div>
            <div class="card-content">
                <div class="data-item">
                    <span class="data-label">SHA-256 Fingerprint:</span>
                    <div id="sha256-fingerprint" class="fingerprint"></div>
                </div>
                <div class="data-item">
                    <span class="data-label">SHA-1 Fingerprint:</span>
                    <div id="sha1-fingerprint" class="fingerprint"></div>
                </div>
            </div>
        </div>

        <div class="cert-card" id="card-algorithm">
            <div class="card-header">
                <span class="i-mdi-file-key card-icon"></span>
                <h4>Detalles Técnicos</h4>
            </div>
            <div class="card-content">
                <div class="data-item">
                    <span class="data-label">Algoritmo de Firma:</span>
                    <span id="sig-algo" class="data-value"></span>
                </div>
                <div class="data-item">
                    <span class="data-label">Versión X.509:</span>
                    <span id="cert-version" class="data-value"></span>
                </div>
                <div class="data-item">
                    <span class="data-label">Número de Serie:</span>
                    <span id="serial-number" class="data-value"></span>
                </div>
            </div>
        </div>
    </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/node-forge@1.3.1/dist/forge.min.js"></script>

<script>
    const dropZone = document.getElementById("drop-zone") as HTMLDivElement;
    const fileInput = document.getElementById("cert-file") as HTMLInputElement;
    const results = document.getElementById("results") as HTMLDivElement;
    const errorMsg = document.getElementById("error-message") as HTMLDivElement;

    fileInput.addEventListener("change", (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) handleFile(file);
    });

    ["dragenter", "dragover", "dragleave", "drop"].forEach((eventName) => {
        dropZone.addEventListener(eventName, (e) => {
            e.preventDefault();
            e.stopPropagation();
        });
    });

    dropZone.addEventListener("dragover", () => dropZone.classList.add("drag-active"));
    dropZone.addEventListener("dragleave", () => dropZone.classList.remove("drag-active"));
    dropZone.addEventListener("drop", (e) => {
        dropZone.classList.remove("drag-active");
        const file = e.dataTransfer?.files[0];
        if (file) handleFile(file);
    });

    async function handleFile(file: File) {
        errorMsg.style.display = "none";
        results.classList.remove("visible");

        try {
            const buffer = await file.arrayBuffer();
            const bytes = new Uint8Array(buffer);
            const content = new TextDecoder().decode(bytes);

            const forge = (window as any).forge;
            if (!forge) throw new Error("La librería criptográfica no se ha cargado.");

            const pki = forge.pki;
            let cert;

            const trimmedContent = content.trim();
            if (trimmedContent.includes("-----BEGIN CERTIFICATE-----")) {
                const pemMatch = trimmedContent.match(
                    /-----BEGIN CERTIFICATE-----[\s\S]+?-----END CERTIFICATE-----/
                );
                if (!pemMatch) throw new Error("Formato PEM malformado.");
                cert = pki.certificateFromPem(pemMatch[0]);
            } else {
                const forgeBuffer = forge.util.createBuffer(Array.from(bytes));
                const asn1 = forge.asn1.fromDer(forgeBuffer);
                cert = pki.certificateFromAsn1(asn1);
            }

            if (!cert) throw new Error("Información de certificado no válida.");

            displayCertInfo(cert, buffer);
        } catch (err: any) {
            console.error("Error:", err);
            errorMsg.textContent = `Error: ${err.message || "Archivo no válido."}`;
            errorMsg.style.display = "block";
        }
    }

    interface CertAttribute {
        shortName: string;
        name: string;
        value: string;
    }

    interface ForgeCert {
        validity: {
            notBefore: Date;
            notAfter: Date;
        };
        subject: {
            attributes: CertAttribute[];
        };
        issuer: {
            attributes: CertAttribute[];
        };
        signatureOid: string;
        version: number;
        serialNumber: string;
    }

    async function displayCertInfo(cert: ForgeCert, rawBuffer: ArrayBuffer) {
        const now = new Date();
        const notBefore = cert.validity.notBefore;
        const notAfter = cert.validity.notAfter;
        const isValid = now >= notBefore && now <= notAfter;

        const validezEl = document.getElementById("validez-status");
        if (validezEl) {
            validezEl.innerHTML = isValid
                ? '<span class="status-badge status-valid"><span class="i-mdi-check-circle-outline"></span>&nbsp;Válido</span>'
                : '<span class="status-badge status-expired"><span class="i-mdi-alert-circle-outline"></span>&nbsp;No válido</span>';
        }

        const expiryEl = document.getElementById("expiry-date");
        const issueEl = document.getElementById("issue-date");
        if (expiryEl) expiryEl.textContent = notAfter.toLocaleString();
        if (issueEl) issueEl.textContent = notBefore.toLocaleString();

        const formatDN = (attributes: CertAttribute[]) => {
            const map: Record<string, string> = {
                CN: "Common Name",
                O: "Organization",
                OU: "Org. Unit",
                L: "Locality",
                ST: "State/Province",
                C: "Country",
                E: "Email",
            };
            return attributes
                .map((attr) => {
                    const label = map[attr.shortName] || attr.name || attr.shortName || "Unknown";
                    return `
                    <div class="data-item">
                        <span class="data-label">${label}:</span>
                        <span class="data-value">${attr.value}</span>
                    </div>
                `;
                })
                .join("");
        };

        const subjectDetails = document.getElementById("subject-details");
        const issuerDetails = document.getElementById("issuer-details");

        if (subjectDetails) subjectDetails.innerHTML = formatDN(cert.subject.attributes);
        if (issuerDetails) issuerDetails.innerHTML = formatDN(cert.issuer.attributes);

        const sha1Buf = await crypto.subtle.digest("SHA-1", rawBuffer);
        const sha256Buf = await crypto.subtle.digest("SHA-256", rawBuffer);

        const bufToHex = (buf: ArrayBuffer) => {
            return Array.from(new Uint8Array(buf))
                .map((b) => b.toString(16).padStart(2, "0").toUpperCase())
                .join(":");
        };

        const sha1El = document.getElementById("sha1-fingerprint");
        const sha256El = document.getElementById("sha256-fingerprint");
        if (sha1El) sha1El.textContent = bufToHex(sha1Buf);
        if (sha256El) sha256El.textContent = bufToHex(sha256Buf);

        const sigEl = document.getElementById("sig-algo");
        const verEl = document.getElementById("cert-version");
        const serialEl = document.getElementById("serial-number");

        const forge = (window as any).forge;
        if (sigEl && forge)
            sigEl.textContent = forge.pki.oids[cert.signatureOid] || cert.signatureOid;
        if (verEl) verEl.textContent = (cert.version + 1).toString();
        if (serialEl) serialEl.textContent = cert.serialNumber;

        results.classList.add("visible");
    }
</script>
