---
import { Icon } from "astro-icon/components";
import "./CardUtility.css";

interface Props {
    href: string;
    title: string;
    description: string;
    iconBg: string;
    iconFg: string;
    color: string;
}

const { href, title, description, iconBg, iconFg, color } = Astro.props;
---

<a
    href={href}
    class="utility-card"
    style={`--theme-color: ${color}`}
    data-utility-card
    data-title={title}
    data-description={description}
>
    <div class="utility-card-bg-icon-wrapper">
        <Icon name={iconBg} class="utility-card-bg-icon" />
    </div>

    <div class="utility-card-content">
        <div
            class="utility-card-icon-container"
            style={`background-color: color-mix(in srgb, var(--theme-color), transparent 90%);`}
        >
            <Icon name={iconFg} class="utility-card-icon" />
        </div>

        <h2 class="utility-card-title">
            {title}
        </h2>
        <p class="utility-card-description">
            {description}
        </p>

        <div class="utility-card-action">
            <span>usar herramienta</span>
            <Icon name="mdi:arrow-right" class="utility-card-arrow" />
        </div>
    </div>
</a>
