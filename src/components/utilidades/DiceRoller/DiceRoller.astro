---
import "./DiceRoller.css";
import DiceSelector from "./parts/DiceSelector.astro";
import DiceControls from "./parts/DiceControls.astro";
import DiceResults from "./parts/DiceResults.astro";
---

<div class="dice-roller-container">
    <div class="glass-card animate-in fade-in slide-in-from-bottom duration-700">
        <DiceSelector />
        <DiceControls />
    </div>

    <div
        class="glass-card result-card animate-in fade-in slide-in-from-bottom duration-700 delay-100"
    >
        <DiceResults />
    </div>
</div>

<script>
    interface Die {
        id: string;
        sides: number;
    }

    let pool: Die[] = [];
    const dicePoolContainer = document.getElementById("dice-pool");
    const diceBtns = document.querySelectorAll(".dice-btn");
    const btnRoll = document.getElementById("btn-roll");
    const btnClear = document.getElementById("btn-clear");
    const modifierInput = document.getElementById("modifier") as HTMLInputElement | null;
    const totalResultDisplay = document.getElementById("total-result");
    const historyContainer = document.getElementById("dice-history");
    const diceVisualContainer = document.getElementById("dice-visual-container");

    function updatePoolUI(): void {
        if (!dicePoolContainer) return;

        if (pool.length === 0) {
            dicePoolContainer.innerHTML =
                '<p class="empty-pool-text">Haz clic en los dados para añadirlos</p>';
            return;
        }

        dicePoolContainer.innerHTML = "";
        pool.forEach((die) => {
            const dieEl = document.createElement("div");
            dieEl.className = "pool-die";
            dieEl.innerHTML = `<span>d${die.sides}</span><button class="remove-die" data-id="${die.id}">&times;</button>`;
            dieEl.querySelector(".remove-die")?.addEventListener("click", () => removeDie(die.id));
            dicePoolContainer.appendChild(dieEl);
        });
    }

    function addDie(sides: number): void {
        const newDie: Die = {
            id: Math.random().toString(36).slice(2, 11),
            sides,
        };
        pool.push(newDie);
        updatePoolUI();
    }

    function removeDie(id: string): void {
        pool = pool.filter((d) => d.id !== id);
        updatePoolUI();
    }

    function roll(): void {
        if (pool.length === 0 || !totalResultDisplay || !diceVisualContainer) return;

        btnRoll?.classList.add("rolling");
        totalResultDisplay.classList.add("rolling-text");

        const rollDuration = 600;
        const startTime = Date.now();

        const animInterval = setInterval(() => {
            const elapsed = Date.now() - startTime;
            if (elapsed >= rollDuration) {
                clearInterval(animInterval);
                finalizeRoll();
            } else {
                const tempTotal = pool.reduce(
                    (acc, die) => acc + Math.floor(Math.random() * die.sides) + 1,
                    0
                );
                totalResultDisplay.textContent = tempTotal.toString();
            }
        }, 50);
    }

    function finalizeRoll(): void {
        if (!totalResultDisplay || !diceVisualContainer) return;

        btnRoll?.classList.remove("rolling");
        totalResultDisplay.classList.remove("rolling-text");

        const results = pool.map((die) => ({
            sides: die.sides,
            value: Math.floor(Math.random() * die.sides) + 1,
        }));

        const modifier = parseInt(modifierInput?.value || "0");
        const sum = results.reduce((a, b) => a + b.value, 0);
        const total = sum + modifier;

        totalResultDisplay.textContent = total.toString();

        diceVisualContainer.innerHTML = "";
        results.forEach((res, index) => {
            const dieVisual = document.createElement("div");
            dieVisual.className = "visual-die animate-in zoom-in spin-in duration-300";
            dieVisual.style.animationDelay = `${index * 50}ms`;
            dieVisual.innerHTML = `<span class="die-sides-bg">d${res.sides}</span><span class="die-value">${res.value}</span>`;
            diceVisualContainer.appendChild(dieVisual);
        });

        addToHistory(
            results.map((r) => r.value),
            modifier,
            total
        );
    }

    function addToHistory(results: number[], modifier: number, total: number): void {
        if (!historyContainer) return;

        const historyItem = document.createElement("div");
        historyItem.className = "history-item animate-in fade-in slide-in-from-top";

        const diceStr = results.join(" + ");
        const modStr =
            modifier !== 0 ? (modifier > 0 ? ` + ${modifier}` : ` - ${Math.abs(modifier)}`) : "";

        historyItem.innerHTML = `
            <div class="history-formula">(${diceStr})${modStr}</div>
            <div class="history-total">${total}</div>
        `;

        if (historyContainer.querySelector(".empty-history-text")) {
            historyContainer.innerHTML = "";
        }

        historyContainer.prepend(historyItem);

        if (historyContainer.children.length > 20) {
            historyContainer.lastElementChild?.remove();
        }
    }

    diceBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const sides = parseInt((btn as HTMLElement).dataset.sides || "6");
            addDie(sides);
        });
    });

    btnRoll?.addEventListener("click", roll);
    btnClear?.addEventListener("click", () => {
        pool = [];
        updatePoolUI();
        if (totalResultDisplay) totalResultDisplay.textContent = "0";
        if (diceVisualContainer) diceVisualContainer.innerHTML = "";
    });
</script>
