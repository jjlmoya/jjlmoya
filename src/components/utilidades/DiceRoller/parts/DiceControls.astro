<div class="current-pool">
    <label class="label">Pool de Dados</label>
    <div id="dice-pool" class="dice-pool">
        <p class="empty-pool-text">Haz clic en los dados para añadirlos</p>
    </div>
</div>

<div class="modifier-group">
    <label for="modifier" class="label">Modificador (+/-)</label>
    <input type="number" id="modifier" class="text-input" value="0" />
</div>

<div class="action-buttons">
    <button id="btn-roll" class="btn btn-primary"> Lanzar Dados </button>
    <button id="btn-clear" class="btn btn-secondary"> Limpiar Pool </button>
</div>
