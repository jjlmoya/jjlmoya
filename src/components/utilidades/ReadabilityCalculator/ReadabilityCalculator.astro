---
import "./ReadabilityCalculator.css";
---

<div class="readability-container">
    <div class="glass-card left-panel animate-in fade-in slide-in-from-left duration-700">
        <div class="control-section">
            <div class="group-title">
                <i class="mdi mdi-palette"></i> Colores Base
            </div>

            <div class="inputs-grid">
                <div class="input-wrapper">
                    <label class="label-mini">Texto</label>
                    <div class="color-input-container">
                        <input type="color" id="text-color" class="color-picker" value="#1e293b" />
                        <span id="text-hex-val" class="hex-text">#1E293B</span>
                    </div>
                </div>
                <div class="input-wrapper">
                    <label class="label-mini">Fondo</label>
                    <div class="color-input-container">
                        <input type="color" id="bg-color" class="color-picker" value="#ffffff" />
                        <span id="bg-hex-val" class="hex-text">#FFFFFF</span>
                    </div>
                </div>
            </div>

            <div class="group-title">
                <i class="mdi mdi-format-size"></i> Tipografía
            </div>

            <div class="sliders-stack">
                <div class="slider-group">
                    <div class="slider-header">
                        <label class="label-mini">Tamaño de Fuente</label>
                        <span id="size-val" class="slider-value">16px</span>
                    </div>
                    <input type="range" id="size-slider" min="12" max="72" value="16" />
                </div>
                <div class="slider-group">
                    <div class="slider-header">
                        <label class="label-mini">Grosor (Weight)</label>
                        <span id="weight-val" class="slider-value">400</span>
                    </div>
                    <input
                        type="range"
                        id="weight-slider"
                        min="100"
                        max="900"
                        step="100"
                        value="400"
                    />
                </div>
            </div>

            <div class="group-title">
                <i class="mdi mdi-chart-box"></i> Comparativa de Contraste
            </div>

            <div class="comparison-grid">
                <div class="score-card">
                    <span class="score-label">WCAG 2.1 Ratio</span>
                    <span id="wcag-ratio" class="score-value">21.0</span>
                    <span id="wcag-status" class="score-status status-pass">Pasa AAA</span>
                </div>
                <div class="score-card">
                    <span class="score-label">APCA Lc (WCAG 3)</span>
                    <span id="apca-lc" class="score-value">100</span>
                    <span id="apca-status" class="score-status status-pass">Pasa</span>
                </div>
            </div>
        </div>
    </div>

    <div
        class="glass-card right-panel animate-in fade-in slide-in-from-right duration-700 delay-100"
    >
        <div class="preview-container">
            <div class="group-title">
                <i class="mdi mdi-eye"></i> Vista Previa Perceptual
            </div>

            <div id="preview-box" class="main-preview-box">
                <p id="preview-text" class="preview-text-main">
                    La legibilidad visual no es solo matemática. Es cómo luz y sombra interactúan
                    con tus ojos.
                </p>
            </div>

            <div class="apca-breakdown">
                <div class="group-title" style="margin-bottom: 0.75rem;">Recomendaciones APCA</div>
                <div class="breakdown-list">
                    <div class="breakdown-item">
                        <span class="item-label">Texto de Lectura (Body)</span>
                        <span id="apca-body" class="item-check check-yes"
                            ><i class="mdi mdi-check-circle"></i> Sí</span
                        >
                    </div>
                    <div class="breakdown-item">
                        <span class="item-label">Texto Pequeño / Caption</span>
                        <span id="apca-small" class="item-check check-yes"
                            ><i class="mdi mdi-check-circle"></i> Sí</span
                        >
                    </div>
                    <div class="breakdown-item">
                        <span class="item-label">UI / Botones</span>
                        <span id="apca-ui" class="item-check check-yes"
                            ><i class="mdi mdi-check-circle"></i> Sí</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const textColorInput = document.getElementById("text-color") as HTMLInputElement;
    const bgColorInput = document.getElementById("bg-color") as HTMLInputElement;
    const sizeSlider = document.getElementById("size-slider") as HTMLInputElement;
    const weightSlider = document.getElementById("weight-slider") as HTMLInputElement;

    const textHexVal = document.getElementById("text-hex-val");
    const bgHexVal = document.getElementById("bg-hex-val");
    const sizeVal = document.getElementById("size-val");
    const weightVal = document.getElementById("weight-val");

    const wcagRatioEl = document.getElementById("wcag-ratio");
    const wcagStatusEl = document.getElementById("wcag-status");
    const apcaLcEl = document.getElementById("apca-lc");
    const apcaStatusEl = document.getElementById("apca-status");

    const previewBox = document.getElementById("preview-box");
    const previewText = document.getElementById("preview-text");

    const apcaBodyEl = document.getElementById("apca-body");
    const apcaSmallEl = document.getElementById("apca-small");
    const apcaUiEl = document.getElementById("apca-ui");

    function hexToRgb(hex: string) {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        return { r, g, b };
    }

    function getLuminance(r: number, g: number, b: number) {
        const a = [r, g, b].map((v) => {
            v /= 255;
            return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
        });
        return a[0] * 0.2126 + a[1] * 0.7152 + a[2] * 0.0722;
    }

    function calcWCAG(lum1: number, lum2: number) {
        const l1 = Math.max(lum1, lum2);
        const l2 = Math.min(lum1, lum2);
        return (l1 + 0.05) / (l2 + 0.05);
    }

    function sRGBtoY(r: number, g: number, b: number) {
        const tr = Math.pow(r / 255, 2.4);
        const tg = Math.pow(g / 255, 2.4);
        const tb = Math.pow(b / 255, 2.4);
        return tr * 0.2126729 + tg * 0.7151522 + tb * 0.072175;
    }

    function calcAPCA(textHex: string, bgHex: string) {
        const textRgb = hexToRgb(textHex);
        const bgRgb = hexToRgb(bgHex);

        const Ytxt = sRGBtoY(textRgb.r, textRgb.g, textRgb.b);
        const Ybg = sRGBtoY(bgRgb.r, bgRgb.g, bgRgb.b);

        let contrast = 0;
        const mainExp = 0.88;
        const subExp = 0.56;
        const scale = 1.14;

        if (Ybg > Ytxt) {
            contrast = (Math.pow(Ybg, mainExp) - Math.pow(Ytxt, subExp)) * scale;
        } else {
            contrast = (Math.pow(Ybg, subExp) - Math.pow(Ytxt, mainExp)) * scale;
        }

        const Lc = Math.abs(contrast) * 100;
        return Math.round(Lc);
    }

    function update() {
        const textHex = textColorInput.value;
        const bgHex = bgColorInput.value;
        const size = parseInt(sizeSlider.value);
        const weight = parseInt(weightSlider.value);

        textHexVal!.textContent = textHex.toUpperCase();
        bgHexVal!.textContent = bgHex.toUpperCase();
        sizeVal!.textContent = `${size}px`;
        weightVal!.textContent = weight.toString();

        const textRgb = hexToRgb(textHex);
        const bgRgb = hexToRgb(bgHex);
        const lumText = getLuminance(textRgb.r, textRgb.g, textRgb.b);
        const lumBg = getLuminance(bgRgb.r, bgRgb.g, bgRgb.b);

        const ratio = calcWCAG(lumText, lumBg);
        wcagRatioEl!.textContent = ratio.toFixed(2);

        if (ratio >= 7) {
            wcagStatusEl!.textContent = "Pasa AAA";
            wcagStatusEl!.className = "score-status status-pass";
        } else if (ratio >= 4.5) {
            wcagStatusEl!.textContent = "Pasa AA";
            wcagStatusEl!.className = "score-status status-pass";
        } else if (ratio >= 3) {
            wcagStatusEl!.textContent = "Solo Texto Grande";
            wcagStatusEl!.className = "score-status status-pass";
        } else {
            wcagStatusEl!.textContent = "No Pasa";
            wcagStatusEl!.className = "score-status status-fail";
        }

        const Lc = calcAPCA(textHex, bgHex);
        apcaLcEl!.textContent = Lc.toString();

        if (Lc >= 75) {
            apcaStatusEl!.textContent = "Excelente";
            apcaStatusEl!.className = "score-status status-pass";
        } else if (Lc >= 60) {
            apcaStatusEl!.textContent = "Bueno";
            apcaStatusEl!.className = "score-status status-pass";
        } else if (Lc >= 45) {
            apcaStatusEl!.textContent = "Mínimo";
            apcaStatusEl!.className = "score-status status-pass";
        } else {
            apcaStatusEl!.textContent = "Pobre";
            apcaStatusEl!.className = "score-status status-fail";
        }

        previewBox!.style.backgroundColor = bgHex;
        previewText!.style.color = textHex;
        previewText!.style.fontSize = `${size}px`;
        previewText!.style.fontWeight = weight.toString();

        const checkMark = '<i class="mdi mdi-check-circle"></i> Sí';
        const crossMark = '<i class="mdi mdi-close-circle"></i> No';

        const isBodyOk = Lc >= 60 && size >= 14;
        const isSmallOk = Lc >= 75 && size >= 12;
        const isUiOk = Lc >= 45;

        apcaBodyEl!.innerHTML = isBodyOk ? checkMark : crossMark;
        apcaBodyEl!.className = `item-check ${isBodyOk ? "check-yes" : "check-no"}`;

        apcaSmallEl!.innerHTML = isSmallOk ? checkMark : crossMark;
        apcaSmallEl!.className = `item-check ${isSmallOk ? "check-yes" : "check-no"}`;

        apcaUiEl!.innerHTML = isUiOk ? checkMark : crossMark;
        apcaUiEl!.className = `item-check ${isUiOk ? "check-yes" : "check-no"}`;
    }

    [textColorInput, bgColorInput, sizeSlider, weightSlider].forEach((el) => {
        el.addEventListener("input", update);
    });

    update();
</script>
