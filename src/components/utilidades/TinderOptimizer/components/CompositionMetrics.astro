<div class="panel">
  <h3>Analítica de Composición</h3>
  <div class="metrics-grid">
    <div class="metric-card">
      <span class="metric-value" id="metric-face-size">0%</span>
      <span class="metric-label">Ratio de Rostro</span>
    </div>
    <div class="metric-card">
      <span class="metric-value" id="metric-eye-line">--</span>
      <span class="metric-label">Línea de Mirada</span>
    </div>
    <div class="metric-card">
      <span class="metric-value" id="metric-coverage">--</span>
      <span class="metric-label">Cobertura</span>
    </div>
    <div class="metric-card">
      <span class="metric-value" id="metric-mood">--</span>
      <span class="metric-label">Expresión</span>
    </div>
    <div class="metric-card">
      <span class="metric-value" id="metric-quality">--</span>
      <span class="metric-label">Confianza</span>
    </div>
  </div>
</div>
