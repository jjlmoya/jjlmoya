---
---
<div class="panel">
  <h3>Ajustes Manuales</h3>
  <div class="control-group">
    <label>Zoom <span>1x</span></label>
    <input type="range" id="zoom-slider" min="1" max="3" step="0.1" value="1" />
  </div>
  <div class="control-group">
    <label>Brillo <span>100%</span></label>
    <input type="range" id="brightness-slider" min="50" max="150" step="1" value="100" />
  </div>
</div>

<div class="panel">
  <h3>Visualización Avanzada</h3>
  <div class="toggles-grid">
    <label class="switch-item">
      <div class="switch-info">
        <span class="switch-label">Rejilla de Tercios</span>
        <span class="switch-desc">Ajuste de composición clásica</span>
      </div>
      <div class="switch-wrapper">
        <input type="checkbox" id="toggle-grid-switch" checked />
        <span class="slider"></span>
      </div>
    </label>

    <label class="switch-item danger-zone">
      <div class="switch-info">
        <span class="switch-label">Zonas de Peligro</span>
        <span class="switch-desc">Evita que la UI oculte tu cara</span>
      </div>
      <div class="switch-wrapper">
        <input type="checkbox" id="toggle-deadzones-switch" checked />
        <span class="slider"></span>
      </div>
    </label>

    <label class="switch-item face-detect-toggle" id="face-box-container" style="opacity: 0.5; pointer-events: none;">
      <div class="switch-info">
        <span class="switch-label">Ver Rostro Detectado</span>
        <span class="switch-desc">Landmarks y área de detección</span>
      </div>
      <div class="switch-wrapper">
        <input type="checkbox" id="toggle-face-box-switch" checked />
        <span class="slider"></span>
      </div>
    </label>
  </div>
</div>
