---
---
<div class="upload-zone" id="drop-zone">
  <input type="file" id="image-input" accept="image/*" hidden />
  <div id="upload-prompt" class="upload-prompt">
    <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="upload-icon">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
    </svg>
    <div class="prompt-text">
      <p id="prompt-main-text">Arrastra tu foto aquí o haz clic para subir</p>
      <span id="prompt-sub-text">Formatos aceptados: JPG, PNG, WEBP</span>
    </div>
  </div>
</div>
