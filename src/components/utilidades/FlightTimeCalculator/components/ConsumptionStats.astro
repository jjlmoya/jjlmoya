---
---

<div class="tech-section">
    <h3 class="section-title">Dinámica de Consumo</h3>
    
    <div class="input-group">
        <div class="label-row">
            <label for="drawInput">Consumo Medio</label>
            <div class="value-badge"><span id="drawDisplay">25</span> A</div>
        </div>
        <input type="range" id="drawInput" min="1" max="150" step="1" value="25" class="tech-slider" />
    </div>

    <div class="input-group">
        <div class="label-row">
            <label for="wattsInput">Potencia (Watios)</label>
            <div class="value-badge"><span id="wattsDisplay">370</span> W</div>
        </div>
        <input type="number" id="wattsInput" value="370" class="tech-input" />
        <small class="hint">Al cambiar Amperios, los Watios se recalculan según el voltaje S.</small>
    </div>

    <div class="input-group">
        <div class="label-row">
            <label for="efficiencyInput">Eficiencia Estimada</label>
            <div class="value-badge"><span id="effDisplay">6.5</span> g/W</div>
        </div>
        <input type="range" id="efficiencyInput" min="2" max="15" step="0.5" value="6.5" class="tech-slider" />
        <small class="hint">Típico: 4-6 (Racing), 8-12 (Cinematic/Long Range).</small>
    </div>
</div>

<style>
    .tech-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .section-title {
        font-size: 0.95rem;
        font-weight: 800;
        color: #1e293b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0;
    }

    :global(.dark) .card-title { color: #f1f5f9; }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
    }

    .value-badge {
        padding: 0.25rem 0.75rem;
        background: rgba(14, 165, 233, 0.1);
        border-radius: 12px;
        color: #0ea5e9;
        font-weight: 800;
        font-size: 0.9rem;
    }

    .tech-slider {
        width: 100%;
        height: 6px;
        appearance: none;
        background: #e2e8f0;
        border-radius: 3px;
        outline: none;
    }

    :global(.dark) .tech-slider { background: #334155; }

    .tech-slider::-webkit-slider-thumb {
        appearance: none;
        width: 18px;
        height: 18px;
        background: #0ea5e9;
        border: 3px solid white;
        border-radius: 50%;
        cursor: pointer;
    }

    .tech-input {
        width: 100%;
        padding: 0.75rem;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
        color: #1e293b;
    }

    :global(.dark) .tech-input {
        background: #1e293b;
        border-color: #334155;
        color: #f1f5f9;
    }

    .hint { font-size: 0.75rem; color: #94a3b8; }
</style>
