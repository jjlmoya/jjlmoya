---
---

<div class="tech-section">
    <h3 class="section-title">Especificaciones Batería</h3>
    
    <div class="input-group">
        <div class="label-row">
            <label for="capacityInput">Capacidad</label>
            <div class="value-badge"><span id="capDisplay">1500</span> mAh</div>
        </div>
        <input type="range" id="capacityInput" min="300" max="10000" step="50" value="1500" class="tech-slider" />
        <div class="presets">
            <button class="preset-btn" data-val="450">450</button>
            <button class="preset-btn" data-val="1300">1300</button>
            <button class="preset-btn" data-val="1550">1550</button>
            <button class="preset-btn" data-val="5000">5000</button>
        </div>
    </div>

    <div class="input-group">
        <div class="label-row">
            <label for="cellsInput">Voltaje (Celdas S)</label>
            <div class="value-badge"><span id="cellsDisplay">4</span>S (<span id="voltsDisplay">14.8</span>V)</div>
        </div>
        <select id="cellsInput" class="tech-select">
            <option value="1">1S (3.7V)</option>
            <option value="2">2S (7.4V)</option>
            <option value="3">3S (11.1V)</option>
            <option value="4" selected>4S (14.8V)</option>
            <option value="6">6S (22.2V)</option>
            <option value="8">8S (29.6V)</option>
            <option value="12">12S (44.4V)</option>
        </select>
    </div>

    <div class="input-group">
        <div class="label-row">
            <label for="safetyInput">Margen de Seguridad</label>
            <div class="value-badge"><span id="safetyDisplay">80</span>%</div>
        </div>
        <input type="range" id="safetyInput" min="50" max="100" step="5" value="80" class="tech-slider" />
        <small class="hint">Aterrizar con 3.5V - 3.7V por celda.</small>
    </div>
</div>

<style>
    .tech-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .section-title {
        font-size: 0.95rem;
        font-weight: 800;
        color: #1e293b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0;
    }

    :global(.dark) .card-title { color: #f1f5f9; }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
    }

    .value-badge {
        padding: 0.25rem 0.75rem;
        background: rgba(249, 115, 22, 0.1);
        border-radius: 12px;
        color: #f97316;
        font-weight: 800;
        font-size: 0.9rem;
    }

    .tech-slider {
        width: 100%;
        height: 6px;
        appearance: none;
        background: #e2e8f0;
        border-radius: 3px;
        outline: none;
    }

    :global(.dark) .tech-slider { background: #334155; }

    .tech-slider::-webkit-slider-thumb {
        appearance: none;
        width: 18px;
        height: 18px;
        background: #f97316;
        border: 3px solid white;
        border-radius: 50%;
        cursor: pointer;
    }

    .tech-select {
        width: 100%;
        padding: 0.75rem;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
        color: #1e293b;
    }

    :global(.dark) .tech-select {
        background: #1e293b;
        border-color: #334155;
        color: #f1f5f9;
    }

    .presets {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .preset-btn {
        padding: 0.35rem 0.65rem;
        background: #f1f5f9;
        border: none;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s;
    }

    :global(.dark) .preset-btn { background: #1e293b; color: #94a3b8; }

    .preset-btn:hover { background: #e2e8f0; color: #1e293b; }
    :global(.dark) .preset-btn:hover { background: #334155; color: #f8fafc; }

    .hint { font-size: 0.75rem; color: #94a3b8; }
</style>
