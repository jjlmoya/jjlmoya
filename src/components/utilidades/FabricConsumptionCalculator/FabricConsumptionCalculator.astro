---
import "./FabricConsumptionCalculator.css";
---

<div class="fabric-calculator-card" id="fabric-calc-app">
  <aside class="fabric-sidebar">
    <div class="config-group">
      <h3>Proyecto</h3>
      <div class="fabric-field">
        <label>Tipo de prenda</label>
        <select id="garment-type" class="fabric-select">
          <option value="skirt" data-merceria="1 crem. 20cm, 1 botón">Falda (Recta/Aline)</option>
          <option value="pants" data-merceria="1 crem. 20cm, 1 botón, 30cm entretela">Pantalón</option>
          <option value="dress" data-merceria="1 crem. 60cm, 50cm entretela">Vestido</option>
          <option value="shirt" data-merceria="7 botones, 1m entretela fina">Camisa / Blusa</option>
          <option value="coat" data-merceria="3 botones grandes, 1.5m entretela, forro">Abrigo / Chaqueta</option>
          <option value="tote" data-merceria="2m cinta para asas">Tote Bag</option>
        </select>
      </div>
      <div class="fabric-field">
        <label>Talla</label>
        <div class="preset-group" id="size-presets">
          <button class="preset-pill" data-val="xs_core">XS-S</button>
          <button class="preset-pill active" data-val="m_core">M-L</button>
          <button class="preset-pill" data-val="xl_core">XL-XXL</button>
        </div>
      </div>
    </div>

    <div class="config-group">
      <h3>Material</h3>
      <div class="fabric-field">
        <label>Ancho de tela (cm)</label>
        <select id="fabric-width" class="fabric-select">
          <option value="90">90 cm (Estrecha)</option>
          <option value="115">115 cm (Patchwork)</option>
          <option value="140" selected>140 cm (Estándar EU)</option>
          <option value="150">150 cm (Tapicería)</option>
        </select>
      </div>
      <div class="fabric-field">
        <label>Margen de costura (cm)</label>
        <div class="shop-stepper">
          <button class="step-btn" id="sub-allow">−</button>
          <input type="number" id="seam-allowance" class="fabric-input" value="1.5" step="0.5" min="0" max="5" />
          <button class="step-btn" id="add-allow">+</button>
        </div>
      </div>
    </div>

    <div class="btn-actions">
      <button id="btn-clear-f" class="f-btn f-seco">Limpiar</button>
      <button id="btn-share-f" class="f-btn f-prim">Compartir</button>
    </div>
  </aside>

  <main class="fabric-main">
    <div id="warning-msg" class="warning-banner"></div>

    <section class="magic-result-area">
      <span class="result-lbl">Necesitas:</span>
      <div class="val"><span id="main-meters">1.40</span><span class="unit">Metros</span></div>
      <div class="advice-tag" id="shop-advice">Pide 1.50m en la tienda</div>
    </section>

    <div class="layout-container">
      <div class="canvas-wrapper">
        <div class="scheme-area">
          <div class="ruler" id="ruler-col"></div>
          <div id="fabric-board-box" class="fabric-board">
            <div class="board-empty-state">Selecciona un proyecto para ver la disposición</div>
          </div>
        </div>
        <div class="scheme-info" id="board-desc">Ancho: 140cm | Largo: 1.40m</div>
      </div>
    </div>

    <section class="merch-section">
      <div class="merch-header">
        <h3 class="merch-title">Mercería y Materiales</h3>
        <button id="copy-list-btn" class="copy-list-btn">Copiar lista</button>
      </div>
      <ul id="check-list" class="merceria-checklist"></ul>
    </section>
  </main>
</div>

<script>
    interface PieceSpec {
        name: string;
        w: number;
        fold?: boolean;
        col: number;
    }

    interface PieceRow {
        h: number;
        pieces: PieceSpec[];
    }

    const PIECE_COLORS = [
        'rgba(196, 181, 253, 0.55)',
        'rgba(165, 180, 252, 0.55)',
        'rgba(139, 92, 246, 0.30)',
        'rgba(167, 139, 250, 0.45)',
        'rgba(129, 140, 248, 0.45)',
        'rgba(110, 231, 183, 0.40)',
    ];

    const PIECE_BORDERS = [
        'rgba(139, 92, 246, 0.50)',
        'rgba(99, 102, 241, 0.50)',
        'rgba(139, 92, 246, 0.70)',
        'rgba(124, 58, 237, 0.50)',
        'rgba(79, 70, 229, 0.50)',
        'rgba(16, 185, 129, 0.50)',
    ];

    const pieceRows: Record<string, PieceRow[]> = {
        'skirt': [
            { h: 0.38, pieces: [{ name: 'Delantero', w: 0.88, fold: true, col: 0 }] },
            { h: 0.33, pieces: [{ name: 'Espalda', w: 0.44, col: 1 }, { name: 'Espalda', w: 0.44, col: 1 }] },
            { h: 0.12, pieces: [{ name: 'Cinturilla', w: 0.88, col: 2 }] },
        ],
        'pants': [
            { h: 0.32, pieces: [{ name: 'Delantero', w: 0.44, col: 0 }, { name: 'Delantero', w: 0.44, col: 0 }] },
            { h: 0.30, pieces: [{ name: 'Espalda', w: 0.44, col: 1 }, { name: 'Espalda', w: 0.44, col: 1 }] },
            { h: 0.09, pieces: [{ name: 'Pretina', w: 0.88, fold: true, col: 2 }] },
            { h: 0.12, pieces: [{ name: 'Bolsillo', w: 0.22, col: 5 }, { name: 'Bolsillo', w: 0.22, col: 5 }] },
        ],
        'dress': [
            { h: 0.36, pieces: [{ name: 'Delantero', w: 0.88, fold: true, col: 0 }] },
            { h: 0.27, pieces: [{ name: 'Espalda', w: 0.44, col: 1 }, { name: 'Espalda', w: 0.44, col: 1 }] },
            { h: 0.22, pieces: [{ name: 'Manga', w: 0.44, col: 3 }, { name: 'Manga', w: 0.44, col: 3 }] },
            { h: 0.08, pieces: [{ name: 'Vistas', w: 0.88, col: 4 }] },
        ],
        'shirt': [
            { h: 0.35, pieces: [{ name: 'Delantero', w: 0.44, col: 0 }, { name: 'Delantero', w: 0.44, col: 0 }] },
            { h: 0.28, pieces: [{ name: 'Espalda', w: 0.88, fold: true, col: 1 }] },
            { h: 0.20, pieces: [{ name: 'Manga', w: 0.44, col: 3 }, { name: 'Manga', w: 0.44, col: 3 }] },
            { h: 0.08, pieces: [{ name: 'Cuello', w: 0.40, col: 2 }, { name: 'Cuello', w: 0.40, col: 2 }] },
            { h: 0.06, pieces: [{ name: 'Puños', w: 0.35, col: 4 }, { name: 'Puños', w: 0.35, col: 4 }] },
        ],
        'coat': [
            { h: 0.32, pieces: [{ name: 'Delantero', w: 0.44, col: 0 }, { name: 'Delantero', w: 0.44, col: 0 }] },
            { h: 0.30, pieces: [{ name: 'Espalda', w: 0.88, fold: true, col: 1 }] },
            { h: 0.20, pieces: [{ name: 'Manga', w: 0.44, col: 3 }, { name: 'Manga', w: 0.44, col: 3 }] },
            { h: 0.08, pieces: [{ name: 'Cuello', w: 0.78, col: 2 }] },
            { h: 0.06, pieces: [{ name: 'Tapetas', w: 0.55, col: 4 }] },
        ],
        'tote': [
            { h: 0.62, pieces: [{ name: 'Cuerpo', w: 0.44, col: 0 }, { name: 'Cuerpo', w: 0.44, col: 0 }] },
            { h: 0.20, pieces: [{ name: 'Asa A', w: 0.15, col: 5 }, { name: 'Asa B', w: 0.15, col: 5 }] },
        ],
    };

    const consumptionMatrix: Record<string, Record<string, number>> = {
        'skirt': { '90': 2.0, '115': 1.5, '140': 1.2, '150': 1.1 },
        'pants': { '90': 2.5, '115': 2.2, '140': 1.6, '150': 1.5 },
        'dress': { '90': 3.5, '115': 3.0, '140': 2.5, '150': 2.2 },
        'shirt': { '90': 2.2, '115': 1.8, '140': 1.4, '150': 1.2 },
        'coat': { '90': 4.5, '115': 3.8, '140': 3.0, '150': 2.8 },
        'tote': { '90': 1.2, '115': 1.0, '140': 0.8, '150': 0.7 },
    };

    const sizeMults: Record<string, number> = {
        'xs_core': 0.88,
        'm_core': 1.0,
        'xl_core': 1.25,
    };

    const sizeMinWidths: Record<string, number> = {
        'xs_core': 40,
        'm_core': 55,
        'xl_core': 70,
    };

    const domEls = {
        garment:    document.getElementById('garment-type') as HTMLSelectElement,
        fabricWidth: document.getElementById('fabric-width') as HTMLSelectElement,
        allowanceIn: document.getElementById('seam-allowance') as HTMLInputElement,
        sizeGroup:  document.getElementById('size-presets'),
        mainRes:    document.getElementById('main-meters'),
        advice:     document.getElementById('shop-advice'),
        board:      document.getElementById('fabric-board-box'),
        ruler:      document.getElementById('ruler-col'),
        boardDesc:  document.getElementById('board-desc'),
        warning:    document.getElementById('warning-msg'),
        checks:     document.getElementById('check-list'),
    };

    let activeSize = 'm_core';

    function calculateConsumption() {
        const type  = domEls.garment.value;
        const width = domEls.fabricWidth.value;
        const allow = parseFloat(domEls.allowanceIn.value || '1.5');
        const widthVal = parseInt(width);

        const baseVal = consumptionMatrix[type]?.[width] || 1.5;
        const mult    = sizeMults[activeSize] ?? 1.0;
        const minW    = sizeMinWidths[activeSize] ?? 55;

        let meters   = baseVal * mult;
        let isSerial = false;

        if (minW * 2 > widthVal && type !== 'tote') {
            meters  *= 1.4;
            isSerial = true;
        }

        meters = parseFloat((meters + allow * 0.1).toFixed(2));

        if (domEls.warning) {
            domEls.warning.style.display = isSerial ? 'block' : 'none';
            if (isSerial) {
                domEls.warning.textContent = `En telas de ${width}cm las piezas de tu talla no caben en paralelo. Consumo ajustado para corte en serie.`;
            }
        }

        if (domEls.mainRes) domEls.mainRes.textContent = meters.toFixed(2);

        if (domEls.advice) {
            const rounded = Math.ceil(meters * 4) / 4;
            const store   = rounded < meters + 0.1 ? rounded + 0.25 : rounded;
            domEls.advice.textContent = `Pide ${store.toFixed(2)}m en la tienda`;
        }

        renderLayout(type, widthVal, meters);
        updateChecklist();
        updateUrl();
    }

    function renderLayout(type: string, fabricWidthCm: number, totalMeters: number) {
        if (!domEls.board) return;

        const rows = pieceRows[type];
        domEls.board.innerHTML = '';

        if (!rows || rows.length === 0) {
            const empty = document.createElement('div');
            empty.className = 'board-empty-state';
            empty.textContent = 'Selecciona un proyecto para ver la disposición';
            domEls.board.appendChild(empty);
            renderRuler(totalMeters);
            return;
        }

        rows.forEach(row => {
            const rowEl = document.createElement('div');
            rowEl.className = 'piece-row';
            rowEl.style.flex = `0 0 ${row.h * 100}%`;

            row.pieces.forEach(spec => {
                const pieceEl = document.createElement('div');
                pieceEl.className = 'piece-block' + (spec.fold ? ' piece-fold' : '');
                pieceEl.style.width      = `${spec.w * 100}%`;
                pieceEl.style.background = PIECE_COLORS[spec.col];
                pieceEl.style.borderColor = PIECE_BORDERS[spec.col];

                const nameEl = document.createElement('span');
                nameEl.className   = 'piece-name';
                nameEl.textContent = spec.name;
                pieceEl.appendChild(nameEl);

                if (spec.fold) {
                    const foldEl = document.createElement('div');
                    foldEl.className   = 'fold-indicator';
                    foldEl.textContent = '⊟ doblez';
                    pieceEl.appendChild(foldEl);
                }

                rowEl.appendChild(pieceEl);
            });

            domEls.board!.appendChild(rowEl);
        });

        renderRuler(totalMeters);

        if (domEls.boardDesc) {
            domEls.boardDesc.textContent = `Ancho: ${fabricWidthCm}cm | Largo: ${totalMeters.toFixed(2)}m`;
        }
    }

    function renderRuler(totalMeters: number) {
        if (!domEls.ruler) return;
        domEls.ruler.innerHTML = '';

        const step = totalMeters <= 1.5 ? 0.25 : totalMeters <= 3 ? 0.5 : 1;
        let mark = 0;

        while (mark <= totalMeters + 0.001) {
            const pct    = (mark / totalMeters) * 100;
            const markEl = document.createElement('div');
            markEl.className    = 'ruler-mark';
            markEl.style.top    = `${pct}%`;

            const label = document.createElement('span');
            label.textContent = `${mark.toFixed(step < 0.5 ? 2 : 1)}m`;
            markEl.appendChild(label);
            domEls.ruler.appendChild(markEl);

            mark = parseFloat((mark + step).toFixed(3));
        }
    }

    function updateChecklist() {
        if (!domEls.checks) return;
        const extraText = domEls.garment.selectedOptions[0]?.getAttribute('data-merceria') || '';
        const extras    = extraText.split(',').map(s => s.trim()).filter(Boolean);
        const items     = ['Hilo a juego', ...extras];

        domEls.checks.innerHTML = '';
        items.forEach(it => {
            const li = document.createElement('li');
            li.className = 'merch-item';
            li.innerHTML = `<span class="merch-dot" aria-hidden="true">◆</span>${it}`;
            domEls.checks?.appendChild(li);
        });
    }

    function updateUrl() {
        const p = new URLSearchParams();
        p.set('g', domEls.garment.value);
        p.set('s', activeSize);
        p.set('w', domEls.fabricWidth.value);
        p.set('a', domEls.allowanceIn.value);
        window.history.replaceState({}, '', `${window.location.pathname}?${p.toString()}`);
    }

    domEls.sizeGroup?.addEventListener('click', e => {
        const btn = (e.target as HTMLElement).closest('.preset-pill');
        if (!btn) return;
        domEls.sizeGroup?.querySelectorAll('.preset-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeSize = btn.getAttribute('data-val') || 'm_core';
        calculateConsumption();
    });

    document.getElementById('sub-allow')?.addEventListener('click', () => {
        domEls.allowanceIn.value = String(Math.max(0, parseFloat(domEls.allowanceIn.value) - 0.5));
        calculateConsumption();
    });

    document.getElementById('add-allow')?.addEventListener('click', () => {
        domEls.allowanceIn.value = String(Math.min(5, parseFloat(domEls.allowanceIn.value) + 0.5));
        calculateConsumption();
    });

    [domEls.garment, domEls.fabricWidth, domEls.allowanceIn].forEach(el => el?.addEventListener('input', calculateConsumption));

    document.getElementById('btn-clear-f')?.addEventListener('click', () => {
        domEls.garment.value     = 'skirt';
        domEls.fabricWidth.value = '140';
        domEls.allowanceIn.value = '1.5';
        activeSize = 'm_core';
        domEls.sizeGroup?.querySelectorAll('.preset-pill').forEach(b => {
            b.classList.toggle('active', b.getAttribute('data-val') === 'm_core');
        });
        calculateConsumption();
    });

    document.getElementById('btn-share-f')?.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        const b = document.getElementById('btn-share-f');
        if (b) {
            const old = b.textContent;
            b.textContent = '¡Copiado!';
            setTimeout(() => { if (b) b.textContent = old; }, 2000);
        }
    });

    document.getElementById('copy-list-btn')?.addEventListener('click', () => {
        const lines = Array.from(domEls.checks?.querySelectorAll('.merch-item') || [])
            .map(li => '• ' + (li.textContent || '').replace('◆', '').trim());
        navigator.clipboard.writeText(lines.join('\n'));
        const btn = document.getElementById('copy-list-btn');
        if (btn) {
            const old = btn.textContent;
            btn.textContent = '¡Copiado!';
            setTimeout(() => { if (btn) btn.textContent = old; }, 2000);
        }
    });

    const q = new URLSearchParams(window.location.search);
    if (q.has('g')) domEls.garment.value     = q.get('g') || 'skirt';
    if (q.has('w')) domEls.fabricWidth.value = q.get('w') || '140';
    if (q.has('a')) domEls.allowanceIn.value = q.get('a') || '1.5';
    if (q.has('s')) {
        activeSize = q.get('s') || 'm_core';
        domEls.sizeGroup?.querySelectorAll('.preset-pill').forEach(b => {
            b.classList.toggle('active', b.getAttribute('data-val') === activeSize);
        });
    }

    calculateConsumption();
</script>
