---
import "./IrpfCalculator2026.css";
---

<div class="irpf-container">
    <div class="irpf-main-card">
        <div class="form-section">
            <div class="section-title">
                <span>Variables de Cálculo</span>
            </div>

            <div class="form-grid">
                <div class="input-block full-width">
                    <label class="input-label">Salario Bruto Anual (€)</label>
                    <input type="number" id="bruto-anual" class="irpf-input" placeholder="32.000" value="30000" min="0" />
                </div>

                <div class="input-block">
                    <label class="input-label">Número de Pagas</label>
                    <select id="numero-pagas" class="irpf-select">
                        <option value="12">12 pagas</option>
                        <option value="14" selected>14 pagas</option>
                    </select>
                </div>

                <div class="input-block">
                    <label class="input-label">Residencia Fiscal</label>
                    <select id="comunidad" class="irpf-select">
                        <option value="GEN">Territorio Común (General)</option>
                        <option value="MAD">Madrid</option>
                        <option value="CAT">Cataluña</option>
                        <option value="AND">Andalucía</option>
                        <option value="VAL">C. Valenciana</option>
                        <option value="PV">País Vasco (Foral)</option>
                        <option value="NAV">Navarra (Foral)</option>
                    </select>
                </div>

                <div class="input-block">
                    <label class="input-label">Hijos (menores de 25)</label>
                    <input type="number" id="hijos" class="irpf-input" value="0" min="0" />
                </div>

                <div class="input-block">
                    <label class="input-label">Grado Discapacidad</label>
                    <select id="discapacidad" class="irpf-select">
                        <option value="0">Ninguna</option>
                        <option value="33">&gt; 33%</option>
                        <option value="65">&gt; 65%</option>
                    </select>
                </div>

                <div class="input-block full-width">
                    <label class="input-label">Unidad Familiar o Convivencia</label>
                    <select id="estado-unid" class="irpf-select">
                        <option value="soltero" selected>Soltero, divorciado o viudo</option>
                        <option value="casado-low">Casado (pareja gana menos de 1.500€/año)</option>
                        <option value="casado-high">Casado (pareja dispone de ingresos)</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="results-section">
            <div class="section-title results-title">
                <span>Cálculo Transparente 2026</span>
            </div>

            <div class="breakdown-card">
                <div class="breakdown-item">
                    <span class="breakdown-label">Salario Bruto</span>
                    <span id="b-bruto-fmt" class="breakdown-value">---</span>
                </div>
                <div class="breakdown-item">
                    <span class="breakdown-label">Seguridad Social / MEI (-)</span>
                    <span id="b-ss-fmt" class="breakdown-value negative">---</span>
                </div>
                <div class="breakdown-item">
                    <span class="breakdown-label">Gastos Deducibles (Art. 20)</span>
                    <span id="b-deduct-fmt" class="breakdown-value negative">---</span>
                </div>
                <div class="breakdown-item net-highlight">
                    <span class="breakdown-label net-label">SALARIO NETO ANUAL</span>
                    <span id="b-neto-fmt" class="breakdown-value net-value">---</span>
                </div>
            </div>

            <div class="protagonist-card">
                <div class="protagonista-label">Retención IRPF (%)</div>
                <div id="p-perc" class="protagonista-value">---</div>
                <div id="p-anual" class="protagonista-sub">---</div>
            </div>

            <div class="breakdown-card">
                <div class="breakdown-item monthly-highlight">
                    <span class="breakdown-label">Neto Mensual Disponible</span>
                    <span id="res-mensual-euro" class="breakdown-value monthly-value">---</span>
                </div>
                <div class="breakdown-item marginal-highlight">
                    <span class="breakdown-label">Tipo Marginal Aplicado</span>
                    <span id="m-marginal" class="breakdown-value marginal-label-red">-- %</span>
                </div>
            </div>

            <div class="info-alert">
                <svg class="info-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div class="info-text">
                    Algoritmo AEAT (Cuota Íntegra Base - Cuota Mínimo) validado para 2026. Incluye cotización MEI al 6,47% y reducciones por rendimientos del trabajo. jjlmoya.es.
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    class TaxCalculator {
        private static STATE_SCALE = [
            { limit: 12450, rate: 0.095 }, { limit: 20200, rate: 0.12 }, { limit: 35200, rate: 0.15 },
            { limit: 60000, rate: 0.185 }, { limit: 300000, rate: 0.225 }, { limit: Infinity, rate: 0.245 }
        ];

        private static AUTO_OFFSET: Record<string, number> = { 
            MAD: -0.02, CAT: 0.015, AND: -0.01, VAL: 0.01, PV: -0.025, NAV: -0.02, GEN: 0 
        };

        static calculate(params: {
            salary: number, pagas: number, comunidad: string, 
            estado: string, hijos: number, discapacidad: number
        }) {
            if (params.salary <= 0) {
                return { netAnual: 0, netMensual: 0, totalTax: 0, irpfPerc: 0, ssAnual: 0, totalDeducible: 0, netPerc: 0, marginal: 0 };
            }

            const ssRate = 0.0647;
            const ssAnual = Math.min(params.salary, 54000) * ssRate;
            const reduction = params.salary < 19747 ? Math.max(0, 6498 - (params.salary > 14852 ? 1.14 * (params.salary - 14852) : 0)) : 0;
            const totalDeducible = reduction + 2000;
            const baseLiquidable = Math.max(0, params.salary - ssAnual - totalDeducible);

            let baseExempt = 5550;
            if (params.discapacidad >= 33) baseExempt += 3000;
            if (params.discapacidad >= 65) baseExempt += 9000;
            for (let i = 0; i < params.hijos; i++) baseExempt += [2400, 2700, 4000, 4500][Math.min(i, 3)];

            let situationAdjustment = 0;
            if (params.estado === 'soltero' && params.hijos > 0) situationAdjustment = 1200;
            else if (params.estado === 'casado-low') situationAdjustment = 1620 + (params.hijos * 600);
            
            const totalExempt = baseExempt + situationAdjustment;
            const off = this.AUTO_OFFSET[params.comunidad] || 0;
            
            const ciBase = this.calcCuota(baseLiquidable, this.STATE_SCALE) + this.calcCuota(baseLiquidable, this.STATE_SCALE.map(b => ({...b, rate: b.rate + off})));
            const ciMin = this.calcCuota(totalExempt, this.STATE_SCALE) + this.calcCuota(totalExempt, this.STATE_SCALE.map(b => ({...b, rate: b.rate + off})));

            const totalTax = Math.max(0, ciBase - ciMin);
            const netAnual = params.salary - ssAnual - totalTax;
            const marginal = (this.STATE_SCALE.find(b => baseLiquidable < b.limit)?.rate || 0.245) * 200 + (off*100);

            return { 
                netAnual, netMensual: netAnual/params.pagas, totalTax, 
                irpfPerc: (totalTax/params.salary)*100, ssAnual, totalDeducible,
                netPerc: (netAnual/params.salary)*100, marginal 
            };
        }

        private static calcCuota(base: number, scale: { limit: number, rate: number }[]) {
            let cuota = 0, prev = 0;
            for (const step of scale) {
                if (base > prev) {
                    cuota += Math.min(base - prev, step.limit - prev) * step.rate;
                    prev = step.limit;
                } else break;
            }
            return cuota;
        }
    }

    const IDs = ['bruto-anual', 'numero-pagas', 'comunidad', 'estado-unid', 'hijos', 'discapacidad'];
    const UI = {
        bBruto: document.getElementById('b-bruto-fmt'),
        bSs: document.getElementById('b-ss-fmt'),
        bDeduct: document.getElementById('b-deduct-fmt'),
        bIrpf: document.getElementById('b-irpf-fmt'),
        bNeto: document.getElementById('b-neto-fmt'),
        pPerc: document.getElementById('p-perc'), 
        pAnual: document.getElementById('p-anual'),
        resM: document.getElementById('res-mensual-euro'),
        marg: document.getElementById('m-marginal')
    };

    function update() {
        const root = document.getElementById('bruto-anual') as HTMLInputElement;
        if (!root) return;
        
        const salaryVal = parseFloat(root.value) || 0;
        const res = TaxCalculator.calculate({
            salary: salaryVal, 
            pagas: parseInt((document.getElementById('numero-pagas') as HTMLSelectElement).value),
            comunidad: (document.getElementById('comunidad') as HTMLSelectElement).value,
            estado: (document.getElementById('estado-unid') as HTMLSelectElement).value,
            hijos: parseInt((document.getElementById('hijos') as HTMLInputElement).value) || 0,
            discapacidad: parseInt((document.getElementById('discapacidad') as HTMLSelectElement).value)
        });

        const fP = (v: number) => `(${v.toFixed(2).replace('.', ',')}%)`;
        const fmtEuro = new Intl.NumberFormat('es-ES', { useGrouping: true, minimumFractionDigits: 0, maximumFractionDigits: 0 });
        const fC = (v: number) => fmtEuro.format(Math.round(v)) + ' €';

        if(UI.bBruto) UI.bBruto.textContent = fC(salaryVal);
        if(UI.bSs) UI.bSs.textContent = `- ${fC(res.ssAnual)} (6,47%)`;
        if(UI.bDeduct) UI.bDeduct.textContent = `- ${fC(res.totalDeducible)}`;
        if(UI.bIrpf) UI.bIrpf.textContent = `- ${fC(res.totalTax)} ${fP(res.irpfPerc)}`;
        if(UI.bNeto) UI.bNeto.textContent = fC(res.netAnual);
        
        if(UI.pPerc) UI.pPerc.textContent = res.irpfPerc.toFixed(2).replace('.', ',') + ' %';
        if(UI.pAnual) UI.pAnual.textContent = fC(res.totalTax) + ' / año';
        if(UI.resM) UI.resM.textContent = fC(res.netMensual);
        if(UI.marg) UI.marg.textContent = `${res.marginal.toFixed(1)} %`;
    }

    IDs.forEach(id => {
        const el = document.getElementById(id);
        el?.addEventListener('input', update);
        el?.addEventListener('change', update);
    });
    
    update();
</script>
