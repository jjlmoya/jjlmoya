---
import './CoffeeWaterCalculator.css';
import { Icon } from 'astro-icon/components';
import { WATER_PROFILES, SALTS } from './logic';
import { GLOSSARY } from './data';
---

<div class="coffee-water-calculator">
  <div class="calc-container">

    <div class="config-panel">
      
      <section class="section-card">
        <header class="section-header">
          <Icon name="mdi:tune-variant" />
          <h3>Configuración de Mezcla</h3>
        </header>
        
        <div class="input-row">
          <div class="field">
            <label for="base-liters">Volumen Final</label>
            <div class="input-wrapper">
              <input type="number" id="base-liters" value="1" step="0.1" min="0.1" />
              <span class="unit-badge">LITROS</span>
            </div>
          </div>
          <div class="field" id="custom-ppm-inputs" style="display: none;">

          </div>
        </div>

        <div class="field">
          <label>Perfil de Agua Objetivo</label>
          <div class="presets-grid">            {WATER_PROFILES.map((profile) => (
              <button 
                class="preset-chip" 
                data-profile={JSON.stringify(profile)}
                title={`${profile.gh} GH / ${profile.kh} KH - ${profile.description}`}
              >
                {profile.name}
              </button>
            ))}
            <button class="preset-chip" id="custom-profile-btn">Personalizado</button>
          </div>
        </div>
        
        <div id="ppm-manual-fields" style="display: none; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem;">
          <div class="field">
            <label for="target-gh">GH Objetivo</label>
            <div class="input-wrapper">
              <input type="number" id="target-gh" value="68" step="1" />
              <span class="unit-badge">mg/L</span>
            </div>
          </div>
          <div class="field">
            <label for="target-kh">KH Objetivo</label>
            <div class="input-wrapper">
              <input type="number" id="target-kh" value="40" step="1" />
              <span class="unit-badge">mg/L</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section-card">
        <header class="section-header">
          <Icon name="mdi:beaker-outline" />
          <h3>Tus Botellas de Concentrado (g/100ml)</h3>
        </header>
        
        <div class="input-row">
          <div class="field">
            <label>{SALTS.MAGNESIUM.name}</label>
            <div class="input-wrapper">
              <input type="number" id="stock-mg" value={SALTS.MAGNESIUM.defaultConcentration} step="0.01" />
              <span class="unit-badge">g/100ml</span>
            </div>
          </div>
          <div class="field">
            <label>{SALTS.CALCIUM.name}</label>
            <div class="input-wrapper">
              <input type="number" id="stock-ca" value={SALTS.CALCIUM.defaultConcentration} step="0.01" />
              <span class="unit-badge">g/100ml</span>
            </div>
          </div>
        </div>
        
        <div class="field" style="max-width: calc(50% - 0.75rem);">
          <label>{SALTS.BUFFER.name}</label>
          <div class="input-wrapper">
            <input type="number" id="stock-buffer" value={SALTS.BUFFER.defaultConcentration} step="0.01" />
            <span class="unit-badge">g/100ml</span>
          </div>
        </div>
      </section>
    </div>


    <aside class="results-sidebar">
      <div class="recipe-display">
        <header class="section-header" style="border-color: var(--accent);">
          <Icon name="mdi:clipboard-text-outline" style="color: var(--secondary);" />
          <h3 style="color: white;"><span id="active-profile-name">Receta</span></h3>
        </header>
        <p id="profile-values-sub" style="font-size: 0.75rem; color: var(--secondary); margin-top: -1rem; margin-bottom: 1.5rem; font-weight: 700;"></p>

        <div class="recipe-item">
          <span class="recipe-label">Magnesio:</span>
          <span class="recipe-value"><span id="res-mg">0.00</span> <small>ml</small></span>
        </div>
        <div class="recipe-item">
          <span class="recipe-label">Calcio:</span>
          <span class="recipe-value"><span id="res-ca">0.00</span> <small>ml</small></span>
        </div>
        <div class="recipe-item">
          <span class="recipe-label">Bicarbonato:</span>
          <span class="recipe-value"><span id="res-buffer">0.00</span> <small>ml</small></span>
        </div>
        
        <div class="total-water">
          <span class="recipe-label">Agua Destilada hasta</span>
          <div class="recipe-value" style="color: white;"><span id="res-water">0</span> <small>ml</small></div>
        </div>


        <button class="copy-action" id="copy-recipe">
          <Icon name="mdi:content-copy" />
          Copiar Receta
        </button>
      </div>

      <div class="safety-status">
        <div id="alert-corrosion" class="status-box status-yellow">
          <div class="status-icon"><Icon name="mdi:alert-circle-outline" /></div>
          <div class="status-info">
            <h4>Seguridad Metales</h4>
            <p id="corrosion-msg">Calculando...</p>
          </div>
        </div>
        
        <div id="alert-scale" class="status-box status-green">
          <div class="status-icon"><Icon name="mdi:information-outline" /></div>
          <div class="status-info">
            <h4>Riesgo de Cal</h4>
            <p id="scale-msg">Calculando...</p>
          </div>
        </div>
      </div>
    </aside>
  </div>


  <footer class="info-section section-card">
    <header class="section-header">
      <Icon name="mdi:book-open-variant" />
      <h3>Guía Rápida de Minerales</h3>
    </header>
    <div class="glossary-wrap">
      {GLOSSARY.slice(0, 4).map(item => (
        <div class="glossary-card">
          <h4>{item.term}</h4>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </footer>
</div>

<script>
  import { calculateConcentrateAmount, getCorrosionRisk, getLimescaleRisk, SALTS } from './logic';
  import { SAFETY_MESSAGES } from './data';

  const inputs = {
    baseLiters: document.getElementById('base-liters') as HTMLInputElement,
    targetGH: document.getElementById('target-gh') as HTMLInputElement,
    targetKH: document.getElementById('target-kh') as HTMLInputElement,
    stockMg: document.getElementById('stock-mg') as HTMLInputElement,
    stockCa: document.getElementById('stock-ca') as HTMLInputElement,
    stockBuffer: document.getElementById('stock-buffer') as HTMLInputElement,
  };

  const results = {
    mg: document.getElementById('res-mg'),
    ca: document.getElementById('res-ca'),
    buffer: document.getElementById('res-buffer'),
    water: document.getElementById('res-water'),
    corrosionMsg: document.getElementById('corrosion-msg'),
    scaleMsg: document.getElementById('scale-msg'),
    corrosionAlert: document.getElementById('alert-corrosion'),
    scaleAlert: document.getElementById('alert-scale'),
  };

  const presetBtns = document.querySelectorAll('.preset-chip');
  const customProfileBtn = document.getElementById('custom-profile-btn');
  const ppmManualFields = document.getElementById('ppm-manual-fields');
  const copyBtn = document.getElementById('copy-recipe');

  let activeProfile = JSON.parse(presetBtns[0].getAttribute('data-profile') || '{}');

  function updateCalculations() {
    const liters = parseFloat(inputs.baseLiters.value) || 0;
    const gh = parseFloat(inputs.targetGH.value) || 0;
    const kh = parseFloat(inputs.targetKH.value) || 0;
    
    const stockMg = parseFloat(inputs.stockMg.value) || 0;
    const stockCa = parseFloat(inputs.stockCa.value) || 0;
    const stockBuffer = parseFloat(inputs.stockBuffer.value) || 0;

    const mgRatio = activeProfile?.magnesiumRatio ?? 1;
    const targetMgHardness = gh * mgRatio;
    const targetCaHardness = gh * (1 - mgRatio);

    const amtMg = calculateConcentrateAmount(targetMgHardness, liters, stockMg, SALTS.MAGNESIUM.factor);
    const amtCa = calculateConcentrateAmount(targetCaHardness, liters, stockCa, SALTS.CALCIUM.factor);
    const amtBuffer = calculateConcentrateAmount(kh, liters, stockBuffer, SALTS.BUFFER.factor);

    if (results.mg) results.mg.innerText = amtMg.toFixed(2);
    if (results.ca) results.ca.innerText = amtCa.toFixed(2);
    if (results.buffer) results.buffer.innerText = amtBuffer.toFixed(2);
    
    const totalAdditivesMl = amtMg + amtCa + amtBuffer;
    const pureWaterNeeded = (liters * 1000) - totalAdditivesMl;
    if (results.water) results.water.innerText = pureWaterNeeded.toFixed(0);

    const profileNameEl = document.getElementById('active-profile-name');
    const profileSubEl = document.getElementById('profile-values-sub');
    if (profileNameEl) profileNameEl.innerText = activeProfile ? activeProfile.name : 'Personalizada';
    if (profileSubEl) profileSubEl.innerText = `Objetivo: ${gh} GH / ${kh} KH`;

    const corrRisk = getCorrosionRisk(gh, kh);
    const scaleRisk = getLimescaleRisk(gh, kh);

    if (results.corrosionMsg) results.corrosionMsg.innerText = SAFETY_MESSAGES.corrosion[corrRisk];
    if (results.scaleMsg) results.scaleMsg.innerText = SAFETY_MESSAGES.scale[scaleRisk];

    const corrClass = corrRisk === 'high' ? 'status-orange' : (corrRisk === 'medium' ? 'status-yellow' : 'status-green');
    const scaleClass = scaleRisk === 'high' ? 'status-orange' : (scaleRisk === 'medium' ? 'status-yellow' : 'status-green');

    results.corrosionAlert?.setAttribute('class', `status-box ${corrClass}`);
    results.scaleAlert?.setAttribute('class', `status-box ${scaleClass}`);

    localStorage.setItem('coffee-water-stocks', JSON.stringify({
      mg: stockMg,
      ca: stockCa,
      buffer: stockBuffer
    }));
  }

  Object.values(inputs).forEach(input => {
    input.addEventListener('input', updateCalculations);
  });

  presetBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const profileData = btn.getAttribute('data-profile');
      if (profileData) {
        presetBtns.forEach(b => b.classList.remove('active'));
        customProfileBtn?.classList.remove('active');
        btn.classList.add('active');
        activeProfile = JSON.parse(profileData);
        
        inputs.targetGH.value = activeProfile.gh.toString();
        inputs.targetKH.value = activeProfile.kh.toString();
        
        if (ppmManualFields) ppmManualFields.style.display = 'none';
        updateCalculations();
      }
    });
  });

  customProfileBtn?.addEventListener('click', () => {
    presetBtns.forEach(b => b.classList.remove('active'));
    customProfileBtn.classList.add('active');
    if (ppmManualFields) ppmManualFields.style.display = 'grid';
    activeProfile = null;
    updateCalculations();
  });

  copyBtn?.addEventListener('click', () => {
    const text = `Receta de Agua Café (${activeProfile?.name || 'Personalizada'}):
- Volumen: ${inputs.baseLiters.value}L
- Concentrado Magnesio: ${results.mg?.innerText}ml
- Concentrado Calcio: ${results.ca?.innerText}ml
- Concentrado Bicarbonato: ${results.buffer?.innerText}ml
- Agua Destilada: ${results.water?.innerText}ml
(Calculado en jjlmoya.com)`;
    
    navigator.clipboard.writeText(text).then(() => {
      const originalIcon = copyBtn.innerHTML;
      copyBtn.innerHTML = '<span>¡Copiado!</span>';
      setTimeout(() => { copyBtn.innerHTML = originalIcon; }, 2000);
    });
  });


  window.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('coffee-water-stocks');
    if (saved) {
      const data = JSON.parse(saved);
      inputs.stockMg.value = data.mg;
      inputs.stockCa.value = data.ca;
      inputs.stockBuffer.value = data.buffer;
    }
    presetBtns[0].classList.add('active');
    updateCalculations();
  });
</script>
