---
import "./PhotoCollageCreator.css";
---

<section class="collage-utility">
    <div class="glass-panel">
        <div class="collage-container">
            <div class="controls-section">
                <div class="input-group">
                    <label for="image-input">Cargar Imágenes</label>
                    <input
                        type="file"
                        id="image-input"
                        class="file-input"
                        multiple
                        accept="image/*"
                    />
                    <label for="image-input" class="file-input-label" role="button" tabindex="0">
                        <svg viewBox="0 0 24 24" width="24" height="24">
                            <path
                                fill="currentColor"
                                d="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                            ></path>
                        </svg>
                        <span>Selecciona 2-9 imágenes</span>
                    </label>
                    <div id="image-error" class="error-box hidden">
                        <svg viewBox="0 0 24 24" width="20" height="20">
                            <path fill="currentColor" d="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M13,17H11V15H13V17M13,13H11V7H13V13Z"></path>
                        </svg>
                        <span id="error-text"></span>
                    </div>
                </div>

                <div id="images-list-container" class="images-list-container hidden">
                    <div class="list-header">
                        <label>Imágenes Cargadas</label>
                        <span id="image-counter" class="counter">0/9</span>
                    </div>
                    <div id="images-list" class="images-list"></div>
                </div>

                <div id="layout-group" class="input-group layout-group hidden">
                    <label for="layout-select">Diseño de Collage</label>
                    <select id="layout-select" class="custom-select">
                        <option value="">Elige imágenes primero</option>
                        <option value="2x1" data-images="2">2x1 - Lado a lado (2 imágenes)</option>
                        <option value="1x2" data-images="2">1x2 - Arriba/Abajo (2 imágenes)</option>
                        <option value="3-split" data-images="3">3 en fila (3 imágenes)</option>
                        <option value="2+2" data-images="4">2x2 - Cuadrícula (4 imágenes)</option>
                        <option value="big-left" data-images="4">Grande + 3 pequeñas (4 imágenes)</option>
                        <option value="big-right" data-images="4">3 pequeñas + Grande (4 imágenes)</option>
                        <option value="5-grid" data-images="5">5 en grilla personalizada (5 imágenes)</option>
                        <option value="2x3" data-images="6">2x3 - 6 imágenes en 2 columnas</option>
                        <option value="7-grid" data-images="7">7 en grilla personalizada (7 imágenes)</option>
                        <option value="2x4" data-images="8">2x4 - 8 imágenes en 2 columnas</option>
                        <option value="3x3" data-images="9">3x3 - Cuadrícula perfecta (9 imágenes)</option>
                    </select>
                </div>

                <div class="input-group">
                    <label for="border-width">Ancho del Borde (px)</label>
                    <div class="slider-container">
                        <input
                            type="range"
                            id="border-width"
                            min="0"
                            max="20"
                            value="0"
                            class="slider"
                        />
                        <span id="border-width-value">0</span>
                    </div>
                </div>

                <div class="input-group">
                    <label for="border-color">Color del Borde</label>
                    <div class="color-input-wrapper">
                        <input
                            type="color"
                            id="border-color"
                            value="#ffffff"
                            class="color-input"
                        />
                        <span id="border-color-value">#FFFFFF</span>
                    </div>
                </div>

                <div class="input-group">
                    <label for="bg-color">Color de Fondo</label>
                    <div class="color-input-wrapper">
                        <input
                            type="color"
                            id="bg-color"
                            value="#f5f5f5"
                            class="color-input"
                        />
                        <span id="bg-color-value">#F5F5F5</span>
                    </div>
                </div>

                <div class="action-buttons">
                    <button id="create-btn" class="primary-btn" disabled>
                        <svg viewBox="0 0 24 24" width="20" height="20">
                            <path
                                fill="currentColor"
                                d="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                            ></path>
                        </svg>
                        Crear Collage
                    </button>
                    <button id="download-btn" class="secondary-btn" disabled>
                        <svg viewBox="0 0 24 24" width="20" height="20">
                            <path
                                fill="currentColor"
                                d="M19,9H15V3H9V9H5L12,16L19,9M5,18V20H19V18H5Z"
                            ></path>
                        </svg>
                        Descargar
                    </button>
                </div>
            </div>

            <div id="preview-section" class="preview-section hidden">
                <h3>Vista Previa del Collage</h3>
                <canvas id="collage-canvas"></canvas>
            </div>
        </div>
    </div>
</section>

<script>
    interface ImageData {
        src: string;
        width: number;
        height: number;
        name: string;
    }

    let loadedImages: ImageData[] = [];
    let collageCanvas: HTMLCanvasElement | null = null;

    function showError(message: string): void {
        const errorBox = document.getElementById("image-error") as HTMLDivElement;
        const errorText = document.getElementById("error-text") as HTMLSpanElement;
        if (errorBox && errorText) {
            errorText.textContent = message;
            errorBox.classList.remove("hidden");
            setTimeout(() => {
                errorBox.classList.add("hidden");
            }, 4000);
        }
    }

    function renderImagesList(): void {
        const container = document.getElementById("images-list") as HTMLDivElement;
        const listContainer = document.getElementById("images-list-container") as HTMLDivElement;
        const counter = document.getElementById("image-counter") as HTMLSpanElement;

        if (!container) return;

        if (loadedImages.length === 0) {
            if (listContainer) listContainer.classList.add("hidden");
            return;
        }

        if (listContainer) listContainer.classList.remove("hidden");
        if (counter) counter.textContent = `${loadedImages.length}/9`;

        container.innerHTML = loadedImages
            .map(
                (img, idx) => `
            <div class="image-item" data-index="${idx}">
                <div class="image-thumbnail">
                    <img src="${img.src}" alt="Imagen ${idx + 1}" />
                    <span class="image-number">${idx + 1}</span>
                </div>
                <div class="image-info">
                    <p class="image-name">${img.name}</p>
                    <p class="image-dims">${img.width}x${img.height}px</p>
                </div>
                <button class="delete-btn" type="button" data-index="${idx}" title="Eliminar">
                    <svg viewBox="0 0 24 24" width="18" height="18">
                        <path fill="currentColor" d="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"></path>
                    </svg>
                </button>
            </div>
        `
            )
            .join("");

        const deleteButtons = container.querySelectorAll(".delete-btn");
        deleteButtons.forEach((btn) => {
            btn.addEventListener("click", (e) => {
                const index = parseInt((e.currentTarget as HTMLElement).dataset.index || "-1");
                if (index >= 0) {
                    loadedImages.splice(index, 1);
                    updateImageCount();
                    renderImagesList();
                }
            });
        });
    }

    function updateImageCount(): void {
        const layoutGroup = document.getElementById("layout-group") as HTMLDivElement;
        const layoutSelect = document.getElementById("layout-select") as HTMLSelectElement;
        const createBtn = document.getElementById("create-btn") as HTMLButtonElement;

        if (loadedImages.length > 0) {
            if (layoutGroup) {
                layoutGroup.classList.remove("hidden");
            }

            if (layoutSelect) {
                const options = layoutSelect.querySelectorAll("option");
                options.forEach((option: Element) => {
                    const optionElement = option as HTMLOptionElement;
                    const requiredImages = optionElement.dataset.images;
                    if (requiredImages) {
                        const required = parseInt(requiredImages);
                        if (
                            loadedImages.length === required ||
                            (loadedImages.length <= required && required === 9)
                        ) {
                            optionElement.disabled = false;
                        } else {
                            optionElement.disabled = true;
                        }
                    }
                });

                const firstAvailable = Array.from(options).find(
                    (o: Element) =>
                        !(o as HTMLOptionElement).disabled &&
                        (o as HTMLOptionElement).value !== ""
                ) as HTMLOptionElement | undefined;
                if (firstAvailable) {
                    layoutSelect.value = firstAvailable.value;
                }
            }

            if (createBtn) {
                createBtn.disabled = false;
            }
        } else {
            if (layoutGroup) {
                layoutGroup.classList.add("hidden");
            }
            if (layoutSelect) {
                layoutSelect.value = "";
            }
            if (createBtn) {
                createBtn.disabled = true;
            }
        }
    }

    function createImageFromFile(file: File): Promise<ImageData> {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = (e: ProgressEvent<FileReader>) => {
                const img = new Image();
                img.onload = () => {
                    resolve({
                        src: e.target?.result as string,
                        width: img.width,
                        height: img.height,
                        name: file.name,
                    });
                };
                img.onerror = () => reject(new Error("Error loading image"));
                img.src = e.target?.result as string;
            };
            reader.readAsDataURL(file);
        });
    }

    async function handleImageInput(event: Event): Promise<void> {
        const input = event.target as HTMLInputElement;
        const files = Array.from(input.files || []);

        if (files.length < 2 || files.length > 9) {
            const message =
                files.length === 0
                    ? "Selecciona entre 2 y 9 imágenes"
                    : files.length === 1
                      ? "Necesitas al menos 2 imágenes"
                      : "Máximo 9 imágenes permitidas";
            showError(message);
            return;
        }

        try {
            loadedImages = await Promise.all(files.map(createImageFromFile));
            updateImageCount();
            renderImagesList();
        } catch (err) {
            showError("Error al cargar las imágenes. Intenta de nuevo.");
            console.error(err);
        }
    }

    function drawImage(
        ctx: CanvasRenderingContext2D,
        src: string,
        x: number,
        y: number,
        width: number,
        height: number
    ): Promise<void> {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => {
                ctx.drawImage(img, x, y, width, height);
                resolve();
            };
            img.onerror = () => reject(new Error("Error drawing image"));
            img.src = src;
        });
    }

    async function createCollage(): Promise<void> {
        if (loadedImages.length < 2) return;

        const layoutSelect = document.getElementById("layout-select") as HTMLSelectElement;
        const borderWidth = parseInt(
            (document.getElementById("border-width") as HTMLInputElement).value || "0"
        );
        const borderColor = (document.getElementById("border-color") as HTMLInputElement).value;
        const bgColor = (document.getElementById("bg-color") as HTMLInputElement).value;

        const layout = layoutSelect.value;
        const canvas = document.getElementById("collage-canvas") as HTMLCanvasElement;

        if (!canvas) return;

        collageCanvas = canvas;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        let canvasWidth = 800;
        let canvasHeight = 800;
        let positions: Array<[number, number, number, number]> = [];

        const gap = borderWidth;

        if (layout === "2x1") {
            canvasWidth = 800;
            canvasHeight = 400;
            const cellW = (800 - gap * 3) / 2;
            const cellH = 400 - gap * 2;
            positions = [
                [gap, gap, cellW, cellH],
                [gap * 2 + cellW, gap, cellW, cellH],
            ];
        } else if (layout === "1x2") {
            canvasWidth = 400;
            canvasHeight = 800;
            const cellW = 400 - gap * 2;
            const cellH = (800 - gap * 3) / 2;
            positions = [
                [gap, gap, cellW, cellH],
                [gap, gap * 2 + cellH, cellW, cellH],
            ];
        } else if (layout === "3-split") {
            canvasWidth = 900;
            canvasHeight = 300;
            const cellW = (900 - gap * 4) / 3;
            const cellH = 300 - gap * 2;
            positions = [
                [gap, gap, cellW, cellH],
                [gap * 2 + cellW, gap, cellW, cellH],
                [gap * 3 + cellW * 2, gap, cellW, cellH],
            ];
        } else if (layout === "2+2") {
            canvasWidth = 800;
            canvasHeight = 800;
            const cellSize = (800 - gap * 3) / 2;
            positions = [
                [gap, gap, cellSize, cellSize],
                [gap * 2 + cellSize, gap, cellSize, cellSize],
                [gap, gap * 2 + cellSize, cellSize, cellSize],
                [gap * 2 + cellSize, gap * 2 + cellSize, cellSize, cellSize],
            ];
        } else if (layout === "big-left") {
            canvasWidth = 800;
            canvasHeight = 600;
            const bigSize = 400 - gap;
            const smallSize = (800 - bigSize - gap * 4) / 3;
            positions = [
                [gap, gap, bigSize, bigSize],
                [bigSize + gap * 2, gap, smallSize, smallSize],
                [bigSize + gap * 2, gap * 2 + smallSize, smallSize, smallSize],
                [bigSize + gap * 2, gap * 3 + smallSize * 2, smallSize, smallSize],
            ];
        } else if (layout === "big-right") {
            canvasWidth = 800;
            canvasHeight = 600;
            const bigSize = 400 - gap;
            const smallSize = (800 - bigSize - gap * 4) / 3;
            positions = [
                [gap, gap, smallSize, smallSize],
                [gap, gap * 2 + smallSize, smallSize, smallSize],
                [gap, gap * 3 + smallSize * 2, smallSize, smallSize],
                [smallSize + gap * 2, gap, bigSize, bigSize],
            ];
        } else if (layout === "5-grid") {
            canvasWidth = 900;
            canvasHeight = 750;
            const col1Width = (900 - gap * 3) / 2;
            const col2Width = (900 - gap * 4) / 3;
            const row1Height = 750 - gap * 2;
            const row2Height = (750 - gap * 3) / 2;
            positions = [
                [gap, gap, col1Width, row1Height],
                [col1Width + gap * 2, gap, col2Width, row2Height],
                [col1Width + gap * 2 + col2Width + gap, gap, col2Width, row2Height],
                [col1Width + gap * 2, gap * 2 + row2Height, col2Width, row2Height],
                [col1Width + gap * 2 + col2Width + gap, gap * 2 + row2Height, col2Width, row2Height],
            ];
        } else if (layout === "2x3") {
            canvasWidth = 800;
            canvasHeight = 1200;
            const cellW = (800 - gap * 3) / 2;
            const cellH = (1200 - gap * 4) / 3;
            for (let row = 0; row < 3; row++) {
                for (let col = 0; col < 2; col++) {
                    positions.push([
                        gap * (col + 1) + cellW * col,
                        gap * (row + 1) + cellH * row,
                        cellW,
                        cellH,
                    ]);
                }
            }
        } else if (layout === "7-grid") {
            canvasWidth = 1050;
            canvasHeight = 700;
            const cellW = (1050 - gap * 4) / 3;
            const cellH = (700 - gap * 3) / 2;
            positions = [
                [gap, gap, cellW, cellH],
                [gap * 2 + cellW, gap, cellW, cellH],
                [gap * 3 + cellW * 2, gap, cellW, cellH],
                [gap, gap * 2 + cellH, cellW, cellH],
                [gap * 2 + cellW, gap * 2 + cellH, cellW, cellH],
                [gap * 3 + cellW * 2, gap * 2 + cellH, cellW, cellH],
                [gap + cellW / 4, gap * 3 + cellH * 2, cellW * 1.5, cellH],
            ];
        } else if (layout === "2x4") {
            canvasWidth = 800;
            canvasHeight = 1600;
            const cellW = (800 - gap * 3) / 2;
            const cellH = (1600 - gap * 5) / 4;
            for (let row = 0; row < 4; row++) {
                for (let col = 0; col < 2; col++) {
                    positions.push([
                        gap * (col + 1) + cellW * col,
                        gap * (row + 1) + cellH * row,
                        cellW,
                        cellH,
                    ]);
                }
            }
        } else if (layout === "3x3") {
            canvasWidth = 900;
            canvasHeight = 900;
            const cellSize = (900 - gap * 4) / 3;
            for (let row = 0; row < 3; row++) {
                for (let col = 0; col < 3; col++) {
                    positions.push([
                        gap * (col + 1) + cellSize * col,
                        gap * (row + 1) + cellSize * row,
                        cellSize,
                        cellSize,
                    ]);
                }
            }
        }

        canvas.width = canvasWidth;
        canvas.height = canvasHeight;
        ctx.fillStyle = bgColor;
        ctx.fillRect(0, 0, canvasWidth, canvasHeight);

        const imagesToUse = loadedImages.slice(0, positions.length);

        for (let i = 0; i < imagesToUse.length; i++) {
            const [x, y, width, height] = positions[i];
            await drawImage(ctx, imagesToUse[i].src, x, y, width, height);

            if (borderWidth > 0) {
                ctx.strokeStyle = borderColor;
                ctx.lineWidth = borderWidth;
                ctx.strokeRect(x - borderWidth / 2, y - borderWidth / 2, width + borderWidth, height + borderWidth);
            }
        }

        const previewSection = document.getElementById("preview-section") as HTMLDivElement;
        if (previewSection) {
            previewSection.classList.remove("hidden");
        }

        const downloadBtn = document.getElementById("download-btn") as HTMLButtonElement;
        if (downloadBtn) {
            downloadBtn.disabled = false;
        }
    }

    function downloadCollage(): void {
        if (!collageCanvas) return;

        const link = document.createElement("a");
        link.href = collageCanvas.toDataURL("image/png");
        link.download = "collage-fotos.png";
        link.click();
    }

    function updateSliderValue(event: Event): void {
        const input = event.target as HTMLInputElement;
        const value = input.value;
        const display = document.getElementById("border-width-value");
        if (display) {
            display.textContent = value;
        }
    }

    function updateColorValue(event: Event): void {
        const input = event.target as HTMLInputElement;
        const isBackgroundColor = input.id === "bg-color";
        const display = document.getElementById(
            isBackgroundColor ? "bg-color-value" : "border-color-value"
        );
        if (display) {
            display.textContent = input.value.toUpperCase();
        }
    }

    function initCollageCreator(): void {
        const imageInput = document.getElementById("image-input") as HTMLInputElement;
        const createBtn = document.getElementById("create-btn") as HTMLButtonElement;
        const downloadBtn = document.getElementById("download-btn") as HTMLButtonElement;
        const borderWidthSlider = document.getElementById("border-width") as HTMLInputElement;
        const borderColorInput = document.getElementById("border-color") as HTMLInputElement;
        const bgColorInput = document.getElementById("bg-color") as HTMLInputElement;

        if (imageInput) {
            imageInput.addEventListener("change", handleImageInput);
        }

        if (createBtn) {
            createBtn.addEventListener("click", createCollage);
        }

        if (downloadBtn) {
            downloadBtn.addEventListener("click", downloadCollage);
        }

        if (borderWidthSlider) {
            borderWidthSlider.addEventListener("input", updateSliderValue);
        }

        if (borderColorInput) {
            borderColorInput.addEventListener("input", updateColorValue);
        }

        if (bgColorInput) {
            bgColorInput.addEventListener("input", updateColorValue);
        }
    }

    document.addEventListener(
        "astro:page-load",
        () => {
            initCollageCreator();
        },
        { once: false }
    );

    initCollageCreator();
</script>
