---
import { Icon } from "astro-icon/components";
import "./CourtFeeCalculator.css";
---

<div class="court-fee-calculator-container">
    <div class="calc-wrapper">
        <aside class="calc-sidebar">
            <div class="section-title">
                <Icon name="mdi:cog" size={16} />
                Parámetros Legales
            </div>

            <div class="input-stack">
                <div class="input-field">
                    <label for="entity-type">Sujeto Pasivo</label>
                    <select id="entity-type" class="input-control">
                        <option value="juridica">Persona Jurídica (S.L., S.A.)</option>
                        <option value="fisica">Persona Física (Exento)</option>
                    </select>
                </div>

                <div class="input-field">
                    <label for="jurisdiction">Jurisdicción</label>
                    <select id="jurisdiction" class="input-control">
                        <option value="civil">Orden Civil</option>
                        <option value="contencioso">Contencioso-Administrativo</option>
                        <option value="social">Orden Social</option>
                    </select>
                </div>

                <div class="input-field">
                    <label for="procedure">Tipo de Proceso</label>
                    <select id="procedure" class="input-control">
                        <option value="ordinario" class="opt-civil">Juicio Ordinario (300€)</option>
                        <option value="monitorio" class="opt-civil"
                            >Juicio Verbal / Monitorio (100€)</option
                        >
                        <option value="ejecutivo" class="opt-civil">Ejecutivo (200€)</option>
                        <option value="apelacion" class="opt-civil">Apelación (800€)</option>
                        <option value="casacion" class="opt-civil">Casación (1.200€)</option>

                        <option value="abreviado" class="opt-contencioso" style="display:none"
                            >Abreviado (200€)</option
                        >
                        <option value="cont-ordinario" class="opt-contencioso" style="display:none"
                            >Ordinario (350€)</option
                        >
                        <option value="cont-apelacion" class="opt-contencioso" style="display:none"
                            >Apelación (800€)</option
                        >
                        <option value="cont-casacion" class="opt-contencioso" style="display:none"
                            >Casación (1.200€)</option
                        >

                        <option value="suplicacion" class="opt-social" style="display:none"
                            >Suplicación (500€)</option
                        >
                        <option value="soc-casacion" class="opt-social" style="display:none"
                            >Casación (600€)</option
                        >
                    </select>
                </div>

                <div class="input-field" id="amount-container">
                    <label for="claim-amount">Cuantía del Litigio</label>
                    <div style="position: relative;">
                        <input
                            type="number"
                            id="claim-amount"
                            class="input-control"
                            value="30000"
                            step="1000"
                        />
                        <span
                            style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); font-weight: 700; color: var(--court-accent);"
                            >€</span
                        >
                    </div>
                </div>
            </div>
        </aside>

        <main class="calc-main">
            <div class="result-header">
                <span class="total-label">Liquidación Estimada</span>
                <div id="exento-tag" class="badge-exento" style="display:none">Sujeto Exento</div>
            </div>

            <div class="total-display">
                <Icon name="mdi:gavel" class="legal-seal" size={120} />
                <span class="total-amount" id="val-total">0,00 €</span>
                <span class="total-label" id="val-info-text">Modelo 696 AEAT</span>
            </div>

            <div class="breakdown-list">
                <div class="breakdown-item">
                    <span class="item-label">Cuota Fija (Procesal)</span>
                    <span class="item-value" id="val-fixed">0,00 €</span>
                </div>
                <div class="breakdown-item">
                    <span class="item-label">Cuota Variable (0,5% / 0,25%)</span>
                    <span class="item-value" id="val-variable">0,00 €</span>
                </div>
                <div class="breakdown-item">
                    <span class="item-label">Base Imponible</span>
                    <span class="item-value" id="val-base">30.000 €</span>
                </div>
            </div>

            <footer class="actions-area">
                <button class="btn-premium" id="btn-copy">
                    <Icon name="mdi:content-copy" size={20} />
                    Copiar Liquidación Jurídica
                </button>
            </footer>
        </main>
    </div>
</div>

<script>
    const entity = document.getElementById("entity-type") as HTMLSelectElement | null;
    const juris = document.getElementById("jurisdiction") as HTMLSelectElement | null;
    const procedure = document.getElementById("procedure") as HTMLSelectElement | null;
    const amount = document.getElementById("claim-amount") as HTMLInputElement | null;
    const amountContainer = document.getElementById("amount-container");

    const totalDisp = document.getElementById("val-total");
    const fixedDisp = document.getElementById("val-fixed");
    const variableDisp = document.getElementById("val-variable");
    const baseDisp = document.getElementById("val-base");
    const exentoTag = document.getElementById("exento-tag");
    const copyBtn = document.getElementById("btn-copy");

    const DATA = {
        civil: { ordinario: 300, monitorio: 100, ejecutivo: 200, apelacion: 800, casacion: 1200 },
        contencioso: {
            abreviado: 200,
            "cont-ordinario": 350,
            "cont-apelacion": 800,
            "cont-casacion": 1200,
        },
        social: { suplicacion: 500, "soc-casacion": 600 },
    };

    function fmt(n: number) {
        return new Intl.NumberFormat("es-ES", { style: "currency", currency: "EUR" }).format(n);
    }

    function sync() {
        if (!juris || !procedure) return;
        const j = juris.value;
        const opts = procedure.options;
        let first = "";
        for (let i = 0; i < opts.length; i++) {
            const isMatch = opts[i].classList.contains(`opt-${j}`);
            opts[i].style.display = isMatch ? "block" : "none";
            if (isMatch && !first) first = opts[i].value;
        }
        if (first) procedure.value = first;

        if (amountContainer) {
            amountContainer.style.opacity = j === "social" ? "0.3" : "1";
            amountContainer.style.pointerEvents = j === "social" ? "none" : "auto";
        }

        calc();
    }

    function calc() {
        if (!entity || !juris || !procedure || !amount) return;

        const isFisica = entity.value === "fisica";
        if (exentoTag) exentoTag.style.display = isFisica ? "inline-block" : "none";

        if (isFisica) {
            if (totalDisp) totalDisp.textContent = "0,00 €";
            if (fixedDisp) fixedDisp.textContent = "0,00 €";
            if (variableDisp) variableDisp.textContent = "0,00 €";
            if (baseDisp) baseDisp.textContent = "Exento";
            return;
        }

        const jVal = juris.value as keyof typeof DATA;
        const pVal = procedure.value;
        const amt = parseFloat(amount.value) || 0;

        const fixed = (DATA[jVal] as any)[pVal] || 0;
        let variable = 0;

        if (jVal !== "social") {
            if (amt <= 1000000) {
                variable = amt * 0.005;
            } else {
                variable = 5000 + (amt - 1000000) * 0.0025;
            }
            if (variable > 10000) variable = 10000;
        }

        const total = fixed + variable;

        if (totalDisp) {
            totalDisp.textContent = fmt(total);
            totalDisp.classList.remove("animate-value");
            void totalDisp.offsetWidth;
            totalDisp.classList.add("animate-value");
        }
        if (fixedDisp) fixedDisp.textContent = fmt(fixed);
        if (variableDisp) variableDisp.textContent = fmt(variable);
        if (baseDisp) baseDisp.textContent = fmt(amt);
    }

    juris?.addEventListener("change", sync);
    [entity, procedure, amount].forEach((el) => el?.addEventListener("input", calc));

    copyBtn?.addEventListener("click", () => {
        const text = `
LIQUIDACIÓN DE TASAS (MODELO 696)
-------------------------------
Sujeto: ${entity?.options[entity.selectedIndex].text}
Orden: ${juris?.options[juris.selectedIndex].text}
Proceso: ${procedure?.options[procedure.selectedIndex].text}
Cuantía: ${baseDisp?.textContent}
-------------------------------
Cuota Fija: ${fixedDisp?.textContent}
Cuota Variable: ${variableDisp?.textContent}
TOTAL: ${totalDisp?.textContent}

Simulación realizada en jjlmoya.es
        `.trim();
        navigator.clipboard.writeText(text);
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = "¡Copiado!";
        setTimeout(() => (copyBtn.innerHTML = original), 2000);
    });

    sync();
</script>
