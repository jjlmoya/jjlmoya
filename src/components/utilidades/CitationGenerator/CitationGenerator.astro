---
import "./CitationGenerator.css";
---

<div class="citation-generator-container view-fade-in">
    <div class="type-tabs">
        <button class="type-tab active" data-type="book">Libro</button>
        <button class="type-tab" data-type="website">Sitio Web</button>
        <button class="type-tab" data-type="article">Artículo</button>
    </div>

    <div class="generator-grid">
        <div class="config-section">
            <div class="form-grid">
                <div class="field-group">
                    <label class="field-label">Formato</label>
                    <select id="citation-style" class="input-control select-control">
                        <option value="apa">APA (7ª edición)</option>
                        <option value="mla">MLA (9ª edición)</option>
                        <option value="vancouver">Vancouver</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Año de publicación</label>
                    <input type="text" id="year" class="input-control" placeholder="Ej: 2024" />
                </div>
            </div>

            <div class="field-group">
                <label class="field-label">Autores (Apellidos, Iniciales)</label>
                <input
                    type="text"
                    id="authors"
                    class="input-control"
                    placeholder="Ej: Perez, J.; Garcia, M."
                />
            </div>

            <div class="field-group">
                <label class="field-label" id="title-label">Título del libro</label>
                <input
                    type="text"
                    id="title"
                    class="input-control"
                    placeholder="Ingrese el título completo"
                />
            </div>

            <div class="form-grid">
                <div class="field-group" id="extra-field-container">
                    <label class="field-label" id="extra-label">Editorial</label>
                    <input
                        type="text"
                        id="extra-field"
                        class="input-control"
                        placeholder="Ej: Editorial Médica Panamericana"
                    />
                </div>
                <div class="field-group">
                    <label class="field-label">Ciudad / URL</label>
                    <input
                        type="text"
                        id="location-url"
                        class="input-control"
                        placeholder="Ej: Madrid o https://..."
                    />
                </div>
            </div>

            <button id="add-to-history" class="add-btn">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg
                >
                Guardar en mi lista
            </button>
        </div>

        <div class="results-sidebar">
            <div class="preview-card">
                <div class="preview-title">Vista Previa</div>
                <div id="citation-output" class="citation-result" title="Haz clic para copiar">
                    Introduce los datos para generar la cita...
                </div>
                <div class="copy-helper">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
                        ></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg
                    >
                    Haz clic en la cita para copiarla directamente
                </div>
            </div>
        </div>
    </div>

    <div class="history-section">
        <h3 class="history-title">Mis Citas Guardadas</h3>
        <div id="history-list" class="history-list"></div>
    </div>
</div>

<script>
    interface CitationData {
        id: string;
        authors: string;
        year: string;
        title: string;
        extra: string;
        location: string;
        style: string;
        type: string;
        formatted: string;
    }

    const STORAGE_KEY = "jjlmoya_citations_v1";

    const inputs = {
        style: document.getElementById("citation-style") as HTMLSelectElement,
        year: document.getElementById("year") as HTMLInputElement,
        authors: document.getElementById("authors") as HTMLInputElement,
        title: document.getElementById("title") as HTMLInputElement,
        extra: document.getElementById("extra-field") as HTMLInputElement,
        location: document.getElementById("location-url") as HTMLInputElement,
    };

    const output = document.getElementById("citation-output");
    const historyList = document.getElementById("history-list");
    const addBtn = document.getElementById("add-to-history");
    const tabs = document.querySelectorAll(".type-tab");

    const labels = {
        title: document.getElementById("title-label"),
        extra: document.getElementById("extra-label"),
    };

    let currentType = "book";

    function formatAPA(data: any): string {
        const { authors, year, title, extra, location, type } = data;
        const authorStr = authors ? `${authors}. ` : "";
        const yearStr = year ? `(${year}). ` : "";

        if (type === "book") {
            return `${authorStr}${yearStr}<em>${title}</em>. ${extra}.`;
        } else if (type === "website") {
            return `${authorStr}${yearStr}<em>${title}</em>. ${extra}. Recuperado de ${location}`;
        } else {
            return `${authorStr}${yearStr}${title}. <em>${extra}</em>. ${location}`;
        }
    }

    function formatMLA(data: any): string {
        const { authors, year, title, extra, location, type } = data;
        const authorStr = authors ? `${authors}. ` : "";

        if (type === "book") {
            return `${authorStr}<em>${title}</em>. ${extra}, ${year}.`;
        } else if (type === "website") {
            return `${authorStr}"${title}." <em>${extra}</em>, ${year}, ${location}.`;
        } else {
            return `${authorStr}"${title}." <em>${extra}</em>, vol. ${location}, ${year}.`;
        }
    }

    function formatVancouver(data: any): string {
        const { authors, year, title, extra, location, type } = data;
        const authorStr = authors ? `${authors}. ` : "";

        if (type === "book") {
            return `${authorStr}${title}. ${location}: ${extra}; ${year}.`;
        } else if (type === "website") {
            return `${authorStr}${title} [Internet]. ${extra}; ${year} [citado el ${new Date().toLocaleDateString()}]. Disponible en: ${location}`;
        } else {
            return `${authorStr}${title}. ${extra}. ${year};${location}.`;
        }
    }

    function updatePreview() {
        const data = {
            authors: inputs.authors.value.trim(),
            year: inputs.year.value.trim(),
            title: inputs.title.value.trim(),
            extra: inputs.extra.value.trim(),
            location: inputs.location.value.trim(),
            type: currentType,
        };

        if (!data.title) {
            if (output) output.innerHTML = "Introduce al menos el título...";
            return;
        }

        const style = inputs.style.value;
        let formatted = "";

        if (style === "apa") formatted = formatAPA(data);
        else if (style === "mla") formatted = formatMLA(data);
        else formatted = formatVancouver(data);

        if (output) output.innerHTML = formatted;
        return formatted;
    }

    function saveToLocalStorage(item: CitationData) {
        const saved = localStorage.getItem(STORAGE_KEY);
        const list: CitationData[] = saved ? JSON.parse(saved) : [];
        list.unshift(item);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
        renderHistory();
    }

    function renderHistory() {
        if (!historyList) return;
        const saved = localStorage.getItem(STORAGE_KEY);
        const list: CitationData[] = saved ? JSON.parse(saved) : [];

        historyList.innerHTML = list.length
            ? ""
            : '<div style="text-align: center; opacity: 0.5; padding: 2rem;">No tienes citas guardadas.</div>';

        list.forEach((item) => {
            const el = document.createElement("div");
            el.className = "history-item";
            el.innerHTML = `
                <div class="history-text">${item.formatted}</div>
                <div class="history-actions">
                    <button class="action-btn btn-copy-history" title="Copiar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                    <button class="action-btn btn-delete" title="Borrar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                    </button>
                </div>
            `;

            el.querySelector(".btn-delete")?.addEventListener("click", () => {
                const newList = list.filter((i) => i.id !== item.id);
                localStorage.setItem(STORAGE_KEY, JSON.stringify(newList));
                renderHistory();
            });

            el.querySelector(".btn-copy-history")?.addEventListener("click", () => {
                const text = el.querySelector(".history-text")?.textContent || "";
                navigator.clipboard.writeText(text);
                const btn = el.querySelector(".btn-copy-history");
                if (btn)
                    btn.innerHTML =
                        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                setTimeout(() => {
                    if (btn)
                        btn.innerHTML =
                            '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
                }, 2000);
            });

            historyList.appendChild(el);
        });
    }

    tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            tabs.forEach((t) => t.classList.remove("active"));
            tab.classList.add("active");
            currentType = tab.getAttribute("data-type") || "book";

            if (currentType === "book") {
                if (labels.title) labels.title.textContent = "Título del libro";
                if (labels.extra) labels.extra.textContent = "Editorial";
                inputs.extra.placeholder = "Ej: Editorial Planeta";
            } else if (currentType === "website") {
                if (labels.title) labels.title.textContent = "Título de la página";
                if (labels.extra) labels.extra.textContent = "Nombre del sitio";
                inputs.extra.placeholder = "Ej: Wikipedia o El País";
            } else {
                if (labels.title) labels.title.textContent = "Título del artículo";
                if (labels.extra) labels.extra.textContent = "Nombre de la revista";
                inputs.extra.placeholder = "Ej: Nature o Journal of Medicine";
            }
            updatePreview();
        });
    });

    Object.values(inputs).forEach((input) => {
        input.addEventListener("input", updatePreview);
    });

    addBtn?.addEventListener("click", () => {
        const formatted = updatePreview();
        if (formatted && formatted !== "Introduce al menos el título...") {
            saveToLocalStorage({
                id: Date.now().toString(),
                authors: inputs.authors.value,
                year: inputs.year.value,
                title: inputs.title.value,
                extra: inputs.extra.value,
                location: inputs.location.value,
                style: inputs.style.value,
                type: currentType,
                formatted: formatted,
            });
        }
    });

    let isCopying = false;
    output?.addEventListener("click", () => {
        if (isCopying) return;

        const text = output?.textContent || "";
        if (text && text !== "Introduce al menos el título...") {
            isCopying = true;
            navigator.clipboard.writeText(text);

            output.classList.add("copied-pulse");
            const originalHtml = output.innerHTML;
            output.innerHTML = "¡Copiado!";

            setTimeout(() => {
                output.classList.remove("copied-pulse");
                output.innerHTML = originalHtml;
                isCopying = false;
            }, 1000);
        }
    });

    renderHistory();
</script>
