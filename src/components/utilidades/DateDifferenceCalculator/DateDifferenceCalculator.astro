---
import "./DateDifferenceCalculator.css";
---

<div class="date-calculator-container">
    <div class="date-input-grid">
        <div class="input-block">
            <div class="label-wrapper">
                <span class="input-label">Fecha de Inicio</span>
                <div class="quick-actions">
                    <button class="btn-quick" data-action="now" data-target="start">Ahora</button>
                    <button class="btn-quick" data-action="today" data-target="start">Hoy</button>
                </div>
            </div>
            <div class="date-field-wrapper">
                <input type="datetime-local" id="date-start" class="date-input" />
            </div>
        </div>

        <div class="input-block">
            <div class="label-wrapper">
                <span class="input-label">Fecha de Fin</span>
                <div class="quick-actions">
                    <button class="btn-quick" data-action="now" data-target="end">Ahora</button>
                    <button class="btn-quick" data-action="tomorrow" data-target="end"
                        >Mañana</button
                    >
                </div>
            </div>
            <div class="date-field-wrapper">
                <input type="datetime-local" id="date-end" class="date-input" />
            </div>
        </div>
    </div>

    <div class="results-display">
        <div class="main-diff-text" id="main-diff-text">Calculando Diferencia...</div>

        <div class="diff-grid">
            <div class="diff-item">
                <span class="diff-value" id="val-days">0</span>
                <span class="diff-label">Días</span>
            </div>
            <div class="diff-item">
                <span class="diff-value" id="val-hours">0</span>
                <span class="diff-label">Horas</span>
            </div>
            <div class="diff-item">
                <span class="diff-value" id="val-mins">0</span>
                <span class="diff-label">Mins</span>
            </div>
            <div class="diff-item">
                <span class="diff-value" id="val-secs">0</span>
                <span class="diff-label">Segs</span>
            </div>
        </div>

        <div class="secondary-results">
            <div class="secondary-item">
                <span id="total-weeks">0</span>
                <span>Semanas Totales</span>
            </div>
            <div class="secondary-item">
                <span id="total-hours">0</span>
                <span>Horas Totales</span>
            </div>
            <div class="secondary-item">
                <span id="total-minutes">0</span>
                <span>Minutos Totales</span>
            </div>
        </div>
    </div>
</div>

<script>
    const inputStart = document.getElementById("date-start") as HTMLInputElement | null;
    const inputEnd = document.getElementById("date-end") as HTMLInputElement | null;
    const valDays = document.getElementById("val-days");
    const valHours = document.getElementById("val-hours");
    const valMins = document.getElementById("val-mins");
    const valSecs = document.getElementById("val-secs");
    const mainText = document.getElementById("main-diff-text");
    const totalWeeks = document.getElementById("total-weeks");
    const totalHours = document.getElementById("total-hours");
    const totalMinutes = document.getElementById("total-minutes");
    const quickBtns = document.querySelectorAll(".btn-quick");

    function formatDateTimeLocal(date: Date): string {
        const offset = date.getTimezoneOffset() * 60000;
        const localISOTime = new Date(date.getTime() - offset).toISOString().slice(0, 16);
        return localISOTime;
    }

    function initInputs() {
        if (!inputStart || !inputEnd) return;
        const now = new Date();
        const tomorrow = new Date(now);
        tomorrow.setDate(now.getDate() + 1);

        inputStart.value = formatDateTimeLocal(now);
        inputEnd.value = formatDateTimeLocal(tomorrow);

        calculate();
    }

    function calculate() {
        if (!inputStart || !inputEnd) return;

        const start = new Date(inputStart.value).getTime();
        const end = new Date(inputEnd.value).getTime();

        if (isNaN(start) || isNaN(end)) {
            if (mainText) mainText.textContent = "Datos no válidos";
            return;
        }

        const diff = Math.abs(end - start);

        const seconds = Math.floor(diff / 1000);
        const minutes = Math.floor(seconds / 60);
        const hours = Math.floor(minutes / 60);
        const days = Math.floor(hours / 24);

        const remHours = hours % 24;
        const remMinutes = minutes % 60;
        const remSeconds = seconds % 60;

        if (valDays) valDays.textContent = days.toString();
        if (valHours) valHours.textContent = remHours.toString();
        if (valMins) valMins.textContent = remMinutes.toString();
        if (valSecs) valSecs.textContent = remSeconds.toString();

        if (totalWeeks) totalWeeks.textContent = (days / 7).toFixed(1);
        if (totalHours) totalHours.textContent = hours.toLocaleString();
        if (totalMinutes) totalMinutes.textContent = minutes.toLocaleString();

        if (mainText) {
            const isFuture = end >= start;
            mainText.textContent = isFuture ? "Tiempo Transcurrido" : "Tiempo en el Pasado";
        }
    }

    inputStart?.addEventListener("change", calculate);
    inputEnd?.addEventListener("change", calculate);

    quickBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const action = btn.getAttribute("data-action");
            const target = btn.getAttribute("data-target");
            const targetInput = target === "start" ? inputStart : inputEnd;

            if (!targetInput) return;

            const now = new Date();
            if (action === "now") {
                targetInput.value = formatDateTimeLocal(now);
            } else if (action === "today") {
                now.setHours(0, 0, 0, 0);
                targetInput.value = formatDateTimeLocal(now);
            } else if (action === "tomorrow") {
                now.setDate(now.getDate() + 1);
                now.setHours(0, 0, 0, 0);
                targetInput.value = formatDateTimeLocal(now);
            }

            calculate();
        });
    });

    initInputs();
</script>
