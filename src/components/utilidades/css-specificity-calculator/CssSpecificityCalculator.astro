---
import "./CssSpecificityCalculator.css";
---

<div class="spec-container">
    <div class="spec-header">
        <h2>Calculadora de Especificidad</h2>
        <p>
            Introduce dos selectores CSS para calcular su especificidad y compararlos. Descubre
            visualmente cuál regla prevalecerá en tu diseño.
        </p>
    </div>

    <div class="spec-comparison-grid">
        <div class="spec-vs-badge">VS</div>

        
        <div class="spec-block" id="block-a">
            <div class="spec-winner-banner">🏆 ¡Este selector gana!</div>
            <div class="spec-form-group">
                <label for="spec-input-a" class="spec-label">Selector A</label>
                <input
                    type="text"
                    id="spec-input-a"
                    class="spec-input"
                    placeholder="ej. #header .nav-item > a"
                    autocomplete="off"
                    spellcheck="false"
                />
            </div>

            <div class="spec-results-grid">
                <div class="spec-card spec-card-1">
                    <div class="spec-card-value" id="res-a-id">0</div>
                    <div class="spec-card-title">IDs</div>
                </div>
                <div class="spec-card spec-card-2">
                    <div class="spec-card-value" id="res-a-class">0</div>
                    <div class="spec-card-title">Clases / Pseudos</div>
                </div>
                <div class="spec-card spec-card-3">
                    <div class="spec-card-value" id="res-a-element">0</div>
                    <div class="spec-card-title">Elementos</div>
                </div>
            </div>
        </div>

        
        <div class="spec-block" id="block-b">
            <div class="spec-winner-banner">🏆 ¡Este selector gana!</div>
            <div class="spec-form-group">
                <label for="spec-input-b" class="spec-label">Selector B</label>
                <input
                    type="text"
                    id="spec-input-b"
                    class="spec-input"
                    placeholder="ej. ul li.active a:hover"
                    autocomplete="off"
                    spellcheck="false"
                />
            </div>

            <div class="spec-results-grid">
                <div class="spec-card spec-card-1">
                    <div class="spec-card-value" id="res-b-id">0</div>
                    <div class="spec-card-title">IDs</div>
                </div>
                <div class="spec-card spec-card-2">
                    <div class="spec-card-value" id="res-b-class">0</div>
                    <div class="spec-card-title">Clases / Pseudos</div>
                </div>
                <div class="spec-card spec-card-3">
                    <div class="spec-card-value" id="res-b-element">0</div>
                    <div class="spec-card-title">Elementos</div>
                </div>
            </div>
        </div>
    </div>

    <div class="spec-tie-message" id="tie-message">
        ⚖️ Ambos selectores tienen el mismo peso. Si compiten por el mismo elemento, ganará el que
        esté escrito <b>último</b> en el archivo CSS de forma descendente.
    </div>
</div>

<script>
    const inputA = document.getElementById("spec-input-a") as HTMLInputElement;
    const inputB = document.getElementById("spec-input-b") as HTMLInputElement;
    const blockA = document.getElementById("block-a");
    const blockB = document.getElementById("block-b");
    const tieMessage = document.getElementById("tie-message");

    
    const resA = {
        ids: document.getElementById("res-a-id"),
        classes: document.getElementById("res-a-class"),
        elements: document.getElementById("res-a-element"),
    };

    
    const resB = {
        ids: document.getElementById("res-b-id"),
        classes: document.getElementById("res-b-class"),
        elements: document.getElementById("res-b-element"),
    };

    function calculateSpecificity(selector: string) {
        if (!selector.trim()) return [0, 0, 0];

        let s = selector;

        const ids = (s.match(/#[a-zA-Z0-9_\-]+/g) || []).length;
        s = s.replace(/#[a-zA-Z0-9_\-]+/g, " ");

        const classes = (s.match(/\.[a-zA-Z0-9_\-]+/g) || []).length;
        s = s.replace(/\.[a-zA-Z0-9_\-]+/g, " ");

        const attrs = (s.match(/\[[^\]]+\]/g) || []).length;
        s = s.replace(/\[[^\]]+\]/g, " ");

        const pElemsMatch = s.match(/::[a-zA-Z0-9_\-]+/g) || [];
        const pElems = pElemsMatch.length;
        s = s.replace(/::[a-zA-Z0-9_\-]+/g, " ");

        const pClassesMatch = s.match(/:[a-zA-Z0-9_\-\(\)]+/g) || [];
        const pClasses = pClassesMatch.length;
        s = s.replace(/:[a-zA-Z0-9_\-\(\)]+/g, " ");

        s = s
            .replace(/[*+>~,]/g, " ")
            .replace(/\s+/g, " ")
            .trim();
        const elems = s ? s.split(" ").length : 0;

        return [ids, classes + attrs + pClasses, elems + pElems];
    }

    function compareAndRender() {
        if (!inputA || !inputB || !blockA || !blockB || !tieMessage) return;

        const valA = inputA.value.trim();
        const valB = inputB.value.trim();

        const specA = calculateSpecificity(valA);
        const specB = calculateSpecificity(valB);

        
        if (resA.ids && resA.classes && resA.elements) {
            resA.ids.textContent = specA[0].toString();
            resA.classes.textContent = specA[1].toString();
            resA.elements.textContent = specA[2].toString();
        }

        if (resB.ids && resB.classes && resB.elements) {
            resB.ids.textContent = specB[0].toString();
            resB.classes.textContent = specB[1].toString();
            resB.elements.textContent = specB[2].toString();
        }

        
        blockA.classList.remove("winner");
        blockB.classList.remove("winner");
        tieMessage.classList.remove("visible");

        if (!valA && !valB) return;

        
        let winner = 0; 

        for (let i = 0; i < 3; i++) {
            if (specA[i] > specB[i]) {
                winner = 1;
                break;
            } else if (specB[i] > specA[i]) {
                winner = 2;
                break;
            }
        }

        if (winner === 1 && valA) {
            blockA.classList.add("winner");
        } else if (winner === 2 && valB) {
            blockB.classList.add("winner");
        } else if (winner === 0 && valA && valB) {
            tieMessage.classList.add("visible");
        }
    }

    if (inputA && inputB) {
        inputA.addEventListener("input", compareAndRender);
        inputB.addEventListener("input", compareAndRender);
    }
</script>
