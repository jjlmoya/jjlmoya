---

<div class="glass-panel wrapper-items mt-4">
    <div class="control-group">
        <div class="flex-between">
            <h4>4. Filas de Factura</h4>
            <button type="button" id="btn-add-item" class="btn-sm">+ Fila</button>
        </div>
        <div class="items-editor-list" id="items-editor-list"></div>
    </div>

    <div class="control-group">
        <h4>5. Impuestos</h4>
        <div class="input-grid">
            <div class="input-with-label">
                <label>IVA (%):</label>
                <input type="number" id="inv-tax" value="21" min="0" max="100" />
            </div>
            <div class="input-with-label">
                <label>IRPF retenido (%):</label>
                <input type="number" id="inv-retention" value="0" min="0" max="100" />
            </div>
        </div>
    </div>

    <button type="button" id="btn-print-invoice" class="primary-btn print-btn">
        Generar PDF / Imprimir
    </button>
</div>
