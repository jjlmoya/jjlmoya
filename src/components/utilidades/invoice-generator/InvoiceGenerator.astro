---
import InvoiceEditableDoc from "./InvoiceEditableDoc.astro";
import "./InvoiceGenerator.css";
---

<section class="invoice-utility">
    <div class="invoice-container">
        <div class="print-actions no-print glass-header">
            <div class="action-text">
                <h3>Editor Interactivo</h3>
                <p>Haz clic en cualquier texto del documento para editarlo directamente.</p>
            </div>
            <button type="button" id="btn-print-invoice" class="primary-btn shrink-0">
                <svg viewBox="0 0 24 24" width="20" height="20" class="mr-2 inline">
                    <path
                        fill="currentColor"
                        d="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z"
                    ></path>
                </svg>
                Generar PDF Final
            </button>
        </div>

        <div class="a4-wrapper print-area">
            <InvoiceEditableDoc />
        </div>
    </div>
</section>

<script>
    import { initInvoiceGenerator } from "./InvoiceController";

    document.addEventListener(
        "astro:page-load",
        () => {
            initInvoiceGenerator();
        },
        { once: false }
    );

    setTimeout(initInvoiceGenerator, 50);
</script>
