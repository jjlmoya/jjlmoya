---

---

<div class="invoice-document" id="invoice-document">
    <div class="inv-header">
        <div class="inv-header-left">
            <h1 class="inv-title">FACTURA</h1>
            <div class="inv-meta">
                <p><strong>Nº:</strong> <span id="out-number"></span></p>
                <p><strong>Fecha:</strong> <span id="out-date"></span></p>
            </div>
        </div>
    </div>

    <div class="inv-parties">
        <div class="inv-from">
            <h3>De:</h3>
            <p class="font-bold" id="out-from-name"></p>
            <p id="out-from-id"></p>
            <p id="out-from-address"></p>
            <p id="out-from-email"></p>
        </div>
        <div class="inv-to">
            <h3>A:</h3>
            <p class="font-bold" id="out-to-name"></p>
            <p id="out-to-id"></p>
            <p id="out-to-address"></p>
            <p id="out-to-email"></p>
        </div>
    </div>

    <table class="inv-table">
        <thead>
            <tr>
                <th class="text-left w-full">Descripción</th>
                <th class="text-right">Unid.</th>
                <th class="text-right">Precio (<span class="out-currency">€</span>)</th>
                <th class="text-right">Total (<span class="out-currency">€</span>)</th>
            </tr>
        </thead>
        <tbody id="out-items-body"></tbody>
    </table>

    <div class="inv-footer">
        <div class="inv-notes">
            <p class="font-bold mb-1">Notas / IBAN:</p>
            <textarea id="inv-notes-input" class="no-print notes-textarea inline-editor"></textarea>
            <div id="out-notes" class="print-only whitespace-pre-line text-sm"></div>
        </div>

        <div class="inv-totals">
            <div class="tot-row">
                <span>Base M.I:</span>
                <span><span id="out-subtotal"></span> <span class="out-currency">€</span></span>
            </div>
            <div class="tot-row text-slate-500" id="row-tax">
                <span>IVA (<span id="out-tax-pct"></span>%):</span>
                <span><span id="out-tax-val"></span> <span class="out-currency">€</span></span>
            </div>
            <div class="tot-row text-slate-500" id="row-retention" style="display: none;">
                <span>IRPF (<span id="out-ret-pct"></span>%):</span>
                <span>-<span id="out-ret-val"></span> <span class="out-currency">€</span></span>
            </div>
            <div class="tot-row tot-final">
                <span>TOTAL A PAGAR:</span>
                <span><span id="out-total"></span> <span class="out-currency">€</span></span>
            </div>
        </div>
    </div>

    <div class="inv-brand-stripe"></div>
</div>
