---

---

<div class="glass-panel wrapper-controls">
    <h3 class="panel-title">Configuración</h3>

    <div class="control-group">
        <h4>1. Emisor</h4>
        <div class="input-grid">
            <input
                type="text"
                id="inv-from-name"
                placeholder="Tu Nombre/Empresa"
                value="Mi Empresa S.L."
            />
            <input type="text" id="inv-from-id" placeholder="NIF/CIF" value="B12345678" />
            <input
                type="text"
                id="inv-from-address"
                placeholder="Dirección Postal"
                value="Calle Real 1, Madrid"
            />
            <input
                type="text"
                id="inv-from-email"
                placeholder="Contacto"
                value="hola@ejemplo.com"
            />
        </div>
    </div>

    <div class="control-group">
        <h4>2. Cliente</h4>
        <div class="input-grid">
            <input type="text" id="inv-to-name" placeholder="Nombre Cliente" value="Cliente S.A." />
            <input type="text" id="inv-to-id" placeholder="NIF/CIF Cliente" value="A87654321" />
            <input
                type="text"
                id="inv-to-address"
                placeholder="Dirección Cliente"
                value="Avenida Sur 45"
            />
            <input type="text" id="inv-to-email" placeholder="Contacto" value="info@cliente.com" />
        </div>
    </div>

    <div class="control-group">
        <h4>3. Metadatos</h4>
        <div class="input-grid">
            <div class="input-with-label">
                <label>Nº Factura:</label>
                <input type="text" id="inv-number" value="FAC-24-01" />
            </div>
            <div class="input-with-label">
                <label>Fecha:</label>
                <input type="date" id="inv-date" />
            </div>
            <div class="input-with-label">
                <label>Moneda:</label>
                <select id="inv-currency">
                    <option value="€" selected>EUR (€)</option>
                    <option value="$">USD ($)</option>
                </select>
            </div>
        </div>
    </div>
</div>
