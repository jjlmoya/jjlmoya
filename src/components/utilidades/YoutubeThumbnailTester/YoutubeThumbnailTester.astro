---
import { Icon } from "astro-icon/components";
import "./YoutubeThumbnailTester.css";

const defaultImage = "/images/utilities/youtube-thumbnail-tester/default-thumb.webp";
const defaultAvatar = "/images/utilities/youtube-thumbnail-tester/avatar.webp";
const defaultTitle = "Descargas las aplicaciones de Gamebob Ahora";
const defaultChannel = "GameBob";
---

<div class="yt-tester-container">
    <div class="premium-card">
        <div class="main-layout">
            <aside class="sidebar">
                <div class="upload-group">
                    <div
                        id="dropThumb"
                        class="drop-zone"
                        role="button"
                        aria-label="Añadir miniaturas"
                    >
                        <div class="drop-icon"><Icon name="mdi:image-multiple" /></div>
                        <div class="drop-text">
                            <h3>Feed</h3>
                            <p>Añadir miniaturas</p>
                        </div>
                        <input
                            type="file"
                            id="thumbInput"
                            accept="image/*"
                            multiple
                            class="hidden"
                        />
                    </div>

                    <div
                        id="dropAvatar"
                        class="drop-zone"
                        role="button"
                        aria-label="Cambiar avatar"
                    >
                        <div class="drop-icon"><Icon name="mdi:account-circle" /></div>
                        <div class="drop-text">
                            <h3>Avatar</h3>
                            <p>Logo del canal</p>
                        </div>
                        <input type="file" id="avatarInput" accept="image/*" class="hidden" />
                    </div>
                </div>

                <div id="galleryPreview" class="gallery-preview"></div>

                <div class="custom-settings">
                    <div class="settings-group">
                        <label>Título común</label>
                        <input
                            type="text"
                            id="mockupTitle"
                            value={defaultTitle}
                            placeholder="Título..."
                        />
                    </div>
                    <div class="settings-group">
                        <label>Nombre del Canal</label>
                        <input
                            type="text"
                            id="mockupChannel"
                            value={defaultChannel}
                            placeholder="Canal..."
                        />
                    </div>
                </div>

                <div class="tester-controls">
                    <button id="btnDesktop" class="control-btn active" data-view="desktop">
                        <Icon name="mdi:monitor" />
                        <span>Escritorio</span>
                    </button>
                    <button id="btnMobile" class="control-btn" data-view="mobile">
                        <Icon name="mdi:cellphone" />
                        <span>Móvil</span>
                    </button>
                    <button
                        id="btnReset"
                        class="control-btn"
                        style="grid-column: span 2; color: #ef4444; border-color: rgba(239, 68, 68, 0.2);"
                    >
                        <Icon name="mdi:delete-sweep" />
                        <span>Limpiar Feed</span>
                    </button>
                </div>
            </aside>

            <main class="preview-area">
                <div class="comparison-container" id="comparisonContainer">
                    <div class="comparison-side yt-mockup light">
                        <span class="comparison-label">MODO CLARO</span>
                        <div id="comparisonLight" class="mockup-grid"></div>
                    </div>
                    <div class="comparison-side yt-mockup dark">
                        <span class="comparison-label">MODO OSCURO</span>
                        <div id="comparisonDark" class="mockup-grid"></div>
                    </div>
                </div>
            </main>
        </div>
    </div>
</div>

<script define:vars={{ defaultImage, defaultAvatar }}>
    const thumbInput = document.getElementById("thumbInput");
    const avatarInput = document.getElementById("avatarInput");
    const dropThumb = document.getElementById("dropThumb");
    const dropAvatar = document.getElementById("dropAvatar");
    const galleryPreview = document.getElementById("galleryPreview");
    const comparisonLight = document.getElementById("comparisonLight");
    const comparisonDark = document.getElementById("comparisonDark");
    const comparisonContainer = document.getElementById("comparisonContainer");
    const btnDesktop = document.getElementById("btnDesktop");
    const btnMobile = document.getElementById("btnMobile");
    const btnReset = document.getElementById("btnReset");
    const mockupTitle = document.getElementById("mockupTitle");
    const mockupChannel = document.getElementById("mockupChannel");

    let thumbnailsList = [defaultImage];
    let currentAvatar = defaultAvatar;
    const state = { view: "desktop" };

    function setupDropzone(el, input, handler) {
        if (!el || !input) return;
        el.addEventListener("click", () => input.click());
        el.addEventListener("dragover", (e) => {
            e.preventDefault();
            el.classList.add("hover");
        });
        el.addEventListener("dragleave", () => el.classList.remove("hover"));
        el.addEventListener("drop", (e) => {
            e.preventDefault();
            el.classList.remove("hover");
            const files = e.dataTransfer?.files;
            if (files) handler(files);
        });
        input.addEventListener("change", (e) => {
            const files = e.target.files;
            if (files) handler(files);
        });
    }

    setupDropzone(dropThumb, thumbInput, (files) => {
        for (const file of files) {
            if (file.type.startsWith("image/")) {
                thumbnailsList.push(URL.createObjectURL(file));
            }
        }
        renderFeed();
    });

    setupDropzone(dropAvatar, avatarInput, (files) => {
        const file = files[0];
        if (file && file.type.startsWith("image/")) {
            currentAvatar = URL.createObjectURL(file);
            renderFeed();
        }
    });

    function createVideoMock(thumb, i) {
        const title = mockupTitle?.value || "Título del vídeo";
        const channel = mockupChannel?.value || "GameBob";
        const views = [
            "1.2M de visualizaciones • hace 1 hora",
            "Hace 45 minutos",
            "250.000 visualizaciones • hace 1 día",
            "3.1M de visualizaciones • hace 1 semana",
        ][i % 4];

        return `
            <div class="yt-card">
                <div class="yt-thumbnail-wrapper">
                    <img src="${thumb}" alt="Thumbnail" />
                    <div class="yt-duration">10:45</div>
                </div>
                <div class="yt-info-row">
                    <div class="yt-avatar"><img src="${currentAvatar}" alt="Avatar" /></div>
                    <div class="yt-text-meta">
                        <h4 class="yt-title" title="${title}">${title}</h4>
                        <p class="yt-channel">${channel}</p>
                        <p class="yt-views">${views}</p>
                    </div>
                </div>
            </div>
        `;
    }

    function renderFeed() {
        if (galleryPreview) {
            galleryPreview.innerHTML = thumbnailsList
                .map(
                    (t, i) => `
                <div class="gallery-item">
                    <img src="${t}" alt="Miniatura" />
                    <button class="btn-remove-thumb" data-idx="${i}">&times;</button>
                </div>
            `
                )
                .join("");

            galleryPreview.querySelectorAll(".btn-remove-thumb").forEach((btn) => {
                btn.addEventListener("click", (e) => {
                    const idx = parseInt(e.target.dataset.idx);
                    thumbnailsList.splice(idx, 1);
                    renderFeed();
                });
            });
        }

        if (comparisonContainer) {
            comparisonContainer.className = `comparison-container mockup-${state.view}`;
        }

        const html = thumbnailsList.map((t, i) => createVideoMock(t, i)).join("");
        if (comparisonLight) comparisonLight.innerHTML = html;
        if (comparisonDark) comparisonDark.innerHTML = html;
    }

    btnDesktop?.addEventListener("click", () => {
        state.view = "desktop";
        btnDesktop.classList.add("active");
        btnMobile?.classList.remove("active");
        renderFeed();
    });

    btnMobile?.addEventListener("click", () => {
        state.view = "mobile";
        btnMobile.classList.add("active");
        btnDesktop?.classList.remove("active");
        renderFeed();
    });

    btnReset?.addEventListener("click", () => {
        thumbnailsList = [];
        renderFeed();
    });

    [mockupTitle, mockupChannel].forEach((inp) => inp?.addEventListener("input", renderFeed));

    renderFeed();
</script>
