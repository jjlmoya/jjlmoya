---
import { Icon } from "astro-icon/components";
import "./YoutubeThumbnailTester.css";
---

<div class="yt-tester-container">
    <div class="premium-card">
        <!-- Upload State -->
        <div id="uploadPanel" class="upload-section">
            <div id="dropZone" class="drop-zone" role="button" aria-label="Subir miniatura">
                <div class="drop-icon">
                    <Icon name="mdi:image-plus" />
                </div>
                <div class="drop-text">
                    <h3>Subir Miniatura</h3>
                    <p>Arrastra tu diseño (1280x720 recomendado)</p>
                </div>
                <input type="file" id="thumbInput" accept="image/*" class="hidden" />
            </div>
            <p
                style="font-size: 0.75rem; color: #94a3b8; font-weight: 700; text-transform: uppercase;"
            >
                El archivo se procesa en tu navegador. Privacidad 100%.
            </p>
        </div>

        <!-- Dashboard State (Initially Hidden) -->
        <div
            id="dashboardPanel"
            class="hidden"
            style="display: flex; flex-direction: column; gap: 2rem;"
        >
            <!-- Context Customization -->
            <div class="custom-settings">
                <div class="settings-group">
                    <label>Título del Vídeo</label>
                    <input
                        type="text"
                        id="mockupTitle"
                        value="Cómo hacer una miniatura profesional [Guía Definitiva]"
                        placeholder="Escribe el título..."
                    />
                </div>
                <div class="settings-group">
                    <label>Nombre del Canal</label>
                    <input
                        type="text"
                        id="mockupChannel"
                        value="TecnoCreativos"
                        placeholder="Nombre de tu canal..."
                    />
                </div>
            </div>

            <!-- Controls Row -->
            <div class="tester-controls">
                <button
                    id="btnDesktop"
                    class="control-btn active"
                    data-view="desktop"
                    title="Vista Ordenador"
                >
                    <Icon name="mdi:monitor" />
                    <span>Desktop</span>
                </button>
                <button id="btnMobile" class="control-btn" data-view="mobile" title="Vista Móvil">
                    <Icon name="mdi:cellphone" />
                    <span>Mobile</span>
                </button>
                <div
                    style="width: 1px; height: 18px; background: rgba(0,0,0,0.1); margin: 0 0.5rem;"
                >
                </div>
                <button
                    id="btnLight"
                    class="control-btn active"
                    data-theme="light"
                    title="Tema Claro"
                >
                    <Icon name="mdi:white-balance-sunny" />
                    <span>Lite</span>
                </button>
                <button id="btnDark" class="control-btn" data-theme="dark" title="Tema Oscuro">
                    <Icon name="mdi:moon-waning-crescent" />
                    <span>Dark</span>
                </button>
                <button id="btnSplit" class="control-btn" title="Comparar Modos">
                    <Icon name="mdi:compare" />
                    <span>Split</span>
                </button>
                <button
                    id="btnReset"
                    class="control-btn"
                    title="Subir otro diseño"
                    style="color: #ef4444;"
                >
                    <Icon name="mdi:refresh" />
                </button>
            </div>

            <!-- Preview Display Area -->
            <div id="previewLayout" class="preview-layout active">
                <!-- Single Mockup Mode -->
                <div id="singleView" class="yt-mockup light mockup-home">
                    <div class="mockup-grid" id="mockupGrid">
                        <!-- Content injected by JS -->
                    </div>
                </div>

                <!-- Comparison / Split Mode -->
                <div id="comparisonView" class="hidden">
                    <div class="comparison-container">
                        <div class="comparison-side yt-mockup light">
                            <span class="comparison-label">MODO CLARO</span>
                            <div
                                id="comparisonLight"
                                class="mockup-grid"
                                style="grid-template-columns: 1fr; padding-top: 1.5rem;"
                            >
                            </div>
                        </div>
                        <div class="comparison-side yt-mockup dark">
                            <span class="comparison-label">MODO OSCURO</span>
                            <div
                                id="comparisonDark"
                                class="mockup-grid"
                                style="grid-template-columns: 1fr; padding-top: 1.5rem;"
                            >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const thumbInput = document.getElementById("thumbInput") as HTMLInputElement | null;
    const dropZone = document.getElementById("dropZone") as HTMLElement | null;
    const uploadPanel = document.getElementById("uploadPanel") as HTMLElement | null;
    const dashboardPanel = document.getElementById("dashboardPanel") as HTMLElement | null;
    const previewLayout = document.getElementById("previewLayout") as HTMLElement | null;

    // Grids
    const mockupGrid = document.getElementById("mockupGrid") as HTMLElement | null;
    const singleView = document.getElementById("singleView") as HTMLElement | null;
    const comparisonView = document.getElementById("comparisonView") as HTMLElement | null;
    const comparisonLight = document.getElementById("comparisonLight") as HTMLElement | null;
    const comparisonDark = document.getElementById("comparisonDark") as HTMLElement | null;

    // Controls
    const btnDesktop = document.getElementById("btnDesktop") as HTMLButtonElement | null;
    const btnMobile = document.getElementById("btnMobile") as HTMLButtonElement | null;
    const btnLight = document.getElementById("btnLight") as HTMLButtonElement | null;
    const btnDark = document.getElementById("btnDark") as HTMLButtonElement | null;
    const btnSplit = document.getElementById("btnSplit") as HTMLButtonElement | null;
    const btnReset = document.getElementById("btnReset") as HTMLButtonElement | null;

    // Inputs
    const mockupTitle = document.getElementById("mockupTitle") as HTMLInputElement | null;
    const mockupChannel = document.getElementById("mockupChannel") as HTMLInputElement | null;

    let currentImageUrl = "";
    let state = {
        view: "desktop",
        theme: "light",
        isSplit: false,
    };

    if (dropZone && thumbInput) {
        dropZone.addEventListener("click", () => thumbInput.click());

        dropZone.addEventListener("dragover", (e) => {
            e.preventDefault();
            dropZone.classList.add("hover");
        });

        dropZone.addEventListener("dragleave", () => {
            dropZone.classList.remove("hover");
        });

        dropZone.addEventListener("drop", (e) => {
            e.preventDefault();
            dropZone.classList.remove("hover");
            const file = e.dataTransfer?.files[0];
            if (file) processFile(file);
        });

        thumbInput.addEventListener("change", (e) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            if (file) processFile(file);
        });
    }

    function processFile(file: File) {
        if (!file.type.startsWith("image/")) return;
        currentImageUrl = URL.createObjectURL(file);

        uploadPanel?.classList.add("hidden");
        dashboardPanel?.classList.remove("hidden");
        render();
    }

    function createCard(idx: number) {
        const title = mockupTitle?.value || "Título del vídeo";
        const channel = mockupChannel?.value || "Canal";
        const viewsArr = [
            "1.5M de visualizaciones",
            "45k visualizaciones",
            "9.2k visualizaciones",
            "Hace 1 hora",
        ];
        const views = viewsArr[idx % viewsArr.length];

        return `
            <div class="yt-card">
                <div class="yt-thumbnail-wrapper">
                    <img src="${currentImageUrl}" alt="Thumbnail Test" />
                    <div class="yt-duration">12:45</div>
                </div>
                <div class="yt-info-row">
                    <div class="yt-avatar"></div>
                    <div class="yt-text-meta">
                        <h4 class="yt-title" title="${title}">${title}</h4>
                        <p class="yt-channel">${channel}</p>
                        <p class="yt-views">${views}</p>
                    </div>
                </div>
            </div>
        `;
    }

    function render() {
        if (!currentImageUrl) return;

        // Reset views
        singleView?.classList.add("hidden");
        comparisonView?.classList.add("hidden");

        if (state.isSplit) {
            comparisonView?.classList.remove("hidden");
            if (comparisonLight) comparisonLight.innerHTML = createCard(0);
            if (comparisonDark) comparisonDark.innerHTML = createCard(1);
        } else {
            singleView?.classList.remove("hidden");
            singleView?.classList.remove("light", "dark", "mockup-home", "mockup-mobile");
            singleView?.classList.add(state.theme);
            singleView?.classList.add(state.view === "desktop" ? "mockup-home" : "mockup-mobile");

            if (mockupGrid) {
                const count = state.view === "desktop" ? 3 : 1;
                let html = "";
                for (let i = 0; i < count; i++) html += createCard(i);
                mockupGrid.innerHTML = html;
            }
        }
    }

    // Event Listeners
    btnDesktop?.addEventListener("click", () => {
        state.view = "desktop";
        btnDesktop.classList.add("active");
        btnMobile?.classList.remove("active");
        render();
    });

    btnMobile?.addEventListener("click", () => {
        state.view = "mobile";
        btnMobile.classList.add("active");
        btnDesktop?.classList.remove("active");
        render();
    });

    btnLight?.addEventListener("click", () => {
        state.theme = "light";
        state.isSplit = false;
        btnLight.classList.add("active");
        btnDark?.classList.remove("active");
        btnSplit?.classList.remove("active");
        render();
    });

    btnDark?.addEventListener("click", () => {
        state.theme = "dark";
        state.isSplit = false;
        btnDark.classList.add("active");
        btnLight?.classList.remove("active");
        btnSplit?.classList.remove("active");
        render();
    });

    btnSplit?.addEventListener("click", () => {
        state.isSplit = true;
        btnSplit.classList.add("active");
        btnLight?.classList.remove("active");
        btnDark?.classList.remove("active");
        render();
    });

    btnReset?.addEventListener("click", () => {
        currentImageUrl = "";
        uploadPanel?.classList.remove("hidden");
        dashboardPanel?.classList.add("hidden");
        if (thumbInput) thumbInput.value = "";
    });

    [mockupTitle, mockupChannel].forEach((inp) => {
        inp?.addEventListener("input", render);
    });
</script>
