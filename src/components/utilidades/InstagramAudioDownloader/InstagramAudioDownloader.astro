---
import "./InstagramAudioDownloader.css";
---

<section class="audio-downloader-dashboard animate-in">
    <div class="main-card">
        <div class="input-section">
            <div class="url-input-group">
                <div class="input-icon">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        width="24"
                        height="24"
                    >
                        d="M 10 20 C 4.47715 20 0 15.5228 0 10 C 0 4.47715 4.47715 0 10 0 C 15.5228
                        0 20 4.47715 20 10 C 20 12.3533 19.1869 14.5168 17.8209 16.2307 L 23.7335
                        22.1432 C 24.124 22.5338 24.1241 23.1669 23.7335 23.5574 C 23.3429 23.948
                        22.7098 23.948 22.3193 23.5574 L 16.4068 17.6449 C 14.693 19.0108 12.5295
                        19.824 10.1762 19.824 L 10 20 Z M 10 18 C 14.4183 18 18 14.4183 18 10 C 18
                        5.58172 14.4183 2 C 10 2 C 5.58172 2 2 5.58172 2 10 C 2 14.4183 5.58172 18
                        10 18 Z" ></svg
                    >
                </div>
            </div>
            <input
                type="url"
                id="audio-url-input"
                placeholder="Pega el enlace del Instagram Reel aquí..."
                autocomplete="off"
                spellcheck="false"
            />
            <button id="paste-btn" class="action-icon-btn" title="Pegar desde portapapeles">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    width="20"
                    height="20"
                >
                    <path
                        d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2ZM13 18H7V16H13V18ZM17 14H7V12H17V14ZM11 10H7V8H11V10ZM13 9V3.5L18.5 9H13Z"
                    ></path>
                </svg>
            </button>
        </div>
        <div class="format-selection">
            <span class="label">Calidad de audio:</span>
            <div class="pills">
                <button class="pill active" data-quality="max">Máxima</button>
                <button class="pill" data-quality="320">320kbps</button>
                <button class="pill" data-quality="128">128kbps</button>
            </div>
        </div>
        <button id="process-btn" class="process-btn">
            <span>Extraer Audio de Reel</span>
            <div class="spinner hidden"></div>
        </button>
    </div>

    <div id="status-panel" class="status-panel hidden">
        <div class="loader-content">
            <div class="audio-waves">
                <span></span><span></span><span></span><span></span><span></span>
            </div>
            <p id="status-text">Procesando Reel de Instagram...</p>
        </div>
    </div>

    <div id="result-panel" class="result-panel hidden">
        <div class="result-card">
            <div class="thumbnail-container">
                <img id="result-thumb" src="" alt="Miniatura" crossorigin="anonymous" />
                <div class="audio-badge">Instagram MP3</div>
            </div>
            <div class="info-container">
                <h3 id="result-title">Audio del Reel</h3>
                <p id="result-author">Instagram</p>
                <div class="actions">
                    <a id="download-link" href="#" class="download-btn" download>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            width="24"
                            height="24"
                        >
                            <path
                                d="M12 16L7 11L8.4 9.55L11 12.15V4H13V12.15L15.6 9.55L17 11L12 16ZM6 20C5.45 20 4.97917 19.8042 4.5875 19.4125C4.19583 19.0208 4 18.55 4 18V15H6V18H18V15H20V18C20 18.55 19.8042 19.0208 19.4125 19.4125C19.0208 19.8042 18.55 20 18 20H6Z"
                            ></path>
                        </svg>
                        Descargar MP3
                    </a>
                    <button id="reset-btn" class="secondary-btn">Nueva descarga</button>
                </div>
            </div>
        </div>
    </div>

    <div id="error-panel" class="error-panel hidden">
        <div class="error-card">
            <div class="error-icon-wrapper">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    width="48"
                    height="48"
                >
                    <path
                        d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM12 20C16.4183 20 20 16.4183 20 12C20 7.58172 16.4183 4 12 4C7.58172 4 4 7.58172 4 12C4 16.4183 7.58172 20 12 20ZM11 15H13V17H11V15ZM11 7H13V13H11V7Z"
                    ></path>
                </svg>
            </div>
            <div class="error-text">
                <h4>¡Ups! No hemos podido</h4>
                <p id="error-message">
                    Ha ocurrido un error al intentar extraer el audio de este Reel. Por favor,
                    verifica el enlace.
                </p>
            </div>
            <div class="error-actions">
                <button id="retry-btn-err" class="retry-btn">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        width="20"
                        height="20"
                    >
                        <path
                            d="M12 5V1L7 6L12 11V7C15.31 7 18 9.69 18 13C18 16.31 15.31 19 12 19C8.69 19 6 16.31 6 13H4C4 17.42 7.58 21 12 21C16.42 21 20 17.42 20 13C20 8.58 16.42 5 12 5Z"
                        ></path>
                    </svg>
                    Intentar de nuevo
                </button>
                <button id="reset-error-btn" class="minimal-btn">Volver al inicio</button>
            </div>
        </div>
    </div>
</section>

<script>
    (() => {
        const API_URL = "/api/proxy";

        const urlInput = document.getElementById("audio-url-input") as HTMLInputElement;
        const pasteBtn = document.getElementById("paste-btn") as HTMLButtonElement;
        const processBtn = document.getElementById("process-btn") as HTMLButtonElement;
        const statusPanel = document.getElementById("status-panel") as HTMLDivElement;
        const resultPanel = document.getElementById("result-panel") as HTMLDivElement;
        const errorPanel = document.getElementById("error-panel") as HTMLDivElement;
        const statusText = document.getElementById("status-text") as HTMLParagraphElement;
        const errorMessage = document.getElementById("error-message") as HTMLParagraphElement;

        const resultThumb = document.getElementById("result-thumb") as HTMLImageElement;
        const resultTitle = document.getElementById("result-title") as HTMLHeadingElement;
        const resultAuthor = document.getElementById("result-author") as HTMLParagraphElement;
        const downloadLink = document.getElementById("download-link") as HTMLAnchorElement;
        const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
        const retryBtn = document.getElementById("retry-btn-err") as HTMLButtonElement;
        const resetErrorBtn = document.getElementById("reset-error-btn") as HTMLButtonElement;

        if (
            !urlInput ||
            !pasteBtn ||
            !processBtn ||
            !statusPanel ||
            !resultPanel ||
            !errorPanel ||
            !statusText ||
            !errorMessage ||
            !resultThumb ||
            !resultTitle ||
            !resultAuthor ||
            !downloadLink ||
            !resetBtn ||
            !retryBtn ||
            !resetErrorBtn
        )
            return;

        const qualityPills = document.querySelectorAll(".pill");
        let currentQuality = "max";
        qualityPills.forEach((pill) => {
            pill.addEventListener("click", () => {
                qualityPills.forEach((p) => p.classList.remove("active"));
                pill.classList.add("active");
                currentQuality = (pill as HTMLElement).dataset.quality || "max";
            });
        });

        function showPanel(panel: HTMLElement) {
            [
                statusPanel,
                resultPanel,
                errorPanel,
                document.querySelector(".input-section") as HTMLElement,
            ].forEach((p) => {
                if (p) (p as HTMLElement).classList.add("hidden");
            });
            panel.classList.remove("hidden");
        }

        function resetInput() {
            if (urlInput) urlInput.value = "";
            const inputSection = document.querySelector(".input-section") as HTMLElement;
            if (inputSection) showPanel(inputSection);
        }

        async function processAudio() {
            const url = urlInput.value.trim();
            if (!url || !url.includes("instagram.com")) {
                showError("Por favor, introduce una URL de Instagram válida.");
                return;
            }

            showPanel(statusPanel);
            statusText.textContent = "Analizando Reel de Instagram...";

            try {
                const body = {
                    url: url,
                    downloadMode: "audio",
                    audioFormat: "mp3",
                    audioBitrate: currentQuality === "max" ? "320" : currentQuality,
                };

                const response = await fetch(API_URL, {
                    method: "POST",
                    headers: { Accept: "application/json", "Content-Type": "application/json" },
                    body: JSON.stringify(body),
                });
                const data = await response.json();
                if (data.status === "error") throw new Error(data.text || "Error en el servicio.");
                if (data.status === "redirect" || data.status === "stream")
                    showResult(data.url, url);
                else throw new Error("Respuesta inesperada.");
            } catch (error: any) {
                showError(error.message || "Error de conexión.");
            }
        }

        function showResult(downloadUrl: string, originalUrl: string) {
            resultTitle.textContent = "Audio de Instagram Reels";
            resultAuthor.textContent = "Instagram User";
            resultThumb.src =
                "https://images.unsplash.com/photo-1611262588024-d12430b98920?q=80&w=300&auto=format&fit=crop";

            downloadLink.href = downloadUrl;
            showPanel(resultPanel);
        }

        function showError(msg: string) {
            errorMessage.textContent = msg;
            showPanel(errorPanel);
        }

        processBtn.addEventListener("click", processAudio);
        resetBtn.addEventListener("click", resetInput);
        retryBtn.addEventListener("click", resetInput);
        resetErrorBtn.addEventListener("click", resetInput);
        pasteBtn.addEventListener("click", async () => {
            try {
                urlInput.value = await navigator.clipboard.readText();
            } catch (err) {}
        });
        urlInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") processAudio();
        });
    })();
</script>
