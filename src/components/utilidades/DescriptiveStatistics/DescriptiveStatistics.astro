---
import { Icon } from "astro-icon/components";
import "./DescriptiveStatistics.css";
---

<div class="descriptive-card" id="descriptiveApp">
    <aside class="descriptive-sidebar">
        <div class="sidebar-heading">
            <Icon name="mdi:cog" /> Configuración
        </div>

        <div class="input-group">
            <label for="dataInput">Pegar Datos (Números)</label>
            <textarea id="dataInput" placeholder="Ej: 10, 12, 15, 8, 20..."></textarea>
        </div>

        <div class="input-group">
            <label>Tipo de Cálculo</label>
            <div class="type-toggle" id="calcType">
                <button class="toggle-btn active" data-type="sample">Muestral (n-1)</button>
                <button class="toggle-btn" data-type="population">Poblacional (n)</button>
            </div>
        </div>

        <div style="margin-top: auto; padding: 1.25rem; background: rgba(99, 102, 241, 0.05); border-radius: 1rem; border: 1px dashed rgba(99, 102, 241, 0.1); display: flex; gap: 0.75rem;">
            <Icon name="mdi:information-outline" style="flex-shrink: 0; color: #6366f1;" size={20} />
            <p style="font-size: 0.75rem; color: #64748b; line-height: 1.5; margin: 0; font-weight: 500;">
                Introduce tus datos separados por comas, espacios o saltos de línea. Los caracteres no numéricos se filtrarán automáticamente.
            </p>
        </div>
    </aside>

    <main class="descriptive-main">
        <section class="results-top-grid">
            <div class="stat-block">
                <div class="block-title"><Icon name="mdi:target" /> Tendencia Central</div>
                <div class="stat-grid">
                    <div class="stat-item">
                        <span class="stat-label">Media</span>
                        <span id="res-mean" class="stat-value primary">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Mediana</span>
                        <span id="res-median" class="stat-value">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Moda</span>
                        <span id="res-mode" class="stat-value">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Suma Total</span>
                        <span id="res-sum" class="stat-value">0</span>
                    </div>
                </div>
            </div>

            <div class="stat-block">
                <div class="block-title"><Icon name="mdi:chart-scatter-plot" /> Dispersión</div>
                <div class="stat-grid">
                    <div class="stat-item">
                        <span class="stat-label">Desv. Típica</span>
                        <span id="res-std" class="stat-value primary">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Varianza</span>
                        <span id="res-var" class="stat-value">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Rango</span>
                        <span id="res-range" class="stat-value">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Coef. Var.</span>
                        <span id="res-cv" class="stat-value">0%</span>
                    </div>
                </div>
            </div>

            <div class="stat-block">
                <div class="block-title"><Icon name="mdi:view-column-outline" /> Posición</div>
                <div class="stat-grid">
                    <div class="stat-item">
                        <span class="stat-label">Mínimo</span>
                        <span id="res-min" class="stat-value">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Cuartil Q1</span>
                        <span id="res-q1" class="stat-value">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Cuartil Q3</span>
                        <span id="res-q3" class="stat-value">0</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Máximo</span>
                        <span id="res-max" class="stat-value">0</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="visual-section">
            <div class="block-title" style="margin-bottom: 2rem;"><Icon name="mdi:chart-bell-curve" /> Diagrama de Caja (Boxplot)</div>
            <canvas id="boxplotCanvas"></canvas>
            <div class="interpretation-box" id="interpretation">
                Escribe algunos números para ver el análisis descriptivo completo...
            </div>
            
            <div id="errorOverlay" class="error-overlay" style="display: none;">
                <span class="error-text">Introduce al menos 2 números válidos</span>
            </div>
        </section>

        <footer class="action-bar">
            <div style="font-size: 0.8rem; font-weight: 700; color: #94a3b8;" id="res-n">Muestra: n=0</div>
            <div class="round-btn-group">
                <button class="btn-icon-round" id="clearBtn" title="Limpiar todo">
                    <Icon name="mdi:trash-can-outline" />
                </button>
                <button class="btn-icon-round" id="downloadBtn" title="Descargar Gráfico">
                    <Icon name="mdi:download" />
                </button>
                <button class="btn-icon-round" id="copyBtn" title="Copiar Estadísticas">
                    <Icon name="mdi:content-copy" />
                </button>
            </div>
        </footer>
    </main>
</div>

<script>
    const dataInp = document.getElementById('dataInput') as HTMLTextAreaElement;
    const calcType = document.getElementById('calcType');
    const canvas = document.getElementById('boxplotCanvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d');
    const errorLayer = document.getElementById('errorOverlay');
    const LS_KEY = "jjlmoya_descriptive_stats";

    let currentMode = 'sample';

    const getQuartile = (arr: number[], q: number) => {
        const pos = (arr.length - 1) * q;
        const base = Math.floor(pos);
        const rest = pos - base;
        if (arr[base + 1] !== undefined) {
            return arr[base] + rest * (arr[base + 1] - arr[base]);
        } else {
            return arr[base];
        }
    };

    const fmt = (n: number) => Math.abs(n) >= 100 ? n.toFixed(1) : Math.abs(n) >= 10 ? n.toFixed(2) : n.toFixed(3);

    const drawBoxplot = (data: number[], q1: number, q2: number, q3: number, min: number, max: number) => {
        if (!ctx || !canvas) return;
        const dpr = window.devicePixelRatio || 1;
        const cw = canvas.offsetWidth;
        const ch = canvas.offsetHeight;
        canvas.width = Math.floor(cw * dpr);
        canvas.height = Math.floor(ch * dpr);
        ctx.scale(dpr, dpr);
        ctx.clearRect(0, 0, cw, ch);

        const isMobile = cw < 480;
        const fs = isMobile ? 10 : 12;
        const padL = cw * 0.07, padR = cw * 0.07;
        const padT = ch * 0.14, padB = ch * 0.34;
        const plotW = cw - padL - padR;
        const plotH = ch - padT - padB;
        const cy = padT + plotH / 2;
        const boxH = Math.min(plotH * 0.55, isMobile ? 44 : 72);
        const range = max - min || 1;
        const toX = (v: number) => padL + (v - min) / range * plotW;
        const mean = data.reduce((a, b) => a + b, 0) / data.length;

        const numTicks = isMobile ? 4 : 6;
        for (let i = 0; i <= numTicks; i++) {
            const tx = padL + (i / numTicks) * plotW;
            ctx.strokeStyle = 'rgba(226,232,240,0.7)';
            ctx.lineWidth = 1;
            ctx.beginPath(); ctx.moveTo(tx, padT); ctx.lineTo(tx, padT + plotH + 8); ctx.stroke();
            const tickVal = min + (i / numTicks) * range;
            ctx.fillStyle = '#94a3b8';
            ctx.font = `${fs - 2}px sans-serif`;
            ctx.textAlign = 'center';
            ctx.fillText(fmt(tickVal), tx, padT + plotH + 22);
        }

        ctx.strokeStyle = '#e2e8f0'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.moveTo(padL, padT + plotH + 8); ctx.lineTo(padL + plotW, padT + plotH + 8); ctx.stroke();

        ctx.strokeStyle = 'rgba(99,102,241,0.5)'; ctx.lineWidth = 1.5; ctx.setLineDash([4, 4]);
        ctx.beginPath(); ctx.moveTo(toX(min), cy); ctx.lineTo(toX(q1), cy); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(toX(q3), cy); ctx.lineTo(toX(max), cy); ctx.stroke();
        ctx.setLineDash([]);

        const capH = boxH * 0.35;
        [[min, '#6366f1'], [max, '#6366f1']].forEach(([v, color]) => {
            ctx.strokeStyle = color as string; ctx.lineWidth = 2.5;
            ctx.beginPath(); ctx.moveTo(toX(v as number), cy - capH); ctx.lineTo(toX(v as number), cy + capH); ctx.stroke();
        });

        const grad = ctx.createLinearGradient(0, cy - boxH / 2, 0, cy + boxH / 2);
        grad.addColorStop(0, 'rgba(99,102,241,0.22)');
        grad.addColorStop(1, 'rgba(139,92,246,0.10)');
        ctx.fillStyle = grad;
        ctx.strokeStyle = '#6366f1'; ctx.lineWidth = 2;
        const bx = toX(q1), bw = Math.max(toX(q3) - toX(q1), 2);
        const r = Math.min(6, bw / 4, boxH / 4);
        ctx.beginPath(); ctx.roundRect(bx, cy - boxH / 2, bw, boxH, r); ctx.fill(); ctx.stroke();

        ctx.strokeStyle = '#4338ca'; ctx.lineWidth = 3;
        ctx.beginPath(); ctx.moveTo(toX(q2), cy - boxH / 2); ctx.lineTo(toX(q2), cy + boxH / 2); ctx.stroke();

        ctx.fillStyle = '#ec4899';
        ctx.beginPath(); ctx.arc(toX(mean), cy, isMobile ? 4 : 5, 0, Math.PI * 2); ctx.fill();
        ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(toX(mean), cy, isMobile ? 4 : 5, 0, Math.PI * 2); ctx.stroke();

        ctx.font = `bold ${fs}px sans-serif`;
        const lbY = cy + boxH / 2 + (isMobile ? 14 : 18);
        const lbY2 = cy + boxH / 2 + (isMobile ? 26 : 34);

        const q1x = toX(q1), q2x = toX(q2), q3x = toX(q3), minx = toX(min), maxx = toX(max);
        const minDist = fs * 4.5;

        ctx.fillStyle = '#64748b'; ctx.textAlign = 'center';
        ctx.fillText(fmt(min), minx, Math.abs(minx - q1x) < minDist ? lbY2 : lbY);
        ctx.fillText(fmt(max), maxx, Math.abs(maxx - q3x) < minDist ? lbY2 : lbY);

        ctx.fillStyle = '#6366f1';
        ctx.fillText(`Q1 ${fmt(q1)}`, q1x, Math.abs(q1x - minx) < minDist ? lbY2 : lbY);
        ctx.fillText(`Q3 ${fmt(q3)}`, q3x, Math.abs(q3x - maxx) < minDist ? lbY2 : lbY);

        ctx.fillStyle = '#4338ca';
        const medAbove = cy - boxH / 2 - (isMobile ? 8 : 12);
        ctx.fillText(`Med ${fmt(q2)}`, q2x, medAbove);

        if (!isMobile) {
            ctx.font = `11px sans-serif`; ctx.textAlign = 'left';
            const legendY = padT * 0.55;
            ctx.fillStyle = '#ec4899'; ctx.beginPath(); ctx.arc(padL + 8, legendY, 4, 0, Math.PI * 2); ctx.fill();
            ctx.fillStyle = '#94a3b8'; ctx.fillText('Media', padL + 18, legendY + 4);
            ctx.fillStyle = '#4338ca'; ctx.fillRect(padL + 70, legendY - 2, 16, 3);
            ctx.fillStyle = '#94a3b8'; ctx.fillText('Mediana', padL + 92, legendY + 4);
        }
    };

    const update = () => {
        const rawText = dataInp.value;
        const data = rawText.split(/[\s,;\t\n]+/).map(v => parseFloat(v)).filter(v => !isNaN(v));

        if (data.length < 2) {
            errorLayer!.style.display = 'flex';
            return;
        }
        errorLayer!.style.display = 'none';

        const n = data.length;
        const sorted = [...data].sort((a,b) => a - b);
        const sum = data.reduce((a,b) => a + b, 0);
        const mean = sum / n;
        
        const q1 = getQuartile(sorted, 0.25);
        const q2 = getQuartile(sorted, 0.5);
        const q3 = getQuartile(sorted, 0.75);
        const min = sorted[0];
        const max = sorted[n - 1];
        const range = max - min;
        const iqr = q3 - q1;

        const sqDiffs = data.map(v => Math.pow(v - mean, 2)).reduce((a,b) => a + b, 0);
        const div = currentMode === 'sample' ? n - 1 : n;
        const variance = sqDiffs / div;
        const std = Math.sqrt(variance);
        const cv = (std / mean) * 100;

        const counts: Record<number, number> = {};
        let maxFreq = 0;
        data.forEach(v => {
            counts[v] = (counts[v] || 0) + 1;
            if (counts[v] > maxFreq) maxFreq = counts[v];
        });
        const modes = Object.keys(counts).filter(k => counts[Number(k)] === maxFreq);
        const modeStr = maxFreq > 1 ? modes.join(', ') : 'N/A';

        document.getElementById('res-mean')!.textContent = mean.toFixed(3);
        document.getElementById('res-median')!.textContent = q2.toFixed(3);
        document.getElementById('res-mode')!.textContent = modeStr;
        document.getElementById('res-sum')!.textContent = sum.toLocaleString();
        document.getElementById('res-std')!.textContent = std.toFixed(3);
        document.getElementById('res-var')!.textContent = variance.toFixed(3);
        document.getElementById('res-range')!.textContent = range.toFixed(3);
        document.getElementById('res-cv')!.textContent = isFinite(cv) ? cv.toFixed(2) + '%' : '0%';
        document.getElementById('res-min')!.textContent = min.toFixed(3);
        document.getElementById('res-max')!.textContent = max.toFixed(3);
        document.getElementById('res-q1')!.textContent = q1.toFixed(3);
        document.getElementById('res-q3')!.textContent = q3.toFixed(3);
        document.getElementById('res-n')!.textContent = `Muestra: n=${n}`;

        let interp = `La muestra tiene un promedio de ${mean.toFixed(2)}. `;
        if (cv > 30) interp += `Ojo: el coeficiente de variación es alto (${cv.toFixed(1)}%), los datos están dispersos. `;
        else interp += `Los datos son bastante homogéneos. `;
        interp += `El 50% central de los valores se encuentra entre ${q1.toFixed(2)} y ${q3.toFixed(2)} (IQR: ${iqr.toFixed(2)}).`;
        document.getElementById('interpretation')!.textContent = interp;

        drawBoxplot(sorted, q1, q2, q3, min, max);

        localStorage.setItem(LS_KEY, JSON.stringify({ data: rawText, mode: currentMode }));
    };

    dataInp.addEventListener('input', update);
    
    calcType?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.toggle-btn');
        if (!btn) return;
        calcType.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentMode = (btn as HTMLElement).dataset.type!;
        update();
    });

    document.getElementById('clearBtn')?.addEventListener('click', () => {
        dataInp.value = '';
        update();
    });

    document.getElementById('copyBtn')?.addEventListener('click', () => {
        const text = `Resultados Estadística Descriptiva (n=${document.getElementById('res-n')?.textContent}): 
Media: ${document.getElementById('res-mean')?.textContent}
Mediana: ${document.getElementById('res-median')?.textContent}
Desv: ${document.getElementById('res-std')?.textContent}
[${document.getElementById('res-min')?.textContent} - ${document.getElementById('res-max')?.textContent}]
Calculado en jjlmoya.es`;
        navigator.clipboard.writeText(text);
        const icon = document.getElementById('copyBtn')!.innerHTML;
        document.getElementById('copyBtn')!.innerHTML = 'Ok!';
        setTimeout(() => document.getElementById('copyBtn')!.innerHTML = icon, 1200);
    });

    document.getElementById('downloadBtn')?.addEventListener('click', () => {
        const link = document.createElement('a');
        link.download = 'boxplot-estadistica.webp';
        link.href = canvas.toDataURL('image/webp');
        link.click();
    });

    const saved = localStorage.getItem(LS_KEY);
    if (saved) {
        const { data, mode } = JSON.parse(saved);
        dataInp.value = data || '';
        currentMode = mode || 'sample';
        calcType?.querySelectorAll('.toggle-btn').forEach(b => {
             b.classList.toggle('active', (b as HTMLElement).dataset.type === currentMode);
        });
    } else {
        dataInp.value = "25, 30, 28, 35, 40, 22, 31, 29, 33, 30";
    }

    window.addEventListener('resize', update);
    update();
</script>
