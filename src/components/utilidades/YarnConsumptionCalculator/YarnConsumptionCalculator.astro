---
import "./YarnConsumptionCalculator.css";
---

<div class="yarn-calc-wrapper" id="yarn-calc">
    <div class="yarn-calc-card">
        <div class="calc-sidebar">
            <div class="input-block">
                <span class="section-label">1. TIPO DE PROYECTO</span>
                <div class="project-grid" id="project-selector">
                    <div class="project-item active" data-id="sweater">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/></svg>
                        <span>JERSEY</span>
                    </div>
                    <div class="project-item" data-id="scarf">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16M8 8a4 4 0 1 1 8 0M8 12a4 4 0 1 1 8 0M8 16a4 4 0 1 1 8 0"/></svg>
                        <span>BUFANDA</span>
                    </div>
                    <div class="project-item" data-id="hat">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 0-10 10c0 4.42 5.5 8 10 8s10-3.58 10-8A10 10 0 0 0 12 2zM12 4v4M12 12v4"/></svg>
                        <span>GORRO</span>
                    </div>
                    <div class="project-item" data-id="socks">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12V4a2 2 0 0 1 2-2h4l4 12h6v6a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-4l-2-6z"/></svg>
                        <span>CALCETINES</span>
                    </div>
                    <div class="project-item" data-id="blanket">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="4"/></svg>
                        <span>MANTA</span>
                    </div>
                    <div class="project-item" data-id="cardigan">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23zM12 8v12"/></svg>
                        <span>CHAQUETA</span>
                    </div>
                </div>
            </div>

            <div class="input-block">
                <span class="section-label">2. DIMENSIONES / TALLA</span>
                <div class="pill-selector" id="size-selector">
                    <button class="pill-btn active" data-val="s">S</button>
                    <button class="pill-btn" data-val="m">M</button>
                    <button class="pill-btn" data-val="l">L</button>
                    <button class="pill-btn" data-val="xl">XL</button>
                </div>
            </div>

            <div class="input-block">
                <span class="section-label">3. GROSOR DEL HILO</span>
                <div class="pill-selector" id="weight-selector">
                    <button class="pill-btn active" data-val="fingering">Fino</button>
                    <button class="pill-btn" data-val="dk">Medio</button>
                    <button class="pill-btn" data-val="worsted">Grueso</button>
                    <button class="pill-btn" data-val="bulky">XXL</button>
                </div>
            </div>

            <div class="input-block">
                <span class="section-label">4. CARACTERÍSTICAS DEL PATRÓN</span>
                <div class="switch-row" id="cable-switch">
                    <span style="font-size:13px; font-weight:800">¿Trenzas o texturas densas?</span>
                    <div class="switch-toggle"></div>
                </div>
            </div>

            <div class="input-block">
                <span class="section-label">5. DATOS DEL OVILLO</span>
                <div class="custom-input-box">
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px">
                        <div>
                            <label class="label-tiny" style="font-size:9px; font-weight:800; color:#64748b; margin-bottom:8px; display:block">GRAMOS / OVILLO</label>
                            <input type="number" id="ball-weight" class="custom-input" value="100" />
                        </div>
                        <div>
                            <label class="label-tiny" style="font-size:9px; font-weight:800; color:#64748b; margin-bottom:8px; display:block">METROS / OVILLO</label>
                            <input type="number" id="ball-meters" class="custom-input" value="200" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="calc-main">
            <div class="results-panel">
                <div class="main-stat">
                    <span class="stat-prefix">CONSUMO ESTIMADO TOTAL</span>
                    <div style="display:flex; align-items: baseline; justify-content:center">
                        <span class="stat-value" id="total-meters">1.250</span>
                        <span class="stat-suffix">M</span>
                    </div>
                    <p style="font-size:14px; font-weight:600; color:#64748b; margin-top:12px">Metraje final calculado con stock de reserva del 10%.</p>
                </div>

                <div class="balls-cta">
                    <div class="balls-icon">
                        <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M17,18C15.89,18 15,18.89 15,20A2,2 0 0,0 17,22A2,2 0 0,0 19,20C19,18.89 18.11,18 17,18M7,18C5.89,18 5,18.89 5,20A2,2 0 0,0 7,22A2,2 0 0,0 9,20C9,18.89 8.11,18 7,18M7,16L7.1,15.93L8.5,13.43L15.33,13.43C16.08,13.43 16.74,13.04 17.11,12.44L21.43,4.6L19.7,3.65L15.33,11.43L8.7,11.43L3.1,1.11L1,1.11V3.11H3L6.6,10.66L5.25,13.11C5.1,13.41 5,13.7 5,14C5,15.11 5.89,16 7,16H19V14H7.42C7.28,14 7.16,13.89 7.16,13.74V13.71L8.1,12H15.55C16.3,12 16.96,11.61 17.33,11.01L22.25,2.11L20.52,1.11L15.55,10H8.38L4.62,3H1V5H3.14L6.9,12L5.25,15.11C5.1,15.41 5,15.7 5,16C5,17.11 5.89,18 7,18H19V16H7.42C7.28,16 7.16,15.89 7.16,15.74Z"/></svg>
                    </div>
                    <span class="balls-count" id="total-balls">Compra 7 ovillos</span>
                    <span class="balls-desc" id="balls-detail">Ovillos de 100g / 200m cada uno.</span>
                </div>

                <div class="panic-alert">
                    <div class="alert-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 9v2m0 4h.01M5.93 21h12.14a2 2 0 0 0 1.73-3L13.73 4a2 2 0 0 0-3.46 0L4.2 18a2 2 0 0 0 1.73 3z"/></svg>
                    </div>
                    <div>
                        <strong>Seguridad estratégica:</strong> Este cálculo ya garantiza que no te quedarás sin hilo. Recuerda validar el número de lote (dye lot) al comprar tus ovillos para evitar saltos de color.
                    </div>
                </div>

                <div class="garment-scheme">
                    <div class="scheme-container" id="scheme-draw">
                        <svg width="320" height="240" viewBox="0 0 200 160" id="main-svg"></svg>
                        <div id="lbl-left" class="scheme-label" style="opacity: 0"></div>
                        <div id="lbl-right" class="scheme-label" style="opacity: 0"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const projects = {
        sweater: {
            s: [1100, 1000, 900, 800], m: [1250, 1150, 1050, 950], l: [1450, 1350, 1250, 1150], xl: [1700, 1600, 1500, 1400],
            labels: ['S', 'M', 'L', 'XL'], parts: { body: 0.7, sleeves: 0.3 }
        },
        cardigan: {
            s: [1200, 1100, 1000, 900], m: [1350, 1250, 1150, 1050], l: [1550, 1450, 1350, 1250], xl: [1850, 1750, 1650, 1550],
            labels: ['S', 'M', 'L', 'XL'], parts: { body: 0.65, sleeves: 0.35 }
        },
        hat: {
            s: [180, 160, 140, 120], m: [210, 190, 170, 150], l: [250, 230, 210, 190], xl: [300, 280, 260, 240],
            labels: ['Niño', 'S', 'M', 'L'], parts: { body: 1, sleeves: 0 }
        },
        scarf: {
            s: [350, 300, 250, 200], m: [500, 450, 400, 350], l: [700, 650, 600, 550], xl: [950, 900, 850, 800],
            labels: ['Mini', 'M', 'Grande', 'Maxi'], parts: { body: 1, sleeves: 0 }
        },
        socks: {
            s: [300, 250, 200, 150], m: [400, 350, 300, 250], l: [500, 450, 400, 350], xl: [650, 600, 550, 500],
            labels: ['Niño', 'Ad. S', 'Ad. M', 'Ad. L'], parts: { body: 1, sleeves: 0 }
        },
        blanket: {
            s: [800, 750, 700, 650], m: [3500, 3200, 3000, 2800], l: [5500, 5000, 4500, 4000], xl: [8000, 7500, 7000, 6500],
            labels: ['Bebé', 'Sofá', 'Cama 90', 'Cama 150'], parts: { body: 1, sleeves: 0 }
        }
    };

    const weights = { fingering: 0, dk: 1, worsted: 2, bulky: 3 };
    const state = { project: 'sweater', size: 'm', weight: 'fingering', cables: false, ballW: 100, ballM: 200 };

    function updateQuery() {
        const params = new URLSearchParams();
        params.set('p', state.project); params.set('s', state.size); params.set('w', state.weight);
        params.set('c', state.cables ? '1' : '0'); params.set('bw', state.ballW.toString()); params.set('bm', state.ballM.toString());
        window.history.replaceState({}, '', `${window.location.pathname}?${params.toString()}`);
    }

    function calculate() {
        const proj = (projects as any)[state.project];
        let baseM = proj[state.size][(weights as any)[state.weight]];
        if (state.cables) baseM *= 1.25;
        const totalWithSafety = Math.ceil(baseM * 1.10);
        const balls = Math.ceil(totalWithSafety / state.ballM);
        const totalMEl = document.getElementById('total-meters');
        const totalBEl = document.getElementById('total-balls');
        const detailEl = document.getElementById('balls-detail');
        if (totalMEl) totalMEl.innerText = totalWithSafety.toLocaleString();
        if (totalBEl) totalBEl.innerText = `Compra ${balls} ovillo${balls > 1 ? 's' : ''}`;
        if (detailEl) detailEl.innerText = `Ovillos de ${state.ballW}g / ${state.ballM}m cada uno.`;
        drawScheme(totalWithSafety, proj.parts);
        updateQuery();
    }

    function drawScheme(total: number, parts: any) {
        const svg = document.getElementById('main-svg');
        const lblLeft = document.getElementById('lbl-left');
        const lblRight = document.getElementById('lbl-right');
        if (!svg || !lblLeft || !lblRight) return;
        svg.innerHTML = '';
        lblLeft.style.opacity = '0'; lblRight.style.opacity = '0';

        const bM = Math.round(total * parts.body);
        const sMTotal = Math.round(total * parts.sleeves);

        if (state.project === 'sweater' || state.project === 'cardigan') {
            svg.innerHTML = `
                <line class="scheme-callout" x1="10" y1="35" x2="55" y2="75" />
                <circle class="scheme-dot" cx="55" cy="75" r="3" />
                <line class="scheme-callout" x1="190" y1="90" x2="130" y2="100" />
                <circle class="scheme-dot" cx="130" cy="100" r="3" />
                <rect class="scheme-item filled" x="60" y="40" width="80" height="100" />
                <path class="scheme-item filled" d="M60 40 L30 100 L50 110 L60 60 Z" />
                <path class="scheme-item filled" d="M140 40 L170 100 L150 110 L140 60 Z" />
            `;
            lblLeft.style.opacity = '1'; lblLeft.style.top = '10%'; lblLeft.style.left = '5%';
            lblLeft.innerHTML = `<span>Mangas</span> <strong>${sMTotal}m</strong> <em>${Math.round(sMTotal/2)}m c/u</em>`;
            lblRight.style.opacity = '1'; lblRight.style.top = '50%'; lblRight.style.right = '5%';
            lblRight.innerHTML = `<span>Cuerpo</span> <strong>${bM}m</strong>`;
        } else if (state.project === 'hat') {
            svg.innerHTML = `
                <line class="scheme-callout" x1="190" y1="60" x2="120" y2="70" />
                <circle class="scheme-dot" cx="120" cy="70" r="3" />
                <path class="scheme-item filled" d="M60 130 Q 60 40, 100 40 Q 140 40, 140 130 Z" />
            `;
            lblRight.style.opacity = '1'; lblRight.style.top = '25%'; lblRight.style.right = '10%';
            lblRight.innerHTML = `<span>Total Gorro</span> <strong>${total}m</strong>`;
        } else if (state.project === 'scarf' || state.project === 'blanket') {
            svg.innerHTML = `
                <line class="scheme-callout" x1="190" y1="60" x2="120" y2="80" />
                <circle class="scheme-dot" cx="120" cy="80" r="3" />
                <rect class="scheme-item filled" x="40" y="60" width="120" height="60" />
            `;
            lblRight.style.opacity = '1'; lblRight.style.top = '20%'; lblRight.style.right = '10%';
            lblRight.innerHTML = `<span>Total Pieza</span> <strong>${total}m</strong>`;
        } else if (state.project === 'socks') {
            svg.innerHTML = `
                <line class="scheme-callout" x1="190" y1="50" x2="100" y2="80" />
                <circle class="scheme-dot" cx="100" cy="80" r="3" />
                <path class="scheme-item filled" d="M80 40 L80 120 L120 120 L120 100 L100 100 L100 40 Z" />
            `;
            lblRight.style.opacity = '1'; lblRight.style.top = '15%'; lblRight.style.right = '10%';
            lblRight.innerHTML = `<span>Total Par</span> <strong>${total}m</strong>`;
        }
    }

    function init() {
        const params = new URLSearchParams(window.location.search);
        if (params.has('p')) state.project = params.get('p') || 'sweater';
        if (params.has('s')) state.size = params.get('s') || 'm';
        if (params.has('w')) state.weight = params.get('w') || 'fingering';
        if (params.has('c')) state.cables = params.get('c') === '1';
        if (params.has('bw')) state.ballW = parseInt(params.get('bw')!) || 100;
        if (params.has('bm')) state.ballM = parseInt(params.get('bm')!) || 200;

        const pItems = document.querySelectorAll('.project-item');
        pItems.forEach(i => { i.classList.toggle('active', (i as HTMLElement).dataset.id === state.project); });
        const sBtns = document.querySelectorAll('#size-selector .pill-btn');
        sBtns.forEach(btn => { btn.classList.toggle('active', (btn as HTMLElement).dataset.val === state.size); });
        const wBtns = document.querySelectorAll('#weight-selector .pill-btn');
        wBtns.forEach(btn => { btn.classList.toggle('active', (btn as HTMLElement).dataset.val === state.weight); });
        const cRow = document.getElementById('cable-switch');
        if (cRow) cRow.classList.toggle('active', state.cables);
        const bW = document.getElementById('ball-weight') as HTMLInputElement;
        const bM = document.getElementById('ball-meters') as HTMLInputElement;
        if (bW) bW.value = state.ballW.toString();
        if (bM) bM.value = state.ballM.toString();

        pItems.forEach(item => { item.addEventListener('click', () => {
            pItems.forEach(i => i.classList.remove('active')); item.classList.add('active');
            state.project = (item as HTMLElement).dataset.id!; updateSizeLabels(); calculate();
        }); });
        sBtns.forEach(btn => { btn.addEventListener('click', () => {
            sBtns.forEach(b => b.classList.remove('active')); btn.classList.add('active');
            state.size = (btn as HTMLElement).dataset.val!; calculate();
        }); });
        wBtns.forEach(btn => { btn.addEventListener('click', () => {
            wBtns.forEach(b => b.classList.remove('active')); btn.classList.add('active');
            state.weight = (btn as HTMLElement).dataset.val!; calculate();
        }); });
        if (cRow) { cRow.addEventListener('click', () => {
            cRow.classList.toggle('active'); state.cables = cRow.classList.contains('active'); calculate();
        }); }
        [bW, bM].forEach(el => { el?.addEventListener('input', (e) => {
            const val = parseInt((e.target as HTMLInputElement).value) || 1;
            if (el.id === 'ball-weight') state.ballW = val; else state.ballM = val;
            calculate();
        }); });
        updateSizeLabels(); calculate();
    }
    function updateSizeLabels() {
        const btns = document.querySelectorAll('#size-selector .pill-btn');
        const projData = (projects as any)[state.project];
        if (projData) { btns.forEach((btn, idx) => { (btn as HTMLElement).innerText = projData.labels[idx]; }); }
    }
    document.addEventListener('DOMContentLoaded', init);
</script>
