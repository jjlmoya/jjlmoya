---
---

<div class="stair-panel inputs">
    <h2 class="panel-title">Medidas Reales de Obra</h2>
    
    <div class="input-group">
        <label for="total-height">Desnivel Total (H) <small>(cm)</small></label>
        <div class="stepper">
            <button type="button" class="step-btn minus" data-input="total-height" aria-label="Restar">-</button>
            <input type="number" id="total-height" value="300" step="1" min="10">
            <button type="button" class="step-btn plus" data-input="total-height" aria-label="Sumar">+</button>
        </div>
    </div>

    <div class="input-group">
        <label for="total-length">Longitud Disponible (L) <small>(cm)</small></label>
        <div class="stepper">
            <button type="button" class="step-btn minus" data-input="total-length" aria-label="Restar">-</button>
            <input type="number" id="total-length" value="450" step="1" min="0">
            <button type="button" class="step-btn plus" data-input="total-length" aria-label="Sumar">+</button>
        </div>
        <p class="input-help">Opcional. Pon 0 para calcular según Blondel.</p>
    </div>

    <div class="input-group">
        <label for="num-steps">Número de Peldaños</label>
        <div class="stepper">
            <button type="button" class="step-btn minus" data-input="num-steps" aria-label="Restar">-</button>
            <input type="number" id="num-steps" value="17" step="1" min="1">
            <button type="button" class="step-btn plus" data-input="num-steps" aria-label="Sumar">+</button>
        </div>
    </div>

    <div class="input-group">
        <label for="finish-thickness">Grosor Recrecido <small>(cm)</small></label>
        <div class="stepper">
            <button type="button" class="step-btn minus" data-input="finish-thickness" aria-label="Restar">-</button>
            <input type="number" id="finish-thickness" value="0" step="0.5" min="0">
            <button type="button" class="step-btn plus" data-input="finish-thickness" aria-label="Sumar">+</button>
        </div>
    </div>
</div>

<div class="stair-panel materials">
    <h2 class="panel-title">Estimación Materiales</h2>
    <div class="input-group">
        <label for="stair-width">Ancho Escalera <small>(cm)</small></label>
        <div class="stepper">
            <button type="button" class="step-btn minus" data-input="stair-width" aria-label="Restar">-</button>
            <input type="number" id="stair-width" value="100" step="5" min="40">
            <button type="button" class="step-btn plus" data-input="stair-width" aria-label="Sumar">+</button>
        </div>
    </div>
    <div class="material-list">
        <div class="material-item">
            <span>Hormigón Total:</span>
            <strong id="mat-volume">0.00</strong> m³
        </div>
        <div class="material-item">
            <span>Sacos Cemento:</span>
            <strong id="mat-cement">0</strong>
        </div>
        <div class="material-item">
            <span>Arena:</span>
            <strong id="mat-sand">0</strong> L
        </div>
    </div>
</div>
