---
import './StairCalculator.css';
---

<div class="stair-calculator" id="stair-calculator">
    <div class="stair-card">
        <aside class="stair-sidebar">
            <div class="sidebar-section">
                <h3>Geometría y Hueco</h3>
                <div class="input-group">
                    <label for="total-height">Desnivel Total (H) <small>(cm)</small></label>
                    <div class="stepper">
                        <button type="button" class="step-btn minus" data-input="total-height">-</button>
                        <input type="number" id="total-height" value="300" step="1" min="10">
                        <button type="button" class="step-btn plus" data-input="total-height">+</button>
                    </div>
                </div>

                <div class="input-group">
                    <label for="total-length">Longitud Disponible (L) <small>(cm)</small></label>
                    <div class="stepper">
                        <input type="number" id="total-length" value="442" step="1" min="0">
                    </div>
                    <small style="opacity:0.6">Usa 0 para cálculo libre.</small>
                </div>

                <div class="input-group">
                    <label for="num-steps">Nº Peldaños</label>
                    <div class="stepper">
                        <button type="button" class="step-btn minus" data-input="num-steps">-</button>
                        <input type="number" id="num-steps" value="17" step="1" min="1">
                        <button type="button" class="step-btn plus" data-input="num-steps">+</button>
                    </div>
                    <button type="button" id="btn-optimize" class="optimize-btn">Optimizar (18cm)</button>
                </div>
            </div>

            <div class="sidebar-section">
                <h3>Obra e Instalación</h3>
                <div class="input-grid">
                    <div class="input-group">
                        <label for="slab-thickness">Losa (e) <small>(cm)</small></label>
                        <div class="stepper">
                            <input type="number" id="slab-thickness" value="15" step="1" min="8">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="finish-thickness">Acabado <small>(cm)</small></label>
                        <div class="stepper">
                            <input type="number" id="finish-thickness" value="3" step="0.5" min="0">
                        </div>
                    </div>
                </div>
                <div class="input-group">
                    <label for="ceiling-height">Altura Techo (Opción) <small>(cm)</small></label>
                    <div class="stepper">
                        <input type="number" id="ceiling-height" value="0" step="1" min="0">
                    </div>
                </div>
                <div class="input-group">
                    <label for="stair-width">Ancho Escalera <small>(cm)</small></label>
                    <input type="number" id="stair-width" value="100" class="stair-select">
                </div>
                <div class="input-group">
                    <label for="dosif">Resistencia Hormigón</label>
                    <select id="dosif" class="stair-select">
                        <option value="150">H-150 (Limpieza)</option>
                        <option value="200" selected>H-200 (Vivienda)</option>
                        <option value="250">H-250 (Estructural)</option>
                    </select>
                </div>
            </div>

            <div id="blondel-status" class="blondel-alert warning">
                <span class="blondel-title" id="blondel-title">Calculando...</span>
                <span class="blondel-msg" id="blondel-text">Ingresa medidas</span>
            </div>
        </aside>

        <main class="stair-main">
            <div class="stair-results-header">
                <div class="stat-box">
                    <span class="stat-label">Contrahuella</span>
                    <span class="stat-value" id="res-riser">--</span>
                    <span class="stat-unit">cm</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Huella</span>
                    <span class="stat-value" id="res-tread">--</span>
                    <span class="stat-unit">cm</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Pendiente</span>
                    <span class="stat-value" id="res-angle">--</span>
                    <span class="stat-unit">º</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Avance Real</span>
                    <span class="stat-value" id="res-len">--</span>
                    <span class="stat-unit">cm</span>
                </div>
            </div>

            <div class="visualizer-container">
                <svg id="stair-svg" viewBox="0 0 550 380" preserveAspectRatio="xMidYMid meet">
                    <defs>
                        <marker id="arrow" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
                        </marker>
                    </defs>
                    <path id="stair-slab" d="" fill="rgba(79, 70, 229, 0.08)" stroke="#4f46e5" stroke-width="1.5" stroke-dasharray="4,2" />
                    <path id="stair-path" d="" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round" />
                    <line id="ceiling-line" x1="0" y1="0" x2="0" y2="0" stroke="#f43f5e" stroke-width="2" stroke-dasharray="8,4" />
                    <path id="angle-arc" d="" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6" marker-end="url(#arrow)" />
                    <text id="angle-text" x="0" y="0" font-size="12" font-weight="700" fill="currentColor"></text>
                    <text id="warning-text" x="20" y="30" font-size="14" font-weight="800" fill="#f43f5e"></text>
                </svg>
            </div>

            <div class="stair-bottom-grid">
                <div class="table-card">
                    <h3>Replanteo y Ejecución</h3>
                    <div class="table-wrapper">
                        <table id="layout-table">
                            <thead>
                                <tr>
                                    <th>Peldaño</th>
                                    <th>H. Hormigón <small>(cm)</small></th>
                                    <th>H. Terminada <small>(cm)</small></th>
                                    <th>Avance <small>(cm)</small></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div class="materials-card">
                    <h3>Cubicación y Pedido</h3>
                    <div class="material-row">
                        <span>Hormigón Total:</span>
                        <div><strong id="mat-volume">0.00</strong> <span>m³</span></div>
                    </div>
                    <div class="material-row">
                        <span>Cemento (sacos/25kg):</span>
                        <strong id="mat-cement">0</strong>
                    </div>
                    <div class="material-row">
                        <span>Arena necesaria:</span>
                        <strong id="mat-sand">0</strong> L
                    </div>
                    <div class="actions-row">
                        <button id="btn-share" class="action-btn btn-secondary">Compartir</button>
                        <button id="btn-print" class="action-btn btn-primary">Imprimir PDF</button>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
    const inputs = {
        h: document.getElementById('total-height') as HTMLInputElement,
        l: document.getElementById('total-length') as HTMLInputElement,
        n: document.getElementById('num-steps') as HTMLInputElement,
        slab: document.getElementById('slab-thickness') as HTMLInputElement,
        finish: document.getElementById('finish-thickness') as HTMLInputElement,
        ceiling: document.getElementById('ceiling-height') as HTMLInputElement,
        width: document.getElementById('stair-width') as HTMLInputElement,
        dosif: document.getElementById('dosif') as HTMLSelectElement
    };

    const results = {
        riser: document.getElementById('res-riser') as HTMLElement,
        tread: document.getElementById('res-tread') as HTMLElement,
        angle: document.getElementById('res-angle') as HTMLElement,
        len: document.getElementById('res-len') as HTMLElement,
        blondelTitle: document.getElementById('blondel-title') as HTMLElement,
        blondelText: document.getElementById('blondel-text') as HTMLElement,
        blondelBox: document.getElementById('blondel-status') as HTMLElement,
        tableBody: document.querySelector('#layout-table tbody') as HTMLElement,
        svgPath: document.getElementById('stair-path') as unknown as SVGPathElement,
        slabPath: document.getElementById('stair-slab') as unknown as SVGPathElement,
        ceilingLine: document.getElementById('ceiling-line') as unknown as SVGLineElement,
        angleArc: document.getElementById('angle-arc') as unknown as SVGPathElement,
        angleText: document.getElementById('angle-text') as unknown as SVGTextElement,
        warningText: document.getElementById('warning-text') as unknown as SVGTextElement,
        matVol: document.getElementById('mat-volume') as HTMLElement,
        matCement: document.getElementById('mat-cement') as HTMLElement,
        matSand: document.getElementById('mat-sand') as HTMLElement
    };

    function updateCalculations() {
        const H = parseFloat(inputs.h.value) || 0;
        const L_avail = parseFloat(inputs.l.value) || 0;
        const N = parseInt(inputs.n.value) || 1;
        const slab_e = parseFloat(inputs.slab.value) || 15;
        const finish_e = parseFloat(inputs.finish.value) || 0;
        const ceiling_h = parseFloat(inputs.ceiling.value) || 0;
        const W = parseFloat(inputs.width.value) || 100;
        const cement_fac = parseInt(inputs.dosif.value) || 300;

        if (H <= 0 || N <= 0) return;

        const CH = H / N;
        const H_target = 63 - (2 * CH);
        const H_real = L_avail > 0 ? (L_avail / (N - 1)) : Math.max(24, H_target);
        
        const blondel = (2 * CH) + H_real;
        results.riser.textContent = CH.toFixed(1);
        results.tread.textContent = H_real.toFixed(1);

        let space_warn = "";
        if (L_avail > 0 && H_real < 24) {
            space_warn = "ESPACIO INSUFICIENTE";
            results.blondelBox.className = 'blondel-alert error';
            results.blondelTitle.textContent = "Error de Huella";
            results.blondelText.textContent = `La huella de ${H_real.toFixed(1)}cm es peligrosa.`;
        } else if (blondel >= 62 && blondel <= 64.5) {
            results.blondelBox.className = 'blondel-alert success';
            results.blondelTitle.textContent = "Confort Óptimo";
            results.blondelText.textContent = `Paso cómodo: ${blondel.toFixed(1)}cm.`;
        } else {
            const level = (CH > 19 || H_real < 25) ? 'error' : 'warning';
            results.blondelBox.className = `blondel-alert ${level}`;
            results.blondelTitle.textContent = (level === 'error') ? "Diseño Crítico" : "Margen Límite";
            results.blondelText.textContent = `Blondel: ${blondel.toFixed(1)}cm.`;
        }

        const realL = H_real * (N - 1);
        const angleRad = Math.atan(H / (realL || 1));
        const angleDeg = angleRad * (180 / Math.PI);
        const hypo = Math.sqrt(H**2 + realL**2);

        results.angle.textContent = isFinite(angleDeg) ? angleDeg.toFixed(0) : "90";
        results.len.textContent = realL.toFixed(0);

        let tableHTML = '';
        for (let i = 1; i <= N; i++) {
            const h_term = i * CH;
            let h_conc = h_term;
            if (i === 1) h_conc = CH - finish_e;
            
            const l_acu = (i - 1) * H_real;
            const extra = i === 1 ? ' <small>(Ajustado)</small>' : '';
            tableHTML += `<tr><td>${i}</td><td class="col-hl">${h_conc.toFixed(1)}${extra}</td><td>${h_term.toFixed(1)}</td><td>${l_acu.toFixed(1)}</td></tr>`;
        }
        results.tableBody.innerHTML = tableHTML;

        const svgW = 500, svgH = 320, margin = 50;
        const scale = Math.min((svgH - margin * 2) / H, (svgW - margin * 2) / (realL || 1));
        const x0 = margin, y0 = svgH - margin;

        let d_stair = `M ${x0} ${y0}`;
        for (let i = 0; i < N; i++) {
            d_stair += ` v -${CH * scale} h ${H_real * scale}`;
        }
        results.svgPath.setAttribute('d', d_stair);

        const slab_y_off = slab_e * scale / Math.cos(angleRad);
        const d_slab = d_stair + ` L ${x0 + (realL * scale) + (H_real * scale)} ${y0 - (H * scale) + slab_y_off} L ${x0} ${y0 + slab_y_off} Z`;
        results.slabPath.setAttribute('d', d_slab);

        if (ceiling_h > 0) {
            const cy = y0 - (ceiling_h * scale);
            results.ceilingLine.setAttribute('x1', String(x0));
            results.ceilingLine.setAttribute('y1', String(cy));
            results.ceilingLine.setAttribute('x2', String(x0 + realL * scale));
            results.ceilingLine.setAttribute('y2', String(cy));
            
            const min_head = ceiling_h - H;
            if (min_head < 200) space_warn = "CABECEO BAJO (<2m)";
        } else {
            results.ceilingLine.setAttribute('x1', "0");
        }
        results.warningText.textContent = space_warn;

        const arcR = 40;
        results.angleArc.setAttribute('d', `M ${x0 + arcR} ${y0} A ${arcR} ${arcR} 0 0 0 ${x0 + arcR * Math.cos(angleRad)} ${y0 - arcR * Math.sin(angleRad)}`);
        results.angleText.setAttribute('x', String(x0 + arcR + 5));
        results.angleText.setAttribute('y', String(y0 - 5));
        results.angleText.textContent = `${angleDeg.toFixed(0)}\u00ba`;

        const volSteps = (H_real * CH / 2) * W * N / 1000000;
        const volSlab = (hypo * slab_e * W) / 1000000;
        const totalVol = volSteps + volSlab;

        results.matVol.textContent = totalVol.toFixed(2);
        results.matCement.textContent = Math.ceil(totalVol * cement_fac / 25).toString();
        results.matSand.textContent = Math.round(totalVol * 0.5 * 1000).toString();
    }

    document.querySelectorAll('.step-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const inputId = btn.getAttribute('data-input');
            if (!inputId) return;
            const input = document.getElementById(inputId) as HTMLInputElement;
            const step = parseFloat(input.getAttribute('step') || '1');
            const val = parseFloat(input.value);
            input.value = (btn.classList.contains('plus') ? (val + step) : Math.max(parseFloat(input.getAttribute('min') || '0'), val - step)).toString();
            updateCalculations();
        });
    });

    document.getElementById('btn-optimize')?.addEventListener('click', () => {
        const H_val = parseFloat(inputs.h.value) || 0;
        if (H_val > 0) {
            inputs.n.value = Math.round(H_val / 18).toString();
            updateCalculations();
        }
    });

    Object.values(inputs).forEach(input => input?.addEventListener('input', updateCalculations));
    
    document.getElementById('btn-print')?.addEventListener('click', async () => {
        const card = document.querySelector('.stair-card') as HTMLElement;
        if (!card) return;

        const { default: html2canvas } = await import('html2canvas');
        const { jsPDF } = await import('jspdf');

        const canvas = await html2canvas(card, {
            scale: 2,
            useCORS: true,
            logging: false,
            backgroundColor: '#ffffff',
            scrollX: 0,
            scrollY: -window.scrollY,
            onclone: (doc) => {
                const clonedCard = doc.querySelector('.stair-card') as HTMLElement;
                if (clonedCard) {
                    clonedCard.style.boxShadow = 'none';
                    clonedCard.style.border = 'none';
                    clonedCard.style.borderRadius = '0';
                    clonedCard.style.margin = '0';
                    clonedCard.style.padding = '15px';
                    
                    const actions = clonedCard.querySelector('.actions-row');
                    if (actions) (actions as HTMLElement).style.display = 'none';
                    
                    const optBtn = clonedCard.querySelector('.optimize-btn');
                    if (optBtn) (optBtn as HTMLElement).style.display = 'none';

                    doc.querySelectorAll('.step-btn').forEach(btn => (btn as HTMLElement).style.display = 'none');
                    doc.querySelectorAll('.stepper, .stair-select').forEach(el => {
                        const container = el as HTMLElement;
                        container.style.border = 'none';
                        container.style.background = 'transparent';
                        container.style.padding = '0';
                        container.style.minHeight = 'auto';
                    });
                    
                    doc.querySelectorAll('input, select').forEach(el => {
                        const input = el as HTMLInputElement | HTMLSelectElement;
                        const span = doc.createElement('span');
                        span.textContent = input.value + (input.id === 'total-height' || input.id === 'total-length' || input.id === 'slab-thickness' || input.id === 'finish-thickness' || input.id === 'stair-width' || input.id === 'ceiling-height' ? ' cm' : '');
                        span.style.fontWeight = '700';
                        span.style.fontSize = '0.95rem';
                        span.style.color = '#1e293b';
                        if (input.tagName === 'SELECT') {
                            const select = input as HTMLSelectElement;
                            span.textContent = select.options[select.selectedIndex].text;
                        }
                        input.parentNode?.replaceChild(span, input);
                    });
                }
            }
        });

        const pdf = new jsPDF({
            orientation: 'landscape',
            unit: 'mm',
            format: 'a4'
        });

        const pageWidth = pdf.internal.pageSize.getWidth();
        const pageHeight = pdf.internal.pageSize.getHeight();
        const margin = 10;
        const maxWidth = pageWidth - (margin * 2);
        const maxHeight = pageHeight - (margin * 2);

        const imgData = canvas.toDataURL('image/jpeg', 0.95);
        const imgProps = pdf.getImageProperties(imgData);
        
        let finalWidth = maxWidth;
        let finalHeight = (imgProps.height * finalWidth) / imgProps.width;

        if (finalHeight > maxHeight) {
            finalHeight = maxHeight;
            finalWidth = (imgProps.width * finalHeight) / imgProps.height;
        }

        const x = (pageWidth - finalWidth) / 2;
        const y = (pageHeight - finalHeight) / 2;

        pdf.addImage(imgData, 'JPEG', x, y, finalWidth, finalHeight);
        pdf.save(`calculo-escalera-jjlmoya-${new Date().toISOString().split('T')[0]}.pdf`);
    });
    
    document.getElementById('btn-share')?.addEventListener('click', () => {
        const text = `Escalera: H=${inputs.h.value}cm, N=${inputs.n.value}, CH=${results.riser.textContent}cm, Vol=${results.matVol.textContent}m3`;
        if (navigator.share) navigator.share({ title: 'Resumen Obra', text }).catch(() => {});
        else alert(text);
    });

    updateCalculations();
</script>
