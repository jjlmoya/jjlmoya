---

<div class="stair-panel results">
    <h2 class="panel-title">Geometría Resultante</h2>
    <div class="result-cards">
        <div class="result-card" id="card-riser">
            <span class="card-label">Contrahuella (CH)</span>
            <span class="card-value" id="res-riser">--</span>
            <span class="card-unit">cm</span>
        </div>
        <div class="result-card" id="card-tread">
            <span class="card-label">Huella (H)</span>
            <span class="card-value" id="res-tread">--</span>
            <span class="card-unit">cm</span>
        </div>
        <div class="result-card" id="card-angle">
            <span class="card-label">Ángulo Inclinación</span>
            <span class="card-value" id="res-angle">--</span>
            <span class="card-unit">º</span>
        </div>
        <div class="result-card" id="card-hypotenuse">
            <span class="card-label">Hipotenusa (L. Viga)</span>
            <span class="card-value" id="res-hypo">--</span>
            <span class="card-unit">cm</span>
        </div>
    </div>

    <div id="blondel-status" class="status-box warning">
        <span id="blondel-text">Ingresa datos...</span>
    </div>
</div>
