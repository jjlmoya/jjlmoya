---
import "./YoutubeThumbnailExtractor.css";
---

<section class="yt-extractor-dashboard animate-in">
    <div class="input-panel">
        <div class="url-input-container">
            <svg
                class="search-icon"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
            >
                <path
                    d="M10 20C4.47715 20 0 15.5228 0 10C0 4.47715 4.47715 0 10 0C15.5228 0 20 4.47715 20 10C20 12.3533 19.1869 14.5168 17.8209 16.2307L23.7335 22.1432C24.124 22.5338 24.1241 23.1669 23.7335 23.5574C23.3429 23.948 22.7098 23.948 22.3193 23.5574L16.4068 17.6449C14.693 19.0108 12.5295 19.824 10.1762 19.824L10 20ZM10 18C14.4183 18 18 14.4183 18 10C18 5.58172 14.4183 2 10 2C5.58172 2 2 5.58172 2 10C2 14.4183 5.58172 18 10 18Z"
                ></path>
            </svg>
            <input
                type="url"
                id="yt-url-input"
                placeholder="Pega el enlace de YouTube aquí..."
                autocomplete="off"
                spellcheck="false"
            />
            <button
                id="yt-paste-btn"
                type="button"
                class="paste-btn"
                aria-label="Pegar desde portapapeles"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    width="20"
                    height="20"
                >
                    <path
                        d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2ZM13 18H7V16H13V18ZM17 14H7V12H17V14ZM11 10H7V8H11V10ZM13 9V3.5L18.5 9H13Z"
                    ></path>
                </svg>
            </button>
        </div>
        <p class="helper-text">Formatos soportados: youtube.com, youtu.be, shorts.</p>
    </div>

    <div id="yt-results" class="results-panel hidden">
        <div class="main-thumbnail-card">
            <div class="hq-ribbon">Máxima Calidad</div>
            <img id="yt-main-img" src="" alt="Miniatura HD de YouTube" crossorigin="anonymous" />
            <div class="card-actions">
                <button id="yt-download-btn" class="download-primary-btn">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        width="24"
                        height="24"
                        fill="currentColor"
                    >
                        <path
                            d="M12 16L7 11L8.4 9.55L11 12.15V4H13V12.15L15.6 9.55L17 11L12 16ZM6 20C5.45 20 4.97917 19.8042 4.5875 19.4125C4.19583 19.0208 4 18.55 4 18V15H6V18H18V15H20V18C20 18.55 19.8042 19.0208 19.4125 19.4125C19.0208 19.8042 18.55 20 18 20H6Z"
                        ></path>
                    </svg>
                    Descargar en Máxima Resolución
                </button>
            </div>
        </div>

        <div class="resolutions-grid">
            <div class="res-card">
                <p class="res-label">Calidad Media</p>
                <img id="yt-mq-img" src="" alt="Medium Quality" />
                <a id="yt-mq-link" href="#" target="_blank" rel="noopener noreferrer">Ver Imagen</a>
            </div>
            <div class="res-card">
                <p class="res-label">Calidad Estándar</p>
                <img id="yt-sd-img" src="" alt="Standard Quality" />
                <a id="yt-sd-link" href="#" target="_blank" rel="noopener noreferrer">Ver Imagen</a>
            </div>
            <div class="res-card">
                <p class="res-label">Baja Calidad</p>
                <img id="yt-hq-img" src="" alt="High Quality" />
                <a id="yt-hq-link" href="#" target="_blank" rel="noopener noreferrer">Ver Imagen</a>
            </div>
        </div>
    </div>

    <div id="yt-error" class="error-panel hidden">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            width="32"
            height="32"
        >
            <path
                d="M12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2ZM13 17H11V15H13V17ZM13 13H11V7H13V13Z"
            ></path>
        </svg>
        <span id="yt-error-msg">Parece que el enlace no es válido. ¿Seguro que es de YouTube?</span>
    </div>
</section>

<script>
    const urlInput = document.getElementById("yt-url-input") as HTMLInputElement;
    const pasteBtn = document.getElementById("yt-paste-btn") as HTMLButtonElement;
    const resultsPanel = document.getElementById("yt-results") as HTMLDivElement;
    const errorPanel = document.getElementById("yt-error") as HTMLDivElement;
    const errorMsg = document.getElementById("yt-error-msg") as HTMLSpanElement;

    const mainImg = document.getElementById("yt-main-img") as HTMLImageElement;
    const downloadBtn = document.getElementById("yt-download-btn") as HTMLButtonElement;

    const mqImg = document.getElementById("yt-mq-img") as HTMLImageElement;
    const sdImg = document.getElementById("yt-sd-img") as HTMLImageElement;
    const hqImg = document.getElementById("yt-hq-img") as HTMLImageElement;
    const mqLink = document.getElementById("yt-mq-link") as HTMLAnchorElement;
    const sdLink = document.getElementById("yt-sd-link") as HTMLAnchorElement;
    const hqLink = document.getElementById("yt-hq-link") as HTMLAnchorElement;

    let currentVideoId = "";

    function extractVideoId(url: string) {
        const regex =
            /(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/|youtube\.com\/shorts\/)([^"&?\/\s]{11})/i;
        const match = url.match(regex);
        return match ? match[1] : null;
    }

    function updateThumbnails(videoId: string) {
        if (!videoId) return;
        currentVideoId = videoId;

        resultsPanel.classList.remove("hidden");
        errorPanel.classList.add("hidden");

        const maxresUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
        const hqUrl = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
        const mqUrl = `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;
        const sdUrl = `https://img.youtube.com/vi/${videoId}/sddefault.jpg`;

        mainImg.src = maxresUrl;

        mainImg.onload = () => {
            if (mainImg.naturalWidth < 200) {
                mainImg.src = hqUrl;
            }
        };

        mqImg.src = mqUrl;
        sdImg.src = sdUrl;
        hqImg.src = hqUrl;

        mqLink.href = mqUrl;
        sdLink.href = sdUrl;
        hqLink.href = hqUrl;
    }

    urlInput.addEventListener("input", (e) => {
        const url = (e.target as HTMLInputElement).value.trim();
        if (!url) {
            resultsPanel.classList.add("hidden");
            errorPanel.classList.add("hidden");
            return;
        }

        const videoId = extractVideoId(url);
        if (videoId) {
            updateThumbnails(videoId);
        } else {
            resultsPanel.classList.add("hidden");
            errorPanel.classList.remove("hidden");
            errorMsg.textContent = "URL de YouTube no válida. Por favor, compruébala.";
        }
    });

    pasteBtn.addEventListener("click", async () => {
        try {
            const text = await navigator.clipboard.readText();
            urlInput.value = text;
            urlInput.dispatchEvent(new Event("input"));
        } catch (err) {
            console.error("Failed to read clipboard", err);
        }
    });

    downloadBtn.addEventListener("click", async () => {
        if (!mainImg.src || !currentVideoId) return;

        try {
            const response = await fetch(mainImg.src);
            const blob = await response.blob();
            const blobUrl = URL.createObjectURL(blob);

            const a = document.createElement("a");
            a.href = blobUrl;
            const ext = "webp";
            a.download = `youtube-thumbnail-${currentVideoId}.${ext}`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);

            URL.revokeObjectURL(blobUrl);
        } catch (error) {
            window.open(mainImg.src, "_blank");
        }
    });
</script>
