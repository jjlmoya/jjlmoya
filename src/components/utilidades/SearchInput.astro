---
import { Icon } from "astro-icon/components";
import type { SectionData } from "../../data/utilities";
import "./SearchInput.css";

interface Props {
    sections: SectionData[];
}

const { sections } = Astro.props;

interface FlatUtility {
    title: string;
    description: string;
    href: string;
    icon: string;
    category: string;
}

const flatUtilities: FlatUtility[] = sections.flatMap((section) =>
    section.utilities.map((u) => ({
        title: u.title,
        description: u.description,
        href: u.href,
        icon: u.iconFg || "mdi:tools",
        category: section.title,
    }))
);
---

<div class="search-container" id="search-container">
    <div class="search-field-wrapper">
        <input
            type="text"
            id="utility-search"
            placeholder="Buscar..."
            class="search-input"
            autocomplete="off"
        />
        <div class="search-icon">
            <Icon name="mdi:magnify" />
        </div>
        <div class="shortcut-hint">/</div>
    </div>

    <div id="search-results" class="search-results">
        <div id="results-list"></div>
        <div id="no-results-view" class="request-tool-card" style="display: none;">
            <p class="request-tool-text">Aún no he tenido tiempo para hacer esta herramienta</p>
            <button id="request-tool-btn" class="request-tool-button">
                <span class="btn-text">¿Te gustaría que la hiciera?</span>
                <span class="btn-loading"><div class="spinner"></div></span>
                <span class="btn-success"><Icon name="mdi:thumb-up" /></span>
            </button>
            <div id="request-status" class="request-status">
                <span class="status-success">¡Oído cocina! Me pongo con ello.</span>
            </div>
        </div>
    </div>
</div>

<script is:inline define:vars={{ flatUtilities }}>

    function normalize(text) {
        return text
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .toLowerCase();
    }

    function initSearch() {
        const input = document.getElementById("utility-search");
        const results = document.getElementById("search-results");
        const noResults = document.getElementById("no-results-view");
        const requestBtn = document.getElementById("request-tool-btn");
        const status = document.getElementById("request-status");

        if (!input) return;

        if (results) {
            results.style.pointerEvents = "none";
            results.style.position = "absolute";
            results.style.opacity = "0";
            results.style.visibility = "hidden";
        }

        input.addEventListener("input", (e) => {
            const query = normalize(e.target.value.trim());
            const sections = document.querySelectorAll("[data-utility-section]");
            let hasAnyMatches = false;

            sections.forEach((section) => {
                const details = section.querySelector("details");
                const cards = section.querySelectorAll("[data-utility-card]");
                const sectionTitle = normalize(section.getAttribute("data-section-title") || "");
                const isCategoryMatch = query && sectionTitle.includes(query);
                let sectionMatchCount = 0;

                cards.forEach((card) => {
                    const title = normalize(card.getAttribute("data-title") || "");
                    const description = normalize(card.getAttribute("data-description") || "");
                    
                    if (!query || isCategoryMatch || title.includes(query) || description.includes(query)) {
                        card.style.display = "";
                        sectionMatchCount++;
                        hasAnyMatches = true;
                    } else {
                        card.style.display = "none";
                    }
                });

                const countBadge = section.querySelector(".utility-section-count");
                if (countBadge) {
                    if (query && !isCategoryMatch) {
                        countBadge.textContent = `(${sectionMatchCount} de ${cards.length})`;
                    } else {
                        countBadge.textContent = `(${cards.length})`;
                    }
                }

                if (query) {
                    if (sectionMatchCount > 0) {
                        section.style.display = "";
                        if (details) details.open = true;
                    } else {
                        section.style.display = "none";
                    }
                } else {
                    section.style.display = "";
                    if (details) details.open = false;
                }
            });

            if (noResults) {
                if (query && !hasAnyMatches) {
                    if (results) {
                        results.style.pointerEvents = "";
                        results.style.position = "";
                        results.style.opacity = "";
                        results.style.visibility = "";
                        results.classList.add("active");
                    }
                    noResults.style.display = "block";
                } else {
                    if (results) {
                        results.style.pointerEvents = "none";
                        results.style.position = "absolute";
                        results.style.opacity = "0";
                        results.style.visibility = "hidden";
                        results.classList.remove("active");
                    }
                    noResults.style.display = "none";
                }
            }

            status.style.display = "none";
            status.className = "request-status";
            requestBtn.classList.remove("is-success");
            requestBtn.disabled = false;
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "/" && document.activeElement !== input) {
                e.preventDefault();
                input.focus();
            }
        });

        requestBtn.addEventListener("click", async () => {
            const query = input.value.trim();
            if (!query) return;

            requestBtn.classList.add("is-loading");
            requestBtn.disabled = true;

            let userId = "Anónimo";
            try {
                const footprint = localStorage.getItem("jjlmoya_footprint_v5");
                if (footprint) {
                    const data = JSON.parse(footprint);
                    if (data.id) userId = data.id;
                }
            } catch (e) {}

            try {
                await fetch(
                    "https://script.google.com/macros/s/AKfycbySUhlqnbamZCYZjuCJlQD51jmuAnjX6q6jb8XSFo7CRAG3_M_Xb90MWqSB_2zb-OQc/exec",
                    {
                        method: "POST",
                        mode: "no-cors",
                        headers: { "Content-Type": "text/plain" },
                        body: JSON.stringify({
                            type: "utility-request",
                            query: query,
                            ua: navigator.userAgent,
                            id: userId,
                            timestamp: new Date().toISOString(),
                        }),
                    }
                );

                requestBtn.classList.remove("is-loading");
                requestBtn.classList.add("is-success");
                status.style.display = "block";
                status.className = "request-status success";
            } catch (err) {
                requestBtn.classList.remove("is-loading");
                requestBtn.disabled = false;
                alert("Uy, no he podido enviar la propuesta. ¡Inténtalo de nuevo!");
            }
        });
    }

    initSearch();
    document.addEventListener("astro:page-load", initSearch);
</script>
