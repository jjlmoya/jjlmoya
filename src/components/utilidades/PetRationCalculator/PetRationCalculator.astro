---
import { Icon } from "astro-icon/components";
import "./PetRationCalculator.css";
---

<div class="pet-ration-calculator-final" id="calcWrapper">
    <div class="calc-loader" id="calcLoader">
        <Icon name="mdi:loading" class="loader-spinner" />
    </div>

    <div class="calc-container">
        <div class="calc-section">
            <h3 class="section-title">1. Perfil de la Mascota</h3>
            
            <div class="input-item">
                <label class="item-label">Animal</label>
                <div class="species-selector-v2">
                    <input type="radio" name="petType" id="dog" value="dog" checked />
                    <label for="dog" class="btn-species">
                        <Icon name="mdi:dog" class="icon-v2" /> Perro
                    </label>
                    
                    <input type="radio" name="petType" id="cat" value="cat" />
                    <label for="cat" class="btn-species">
                        <Icon name="mdi:cat" class="icon-v2" /> Gato
                    </label>

                    <input type="radio" name="petType" id="rabbit" value="rabbit" />
                    <label for="rabbit" class="btn-species">
                        <Icon name="mdi:rabbit" class="icon-v2" /> Conejo
                    </label>
                </div>
            </div>

            <div class="input-item">
                <label class="item-label">Etapa Vital</label>
                <div class="segmented-v2">
                    <input type="radio" name="lifeStage" id="puppy" value="puppy" />
                    <label for="puppy">Cachorro</label>
                    <input type="radio" name="lifeStage" id="adult" value="adult" checked />
                    <label for="adult">Adulto</label>
                    <input type="radio" name="lifeStage" id="senior" value="senior" />
                    <label for="senior">Senior</label>
                </div>
            </div>

            <div class="input-item">
                <div class="label-row-v2">
                    <label class="item-label">Peso Corporal</label>
                    <div class="val-badge"><span id="weightDisplay">10</span> kg</div>
                </div>
                <input type="range" id="weightRange" min="1" max="85" step="0.5" value="10" class="range-v2" />
            </div>

            <div class="input-item">
                <label class="item-label">Actividad Física</label>
                <div class="segmented-v2 activity-box">
                    <input type="radio" name="activity" id="act-low" value="low" />
                    <label for="act-low">Baja</label>
                    <input type="radio" name="activity" id="act-mod" value="mod" checked />
                    <label for="act-mod">Normal</label>
                    <input type="radio" name="activity" id="act-high" value="high" />
                    <label for="act-high">Alta</label>
                </div>
            </div>
        </div>

        <div class="calc-section">
            <h3 class="section-title">2. Dieta y Alimento</h3>
            
            <div class="input-item">
                <label class="item-label">Tipo de Alimentación</label>
                <div class="ratio-presets">
                    <input type="radio" name="dietRatioPreset" id="r-dry" value="0" checked />
                    <label for="r-dry">Solo Seco</label>
                    
                    <input type="radio" name="dietRatioPreset" id="r-mixed" value="25" />
                    <label for="r-mixed">Mixta (25%)</label>
                    
                    <input type="radio" name="dietRatioPreset" id="r-half" value="50" />
                    <label for="r-half">Mitad (50%)</label>
                    
                    <input type="radio" name="dietRatioPreset" id="r-wet" value="100" />
                    <label for="r-wet">Solo Húmedo</label>
                </div>
                <div class="custom-ratio-link" id="showManualSlider">Ajuste manual (1-99%)</div>
                <div class="manual-slider-box" id="manualSliderBox" style="display: none;">
                    <input type="range" id="dietRatioRange" min="0" max="100" step="5" value="0" class="range-v2 ratio-slider" />
                    <div class="ratio-labels">
                        <span>% de comida húmeda en la dieta</span>
                        <strong id="ratioValDisplay">0%</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="results-v2">
            <div class="res-cards-v2">
                <div class="res-card-v2 dry" id="dryResCard">
                    <span class="res-tag">Seco</span>
                    <span class="res-num"><span id="dryResVal">0</span><small>g</small></span>
                </div>
                <div class="res-card-v2 wet" id="wetResCard" style="display: none;">
                    <span class="res-tag">Húmedo</span>
                    <span class="res-num"><span id="wetResVal">0</span><small>g</small></span>
                </div>
            </div>
            
            <div class="res-footer-v2">
                <div class="total-info">
                    <Icon name="mdi:chart-donut" class="footer-icon" />
                    Total: <strong id="kcalTotalVal">0</strong> kcal/día
                </div>
                <div class="status-box-v2" id="statusBoxV2">Mantenimiento ideal</div>
            </div>
        </div>
    </div>
</div>

<script>
    const MULTIPLIERS = {
        dog: { puppy: { low: 2.5, mod: 3.0, high: 3.5 }, adult: { low: 1.2, mod: 1.6, high: 2.0 }, senior: { low: 1.0, mod: 1.2, high: 1.4 } },
        cat: { puppy: { low: 2.0, mod: 2.5, high: 3.0 }, adult: { low: 1.0, mod: 1.2, high: 1.4 }, senior: { low: 0.9, mod: 1.0, high: 1.1 } },
        rabbit: { puppy: { low: 1.5, mod: 2.0, high: 2.5 }, adult: { low: 1.0, mod: 1.2, high: 1.4 }, senior: { low: 0.8, mod: 1.0, high: 1.2 } }
    };

    function init() {
        const els = {
            weightRange: document.getElementById("weightRange") as HTMLInputElement,
            weightLabel: document.getElementById("weightDisplay"),
            ratioRange: document.getElementById("dietRatioRange") as HTMLInputElement,
            ratioLabel: document.getElementById("ratioValDisplay"),
            presets: document.getElementsByName("dietRatioPreset") as NodeListOf<HTMLInputElement>,
            manualBox: document.getElementById("manualSliderBox"),
            showManual: document.getElementById("showManualSlider"),
            dryCard: document.getElementById("dryResCard"),
            wetCard: document.getElementById("wetResCard"),
            dryVal: document.getElementById("dryResVal"),
            wetVal: document.getElementById("wetResVal"),
            kcalTotal: document.getElementById("kcalTotalVal"),
            status: document.getElementById("statusBoxV2"),
            loader: document.getElementById("calcLoader")
        };

        if (!els.weightRange) return;

        const standards = { kDry: 3500, kWet: 1000 };

        function calculate() {
            try {
                const species = ((document.querySelector('input[name="petType"]:checked') as HTMLInputElement)?.value || "dog") as "dog" | "cat" | "rabbit";
                const stage = ((document.querySelector('input[name="lifeStage"]:checked') as HTMLInputElement)?.value || "adult") as "puppy" | "adult" | "senior";
                const activity = ((document.querySelector('input[name="activity"]:checked') as HTMLInputElement)?.value || "mod") as "low" | "mod" | "high";
                const weight = parseFloat(els.weightRange.value) || 0;
                const wetPct = parseInt(els.ratioRange.value) / 100;
                const dryPct = 1 - wetPct;

                const rer = 70 * Math.pow(weight, 0.75);
                const der = rer * (MULTIPLIERS[species][stage][activity] || 1.6);

                const gDry = (der * dryPct / standards.kDry) * 1000;
                const gWet = (der * wetPct / standards.kWet) * 1000;

                if (els.weightLabel) els.weightLabel.innerText = weight.toString();
                if (els.ratioLabel) els.ratioLabel.innerText = `${Math.round(wetPct * 100)}%`;
                if (els.dryVal) els.dryVal.innerText = Math.round(gDry).toString();
                if (els.wetVal) els.wetVal.innerText = Math.round(gWet).toString();
                if (els.kcalTotal) els.kcalTotal.innerText = Math.round(der).toString();

                if (els.dryCard) els.dryCard.style.display = dryPct > 0 ? "flex" : "none";
                if (els.wetCard) els.wetCard.style.display = wetPct > 0 ? "flex" : "none";

                let msg = "Peso equilibrado";
                if (stage === "puppy") msg = "Fase de crecimiento rápido";
                if (stage === "senior") msg = "Metabolismo maduro";
                if (weight > 40 && species === "dog") msg = "Raza grande: Control articular";
                if (els.status) els.status.innerText = msg;

                localStorage.setItem("pet_v2_state", JSON.stringify({ species, stage, activity, weight, wetPct }));
                
                const url = new URL(window.location.href);
                url.searchParams.set("w", weight.toString());
                url.searchParams.set("s", species);
                url.searchParams.set("st", stage);
                url.searchParams.set("a", activity);
                url.searchParams.set("r", els.ratioRange.value);
                window.history.replaceState({}, "", url.toString());
            } catch (e) {
                console.error("Calc error:", e);
            }
        }

        const params = new URLSearchParams(window.location.search);
        const stored = JSON.parse(localStorage.getItem("pet_v2_state") || "{}");

        const setRadio = (name: string, val: string) => {
            const el = document.querySelector(`input[name="${name}"][value="${val}"]`) as HTMLInputElement;
            if (el) el.checked = true;
        };

        const config = {
            s: params.get("s") || stored.species || "dog",
            st: params.get("st") || stored.stage || "adult",
            a: params.get("a") || stored.activity || "mod",
            w: params.get("w") || stored.weight || "10",
            r: params.get("r") || (stored.wetPct !== undefined ? (stored.wetPct * 100).toString() : "0")
        };

        setRadio("petType", config.s);
        setRadio("lifeStage", config.st);
        setRadio("activity", config.a);
        
        els.weightRange.value = config.w;
        els.ratioRange.value = config.r;
        
        const preset = Array.from(els.presets).find(p => p.value === config.r);
        if (preset) preset.checked = true;
        else if (els.manualBox && config.r !== "0" && config.r !== "100") {
            els.manualBox.style.display = "block";
            if (els.showManual) els.showManual.style.display = "none";
        }

        const setMaxWeight = (sp: string) => {
            if (sp === "rabbit") els.weightRange.max = "10";
            else if (sp === "cat") els.weightRange.max = "20";
            else els.weightRange.max = "85";
        };
        setMaxWeight(config.s);

        document.querySelector(".pet-ration-calculator-final")?.addEventListener("input", calculate);
        document.querySelector(".pet-ration-calculator-final")?.addEventListener("change", calculate);

        els.showManual?.addEventListener("click", () => {
            if (els.manualBox) els.manualBox.style.display = "block";
            els.showManual!.style.display = "none";
        });

        els.presets.forEach(p => p.addEventListener("change", (e) => {
            els.ratioRange.value = (e.target as HTMLInputElement).value;
            calculate();
        }));

        document.getElementsByName("petType").forEach(r => {
            r.addEventListener("change", (e) => {
                setMaxWeight((e.target as HTMLInputElement).value);
                calculate();
            });
        });

        calculate();
        
        setTimeout(() => {
            if (els.loader) els.loader.classList.add("hidden");
        }, 50);
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
    } else {
        init();
    }
</script>
