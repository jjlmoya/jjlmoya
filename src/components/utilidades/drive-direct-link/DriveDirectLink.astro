---
import "./DriveDirectLink.css";
---

<section class="drive-utility">
    <div class="glass-panel">
        <div class="input-group">
            <label for="drive-url-input">Pega tu enlace de Google Drive aquí:</label>
            <input
                type="text"
                id="drive-url-input"
                placeholder="https://drive.google.com/file/d/..."
            />
        </div>

        <button id="generate-btn" class="primary-btn">Generar Enlace Directo</button>

        <div id="result-container" class="result-container hidden">
            <label>Enlace de Descarga Directa:</label>
            <div class="output-wrapper">
                <input type="text" id="direct-link-output" readonly />
                <button id="copy-btn" class="icon-btn" title="Copiar al portapapeles">
                    <svg viewBox="0 0 24 24" width="24" height="24">
                        <path
                            fill="currentColor"
                            d="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                        ></path>
                    </svg>
                </button>
            </div>
            <a
                id="test-download-btn"
                class="secondary-btn"
                href="#"
                target="_blank"
                rel="noopener noreferrer">Testear Descarga</a
            >
        </div>
        <div id="error-message" class="error-message hidden">
            El enlace introducido no parece ser un enlace válido de Google Drive.
        </div>
    </div>
</section>

<script>
    const driveInput = document.getElementById("drive-url-input") as HTMLInputElement | null;
    const generateBtn = document.getElementById("generate-btn") as HTMLButtonElement | null;
    const resultContainer = document.getElementById("result-container") as HTMLDivElement | null;
    const directLinkOutput = document.getElementById(
        "direct-link-output"
    ) as HTMLInputElement | null;
    const copyBtn = document.getElementById("copy-btn") as HTMLButtonElement | null;
    const errorMsg = document.getElementById("error-message") as HTMLDivElement | null;
    const testDownloadBtn = document.getElementById(
        "test-download-btn"
    ) as HTMLAnchorElement | null;

    function extractDriveId(url: string): string | null {
        try {
            const parsedUrl = new URL(url);

            const pathSegments = parsedUrl.pathname.split("/");
            const fileDIndex = pathSegments.indexOf("d");
            if (fileDIndex !== -1 && fileDIndex + 1 < pathSegments.length) {
                return pathSegments[fileDIndex + 1];
            }

            const idParam = parsedUrl.searchParams.get("id");
            if (idParam) {
                return idParam;
            }
        } catch {
            return null;
        }
        return null;
    }

    function handleGenerate() {
        if (!driveInput || !resultContainer || !directLinkOutput || !errorMsg || !testDownloadBtn)
            return;

        const url = driveInput.value.trim();
        if (!url) {
            resultContainer.classList.add("hidden");
            errorMsg.classList.add("hidden");
            return;
        }

        const id = extractDriveId(url);

        if (id) {
            const directUrl = `https://drive.google.com/uc?export=download&id=${id}`;
            directLinkOutput.value = directUrl;
            testDownloadBtn.href = directUrl;

            resultContainer.classList.remove("hidden");
            errorMsg.classList.add("hidden");
        } else {
            resultContainer.classList.add("hidden");
            errorMsg.classList.remove("hidden");
        }
    }

    if (generateBtn) {
        generateBtn.addEventListener("click", handleGenerate);
    }

    if (driveInput) {
        driveInput.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                handleGenerate();
            }
        });
    }

    if (copyBtn && directLinkOutput) {
        copyBtn.addEventListener("click", () => {
            directLinkOutput.select();
            navigator.clipboard.writeText(directLinkOutput.value).then(() => {
                const originalTitle = copyBtn.getAttribute("title");
                copyBtn.setAttribute("title", "Copiado");
                setTimeout(() => {
                    if (originalTitle) {
                        copyBtn.setAttribute("title", originalTitle);
                    }
                }, 2000);
            });
        });
    }
</script>
