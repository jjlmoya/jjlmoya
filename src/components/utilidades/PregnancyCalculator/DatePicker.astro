---
---
<div class="dp-wrap">
    <div class="dp-label-row">
        <span class="dp-label" id="dp-label">Fecha de última regla</span>
    </div>
    <div class="dp-selects">
        <div class="dp-field">
            <select id="dp-day" class="dp-select" aria-label="Día">
                <option value="">Día</option>
            </select>
        </div>
        <div class="dp-sep">/</div>
        <div class="dp-field">
            <select id="dp-month" class="dp-select" aria-label="Mes">
                <option value="">Mes</option>
            </select>
        </div>
        <div class="dp-sep">/</div>
        <div class="dp-field dp-field--year">
            <select id="dp-year" class="dp-select" aria-label="Año">
                <option value="">Año</option>
            </select>
        </div>
    </div>
</div>

<script>
import { setState, subscribe, getState } from './store';

const MONTHS = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

const selDay   = document.getElementById('dp-day')   as HTMLSelectElement;
const selMonth = document.getElementById('dp-month') as HTMLSelectElement;
const selYear  = document.getElementById('dp-year')  as HTMLSelectElement;
const label    = document.getElementById('dp-label') as HTMLElement;

MONTHS.forEach((m, i) => {
    const opt = document.createElement('option');
    opt.value = String(i + 1);
    opt.textContent = m;
    selMonth.appendChild(opt);
});

const now = new Date();
for (let y = now.getFullYear(); y >= now.getFullYear() - 1; y--) {
    const opt = document.createElement('option');
    opt.value = String(y);
    opt.textContent = String(y);
    selYear.appendChild(opt);
}

function populateDays(preserveDay?: number) {
    const m = parseInt(selMonth.value) || 1;
    const y = parseInt(selYear.value) || now.getFullYear();
    const max = new Date(y, m, 0).getDate();
    const cur = preserveDay ?? (parseInt(selDay.value) || 0);
    selDay.innerHTML = '<option value="">Día</option>';
    for (let d = 1; d <= max; d++) {
        const opt = document.createElement('option');
        opt.value = String(d);
        opt.textContent = String(d).padStart(2, '0');
        if (d === cur) opt.selected = true;
        selDay.appendChild(opt);
    }
}

const saved = getState();
if (saved.date) {
    const [sy, sm, sd] = saved.date.split('-').map(Number);
    selYear.value  = String(sy);
    selMonth.value = String(sm);
    populateDays(sd);
} else {
    populateDays();
}

label.textContent = saved.method === 'fur' ? 'Fecha de última regla' : 'Fecha de concepción';

function getDateString(): string {
    const d = selDay.value, m = selMonth.value, y = selYear.value;
    if (!d || !m || !y) return '';
    return `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}`;
}

function trySetDate() {
    const str = getDateString();
    setState({ date: str });
}

selMonth.addEventListener('change', () => { populateDays(); trySetDate(); });
selYear.addEventListener('change',  () => { populateDays(); trySetDate(); });

selDay.addEventListener('change', trySetDate);

subscribe(({ method }) => {
    label.textContent = method === 'fur' ? 'Fecha de última regla' : 'Fecha de concepción';
});
</script>

<style>
.dp-wrap { display: flex; flex-direction: column; gap: 10px; }

.dp-label-row { display: flex; align-items: center; gap: 8px; }

.dp-label {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #94a3b8;
}

.dp-selects {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 18px;
    padding: 6px 10px;
    gap: 4px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);
    transition: box-shadow 0.2s;
}

:global(.dark) .dp-selects {
    background: #1a2332;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2), 0 0 0 1px rgba(255,255,255,0.06);
}

.dp-selects:focus-within {
    box-shadow: 0 4px 20px var(--tri-glow, rgba(16,185,129,0.15)), 0 0 0 2px var(--tri-primary, #86efac);
}

.dp-field { flex: 1; }
.dp-field--year { flex: 1.4; }

.dp-select {
    width: 100%;
    border: none;
    background: transparent;
    font-size: 0.95rem;
    font-weight: 700;
    color: #1e293b;
    cursor: pointer;
    padding: 8px 4px;
    appearance: none;
    -webkit-appearance: none;
    outline: none;
    text-align: center;
}

:global(.dark) .dp-select { color: #f1f5f9; }

.dp-select option { background: #fff; color: #1e293b; }
:global(.dark) .dp-select option { background: #1a2332; color: #f1f5f9; }

.dp-sep {
    font-size: 1rem;
    font-weight: 300;
    color: #cbd5e1;
    flex-shrink: 0;
    padding: 0 2px;
}
</style>
