---
---
<div class="sd-wrap">
    <div class="stats-row">
        <div class="stat-chip">
            <span class="stat-key">Semanas</span>
            <span class="stat-value accent" id="sd-weeks">—</span>
        </div>
        <div class="stat-chip">
            <span class="stat-key">Trimestre</span>
            <span class="stat-value" id="sd-tri">—</span>
        </div>
    </div>

    <div class="edd-box">
        <div class="edd-label">Fecha Probable de Parto</div>
        <div class="edd-date" id="sd-edd">Introduce tu fecha</div>
        <div class="edd-note">Solo el 3–5% de los bebés nace ese día exacto</div>
    </div>

    <button class="btn-cal" id="sd-btn-cal" disabled>
        Guardar en Calendario
    </button>
</div>

<script>
import { subscribe, getState } from './store';

const elWeeks = document.getElementById('sd-weeks') as HTMLElement;
const elTri   = document.getElementById('sd-tri')   as HTMLElement;
const elEdd   = document.getElementById('sd-edd')   as HTMLElement;
const btnCal  = document.getElementById('sd-btn-cal') as HTMLButtonElement;

function renderStats(result: ReturnType<typeof getState>['result']) {
    if (!result) {
        elWeeks.textContent = '—';
        elTri.textContent   = '—';
        elEdd.textContent   = 'Introduce tu fecha';
        btnCal.disabled     = true;
        return;
    }
    elWeeks.textContent = `${result.weeks}s ${result.days}d`;
    elTri.textContent   = `${result.trimester}º`;
    elEdd.textContent   = result.edd.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
    btnCal.disabled     = false;
}

renderStats(getState().result);

subscribe(({ result }) => renderStats(result));

btnCal.addEventListener('click', () => {
    import('./store').then(({ getState }) => {
        const { result } = getState();
        if (!result) return;
        const d = result.edd;
        const pad = (n: number) => String(n).padStart(2, '0');
        const dt = `${d.getFullYear()}${pad(d.getMonth()+1)}${pad(d.getDate())}`;
        const ics = [
            'BEGIN:VCALENDAR', 'VERSION:2.0',
            'PRODID:-//jjlmoya.es//Calculadora Embarazo//ES',
            'BEGIN:VEVENT',
            `DTSTART;VALUE=DATE:${dt}`, `DTEND;VALUE=DATE:${dt}`,
            'SUMMARY:Fecha Probable de Parto',
            'DESCRIPTION:Fecha estimada calculada en jjlmoya.es',
            `UID:pregnancy-${dt}@jjlmoya.es`,
            'END:VEVENT', 'END:VCALENDAR'
        ].join('\r\n');
        const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
        const url  = URL.createObjectURL(blob);
        const a    = Object.assign(document.createElement('a'), { href: url, download: 'fecha-parto.ics' });
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    });
});
</script>

<style>
.sd-wrap { display: flex; flex-direction: column; gap: 12px; }

.stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

.stat-chip {
    background: #f8fafc;
    border-radius: 16px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
}

:global(.dark) .stat-chip { background: #1e2936; }

.stat-key {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #94a3b8;
}

.stat-value {
    font-size: 1.5rem;
    font-weight: 900;
    color: #1e293b;
    letter-spacing: -0.02em;
    transition: color 0.5s;
}

:global(.dark) .stat-value { color: #f1f5f9; }
.stat-value.accent { color: var(--tri-accent, #10b981); }

.edd-box {
    border-radius: 18px;
    padding: 20px;
    background: var(--tri-bg, #f0fdf4);
    text-align: center;
    transition: background 0.5s;
}

:global(.dark) .edd-box { background: rgba(255,255,255,0.04); }

.edd-label {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #94a3b8;
    margin-bottom: 6px;
}

.edd-date {
    font-size: 1.15rem;
    font-weight: 900;
    color: var(--tri-text, #065f46);
    letter-spacing: -0.02em;
    transition: color 0.5s;
}

:global(.dark) .edd-date { color: var(--tri-primary, #86efac); }

.edd-note {
    font-size: 0.72rem;
    color: #94a3b8;
    margin-top: 5px;
    font-style: italic;
}

.btn-cal {
    width: 100%;
    padding: 15px;
    background: var(--tri-accent, #10b981);
    color: #fff;
    border: none;
    border-radius: 16px;
    font-size: 0.82rem;
    font-weight: 800;
    cursor: pointer;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
    box-shadow: 0 4px 16px var(--tri-glow, rgba(16,185,129,0.25));
}

.btn-cal:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--tri-glow, rgba(16,185,129,0.35));
}

.btn-cal:disabled {
    background: #e2e8f0;
    color: #94a3b8;
    box-shadow: none;
    cursor: default;
}

:global(.dark) .btn-cal:disabled { background: #1e2936; }
</style>
