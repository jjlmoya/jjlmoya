---

---

<div class="mp-wrap">
    <div class="mp-empty" id="mp-empty">
        <div class="mp-empty-dot"></div>
        <div class="mp-empty-title">Empieza aquí</div>
        <p class="mp-empty-body">
            Selecciona la fecha de tu última regla y descubre en qué semana estás, qué está formando
            tu bebé hoy y cuándo podría llegar.
        </p>
    </div>

    <div class="mp-egg" id="mp-egg" style="display:none">
        <div class="egg-dot" id="egg-dot"></div>
        <div class="egg-title" id="egg-title"></div>
        <p class="egg-body" id="egg-body"></p>
    </div>

    <div class="mp-results" id="mp-results" style="display:none">
        <div class="mp-top-row">
            <span class="mp-badge" id="mp-badge">Semana —</span>
            <div class="analogy-tabs" role="group" aria-label="Tipo de comparación">
                <button class="at-btn active" data-cat="fruits">Frutas</button>
                <button class="at-btn" data-cat="geek">Geek</button>
                <button class="at-btn" data-cat="sweets">Dulces</button>
            </div>
        </div>

        <div class="size-card">
            <span class="size-name" id="mp-analogy">—</span>
            <span class="size-measure" id="mp-size">—</span>
        </div>

        <div class="info-stack">
            <div class="info-block">
                <div class="info-key">Formación biológica</div>
                <p class="info-text" id="mp-bio"></p>
            </div>
            <div class="info-block">
                <div class="info-key" id="mp-mom-key">Tu cuerpo hoy</div>
                <p class="info-text" id="mp-mom"></p>
            </div>
        </div>

        <div class="wonder-line" id="mp-wonder"></div>

        <div class="semaphore">
            <div class="sema safe">
                <div class="sema-title">Molestias normales</div>
                <ul class="sema-list" id="mp-safe"></ul>
            </div>
            <div class="sema alert">
                <div class="sema-title">Consultar si hay...</div>
                <ul class="sema-list" id="mp-alert"></ul>
            </div>
        </div>
    </div>
</div>

<script>
    import { setState, subscribe, getState } from "./store";
    import { getMilestone } from "./milestones";

    const empty = document.getElementById("mp-empty") as HTMLElement;
    const egg = document.getElementById("mp-egg") as HTMLElement;
    const eggDot = document.getElementById("egg-dot") as HTMLElement;
    const eggTitle = document.getElementById("egg-title") as HTMLElement;
    const eggBody = document.getElementById("egg-body") as HTMLElement;
    const results = document.getElementById("mp-results") as HTMLElement;

    const EASTER_EGGS = {
        future: [
            {
                title: "Viajera en el tiempo detectada",
                body: "Esa fecha aun no ha llegado. Vuelve cuando la realidad te alcance.",
            },
            {
                title: "Profecia recibida",
                body: "Esta herramienta calcula embarazos, no horóscopos. Introduce una fecha pasada.",
            },
            {
                title: "Señal de red: sin cobertura",
                body: "No hay embarazo en el futuro. Al menos que yo sepa.",
            },
        ],
        "too-old": [
            {
                title: "Con esa fecha ya tocaba velas",
                body: "Tu bebé deberia estar en el cole. Revisa el año, algo no cuadra.",
            },
            {
                title: "Fecha caducada",
                body: "Han pasado más de 40 semanas desde esa fecha. Si todo fue bien, ya es mundo exterior.",
            },
            {
                title: "Houston, tenemos un problema de calendario",
                body: "Eso supera los 9 meses. O cambias la fecha o nos cuentas qué pasó.",
            },
        ],
    } as const;

    function showEasterEgg(reason: "future" | "too-old") {
        const options = EASTER_EGGS[reason];
        const pick = options[Math.floor(Math.random() * options.length)];
        eggDot.dataset.reason = reason;
        eggTitle.textContent = pick.title;
        eggBody.textContent = pick.body;
        empty.style.display = "none";
        results.style.display = "none";
        egg.style.display = "";
    }
    const elBadge = document.getElementById("mp-badge") as HTMLElement;
    const elName = document.getElementById("mp-analogy") as HTMLElement;
    const elSize = document.getElementById("mp-size") as HTMLElement;
    const elBio = document.getElementById("mp-bio") as HTMLElement;
    const elMom = document.getElementById("mp-mom") as HTMLElement;
    const elMomKey = document.getElementById("mp-mom-key") as HTMLElement;
    const elWonder = document.getElementById("mp-wonder") as HTMLElement;
    const elSafe = document.getElementById("mp-safe") as HTMLElement;
    const elAlert = document.getElementById("mp-alert") as HTMLElement;

    const atBtns = document.querySelectorAll(".at-btn");

    const initCat = getState().analogyCat;
    atBtns.forEach((btn) => {
        const isActive = (btn as HTMLElement).dataset.cat === initCat;
        btn.classList.toggle("active", isActive);
        btn.addEventListener("click", () => {
            atBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            setState({
                analogyCat: (btn as HTMLElement).dataset.cat as "fruits" | "geek" | "sweets",
            });
        });
    });

    function render(weeks: number, cat: string, partner: boolean) {
        const mile = getMilestone(weeks);
        elBadge.textContent = `Semana ${weeks}`;
        elName.textContent = mile.analogies[cat as "fruits" | "geek" | "sweets"];
        elSize.textContent = mile.size;
        elBio.textContent = mile.biolook;
        elMomKey.textContent = partner ? "Como apoyarla hoy" : "Tu cuerpo hoy";
        elMom.textContent = partner ? mile.partner : mile.mom;
        elWonder.textContent = mile.wonder;
        elSafe.innerHTML = mile.symptoms.map((s) => `<li>${s}</li>`).join("");
        elAlert.innerHTML = mile.alerts.map((s) => `<li>${s}</li>`).join("");
    }

    function applyState(
        result: ReturnType<typeof getState>["result"],
        analogyCat: string,
        partner: boolean
    ) {
        if (!result) {
            empty.style.display = "";
            egg.style.display = "none";
            results.style.display = "none";
            return;
        }
        if (!result.valid && result.outOfRange) {
            showEasterEgg(result.outOfRange);
            return;
        }
        const wasHidden = results.style.display === "none";
        empty.style.display = "none";
        egg.style.display = "none";
        results.style.display = "";
        if (wasHidden) {
            results.classList.remove("mp-enter");
            void results.offsetWidth;
            results.classList.add("mp-enter");
        }
        render(result.weeks, analogyCat, partner);
    }

    const init = getState();
    applyState(init.result, init.analogyCat, init.partner);

    subscribe(({ result, analogyCat, partner }) => applyState(result, analogyCat, partner));
</script>

<style>
    .mp-wrap {
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .mp-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 14px;
        padding: 48px 32px;
    }

    .mp-empty-dot {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--tri-badge, #dcfce7);
        border: 2px solid var(--tri-primary, #86efac);
        transition:
            background 0.5s,
            border-color 0.5s;
        animation: breathe 3s ease-in-out infinite;
    }

    @keyframes breathe {
        0%,
        100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.08);
        }
    }

    .mp-empty-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: -0.02em;
    }
    :global(.dark) .mp-empty-title {
        color: #f1f5f9;
    }

    .mp-empty-body {
        font-size: 0.92rem;
        color: #94a3b8;
        max-width: 300px;
        line-height: 1.7;
    }

    .mp-egg {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 14px;
        padding: 48px 32px;
        animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .egg-dot {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 2px dashed #f87171;
        background: #fef2f2;
        animation: spin 6s linear infinite;
    }

    .egg-dot[data-reason="too-old"] {
        border-color: #fb923c;
        background: #fff7ed;
    }

    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    .egg-title {
        font-size: 1.2rem;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: -0.02em;
    }
    :global(.dark) .egg-title {
        color: #f1f5f9;
    }

    .egg-body {
        font-size: 0.92rem;
        color: #94a3b8;
        max-width: 300px;
        line-height: 1.7;
        font-style: italic;
    }

    .mp-results {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .mp-enter {
        animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .mp-top-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .mp-badge {
        background: var(--tri-badge, #dcfce7);
        color: var(--tri-text, #065f46);
        border-radius: 10px;
        padding: 5px 14px;
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        transition:
            background 0.5s,
            color 0.5s;
    }

    .analogy-tabs {
        display: flex;
        gap: 4px;
        background: #f1f5f9;
        border-radius: 12px;
        padding: 3px;
    }
    :global(.dark) .analogy-tabs {
        background: rgba(255, 255, 255, 0.06);
    }

    .at-btn {
        padding: 5px 12px;
        border: none;
        border-radius: 9px;
        font-size: 0.7rem;
        font-weight: 800;
        background: transparent;
        color: #94a3b8;
        cursor: pointer;
        transition: all 0.2s;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .at-btn.active {
        background: #fff;
        color: var(--tri-text, #065f46);
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
    }
    :global(.dark) .at-btn.active {
        background: #1e2936;
        color: var(--tri-primary, #86efac);
    }

    .size-card {
        background: #f8fafc;
        border-radius: 20px;
        padding: 24px 28px;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
    }
    :global(.dark) .size-card {
        background: #1a2332;
    }

    .size-name {
        font-size: 1.6rem;
        font-weight: 300;
        font-style: italic;
        color: #1e293b;
        letter-spacing: -0.01em;
    }
    :global(.dark) .size-name {
        color: #f1f5f9;
    }

    .size-measure {
        font-size: 0.8rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        white-space: nowrap;
    }

    .info-stack {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .info-block {
        background: #fff;
        border-radius: 16px;
        padding: 18px 20px;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
    }
    :global(.dark) .info-block {
        background: #1a2332;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.15);
    }

    .info-key {
        font-size: 0.65rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--tri-accent, #10b981);
        margin-bottom: 7px;
        transition: color 0.5s;
    }

    .info-text {
        font-size: 0.92rem;
        line-height: 1.75;
        color: #475569;
        font-weight: 500;
    }
    :global(.dark) .info-text {
        color: #94a3b8;
    }

    .wonder-line {
        border-left: 3px solid var(--tri-primary, #86efac);
        padding: 12px 16px;
        border-radius: 0 12px 12px 0;
        background: var(--tri-bg, #f0fdf4);
        font-size: 0.85rem;
        line-height: 1.6;
        color: var(--tri-text, #065f46);
        font-weight: 600;
        font-style: italic;
        transition:
            background 0.5s,
            color 0.5s,
            border-color 0.5s;
    }
    :global(.dark) .wonder-line {
        background: rgba(255, 255, 255, 0.03);
        color: var(--tri-primary, #86efac);
    }

    .semaphore {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }
    @media (max-width: 500px) {
        .semaphore {
            grid-template-columns: 1fr;
        }
    }

    .sema {
        border-radius: 16px;
        padding: 18px;
    }
    .sema.safe {
        background: #f0fdf4;
    }
    .sema.alert {
        background: #fff7ed;
    }
    :global(.dark) .sema.safe {
        background: rgba(16, 185, 129, 0.08);
    }
    :global(.dark) .sema.alert {
        background: rgba(249, 115, 22, 0.08);
    }

    .sema-title {
        font-size: 0.65rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        margin-bottom: 10px;
    }
    .safe .sema-title {
        color: #16a34a;
    }
    .alert .sema-title {
        color: #ea580c;
    }

    .sema-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    .sema-list li {
        font-size: 0.8rem;
        color: #64748b;
        padding-left: 14px;
        position: relative;
        line-height: 1.4;
    }
    :global(.dark) .sema-list li {
        color: #94a3b8;
    }
    .safe .sema-list li::before {
        content: "v";
        position: absolute;
        left: 0;
        color: #22c55e;
        font-weight: 900;
        font-size: 0.7rem;
    }
    .alert .sema-list li::before {
        content: "!";
        position: absolute;
        left: 0;
        color: #f97316;
        font-weight: 900;
        font-size: 0.7rem;
    }
</style>
