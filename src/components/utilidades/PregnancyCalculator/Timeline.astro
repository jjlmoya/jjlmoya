---
---
<aside class="tl-aside">
    <div class="tl-header">Línea de tiempo</div>
    <div class="tl-scroll" id="tl-scroll">
    </div>
</aside>

<script>
import { subscribe, getState } from './store';
import { timelineLabels } from './milestones';

const scroll = document.getElementById('tl-scroll') as HTMLElement;

const frag = document.createDocumentFragment();
for (let w = 4; w <= 40; w++) {
    const label = timelineLabels[w] ?? '';
    const row = document.createElement('div');
    row.className = 'tl-row';
    row.dataset.week = String(w);
    row.innerHTML = `
        <div class="tl-line-col">
            <div class="tl-dot"></div>
            ${w < 40 ? '<div class="tl-line"></div>' : ''}
        </div>
        <div class="tl-info">
            <span class="tl-num">Sem ${w}</span>
            ${label ? `<span class="tl-label">${label}</span>` : ''}
        </div>
    `;
    frag.appendChild(row);
}
scroll.appendChild(frag);

function updateTimeline(weeks: number) {
    document.querySelectorAll('.tl-row').forEach(el => {
        const w = parseInt((el as HTMLElement).dataset.week ?? '0');
        el.classList.toggle('tl-past', w < weeks);
        el.classList.toggle('tl-current', w === weeks);
        el.classList.toggle('tl-future', w > weeks);
    });
    const current = scroll.querySelector('.tl-current') as HTMLElement | null;
    if (current) current.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

const initWeeks = getState().result?.weeks ?? -1;
if (initWeeks >= 0) updateTimeline(initWeeks);

subscribe(({ result }) => {
    if (result) updateTimeline(result.weeks);
});
</script>

<style>
.tl-aside {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: #f8fafc;
    border-left: 1px solid #edf2f7;
    overflow: hidden;
}

:global(.dark) .tl-aside { background: #0f1923; border-color: rgba(255,255,255,0.04); }

.tl-header {
    padding: 18px 18px 12px;
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #94a3b8;
    border-bottom: 1px solid #edf2f7;
    flex-shrink: 0;
}

:global(.dark) .tl-header { border-color: rgba(255,255,255,0.04); }

.tl-scroll {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 12px 14px 20px;
    scrollbar-width: thin;
    scrollbar-color: #e2e8f0 transparent;
}

:global(.dark) .tl-scroll { scrollbar-color: #334155 transparent; }
.tl-scroll::-webkit-scrollbar { width: 3px; }
.tl-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 2px; }
:global(.dark) .tl-scroll::-webkit-scrollbar-thumb { background: #334155; }
</style>

<style is:global>
.tl-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    position: relative;
}

.tl-line-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 16px;
}

.tl-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #dde3ea;
    flex-shrink: 0;
    transition: background 0.3s, box-shadow 0.3s, transform 0.3s;
    margin-top: 4px;
}

:global(.dark) .tl-dot { background: #2d3d50; }

.tl-line {
    width: 1px;
    height: 26px;
    background: #e8edf2;
    transition: background 0.3s;
}

:global(.dark) .tl-line { background: #2d3d50; }

.tl-info {
    padding-top: 1px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding-bottom: 10px;
}

.tl-num {
    font-size: 0.68rem;
    font-weight: 700;
    color: #c8d3dd;
    transition: color 0.3s;
    line-height: 1.2;
}

:global(.dark) .tl-num { color: #3d5268; }

.tl-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: #b0bec9;
    line-height: 1.3;
    transition: color 0.3s;
}

:global(.dark) .tl-label { color: #3d5268; }

.tl-past .tl-dot  { background: var(--tri-primary, #86efac); }
.tl-past .tl-line { background: var(--tri-primary, #86efac); }
.tl-past .tl-num  { color: #7b93a8; }
:global(.dark) .tl-past .tl-num { color: #5a7a94; }

.tl-current .tl-dot {
    background: var(--tri-accent, #10b981);
    box-shadow: 0 0 0 4px var(--tri-glow, rgba(16,185,129,0.2));
    transform: scale(1.4);
}

.tl-current .tl-num {
    color: var(--tri-accent, #10b981);
    font-weight: 900;
}

.tl-current .tl-label {
    color: #1e293b;
    font-weight: 800;
}

:global(.dark) .tl-current .tl-label { color: #f1f5f9; }
</style>
