---
---
<div class="pc-header">
    <div class="method-group" role="group" aria-label="Método de cálculo">
        <button class="method-btn active" data-method="fur" aria-pressed="true">
            Última Regla
        </button>
        <button class="method-btn" data-method="conception" aria-pressed="false">
            Fecha de Concepción
        </button>
    </div>

    <label class="partner-wrap" title="Activar modo pareja">
        <span class="partner-label">Modo pareja</span>
        <div class="toggle-track" id="partner-track">
            <div class="toggle-thumb"></div>
        </div>
    </label>
</div>

<script>
import { setState, getState } from './store';

const btns = document.querySelectorAll('.method-btn');
const track = document.getElementById('partner-track') as HTMLElement;

const initial = getState();
if (initial.method === 'conception') {
    btns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
    const conceptionBtn = document.querySelector('[data-method="conception"]');
    conceptionBtn?.classList.add('active');
    conceptionBtn?.setAttribute('aria-pressed', 'true');
}
if (initial.partner) track.classList.add('on');

btns.forEach(btn => {
    btn.addEventListener('click', () => {
        btns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        setState({ method: (btn as HTMLElement).dataset.method as 'fur' | 'conception' });
    });
});

track.addEventListener('click', () => {
    import('./store').then(({ getState, setState }) => {
        const next = !getState().partner;
        track.classList.toggle('on', next);
        setState({ partner: next });
    });
});
</script>

<style>
.pc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 32px 20px;
    gap: 16px;
    flex-wrap: wrap;
    border-bottom: 1px solid #f1f5f9;
}

:global(.dark) .pc-header { border-color: rgba(255,255,255,0.05); }

.method-group {
    display: flex;
    background: #f1f5f9;
    border-radius: 16px;
    padding: 4px;
    gap: 0;
}

:global(.dark) .method-group { background: rgba(255,255,255,0.06); }

.method-btn {
    padding: 9px 20px;
    border: none;
    background: transparent;
    border-radius: 12px;
    font-size: 0.78rem;
    font-weight: 800;
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
}

.method-btn.active {
    background: #fff;
    color: var(--tri-accent, #10b981);
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
}

:global(.dark) .method-btn.active { background: #1e2936; color: var(--tri-primary, #86efac); }

.partner-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    user-select: none;
}

.partner-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.07em;
}

.toggle-track {
    width: 42px;
    height: 22px;
    background: #e2e8f0;
    border-radius: 11px;
    position: relative;
    transition: background 0.3s;
    flex-shrink: 0;
}

:global(.dark) .toggle-track { background: #334155; }
.toggle-track.on { background: var(--tri-accent, #10b981); }

.toggle-thumb {
    position: absolute;
    top: 3px; left: 3px;
    width: 16px; height: 16px;
    background: #fff;
    border-radius: 50%;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
}

.toggle-track.on .toggle-thumb { transform: translateX(20px); }
</style>
