---
---
<div class="cs-wrap" id="cs-wrap">
    <div class="cs-header">
        <span class="cs-label">Duración del ciclo</span>
        <span class="cs-value-wrap">
            <span class="cs-value" id="cs-value">28</span>
            <span class="cs-unit">días</span>
        </span>
    </div>
    <input
        type="range"
        id="cs-slider"
        class="cs-slider"
        min="21"
        max="45"
        value="28"
        aria-label="Duración del ciclo menstrual en días"
        style="--pct: 29.2%"
    />
    <div class="cs-extremes">
        <span>21 días</span>
        <span>45 días</span>
    </div>
</div>

<script>
import { setState, subscribe, getState } from './store';

const slider  = document.getElementById('cs-slider') as HTMLInputElement;
const display = document.getElementById('cs-value')  as HTMLElement;
const wrap    = document.getElementById('cs-wrap')   as HTMLElement;

function updateTrack(val: number) {
    const pct = ((val - 21) / (45 - 21)) * 100;
    slider.style.setProperty('--pct', `${pct}%`);
    display.textContent = String(val);
}

const savedCycle = getState().cycle;
slider.value = String(savedCycle);
updateTrack(savedCycle);

slider.addEventListener('input', () => {
    const val = parseInt(slider.value);
    updateTrack(val);
    setState({ cycle: val });
});

subscribe(({ method }) => {
    wrap.style.opacity = method === 'conception' ? '0.35' : '1';
    wrap.style.pointerEvents = method === 'conception' ? 'none' : '';
});
</script>

<style>
.cs-wrap {
    background: #fff;
    border-radius: 18px;
    padding: 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);
    transition: opacity 0.3s;
}

:global(.dark) .cs-wrap {
    background: #1a2332;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2), 0 0 0 1px rgba(255,255,255,0.06);
}

.cs-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 16px;
}

.cs-label {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #94a3b8;
}

.cs-value {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--tri-accent, #10b981);
    display: inline-block;
    transition: color 0.5s, transform 0.18s cubic-bezier(0.34,1.56,0.64,1);
}

.cs-unit {
    font-size: 0.8rem;
    font-weight: 600;
    color: #94a3b8;
    margin-left: 3px;
}

.cs-slider {
    width: 100%;
    height: 4px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--tri-primary, #86efac) var(--pct, 29%), #e2e8f0 var(--pct, 29%));
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    outline: none;
    transition: background 0.4s;
}

:global(.dark) .cs-slider {
    background: linear-gradient(90deg, var(--tri-primary, #86efac) var(--pct, 29%), #334155 var(--pct, 29%));
}

.cs-slider::-webkit-slider-thumb {
    appearance: none;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid var(--tri-accent, #10b981);
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), border-color 0.5s;
}
.cs-slider::-webkit-slider-thumb:hover { transform: scale(1.2); }
.cs-slider::-moz-range-thumb {
    width: 20px; height: 20px; border-radius: 50%;
    background: #fff; border: 3px solid var(--tri-accent, #10b981); cursor: pointer;
}

.cs-extremes {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
}
.cs-extremes span {
    font-size: 0.65rem;
    font-weight: 700;
    color: #cbd5e1;
}
</style>
