---
import { Icon } from "astro-icon/components";
import "./JsonToExcelConverter.css";
---

<div class="data-converter-console">
    <header class="data-header">
        <div class="data-status">
            <span class="status-dot" id="status-json"></span>
            <span id="label-status">Esperando JSON Válido</span>
        </div>
        <div class="option-strip">
            <label class="checkbox-data">
                <input type="checkbox" id="check-flatten" checked />
                <span>Aplanar Objetos</span>
            </label>
        </div>
    </header>

    <main class="data-main-input">
        <div class="drop-zone" id="drop-zone-json">
            <div class="zone-visuals" id="zone-visuals">
                <Icon
                    name="mdi:file-code-outline"
                    size={64}
                    style="color: var(--data-primary); opacity: 0.3;"
                />
                <span class="zone-label">Pega tu JSON aquí o arrastra un archivo</span>
            </div>
            <textarea
                id="json-input"
                class="json-textarea"
                placeholder='[{"id": 1, "nombre": "Juan", "detalles": {"edad": 30}}]'></textarea>
        </div>
    </main>

    <div class="data-preview-table" id="preview-section" style="display: none;">
        <div class="preview-grid-wrapper">
            <table class="grid-preview" id="preview-table"></table>
        </div>
    </div>

    <footer class="data-footer-actions">
        <button id="btn-copy-csv" class="btn-data btn-outline" style="display: none;">
            <Icon name="mdi:content-copy" size={20} />
            Copiar CSV
        </button>
        <button id="btn-download-csv" class="btn-data btn-primary" style="display: none;">
            <Icon name="mdi:microsoft-excel" size={20} />
            Descargar Excel (CSV)
        </button>
    </footer>
</div>

<script>
    const inputArea = document.getElementById("json-input") as HTMLTextAreaElement | null;
    const dropZone = document.getElementById("drop-zone-json") as HTMLElement | null;
    const statusDot = document.getElementById("status-json") as HTMLElement | null;
    const statusLabel = document.getElementById("label-status") as HTMLElement | null;
    const previewSection = document.getElementById("preview-section") as HTMLElement | null;
    const previewTable = document.getElementById("preview-table") as HTMLElement | null;
    const downloadBtn = document.getElementById("btn-download-csv") as HTMLElement | null;
    const copyBtn = document.getElementById("btn-copy-csv") as HTMLElement | null;
    const flattenCheck = document.getElementById("check-flatten") as HTMLInputElement | null;
    const visuals = document.getElementById("zone-visuals") as HTMLElement | null;

    let currentData: Record<string, unknown>[] = [];

    function flattenObject(obj: Record<string, unknown>, prefix = ""): Record<string, unknown> {
        return Object.keys(obj).reduce((acc: Record<string, unknown>, k) => {
            const pre = prefix.length ? prefix + "." : "";
            const value = obj[k];
            if (typeof value === "object" && value !== null && !Array.isArray(value)) {
                Object.assign(acc, flattenObject(value as Record<string, unknown>, pre + k));
            } else {
                acc[pre + k] = value;
            }
            return acc;
        }, {});
    }

    function processJSON(text: string) {
        try {
            const parsed = JSON.parse(text);
            const dataArray = Array.isArray(parsed)
                ? (parsed as Record<string, unknown>[])
                : [parsed as Record<string, unknown>];

            const shouldFlatten = flattenCheck?.checked;
            currentData = shouldFlatten ? dataArray.map((item) => flattenObject(item)) : dataArray;

            updateUI(true);
        } catch (e) {
            updateUI(false);
        }
    }

    function updateUI(valid: boolean) {
        if (statusDot) statusDot.className = `status-dot ${valid ? "active" : ""}`;
        if (statusLabel)
            statusLabel.textContent = valid
                ? `JSON Válido (${currentData.length} entradas)`
                : "JSON Inválido";

        if (valid && currentData.length > 0) {
            if (previewSection) previewSection.style.display = "block";
            if (downloadBtn) downloadBtn.style.display = "flex";
            if (copyBtn) copyBtn.style.display = "flex";
            if (visuals) visuals.style.display = "none";
            renderPreview();
        } else {
            if (previewSection) previewSection.style.display = "none";
            if (downloadBtn) downloadBtn.style.display = "none";
            if (copyBtn) copyBtn.style.display = "none";
            if (visuals) visuals.style.display = "flex";
        }
    }

    function renderPreview() {
        if (!previewTable || currentData.length === 0) return;

        const headers = Object.keys(currentData[0]);
        const rows = currentData.slice(0, 5);

        let html = `<thead><tr>${headers.map((h) => `<th>${h}</th>`).join("")}</tr></thead>`;
        html += `<tbody>${rows.map((row) => `<tr>${headers.map((h) => `<td>${row[h] !== undefined ? row[h] : ""}</td>`).join("")}</tr>`).join("")}</tbody>`;

        previewTable.innerHTML = html;
    }

    function generateCSV(): string {
        if (currentData.length === 0) return "";
        const headers = Object.keys(currentData[0]);
        const csvRows: string[] = [];

        csvRows.push(headers.map((h) => `"${h.replace(/"/g, '""')}"`).join(","));

        for (const row of currentData) {
            const values = headers.map((header) => {
                const val =
                    row[header] === null || row[header] === undefined ? "" : String(row[header]);
                return `"${val.replace(/"/g, '""')}"`;
            });
            csvRows.push(values.join(","));
        }

        return "\uFEFF" + csvRows.join("\n");
    }

    inputArea?.addEventListener("input", (e) =>
        processJSON((e.target as HTMLTextAreaElement).value)
    );

    flattenCheck?.addEventListener("change", () => {
        if (inputArea?.value) processJSON(inputArea.value);
    });

    downloadBtn?.addEventListener("click", () => {
        const csv = generateCSV();
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const link = document.createElement("a");
        const url = URL.createObjectURL(blob);
        link.setAttribute("href", url);
        link.setAttribute("download", `datos_json_${new Date().getTime()}.csv`);
        link.style.visibility = "hidden";
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    });

    copyBtn?.addEventListener("click", () => {
        const csv = generateCSV();
        navigator.clipboard.writeText(csv);
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = "¡Copiado!";
        setTimeout(() => {
            if (copyBtn) copyBtn.innerHTML = original;
        }, 2000);
    });

    if (dropZone) {
        dropZone.addEventListener("dragover", (e) => {
            e.preventDefault();
            dropZone.classList.add("dragover");
        });

        dropZone.addEventListener("dragleave", () => {
            dropZone.classList.remove("dragover");
        });

        dropZone.addEventListener("drop", (e) => {
            e.preventDefault();
            dropZone.classList.remove("dragover");
            const file = e.dataTransfer?.files[0];
            if (file && file.type === "application/json") {
                const reader = new FileReader();
                reader.onload = (rev) => {
                    const text = rev.target?.result as string;
                    if (inputArea) {
                        inputArea.value = text;
                        processJSON(text);
                    }
                };
                reader.readAsText(file);
            }
        });
    }

    updateDesk();

    function updateDesk() {
        if (inputArea?.value) processJSON(inputArea.value);
    }
</script>
