---
import "./BrewRatioCalculator.css";
import { Icon } from "astro-icon/components";
---

<div class="brew-calculator">
    <div class="brew-card">
        <div class="brew-card-header"></div>
        <div class="brew-card-body">

            <div class="brew-mode-switcher">
                <button class="brew-mode-btn active" id="modeCoffee" type="button">
                    <span class="brew-mode-icon"><Icon name="mdi:coffee" /></span>
                    <span>Tengo el Cafe</span>
                    <span class="brew-mode-hint">Dime cuanta agua</span>
                </button>
                <button class="brew-mode-btn" id="modeWater" type="button">
                    <span class="brew-mode-icon"><Icon name="mdi:water-outline" /></span>
                    <span>Tengo el Agua</span>
                    <span class="brew-mode-hint">Dime cuanto cafe moler</span>
                </button>
            </div>

            <div class="brew-grid">
                <div>
                    <div class="brew-section-label">
                        <span class="brew-label-icon" id="inputIconCoffee"><Icon name="mdi:coffee" /></span>
                        <span class="brew-label-icon brew-hidden" id="inputIconWater"><Icon name="mdi:water-outline" /></span>
                        <span id="inputLabel">Gramos de cafe que tienes</span>
                    </div>
                    <div class="brew-input-group">
                        <input
                            type="number"
                            id="brewInput"
                            class="brew-input"
                            value="20"
                            min="1"
                            step="1"
                        />
                        <span class="brew-input-unit" id="inputUnit">g</span>
                    </div>

                    <div style="margin-top:1.5rem">
                        <div class="brew-section-label">
                            <Icon name="mdi:tune-variant" />
                            Intensidad del cafe
                        </div>
                        <div class="brew-intensity-grid">
                            <button class="brew-intensity-btn" data-ratio-min="12" data-ratio-max="14" data-ratio-mid="13" type="button">
                                <span class="brew-ratio-label">1:12-14</span>
                                <span class="brew-intensity-name">Fuerte</span>
                            </button>
                            <button class="brew-intensity-btn active" data-ratio-min="15" data-ratio-max="16" data-ratio-mid="15.5" type="button">
                                <span class="brew-ratio-label">1:15-16</span>
                                <span class="brew-intensity-name">Equilibrado</span>
                            </button>
                            <button class="brew-intensity-btn" data-ratio-min="17" data-ratio-max="18" data-ratio-mid="17.5" type="button">
                                <span class="brew-ratio-label">1:17-18</span>
                                <span class="brew-intensity-name">Suave</span>
                            </button>
                            <button class="brew-intensity-btn" id="customRatioBtn" data-ratio-mid="0" type="button">
                                <span class="brew-ratio-label">1:??</span>
                                <span class="brew-intensity-name">Custom</span>
                            </button>
                        </div>
                        <div class="brew-custom-ratio" id="customRatioInputs">
                            <div>
                                <span class="brew-custom-label">Cafe</span>
                                <input type="number" id="customCoffee" class="brew-custom-input" value="1" min="1" step="0.5" />
                            </div>
                            <div class="brew-custom-sep">:</div>
                            <div>
                                <span class="brew-custom-label">Agua</span>
                                <input type="number" id="customWater" class="brew-custom-input" value="15" min="1" step="0.5" />
                            </div>
                        </div>
                    </div>

                    <label class="brew-ice-toggle" id="iceToggleWrapper">
                        <span class="brew-ice-label">
                            <Icon name="mdi:snowflake" />
                            Modo Iced Coffee
                        </span>
                        <div class="brew-toggle">
                            <input type="checkbox" id="iceToggle" />
                            <span class="brew-toggle-slider"></span>
                        </div>
                    </label>
                </div>

                <div>
                    <div class="brew-section-label">
                        <Icon name="mdi:bullseye-arrow" />
                        Tu receta exacta
                    </div>
                    <div class="brew-results-panel">
                        <div class="brew-results-header">
                            <span class="brew-results-title">Resultado</span>
                            <span class="brew-ratio-badge" id="ratioBadge">1:15.5</span>
                        </div>

                        <div class="brew-result-item">
                            <div class="brew-result-left">
                                <div class="brew-result-icon brew-icon-coffee">
                                    <Icon name="mdi:coffee" />
                                </div>
                                <div>
                                    <div class="brew-result-name">Cafe</div>
                                    <div class="brew-result-sub">Molido fino-medio</div>
                                </div>
                            </div>
                            <div class="brew-result-value" id="outCoffee">20<span>g</span></div>
                        </div>

                        <div class="brew-result-item" id="hotWaterRow">
                            <div class="brew-result-left">
                                <div class="brew-result-icon brew-icon-water">
                                    <Icon name="mdi:water-outline" />
                                </div>
                                <div>
                                    <div class="brew-result-name" id="hotWaterLabel">Agua caliente</div>
                                    <div class="brew-result-sub">90-96 &deg;C</div>
                                </div>
                            </div>
                            <div class="brew-result-value" id="outWater">310<span>ml</span></div>
                        </div>

                        <div class="brew-result-item" id="iceRow" style="display:none">
                            <div class="brew-result-left">
                                <div class="brew-result-icon brew-icon-ice">
                                    <Icon name="mdi:snowflake" />
                                </div>
                                <div>
                                    <div class="brew-result-name">Hielo</div>
                                    <div class="brew-result-sub">En la jarra</div>
                                </div>
                            </div>
                            <div class="brew-result-value" id="outIce">0<span>g</span></div>
                        </div>

                        <div class="brew-result-item" style="background:var(--brew-result);border-color:var(--brew-result-border)">
                            <div class="brew-result-left">
                                <div class="brew-result-icon brew-icon-cup">
                                    <Icon name="mdi:cup-outline" />
                                </div>
                                <div>
                                    <div class="brew-result-name">En tu taza</div>
                                    <div class="brew-result-sub">El cafe retiene ~2ml/g</div>
                                </div>
                            </div>
                            <div class="brew-result-value" style="color:var(--brew-accent)" id="outCup">278<span>ml</span></div>
                        </div>
                    </div>

                    <div id="cupWarning" class="brew-cup-warning"></div>

                    <div class="brew-phases" id="phasesSection">
                        <div class="brew-phases-title">
                            <Icon name="mdi:play-circle-outline" />
                            Guia de vertido
                        </div>
                        <div class="brew-phase-list" id="phaseList"></div>
                    </div>
                </div>
            </div>

            <div class="brew-favorites-section">
                <div class="brew-fav-header">
                    <span class="brew-fav-title">
                        <Icon name="mdi:star-outline" />
                        Mis recetas favoritas
                    </span>
                    <button class="brew-save-btn" id="saveRecipeBtn" type="button">
                        + Guardar esta receta
                    </button>
                </div>
                <div id="favList" class="brew-fav-list">
                    <div class="brew-fav-empty" id="favEmpty">
                        Aun no tienes recetas guardadas. Configura tu brew perfecto y guardalo.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="brew-modal-overlay" id="saveModal">
    <div class="brew-modal">
        <div class="brew-modal-title">Nombra tu receta</div>
        <input
            type="text"
            id="recipeNameInput"
            class="brew-modal-input"
            placeholder='Ej: "V60 Mananero"'
            maxlength="40"
        />
        <div class="brew-modal-actions">
            <button class="brew-modal-cancel" id="cancelSaveBtn" type="button">Cancelar</button>
            <button class="brew-modal-confirm" id="confirmSaveBtn" type="button">Guardar</button>
        </div>
    </div>
</div>

<script>
    type BrewMode = "coffee" | "water";

    interface BrewState {
        mode: BrewMode;
        inputValue: number;
        ratio: number;
        iceMode: boolean;
    }

    interface SavedRecipe {
        id: string;
        name: string;
        mode: BrewMode;
        inputValue: number;
        ratio: number;
        iceMode: boolean;
    }

    const RETENTION_ML_PER_G = 2;
    const ICE_RATIO = 0.4;
    const BLOOM_RATIO = 2;
    const BLOOM_WAIT_SECONDS = 30;
    const STORAGE_KEY = "brew-recipes-v1";

    const state: BrewState = {
        mode: "coffee",
        inputValue: 20,
        ratio: 15.5,
        iceMode: false,
    };

    function loadRecipes(): SavedRecipe[] {
        try {
            return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]");
        } catch {
            return [];
        }
    }

    function saveRecipes(recipes: SavedRecipe[]) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(recipes));
    }

    function computeBrewResult(s: BrewState) {
        let coffeeG: number;
        let totalWaterMl: number;

        if (s.mode === "coffee") {
            coffeeG = s.inputValue;
            totalWaterMl = Math.round(coffeeG * s.ratio);
        } else {
            totalWaterMl = s.inputValue;
            coffeeG = Math.round((totalWaterMl / s.ratio) * 10) / 10;
        }

        const hotWaterMl = s.iceMode
            ? Math.round(totalWaterMl * (1 - ICE_RATIO))
            : totalWaterMl;
        const iceMl = s.iceMode ? Math.round(totalWaterMl * ICE_RATIO) : 0;
        const retainedMl = Math.round(coffeeG * RETENTION_ML_PER_G);
        const inCupMl = s.iceMode
            ? Math.round(hotWaterMl - retainedMl + iceMl * 0.9)
            : hotWaterMl - retainedMl;

        const bloomMl = Math.round(coffeeG * BLOOM_RATIO);
        const remainMl = hotWaterMl - bloomMl;

        return { coffeeG, totalWaterMl, hotWaterMl, iceMl, inCupMl, bloomMl, remainMl };
    }

    function renderPhases(bloomMl: number, remainMl: number, hotWaterMl: number, iceMode: boolean) {
        const list = document.getElementById("phaseList");
        if (!list) return;

        const phases: { text: string }[] = [
            {
                text: `<strong>Bloom:</strong> Vierte <strong>${bloomMl} ml</strong> de agua en espiral. Espera <strong>${BLOOM_WAIT_SECONDS} segundos</strong> para desgasificar el cafe.`,
            },
            {
                text: `<strong>Vertido final:</strong> Agrega el resto hasta completar <strong>${hotWaterMl} ml</strong> en ${Math.ceil(remainMl / 50)} vertidos pausados.`,
            },
        ];

        if (iceMode) {
            phases.push({
                text: `<strong>Iced:</strong> Vierte el cafe caliente directamente sobre los <strong>${Math.round(hotWaterMl * ICE_RATIO)} g</strong> de hielo en la jarra.`,
            });
        }

        list.innerHTML = phases
            .map(
                (p, i) => `
            <div class="brew-phase-item">
                <div class="brew-phase-number">${i + 1}</div>
                <div class="brew-phase-text">${p.text}</div>
            </div>`
            )
            .join("");
    }

    function renderFavorites() {
        const recipes = loadRecipes();
        const listEl = document.getElementById("favList");
        const emptyEl = document.getElementById("favEmpty");
        if (!listEl || !emptyEl) return;

        const existingItems = listEl.querySelectorAll(".brew-fav-item");
        existingItems.forEach((el) => el.remove());

        if (recipes.length === 0) {
            emptyEl.style.display = "block";
            return;
        }

        emptyEl.style.display = "none";

        recipes.forEach((r) => {
            const item = document.createElement("div");
            item.className = "brew-fav-item";
            item.dataset.id = r.id;

            const modeLabel = r.mode === "coffee" ? `${r.inputValue}g cafe` : `${r.inputValue}ml agua`;
            const iceLabel = r.iceMode ? " - Iced" : "";

            item.innerHTML = `
                <span class="brew-fav-icon-dot"></span>
                <div class="brew-fav-info">
                    <div class="brew-fav-name">${r.name}</div>
                    <div class="brew-fav-meta">1:${r.ratio} &middot; ${modeLabel}${iceLabel}</div>
                </div>
                <button class="brew-fav-delete" data-id="${r.id}" type="button" title="Eliminar">&times;</button>
            `;

            item.addEventListener("click", (e) => {
                const target = e.target as HTMLElement;
                if (target.classList.contains("brew-fav-delete")) return;
                loadRecipeIntoState(r);
            });

            item.querySelector(".brew-fav-delete")?.addEventListener("click", () => {
                deleteRecipe(r.id);
            });

            listEl.appendChild(item);
        });
    }

    function loadRecipeIntoState(r: SavedRecipe) {
        state.mode = r.mode;
        state.inputValue = r.inputValue;
        state.ratio = r.ratio;
        state.iceMode = r.iceMode;
        syncUIToState();
        render();
    }

    function syncUIToState() {
        const brewInput = document.getElementById("brewInput") as HTMLInputElement;
        const iceToggle = document.getElementById("iceToggle") as HTMLInputElement;
        const inputLabel = document.getElementById("inputLabel");
        const inputUnit = document.getElementById("inputUnit");
        const inputIconCoffee = document.getElementById("inputIconCoffee");
        const inputIconWater = document.getElementById("inputIconWater");
        const modeCoffeeBtn = document.getElementById("modeCoffee");
        const modeWaterBtn = document.getElementById("modeWater");

        if (brewInput) brewInput.value = String(state.inputValue);
        if (iceToggle) iceToggle.checked = state.iceMode;

        const isCoffee = state.mode === "coffee";
        modeCoffeeBtn?.classList.toggle("active", isCoffee);
        modeWaterBtn?.classList.toggle("active", !isCoffee);

        if (inputLabel) inputLabel.textContent = isCoffee ? "Gramos de cafe que tienes" : "Capacidad de tu taza (ml)";
        if (inputUnit) inputUnit.textContent = isCoffee ? "g" : "ml";
        if (inputIconCoffee) inputIconCoffee.classList.toggle("brew-hidden", !isCoffee);
        if (inputIconWater) inputIconWater.classList.toggle("brew-hidden", isCoffee);

        document.querySelectorAll(".brew-intensity-btn").forEach((btn) => {
            const mid = parseFloat((btn as HTMLElement).dataset.ratioMid ?? "0");
            btn.classList.toggle("active", mid === state.ratio && btn.id !== "customRatioBtn");
        });

        const customBtn = document.getElementById("customRatioBtn");
        const isCustomActive = !document.querySelector(".brew-intensity-btn.active:not(#customRatioBtn)") || state.ratio === 0;

        if (isCustomActive) {
            customBtn?.classList.add("active");
            document.getElementById("customRatioInputs")?.classList.add("visible");
        } else {
            customBtn?.classList.remove("active");
            document.getElementById("customRatioInputs")?.classList.remove("visible");
        }
    }

    function deleteRecipe(id: string) {
        const recipes = loadRecipes().filter((r) => r.id !== id);
        saveRecipes(recipes);
        renderFavorites();
    }

    function render() {
        const res = computeBrewResult(state);

        const outCoffee = document.getElementById("outCoffee");
        const outWater = document.getElementById("outWater");
        const outIce = document.getElementById("outIce");
        const outCup = document.getElementById("outCup");
        const ratioBadge = document.getElementById("ratioBadge");
        const iceRow = document.getElementById("iceRow");
        const hotWaterLabel = document.getElementById("hotWaterLabel");
        const cupWarning = document.getElementById("cupWarning");

        if (outCoffee) outCoffee.innerHTML = `${res.coffeeG % 1 === 0 ? res.coffeeG : res.coffeeG.toFixed(1)}<span>g</span>`;
        if (outWater) outWater.innerHTML = `${res.hotWaterMl}<span>ml</span>`;
        if (outIce) outIce.innerHTML = `${res.iceMl}<span>g</span>`;
        if (outCup) outCup.innerHTML = `${res.inCupMl}<span>ml</span>`;
        if (ratioBadge) ratioBadge.textContent = `1:${state.ratio % 1 === 0 ? state.ratio : state.ratio.toFixed(1)}`;

        if (iceRow) iceRow.style.display = state.iceMode ? "flex" : "none";
        if (hotWaterLabel) hotWaterLabel.textContent = state.iceMode ? "Agua caliente (60%)" : "Agua caliente";

        if (cupWarning) {
            if (state.mode === "water" && res.inCupMl < state.inputValue * 0.6) {
                cupWarning.textContent = `La taza recibe solo ${res.inCupMl} ml. El cafe retiene liquido.`;
                cupWarning.classList.add("visible");
            } else {
                cupWarning.classList.remove("visible");
            }
        }

        renderPhases(res.bloomMl, res.remainMl, res.hotWaterMl, state.iceMode);
    }

    function init() {
        const brewInput = document.getElementById("brewInput") as HTMLInputElement;
        const modeCoffeeBtn = document.getElementById("modeCoffee");
        const modeWaterBtn = document.getElementById("modeWater");
        const iceToggle = document.getElementById("iceToggle") as HTMLInputElement;
        const intensityBtns = document.querySelectorAll(".brew-intensity-btn");
        const customRatioBtn = document.getElementById("customRatioBtn");
        const customRatioInputs = document.getElementById("customRatioInputs");
        const customCoffeeInput = document.getElementById("customCoffee") as HTMLInputElement;
        const customWaterInput = document.getElementById("customWater") as HTMLInputElement;
        const saveRecipeBtn = document.getElementById("saveRecipeBtn");
        const cancelSaveBtn = document.getElementById("cancelSaveBtn");
        const confirmSaveBtn = document.getElementById("confirmSaveBtn");
        const saveModal = document.getElementById("saveModal");
        const recipeNameInput = document.getElementById("recipeNameInput") as HTMLInputElement;

        brewInput?.addEventListener("input", () => {
            state.inputValue = parseFloat(brewInput.value) || 1;
            render();
        });

        modeCoffeeBtn?.addEventListener("click", () => {
            state.mode = "coffee";
            state.inputValue = 20;
            syncUIToState();
            render();
        });

        modeWaterBtn?.addEventListener("click", () => {
            state.mode = "water";
            state.inputValue = 300;
            syncUIToState();
            render();
        });

        iceToggle?.addEventListener("change", () => {
            state.iceMode = iceToggle.checked;
            render();
        });

        intensityBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                if (btn.id === "customRatioBtn") {
                    intensityBtns.forEach((b) => b.classList.remove("active"));
                    btn.classList.add("active");
                    customRatioInputs?.classList.add("visible");
                    const c = parseFloat(customCoffeeInput?.value ?? "1") || 1;
                    const w = parseFloat(customWaterInput?.value ?? "15") || 15;
                    state.ratio = Math.round((w / c) * 10) / 10;
                    render();
                    return;
                }

                intensityBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");
                customRatioInputs?.classList.remove("visible");
                customRatioBtn?.classList.remove("active");

                const mid = parseFloat((btn as HTMLElement).dataset.ratioMid ?? "15.5");
                state.ratio = mid;
                render();
            });
        });

        function updateCustomRatio() {
            const c = parseFloat(customCoffeeInput?.value ?? "1") || 1;
            const w = parseFloat(customWaterInput?.value ?? "15") || 15;
            state.ratio = Math.round((w / c) * 10) / 10;
            render();
        }

        customCoffeeInput?.addEventListener("input", updateCustomRatio);
        customWaterInput?.addEventListener("input", updateCustomRatio);

        saveRecipeBtn?.addEventListener("click", () => {
            if (recipeNameInput) recipeNameInput.value = "";
            saveModal?.classList.add("visible");
            recipeNameInput?.focus();
        });

        cancelSaveBtn?.addEventListener("click", () => {
            saveModal?.classList.remove("visible");
        });

        saveModal?.addEventListener("click", (e) => {
            if (e.target === saveModal) saveModal.classList.remove("visible");
        });

        confirmSaveBtn?.addEventListener("click", () => {
            const name = recipeNameInput?.value.trim();
            if (!name) return;

            const recipe: SavedRecipe = {
                id: Date.now().toString(),
                name,
                mode: state.mode,
                inputValue: state.inputValue,
                ratio: state.ratio,
                iceMode: state.iceMode,
            };

            const recipes = loadRecipes();
            recipes.unshift(recipe);
            saveRecipes(recipes);
            renderFavorites();
            saveModal?.classList.remove("visible");
        });

        recipeNameInput?.addEventListener("keydown", (e) => {
            if (e.key === "Enter") confirmSaveBtn?.click();
            if (e.key === "Escape") saveModal?.classList.remove("visible");
        });

        render();
        renderFavorites();
    }

    init();
</script>
