---
import "./SailAreaCalculator.css";
---

<div id="sail-area-calculator-root" class="sail-area-calculator">
    <div class="calculator-wrapper" id="calculator-capture-area">
        <div class="main-controls">
            <div class="section-group">
                <h3><iconify-icon icon="mdi:sailing-boat"></iconify-icon> Casco y Configuración</h3>
                <div class="compact-grid">
                    <div class="input-row">
                        <label for="displacement">Masa Total</label>
                        <div class="input-with-unit">
                            <input
                                type="number"
                                id="displacement"
                                class="elegant-input"
                                placeholder="8500"
                            />
                            <div class="unit-tag">
                                <select
                                    id="disp-unit"
                                    style="background:transparent; border:none; appearance:none; font-weight:900; cursor:pointer;"
                                >
                                    <option value="kg">KG</option>
                                    <option value="lbs">LBS</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="input-row">
                        <label for="rig-type">Sistema Vélico</label>
                        <select id="rig-type" class="elegant-input">
                            <option value="sloop">Sloop</option>
                            <option value="cutter">Cúter</option>
                            <option value="ketch">Ketch / Yawl</option>
                        </select>
                    </div>
                    <div class="input-row">
                        <label for="boat-type">Uso Previsto</label>
                        <select id="boat-type" class="elegant-input">
                            <option value="cruiser">Crucero</option>
                            <option value="performance">Performance</option>
                            <option value="racer">Regata</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="section-group">
                <h3><iconify-icon icon="mdi:ruler-square"></iconify-icon> Geometría del Aparejo</h3>
                <div class="compact-grid">
                    <div class="input-row">
                        <label>P (Mástil Mayor)</label>
                        <div class="input-with-unit">
                            <input
                                type="number"
                                id="val-p"
                                class="elegant-input"
                                placeholder="12.5"
                            />
                            <div class="unit-tag">
                                <select
                                    class="len-unit"
                                    data-for="val-p"
                                    style="background:transparent; border:none; appearance:none; font-weight:900; cursor:pointer;"
                                >
                                    <option value="m">M</option>
                                    <option value="ft">FT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="input-row">
                        <label>E (Botavara Mayor)</label>
                        <div class="input-with-unit">
                            <input
                                type="number"
                                id="val-e"
                                class="elegant-input"
                                placeholder="4.2"
                            />
                            <div class="unit-tag">
                                <select
                                    class="len-unit"
                                    data-for="val-e"
                                    style="background:transparent; border:none; appearance:none; font-weight:900; cursor:pointer;"
                                >
                                    <option value="m">M</option>
                                    <option value="ft">FT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="input-row">
                        <label>I (Altura Proa)</label>
                        <div class="input-with-unit">
                            <input
                                type="number"
                                id="val-i"
                                class="elegant-input"
                                placeholder="14.0"
                            />
                            <div class="unit-tag">
                                <select
                                    class="len-unit"
                                    data-for="val-i"
                                    style="background:transparent; border:none; appearance:none; font-weight:900; cursor:pointer;"
                                >
                                    <option value="m">M</option>
                                    <option value="ft">FT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="input-row">
                        <label>J (Base Proa)</label>
                        <div class="input-with-unit">
                            <input
                                type="number"
                                id="val-j"
                                class="elegant-input"
                                placeholder="4.5"
                            />
                            <div class="unit-tag">
                                <select
                                    class="len-unit"
                                    data-for="val-j"
                                    style="background:transparent; border:none; appearance:none; font-weight:900; cursor:pointer;"
                                >
                                    <option value="m">M</option>
                                    <option value="ft">FT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div
                    id="mizzen-row"
                    style="display: none; margin-top: 1.5rem;"
                    class="compact-grid"
                >
                    <div class="input-row">
                        <label>Py (Altura Mesana)</label>
                        <div class="input-with-unit">
                            <input
                                type="number"
                                id="val-py"
                                class="elegant-input"
                                placeholder="8.5"
                            />
                            <div class="unit-tag">
                                <select
                                    class="len-unit"
                                    data-for="val-py"
                                    style="background:transparent; border:none; appearance:none; font-weight:900; cursor:pointer;"
                                >
                                    <option value="m">M</option>
                                    <option value="ft">FT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="input-row">
                        <label>Ey (Base Mesana)</label>
                        <div class="input-with-unit">
                            <input
                                type="number"
                                id="val-ey"
                                class="elegant-input"
                                placeholder="3.0"
                            />
                            <div class="unit-tag">
                                <select
                                    class="len-unit"
                                    data-for="val-ey"
                                    style="background:transparent; border:none; appearance:none; font-weight:900; cursor:pointer;"
                                >
                                    <option value="m">M</option>
                                    <option value="ft">FT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section-group">
                <h3><iconify-icon icon="mdi:sails"></iconify-icon> Configuración de Velas</h3>
                <div class="slider-box">
                    <div class="slider-header">
                        <label for="genoa-overlap">Solape de Génova (LP/J)</label>
                        <span id="overlap-val" class="percentage-badge">130%</span>
                    </div>
                    <div class="slider-wrapper">
                        <input
                            type="range"
                            id="genoa-overlap"
                            class="modern-slider"
                            min="100"
                            max="155"
                            value="130"
                            step="1"
                        />
                        <div class="slider-ticks">
                            <span>100% (Foque)</span>
                            <span>155% (Génova G.)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <aside class="sidebar-results">
            <span class="sad-label">Ratio Estimado SA/D</span>
            <span id="sad-ratio-val" class="sad-value-large">0.0</span>
            <div class="gauge-track">
                <div id="gauge-marker-el" class="gauge-indicator" style="left: 0%"></div>
            </div>
            <div class="verdict-box">
                <h4 id="verdict-title-el">-</h4>
                <p id="verdict-text-el">Introduce las dimensiones del aparejo...</p>
            </div>
            <div class="stats-summary">
                <div class="stat-item">
                    <span>Área Vélica</span>
                    <span id="total-area-el">0.0 m²</span>
                </div>
                <div class="stat-item">
                    <span>Rendimiento</span>
                    <span id="power-indicator-el">-</span>
                </div>
            </div>
            <button id="btn-export-pdf-premium" class="export-btn-premium ignore-capture">
                <iconify-icon icon="mdi:file-pdf-box" width="22"></iconify-icon>
                GENERAR INFORME TÉCNICO
            </button>
        </aside>
    </div>
</div>

<script>
    import jsPDF from "jspdf";
    import html2canvas from "html2canvas";

    const rigType = document.getElementById("rig-type") as HTMLSelectElement;
    const displacement = document.getElementById("displacement") as HTMLInputElement;
    const dispUnit = document.getElementById("disp-unit") as HTMLSelectElement;
    const valP = document.getElementById("val-p") as HTMLInputElement;
    const valE = document.getElementById("val-e") as HTMLInputElement;
    const valI = document.getElementById("val-i") as HTMLInputElement;
    const valJ = document.getElementById("val-j") as HTMLInputElement;
    const valPy = document.getElementById("val-py") as HTMLInputElement;
    const valEy = document.getElementById("val-ey") as HTMLInputElement;
    const genoaOverlap = document.getElementById("genoa-overlap") as HTMLInputElement;
    const overlapLabel = document.getElementById("overlap-val") as HTMLElement;
    const totalAreaDisplay = document.getElementById("total-area-el") as HTMLElement;
    const sadRatioDisplay = document.getElementById("sad-ratio-val") as HTMLElement;
    const verdictTitle = document.getElementById("verdict-title-el") as HTMLElement;
    const verdictText = document.getElementById("verdict-text-el") as HTMLElement;
    const gaugeMarker = document.getElementById("gauge-marker-el") as HTMLElement;
    const powerIndicator = document.getElementById("power-indicator-el") as HTMLElement;
    const mizzenRow = document.getElementById("mizzen-row") as HTMLElement;
    const lenUnits = document.querySelectorAll(".len-unit") as NodeListOf<HTMLSelectElement>;

    function getValInM(id: string): number {
        const el = document.getElementById(id) as HTMLInputElement;
        const unitEl = document.querySelector(`.len-unit[data-for="${id}"]`) as HTMLSelectElement;
        const val = parseFloat(el.value) || 0;
        return unitEl.value === "ft" ? val * 0.3048 : val;
    }

    function calculate() {
        const p = getValInM("val-p");
        const e = getValInM("val-e");
        const i = getValInM("val-i");
        const j = getValInM("val-j");
        const py = getValInM("val-py");
        const ey = getValInM("val-ey");
        const overlap = (parseFloat(genoaOverlap.value) || 100) / 100;
        let dispKg = parseFloat(displacement.value) || 0;
        if (dispUnit.value === "lbs") dispKg *= 0.453592;

        const mainA = 0.5 * p * e;
        const genoaA = 0.5 * i * j * overlap;
        let totalA = mainA + genoaA;
        if (rigType.value === "ketch") totalA += 0.5 * py * ey;
        if (rigType.value === "cutter") totalA += 0.5 * i * j * 0.4;

        totalAreaDisplay.textContent = `${totalA.toFixed(1)} m²`;
        const areaSqFt = totalA * 10.7639;
        const dispLbs = dispKg * 2.20462;
        if (dispLbs > 100 && areaSqFt > 1) {
            const sad = areaSqFt / Math.pow(dispLbs / 64, 2 / 3);
            sadRatioDisplay.textContent = sad.toFixed(1);
            updateUI(sad);
        }
    }

    function updateUI(sad: number) {
        let title = "Desplazamiento Pesado";
        let text = "Diseño robusto ideal para seguridad oceánica y travesías.";
        let power = "Moderada";
        const gaugePos = Math.min(100, Math.max(0, (sad - 10) * 4));
        if (sad > 16.5) {
            title = "Crucero Estándar";
            text = "Equilibrio ideal para la mayoría de navegantes de recreo.";
            power = "Óptima";
        }
        if (sad > 20) {
            title = "Performance Cruiser";
            text = "Barcos rápidos que requieren manejo activo de escotas.";
            power = "Alta";
        }
        if (sad > 25) {
            title = "Regata / Sport";
            text = "Máxima agilidad. Respuesta inmediata y potencial de planeo.";
            power = "Extrema";
        }
        verdictTitle.textContent = title;
        verdictText.textContent = text;
        powerIndicator.textContent = power;
        gaugeMarker.style.left = `${gaugePos}%`;
    }

    [rigType, displacement, dispUnit, valP, valE, valI, valJ, valPy, valEy, genoaOverlap].forEach(
        (el) => {
            el.addEventListener("input", () => {
                mizzenRow.style.display = rigType.value === "ketch" ? "grid" : "none";
                overlapLabel.textContent = `${genoaOverlap.value}%`;
                calculate();
                saveToLocal();
            });
        }
    );

    lenUnits.forEach((u) =>
        u.addEventListener("change", () => {
            calculate();
            saveToLocal();
        })
    );

    function saveToLocal() {
        const data = {
            rig: rigType.value,
            disp: displacement.value,
            dispU: dispUnit.value,
            p: valP.value,
            e: valE.value,
            i: valI.value,
            j: valJ.value,
            py: valPy.value,
            ey: valEy.value,
            overlap: genoaOverlap.value,
            lenUnits: Array.from(lenUnits).map((u) => ({
                id: u.getAttribute("data-for"),
                val: u.value,
            })),
        };
        localStorage.setItem("sail_calc_data", JSON.stringify(data));
    }

    function loadFromLocal() {
        const raw = localStorage.getItem("sail_calc_data");
        if (!raw) {
            calculate();
            return;
        }
        try {
            const data = JSON.parse(raw);
            rigType.value = data.rig || "sloop";
            displacement.value = data.disp || "";
            dispUnit.value = data.dispU || "kg";
            valP.value = data.p || "";
            valE.value = data.e || "";
            valI.value = data.i || "";
            valJ.value = data.j || "";
            valPy.value = data.py || "";
            valEy.value = data.ey || "";
            genoaOverlap.value = data.overlap || "130";
            overlapLabel.textContent = `${genoaOverlap.value}%`;

            if (data.lenUnits) {
                data.lenUnits.forEach((u: any) => {
                    const el = document.querySelector(
                        `.len-unit[data-for="${u.id}"]`
                    ) as HTMLSelectElement;
                    if (el) el.value = u.val;
                });
            }

            mizzenRow.style.display = rigType.value === "ketch" ? "grid" : "none";
            calculate();
        } catch (e) {}
    }

    document.getElementById("btn-export-pdf-premium")?.addEventListener("click", async () => {
        const element = document.getElementById("calculator-capture-area");
        if (!element) return;

        try {
            const canvas = await html2canvas(element, {
                scale: 2,
                useCORS: true,
                backgroundColor: "#ffffff",
                ignoreElements: (el) => el.classList.contains("ignore-capture"),
                onclone: (clonedDoc) => {
                    const clonedEl = clonedDoc.getElementById("calculator-capture-area");
                    if (!clonedEl) return;

                    clonedEl.innerHTML = `
            <div style="padding: 40px; color: #333; max-width: 800px; margin: 0 auto;">
              <div style="border-bottom: 3px solid #003b73; padding-bottom: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end;">
                <div>
                  <h1 style="margin: 0; color: #003b73; font-size: 28px; text-transform: uppercase;">Informe Técnico de Superficie Vélica</h1>
                  <p style="margin: 5px 0 0; color: #666; font-size: 14px;">Generado por jjlmoya.es • ${new Date().toLocaleDateString()}</p>
                </div>
                <div style="text-align: right;">
                  <span style="font-size: 12px; font-weight: bold; color: #003b73;">VERSIÓN PROFESIONAL</span>
                </div>
              </div>

              <div style="margin-bottom: 40px; background: #f9f9f9; padding: 25px; border-radius: 8px;">
                <h2 style="margin: 0 0 20px 0; font-size: 18px; border-bottom: 1px solid #ddd; padding-bottom: 10px; color: #003b73;">Resumen de Resultados</h2>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                  <div style="text-align: center; border-right: 1px solid #ddd;">
                    <span style="display: block; font-size: 12px; text-transform: uppercase; color: #666; margin-bottom: 5px;">Ratio SA/D Estimado</span>
                    <span style="font-size: 48px; font-weight: bold; color: #003b73;">${sadRatioDisplay.textContent}</span>
                    <div style="margin-top: 10px; font-weight: bold; color: #ef4135; font-size: 14px;">${verdictTitle.textContent}</div>
                  </div>
                  <div style="text-align: center;">
                    <span style="display: block; font-size: 12px; text-transform: uppercase; color: #666; margin-bottom: 5px;">Superficie Vélica Total</span>
                    <span style="font-size: 48px; font-weight: bold; color: #003b73;">${totalAreaDisplay.textContent}</span>
                    <div style="margin-top: 10px; color: #666; font-size: 14px;">Rendimiento: <strong>${powerIndicator.textContent}</strong></div>
                  </div>
                </div>
              </div>

              <h2 style="font-size: 16px; text-transform: uppercase; color: #003b73; margin-bottom: 15px;">Especificaciones Técnicas</h2>
              <table style="width: 100%; border-collapse: collapse; margin-bottom: 30px;">
                <thead>
                  <tr style="background: #003b73; color: white;">
                    <th style="padding: 10px; text-align: left; font-size: 12px; border: 1px solid #003b73;">Parámetro</th>
                    <th style="padding: 10px; text-align: left; font-size: 12px; border: 1px solid #003b73;">Valor Introducido</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">Tipo de Aparejo</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${rigType.options[rigType.selectedIndex].text}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">Desplazamiento</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${displacement.value} ${dispUnit.value}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">P (Mástil Mayor)</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${valP.value} ${(document.querySelector('.len-unit[data-for="val-p"]') as HTMLSelectElement).value}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">E (Botavara Mayor)</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${valE.value} ${(document.querySelector('.len-unit[data-for="val-e"]') as HTMLSelectElement).value}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">I (Altura de Triángulo de Proa)</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${valI.value} ${(document.querySelector('.len-unit[data-for="val-i"]') as HTMLSelectElement).value}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">J (Base de Triángulo de Proa)</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${valJ.value} ${(document.querySelector('.len-unit[data-for="val-j"]') as HTMLSelectElement).value}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">Porcentaje de Solape Génova</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${genoaOverlap.value}%</td>
                  </tr>
                  ${
                      rigType.value === "ketch"
                          ? `
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">Py (Altura Mesana)</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${valPy.value} ${(document.querySelector('.len-unit[data-for="val-py"]') as HTMLSelectElement).value}</td>
                  </tr>
                  <tr>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px;">Ey (Base Mesana)</td>
                    <td style="padding: 10px; border: 1px solid #ddd; font-size: 13px; font-weight: bold;">${valEy.value} ${(document.querySelector('.len-unit[data-for="val-ey"]') as HTMLSelectElement).value}</td>
                  </tr>
                  `
                          : ""
                  }
                </tbody>
              </table>

              <div style="background: #eef2f6; padding: 20px; border-radius: 8px; font-size: 12px; color: #444; border-left: 4px solid #003b73;">
                <strong>Nota Técnica:</strong> El ratio SA/D (Sail Area/Displacement) es un indicador del rendimiento potencial del barco. Valores por encima de 20 indican barcos de altas prestaciones, mientras que valores por debajo de 16 suelen corresponder a veleros de crucero pesado especializados en navegación oceánica.
              </div>

              <div style="margin-top: 40px; text-align: center; border-top: 1px solid #eee; padding-top: 20px;">
                <p style="font-size: 10px; color: #999;">Documento generado automáticamente por el calculador de jjlmoya.es. Los datos son orientativos y deben ser verificados por un profesional.</p>
              </div>
            </div>
          `;
                },
            });
            const imgData = canvas.toDataURL("image/png");
            const imgWidth = 595.28;
            const imgHeight = (canvas.height * imgWidth) / canvas.width;
            const pdf = new jsPDF("p", "pt", "a4");
            pdf.addImage(imgData, "PNG", 0, 0, imgWidth, imgHeight);
            pdf.save(`informe-superficie-velica-${new Date().getTime()}.pdf`);
        } catch (err) {
            console.error(err);
        }
    });

    loadFromLocal();
</script>
