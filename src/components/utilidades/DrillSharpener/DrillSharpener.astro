---
import './DrillSharpener.css';
import { Icon } from 'astro-icon/components';
---

<div class="drill-sharpener" id="drill-app">
    <div class="drill-layout">
        <section class="gauge-area">
            <svg class="gauge-svg" viewBox="0 0 500 500" id="gauge-container">
                <line x1="250" y1="20" x2="250" y2="480" stroke="#1e293b" stroke-width="2" stroke-dasharray="10,10" />
                <line x1="20" y1="250" x2="480" y2="250" stroke="#1e293b" stroke-width="1" stroke-dasharray="10,10" />

                <rect x="249" y="250" width="2" height="230" fill="#1e293b" rx="1" />

                <g class="guide-circles" fill="none" stroke="#1e293b" stroke-width="1">
                    <circle cx="250" cy="250" r="30" data-val="3" />
                    <circle cx="250" cy="250" r="60" data-val="6" />
                    <circle cx="250" cy="250" r="100" data-val="10" />
                    <circle cx="250" cy="250" r="130" data-val="13" />
                    <circle cx="250" cy="250" r="200" data-val="20" />
                </g>

                <g id="precision-gauge" class="precision-line">
                    <line id="gl" x1="250" y1="250" x2="50" y2="100" stroke="#38bdf8" stroke-width="3" stroke-linecap="round" />
                    <line id="gr" x1="250" y1="250" x2="450" y2="100" stroke="#38bdf8" stroke-width="3" stroke-linecap="round" />
                    <circle cx="250" cy="250" r="6" fill="#0ea5e9" />
                </g>
                
                <text x="250" y="235" text-anchor="middle" fill="#38bdf8" font-size="28" font-weight="900" id="svg-angle-text">118°</text>
            </svg>

            <div class="gauge-instruction">
                <span>APOYA EL EJE EN LA LÍNEA VERTICAL</span>
            </div>
        </section>

        <aside class="drill-controls">
            <div class="control-group">
                <h4>Material del trabajo</h4>
                <div class="material-strip">
                    <button class="mat-btn active" data-angle="118" data-vc="25" data-label="Acero / Hierro">Acero</button>
                    <button class="mat-btn" data-angle="135" data-vc="12" data-label="Inoxidable">Inox</button>
                    <button class="mat-btn" data-angle="140" data-vc="8" data-label="Aceros Duros">Duros</button>
                    <button class="mat-btn" data-angle="90" data-vc="40" data-label="Latón / Cobre">Latón</button>
                    <button class="mat-btn" data-angle="60" data-vc="60" data-label="Plásticos">Plástico</button>
                    <button class="mat-btn" data-angle="80" data-vc="35" data-label="Madera">Madera</button>
                </div>
            </div>

            <div class="control-group">
                <h4>Diámetro de broca (mm)</h4>
                <div class="stepper-ui">
                    <button type="button" class="step-b" id="rem-d">-</button>
                    <input type="number" id="diam-val" value="10" step="0.5" min="1" max="50">
                    <button type="button" class="step-b" id="add-d">+</button>
                </div>
                
                <div style="margin-top: 1.5rem;" class="live-results">
                    <div class="res-box">
                        <span class="res-l">Velocidad</span>
                        <div>
                            <span class="res-v" id="rpm-out">796</span>
                            <span class="res-unit">RPM</span>
                        </div>
                    </div>
                    <div class="res-box">
                        <span class="res-l">Corte</span>
                        <div>
                            <span class="res-v" id="cool-out" style="font-size: 0.8rem; color: #38bdf8;">TALADRINA</span>
                        </div>
                    </div>
                </div>
            </div>

            <button class="diag-btn" id="trigger-diag" title="Si la broca no corta, pulsa aquí">
                <Icon name="mdi:wrench" /> ¿No corta bien? Diagnóstico
            </button>
        </aside>
    </div>

    <div class="diag-modal" id="expert-modal">
        <div class="modal-header">
            <h3>Diagnóstico de Fallos</h3>
            <div class="modal-close" id="close-expert"><Icon name="mdi:close" style="font-size: 1.5rem;" /></div>
        </div>

        <div class="diag-item">
            <strong>1. Saca humo y no atraviesa</strong>
            <p>Falta **Ángulo de Incidencia**. El metal detrás del filo roza la pieza. Rebaja la parte trasera para que el labio sea lo más alto.</p>
            <div class="diag-img">
                <svg viewBox="0 0 160 60" width="100%">
                    <path d="M10,45 L40,15 L70,45 Z" fill="none" stroke="#ef4444" stroke-width="2" />
                    <line x1="40" y1="15" x2="70" y2="15" stroke="#ef444430" stroke-width="1" stroke-dasharray="3,3" />
                    <path d="M90,45 L120,15 L150,25 L150,45 Z" fill="none" stroke="#22c55e" stroke-width="2" />
                    <line x1="120" y1="15" x2="150" y2="15" stroke="#22c55e30" stroke-width="1" stroke-dasharray="3,3" />
                    <text x="10" y="58" fill="#ef4444" font-size="7">MAL: Plano</text>
                    <text x="90" y="58" fill="#22c55e" font-size="7">OK: Destalonado</text>
                </svg>
            </div>
        </div>

        <div class="diag-item">
            <strong>2. Agujero excéntrico o mayor</strong>
            <p>La **Punta no está centrada**. Los labios tienen longitudes diferentes. Asegura que la punta toque el centro exacto de la galga.</p>
        </div>

        <div class="diag-item">
            <strong>3. Filos quemados (Azules)</strong>
            <p>Velocidad excesiva. Revisa el cálculo de RPM de la herramienta para este diámetro y material.</p>
        </div>
    </div>
</div>

<script>
    const state = {
        angle: 118,
        vc: 25,
        diam: 10,
        material: "Acero / Hierro"
    };

    const ui = {
        gaugeL: document.getElementById('gl'),
        gaugeR: document.getElementById('gr'),
        angleHud: document.getElementById('svg-angle-text'),
        rpmOut: document.getElementById('rpm-out'),
        coolOut: document.getElementById('cool-out'),
        inputD: document.getElementById('diam-val') as HTMLInputElement,
        btnR: document.getElementById('rem-d'),
        btnA: document.getElementById('add-d'),
        diagTrigger: document.getElementById('trigger-diag'),
        modal: document.getElementById('expert-modal'),
        modalClose: document.getElementById('close-expert')
    };

    function refresh() {
        if (!ui.gaugeL || !ui.gaugeR || !ui.angleHud) return;

        const halfRad = (state.angle / 2) * (Math.PI / 180);
        const length = 250; 

        const lx2 = 250 - Math.sin(halfRad) * length;
        const ly2 = 250 + Math.cos(halfRad) * length;
        const rx2 = 250 + Math.sin(halfRad) * length;
        const ry2 = 250 + Math.cos(halfRad) * length;

        ui.gaugeL.setAttribute('x2', lx2.toString());
        ui.gaugeL.setAttribute('y2', ly2.toString());
        ui.gaugeR.setAttribute('x2', rx2.toString());
        ui.gaugeR.setAttribute('y2', ry2.toString());
        ui.angleHud.textContent = `${state.angle}°`;

        const circles = document.querySelectorAll('.guide-circle');
        circles.forEach(c => c.classList.remove('active'));
        
        const allCircles = document.querySelectorAll('.guide-circles circle');
        let closest = allCircles[0];
        let minDiff = 1000;
        allCircles.forEach(c => {
            const val = parseFloat(c.getAttribute('data-val') || '0');
            const diff = Math.abs(val - state.diam);
            if (diff < minDiff) {
                minDiff = diff;
                closest = c;
            }
        });
        if (minDiff < 5) closest.classList.add('active');

        const rpm = Math.round((state.vc * 1000) / (Math.PI * (state.diam || 1)));
        if (ui.rpmOut) ui.rpmOut.textContent = rpm.toLocaleString();

        if (ui.coolOut) {
            if (state.angle >= 135) ui.coolOut.textContent = "ACEITE CORTE";
            else if (state.angle <= 70) ui.coolOut.textContent = "AIRE / AGUA";
            else ui.coolOut.textContent = "TALADRINA";
        }
    }

    document.querySelectorAll('.mat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.mat-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            state.angle = parseInt(btn.getAttribute('data-angle') || '118');
            state.vc = parseInt(btn.getAttribute('data-vc') || '25');
            state.material = btn.getAttribute('data-label') || '';
            refresh();
        });
    });

    ui.inputD?.addEventListener('input', (e) => {
        state.diam = parseFloat((e.target as HTMLInputElement).value) || 1;
        refresh();
    });

    ui.btnR?.addEventListener('click', () => {
        const v = Math.max(1, parseFloat(ui.inputD.value) - 0.5);
        ui.inputD.value = v.toString();
        state.diam = v;
        refresh();
    });

    ui.btnA?.addEventListener('click', () => {
        const v = Math.min(50, parseFloat(ui.inputD.value) + 0.5);
        ui.inputD.value = v.toString();
        state.diam = v;
        refresh();
    });

    ui.diagTrigger?.addEventListener('click', () => ui.modal?.classList.add('active'));
    ui.modalClose?.addEventListener('click', () => ui.modal?.classList.remove('active'));

    refresh();
</script>
