---
import { Icon } from "astro-icon/components";
import "./EarlyRetirementCalculator.css";
---

<div class="unified-planning-desk">
    <header class="desk-header">
        <div class="input-pill">
            <span class="pill-label">Nacimiento (Año)</span>
            <input
                type="number"
                id="birth-year"
                class="pill-input"
                value="1975"
                min="1950"
                max="2010"
            />
        </div>
        <div class="input-pill">
            <span class="pill-label">Años Cotizados</span>
            <input
                type="number"
                id="current-contributions"
                class="pill-input"
                value="30"
                min="0"
                max="50"
            />
        </div>
        <div class="input-pill" style="text-align: right;">
            <span class="pill-label">Base Mensual Bruta</span>
            <div style="display: flex; justify-content: flex-end; align-items: baseline; gap: 4px;">
                <input
                    type="number"
                    id="base-pension"
                    class="pill-input"
                    value="2500"
                    style="text-align: right; width: 100px;"
                />
                <span style="font-weight: 900; color: var(--ret-deep); opacity: 0.5;">€</span>
            </div>
        </div>
    </header>

    <div class="desk-body">
        <nav class="desk-sidebar">
            <button class="strategy-nav-btn" data-mode="legal">
                <span class="btn-title">Ordinaria</span>
                <span class="btn-desc">Edad legal sin recortes. 100% de la base.</span>
            </button>
            <button class="strategy-nav-btn active" data-mode="voluntaria">
                <span class="btn-title">Anticipada Voluntaria</span>
                <span class="btn-desc">Adelanto por decisión propia. Recorte mensual.</span>
            </button>
            <button class="strategy-nav-btn" data-mode="involuntaria">
                <span class="btn-title">Involuntaria / ERE</span>
                <span class="btn-desc">Cese forzoso. Coeficientes más suaves.</span>
            </button>
        </nav>

        <main class="desk-main">
            <div class="main-result-hero">
                <div class="metric-group">
                    <span class="pill-label">Edad de Jubilación</span>
                    <div class="metric-large" id="val-age-main">65<span>AÑOS</span></div>
                </div>
                <div class="metric-group" style="text-align: right;">
                    <span class="pill-label">Fecha Prevista</span>
                    <div class="stat-val" id="val-date" style="font-size: 2.5rem;">2040</div>
                </div>
            </div>

            <div class="slider-unit">
                <input
                    type="range"
                    id="age-slider"
                    class="modern-range"
                    min="61"
                    max="70"
                    step="1"
                    value="65"
                />
                <div class="node-grid">
                    <span class="node-year">61</span>
                    <span class="node-year">63</span>
                    <span class="node-year">65</span>
                    <span class="node-year">67</span>
                    <span class="node-year">70</span>
                </div>
            </div>

            <div class="desk-stats-footer">
                <div class="stat-box">
                    <span class="pill-label">Pensión Estimada</span>
                    <div class="stat-val" id="val-pension">1.975,00 €</div>
                </div>
                <div class="stat-box" style="text-align: right;">
                    <span class="pill-label">Reducción Permanente</span>
                    <div class="stat-val stat-accent" id="val-penalty">-21.0%</div>
                </div>
            </div>
        </main>
    </div>

    <footer class="desk-advice-bar">
        <Icon name="mdi:lightbulb-variant-outline" size={24} color="white" />
        <span id="val-advice">Mueve el deslizador para proyectar tu carrera de jubilación.</span>
    </footer>
</div>

<script>
    const birthIn = document.getElementById("birth-year") as HTMLInputElement | null;
    const curContIn = document.getElementById("current-contributions") as HTMLInputElement | null;
    const baseIn = document.getElementById("base-pension") as HTMLInputElement | null;
    const ageSlider = document.getElementById("age-slider") as HTMLInputElement | null;
    const navBtns = document.querySelectorAll(".strategy-nav-btn");

    const ageOut = document.getElementById("val-age-main");
    const penaltyOut = document.getElementById("val-penalty");
    const dateOut = document.getElementById("val-date");
    const pensionOut = document.getElementById("val-pension");
    const adviceOut = document.getElementById("val-advice");

    let currentMode = "voluntaria";

    function updateDesk() {
        if (!birthIn || !curContIn || !baseIn || !ageSlider) return;

        const birthYear = parseInt(birthIn.value);
        const curCont = parseFloat(curContIn.value) || 0;
        const base = parseFloat(baseIn.value) || 0;
        const selectedAge = parseInt(ageSlider.value);

        const today = new Date().getFullYear();
        const currentAge = today - birthYear;
        const yearsToRetirement = selectedAge - currentAge;
        const totalContributed = curCont + Math.max(0, yearsToRetirement);

        const legalOrdinaria = totalContributed >= 38.5 ? 65 : 67;

        let penalty = 0;
        const diff = legalOrdinaria - selectedAge;

        if (selectedAge < legalOrdinaria) {
            if (currentMode === "legal") {
                penalty = 0;
            } else if (currentMode === "voluntaria") {
                if (diff > 2) {
                    penalty = 21;
                } else {
                    if (totalContributed < 38.5) penalty = diff * 7.5;
                    else if (totalContributed < 41.5) penalty = diff * 6.5;
                    else if (totalContributed < 44.5) penalty = diff * 6;
                    else penalty = diff * 5;
                }
            } else if (currentMode === "involuntaria") {
                if (diff > 4) {
                    penalty = 30;
                } else {
                    if (totalContributed < 38.5) penalty = diff * 6;
                    else if (totalContributed < 41.5) penalty = diff * 5.5;
                    else if (totalContributed < 44.5) penalty = diff * 5;
                    else penalty = diff * 4.5;
                }
            }
        } else if (selectedAge > legalOrdinaria) {
            penalty = -(selectedAge - legalOrdinaria) * 4;
        }

        const finalPension = base * (1 - penalty / 100);

        if (ageOut) ageOut.innerHTML = `${selectedAge}<span>AÑOS</span>`;
        if (penaltyOut) {
            if (penalty > 0) {
                penaltyOut.textContent = `-${penalty.toFixed(1)}%`;
                penaltyOut.style.color = "var(--ret-gold)";
            } else if (penalty < 0) {
                penaltyOut.textContent = `+${Math.abs(penalty).toFixed(1)}%`;
                penaltyOut.style.color = "var(--ret-emerald)";
            } else {
                penaltyOut.textContent = "0.0%";
                penaltyOut.style.color = "var(--ret-deep)";
            }
        }
        if (dateOut) dateOut.textContent = (birthYear + selectedAge).toString();
        if (pensionOut)
            pensionOut.textContent = new Intl.NumberFormat("es-ES", {
                style: "currency",
                currency: "EUR",
            }).format(finalPension);

        if (adviceOut) {
            if (penalty > 0) {
                const gain = (base * 0.05).toFixed(0);
                adviceOut.innerHTML = `Si retrasas tu retiro hasta los <strong>${selectedAge + 1} años</strong>, ganarías aproximadamente <strong>${gain}€ extras</strong> al mes.`;
            } else if (penalty < 0) {
                adviceOut.textContent =
                    "Estás capitalizando una bonificación por demora. Tu pensión será superior al 100%.";
            } else {
                adviceOut.textContent =
                    "Has alcanzado la edad ordinaria óptima con el 100% de tu prestación.";
            }
        }
    }

    [birthIn, curContIn, baseIn, ageSlider].forEach((el) => {
        if (el) el.addEventListener("input", updateDesk);
    });

    navBtns.forEach((btn) => {
        if (btn)
            btn.addEventListener("click", () => {
                navBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");
                currentMode = btn.getAttribute("data-mode") || "voluntaria";

                if (currentMode === "legal" && ageSlider) {
                    ageSlider.value = "67";
                } else if (currentMode === "involuntaria" && ageSlider) {
                    ageSlider.value = "63";
                } else if (currentMode === "voluntaria" && ageSlider) {
                    ageSlider.value = "65";
                }

                updateDesk();
            });
    });

    updateDesk();
</script>
