---
import { Icon } from "astro-icon/components";
import CardUtility from "./CardUtility.astro";
import type { UtilityItem } from "../../data/utilities";
import "./UtilitySection.css";

interface Props {
    title: string;
    slug: string;
    icon: string;
    utilities: UtilityItem[];
}

const { title, slug, icon, utilities } = Astro.props;

const categoryUrl = `/utilidades/categorias/${slug}/`;
---

<section data-utility-section data-section-title={title}>
    <a href={categoryUrl} class="utility-section-link">
        <h2 class="utility-section-title">
            <span class="utility-section-icon-container">
                <Icon name={icon} class="utility-section-icon" />
            </span>
            {title}
        </h2>
    </a>
    <div class="utility-cards-grid">
        {utilities.map((u) => <CardUtility {...u} />)}
    </div>
</section>
