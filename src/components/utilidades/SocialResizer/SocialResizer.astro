---
import { Icon } from "astro-icon/components";
import "./SocialResizer.css";

const presets = [
    {
        id: "ig-square",
        name: "Instagram Square",
        size: "1080x1080",
        width: 1080,
        height: 1080,
        platform: "Instagram",
        icon: "mdi:instagram",
    },
    {
        id: "ig-portrait",
        name: "Instagram Portrait",
        size: "1080x1350",
        width: 1080,
        height: 1350,
        platform: "Instagram",
        icon: "mdi:instagram",
    },
    {
        id: "ig-story",
        name: "Stories / TikTok",
        size: "1080x1920",
        width: 1080,
        height: 1920,
        platform: "Instagram",
        icon: "mdi:cellphone",
    },
    {
        id: "yt-thumb",
        name: "YouTube Thumb",
        size: "1280x720",
        width: 1280,
        height: 720,
        platform: "YouTube",
        icon: "mdi:youtube",
    },
    {
        id: "yt-banner",
        name: "YouTube Banner",
        size: "2560x1440",
        width: 2560,
        height: 1440,
        platform: "YouTube",
        icon: "mdi:youtube-subscription",
    },
    {
        id: "x-post",
        name: "X / Twitter Post",
        size: "1200x675",
        width: 1200,
        height: 675,
        platform: "Twitter",
        icon: "mdi:twitter",
    },
    {
        id: "x-header",
        name: "X / Twitter Header",
        size: "1500x500",
        width: 1500,
        height: 500,
        platform: "Twitter",
        icon: "mdi:page-layout-header",
    },
    {
        id: "li-header",
        name: "LinkedIn Cover",
        size: "1584x396",
        width: 1584,
        height: 396,
        platform: "LinkedIn",
        icon: "mdi:linkedin",
    },
];
---

<div class="social-resizer-container">
    <aside class="resizer-sidebar">
        <div class="sidebar-section">
            <h3>
                <Icon name="mdi:responsive" />
                Formatos RRSS
            </h3>
            <div class="preset-grid">
                {
                    presets.map((p, index) => (
                        <button
                            class={`preset-btn ${index === 0 ? "active" : ""}`}
                            data-preset={JSON.stringify(p)}
                            id={`btn-${p.id}`}
                        >
                            <div class="preset-icon">
                                <Icon name={p.icon} />
                            </div>
                            <div class="preset-info">
                                <span class="preset-name">{p.name}</span>
                                <span class="preset-size">{p.size}</span>
                            </div>
                        </button>
                    ))
                }
            </div>
        </div>
    </aside>

    <main class="resizer-main">
        <div class="upload-zone" id="dropzone">
            <div class="upload-icon">
                <Icon name="mdi:cloud-upload-outline" />
            </div>
            <div class="upload-text">
                <h2>Cargar Imagen</h2>
                <p>Arrastra tu foto aquí o haz clic para explorar</p>
            </div>
            <input type="file" id="file-input" accept="image/*" hidden />
        </div>

        <div class="editor-view" id="editor-view">
            <div class="canvas-container" id="canvas-container">
                <canvas id="resizer-canvas"></canvas>
            </div>

            <div class="editor-actions">
                <div class="zoom-control">
                    <Icon name="mdi:magnify-minus-outline" />
                    <input type="range" id="zoom-range" min="10" max="300" value="100" />
                    <Icon name="mdi:magnify-plus-outline" />
                </div>

                <div class="btn-group">
                    <button class="action-btn" id="reset-btn">
                        <Icon name="mdi:refresh" />
                        Reiniciar
                    </button>
                    <button class="action-btn primary" id="download-btn">
                        <Icon name="mdi:download" />
                        Descargar Imagen
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    import { SocialResizer } from "./SocialResizer";

    let resizer: SocialResizer;
    const dropzone = document.getElementById("dropzone");
    const fileInput = document.getElementById("file-input") as HTMLInputElement;
    const editorView = document.getElementById("editor-view");
    const presetBtns = document.querySelectorAll(".preset-btn");
    const zoomRange = document.getElementById("zoom-range") as HTMLInputElement;
    const resetBtn = document.getElementById("reset-btn");
    const downloadBtn = document.getElementById("download-btn");

    function init() {
        resizer = new SocialResizer("resizer-canvas");

        dropzone?.addEventListener("click", () => fileInput?.click());

        fileInput?.addEventListener("change", (e: any) => {
            const file = e.target.files[0];
            if (file) handleFile(file);
        });

        dropzone?.addEventListener("dragover", (e) => {
            e.preventDefault();
            dropzone.classList.add("hover");
        });

        dropzone?.addEventListener("dragleave", () => {
            dropzone.classList.remove("hover");
        });

        dropzone?.addEventListener("drop", (e) => {
            e.preventDefault();
            const file = e.dataTransfer?.files[0];
            if (file) handleFile(file);
        });

        presetBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const preset = JSON.parse(btn.getAttribute("data-preset")!);

                presetBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                resizer.setPreset(preset);
                if (zoomRange) zoomRange.value = "100";
            });
        });

        zoomRange?.addEventListener("input", () => {
            resizer.setScale(parseInt(zoomRange.value) / 100);
        });

        resetBtn?.addEventListener("click", () => {
            const activeBtn = document.querySelector(".preset-btn.active");
            if (activeBtn) {
                const preset = JSON.parse(activeBtn.getAttribute("data-preset")!);
                resizer.setPreset(preset);
                if (zoomRange) zoomRange.value = "100";
            }
        });

        downloadBtn?.addEventListener("click", () => {
            resizer.download();
        });

        const firstPreset = JSON.parse(presetBtns[0].getAttribute("data-preset")!);
        resizer.setPreset(firstPreset);
    }

    async function handleFile(file: File) {
        if (!file.type.startsWith("image/")) return;

        await resizer.loadImage(file);

        dropzone?.style.setProperty("display", "none");
        editorView?.classList.add("active");
    }

    init();
</script>
