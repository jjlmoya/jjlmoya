---
import SEOArticle from "../../ui/seo/SEOArticle.astro";
import SEOTitle from "../../ui/seo/SEOTitle.astro";
import SEOList from "../../ui/seo/SEOList.astro";
import SEOTip from "../../ui/seo/SEOTip.astro";
import SEOTable from "../../ui/seo/SEOTable.astro";
import SEOSummary from "../../ui/seo/SEOSummary.astro";
import SEOComparative from "../../ui/seo/SEOComparative.astro";
import SEOStats from "../../ui/seo/SEOStats.astro";
import SEOProsCons from "../../ui/seo/SEOProsCons.astro";

const summaryItems = [
    "<strong>Compresión Superior:</strong> WebP logra archivos 25-40% más pequeños que PNG manteniendo calidad visual idéntica.",
    "<strong>Transparencias Preservadas:</strong> El WebP soporta canal alfa perfectamente, igual que PNG.",
    "<strong>Mejora SEO Directa:</strong> Archivos más ligeros = sitios más rápidos = mejor posicionamiento en Google.",
    "<strong>Privacidad 100% Local:</strong> Todo ocurre en tu navegador, sin servidores intermediarios.",
    "<strong>Conversión Masiva Instantánea:</strong> Procesa galerías completas en segundos sin latencia.",
];

const statsData = [
    { value: "40%", label: "Reducción de Peso", icon: "mdi:percent" },
    { value: "25-35%", label: "Compresión vs PNG", icon: "mdi:zip-box" },
    {
        value: "0.1s",
        label: "Velocidad Media",
        icon: "mdi:lightning-bolt",
        trend: { value: "Sin servidor", positive: true },
    },
    { value: "Sin Límites", label: "Cantidad de Archivos", icon: "mdi:folder-open" },
];

const comparativeItems = [
    {
        title: "PNG Original (Pesado)",
        description: "Formato antiguo sin optimización moderna.",
        icon: "mdi:image",
        pointIcon: "mdi:close",
        points: [
            "Archivos 40% más pesados",
            "Carga lenta en sitios web",
            "Penalización en Core Web Vitals",
            "Mayor consumo de ancho de banda",
        ],
    },
    {
        title: "WebP Optimizado (Moderno)",
        description: "Formato moderno recomendado por Google.",
        icon: "mdi:check-circle",
        highlight: true,
        points: [
            "Compresión inteligente sin pérdida percibida",
            "Carga ultra rápida (10-40% más veloz)",
            "Mejora directa de Google PageSpeed",
            "Ahorro de ancho de banda y costos",
        ],
    },
];

const prosConsItems = [
    {
        pro: "Archivos 25-40% más pequeños = sitios web más rápidos",
        con: "Algunos navegadores muy antiguos (IE11, Safari < 2020) no lo soportan",
    },
    {
        pro: "Soporte de transparencias igual que PNG",
        con: "Requiere servidor que sirva fallback PNG para navegadores antiguos",
    },
    {
        pro: "Recomendado directamente por Google y PageSpeed Insights",
        con: "CDN y sistemas legados pueden requerir configuración adicional",
    },
];

const resolutionHeaders = ["Tipo de Sitio", "Estrategia Recomendada", "Ventaja"];

const coreWebVitalsMetricas = [
    "<strong>LCP (Largest Contentful Paint):</strong> Velocidad de carga de la imagen más grande. WebP = más rápido.",
    "<strong>FID (First Input Delay):</strong> Tiempo para responder a clicks. Menos datos = mejor respuesta.",
    "<strong>CLS (Cumulative Layout Shift):</strong> Estabilidad visual. Archivos optimizados cargan sin saltos.",
];

const webpVentajasList = [
    "Imágenes 25-35% más pequeñas a igual calidad visual",
    "Soporte de animaciones tipo GIF pero optimizadas",
    "Canal alfa idéntico a PNG para transparencias",
    "Compresión inteligente que entiende la percepción visual humana",
    "Recomendado activamente por Google, Facebook, Netflix",
];

const remotePrivacyRisks = [
    "Subes tu imagen a un servidor desconocido",
    "El servidor procesa tu archivo",
    "Descargas el resultado",
    "¿Qué pasó con tu imagen original? ¿Se elimina? ¿Se guarda? ¿Se indexa?",
];

const localPrivacyBenefits = [
    "Tu navegador lee el PNG desde tu disco duro.",
    "Decodifica el contenido PNG a píxeles RGBA.",
    "Re-codifica esos píxeles usando el algoritmo VP8/VP9 de WebP.",
    "Genera el archivo WebP en memoria.",
    "Descarga el resultado directamente a tu carpeta.",
    "Ningún servidor intermediario. Ningún registro. Ningún riesgo.",
];

const useCasesList = [
    "<strong>Ecommerce:</strong> Tiendas online con miles de imágenes de producto. Convertir a WebP reduce costos de servidor en 30-40%.",
    "<strong>Sitios de Fotografía:</strong> Portfolios con galerías de alta resolución. WebP permite cargar más rápido sin perder detalle.",
    "<strong>Blogs Visualmente Intensos:</strong> Publicaciones con muchas imágenes. WebP mejora Google PageSpeed automáticamente.",
    "<strong>Aplicaciones Web:</strong> Aplicaciones que almacenan imágenes localmente. WebP consume menos espacio de almacenamiento.",
    "<strong>Campañas Publicitarias:</strong> Banners, anuncios, creatividades. WebP carga en móviles 40% más rápido.",
    "<strong>CDN y Distribución Global:</strong> Si sirves imágenes a nivel mundial, menos MB = costos de transferencia más bajos.",
];

const financialImpactList = [
    "<strong>PNG:</strong> 1,000,000 × 500KB = 500GB mensual.",
    "<strong>WebP:</strong> 1,000,000 × 300KB = 300GB mensual.",
    "<strong>Ahorro:</strong> 200GB. En AWS S3 = $4,600 mensuales ahorrados. Eso es $55,200 anuales.",
];

const techAnalysisList = [
    "<strong>PNG:</strong> Usa compresión DEFLATE (patentado LZ77). Luego, filtros de predicción por línea. Resultado: bueno pero no óptimo.",
    "<strong>WebP:</strong> Usa codificación por transformada (VP8/VP9), análisis de entropy, y predicción inteligente. Análisis visual del ojo humano.",
    "<strong>Resultado:</strong> WebP entiende qué detalles son visibles. Comprime más agresivamente donde el ojo no nota, preserva donde importa.",
];

const alternativesList = [
    "<strong>Convertidores Online:</strong> Rápidos pero requieren subir fotos a servidores remotos. Riesgo de privacidad.",
    "<strong>Software de Escritorio:</strong> Seguros pero requieren instalación. Más complejo para usuarios casuales.",
    "<strong>Nuestro Convertidor:</strong> Lo mejor de ambos mundos. Local, seguro, sin instalación, sin límites.",
];

const stepsList = [
    "<strong>1. Abre el Convertidor:</strong> Accede desde cualquier navegador moderno.",
    "<strong>2. Selecciona PNGs:</strong> Arrastra tus archivos PNG o usa el selector.",
    "<strong>3. Espera Conversión:</strong> En segundos verás el estado 'WebP Listo'.",
    "<strong>4. Descarga:</strong> Descarga individualmente o usa el botón .zip para múltiples.",
    "<strong>5. Implementa:</strong> Sube los WebP a tu servidor y actualiza tu HTML.",
];
---

<SEOArticle>
    <SEOTitle title="Convertidor PNG a WebP: Optimización SEO Profesional para tu Sitio Web" />

    <p>
        Google no juega. En 2021 introdujeron <strong>Core Web Vitals</strong> como factor de ranking
        directo. Los sitios rápidos suben. Los lentos caen. Y sabe qué es uno de los culpables silenciosos
        de la lentitud web? Imágenes PNG sin optimizar. Ahora bien: convertir todas tus imágenes a WebP
        individualmente es tedioso. Subirlas a convertidores en línea es arriesgado. ¿La solución? Nuestro
        convertidor PNG a WebP: local, instantáneo, privado.
    </p>

    <SEOSummary
        title="Por qué convertir PNG a WebP es tu mejor inversión en SEO"
        items={summaryItems}
    />

    <p>
        Imagina que gestionas un sitio de ecommerce con 2000+ imágenes de producto en PNG. Cada
        imagen ocupa 500KB. Son 1GB de activos. Cada visitante descarga eso. Tu servidor gime.
        Google registra tiempos de carga lentísimos. Tus clientes se van a la competencia. Es un
        problema real que afecta directamente a tus ingresos. La buena noticia: convertir a WebP
        puede reducir ese 1GB a 600MB sin pérdida visual. Es un 40% de ahorro. De forma instantánea.
    </p>

    <SEOTitle title="Core Web Vitals: Por qué Google ama los archivos pequeños" level={3} />
    <SEOStats stats={statsData} columns={4} />

    <p>Veamos los números. Google mide tres métricas clave en 2024:</p>

    <SEOList items={coreWebVitalsMetricas} />

    <p>Ahora bien: ¿cuál es la diferencia real entre PNG y WebP en Core Web Vitals?</p>

    <p>
        Una imagen PNG de 2MB en tu sitio: LCP = 3.5 segundos. Misma imagen en WebP (600KB): LCP =
        1.2 segundos. Esa diferencia de 2.3 segundos lo es TODO en SEO. Google tiene datos que
        muestran que cada segundo adicional reduce conversiones en 7%. Si tu sitio vende, esto es
        dinero directo.
    </p>

    <SEOTitle title="WebP vs PNG: Más que tamaño, es estrategia" level={3} />
    <p>
        El <strong>PNG (Portable Network Graphics)</strong> fue revolucionario en 1996. Compresión sin
        pérdida, transparencias, compatibilidad universal. Fue estándar durante 25 años. Pero es 2024.
        Las técnicas de compresión han evolucionado dramáticamente. El <strong>WebP</strong>,
        introducido por Google en 2010, usa algoritmos de nueva generación (VP8, VP9). El resultado:
    </p>

    <SEOList items={webpVentajasList} />

    <p>
        La pregunta no es "¿WebP es mejor que PNG?" (sí, objetivamente). La pregunta es "¿por qué
        todavía no estoy usando WebP?"
    </p>

    <SEOTitle title="La Estrategia Moderna: Progressive Enhancement" level={3} />
    <p>No es WebP o PNG. Es WebP Y PNG. Así es como funcionan los sitios profesionales en 2024:</p>

    <SEOComparative items={comparativeItems} />

    <p>
        Implementas una etiqueta HTML `&lt;picture&gt;` que dice: "Sírvele WebP a Chrome, Firefox,
        Edge. Sírvele PNG a Safari antiguo e IE11". El navegador elige automáticamente. Los usuarios
        modernos obtienen archivos ligeros. Los usuarios con navegadores antiguos obtienen
        compatibilidad. Win-win.
    </p>

    <SEOTitle title="¿Cómo Convertir tus PNG a WebP de Forma Segura?" level={3} />
    <p>
        Aquí es donde nuestro convertidor excella. Cuando conviertes PNG a WebP usando un servicio
        remoto:
    </p>

    <SEOList items={remotePrivacyRisks} />

    <p>No tienes forma de saberlo. Con nuestro convertidor local:</p>

    <SEOList items={localPrivacyBenefits} />

    <p>Es tan simple y tan seguro. Porque la privacidad no debería ser un lujo.</p>

    <SEOTitle title="Casos de Uso Reales: Cuándo Necesitas Convertir a WebP" level={3} />
    <p>Te presento escenarios donde la conversión PNG → WebP es no negociable:</p>

    <SEOList items={useCasesList} />

    <SEOTable headers={resolutionHeaders}>
        <tr>
            <td><strong>Blog Mediano (100 posts)</strong></td>
            <td>Convertir ~200 imágenes PNG a WebP</td>
            <td>Mejora LCP de 2.8s a 1.5s</td>
        </tr>
        <tr>
            <td><strong>Ecommerce (5000 productos)</strong></td>
            <td>Convertir lotes de 500+ imágenes simultáneamente</td>
            <td>Ahorro mensual de $500-2000 en ancho de banda</td>
        </tr>
        <tr>
            <td><strong>Galería de Fotografía</strong></td>
            <td>Convertir en tiempo real según necesidad</td>
            <td>Carga 40% más rápida sin calidad visible</td>
        </tr>
        <tr>
            <td><strong>SaaS (Aplicación Web)</strong></td>
            <td>Convertir activos visuales antes de deployment</td>
            <td>Menos datos = usuarios más rápidos = retención</td>
        </tr>
    </SEOTable>

    <SEOTip title="Consejo de Experto: Estrategia de Fallback">
        <p>
            Aquí viene el truco profesional: después de convertir tus PNG a WebP con nuestro
            convertidor, mantén ambas versiones. Actualiza tu HTML para servir WebP primero con PNG
            como fallback. Así: los navegadores modernos obtienen archivos optimizados. Los antiguos
            obtienen compatibilidad. Es la forma correcta de hacer modernización web sin abandonar
            usuarios.
        </p>
    </SEOTip>

    <SEOTitle title="Impacto Financiero: Números que No Puedes Ignorar" level={3} />
    <p>
        Permiteme mostrarte el lado económico. Si tu sitio sirve 1 millón de imágenes PNG por mes:
    </p>

    <SEOList items={financialImpactList} />

    <p>
        Y eso es solo almacenamiento. Agrégale transferencia de datos, CDN, mejor ranking SEO, más
        conversiones por velocidad mejorada... estamos hablando de ahorro/ganancia de 6 cifras en
        empresas medianas-grandes.
    </p>

    <SEOTitle title="Análisis Técnico: Cómo Funciona la Conversión PNG → WebP" level={3} />
    <p>Para entender por qué WebP es superior, necesitas saber cómo funciona:</p>

    <SEOList items={techAnalysisList} />

    <p>
        Es como la diferencia entre un compresor de ZIP estándar y un algoritmo que entiende que
        estás comprimiendo fotos. Uno es genérico. El otro está optimizado.
    </p>

    <SEOTitle title="Ventajas y Desventajas: Evaluación Honesta" level={3} />
    <SEOProsCons items={prosConsItems} title="Balance de Uso" />

    <SEOTitle title="Herramientas Alternas: Por qué Nosotros" level={3} />
    <p>Existen opciones para convertir PNG a WebP:</p>

    <SEOList items={alternativesList} />

    <SEOTitle title="Pasos: Convierte tus PNG a WebP Ahora" level={3} />
    <SEOList items={stepsList} />

    <SEOTitle title="Preguntas Frecuentes" level={3} />
    <p>
        <strong>¿Se perderá calidad al convertir PNG a WebP?</strong> No, en absoluto. WebP está específicamente
        diseñado para mantener igual o mejor calidad que PNG usando menos bytes.
    </p>

    <p>
        <strong>¿Qué pasa con las transparencias del PNG?</strong> Se preservan perfectamente. WebP soporta
        canal alfa idéntico a PNG.
    </p>

    <p>
        <strong>¿Cuántos archivos puedo convertir?</strong> Sin límite. Procesa 1 o 10,000. Solo limitado
        por la RAM de tu dispositivo.
    </p>

    <p>
        <strong>¿Mejorará mi SEO?</strong> Directamente sí. Archivos más pequeños = sitio más rápido
        = mejor LCP = mejor ranking Google.
    </p>

    <SEOTitle title="La Verdad: Este es el Futuro" level={3} />
    <p>
        WebP es el presente, no el futuro. Google ya sirve WebP a 90%+ de sus usuarios. Netflix usa
        WebP para todo. Facebook también. Los CDN lo recomiendan. Los navegadores lo soportan. Es
        hora de que tu sitio lo haga también.
    </p>

    <p>
        Convertir PNG a WebP no es opcional para sitios profesionales. Es obligatorio. Y la forma
        más segura, rápida y privada de hacerlo es con nuestro convertidor local.
    </p>

    <p>
        <strong>Optimiza tu sitio. Mejora tu SEO. Protege tu privacidad.</strong>
    </p>
</SEOArticle>
