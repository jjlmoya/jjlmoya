---
import { Icon } from "astro-icon/components";
import "./ResinCuringCalculator.css";

const resinTypes = [
  { id: "standard", label: "Estándar", factor: 1.0 },
  { id: "transparent", label: "Transparente", factor: 0.8 },
  { id: "opaque", label: "Opaca (Negra/Gris)", factor: 1.3 },
  { id: "tough", label: "Rígida / Tough", factor: 1.5 },
  { id: "flexible", label: "Flexible", factor: 2.2 },
  { id: "castable", label: "Calcinable", factor: 3.0 },
];

const brands = [
  { id: "generic", label: "Genérica", multi: 1.0, defaultPower: 40 },
  { id: "anycubic", label: "Anycubic", multi: 0.95, defaultPower: 40 },
  { id: "elegoo", label: "Elegoo", multi: 1.0, defaultPower: 40 },
  { id: "siraya", label: "Siraya Tech", multi: 1.2, defaultPower: 30 },
];
---

<div class="uv-app-card" id="resin-calc-root">
    <div class="uv-app-sidebar">
        <div class="uv-app-brand">
            <Icon name="mdi:printer-3d" size={24} />
            <span>Industrial Curing v1.1</span>
        </div>
        
        <div class="uv-app-inputs">
            <div class="uv-input-item">
                <label>Marca Maquinaria</label>
                <select id="input-brand" class="uv-app-select">
                    {brands.map(b => <option value={b.multi} data-power={b.defaultPower}>{b.label}</option>)}
                </select>
            </div>

            <div class="uv-input-item">
                <div class="uv-label-box">
                    <label>Potencia Lámpara (W)</label>
                    <span id="val-power">40W</span>
                </div>
                <input type="range" id="input-power" class="uv-app-range" min="6" max="100" value="40" />
            </div>

            <div class="uv-input-item">
                <div class="uv-label-box">
                    <label>Distancia LEDs (cm)</label>
                    <span id="val-dist">10cm</span>
                </div>
                <input type="range" id="input-dist" class="uv-app-range" min="2" max="30" value="10" />
            </div>

            <div class="uv-input-item">
                <label>Tipo de Material</label>
                <select id="input-type" class="uv-app-select">
                    {resinTypes.map(r => <option value={r.factor}>{r.label}</option>)}
                </select>
            </div>

            <div class="uv-input-item">
                <div class="uv-label-box">
                    <label>Peso Estimado (g)</label>
                    <span id="val-size">25g</span>
                </div>
                <input type="range" id="input-size" class="uv-app-range" min="1" max="500" value="25" />
            </div>

            <label class="uv-app-check">
                <input type="checkbox" id="input-ipa" />
                <span>¿Lavado con Alcohol Isopropílico?</span>
            </label>
        </div>

        <div class="uv-app-safety">
            <div class="safety-row" data-tooltip="La exposición directa a 405nm puede dañar la retina de forma permanente.">
                <Icon name="mdi:glasses" size={14} /> Gafas UV Certificadas
            </div>
            <div class="safety-row" data-tooltip="La resina semi-curada es altamente irritante. Usa siempre protección.">
                <Icon name="mdi:hand-back-left" size={14} /> Guantes de Nitrilo
            </div>
        </div>
    </div>

    <div class="uv-app-main">
        <div class="uv-top-stats">
            <div class="uv-stat-mini">
                <small>Longitud</small>
                <strong>405 nm</strong>
            </div>
            <div class="uv-stat-mini">
                <small>Estado</small>
                <strong id="stat-status">Estándar</strong>
            </div>
            <div class="uv-stat-mini">
                <small>Modo</small>
                <strong>Industrial</strong>
            </div>
        </div>

        <div class="uv-main-display">
            <div class="uv-timer-ring">
                <svg viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="44" class="ring-bg" />
                    <circle cx="50" cy="50" r="44" class="ring-fill" id="timer-ring" />
                </svg>
                <div class="uv-timer-text">
                    <span id="final-time">02:30</span>
                    <small>m:s</small>
                    <button id="start-btn" class="uv-app-btn" title="Iniciar/Detener Ciclo de Curado">
                        <Icon name="mdi:play" id="icon-play" size={20} />
                        <Icon name="mdi:stop" id="icon-stop" size={20} style="display:none" />
                    </button>
                </div>
            </div>

            <div class="uv-chart-small">
                <svg viewBox="0 0 100 60" id="power-chart" class="uv-svg-grid">
                    <line x1="0" y1="20" x2="100" y2="20" class="grid-line" />
                    <line x1="0" y1="40" x2="100" y2="40" class="grid-line" />
                    <line x1="25" y1="0" x2="25" y2="60" class="grid-line" />
                    <line x1="50" y1="0" x2="50" y2="60" class="grid-line" />
                    <line x1="75" y1="0" x2="75" y2="60" class="grid-line" />
                    
                    <path class="chart-area" id="chart-area" d="" />
                    <path class="chart-path" id="chart-path" d="" />
                    <circle class="chart-cursor" id="chart-dot" r="2.5" />
                </svg>
                <div class="chart-labels">
                    <span>Cerca (2cm)</span>
                    <span>Intensidad UV (Dosis)</span>
                    <span>Lejos (30cm)</span>
                </div>
                <div class="uv-chart-legend">
                    <div class="legend-item"><span class="line-dot"></span><span>Dosis Teórica</span></div>
                    <div class="legend-item"><span class="point-dot"></span><span>Tu Configuración</span></div>
                </div>
            </div>
        </div>

        <div class="uv-app-alerts" id="alerts-container">
            <div class="uv-alert-box warning" id="ipa-alert" style="display:none">
                <Icon name="mdi:clock-alert-outline" size={18} />
                <span>Evaporar alcohol (min. 10 min) para evitar manchas blancas.</span>
            </div>
            <div class="uv-alert-box info" id="dist-alert">
                <Icon name="mdi:shield-check-outline" size={18} />
                <span>Distancia segura detectada para curado uniforme.</span>
            </div>
        </div>
    </div>
</div>

<script>
    const powerIn = document.getElementById('input-power') as HTMLInputElement;
    const distIn = document.getElementById('input-dist') as HTMLInputElement;
    const massIn = document.getElementById('input-size') as HTMLInputElement;
    const typeIn = document.getElementById('input-type') as HTMLSelectElement;
    const brandIn = document.getElementById('input-brand') as HTMLSelectElement;
    const ipaIn = document.getElementById('input-ipa') as HTMLInputElement;

    const valPower = document.getElementById('val-power');
    const valDist = document.getElementById('val-dist');
    const valSize = document.getElementById('val-size');
    const statStatus = document.getElementById('stat-status');
    const finalTime = document.getElementById('final-time');
    const timerRing = document.getElementById('timer-ring') as SVGCircleElement | null;
    const ipaAlert = document.getElementById('ipa-alert');
    const distAlert = document.getElementById('dist-alert');
    const chartPath = document.getElementById('chart-path') as SVGPathElement | null;
    const chartDot = document.getElementById('chart-dot') as SVGCircleElement | null;
    const chartArea = document.getElementById('chart-area') as SVGPathElement | null;

    let audioCtx: AudioContext | null = null;

    function playBeep() {
        if (!audioCtx) audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.type = 'square';
        osc.frequency.setValueAtTime(880, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.5);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.5);
    }

    let countdownInterval: number | null = null;
    let secondsLeft = 0;
    let initialTotal = 0;

    function formatTime(total: number) {
        const min = Math.floor(total / 60);
        const sec = Math.floor(total % 60);
        return `${min.toString().padStart(2, '0')}:${sec.toString().padStart(2, '0')}`;
    }

    function updateRing(current: number, total: number) {
        if (!timerRing) return;
        const circum = 2 * Math.PI * 44;
        timerRing.style.strokeDasharray = circum.toString();
        const offset = circum - (circum * Math.min(100, (current / total) * 100)) / 100;
        timerRing.style.strokeDashoffset = offset.toString();
    }

    function calculate() {
        if (countdownInterval) return; 
        if (!powerIn || !distIn || !massIn || !typeIn || !brandIn) return;

        const W = parseFloat(powerIn.value);
        const D = parseFloat(distIn.value);
        const S = parseFloat(massIn.value);
        const T = parseFloat(typeIn.value);
        const B = parseFloat(brandIn.value);

        if (valPower) valPower.textContent = W + "W";
        if (valDist) valDist.textContent = D + "cm";
        if (valSize) valSize.textContent = S + "g";

        const baseTime = 120;
        const powerRef = 40;
        const distRef = 10;

        const pFactor = powerRef / W;
        const dFactor = Math.pow((D + 1) / (distRef + 1), 2);
        const sFactor = Math.sqrt(S / 25);
        
        let total = baseTime * T * B * sFactor * pFactor * dFactor;
        total = Math.max(15, Math.min(3600, total));
        initialTotal = total;
        secondsLeft = total;

        if (finalTime) finalTime.textContent = formatTime(total);
        updateRing(total, total); 

        if (statStatus) {
            statStatus.textContent = total > 300 ? "Largo" : total > 90 ? "Óptimo" : "Rápido";
            statStatus.style.color = total > 300 ? "#f97316" : "#fff";
        }

        if (ipaAlert) ipaAlert.style.display = ipaIn.checked ? "flex" : "none";
        if (distAlert) {
            const isNear = D < 6;
            distAlert.className = `uv-alert-box ${isNear ? 'warning' : 'info'}`;
            distAlert.querySelector('span')!.textContent = isNear 
                ? "Riesgo de deformación por calor (Distancia Crítica)." 
                : "Distancia segura detectada para curado uniforme.";
        }

        drawPowerChart(D, W);
    }

    const startBtn = document.getElementById('start-btn') as HTMLButtonElement | null;
    const iconPlay = document.getElementById('icon-play');
    const iconStop = document.getElementById('icon-stop');

    function drawPowerChart(d: number, w: number) {
        if (!chartPath || !chartDot || !chartArea) return;
        let dAttr = "M 0 60";
        for (let x = 0; x <= 100; x += 5) {
            const dist = (x / 100) * 30 + 1;
            const intensity = 60 - ((w / 2) / Math.pow(dist / 5, 2));
            const y = Math.max(2, Math.min(58, intensity));
            dAttr += ` L ${x} ${y}`;
        }
        chartPath.setAttribute("d", dAttr);
        chartArea.setAttribute("d", dAttr + " L 100 60 L 0 60 Z");

        const dotX = ((d - 1) / 30) * 100;
        const dotY = Math.max(2, Math.min(58, 60 - ((w / 2) / Math.pow(d / 5, 2))));
        chartDot.setAttribute("cx", dotX.toString());
        chartDot.setAttribute("cy", dotY.toString());
    }

    function startTimer() {
        if (countdownInterval) {
            clearInterval(countdownInterval);
            countdownInterval = null;
            if (startBtn) {
                startBtn.classList.remove('running');
                if (iconPlay) iconPlay.style.display = "block";
                if (iconStop) iconStop.style.display = "none";
            }
            calculate();
            return;
        }

        if (startBtn) {
            startBtn.classList.add('running');
            if (iconPlay) iconPlay.style.display = "none";
            if (iconStop) iconStop.style.display = "block";
        }

        countdownInterval = window.setInterval(() => {
            secondsLeft--;
            if (finalTime) finalTime.textContent = formatTime(secondsLeft);
            updateRing(secondsLeft, initialTotal);

            if (secondsLeft <= 0) {
                clearInterval(countdownInterval!);
                countdownInterval = null;
                if (startBtn) {
                    startBtn.classList.remove('running');
                    if (iconPlay) iconPlay.style.display = "block";
                    if (iconStop) iconStop.style.display = "none";
                }
                playBeep();
                setTimeout(() => {
                    calculate();
                }, 3000);
            }
        }, 1000);
    }

    startBtn?.addEventListener('click', startTimer);

    brandIn?.addEventListener('change', () => {
        const option = brandIn.options[brandIn.selectedIndex];
        const power = option.getAttribute('data-power');
        if (power && powerIn) {
            powerIn.value = power;
            calculate();
        }
    });

    [powerIn, distIn, massIn, typeIn, brandIn, ipaIn].forEach(el => {
        el?.addEventListener('input', calculate);
    });

    calculate();
</script>
