---
import "./SuitcaseChecklistGenerator.css";
import ChecklistForm from "./ChecklistForm.astro";
import ChecklistResults from "./ChecklistResults.astro";
---

<div class="vacation-checklist-container">
    <ChecklistForm />
    <ChecklistResults />
</div>

<script>
    const generateBtn = document.getElementById("generate-btn") as HTMLButtonElement | null;
    const checklistFormContainer = document.getElementById(
        "checklist-form-container"
    ) as HTMLDivElement | null;
    const resultsSection = document.getElementById("results-section") as HTMLDivElement | null;
    const printBtn = document.getElementById("print-btn") as HTMLButtonElement | null;
    const backBtn = document.getElementById("back-btn") as HTMLButtonElement | null;

    const numInput = document.getElementById("travel-days") as HTMLInputElement | null;
    const btnMinus = document.getElementById("btn-minus") as HTMLButtonElement | null;
    const btnPlus = document.getElementById("btn-plus") as HTMLButtonElement | null;
    const checkInt = document.getElementById("is-international") as HTMLInputElement | null;

    const qtyRopaInterior = document.getElementById("qty-ropa-interior");
    const qtyCamisetas = document.getElementById("qty-camisetas");
    const qtyPantalones = document.getElementById("qty-pantalones");
    const qtyCalcetines = document.getElementById("qty-calcetines");
    const itemInt = document.getElementById("item-internacional");
    const itemAdap = document.getElementById("item-adaptador");

    const tipsContainer = document.getElementById("tips-container");
    const tipsList = document.getElementById("tips-list");

    if (btnMinus && btnPlus && numInput) {
        btnMinus.addEventListener("click", () => {
            const val = parseInt(numInput.value || "1");
            if (val > parseInt(numInput.min)) numInput.value = (val - 1).toString();
        });
        btnPlus.addEventListener("click", () => {
            const val = parseInt(numInput.value || "1");
            if (val < parseInt(numInput.max)) numInput.value = (val + 1).toString();
        });
    }

    if (printBtn) {
        printBtn.addEventListener("click", () => {
            window.print();
        });
    }

    if (backBtn) {
        backBtn.addEventListener("click", () => {
            if (resultsSection) resultsSection.classList.add("hidden");
            if (checklistFormContainer) checklistFormContainer.classList.remove("hidden");
        });
    }

    function updateProgress() {
        const categoriesContainer = document.getElementById("categories-container");
        if (!categoriesContainer) return;

        const visibleCards = Array.from(
            categoriesContainer.querySelectorAll(".category-card")
        ).filter((card) => {
            return (card as HTMLElement).style.display !== "none";
        });

        let total = 0;
        let checked = 0;

        visibleCards.forEach((card) => {
            const lis = card.querySelectorAll("li");
            lis.forEach((li) => {
                if (li.style.display !== "none") {
                    const cb = li.querySelector("input[type='checkbox']") as HTMLInputElement;
                    if (cb) {
                        total++;
                        if (cb.checked) checked++;
                    }
                }
            });
        });

        const percentage = total === 0 ? 0 : Math.round((checked / total) * 100);

        const progressFill = document.getElementById("progress-fill");
        const progressText = document.getElementById("progress-text");

        if (progressFill) progressFill.style.width = `${percentage}%`;
        if (progressText) progressText.textContent = `${percentage}% Completado`;
    }

    document.querySelectorAll(".item-checkbox").forEach((cb) => {
        cb.addEventListener("change", updateProgress);
    });

    function getSelectedRadioValue(name: string): string {
        const radios = document.getElementsByName(name);
        for (let i = 0; i < radios.length; i++) {
            const rb = radios[i] as HTMLInputElement;
            if (rb.checked) return rb.value;
        }
        return "";
    }

    function calculateQuantity(days: number, baseType: string): string {
        const maxClothes = 14;

        if (baseType === "ropa_interior") {
            const amount = Math.min(days + 1, maxClothes);
            return `Ropa interior (${amount} mudas)`;
        }
        if (baseType === "camisetas") {
            const amount = Math.min(days, maxClothes);
            return `Camisetas / Partes arriba (${amount} ud.)`;
        }
        if (baseType === "pantalones") {
            const amount = Math.min(Math.ceil(days / 2) + 1, Math.round(maxClothes / 2));
            return `Pantalones / Partes abajo (${amount} ud.)`;
        }
        if (baseType === "calcetines") {
            const amount = Math.min(days + 1, maxClothes);
            return `Calcetines (${amount} pares)`;
        }
        return "";
    }

    function generateTips(days: number, isInt: boolean, dType: string): string[] {
        const tips = [];
        tips.push(
            "Enrollar la ropa estilo 'militar' ayuda muchísimo a combatir arrugas y ahorra espacio."
        );

        if (days > 7) {
            tips.push(
                "Vas para más de una semana. En lugar de llevar kilos de ropa, planifica lavar tus básicos a la mitad del viaje."
            );
        }
        if (isInt) {
            tips.push(
                "Viaje Internacional: Revisa hoy mismo si tu pasaporte tiene al menos 6 meses de validez porque muchos países lo exigen."
            );
            tips.push(
                "Consulta si hay visas necesarias o si tu banco cobra comisiones en el extranjero."
            );
            tips.push(
                "¡No olvides tu adaptador universal si las clavijas del país de destino son distintas!"
            );
        }
        if (dType === "frio") {
            tips.push(
                "Para el clima frío, la clave es vestirse en capas: una térmica base, una intermedia aislante y un buen abrigo impermeable fuera."
            );
            tips.push(
                "Lleva las prendas más abultadas y pesadas puestas en el avión para ahorrar espacio en cabina."
            );
        }
        if (dType === "playa") {
            tips.push(
                "Asegúrate de llevar más de un bañador; la humedad a veces impide que se sequen para el día siguiente."
            );
        }
        return tips;
    }

    function generateList() {
        if (!resultsSection || !numInput) return;

        const dType = getSelectedRadioValue("dest-type");
        const travelType = getSelectedRadioValue("travel-type");
        const days = parseInt(numInput.value || "3");
        const isInternational = checkInt ? checkInt.checked : false;

        document.querySelectorAll(".variable-cat").forEach((cat) => {
            (cat as HTMLElement).style.display = "none";
        });

        const destCard = document.querySelector(`[data-cat-id="dest-${dType}"]`);
        if (destCard) (destCard as HTMLElement).style.display = "block";

        const travelCard = document.querySelector(`[data-cat-id="travel-${travelType}"]`);
        if (travelCard) (travelCard as HTMLElement).style.display = "block";

        if (qtyRopaInterior) qtyRopaInterior.textContent = calculateQuantity(days, "ropa_interior");
        if (qtyCamisetas) qtyCamisetas.textContent = calculateQuantity(days, "camisetas");
        if (qtyPantalones) qtyPantalones.textContent = calculateQuantity(days, "pantalones");
        if (qtyCalcetines) qtyCalcetines.textContent = calculateQuantity(days, "calcetines");

        if (itemInt) {
            const liItem = itemInt.closest("li");
            if (liItem) {
                liItem.style.display = isInternational ? "block" : "none";
                itemInt.innerHTML = "Pasaporte, Visado, y Seguro Internacional";
            }
        }
        if (itemAdap) {
            const liItem = itemAdap.closest("li");
            if (liItem) {
                liItem.style.display = isInternational ? "block" : "none";
                itemAdap.innerHTML = "Adaptador universal de enchufe";
            }
        }

        if (tipsContainer && tipsList) {
            const tips = generateTips(days, isInternational, dType);
            tipsContainer.style.display = "flex";
            tipsContainer.classList.remove("hidden");
            tipsList.innerHTML = tips.map((t) => `<li>${t}</li>`).join("");
        }

        if (checklistFormContainer) checklistFormContainer.classList.add("hidden");
        resultsSection.style.display = "flex";
        resultsSection.classList.remove("hidden");

        updateProgress();

        setTimeout(() => {
            resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
        }, 100);
    }

    if (generateBtn) {
        generateBtn.addEventListener("click", generateList);
    }
</script>
