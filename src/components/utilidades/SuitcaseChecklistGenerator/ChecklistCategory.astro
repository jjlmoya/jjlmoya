---
import { Icon } from "astro-icon/components";

interface Props {
    id: string;
    title: string;
    icon: string;
    items: { label: string; dynamicId?: string }[];
    isHidden?: boolean;
}

const { id, title, icon, items, isHidden = false } = Astro.props;
---

<div
    class={`category-card ${isHidden ? "variable-cat" : ""}`}
    data-cat-id={id}
    style={isHidden ? "display: none;" : ""}
>
    <div class="category-header">
        <div class="category-icon-wrapper">
            <Icon name={icon} />
        </div>
        <h3 class="category-title">{title}</h3>
    </div>
    <ul class="item-list">
        {
            items.map((item, idx) => (
                <li>
                    <label class="item-row">
                        <input type="checkbox" class="item-checkbox" id={`${id}-cb-${idx}`} />
                        <div class="checkbox-custom">
                            <Icon name="mdi:check" class="check-icon" />
                        </div>
                        <span class="item-label" id={item.dynamicId || undefined}>
                            {item.label}
                        </span>
                    </label>
                </li>
            ))
        }
    </ul>
</div>
