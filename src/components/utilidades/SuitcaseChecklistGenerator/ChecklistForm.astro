---
import { Icon } from "astro-icon/components";
---

<div class="form-section" id="checklist-form-container">
    <div class="form-group">
        <h3 class="section-title"><Icon name="mdi:map-marker-radius" /> Destino y Clima</h3>
        <div class="radio-grid cols-2">
            <label class="radio-card">
                <input type="radio" name="dest-type" value="playa" checked />
                <div class="card-content">
                    <Icon name="mdi:beach" class="card-icon" />
                    <span class="card-text">Playa / Costa</span>
                </div>
            </label>
            <label class="radio-card">
                <input type="radio" name="dest-type" value="ciudad" />
                <div class="card-content">
                    <Icon name="mdi:city" class="card-icon" />
                    <span class="card-text">Ciudad / Urbano</span>
                </div>
            </label>
            <label class="radio-card">
                <input type="radio" name="dest-type" value="montana" />
                <div class="card-content">
                    <Icon name="mdi:pine-tree" class="card-icon" />
                    <span class="card-text">Montaña / Rural</span>
                </div>
            </label>
            <label class="radio-card">
                <input type="radio" name="dest-type" value="frio" />
                <div class="card-content">
                    <Icon name="mdi:snowflake" class="card-icon" />
                    <span class="card-text">Clima Frío / Nieve</span>
                </div>
            </label>
        </div>
    </div>

    <div class="form-row-split">
        <div class="form-group flex-1">
            <h3 class="section-title"><Icon name="mdi:calendar-clock" /> ¿Cuántos días?</h3>
            <div class="number-input-wrapper">
                <button type="button" class="num-btn" id="btn-minus"
                    ><Icon name="mdi:minus" /></button
                >
                <input
                    type="number"
                    id="travel-days"
                    name="travel-days"
                    value="3"
                    min="1"
                    max="90"
                    class="number-input"
                />
                <button type="button" class="num-btn" id="btn-plus"><Icon name="mdi:plus" /></button
                >
            </div>
        </div>

        <div class="form-group flex-1">
            <h3 class="section-title"><Icon name="mdi:earth" /> ¿Viaje Internacional?</h3>
            <label class="toggle-card">
                <input type="checkbox" id="is-international" name="is-international" />
                <div class="toggle-content">
                    <div class="toggle-switch"></div>
                    <span class="toggle-text">Sí, cruzo fronteras</span>
                </div>
            </label>
        </div>
    </div>

    <div class="form-group">
        <h3 class="section-title"><Icon name="mdi:briefcase-variant" /> Motivo del Viaje</h3>
        <div class="radio-grid">
            <label class="radio-card">
                <input type="radio" name="travel-type" value="ocio" checked />
                <div class="card-content">
                    <Icon name="mdi:party-popper" class="card-icon" />
                    <span class="card-text">Ocio / Placer</span>
                </div>
            </label>
            <label class="radio-card">
                <input type="radio" name="travel-type" value="negocios" />
                <div class="card-content">
                    <Icon name="mdi:tie" class="card-icon" />
                    <span class="card-text">Negocios</span>
                </div>
            </label>
        </div>
    </div>

    <button class="generate-btn" id="generate-btn">
        <Icon name="mdi:magic" class="btn-icon" />
        Configurar Maleta Ideal
    </button>
</div>
