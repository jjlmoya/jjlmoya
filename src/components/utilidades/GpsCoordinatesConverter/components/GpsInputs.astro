---
import { Icon } from "astro-icon/components";
---

<div class="tech-section">
    <div class="row-header">
        <div class="mode-switch">
            <button id="modeDD" class="mode-btn active" data-mode="DD">Decimal (DD)</button>
            <button id="modeGMS" class="mode-btn" data-mode="GMS">Grados (GMS)</button>
        </div>
        <button id="btnMyLocation" class="loc-btn" title="Usar mi ubicación">
            <Icon name="mdi:crosshairs-gps" size={18} />
        </button>
    </div>

    <div id="ddInputs" class="compact-inputs">
        <div class="input-block">
            <label class="field-label">Latitud</label>
            <input type="text" id="latDD" class="tech-input" placeholder="40.4168" />
        </div>
        <div class="input-block">
            <label class="field-label">Longitud</label>
            <input type="text" id="lngDD" class="tech-input" placeholder="-3.7038" />
        </div>
    </div>

    <div id="gmsInputs" class="tech-section" style="display: none;">
        <div class="gms-group">
            <label class="field-label">Latitud (GMS)</label>
            <div class="compact-inputs">
                <input type="number" id="latG" class="tech-input" placeholder="G" />
                <input type="number" id="latM" class="tech-input" placeholder="M" />
                <input type="number" id="latS" class="tech-input" placeholder="S" step="any" />
                <select id="latH" class="tech-input">
                    <option value="N">N</option>
                    <option value="S">S</option>
                </select>
            </div>
        </div>
        <div class="gms-group">
            <label class="field-label">Longitud (GMS)</label>
            <div class="compact-inputs">
                <input type="number" id="lngG" class="tech-input" placeholder="G" />
                <input type="number" id="lngM" class="tech-input" placeholder="M" />
                <input type="number" id="lngS" class="tech-input" placeholder="S" step="any" />
                <select id="lngH" class="tech-input">
                    <option value="E">E</option>
                    <option value="W">W</option>
                </select>
            </div>
        </div>
    </div>
</div>

<style>
    .row-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .loc-btn {
        background: #0ea5e910;
        border: 1px solid #0ea5e930;
        color: #0ea5e9;
        padding: 0.6rem;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .loc-btn:hover {
        background: #0ea5e920;
        transform: scale(1.05);
    }
    .gms-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .compact-inputs {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.5rem;
    }
    #ddInputs.compact-inputs {
        grid-template-columns: 1fr 1fr;
    }
</style>
