---
import "./HashGenerator.css";
---

<div class="hash-generator-container">
    <div class="input-section">
        <div class="text-area-wrapper">
            <label for="hash-input" class="hash-label">
                <span class="i-mdi-text-box-outline"></span>
                Texto de entrada
            </label>
            <textarea
                id="hash-input"
                class="hash-input-area"
                placeholder="Escribe o pega aquí el texto para calcular sus hashes..."
                spellcheck="false"></textarea>
        </div>

        <div class="settings-grid">
            <div class="setting-card">
                <label for="hash-salt">Salt (Opcional)</label>
                <input
                    type="text"
                    id="hash-salt"
                    class="setting-input"
                    placeholder="Semilla de seguridad..."
                />
            </div>
            <div class="setting-card">
                <label for="hash-rounds">Rondas (Stretch)</label>
                <input
                    type="number"
                    id="hash-rounds"
                    class="setting-input"
                    value="1"
                    min="1"
                    max="1000"
                />
            </div>
        </div>
    </div>

    <div class="results-section">
        <div class="hash-result-card" data-algo="MD5">
            <div class="result-header">
                <span class="algo-badge">MD5</span>
            </div>
            <div class="hash-output-container">
                <span id="output-md5" class="hash-value">...</span>
                <button class="btn-copy" data-target="output-md5" title="Copiar MD5">
                    <span class="i-mdi-content-copy"></span>
                </button>
            </div>
        </div>

        <div class="hash-result-card" data-algo="SHA-1">
            <div class="result-header">
                <span class="algo-badge">SHA-1</span>
            </div>
            <div class="hash-output-container">
                <span id="output-sha1" class="hash-value">...</span>
                <button class="btn-copy" data-target="output-sha1" title="Copiar SHA-1">
                    <span class="i-mdi-content-copy"></span>
                </button>
            </div>
        </div>

        <div class="hash-result-card" data-algo="SHA-256">
            <div class="result-header">
                <span class="algo-badge">SHA-256</span>
            </div>
            <div class="hash-output-container">
                <span id="output-sha256" class="hash-value">...</span>
                <button class="btn-copy" data-target="output-sha256" title="Copiar SHA-256">
                    <span class="i-mdi-content-copy"></span>
                </button>
            </div>
        </div>

        <div class="hash-result-card" data-algo="SHA-512">
            <div class="result-header">
                <span class="algo-badge">SHA-512</span>
            </div>
            <div class="hash-output-container">
                <span id="output-sha512" class="hash-value">...</span>
                <button class="btn-copy" data-target="output-sha512" title="Copiar SHA-512">
                    <span class="i-mdi-content-copy"></span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    import { md5 } from "./md5";

    const input = document.getElementById("hash-input") as HTMLTextAreaElement;
    const saltInput = document.getElementById("hash-salt") as HTMLInputElement;
    const roundsInput = document.getElementById("hash-rounds") as HTMLInputElement;

    const outputs = {
        md5: document.getElementById("output-md5"),
        sha1: document.getElementById("output-sha1"),
        sha256: document.getElementById("output-sha256"),
        sha512: document.getElementById("output-sha512"),
    };

    async function hashSHA(text: string, algo: "SHA-1" | "SHA-256" | "SHA-512") {
        const msgUint8 = new TextEncoder().encode(text);
        const hashBuffer = await crypto.subtle.digest(algo, msgUint8);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        return hashArray.map((b) => b.toString(16).padStart(2, "0")).join("");
    }

    async function updateHashes() {
        const rawText = input.value;
        const salt = saltInput.value;
        const rounds = parseInt(roundsInput.value) || 1;

        if (!rawText) {
            Object.values(outputs).forEach((el) => {
                if (el) el.textContent = "...";
            });
            return;
        }

        const currentText = rawText + salt;

        
        let md5Val = currentText;
        for (let i = 0; i < rounds; i++) {
            md5Val = md5(md5Val);
        }
        if (outputs.md5) outputs.md5.textContent = md5Val;

        
        const algos = ["SHA-1", "SHA-256", "SHA-512"] as const;
        for (const algo of algos) {
            let shaVal = currentText;
            for (let i = 0; i < rounds; i++) {
                shaVal = await hashSHA(shaVal, algo);
            }
            const key = algo.toLowerCase().replace("-", "") as keyof typeof outputs;
            if (outputs[key]) outputs[key]!.textContent = shaVal;
        }
    }

    input.addEventListener("input", updateHashes);
    saltInput.addEventListener("input", updateHashes);
    roundsInput.addEventListener("input", updateHashes);

    
    document.querySelectorAll(".btn-copy").forEach((btn) => {
        btn.addEventListener("click", () => {
            const targetId = (btn as HTMLElement).dataset.target;
            const target = document.getElementById(targetId!);
            if (target && target.textContent && target.textContent !== "...") {
                navigator.clipboard.writeText(target.textContent);

                const originalHtml = btn.innerHTML;
                btn.innerHTML = '<span class="i-mdi-check text-green-500"></span>';
                setTimeout(() => {
                    btn.innerHTML = originalHtml;
                }, 2000);
            }
        });
    });
</script>
