---
import "./GamepadVibrationTester.css";
---

<div class="vibration-super-container">
    <div class="premium-card">
        <div id="statusHead" class="status-header">
            <div class="status-avatar">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <line x1="6" y1="12" x2="10" y2="12"></line>
                    <line x1="8" y1="10" x2="8" y2="14"></line>
                    <line x1="15" y1="13" x2="15.01" y2="13"></line>
                    <line x1="18" y1="11" x2="18.01" y2="11"></line>
                    <rect x="2" y="6" width="20" height="12" rx="2"></rect>
                </svg>
            </div>
            <div class="status-info">
                <h3 id="devName">Mando Desconectado</h3>
                <p id="devSub">Toca un botón en tu mando para comenzar</p>
            </div>
            <div class="status-indicator"></div>
        </div>

        <div id="supportWarn" class="warning-native">
            ⚠️ No detectamos soporte para 'Dual-Rumble' en tu navegador. Usaremos la vibración
            básica genérica.
        </div>

        <div class="tabs-nav">
            <button class="tab-btn active" data-target="presets">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m10 22 5-20"></path><path d="m6 18-4-4 4-4"></path><path
                        d="m18 6 4 4-4 4"></path></svg
                >
                Presets Top
            </button>
            <button class="tab-btn" data-target="custom">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"></path><path
                        d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"></path><path d="M12 2v2"
                    ></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path
                        d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path
                        d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path
                        d="m19.07 4.93-1.41 1.41"></path></svg
                >
                Precisión Pura
            </button>
        </div>

        <div id="pane-presets" class="tab-pane active">
            <div class="presets-grid">
                <div class="preset-card trigger-preset" data-id="heavy">
                    <div class="preset-icon">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"
                            ></path><path d="M17.64 15 22 10.64"></path><path
                                d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p class="preset-title">Golpe de Martillo</p>
                        <p class="preset-desc">
                            Testea el motor pesado 300ms a tope. Simula un golpe fuerte.
                        </p>
                    </div>
                </div>

                <div class="preset-card trigger-preset" data-id="light">
                    <div class="preset-icon">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"></path><path
                                d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"></path><path d="M12 2v2"
                            ></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"
                            ></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"
                            ></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"
                            ></path><path d="m19.07 4.93-1.41 1.41"></path></svg
                        >
                    </div>
                    <div>
                        <p class="preset-title">Zumbido de Abeja</p>
                        <p class="preset-desc">
                            Solo motor derecho activo. Ideal para buscar zumbidos extraños.
                        </p>
                    </div>
                </div>

                <div class="preset-card trigger-preset" data-id="heartbeat">
                    <div class="preset-icon">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p class="preset-title">Corazón a Mil</p>
                        <p class="preset-desc">
                            Palpitaciones sutiles seguidas, perfecto para ver retenciones
                            inerciales.
                        </p>
                    </div>
                </div>

                <div class="preset-card trigger-preset" data-id="song">
                    <div class="preset-icon">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"></path>
                            <path d="M12 18V6"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="preset-title">Ritmo Moneda</p>
                        <p class="preset-desc">
                            Simula el ruido de conseguir monedas consecutivas. Corto y táctil.
                        </p>
                    </div>
                </div>

                <div class="preset-card trigger-preset" data-id="rockyou">
                    <div class="preset-icon">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                        </svg>
                    </div>
                    <div>
                        <p class="preset-title">Rock You!</p>
                        <p class="preset-desc">
                            El clásico de Queen en tus manos: pum, pum, ¡clap!
                        </p>
                    </div>
                </div>

                <div class="preset-card trigger-preset" data-id="earthquake">
                    <div class="preset-icon">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M22 11h-4l-3 9-6-18-3 9H2"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="preset-title">¡Terremoto Máximo!</p>
                        <p class="preset-desc">
                            Prueba de resistencia: Ambos motores al 100% de fuerza explosiva. MUY
                            intenso.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        
        <div id="pane-custom" class="tab-pane">
            <div class="custom-sliders">
                <div class="slider-group">
                    <div class="slider-header">
                        <span>Fuerza Grave (Izquierda)</span>
                        <span id="sl-str" class="slider-val">100%</span>
                    </div>
                    <input
                        type="range"
                        class="styled-slider"
                        id="inp-str"
                        min="0"
                        max="1"
                        step="0.05"
                        value="1.0"
                    />
                </div>

                <div class="slider-group">
                    <div class="slider-header">
                        <span>Fuerza Aguda (Derecha)</span>
                        <span id="sl-wk" class="slider-val">100%</span>
                    </div>
                    <input
                        type="range"
                        class="styled-slider"
                        id="inp-wk"
                        min="0"
                        max="1"
                        step="0.05"
                        value="1.0"
                    />
                </div>

                <div class="slider-group">
                    <div class="slider-header">
                        <span>Duración del Pulso</span>
                        <span id="sl-dur" class="slider-val">500ms</span>
                    </div>
                    <input
                        type="range"
                        class="styled-slider"
                        id="inp-dur"
                        min="50"
                        max="2500"
                        step="50"
                        value="500"
                    />
                </div>
            </div>

            <button id="btnPlayCustom" class="btn-super-test">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg
                >
                ENVIAR SEÑAL AHORA
            </button>
        </div>
    </div>
</div>

<script>
    let activePad: Gamepad | null = null;
    let sequenceTimeout: ReturnType<typeof setTimeout> | null = null;
    let sequenceInterval: ReturnType<typeof setInterval> | null = null;

    const statusHead = document.getElementById("statusHead") as HTMLDivElement;
    const devName = document.getElementById("devName") as HTMLHeadingElement;
    const devSub = document.getElementById("devSub") as HTMLParagraphElement;
    const supportWarn = document.getElementById("supportWarn") as HTMLDivElement;

    const tabBtns = document.querySelectorAll(".tab-btn");
    const tabPanes = document.querySelectorAll(".tab-pane");

    const inpStr = document.getElementById("inp-str") as HTMLInputElement;
    const inpWk = document.getElementById("inp-wk") as HTMLInputElement;
    const inpDur = document.getElementById("inp-dur") as HTMLInputElement;

    const slStr = document.getElementById("sl-str") as HTMLSpanElement;
    const slWk = document.getElementById("sl-wk") as HTMLSpanElement;
    const slDur = document.getElementById("sl-dur") as HTMLSpanElement;

    const btnPlayCustom = document.getElementById("btnPlayCustom") as HTMLButtonElement;
    const btnStop = document.getElementById("btnStop") as HTMLButtonElement;

    const presetCards = document.querySelectorAll(".trigger-preset");

    tabBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const b = btn as HTMLButtonElement;
            tabBtns.forEach((tb) => tb.classList.remove("active"));
            tabPanes.forEach((tp) => tp.classList.remove("active"));
            b.classList.add("active");
            document.getElementById(`pane-${b.dataset.target}`)?.classList.add("active");
        });
    });

    function updateCustom() {
        if (!inpStr || !inpWk || !inpDur) return;
        slStr.textContent = `${Math.round(parseFloat(inpStr.value) * 100)}%`;
        slWk.textContent = `${Math.round(parseFloat(inpWk.value) * 100)}%`;
        slDur.textContent = `${inpDur.value}ms`;
    }
    inpStr?.addEventListener("input", updateCustom);
    inpWk?.addEventListener("input", updateCustom);
    inpDur?.addEventListener("input", updateCustom);

    function checkSupport(pad: Gamepad) {
        const asAny = pad as any;
        if (!asAny.vibrationActuator && !("vibrate" in navigator)) {
            supportWarn?.classList.add("visible");
        } else {
            supportWarn?.classList.remove("visible");
        }
    }

    function hookGamepad(pad: Gamepad) {
        activePad = pad;
        if (statusHead && devName && devSub) {
            statusHead.classList.add("connected");
            devName.textContent = pad.id.split("(")[0] || "Gamepad Enlazado";
            devSub.textContent = "Conexión estable. Listo para testear.";
            checkSupport(pad);
        }
    }

    function unhookGamepad() {
        activePad = null;
        if (statusHead && devName && devSub) {
            statusHead.classList.remove("connected");
            devName.textContent = "Mando Desconectado";
            devSub.textContent = "Toca un botón en tu mando para comenzar";
            supportWarn?.classList.remove("visible");
        }
    }

    window.addEventListener("gamepadconnected", (e: GamepadEvent) => hookGamepad(e.gamepad));
    window.addEventListener("gamepaddisconnected", (e: GamepadEvent) => {
        if (activePad && activePad.index === e.gamepad.index) unhookGamepad();
    });

    function fireRumble(dur: number, weak: number, strong: number) {
        if (!activePad) return;
        const pad = navigator.getGamepads()[activePad.index] as any;
        if (pad && pad.vibrationActuator) {
            try {
                pad.vibrationActuator.playEffect("dual-rumble", {
                    startDelay: 0,
                    duration: dur,
                    weakMagnitude: weak,
                    strongMagnitude: strong,
                });
            } catch (e) {}
        } else if ("vibrate" in navigator) {
            navigator.vibrate(dur);
        }
    }

    function haltEverything() {
        if (sequenceTimeout !== null) {
            clearTimeout(sequenceTimeout);
            sequenceTimeout = null;
        }
        if (sequenceInterval !== null) {
            clearInterval(sequenceInterval);
            sequenceInterval = null;
        }
        fireRumble(0, 0, 0);

        btnPlayCustom?.classList.remove("vibrating");
        presetCards.forEach((c) => c.classList.remove("vibrating"));
    }

    btnStop?.addEventListener("click", haltEverything);

    btnPlayCustom?.addEventListener("click", () => {
        haltEverything();
        const d = parseInt(inpDur.value, 10);
        const s = parseFloat(inpStr.value);
        const w = parseFloat(inpWk.value);
        fireRumble(d, w, s);
    });

    presetCards.forEach((card) => {
        card.addEventListener("click", () => {
            haltEverything();
            const c = card as HTMLDivElement;
            const id = c.dataset.id;
            c.classList.add("vibrating");

            if (id === "heavy") {
                fireRumble(300, 0.0, 1.0);
                sequenceTimeout = setTimeout(() => c.classList.remove("vibrating"), 300);
            }
            if (id === "light") {
                fireRumble(500, 1.0, 0.0);
                sequenceTimeout = setTimeout(() => c.classList.remove("vibrating"), 500);
            }
            if (id === "heartbeat") {
                let ticks = 0;
                sequenceInterval = setInterval(() => {
                    fireRumble(100, 0.5, 0.8);
                    setTimeout(() => fireRumble(150, 0.8, 1.0), 120);
                    ticks++;
                    if (ticks >= 3 && sequenceInterval !== null) {
                        clearInterval(sequenceInterval);
                        sequenceInterval = null;
                        setTimeout(() => c.classList.remove("vibrating"), 300);
                    }
                }, 800);
            }
            if (id === "song") {
                const seq = [
                [100, 0.8, 0, 150],
                [300, 1.0, 0, 0],
            ];
                runSequence(seq, c);
            }
            if (id === "rockyou") {
                const seq = [
                [200, 0.2, 1.0, 150],
                [200, 0.2, 1.0, 200],
                [300, 1.0, 0.5, 500],
                [200, 0.2, 1.0, 150],
                [200, 0.2, 1.0, 200],
                [300, 1.0, 0.5, 500],
                [200, 0.2, 1.0, 150],
                [200, 0.2, 1.0, 200],
                [300, 1.0, 0.5, 500],
                [200, 0.2, 1.0, 150],
                [200, 0.2, 1.0, 200],
                [300, 1.0, 0.5, 500],
            ];
                runSequence(seq, c);
            }
            if (id === "earthquake") {
                const seq = [[2000, 1, 1, 0]];
                runSequence(seq, c);
            }
        });
    });

    function runSequence(seq: number[][], element: HTMLElement) {
        let index = 0;
        function step() {
            if (index >= seq.length) {
                element.classList.remove("vibrating");
                return;
            }
            const [dur, w, s, pause] = seq[index];
            if (dur > 0) fireRumble(dur, w, s);
            sequenceTimeout = setTimeout(() => {
                index++;
                step();
            }, dur + pause);
        }
        step();
    }

    window.addEventListener("load", () => {
        const pads = navigator.getGamepads ? navigator.getGamepads() : [];
        for (let i = 0; i < pads.length; i++) {
            if (pads[i]) {
                hookGamepad(pads[i] as Gamepad);
                break;
            }
        }
    });
</script>
