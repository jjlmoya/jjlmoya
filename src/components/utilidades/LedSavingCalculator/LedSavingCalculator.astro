---
import { Icon } from "astro-icon/components";
import "./LedSavingCalculator.css";
---

<div class="led-calculator-container">
    <div class="calculator-wrapper">
        <div class="input-panel">
            <div class="section-title">Configuración del Hogar</div>

            <div class="input-grid">
                <div class="fun-input-group full-width">
                    <label>
                        <Icon name="mdi:lightbulb-group-outline" />
                        ¿Cuántas bombillas quieres cambiar?
                    </label>
                    <div class="input-control">
                        <input type="number" id="numBulbs" value="10" min="1" max="200" />
                        <span class="input-addon">unidades</span>
                    </div>
                </div>

                <div class="fun-input-group full-width">
                    <label>
                        <Icon name="mdi:flash-outline" />
                        ¿Qué bombillas tienes ahora?
                    </label>
                    <div class="bulb-selector-grid">
                        <button
                            class="selector-btn active"
                            data-type="inc-60"
                            data-old="60"
                            data-led="9"
                        >
                            <span class="btn-title">Incandescente</span>
                            <span class="btn-subtitle">Clásica (60W)</span>
                        </button>
                        <button class="selector-btn" data-type="inc-40" data-old="40" data-led="5">
                            <span class="btn-title">Incandescente</span>
                            <span class="btn-subtitle">Pequeña (40W)</span>
                        </button>
                        <button
                            class="selector-btn"
                            data-type="inc-100"
                            data-old="100"
                            data-led="14"
                        >
                            <span class="btn-title">Incandescente</span>
                            <span class="btn-subtitle">Grande (100W)</span>
                        </button>
                        <button class="selector-btn" data-type="halo-50" data-old="50" data-led="6">
                            <span class="btn-title">Halógena</span>
                            <span class="btn-subtitle">Focos (50W)</span>
                        </button>
                    </div>
                    <input type="hidden" id="oldWattage" value="60" />
                    <input type="hidden" id="ledWattage" value="9" />
                </div>

                <div class="fun-input-group full-width">
                    <label>
                        <Icon name="mdi:clock-outline" />
                        ¿Cuánto tiempo están encendidas?
                    </label>
                    <div class="usage-slider-container">
                        <input
                            type="range"
                            id="usageSlider"
                            min="1"
                            max="24"
                            value="5"
                            class="usage-range"
                        />
                        <div class="usage-labels">
                            <span id="usageDesc">Uso diario normal (5h)</span>
                        </div>
                    </div>
                    <input type="hidden" id="hoursPerDay" value="5" />
                </div>

                <div class="fun-input-group full-width">
                    <label>
                        <Icon name="mdi:currency-eur" />
                        Precio de la electricidad
                    </label>
                    <div class="price-input-compact">
                        <input
                            type="number"
                            id="electricityPrice"
                            value="0.18"
                            min="0.01"
                            step="0.01"
                        />
                        <span>€/kWh</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="result-panel">
            <div class="led-bg-decoration"></div>

            <div class="result-header">
                <div class="result-badge">Cálculo de ahorro real</div>
                <Icon name="mdi:lightning-bolt" class="w-6 h-6 text-amber-300" />
            </div>

            <div class="main-saving-display">
                <div class="saving-label">Ahorrarás al año</div>
                <div class="saving-amount" id="annualSaving">0.00<span>€</span></div>
            </div>

            <div class="mini-stats">
                <div class="stat-item">
                    <div class="stat-label">Mensual</div>
                    <div class="stat-value" id="monthlySaving">0.00€</div>
                </div>
                <div class="stat-item">
                    <div class="stat-label">Equivalencia</div>
                    <div class="stat-value" id="efficiencyVal">85% menos</div>
                </div>
            </div>

            <div class="eco-box">
                <div class="eco-icon-pulse">
                    <Icon name="mdi:leaf" />
                </div>
                <div class="eco-text">
                    <span class="val" id="co2Saving">0 kg</span>
                    <span class="desc">Reducción de huella CO2</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const usageMessages: Record<number, string> = {
        1: "Casi nunca (1h)",
        2: "Poco uso (2h)",
        3: "Poco uso (3h)",
        4: "Uso normal (4h)",
        5: "Uso normal (5h)",
        6: "Uso moderado (6h)",
        7: "Uso moderado (7h)",
        8: "Uso intenso (8h)",
        12: "Uso profesional (12h)",
        16: "Muy intenso (16h)",
        24: "Siempre encendida (24h)",
    };

    function updateCalculator() {
        const numBulbsInput = document.getElementById("numBulbs") as HTMLInputElement | null;
        const oldWattageInput = document.getElementById("oldWattage") as HTMLInputElement | null;
        const ledWattageInput = document.getElementById("ledWattage") as HTMLInputElement | null;
        const hoursPerDayInput = document.getElementById("hoursPerDay") as HTMLInputElement | null;
        const electricityPriceInput = document.getElementById(
            "electricityPrice"
        ) as HTMLInputElement | null;

        const annualSavingEl = document.getElementById("annualSaving");
        const monthlySavingEl = document.getElementById("monthlySaving");
        const efficiencyValEl = document.getElementById("efficiencyVal");
        const co2SavingEl = document.getElementById("co2Saving");

        if (
            !numBulbsInput ||
            !oldWattageInput ||
            !ledWattageInput ||
            !hoursPerDayInput ||
            !electricityPriceInput ||
            !annualSavingEl ||
            !monthlySavingEl ||
            !efficiencyValEl ||
            !co2SavingEl
        )
            return;

        const numBulbs = Number(numBulbsInput.value) || 0;
        const oldWattage = Number(oldWattageInput.value) || 0;
        const ledWattage = Number(ledWattageInput.value) || 0;
        const hoursPerDay = Number(hoursPerDayInput.value) || 0;
        const electricityPrice = Number(electricityPriceInput.value) || 0;

        const oldAnnualKwh = (numBulbs * oldWattage * hoursPerDay * 365) / 1000;
        const ledAnnualKwh = (numBulbs * ledWattage * hoursPerDay * 365) / 1000;

        const annualKwhSaved = oldAnnualKwh - ledAnnualKwh;
        const annualEuroSaved = annualKwhSaved * electricityPrice;
        const monthlyEuroSaved = annualEuroSaved / 12;
        const co2Saved = annualKwhSaved * 0.25;
        const efficiency =
            oldWattage > 0 ? Math.round(((oldWattage - ledWattage) / oldWattage) * 100) : 0;

        const fmt = new Intl.NumberFormat("es-ES", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
        });

        annualSavingEl.innerHTML = `${fmt.format(annualEuroSaved)}<span>€</span>`;
        monthlySavingEl.textContent = `${fmt.format(monthlyEuroSaved)}€`;
        efficiencyValEl.textContent = `${efficiency}% menos`;
        co2SavingEl.textContent = `${Math.round(co2Saved).toLocaleString("es-ES")} kg`;
    }

    document.querySelectorAll(".selector-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            document.querySelectorAll(".selector-btn").forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            const oldW = btn.getAttribute("data-old");
            const ledW = btn.getAttribute("data-led");
            const oldInput = document.getElementById("oldWattage") as HTMLInputElement | null;
            const ledInput = document.getElementById("ledWattage") as HTMLInputElement | null;

            if (oldInput && ledInput && oldW && ledW) {
                oldInput.value = oldW;
                ledInput.value = ledW;
                updateCalculator();
            }
        });
    });

    const slider = document.getElementById("usageSlider") as HTMLInputElement | null;
    const usageDesc = document.getElementById("usageDesc");
    const hoursInput = document.getElementById("hoursPerDay") as HTMLInputElement | null;

    if (slider && usageDesc && hoursInput) {
        slider.addEventListener("input", () => {
            const val = Number(slider.value);
            hoursInput.value = val.toString();
            usageDesc.textContent = usageMessages[val] || `${val} horas al día`;
            updateCalculator();
        });
    }

    ["numBulbs", "electricityPrice"].forEach((id) => {
        const input = document.getElementById(id);
        if (input) input.addEventListener("input", updateCalculator);
    });

    updateCalculator();
</script>
