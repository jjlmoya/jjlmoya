---
import "./ResignationLetterGenerator.css";
import { Icon } from "astro-icon/components";
---

<main class="tool-content">
    <div class="form-container">
        <div class="form-group">
            <label for="userName">Tu nombre completo</label>
            <input type="text" id="userName" placeholder="Ej: Juan García Pérez" />
        </div>

        <div class="form-group">
            <label for="managerName">Nombre del responsable o RR.HH.</label>
            <input type="text" id="managerName" placeholder="Ej: Marta Gómez (Directora RR.HH.)" />
        </div>

        <div class="form-group">
            <label for="managerGender">Tratamiento del destinatario</label>
            <select id="managerGender">
                <option value="estimadoa">Estimado/a (Neutral)</option>
                <option value="estimado">Estimado (Masculino)</option>
                <option value="estimada">Estimada (Femenino)</option>
            </select>
        </div>

        <div class="form-group">
            <label for="companyName">Nombre de la empresa</label>
            <input type="text" id="companyName" placeholder="Ej: Tech Solutions S.L." />
        </div>

        <div class="form-group">
            <label for="lastDay">Tu último día (Fecha de salida)</label>
            <input type="date" id="lastDay" />
        </div>

        <div class="form-group">
            <label for="reasonType">Planteamiento del motivo</label>
            <select id="reasonType">
                <option value="standard">Estándar (Profesional y cordial)</option>
                <option value="opportunity">Nueva oportunidad profesional</option>
                <option value="personal">Motivos personales</option>
                <option value="education">Crecimiento académico/estudios</option>
                <option value="growth">Falta de crecimiento interno</option>
                <option value="direct">Directo y breve (Sin justificar)</option>
            </select>
        </div>

        <div class="form-group">
            <label for="city">Ciudad desde donde escribes</label>
            <input type="text" id="city" placeholder="Ej: Madrid" />
        </div>

        <div class="actions">
            <button id="copyBtn" class="btn btn-primary">
                <Icon name="mdi:content-copy" class="w-5 h-5" />
                Copiar Carta
            </button>
            <button id="downloadBtn" class="btn btn-secondary">
                <Icon name="mdi:file-download-outline" class="w-5 h-5" />
                Descargar PDF
            </button>
        </div>
    </div>

    <div class="preview-container">
        <div id="copyFeedback" class="copy-feedback">¡Copiado al portapapeles!</div>
        <div id="letterPreview" class="letter-content">
            <div class="letter-header">
                <p id="previewDate" class="font-bold"></p>
                <div class="mt-8">
                    <p id="previewManager"></p>
                    <p id="previewCompany" class="font-bold text-xl"></p>
                </div>
            </div>

            <div class="letter-body mt-10">
                <p id="previewSalutation">
                    <span id="salPrefix">Estimado/a</span>
                    <span id="salName">responsable</span>:
                </p>
                <p id="previewMainBody" class="mt-6"></p>
                <p class="mt-4">
                    Quiero expresar mi más sincero agradecimiento por las oportunidades de
                    crecimiento profesional y personal que se me han brindado durante mi estancia en
                    la empresa.
                </p>
                <p class="mt-4">
                    Me pongo a su entera disposición para colaborar en el proceso de transición de
                    mis responsabilidades y asegurar el traspaso de mis tareas pendientes de la
                    mejor forma posible.
                </p>
            </div>

            <div class="letter-footer mt-12">
                <p>Cordialmente,</p>
                <div class="mt-10">
                    <p
                        id="previewSignature"
                        class="font-bold border-t-2 border-slate-200 pt-2 inline-block min-w-[200px]"
                    >
                    </p>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const inputs = {
        userName: document.getElementById("userName") as HTMLInputElement,
        managerName: document.getElementById("managerName") as HTMLInputElement,
        companyName: document.getElementById("companyName") as HTMLInputElement,
        lastDay: document.getElementById("lastDay") as HTMLInputElement,
        reasonType: document.getElementById("reasonType") as HTMLSelectElement,
        city: document.getElementById("city") as HTMLInputElement,
        managerGender: document.getElementById("managerGender") as HTMLSelectElement,
    };

    const preview = {
        date: document.getElementById("previewDate"),
        manager: document.getElementById("previewManager"),
        company: document.getElementById("previewCompany"),
        salutationName: document.getElementById("salName"),
        salutationPrefix: document.getElementById("salPrefix"),
        mainBody: document.getElementById("previewMainBody"),
        signature: document.getElementById("previewSignature"),
        container: document.getElementById("letterPreview"),
        feedback: document.getElementById("copyFeedback"),
    };

    const buttons = {
        copy: document.getElementById("copyBtn"),
        download: document.getElementById("downloadBtn"),
    };

    const reasons = {
        standard:
            "Le escribo formalmente para presentar mi renuncia irrevocable a mi puesto actual. Mi último día de trabajo será el [DATE], respetando así los términos de preaviso establecidos.",
        opportunity:
            "Le informo de mi decisión de renunciar a mi cargo actual, motivado por la aceptación de una nueva oferta laboral que me permitirá enfrentar nuevos retos profesionales. Mi fecha efectiva de salida será el [DATE].",
        personal:
            "Por motivos personales que requieren de mi atención inmediata y total, me veo en la necesidad de presentar mi renuncia al cargo que vengo desempeñando. Mi vínculo con la empresa finalizará el próximo [DATE].",
        education:
            "He decidido retomar mis estudios de formación avanzada a tiempo completo, por lo cual presento mi renuncia voluntaria. Mi último día de servicio será el [DATE].",
        growth: "Tras una larga reflexión, he decidido dar un giro a mi carrera profesional en busca de un entorno que me permita desarrollar habilidades en áreas distintas a las actuales. Mi salida efectiva se producirá el [DATE].",
        direct: "Por la presente, le comunico mi decisión de extinguir mi relación laboral con la empresa. Mi último día de actividad profesional en el centro de trabajo será el [DATE].",
    };

    function updatePreview() {
        const now = new Date();
        const formattedDate = new Intl.DateTimeFormat("es-ES", {
            day: "numeric",
            month: "long",
            year: "numeric",
        }).format(now);

        const city = inputs.city.value || "Madrid";
        if (preview.date) preview.date.textContent = `${city}, a ${formattedDate}`;

        if (preview.manager) {
            preview.manager.textContent = inputs.managerName.value
                ? `A/A: ${inputs.managerName.value}`
                : "A la atención del Responsable de RR.HH.";
        }

        if (preview.company) {
            preview.company.textContent = inputs.companyName.value || "Nombre de la Empresa";
        }

        if (preview.salutationName) {
            preview.salutationName.textContent =
                inputs.managerName.value.trim().split(" ")[0] || "responsable";
        }

        if (preview.salutationPrefix) {
            const genderMap = {
                estimado: "Estimado",
                estimada: "Estimada",
                estimadoa: "Estimado/a",
            };
            preview.salutationPrefix.textContent =
                genderMap[inputs.managerGender.value as keyof typeof genderMap] || "Estimado/a";
        }

        const lastDayVal = inputs.lastDay.value;
        const dateToFormat = lastDayVal
            ? new Date(lastDayVal)
            : new Date(now.getTime() + 15 * 24 * 60 * 60 * 1000);

        const formattedLastDay = new Intl.DateTimeFormat("es-ES", {
            day: "numeric",
            month: "long",
            year: "numeric",
        }).format(dateToFormat);

        const reasonKey = inputs.reasonType.value as keyof typeof reasons;
        if (preview.mainBody) {
            preview.mainBody.textContent = (reasons[reasonKey] || reasons.standard).replace(
                "[DATE]",
                formattedLastDay
            );
        }

        if (preview.signature) {
            preview.signature.textContent = inputs.userName.value || "Firma del Empleado";
        }
    }

    function handleCopy() {
        if (!preview.container || !preview.feedback) return;

        const text = preview.container.innerText;
        navigator.clipboard.writeText(text).then(() => {
            preview.feedback!.classList.add("show");
            setTimeout(() => {
                preview.feedback!.classList.remove("show");
            }, 2000);
        });
    }

    function handleDownload() {
        if (!preview.container) return;

        const content = preview.container.innerHTML;
        const html = `<!DOCTYPE html><html><head><title></title><style>* { margin: 0; padding: 0; box-sizing: border-box; } @page { size: A4; margin: 0; } @media print { body { margin: 0; padding: 2cm; } } html, body { height: 100%; background: white; color: black; } body { font-size: 12px; line-height: 1.6; color: #000; } p { margin: 0; padding: 0; } p + p { margin-top: 12px; } .font-bold { font-weight: bold; } .text-xl { font-size: 18px; } .mt-8 { margin-top: 32px; } .mt-10 { margin-top: 40px; } .mt-12 { margin-top: 48px; } .mt-4 { margin-top: 16px; } .mt-6 { margin-top: 24px; } .border-t-2 { border-top: 2px solid #000; } .border-slate-200 { border-color: #e2e8f0; } .pt-2 { padding-top: 8px; } .inline-block { display: inline-block; } .min-w-[200px] { min-width: 200px; }</style></head><body>${content}</body></html>`;
        const blob = new Blob([html], { type: "text/html" });
        const url = URL.createObjectURL(blob);
        const printWindow = window.open(url, "", "width=800,height=600");
        if (!printWindow) { URL.revokeObjectURL(url); return; }
        printWindow.addEventListener("load", () => {
            printWindow.print();
            URL.revokeObjectURL(url);
        });
    }

    function setInitialValues() {
        const now = new Date();
        const future = new Date(now.getTime() + 15 * 24 * 60 * 60 * 1000);

        if (!inputs.userName.value) inputs.userName.value = "Juan García Pérez";
        if (!inputs.managerName.value) inputs.managerName.value = "Marta Gómez";
        if (!inputs.companyName.value) inputs.companyName.value = "Tech Solutions S.L.";
        if (!inputs.city.value) inputs.city.value = "Madrid";
        if (!inputs.lastDay.value) inputs.lastDay.value = future.toISOString().split("T")[0];
        if (!inputs.managerGender.value || inputs.managerGender.value === "estimadoa") {
            inputs.managerGender.value = "estimada";
        }
    }

    Object.values(inputs).forEach((input) => {
        input?.addEventListener("input", updatePreview);
    });

    buttons.copy?.addEventListener("click", handleCopy);
    buttons.download?.addEventListener("click", handleDownload);

    setInitialValues();
    updatePreview();
</script>
