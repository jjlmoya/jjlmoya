---
---
<div class="sidebar-inputs">
  <div class="compact-group">
    <label>Capacidad del Depósito</label>
    <div class="input-row">
        <div class="field-wrapper">
            <iconify-icon icon="mdi:gas-station"></iconify-icon>
            <input type="number" id="t1" class="compact-input" placeholder="Ppal" step="1" autocomplete="off" />
            <span class="unit-tag">L</span>
        </div>
        <div class="field-wrapper">
            <iconify-icon icon="mdi:gas-station-outline"></iconify-icon>
            <input type="number" id="t2" class="compact-input" placeholder="Aux" step="1" autocomplete="off" />
            <span class="unit-tag">L</span>
        </div>
    </div>
  </div>

  <div class="compact-group">
    <label for="f-current">Combustible Actual</label>
    <div class="field-wrapper">
        <iconify-icon icon="mdi:water-percent"></iconify-icon>
        <input type="number" id="f-current" class="compact-input" placeholder="0" step="1" autocomplete="off" />
        <span class="unit-tag">Litros</span>
    </div>
  </div>

  <div class="compact-group">
    <label for="sea-s">Condiciones Mar/Viento</label>
    <div class="field-wrapper">
        <iconify-icon icon="mdi:waves"></iconify-icon>
        <select id="sea-s" class="compact-select">
            <option value="1.0">Calma (1.0x)</option>
            <option value="1.15">Marejadilla (+15%)</option>
            <option value="1.30">Marejada (+30%)</option>
            <option value="1.60">Temporal (+60%)</option>
        </select>
        <iconify-icon icon="mdi:chevron-down" style="left: auto; right: 10px; pointer-events: none;"></iconify-icon>
    </div>
  </div>

  <div class="compact-group">
    <label for="f-cons">Consumo Teórico</label>
    <div class="field-wrapper">
        <iconify-icon icon="mdi:timer-sand"></iconify-icon>
        <input type="number" id="f-cons" class="compact-input" placeholder="0.0" step="0.1" autocomplete="off" />
        <span class="unit-tag">L/h</span>
    </div>
  </div>

  <div class="compact-group">
    <label for="v-cruiser">Velocidad Crucero</label>
    <div class="field-wrapper">
        <iconify-icon icon="mdi:speedometer"></iconify-icon>
        <input type="number" id="v-cruiser" class="compact-input" placeholder="0.0" step="0.1" autocomplete="off" />
        <span class="unit-tag">Kn</span>
    </div>
  </div>

  <div class="input-row">
    <div class="compact-group">
        <label for="f-res">Reserva</label>
        <div class="field-wrapper">
            <input type="number" id="f-res" class="compact-input" value="20" style="padding-left: 0.8rem;" />
            <span class="unit-tag">%</span>
        </div>
    </div>
    <div class="compact-group">
        <label for="f-price">Precio Litro</label>
        <div class="field-wrapper">
            <input type="number" id="f-price" class="compact-input" placeholder="0.00" style="padding-left: 0.8rem;" />
            <span class="unit-tag">€</span>
        </div>
    </div>
  </div>
</div>
