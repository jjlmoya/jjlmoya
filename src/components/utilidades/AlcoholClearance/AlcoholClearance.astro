---
import { Icon } from "astro-icon/components";
import "./AlcoholClearance.css";
---

<div class="alcohol-clearance-container">
    <div class="converter-card animate-in fade-in slide-in-from-bottom duration-700">
        <div class="profile-section">
            <div class="input-group">
                <label>
                    <Icon name="mdi:gender-male-female" />
                    Sexo Biológico
                </label>
                <div class="visual-selector">
                    <button
                        class="visual-btn active"
                        data-gender="male"
                        data-r="0.68"
                        title="Hombre"
                    >
                        <Icon name="mdi:gender-male" />
                    </button>
                    <button class="visual-btn" data-gender="female" data-r="0.55" title="Mujer">
                        <Icon name="mdi:gender-female" />
                    </button>
                </div>
            </div>
            <div class="input-group">
                <label for="weight">
                    <Icon name="mdi:weight-kilogram" />
                    Peso Corporal
                </label>
                <div class="input-wrapper">
                    <input type="number" id="weight" value="75" step="1" min="30" max="250" />
                    <span class="unit-tag">kg</span>
                </div>
            </div>
        </div>

        <div class="drinks-selector">
            <div class="input-group">
                <label>
                    <Icon name="mdi:plus-circle-outline" />
                    Añadir Bebida Consumida
                </label>
            </div>
            <div class="selector-grid">
                <button class="drink-btn" data-type="beer">
                    <Icon name="mdi:beer" />
                    <span class="drink-name">Cerveza</span>
                    <span class="drink-info">330ml • 5%</span>
                </button>
                <button class="drink-btn" data-type="wine">
                    <Icon name="mdi:glass-wine" />
                    <span class="drink-name">Vino</span>
                    <span class="drink-info">150ml • 12%</span>
                </button>
                <button class="drink-btn" data-type="spirit">
                    <Icon name="mdi:glass-cocktail" />
                    <span class="drink-name">Copa</span>
                    <span class="drink-info">50ml • 40%</span>
                </button>
                <button class="drink-btn" data-type="shot">
                    <Icon name="mdi:glass-mug-variant" />
                    <span class="drink-name">Chupito</span>
                    <span class="drink-info">40ml • 40%</span>
                </button>
            </div>
        </div>

        <div class="consumed-section" id="consumed-section">
            <div class="list-header">
                <span>Consumo Acumulado</span>
                <span id="items-count"></span>
            </div>
            <div id="drinks-container">
                <div class="empty-placeholder">
                    <Icon name="mdi:glass-cocktail-off" class="empty-icon" />
                    <p>Tu lista de consumo está vacía</p>
                    <span>Selecciona bebidas arriba para empezar el cálculo</span>
                </div>
            </div>
        </div>

        <div class="results-section">
            <div class="result-main">
                <span class="result-label">Alcoholemia Estimada</span>
                <div class="bac-display">
                    <span class="bac-value" id="res-bac">0.00</span>
                    <span class="bac-unit">% BAC</span>
                </div>
                <div class="clearance-time" id="res-time-box">
                    <Icon name="mdi:clock-outline" />
                    <span id="res-time">0h 0m para 0.0</span>
                </div>
            </div>

            <div class="advice-cards">
                <div class="advice-card">
                    <div class="advice-icon icon-water">
                        <Icon name="mdi:water" />
                    </div>
                    <div class="advice-content">
                        <span class="advice-title">Agua (antes de dormir)</span>
                        <span class="advice-value" id="res-water">0 ml</span>
                    </div>
                </div>
                <div class="advice-card">
                    <div class="advice-icon icon-pill">
                        <Icon name="mdi:pill" />
                    </div>
                    <div class="advice-content">
                        <span class="advice-title">Electrolitos / Suplem.</span>
                        <span class="advice-value" id="res-pill">Sin necesidad</span>
                    </div>
                </div>
            </div>

            <div class="disclaimer">
                <Icon name="mdi:alert-circle" />
                <p>
                    Esta calculadora es solo una estimación teórica. Metabolismo, comida y otros
                    factores varían drásticamente. <strong>Si bebes, no conduzcas.</strong>
                </p>
            </div>
        </div>
    </div>

    <div id="icon-templates" style="display: none;">
        <div id="icon-beer"><Icon name="mdi:beer" /></div>
        <div id="icon-wine"><Icon name="mdi:glass-wine" /></div>
        <div id="icon-spirit"><Icon name="mdi:glass-cocktail" /></div>
        <div id="icon-shot"><Icon name="mdi:glass-mug-variant" /></div>
        <div id="icon-trash"><Icon name="mdi:trash-can-outline" /></div>
    </div>
</div>

<script>
    interface DrinkTemplate {
        name: string;
        size: number;
        abv: number;
        type: string;
    }

    const TEMPLATES: Record<string, DrinkTemplate> = {
        beer: { name: "Cerveza", size: 330, abv: 0.05, type: "beer" },
        wine: { name: "Vino", size: 150, abv: 0.12, type: "wine" },
        spirit: { name: "Copa", size: 50, abv: 0.4, type: "spirit" },
        shot: { name: "Chupito", size: 40, abv: 0.4, type: "shot" },
    };

    interface ConsumedDrink {
        id: string;
        name: string;
        grams: number;
        type: string;
    }
    const consumedDrinks: ConsumedDrink[] = [];
    let currentR = 0.68;

    const weightInput = document.getElementById("weight") as HTMLInputElement | null;
    const genderBtns = document.querySelectorAll(".visual-btn");
    const drinksContainer = document.getElementById("drinks-container");
    const drinkBtns = document.querySelectorAll(".drink-btn");
    const itemsCountLabel = document.getElementById("items-count");

    const resBac = document.getElementById("res-bac");
    const resTime = document.getElementById("res-time");
    const resWater = document.getElementById("res-water");
    const resPill = document.getElementById("res-pill");

    function updateUI() {
        if (!drinksContainer || !itemsCountLabel) return;

        if (consumedDrinks.length === 0) {
            drinksContainer.innerHTML = `
                <div class="empty-placeholder animate-in fade-in duration-500">
                    <svg class="empty-icon" viewBox="0 0 24 24" width="48" height="48" fill="currentColor" style="opacity: 0.2"><path d="M2,2.27L3.27,1L21,18.73L19.73,20L17.27,17.54L15.43,21H4.57L6.57,17.18L2,8.12L3.79,7.22L4.54,8.73L2,2.27M11,13L8,7.34V3H21V5.41L13.59,12.82L15,15.54L12.46,13L11,13M10,5V6.47L10.74,7.86L12.18,6.41L12.39,6.8L12.6,6.41L14,5H10Z"/></svg>
                    <p>Tu lista de consumo está vacía</p>
                    <span>Selecciona bebidas arriba para empezar el cálculo</span>
                </div>
            `;
            itemsCountLabel.textContent = "";
        } else {
            drinksContainer.innerHTML = "";

            const grouped: Record<string, { type: string; name: string; count: number }> = {};
            consumedDrinks.forEach((d: ConsumedDrink) => {
                if (!grouped[d.type]) {
                    grouped[d.type] = { type: d.type, name: d.name, count: 0 };
                }
                grouped[d.type].count++;
            });

            Object.values(grouped).forEach(
                (group: { type: string; name: string; count: number }) => {
                    const card = document.createElement("div");
                    card.className = "drink-card animate-in zoom-in duration-300";

                    const iconTpl = document.getElementById(`icon-${group.type}`);
                    if (iconTpl) {
                        const iconClone = iconTpl.cloneNode(true) as HTMLElement;
                        iconClone.style.display = "block";
                        card.appendChild(iconClone);
                    }

                    const nameSpan = document.createElement("span");
                    nameSpan.className = "card-name";
                    nameSpan.textContent = group.name;
                    card.appendChild(nameSpan);

                    if (group.count > 1) {
                        const badge = document.createElement("div");
                        badge.className = "count-badge";
                        badge.textContent = `x${group.count}`;
                        card.appendChild(badge);
                    }

                    const removeBtn = document.createElement("button");
                    removeBtn.className = "card-remove";

                    const trashTpl = document.getElementById("icon-trash");
                    if (trashTpl) {
                        const trashClone = trashTpl.cloneNode(true) as HTMLElement;
                        trashClone.style.display = "block";
                        removeBtn.appendChild(trashClone);
                    }
                    removeBtn.addEventListener("click", (e) => {
                        e.stopPropagation();
                        removeOne(group.type);
                    });
                    card.appendChild(removeBtn);

                    drinksContainer.appendChild(card);
                }
            );

            itemsCountLabel.textContent = `${consumedDrinks.length} bebida${consumedDrinks.length > 1 ? "s" : ""}`;
        }
        calculate();
    }

    function addDrink(type: string) {
        const template = TEMPLATES[type];
        if (!template) return;

        const alcoholGrams = template.size * template.abv * 0.8;
        const newDrink: ConsumedDrink = {
            id: Math.random().toString(36).substring(2, 9),
            name: template.name,
            grams: alcoholGrams,
            type: template.type,
        };

        consumedDrinks.push(newDrink);
        updateUI();
    }

    function removeOne(type: string) {
        const index = consumedDrinks.findIndex((d: ConsumedDrink) => d.type === type);
        if (index !== -1) {
            consumedDrinks.splice(index, 1);
            updateUI();
        }
    }

    function calculate() {
        if (!weightInput || !resBac || !resTime || !resWater || !resPill) return;

        const weight = parseFloat(weightInput.value) || 75;
        const r = currentR;
        const totalGrams = consumedDrinks.reduce(
            (sum: number, d: ConsumedDrink) => sum + d.grams,
            0
        );

        if (totalGrams === 0) {
            resBac.textContent = "0.00";
            resTime.textContent = "0h 0m para 0.0";
            resWater.textContent = "0 ml";
            resPill.textContent = "Sin necesidad";
            return;
        }

        const bacPermille = totalGrams / (weight * r);
        const bacPercent = bacPermille / 10;

        resBac.textContent = bacPercent.toFixed(3);

        const hours = bacPermille / 0.15;
        const h = Math.floor(hours);
        const m = Math.floor((hours - h) * 60);
        resTime.textContent = `${h}h ${m}m para estar a 0.0`;

        const waterMl = consumedDrinks.length * 250;
        resWater.textContent = `${waterMl} ml`;

        if (totalGrams > 30) {
            resPill.textContent = "Electrolitos + Vit. B";
        } else if (totalGrams > 0) {
            resPill.textContent = "Prioriza Hidratación";
        } else {
            resPill.textContent = "Sin necesidad";
        }
    }

    drinkBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const type = (btn as HTMLElement).dataset.type;
            if (type) addDrink(type);
        });
    });

    genderBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            genderBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            currentR = parseFloat((btn as HTMLElement).dataset.r || "0.68");
            calculate();
        });
    });

    weightInput?.addEventListener("input", calculate);

    calculate();
</script>
