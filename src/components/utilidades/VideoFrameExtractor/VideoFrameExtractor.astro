---
import { Icon } from "astro-icon/components";
import "./VideoFrameExtractor.css";
---

<div class="video-extractor-super-container">
    <div class="premium-card">
        <!-- Step 1: Upload -->
        <div id="uploadBox" class="uploader-box">
            <div class="uploader-icon">
                <Icon name="mdi:video-plus" />
            </div>
            <div class="uploader-text">
                <h3>Sube un archivo de vídeo</h3>
                <p>MP4, WebM, MOV o MKV (Máx. 500MB)</p>
            </div>
            <input type="file" id="videoInput" accept="video/*" class="hidden" />
            <div
                style="font-size: 0.75rem; color: #94a3b8; font-weight: 700; text-transform: uppercase;"
            >
                El vídeo no se sube a Internet, se procesa en tu navegador.
            </div>
        </div>

        <!-- Step 2: Main Player & Controls -->
        <div id="playerArea" class="player-container hidden">
            <div class="video-wrapper">
                <video id="mainVideo" preload="metadata"></video>
            </div>

            <div class="controls-glass">
                <div class="time-row">
                    <span id="currentTime">00:00.000</span>
                    <span id="duration">00:00.000</span>
                </div>

                <input
                    type="range"
                    id="timeSlider"
                    class="scrubber-slider"
                    min="0"
                    max="100"
                    step="0.001"
                    value="0"
                    aria-label="Progreso del video"
                />

                <div class="actions-row">
                    <button id="prevFrame" class="btn-main btn-control" title="Retroceder 1 frame">
                        <Icon name="mdi:chevron-left" />
                        <span>-1F</span>
                    </button>
                    <button id="playBtn" class="btn-main btn-control" title="Reproducir/Pausar">
                        <Icon name="mdi:play" />
                        <span id="playText">Play</span>
                    </button>
                    <button id="nextFrame" class="btn-main btn-control" title="Avanzar 1 frame">
                        <span>+1F</span>
                        <Icon name="mdi:chevron-right" />
                    </button>
                </div>

                <div class="actions-row">
                    <button
                        id="captureBtn"
                        class="btn-main btn-capture"
                        title="Capturar frame actual"
                    >
                        <Icon name="mdi:camera-plus" />
                        <span>Capturar Frame</span>
                    </button>
                    <button
                        id="resetBtn"
                        class="btn-main btn-control"
                        title="Subir otro vídeo"
                        style="flex: none; width: 50px;"
                    >
                        <Icon name="mdi:refresh" />
                    </button>
                </div>

                <!-- Batch Extraction Panel -->
                <div class="batch-panel">
                    <div class="batch-header">
                        <Icon name="mdi:auto-fix" />
                        <span>Extracción Automática</span>
                    </div>
                    <div class="batch-controls">
                        <div class="batch-input-group">
                            <label>Cada:</label>
                            <input
                                type="number"
                                id="batchInterval"
                                value="1"
                                min="0.1"
                                step="0.1"
                            />
                            <label>seg</label>
                        </div>
                        <button
                            id="startBatchBtn"
                            class="btn-main btn-capture"
                            style="padding: 0.5rem 1rem; font-size: 0.8rem;"
                        >
                            Iniciar Secuencia
                        </button>
                    </div>
                </div>
            </div>

            <!-- Gallery Section -->
            <div class="gallery-minimal">
                <div class="gallery-header">
                    <h4>Frames Capturados</h4>
                    <button
                        id="downloadAllBtn"
                        class="btn-main btn-control hidden"
                        style="padding: 0.5rem 0.75rem; font-size: 0.75rem; flex: none;"
                    >
                        <Icon name="mdi:download-multiple" />
                        Descargar Todo
                    </button>
                </div>

                <div id="framesGallery" class="frames-scroll">
                    <div
                        style="padding: 1.5rem; text-align: center; color: var(--text-muted); font-size: 0.85rem; width: 100%;"
                    >
                        Las capturas aparecerán aquí conforme las realices.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Simple Lightbox -->
<div id="lightbox" class="v-lightbox">
    <div class="v-lightbox-content">
        <span id="closeLightbox" class="v-close">&times;</span>
        <img id="lightboxImg" class="v-lightbox-img" src="" alt="Vista previa del frame" />
        <div class="actions-row" style="width: 100%; justify-content: center;">
            <a
                id="lightboxDownload"
                class="btn-main btn-capture"
                style="flex: none; padding: 0.8rem 1.5rem;"
                href=""
                download="frame.png"
            >
                <Icon name="mdi:download" />
                Descargar Imagen HD
            </a>
        </div>
    </div>
</div>

<script>
    function convertToTime(seconds: number): string {
        const date = new Date(seconds * 1000);
        const mm = date.getUTCMinutes().toString().padStart(2, "0");
        const ss = date.getUTCSeconds().toString().padStart(2, "0");
        const ms = Math.floor(date.getUTCMilliseconds()).toString().padStart(3, "0");
        return `${mm}:${ss}.${ms}`;
    }

    const videoInput = document.getElementById("videoInput") as HTMLInputElement | null;
    const uploadBox = document.getElementById("uploadBox") as HTMLElement | null;
    const playerArea = document.getElementById("playerArea") as HTMLElement | null;
    const mainVideo = document.getElementById("mainVideo") as HTMLVideoElement | null;
    const playBtn = document.getElementById("playBtn") as HTMLButtonElement | null;
    const playText = document.getElementById("playText") as HTMLElement | null;
    const captureBtn = document.getElementById("captureBtn") as HTMLButtonElement | null;
    const timeSlider = document.getElementById("timeSlider") as HTMLInputElement | null;
    const currentTimeEl = document.getElementById("currentTime") as HTMLElement | null;
    const durationEl = document.getElementById("duration") as HTMLElement | null;
    const framesGallery = document.getElementById("framesGallery") as HTMLElement | null;
    const resetBtn = document.getElementById("resetBtn") as HTMLButtonElement | null;
    const lightbox = document.getElementById("lightbox") as HTMLElement | null;
    const lightboxImg = document.getElementById("lightboxImg") as HTMLImageElement | null;
    const lightboxDownload = document.getElementById(
        "lightboxDownload"
    ) as HTMLAnchorElement | null;
    const closeLightbox = document.getElementById("closeLightbox") as HTMLElement | null;
    const nextFrame = document.getElementById("nextFrame") as HTMLButtonElement | null;
    const prevFrame = document.getElementById("prevFrame") as HTMLButtonElement | null;
    const batchInterval = document.getElementById("batchInterval") as HTMLInputElement | null;
    const startBatchBtn = document.getElementById("startBatchBtn") as HTMLButtonElement | null;
    const downloadAllBtn = document.getElementById("downloadAllBtn") as HTMLButtonElement | null;

    let capturedFrames: { id: string; url: string; timestamp: number }[] = [];
    const FRAME_RATE = 1 / 30; // Default fallback to 30fps

    if (videoInput && mainVideo && uploadBox && playerArea) {
        uploadBox.addEventListener("click", (e) => {
            if (e.target !== videoInput) videoInput.click();
        });

        videoInput.addEventListener("change", (e: Event) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            if (file) {
                const url = URL.createObjectURL(file);
                mainVideo.src = url;
                uploadBox.classList.add("hidden");
                playerArea.classList.remove("hidden");
                mainVideo.load();
            }
        });

        mainVideo.addEventListener("loadedmetadata", () => {
            if (durationEl && timeSlider) {
                durationEl.textContent = convertToTime(mainVideo.duration);
                timeSlider.max = mainVideo.duration.toString();
            }
        });

        mainVideo.addEventListener("timeupdate", () => {
            if (currentTimeEl && timeSlider) {
                currentTimeEl.textContent = convertToTime(mainVideo.currentTime);
                timeSlider.value = mainVideo.currentTime.toString();
            }
        });

        playBtn?.addEventListener("click", () => {
            if (mainVideo.paused) {
                mainVideo.play();
                if (playText) playText.textContent = "Pausa";
            } else {
                mainVideo.pause();
                if (playText) playText.textContent = "Play";
            }
        });

        timeSlider?.addEventListener("input", () => {
            mainVideo.currentTime = parseFloat(timeSlider.value);
            if (currentTimeEl) currentTimeEl.textContent = convertToTime(mainVideo.currentTime);
        });

        captureBtn?.addEventListener("click", () => {
            captureFrame();
        });

        nextFrame?.addEventListener("click", () => {
            mainVideo.pause();
            mainVideo.currentTime += FRAME_RATE;
        });

        prevFrame?.addEventListener("click", () => {
            mainVideo.pause();
            mainVideo.currentTime -= FRAME_RATE;
        });

        startBatchBtn?.addEventListener("click", async () => {
            if (!batchInterval) return;
            const interval = parseFloat(batchInterval.value);
            if (isNaN(interval) || interval <= 0) return;

            startBatchBtn.disabled = true;
            const originalText = startBatchBtn.innerText;
            startBatchBtn.innerText = "Extrayendo...";

            const duration = mainVideo.duration;
            const originalTime = mainVideo.currentTime;

            mainVideo.pause();

            for (let t = 0; t <= duration; t += interval) {
                mainVideo.currentTime = t;
                await new Promise((resolve) => {
                    const onSeek = () => {
                        captureFrame();
                        mainVideo.removeEventListener("seeked", onSeek);
                        resolve(null);
                    };
                    mainVideo.addEventListener("seeked", onSeek);
                });
            }

            mainVideo.currentTime = originalTime;
            startBatchBtn.disabled = false;
            startBatchBtn.innerText = originalText;
        });

        resetBtn?.addEventListener("click", () => {
            mainVideo.pause();
            mainVideo.src = "";
            playerArea.classList.add("hidden");
            uploadBox.classList.remove("hidden");
            videoInput.value = "";
            capturedFrames = [];
            renderFrames();
        });
    }

    function captureFrame() {
        if (!mainVideo) return;
        const canvas = document.createElement("canvas");
        canvas.width = mainVideo.videoWidth;
        canvas.height = mainVideo.videoHeight;
        const ctx = canvas.getContext("2d");

        if (ctx) {
            ctx.drawImage(mainVideo, 0, 0, canvas.width, canvas.height);
            const url = canvas.toDataURL("image/png", 1.0);
            const timestamp = mainVideo.currentTime;
            const id = Math.random().toString(36).substring(7);

            capturedFrames.push({ id, url, timestamp });
            renderFrames();
        }
    }

    function renderFrames() {
        if (!framesGallery) return;

        if (capturedFrames.length === 0) {
            framesGallery.innerHTML = `
                <div style="padding: 1.5rem; text-align: center; color: var(--text-muted); font-size: 0.85rem; width: 100%;">
                    Las capturas aparecerán aquí conforme las realices.
                </div>
            `;
            downloadAllBtn?.classList.add("hidden");
            return;
        }

        downloadAllBtn?.classList.remove("hidden");
        framesGallery.innerHTML = "";
        capturedFrames
            .slice()
            .reverse()
            .forEach((frame) => {
                const card = document.createElement("div");
                card.className = "frame-mini-card";
                card.innerHTML = `
                    <img src="${frame.url}" class="frame-img-box" alt="Frame ${frame.timestamp}" />
                    <button class="btn-del-mini" data-id="${frame.id}">&times;</button>
                    <div class="frame-footer">
                        <span class="frame-stamp">${convertToTime(frame.timestamp)}</span>
                        <a href="${frame.url}" download="frame_${frame.timestamp.toFixed(2)}s.png" style="color: var(--brand-primary); cursor: pointer;" title="Descargar">
                           <svg style="width: 14px; height: 14px;" viewBox="0 0 24 24"><path fill="currentColor" d="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" /></svg>
                        </a>
                    </div>
                `;

                card.querySelector(".frame-img-box")?.addEventListener("click", () => {
                    if (lightbox && lightboxImg && lightboxDownload) {
                        lightboxImg.src = frame.url;
                        lightboxDownload.href = frame.url;
                        lightbox.classList.add("active");
                    }
                });

                card.querySelector(".btn-del-mini")?.addEventListener("click", (e) => {
                    const id = (e.target as HTMLElement).getAttribute("data-id");
                    capturedFrames = capturedFrames.filter((f) => f.id !== id);
                    renderFrames();
                });

                framesGallery.appendChild(card);
            });
    }

    closeLightbox?.addEventListener("click", () => {
        lightbox?.classList.remove("active");
    });

    lightbox?.addEventListener("click", (e) => {
        if (e.target === lightbox) {
            lightbox.classList.remove("active");
        }
    });

    downloadAllBtn?.addEventListener("click", () => {
        capturedFrames.forEach((frame, index) => {
            setTimeout(() => {
                const link = document.createElement("a");
                link.href = frame.url;
                link.download = `frame_${index}_${frame.timestamp.toFixed(1)}s.png`;
                link.click();
            }, index * 200);
        });
    });
</script>
