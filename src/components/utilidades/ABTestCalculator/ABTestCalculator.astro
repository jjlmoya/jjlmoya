---
import { Icon } from "astro-icon/components";
import "./ABTestCalculator.css";
---

<style>
    .math-sym {
        font-style: italic;
        font-weight: 600;
    }
</style>

<div class="abtest-card" id="abTestApp">
    <aside class="abtest-sidebar">
        <div class="sidebar-heading">
            <Icon name="mdi:tune-vertical" /> Parámetros
        </div>

        <div class="type-toggle" id="testType">
            <button class="toggle-btn active" data-type="proportions">Conversiones</button>
            <button class="toggle-btn" data-type="means">Medias</button>
        </div>

        <div class="group-section group-a">
            <div class="group-title"><Icon name="mdi:alpha-a-circle" /> Grupo A (Control)</div>

            <div class="input-row">
                <label for="nA">Casos Totales <span class="math-sym">n₁</span></label>
                <input type="number" id="nA" value="1000" min="1" step="1" />
            </div>

            <div class="input-row type-prop">
                <label for="sA">Éxitos o Conversiones <span class="math-sym">x₁</span></label>
                <input type="number" id="sA" value="150" min="0" step="1" />
            </div>

            <div class="input-row type-mean" style="display: none;">
                <label for="mA">Media Promedio <span class="math-sym">μ₁</span></label>
                <input type="number" id="mA" value="50" step="0.1" />
            </div>

            <div class="input-row type-mean" style="display: none;">
                <label for="sdA">Desviación Típica <span class="math-sym">σ₁</span></label>
                <input type="number" id="sdA" value="10" min="0" step="0.1" />
            </div>
        </div>

        <div class="group-section group-b">
            <div class="group-title"><Icon name="mdi:alpha-b-circle" /> Grupo B (Variante)</div>

            <div class="input-row">
                <label for="nB">Casos Totales <span class="math-sym">n₂</span></label>
                <input type="number" id="nB" value="1000" min="1" step="1" />
            </div>

            <div class="input-row type-prop">
                <label for="sB">Éxitos o Conversiones <span class="math-sym">x₂</span></label>
                <input type="number" id="sB" value="200" min="0" step="1" />
            </div>

            <div class="input-row type-mean" style="display: none;">
                <label for="mB">Media Promedio <span class="math-sym">μ₂</span></label>
                <input type="number" id="mB" value="53" step="0.1" />
            </div>

            <div class="input-row type-mean" style="display: none;">
                <label for="sdB">Desviación Típica <span class="math-sym">σ₂</span></label>
                <input type="number" id="sdB" value="10" min="0" step="0.1" />
            </div>
        </div>

        <div class="group-section">
            <div class="input-row">
                <label for="alpha">Nivel de Significancia <span class="math-sym">α</span></label>
                <select
                    id="alpha"
                    style="padding: 0.5rem; border-radius: 0.5rem; border: 1px solid #cbd5e1; background: #fff; font-weight: 600; color: #0f172a;"
                >
                    <option value="0.10">0.10 (90%)</option>
                    <option value="0.05" selected>0.05 (95%)</option>
                    <option value="0.01">0.01 (99%)</option>
                </select>
            </div>
            <div class="input-row" style="margin-top: 0.75rem;">
                <label>Dirección del Test</label>
                <div class="type-toggle" id="tailsType">
                    <button class="toggle-btn active" data-type="two">2 Colas (Dif.)</button>
                    <button class="toggle-btn" data-type="one">1 Cola (B &gt; A)</button>
                </div>
            </div>
        </div>
    </aside>

    <main class="abtest-main">
        <div
            id="extremeAlert"
            style="display: none; background: #fffbeb; border: 1px solid #fde68a; padding: 1rem; border-radius: 0.75rem; margin-bottom: 0.5rem;"
        >
            <div
                style="color: #d97706; font-weight: 800; font-size: 0.9rem; margin-bottom: 0.25rem;"
            >
                ⚠️ Advertencia de Fiabilidad Estadística
            </div>
            <p style="color: #92400e; font-size: 0.85rem; margin: 0; font-weight: 500;">
                Estás utilizando un tamaño de muestra muy pequeño o valores extremos (0 éxitos). La
                estimación puede no ser representativa del mundo real. <a
                    href="/utilidades/calculadora-tamano-muestra/"
                    style="color: #b45309; text-decoration: underline; font-weight: 700;"
                    >Calcula tu tamaño muestral ideal aquí</a
                >.
            </p>
        </div>

        <section class="results-grid">
            <div class="pvalue-block" id="pvalueBlock">
                <div class="pval-title">P-Valor (<span class="math-sym">p</span>)</div>
                <div class="pval-value" id="res-pvalue">0.000</div>
                <div class="pval-desc" id="res-desc">
                    Hay evidencia suficiente para rechazar la hipótesis nula
                </div>
            </div>

            <div class="lift-block">
                <div class="lift-header">
                    <Icon name="mdi:rocket-launch" /> Análisis de Mejora (Lift)
                </div>
                <div class="lift-content">
                    <span class="lift-value" id="res-lift">0%</span>
                    <span class="lift-text" id="res-lift-text">de mejora respecto al Grupo A</span>
                </div>

                <div class="confidence-bar-container">
                    <div class="confidence-fill" id="confBar"></div>
                </div>
                <div class="confidence-text" id="confText">Confianza estadística: 0%</div>
            </div>
        </section>

        <section class="visual-section">
            <div class="block-title">
                <Icon name="mdi:chart-bell-curve" /> Distribuciones de Probabilidad
            </div>
            <p class="chart-desc">
                Observa el solapamiento: menor solapamiento implica mayor certeza de que las
                diferencias son reales y no fruto del azar.
            </p>
            <canvas id="curvesCanvas"></canvas>
        </section>

        <section class="text-copy-block">
            <div class="copy-header">
                <Icon name="mdi:text-box-outline" />
                <span>Texto para tu informe</span>
            </div>
            <p id="justificationText" class="copy-text">
                Tras analizar X sujetos, el Grupo B presenta una mejora del Y% con una confianza
                estadística del Z% (p=0.00). Muestra diferencias significativas.
            </p>
            <button class="copy-btn" id="copyTextBtn"
                ><Icon name="mdi:content-copy" /> Copiar Texto</button
            >
        </section>

        <footer class="action-bar">
            <div class="link-promo">
                ¿No tienes suficientes datos aún?
                <a href="/utilidades/calculadora-tamano-muestra/" class="promo-link"
                    >Calcula el Tamaño de Muestra necesario</a
                >
            </div>
        </footer>
    </main>
</div>

<script>
    const testType = document.getElementById("testType");
    const tailsType = document.getElementById("tailsType");
    const typeProps = document.querySelectorAll(".type-prop");
    const typeMeans = document.querySelectorAll(".type-mean");

    const nA = document.getElementById("nA") as HTMLInputElement;
    const sA = document.getElementById("sA") as HTMLInputElement;
    const mA = document.getElementById("mA") as HTMLInputElement;
    const sdA = document.getElementById("sdA") as HTMLInputElement;

    const nB = document.getElementById("nB") as HTMLInputElement;
    const sB = document.getElementById("sB") as HTMLInputElement;
    const mB = document.getElementById("mB") as HTMLInputElement;
    const sdB = document.getElementById("sdB") as HTMLInputElement;

    const alphaInput = document.getElementById("alpha") as HTMLSelectElement;

    const canvas = document.getElementById("curvesCanvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d");

    let currentMode = "proportions";
    let currentTails = "two";

    const normCDF = (x: number): number => {
        const t = 1 / (1 + 0.2316419 * Math.abs(x));
        const d = 0.3989422804 * Math.exp((-x * x) / 2);
        const p =
            d *
            t *
            (0.31938153 +
                t * (-0.356563782 + t * (1.781477937 + t * (-1.821255978 + t * 1.330274429))));
        return x > 0 ? 1 - p : p;
    };

    const drawCurves = (meanA: number, seA: number, meanB: number, seB: number) => {
        if (!ctx || !canvas) return;
        const dpr = window.devicePixelRatio || 1;
        const cw = canvas.offsetWidth;
        const ch = canvas.offsetHeight;
        canvas.width = Math.round(cw * dpr);
        canvas.height = Math.round(ch * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, cw, ch);

        const pad = 30;
        const W = cw - pad * 2;
        const H = ch - pad * 2;

        const minX = Math.min(meanA - 4 * seA, meanB - 4 * seB);
        const maxX = Math.max(meanA + 4 * seA, meanB + 4 * seB);
        const range = maxX - minX || 1;

        const maxPdfA = 1 / (seA * Math.sqrt(2 * Math.PI));
        const maxPdfB = 1 / (seB * Math.sqrt(2 * Math.PI));
        const maxY = Math.max(maxPdfA, maxPdfB) * 1.1;

        const toScreenX = (x: number) => pad + ((x - minX) / range) * W;
        const toScreenY = (y: number) => pad + H - (y / maxY) * H;

        const pdf = (x: number, m: number, s: number) => {
            return (1 / (s * Math.sqrt(2 * Math.PI))) * Math.exp(-0.5 * Math.pow((x - m) / s, 2));
        };

        const drawCurve = (m: number, s: number, color: string, fill: string) => {
            ctx.beginPath();
            ctx.moveTo(toScreenX(minX), toScreenY(0));
            for (let i = 0; i <= 150; i++) {
                const x = minX + (i / 150) * range;
                const y = pdf(x, m, s);
                ctx.lineTo(toScreenX(x), toScreenY(y));
            }
            ctx.lineTo(toScreenX(maxX), toScreenY(0));
            ctx.fillStyle = fill;
            ctx.fill();
            ctx.lineWidth = 2;
            ctx.strokeStyle = color;
            ctx.stroke();

            ctx.beginPath();
            ctx.setLineDash([4, 4]);
            ctx.moveTo(toScreenX(m), toScreenY(0));
            ctx.lineTo(toScreenX(m), toScreenY(pdf(m, m, s)));
            ctx.stroke();
            ctx.setLineDash([]);
        };

        ctx.beginPath();
        ctx.strokeStyle = "#cbd5e1";
        ctx.lineWidth = 1;
        ctx.moveTo(pad, pad + H);
        ctx.lineTo(pad + W, pad + H);
        ctx.stroke();

        drawCurve(meanA, seA, "#64748b", "rgba(100, 116, 139, 0.2)");
        drawCurve(meanB, seB, "#f43f5e", "rgba(244, 63, 94, 0.2)");

        ctx.fillStyle = "#1e293b";
        ctx.font = "bold 12px sans-serif";
        ctx.textAlign = "center";

        const meanDisplayA =
            currentMode === "proportions" ? (meanA * 100).toFixed(1) + "%" : meanA.toFixed(2);
        const meanDisplayB =
            currentMode === "proportions" ? (meanB * 100).toFixed(1) + "%" : meanB.toFixed(2);

        ctx.fillText(`A: ${meanDisplayA}`, toScreenX(meanA), pad + H + 20);
        ctx.fillStyle = "#e11d48";
        ctx.fillText(`B: ${meanDisplayB}`, toScreenX(meanB), pad + H + 20);
    };

    const update = () => {
        const numA = parseFloat(nA.value) || 1;
        const numB = parseFloat(nB.value) || 1;
        const alpha = parseFloat(alphaInput.value) || 0.05;

        let Z = 0;
        let pValue = 1;
        let lift = 0;
        let statA = 0;
        let statB = 0;
        let seA = 1;
        let seB = 1;

        if (currentMode === "proportions") {
            const sucA = parseFloat(sA.value) || 0;
            const sucB = parseFloat(sB.value) || 0;

            const pA = sucA / numA;
            const pB = sucB / numB;
            statA = pA;
            statB = pB;

            const pooledP = (sucA + sucB) / (numA + numB);
            const se = Math.sqrt(pooledP * (1 - pooledP) * (1 / numA + 1 / numB));

            seA = Math.sqrt((pA * (1 - pA)) / numA) || 0.0001;
            seB = Math.sqrt((pB * (1 - pB)) / numB) || 0.0001;

            if (se > 0) {
                Z = (pB - pA) / se;
                if (currentTails === "two") {
                    pValue = 2 * (1 - normCDF(Math.abs(Z)));
                } else {
                    pValue = Z > 0 ? 1 - normCDF(Z) : 1;
                }
            }
            lift = pA > 0 ? ((pB - pA) / pA) * 100 : 0;
        } else {
            const meanA = parseFloat(mA.value) || 0;
            const stdA = parseFloat(sdA.value) || 1;
            const meanB = parseFloat(mB.value) || 0;
            const stdB = parseFloat(sdB.value) || 1;

            statA = meanA;
            statB = meanB;
            seA = stdA / Math.sqrt(numA);
            seB = stdB / Math.sqrt(numB);

            const se = Math.sqrt((stdA * stdA) / numA + (stdB * stdB) / numB);
            if (se > 0) {
                Z = (meanB - meanA) / se;
                if (currentTails === "two") {
                    pValue = 2 * (1 - normCDF(Math.abs(Z)));
                } else {
                    pValue = Z > 0 ? 1 - normCDF(Z) : 1;
                }
            }
            lift = meanA !== 0 ? ((meanB - meanA) / Math.abs(meanA)) * 100 : 0;
        }

        const isSignificant = pValue < alpha;

        const pvalBlock = document.getElementById("pvalueBlock")!;
        pvalBlock.className = "pvalue-block " + (isSignificant ? "significant" : "not-significant");
        document.getElementById("res-pvalue")!.textContent =
            pValue < 0.001 ? "<0.001" : pValue.toFixed(3);

        const desc = isSignificant
            ? "Hay evidencia suficiente para rechazar la hipótesis nula."
            : "La diferencia no es estadísticamente significativa.";
        document.getElementById("res-desc")!.textContent = desc;

        const alertBox = document.getElementById("extremeAlert");
        if (
            numA < 30 ||
            numB < 30 ||
            (currentMode === "proportions" &&
                (statA === 0 || statB === 0 || statA === 1 || statB === 1))
        ) {
            alertBox!.style.display = "block";
        } else {
            alertBox!.style.display = "none";
        }

        const liftEl = document.getElementById("res-lift")!;
        liftEl.textContent = (lift > 0 ? "+" : "") + lift.toFixed(2) + "%";
        liftEl.className = "lift-value " + (lift > 0 ? "positive" : "negative");

        const confidence = (1 - pValue) * 100;
        document.getElementById("confBar")!.style.width = Math.min(confidence, 100) + "%";
        document.getElementById("confText")!.textContent =
            `Confianza estadística: ${confidence.toFixed(2)}%`;

        let justText = `Tras analizar un total de ${numA + numB} muestras, el Grupo B presenta un cambio del ${lift > 0 ? "+" : ""}${lift.toFixed(2)}% respecto al Grupo A. `;
        justText += `Con una confianza estadística del ${confidence.toFixed(2)}% (p=${pValue.toFixed(3)}), la diferencia empírica ${isSignificant ? "ES estadísticamente significativa" : "NO es estadísticamente significativa"}.`;
        document.getElementById("justificationText")!.textContent = justText;

        drawCurves(statA, seA, statB, seB);
    };

    testType?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".toggle-btn");
        if (!btn) return;
        testType.querySelectorAll(".toggle-btn").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        currentMode = (btn as HTMLElement).dataset.type!;

        if (currentMode === "proportions") {
            typeProps.forEach((el) => ((el as HTMLElement).style.display = "flex"));
            typeMeans.forEach((el) => ((el as HTMLElement).style.display = "none"));
        } else {
            typeProps.forEach((el) => ((el as HTMLElement).style.display = "none"));
            typeMeans.forEach((el) => ((el as HTMLElement).style.display = "flex"));
        }
        update();
    });

    tailsType?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".toggle-btn");
        if (!btn) return;
        tailsType.querySelectorAll(".toggle-btn").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        currentTails = (btn as HTMLElement).dataset.type!;
        update();
    });

    [nA, sA, mA, sdA, nB, sB, mB, sdB, alphaInput].forEach((el) => {
        el.addEventListener("input", update);
        el.addEventListener("change", update);
    });

    window.addEventListener("resize", update);

    const copyBtn = document.getElementById("copyTextBtn");
    copyBtn?.addEventListener("click", () => {
        const text = document.getElementById("justificationText")!.textContent || "";
        navigator.clipboard.writeText(text);
        const t = copyBtn.innerHTML;
        copyBtn.innerHTML = "¡Copiado!";
        setTimeout(() => (copyBtn.innerHTML = t), 1500);
    });

    update();
</script>
