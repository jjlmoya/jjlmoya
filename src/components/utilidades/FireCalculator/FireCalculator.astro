---
import { Icon } from "astro-icon/components";
import "./FireCalculator.css";
---

<div class="fire-container" id="fire-calculator-main">
    <div class="fire-grid">
        <div class="fire-panel">
            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">Gastos Mensuales</label>
                    <span class="fire-value-display" id="val-expenses">2.500 €</span>
                </div>
                <input
                    type="range"
                    id="fire-expenses"
                    class="fire-range"
                    min="500"
                    max="10000"
                    step="50"
                    value="2500"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">
                        Tasa de Retirada (SWR)
                        <div class="fire-help">
                            <Icon name="mdi:information-outline" size={16} />
                            <span class="fire-tooltip">Safe Withdrawal Rate: Porcentaje de tus ahorros que puedes retirar cada año sin quedarte sin dinero.</span>
                        </div>
                    </label>
                    <span class="fire-value-display" id="val-swr">4.0 %</span>
                </div>
                <input
                    type="range"
                    id="fire-swr"
                    class="fire-range"
                    min="2.5"
                    max="6.0"
                    step="0.1"
                    value="4.0"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">Patrimonio Actual</label>
                    <span class="fire-value-display" id="val-worth-display">50.000 €</span>
                </div>
                <input
                    type="range"
                    id="fire-worth"
                    class="fire-range"
                    min="0"
                    max="1000000"
                    step="1000"
                    value="50000"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">Capacidad de Ahorro Mensual</label>
                    <span class="fire-value-display" id="val-savings">1.000 €</span>
                </div>
                <input
                    type="range"
                    id="fire-savings"
                    class="fire-range"
                    min="0"
                    max="5000"
                    step="50"
                    value="1000"
                />
            </div>

            <div class="fire-input-group">
                <div class="fire-label-row">
                    <label class="fire-label">
                        Rentabilidad Estimada (Neto)
                        <div class="fire-help">
                            <Icon name="mdi:information-outline" size={16} />
                            <span class="fire-tooltip">Rendimiento anual del mercado (ya descontada la inflación). El estándar histórico es el 7%.</span>
                        </div>
                    </label>
                    <span class="fire-value-display" id="val-return">7.0 %</span>
                </div>
                <input
                    type="range"
                    id="fire-return"
                    class="fire-range"
                    min="1"
                    max="12"
                    step="0.5"
                    value="7"
                />
            </div>

            <div class="fire-checklist">
                <h4>Hitos de Libertad</h4>
                <div class="fire-milestones">
                    <div class="milestone-item lean">
                        <div class="milestone-header">
                            <span>Lean FIRE (70% supervivencia)</span>
                            <span id="label-lean">0%</span>
                        </div>
                        <div class="milestone-bar-bg">
                            <div class="milestone-bar-fill" id="bar-lean" style="width: 0%"></div>
                        </div>
                    </div>
                    <div class="milestone-item barista">
                        <div class="milestone-header">
                            <span>Barista FIRE (50% ingresos)</span>
                            <span id="label-barista">0%</span>
                        </div>
                        <div class="milestone-bar-bg">
                            <div class="milestone-bar-fill" id="bar-barista" style="width: 0%"></div>
                        </div>
                    </div>
                    <div class="milestone-item fat">
                        <div class="milestone-header">
                            <span>Fat FIRE (150% lujo)</span>
                            <span id="label-fat">0%</span>
                        </div>
                        <div class="milestone-bar-bg">
                            <div class="milestone-bar-fill" id="bar-fat" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="fire-result-panel">
            <div class="fire-main-result">
                <span class="fire-magic-number-label">Tu Número Mágico para ser Libre</span>
                <div class="fire-magic-number" id="fire-number">750.000 €</div>
                <div class="fire-countdown" id="fire-time">Te faltan 21 años y 4 meses</div>
            </div>

            <div class="fire-chart-container" id="fire-chart">
                <svg class="fire-line-svg" preserveAspectRatio="none" id="svg-chart">
                    <path class="fire-path-savings" id="chart-area" d="" />
                    <path class="fire-path" id="chart-line" d="" />
                </svg>
            </div>

            <div class="fire-checklist">
                <h4>Checklist de Gastos Ocultos</h4>
                <div class="checklist-grid" id="fire-checklist-grid">
                    <label class="checklist-item"><input type="checkbox" data-cost="200" /> Seguros Salud (+200€)</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="150" /> Impuestos (+150€)</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="100" /> Mantenimiento Hogar (+100€)</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="300" /> Viajes y Ocio (+300€)</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="100" /> Fondo Emergencias (+100€)</label>
                    <label class="checklist-item"><input type="checkbox" data-cost="50" /> Suscripciones (+50€)</label>
                </div>
                <div id="checklist-feedback" class="checklist-feedback"></div>
            </div>

            <div class="fire-actions ignore-capture">
                <button class="fire-btn fire-btn-primary" id="btn-export">
                    <Icon name="mdi:file-pdf-box" size={20} />
                    Guardar Plan
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const expensesIn = document.getElementById("fire-expenses") as HTMLInputElement;
    const swrIn = document.getElementById("fire-swr") as HTMLInputElement;
    const worthIn = document.getElementById("fire-worth") as HTMLInputElement;
    const savingsIn = document.getElementById("fire-savings") as HTMLInputElement;
    const returnIn = document.getElementById("fire-return") as HTMLInputElement;

    const valExpenses = document.getElementById("val-expenses");
    const valSwr = document.getElementById("val-swr");
    const valWorth = document.getElementById("val-worth-display");
    const valSavings = document.getElementById("val-savings");
    const valReturn = document.getElementById("val-return");

    const fireNumber = document.getElementById("fire-number");
    const fireTime = document.getElementById("fire-time");

    const barLean = document.getElementById("bar-lean");
    const barBarista = document.getElementById("bar-barista");
    const barFat = document.getElementById("bar-fat");
    const labelLean = document.getElementById("label-lean");
    const labelBarista = document.getElementById("label-barista");
    const labelFat = document.getElementById("label-fat");

    const checklistGrid = document.getElementById("fire-checklist-grid");
    const checklistFeedback = document.getElementById("checklist-feedback");

    const chartLine = document.getElementById("chart-line") as SVGPathElement | null;
    const chartArea = document.getElementById("chart-area") as SVGPathElement | null;

    function formatCurrency(val: number) {
        return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
            maximumFractionDigits: 0,
        }).format(val);
    }

    function calculateFIRE() {
        if (!expensesIn || !swrIn || !worthIn || !savingsIn || !returnIn) return;

        let extraCosts = 0;
        const checks = checklistGrid?.querySelectorAll('input[type="checkbox"]:checked') as NodeListOf<HTMLInputElement>;
        checks.forEach(check => {
            extraCosts += parseFloat(check.getAttribute('data-cost') || '0');
        });

        const baseExpenses = parseFloat(expensesIn.value);
        const monthlyExpenses = baseExpenses + extraCosts;
        
        const swr = parseFloat(swrIn.value) / 100;
        const currentWorth = parseFloat(worthIn.value);
        const monthlySavings = parseFloat(savingsIn.value);
        const annualReturn = parseFloat(returnIn.value) / 100;
        const monthlyReturn = Math.pow(1 + annualReturn, 1/12) - 1;

        const annualExpenses = monthlyExpenses * 12;
        const targetFI = annualExpenses / swr;

        if (fireNumber) fireNumber.textContent = formatCurrency(targetFI);
        if (valExpenses) {
            valExpenses.textContent = formatCurrency(monthlyExpenses);
            if (extraCosts > 0) {
                valExpenses.style.color = "var(--fire-accent)";
            } else {
                valExpenses.style.color = "var(--fire-primary)";
            }
        }
        if (valSwr) valSwr.textContent = (swr * 100).toFixed(1) + " %";
        if (valWorth) valWorth.textContent = formatCurrency(currentWorth);
        if (valSavings) valSavings.textContent = formatCurrency(monthlySavings);
        if (valReturn) valReturn.textContent = (annualReturn * 100).toFixed(1) + " %";

        const leanTarget = targetFI * 0.7;
        const baristaTarget = targetFI * 0.5;
        const fatTarget = targetFI * 1.5;

        const updateMilestone = (current: number, target: number, bar: HTMLElement | null, label: HTMLElement | null) => {
            const pct = Math.min(100, (current / target) * 100);
            if (bar) bar.style.width = pct + "%";
            if (label) label.textContent = pct.toFixed(0) + "%";
        };

        updateMilestone(currentWorth, leanTarget, barLean, labelLean);
        updateMilestone(currentWorth, baristaTarget, barBarista, labelBarista);
        updateMilestone(currentWorth, fatTarget, barFat, labelFat);

        const r = monthlyReturn;
        const PMT = monthlySavings;
        const PV = currentWorth;
        const FV = targetFI;

        let months = 0;
        if (PV >= FV) {
            months = 0;
        } else if (r === 0) {
            months = PMT > 0 ? (FV - PV) / PMT : Infinity;
        } else {
            const numerator = (FV * r + PMT);
            const denominator = (PV * r + PMT);
            if (numerator > 0 && denominator > 0) {
                months = Math.log(numerator / denominator) / Math.log(1 + r);
            } else {
                months = Infinity;
            }
        }

        if (fireTime) {
            if (isFinite(months) && months >= 0) {
                const totalMonths = Math.ceil(months);
                const years = Math.floor(totalMonths / 12);
                const remainingMonths = totalMonths % 12;
                
                if (years === 0 && remainingMonths === 0) {
                    fireTime.textContent = "¡Ya has alcanzado la libertad financiera!";
                } else {
                    fireTime.textContent = `Te faltan ${years} años y ${remainingMonths} meses`;
                }
            } else {
                fireTime.textContent = "Meta inalcanzable con este ahorro";
            }
        }

        const wealthHistory: number[] = [currentWorth];
        const steps = 50; 
        const duration = isFinite(months) ? Math.max(months, 12) : 12 * 50;
        
        for (let i = 1; i <= steps; i++) {
            const t = (i / steps) * duration;
            let w;
            if (r === 0) {
                w = PV + PMT * t;
            } else {
                w = PV * Math.pow(1 + r, t) + PMT * ((Math.pow(1 + r, t) - 1) / r);
            }
            wealthHistory.push(w);
        }

        if (chartLine && chartArea) {
            const pointsCount = wealthHistory.length;
            const maxVal = Math.max(targetFI * 1.1, ...wealthHistory);
            
            let d = "";
            wealthHistory.forEach((v, i) => {
                const x = (i / (pointsCount - 1)) * 100;
                const y = 100 - (v / maxVal) * 100;
                d += (i === 0 ? "M " : " L ") + x + " " + y;
            });

            chartLine.setAttribute("d", d);
            
            const areaD = d + " L 100 100 L 0 100 Z";
            chartArea.setAttribute("d", areaD);
            
            const svg = document.getElementById("svg-chart");
            if (svg) svg.setAttribute("viewBox", `0 0 100 100`);
        }
    }

    [expensesIn, swrIn, worthIn, savingsIn, returnIn].forEach(el => {
        el?.addEventListener("input", calculateFIRE);
    });

    checklistGrid?.addEventListener("change", (e) => {
        const target = e.target as HTMLInputElement;
        if (target && checklistFeedback) {
            if (target.checked) {
                checklistFeedback.textContent = `Añadido: ${target.parentElement?.textContent?.trim()}`;
                checklistFeedback.classList.add('visible');
                setTimeout(() => checklistFeedback.classList.remove('visible'), 2000);
            }
        }
        calculateFIRE();
    });

    const btnExport = document.getElementById("btn-export");
    btnExport?.addEventListener("click", async () => {
        const { default: jsPDF } = await import("jspdf");
        const { default: html2canvas } = await import("html2canvas");
        
        const element = document.getElementById("fire-calculator-main");
        if (!element) return;

        try {
            const canvas = await html2canvas(element, {
                scale: 2,
                useCORS: true,
                backgroundColor: "#ffffff",
                ignoreElements: (el) => el.classList.contains("ignore-capture"),
                onclone: (clonedDoc) => {
                   const clonedEl = clonedDoc.getElementById("fire-calculator-main");
                   if (clonedEl) {
                       clonedEl.style.padding = "40px";
                       clonedEl.style.borderRadius = "0";
                       clonedEl.style.background = "#ffffff";
                       clonedEl.style.color = "#000000";
                       clonedEl.style.width = "1000px";
                       
                       const results = clonedEl.querySelector(".fire-result-panel") as HTMLElement;
                       if (results) {
                           results.style.background = "#f9fafb";
                           results.style.borderColor = "#e5e7eb";
                           results.style.color = "#000000";
                       }

                       const magicNumber = clonedEl.querySelector(".fire-magic-number") as HTMLElement;
                       if (magicNumber) magicNumber.style.color = "#10b981";

                       const textMuted = clonedEl.querySelectorAll(".fire-text-muted, .fire-magic-number-label");
                       textMuted.forEach(el => (el as HTMLElement).style.color = "#4b5563");
                   }
                }
            });
            
            const imgData = canvas.toDataURL("image/png");
            const imgWidth = 595.28; 
            const imgHeight = (canvas.height * imgWidth) / canvas.width;

            const pdf = new jsPDF("p", "pt", "a4");
            pdf.addImage(imgData, "PNG", 0, 0, imgWidth, imgHeight);
            pdf.save("mi-plan-fire-jjlmoya.pdf");
        } catch (error) {
            console.error("Error generando PDF:", error);
        }
    });

    calculateFIRE();
</script>
