---
import "./DCFGradeBadge.css";
---

<div id="dcf-grade-badge" class="grade-badge-wrapper">
    <div id="dcf-grade-circle" class="grade-circle">
        <span id="dcf-grade-label" class="grade-label">--</span>
    </div>
    <div class="grade-meta">
        <p id="dcf-grade-desc" class="grade-desc"></p>
        <div class="grade-bar-track">
            <div id="dcf-grade-bar" class="grade-bar-fill"></div>
        </div>
    </div>
</div>

<script>
    import type { DCFResult } from "./dcf-engine.ts";

    window.addEventListener("dcf:result", (e) => {
        const result = (e as CustomEvent<DCFResult>).detail;
        const { label, color, pct, desc } = result.rating;

        const circle = document.getElementById("dcf-grade-circle") as HTMLElement;
        const labelEl = document.getElementById("dcf-grade-label") as HTMLElement;
        const descEl = document.getElementById("dcf-grade-desc") as HTMLElement;
        const bar = document.getElementById("dcf-grade-bar") as HTMLElement;

        circle.style.borderColor = color;
        labelEl.textContent = label;
        labelEl.style.color = color;
        descEl.textContent = desc;
        bar.style.width = `${pct}%`;
        bar.style.background = color;
    });
</script>
