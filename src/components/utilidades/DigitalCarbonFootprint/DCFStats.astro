---
import "./DCFStats.css";
---

<ul class="dcf-stats-grid" id="dcf-stats-grid">
    <li class="stat-pill" id="dcf-stat-size">
        <i class="mdi mdi-file-outline stat-icon"></i>
        <span class="stat-value" id="dcf-stat-size-val">--</span>
        <span class="stat-name">Peso página</span>
    </li>
    <li class="stat-pill" id="dcf-stat-co2">
        <i class="mdi mdi-molecule-co2 stat-icon"></i>
        <span class="stat-value" id="dcf-stat-co2-val">--</span>
        <span class="stat-name">CO₂ por visita</span>
    </li>
    <li class="stat-pill" id="dcf-stat-energy">
        <i class="mdi mdi-lightning-bolt stat-icon"></i>
        <span class="stat-value" id="dcf-stat-energy-val">--</span>
        <span class="stat-name">Energía por visita</span>
    </li>
    <li class="stat-pill" id="dcf-stat-year">
        <i class="mdi mdi-factory stat-icon"></i>
        <span class="stat-value" id="dcf-stat-year-val">--</span>
        <span class="stat-name">CO₂ anual (100k visitas)</span>
    </li>
    <li class="stat-pill" id="dcf-stat-trees">
        <i class="mdi mdi-tree stat-icon"></i>
        <span class="stat-value" id="dcf-stat-trees-val">--</span>
        <span class="stat-name">Árboles necesarios/año</span>
    </li>
    <li class="stat-pill" id="dcf-stat-km">
        <i class="mdi mdi-car stat-icon"></i>
        <span class="stat-value" id="dcf-stat-km-val">--</span>
        <span class="stat-name">Km en coche equiv.</span>
    </li>
</ul>

<script>
    import type { DCFResult } from "./dcf-engine.ts";

    window.addEventListener("dcf:result", (e) => {
        const r = (e as CustomEvent<DCFResult>).detail;

        const set = (id: string, val: string) => {
            const el = document.getElementById(id);
            if (el) el.textContent = val;
        };

        set("dcf-stat-size-val", r.pageSize);
        set("dcf-stat-co2-val", `${r.co2g.toFixed(3)} g`);
        set("dcf-stat-energy-val", `${r.energyWh.toFixed(4)} Wh`);
        set("dcf-stat-year-val", `${r.co2Year.toFixed(2)} kg`);
        set("dcf-stat-trees-val", `${r.trees} árboles`);
        set("dcf-stat-km-val", `${r.km} km`);
    });
</script>
