---
import "./DCFResultPanel.css";
import DCFGradeBadge from "./DCFGradeBadge.astro";
import DCFStats from "./DCFStats.astro";
import DCFShareButton from "./DCFShareButton.astro";
---

<div id="dcf-result-panel" class="dcf-result-panel glass-card dark-card hidden">
    <DCFGradeBadge />
    <DCFStats />
    <DCFShareButton />
</div>

<script>
    window.addEventListener("dcf:result", () => {
        document.getElementById("dcf-result-panel")?.classList.remove("hidden");
    });

    window.addEventListener("dcf:reset", () => {
        document.getElementById("dcf-result-panel")?.classList.add("hidden");
    });
</script>
