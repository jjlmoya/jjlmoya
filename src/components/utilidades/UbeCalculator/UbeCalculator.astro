---
import { Icon } from "astro-icon/components";
import "./UbeCalculator.css";
---

<div class="ube-container">
    <div class="converter-card animate-in fade-in slide-in-from-bottom duration-700">
        
        <div class="drinks-selector">
            <div class="input-group">
                <label>
                    <Icon name="mdi:plus-circle-outline" />
                    Añadir Bebida Tipo
                </label>
            </div>
            <div class="selector-grid">
                <button class="drink-btn preset-btn" data-vol="200" data-abv="5" data-icon="mdi:glass-mug-variant" data-name="Caña">
                    <Icon name="mdi:glass-mug-variant" />
                    <span class="drink-name">Caña</span>
                    <div class="drink-badges">
                        <span class="badge-vol">200ml</span>
                        <span class="badge-abv">5%</span>
                    </div>
                </button>
                <button class="drink-btn preset-btn" data-vol="330" data-abv="5" data-icon="mdi:beer" data-name="Tercio">
                    <Icon name="mdi:beer" />
                    <span class="drink-name">Tercio</span>
                    <div class="drink-badges">
                        <span class="badge-vol">330ml</span>
                        <span class="badge-abv">5%</span>
                    </div>
                </button>
                <button class="drink-btn preset-btn" data-vol="120" data-abv="12" data-icon="mdi:glass-wine" data-name="Vino">
                    <Icon name="mdi:glass-wine" />
                    <span class="drink-name">Vino</span>
                    <div class="drink-badges">
                        <span class="badge-vol">120ml</span>
                        <span class="badge-abv">12%</span>
                    </div>
                </button>
                <button class="drink-btn preset-btn" data-vol="50" data-abv="40" data-icon="mdi:glass-cocktail" data-name="Copa">
                    <Icon name="mdi:glass-cocktail" />
                    <span class="drink-name">Copa</span>
                    <div class="drink-badges">
                        <span class="badge-vol">50ml</span>
                        <span class="badge-abv">40%</span>
                    </div>
                </button>
                <button class="drink-btn preset-btn" data-vol="40" data-abv="40" data-icon="mdi:glass-tulip" data-name="Chupito">
                    <Icon name="mdi:glass-tulip" />
                    <span class="drink-name">Chupito</span>
                    <div class="drink-badges">
                        <span class="badge-vol">40ml</span>
                        <span class="badge-abv">40%</span>
                    </div>
                </button>
            </div>
        </div>

        <div class="profile-section">
            <div class="input-group">
                <label for="volInput">
                    <Icon name="mdi:cup-water" />
                    Volumen Personalizado
                </label>
                <div class="input-wrapper">
                    <input type="number" id="volInput" value="200" step="10" min="10" max="2000" />
                    <span class="unit-tag">ml</span>
                </div>
            </div>

            <div class="input-group">
                <label for="abvInput">
                    <Icon name="mdi:percent" />
                    Graduación Alcohólica
                </label>
                <div class="input-wrapper">
                    <input type="number" id="abvInput" value="5.0" step="0.5" min="0" max="80" />
                    <span class="unit-tag">% ABV</span>
                </div>
            </div>
            
            <button id="addCustomDrinkBtn" class="add-custom-btn btn-primary">
                <Icon name="mdi:plus" />
                Añadir Bebida Manual
            </button>
        </div>

        <div class="consumed-section" id="consumed-section">
            <div class="list-header">
                <span>Consumo Acumulado</span>
                <span id="items-count"></span>
            </div>
            <div id="drinks-container" class="drinks-container">
            </div>
        </div>

        <div class="results-section">
            <div class="result-main">
                <span class="result-label">Carga Tóxica Absoluta</span>
                <div class="bac-display">
                    <span class="bac-value" id="gramsVal">0.0</span>
                    <span class="bac-unit">g</span>
                </div>
                <div class="ubes-subtext">
                    <span id="ubesVal">0.00</span> UBEs
                </div>
            </div>

            <div class="risk-cards">
                <div class="risk-card">
                    <div class="risk-header">
                        <Icon name="mdi:clipboard-pulse-outline" />
                        Riesgo Epidemiológico
                    </div>
                    <div class="risk-status success" id="riskText">Sin Consumo</div>
                    <div class="risk-track">
                        <div class="risk-fill bg-success" id="riskFill"></div>
                    </div>
                    <div class="risk-markers">
                        <span>0 UBEs</span>
                        <span>Riesgo Alto &gt; 4 UBEs</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div id="icon-templates" style="display: none;">
        <div id="icon-mdi-glass-mug-variant"><Icon name="mdi:glass-mug-variant" /></div>
        <div id="icon-mdi-beer"><Icon name="mdi:beer" /></div>
        <div id="icon-mdi-glass-wine"><Icon name="mdi:glass-wine" /></div>
        <div id="icon-mdi-glass-cocktail"><Icon name="mdi:glass-cocktail" /></div>
        <div id="icon-mdi-glass-tulip"><Icon name="mdi:glass-tulip" /></div>
        <div id="icon-mdi-cup-water"><Icon name="mdi:cup-water" /></div>
        <div id="icon-trash"><Icon name="mdi:trash-can-outline" /></div>
    </div>
</div>

<script>
    interface ConsumedDrink {
        id: string;
        name: string;
        vol: number;
        abv: number;
        grams: number;
        ubes: number;
        icon: string;
    }

    const consumedDrinks: ConsumedDrink[] = [];

    const volInput = document.getElementById('volInput') as HTMLInputElement;
    const abvInput = document.getElementById('abvInput') as HTMLInputElement;
    
    const gramsVal = document.getElementById('gramsVal') as HTMLSpanElement;
    const ubesVal = document.getElementById('ubesVal') as HTMLSpanElement;
    const riskFill = document.getElementById('riskFill') as HTMLDivElement;
    const riskText = document.getElementById('riskText') as HTMLElement;
    const drinksContainer = document.getElementById('drinks-container');
    const itemsCountLabel = document.getElementById('items-count');

    const presetBtns = document.querySelectorAll('.preset-btn');
    const addCustomBtn = document.getElementById('addCustomDrinkBtn');

    function calculateItemValues(vol: number, abv: number) {
        const grams = vol * (abv / 100) * 0.8;
        const ubes = grams / 10;
        return { grams, ubes };
    }

    function addDrink(name: string, vol: number, abv: number, iconName: string) {
        const { grams, ubes } = calculateItemValues(vol, abv);
        
        const newDrink: ConsumedDrink = {
            id: Math.random().toString(36).substring(2, 9),
            name,
            vol,
            abv,
            grams,
            ubes,
            icon: iconName
        };

        consumedDrinks.push(newDrink);
        updateUI();
    }

    function removeDrink(id: string) {
        const index = consumedDrinks.findIndex(d => d.id === id);
        if (index !== -1) {
            consumedDrinks.splice(index, 1);
            updateUI();
        }
    }

    function updateRiskMeter(totalUbes: number) {
        if (!riskFill || !riskText) return;
        
        let percentage = (totalUbes / 6) * 100;
        if (percentage > 100) percentage = 100;
        
        riskFill.style.width = `${percentage}%`;
        riskText.classList.remove('success', 'warning', 'danger');
        riskFill.classList.remove('bg-success', 'bg-warning', 'bg-danger');

        if (totalUbes === 0) {
            riskText.textContent = 'Sin Consumo';
            riskText.classList.add('success');
            riskFill.classList.add('bg-success');
        } else if (totalUbes <= 2) {
            riskText.textContent = 'Bajo (Consumo Seguro)';
            riskText.classList.add('success');
            riskFill.classList.add('bg-success');
        } else if (totalUbes <= 4) {
            riskText.textContent = 'Tránsito (Riesgo Moderado)';
            riskText.classList.add('warning');
            riskFill.classList.add('bg-warning');
        } else {
            riskText.textContent = 'Alto (Consumo de Riesgo)';
            riskText.classList.add('danger');
            riskFill.classList.add('bg-danger');
        }
    }

    function updateUI() {
        let totalGrams = 0;
        let totalUbes = 0;

        if (!drinksContainer || !itemsCountLabel) return;
        drinksContainer.innerHTML = '';

        if (consumedDrinks.length === 0) {
            drinksContainer.innerHTML = `
                <div class="empty-placeholder">
                    <svg class="empty-icon" viewBox="0 0 24 24" width="48" height="48" fill="currentColor"><path d="M21,3H3A1,1 0 0,0 2,4V6.5A1,1 0 0,0 2.87,7.45L8,9.5V11C7.45,11 7,11.45 7,12V20C7,20.55 7.45,21 8,21H16C16.55,21 17,20.55 17,20V12C17,11.45 16.55,11 16,11V9.5L21.13,7.45A1,1 0 0,0 22,6.5V4A1,1 0 0,0 21,3M4,5H20V6.15L15,8.15V9.5A1,1 0 0,0 15.87,10.45L20,12.1V19H4V12.1L8.13,10.45C8.63,10.25 9,9.75 9,9.2V8.15L4,6.15V5Z"/></svg>
                    <p>Tu lista de consumo está vacía</p>
                    <span>Selecciona bebidas arriba o añade manualmente</span>
                </div>
            `;
            itemsCountLabel.style.display = 'none';
        } else {
            itemsCountLabel.style.display = 'inline-block';
            itemsCountLabel.textContent = `${consumedDrinks.length} bebida${consumedDrinks.length > 1 ? 's' : ''}`;

            consumedDrinks.forEach(drink => {
                totalGrams += drink.grams;
                totalUbes += drink.ubes;

                const item = document.createElement('div');
                item.className = 'drink-card animate-in zoom-in duration-300';
                
                const iconTplId = drink.icon.replace(':', '-');
                let iconHtml = '';
                const iconEl = document.getElementById(`icon-${iconTplId}`);
                if (iconEl) {
                    iconHtml = iconEl.innerHTML;
                } else {
                    const fallbackEl = document.getElementById('icon-mdi-cup-water');
                    if (fallbackEl) iconHtml = fallbackEl.innerHTML;
                }

                let trashHtml = '';
                const trashEl = document.getElementById('icon-trash');
                if (trashEl) trashHtml = trashEl.innerHTML;

                item.innerHTML = `
                    <div class="drink-icon-wrapper">
                        ${iconHtml}
                        <div class="count-badge">
                            +${drink.ubes.toFixed(1)} ube
                        </div>
                    </div>
                    <span class="card-name">${drink.name}</span>
                    <div class="drink-badges">
                        <span class="badge-vol">
                            ${drink.vol}ml
                        </span>
                        <span class="badge-abv">
                            ${drink.abv}%
                        </span>
                    </div>
                    <button class="card-remove" data-id="${drink.id}">${trashHtml}</button>
                `;
                
                drinksContainer.appendChild(item);
            });
            
            document.querySelectorAll('.card-remove').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const target = e.currentTarget as HTMLButtonElement;
                    const id = target.getAttribute('data-id');
                    if (id) removeDrink(id);
                });
            });
        }

        if (gramsVal) gramsVal.textContent = totalGrams.toFixed(1);
        if (ubesVal) ubesVal.textContent = totalUbes.toFixed(2);
        
        updateRiskMeter(totalUbes);
    }

    presetBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const vol = parseFloat(btn.getAttribute('data-vol') || '0');
            const abv = parseFloat(btn.getAttribute('data-abv') || '0');
            const icon = btn.getAttribute('data-icon') || 'mdi:glass-mug-variant';
            const name = btn.getAttribute('data-name') || 'Bebida';
            
            if (vol > 0 && abv > 0) {
                if (volInput) volInput.value = vol.toString();
                if (abvInput) abvInput.value = abv.toString();
                
                addDrink(name, vol, abv, icon);
            }
        });
    });

    addCustomBtn?.addEventListener('click', () => {
        if (!volInput || !abvInput) return;
        const vol = parseFloat(volInput.value);
        const abv = parseFloat(abvInput.value);
        if (vol > 0 && abv > 0) {
            addDrink('Personalizada', vol, abv, 'mdi:cup-water');
        }
    });

    updateUI();
</script>
