---

---

<header class="pl-topbar">
    <div class="pl-search-container">
        <svg
            class="pl-search-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
            type="text"
            id="pl-search"
            class="pl-search-input"
            placeholder="Buscar por palabra clave o etiqueta..."
            aria-label="Buscar prompts"
        />
    </div>
    <button id="pl-open-modal" class="pl-btn pl-btn-primary" aria-label="Añadir nuevo prompt">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nuevo Prompt
    </button>
</header>
