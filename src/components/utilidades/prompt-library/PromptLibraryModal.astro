---

<dialog id="pl-modal" class="pl-modal">
    <div class="pl-modal-container">
        <div class="pl-modal-header">
            <h3 class="pl-modal-title">Crear Nuevo Prompt</h3>
            <button id="pl-close-modal" class="pl-btn-icon" aria-label="Cerrar">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"
                    ></line></svg
                >
            </button>
        </div>
        <form id="pl-form" class="pl-form">
            <div class="pl-form-group">
                <label for="pl-title" class="pl-label">Título identificativo</label>
                <input
                    type="text"
                    id="pl-title"
                    class="pl-input"
                    placeholder="Ej: Experto en Marketing SEO"
                    required
                    autocomplete="off"
                />
            </div>

            <div class="pl-form-group">
                <label for="pl-content" class="pl-label">Instrucción (Prompt)</label>
                <textarea
                    id="pl-content"
                    class="pl-textarea"
                    placeholder="Escribe aquí las instrucciones detalladas para la IA..."
                    required></textarea>
                <span class="pl-hint"
                    >Recomendación: usa corchetes [COMO ESTOS] para rellenar variables más tarde.</span
                >
            </div>

            <div class="pl-form-group">
                <label for="pl-tags-input" class="pl-label">Etiquetas</label>
                <div class="pl-tags-input-wrapper" id="pl-tags-wrapper">
                    <div id="pl-tags-list" class="pl-tags-list"></div>
                    <input
                        type="text"
                        id="pl-tags-input"
                        class="pl-tags-input-field"
                        placeholder="Ej: marketing, seo (espacio o coma para añadir)"
                        autocomplete="off"
                    />
                </div>
            </div>

            <div class="pl-modal-footer">
                <button type="button" id="pl-cancel-form" class="pl-btn pl-btn-ghost"
                    >Cancelar</button
                >
                <button type="submit" class="pl-btn pl-btn-primary">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"
                        ></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline
                            points="7 3 7 8 15 8"></polyline></svg
                    >
                    Guardar en Local
                </button>
            </div>
        </form>
    </div>
</dialog>

<dialog id="pl-confirm-modal" class="pl-modal">
    <div class="pl-modal-container" style="max-width: 400px; text-align: center;">
        <div class="pl-empty-icon" style="margin-bottom: 1rem; color: #ef4444;">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                class="pl-star-icon"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"
                ></path><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line
                    x1="10"
                    y1="11"
                    x2="10"
                    y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg
            >
        </div>
        <h3 class="pl-empty-title" style="font-size: 1.25rem;">¿Eliminar prompt?</h3>
        <p class="pl-empty-desc" style="font-size: 1rem; margin-bottom: 1.5rem; max-width: 100%;">
            Esta acción no se puede deshacer.
        </p>
        <div
            class="pl-modal-footer"
            style="justify-content: center; gap: 1rem; border: none; padding-top: 0;"
        >
            <button type="button" id="pl-cancel-delete" class="pl-btn pl-btn-ghost">Cancelar</button
            >
            <button
                type="button"
                id="pl-confirm-delete"
                class="pl-btn pl-btn-primary"
                style="background: #ef4444; box-shadow: 0 4px 15px -3px rgba(239, 68, 68, 0.4);"
                >Eliminar definitivamente</button
            >
        </div>
    </div>
</dialog>
