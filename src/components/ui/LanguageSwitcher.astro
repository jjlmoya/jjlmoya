---
import { LANG_METADATA } from "../../i18n/slugs";
---

<div id="lang-switcher" class="lang-switcher" aria-label="Versiones en otros idiomas" hidden>
    <button
        id="lang-switcher-btn"
        class="lang-switcher__btn"
        aria-haspopup="listbox"
        aria-expanded="false"
        title="Ver en otro idioma"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        <span class="lang-switcher__label">ES</span>
    </button>

    <ul id="lang-switcher-menu" class="lang-switcher__menu" role="listbox" aria-label="Idiomas disponibles" hidden>
        <li class="lang-switcher__item lang-switcher__item--current" role="option" aria-selected="true">
            <span class="lang-switcher__flag">🇪🇸</span>
            <span>Español</span>
            <svg class="lang-switcher__check" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        </li>
    </ul>
</div>

<script is:inline define:vars={{ LANG_METADATA }}>

    function init() {
        if (new URLSearchParams(window.location.search).has("widget")) return;

        const allLinks = Array.from(document.querySelectorAll('link[rel="alternate"]'));
        const alternates = allLinks.filter((el) => {
            const hreflang = el.getAttribute('hreflang');
            return hreflang && hreflang !== "es" && hreflang !== "x-default";
        });

        if (alternates.length === 0) return;

        const switcher = document.getElementById("lang-switcher");
        const btn = document.getElementById("lang-switcher-btn");
        const menu = document.getElementById("lang-switcher-menu");
        if (!switcher || !btn || !menu) return;

        alternates.forEach((link) => {
            const hreflang = link.getAttribute('hreflang');
            const href = link.getAttribute('href');
            const meta = LANG_METADATA[hreflang];
            if (!meta) return;
            const li = document.createElement("li");
            li.className = "lang-switcher__item";
            li.setAttribute("role", "option");
            li.setAttribute("aria-selected", "false");
            li.innerHTML = `<span class="lang-switcher__flag">${meta.flag}</span><a href="${href}" class="lang-switcher__link">${meta.label}</a>`;
            menu.appendChild(li);
        });

        switcher.hidden = false;

        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            const isOpen = !menu.hidden;
            menu.hidden = isOpen;
            btn.setAttribute("aria-expanded", String(!isOpen));
        });

        document.addEventListener("click", () => {
            menu.hidden = true;
            btn.setAttribute("aria-expanded", "false");
        });

        menu.addEventListener("click", (e) => e.stopPropagation());
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
    } else {
        init();
    }
</script>

<style is:global>
    .lang-switcher {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 200;
        font-family: inherit;
    }

    .lang-switcher__btn {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 0.875rem;
        background: #1e293b;
        color: #f1f5f9;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 9999px;
        cursor: pointer;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        backdrop-filter: blur(8px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        transition: background 0.15s, transform 0.15s;
    }

    .lang-switcher__btn:hover {
        background: #334155;
        transform: translateY(-1px);
    }

    .lang-switcher__label {
        font-size: 0.75rem;
    }

    .lang-switcher__menu {
        position: absolute;
        bottom: calc(100% + 0.5rem);
        right: 0;
        min-width: 160px;
        background: #1e293b;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 0.75rem;
        padding: 0.375rem 0;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        list-style: none;
        margin: 0;
        overflow: hidden;
    }

    .lang-switcher__item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.875rem;
        font-size: 0.875rem;
        color: #cbd5e1;
        transition: background 0.1s;
    }

    .lang-switcher__item:hover {
        background: rgba(255, 255, 255, 0.07);
    }

    .lang-switcher__item--current {
        color: #f1f5f9;
        font-weight: 600;
    }

    .lang-switcher__flag {
        font-size: 1rem;
        line-height: 1;
    }

    .lang-switcher__check {
        margin-left: auto;
        color: #6366f1;
    }

    .lang-switcher__link,
    .lang-switcher__link:visited,
    .lang-switcher__link:link {
        color: #cbd5e1;
        text-decoration: none;
        flex: 1;
    }

    .lang-switcher__link:hover {
        color: #f1f5f9;
    }

    :global(body.is-widget) .lang-switcher {
        display: none !important;
    }

    @media (prefers-color-scheme: light) {
        .lang-switcher__btn {
            background: #0f172a;
        }
        .lang-switcher__menu {
            background: #0f172a;
        }
    }
</style>
