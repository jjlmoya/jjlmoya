---
import "./ThemeToggle.css";
---

<button
    class="theme-toggle-btn"
    aria-label="Cambiar tema"
    title="Cambiar tema"
>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="sun-icon"
    >
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path>
        <path d="M12 20v2"></path>
        <path d="m4.93 4.93 1.41 1.41"></path>
        <path d="m17.66 17.66 1.41 1.41"></path>
        <path d="M2 12h2"></path>
        <path d="M20 12h2"></path>
        <path d="m6.34 17.66-1.41 1.41"></path>
        <path d="m19.07 4.93-1.41 1.41"></path>
    </svg>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="moon-icon"
    >
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
    </svg>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="system-icon"
    >
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
        <line x1="8" y1="21" x2="16" y2="21"></line>
        <line x1="12" y1="17" x2="12" y2="21"></line>
    </svg>
</button>

<script>
    const THEMES = ["theme-light", "theme-dark", "theme-system"];

    const applyStoredTheme = () => {
        const stored = (typeof localStorage !== "undefined" && localStorage.getItem("theme")) || "theme-system";
        const root = document.documentElement;
        let isDark;
        if (stored === "theme-system") {
            isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        } else {
            isDark = stored === "theme-dark";
        }
        root.classList.remove("theme-light", "theme-dark", "theme-system");
        root.classList.add(stored);
        root.classList.toggle("theme-light", !isDark);
        root.classList.toggle("theme-dark", isDark);
        root.classList.toggle("dark", isDark);
    };

    const setupThemeToggle = () => {
        const themeToggleBtns = document.querySelectorAll(".theme-toggle-btn");
        
        const getCurrentTheme = (): string => {
            if (typeof localStorage !== "undefined") {
                return localStorage.getItem("theme") || "theme-system";
            }
            return "theme-system";
        };

        const setTheme = (theme: string) => {
            const root = document.documentElement;
            let isDark;
            if (theme === "theme-system") {
                isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            } else {
                isDark = theme === "theme-dark";
            }
            root.classList.remove("theme-light", "theme-dark", "theme-system");
            root.classList.add(theme);
            root.classList.toggle("theme-light", !isDark);
            root.classList.toggle("theme-dark", isDark);
            root.classList.toggle("dark", isDark);
            localStorage.setItem("theme", theme);
        };

        const cycleTheme = (current: string) => {
            const idx = THEMES.indexOf(current);
            return THEMES[(idx + 1) % THEMES.length];
        };

        themeToggleBtns.forEach((btn) => {
            const newBtn = btn.cloneNode(true);
            btn.parentNode?.replaceChild(newBtn, btn);

            newBtn.addEventListener("click", () => {
                const current = getCurrentTheme();
                const next = cycleTheme(current);
                setTheme(next);
            });
        });
    };

    let systemThemeListener: MediaQueryList | null = null;

    const watchSystemTheme = () => {
        if (systemThemeListener) return;
        const mq = window.matchMedia("(prefers-color-scheme: dark)");
        systemThemeListener = mq;
        const handler = () => {
            const stored = (typeof localStorage !== "undefined" && localStorage.getItem("theme")) || "theme-system";
            if (stored === "theme-system") {
                applyStoredTheme();
            }
        };
        if (mq.addEventListener) {
            mq.addEventListener("change", handler);
        }
    };

    applyStoredTheme();
    watchSystemTheme();
    setupThemeToggle();
    document.addEventListener("astro:after-swap", () => {
        applyStoredTheme();
        watchSystemTheme();
        setupThemeToggle();
    });
</script>
