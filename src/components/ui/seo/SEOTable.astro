---
interface Props {
    headers: string[];
    striped?: boolean;
    responsive?: boolean;
}

const { headers, striped = true, responsive = true } = Astro.props;
---

<div class={`seo-table-wrapper ${responsive ? "responsive" : ""}`}>
    <table class="seo-table" role="table">
        <thead>
            <tr class="header-row">
                {
                    headers.map((header, index) => (
                        <th
                            scope="col"
                            class={`header-cell ${index === 0 ? "first" : ""} ${index === headers.length - 1 ? "last" : ""}`}
                        >
                            {header}
                        </th>
                    ))
                }
            </tr>
        </thead>
        <tbody>
            <slot />
        </tbody>
    </table>
</div>

<style>
    .seo-table-wrapper {
        width: 100%;
        margin: 2.5rem 0;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow:
            0 1px 3px 0 rgba(0, 0, 0, 0.08),
            0 4px 6px -2px rgba(0, 0, 0, 0.08);
        background: white;
        border: 1px solid #e2e8f0;
    }

    .seo-table-wrapper.responsive {
        overflow-x: auto;
    }

    .seo-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .header-row {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        border-bottom: 2px solid #cbd5e1;
    }

    .header-cell {
        padding: 1.25rem 1.5rem;
        font-weight: 700;
        color: #0f172a;
        white-space: nowrap;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .header-cell.first {
        border-radius: 1rem 0 0 0;
    }

    .header-cell.last {
        border-radius: 0 1rem 0 0;
    }

    .seo-table :global(tbody tr) {
        border-bottom: 1px solid #f1f5f9;
        transition: all 0.2s ease-in-out;
    }

    .seo-table :global(tbody tr:last-child) {
        border-bottom: none;
    }

    .seo-table :global(tbody tr:nth-child(odd)) {
        background-color: rgba(255, 255, 255, 1);
    }

    .seo-table :global(tbody tr:nth-child(even)) {
        background-color: #f9fafb;
    }

    .seo-table :global(tbody tr:hover) {
        background-color: #f0f4f8 !important;
        box-shadow: inset 0 0 0 1px #e2e8f0;
    }

    .seo-table :global(td) {
        padding: 1.25rem 1.5rem;
        color: #334155;
        vertical-align: middle;
        font-weight: 400;
    }

    .seo-table :global(td strong) {
        color: #0f172a;
        font-weight: 600;
    }

    :global(.dark) .seo-table-wrapper {
        border-color: #1e293b;
        background: #0f172a;
        box-shadow:
            0 1px 3px 0 rgba(0, 0, 0, 0.5),
            0 4px 6px -2px rgba(0, 0, 0, 0.3);
    }

    :global(.dark) .header-row {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        border-bottom-color: #334155;
    }

    :global(.dark) .header-cell {
        color: #f1f5f9;
    }

    :global(.dark) .seo-table :global(tbody tr) {
        border-bottom-color: #1e293b;
    }

    :global(.dark) .seo-table :global(tbody tr:nth-child(odd)) {
        background-color: rgba(15, 23, 42, 1);
    }

    :global(.dark) .seo-table :global(tbody tr:nth-child(even)) {
        background-color: #0f172a;
    }

    :global(.dark) .seo-table :global(tbody tr:hover) {
        background-color: #1e293b !important;
        box-shadow: inset 0 0 0 1px #334155;
    }

    :global(.dark) .seo-table :global(td) {
        color: #cbd5e1;
    }

    :global(.dark) .seo-table :global(td strong) {
        color: #f1f5f9;
    }

    @media (max-width: 768px) {
        .header-cell {
            padding: 1rem 1.25rem;
            font-size: 0.75rem;
        }

        .seo-table :global(td) {
            padding: 1rem 1.25rem;
            font-size: 0.9rem;
        }

        .seo-table-wrapper {
            margin: 2rem 0;
            border-radius: 0.75rem;
        }

        .header-cell.first {
            border-radius: 0.75rem 0 0 0;
        }

        .header-cell.last {
            border-radius: 0 0.75rem 0 0;
        }
    }

    @media (max-width: 480px) {
        .header-cell {
            padding: 0.875rem 1rem;
            font-size: 0.7rem;
            letter-spacing: 0.25px;
        }

        .seo-table :global(td) {
            padding: 0.875rem 1rem;
            font-size: 0.875rem;
        }
    }
</style>
