---
import { sections } from "../../../data/utilities";

interface Props {
    toolKey: string;
}

const { toolKey } = Astro.props;

let tool: any = null;
let toolHref: string = "";

const normalizeKey = (str: string) => str.toLowerCase().replace(/[^a-z0-9]/g, "");
const searchKey = normalizeKey(toolKey);

for (const section of sections) {
    const found = section.utilities.find((u) => {
        const hrefKey = normalizeKey(u.href);
        const titleKey = normalizeKey(u.title);
        return hrefKey.includes(searchKey) || titleKey.includes(searchKey);
    });

    if (found) {
        tool = found;
        toolHref = found.href;
        break;
    }
}

if (!tool) {
    console.warn(`SEOTool: No se encontró herramienta con key: ${toolKey}`);
}
---

{
    tool && (
        <a href={toolHref} class="seo-tool-card" style={{ "--tool-color": tool.color } as any}>
            {tool.title}
        </a>
    )
}

<style>
    .seo-tool-card {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: rgba(248, 250, 252, 0.8);
        color: var(--tool-color);
        border: 1.5px solid var(--tool-color);
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        margin: 0 0 2.5rem 0;
        display: inline-block;
    }

    .seo-tool-card:hover {
        background: var(--tool-color);
        color: white;
    }

    @media (prefers-color-scheme: dark) {
        .seo-tool-card {
            background: rgba(30, 41, 59, 0.6);
            border-color: var(--tool-color);
            color: var(--tool-color);
        }

        .seo-tool-card:hover {
            background: var(--tool-color);
            color: #1e293b;
        }
    }
</style>
