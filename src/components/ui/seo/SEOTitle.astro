---
interface Props {
    title: string;
    level?: 2 | 3 | 4;
}

const { title, level = 2 } = Astro.props;
const Tag = `h${level}` as any;
---

<Tag class="seo-title">
    <span class="prefix">#</span>
    {title}
</Tag>

<style>
    .seo-title {
        color: #0f172a;
        line-height: 1.3;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    :global(.dark) .seo-title {
        color: #f8fafc;
    }

    .prefix {
        font-weight: 700;
        color: #3b82f6;
    }

    h2.seo-title {
        font-size: 2rem;
        font-weight: 800;
        margin-top: 4rem;
    }

    h3.seo-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-top: 3rem;
    }

    h4.seo-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-top: 2rem;
    }

    @media (max-width: 768px) {
        h2.seo-title {
            font-size: 1.75rem;
        }
        h3.seo-title {
            font-size: 1.35rem;
        }
    }
</style>
