---
interface Props {
    items?: string[];
}

const { items } = Astro.props;
---

<ul class="seo-list">
    {
        items ? (
            items.map((item) => (
                <li>
                    <Fragment set:html={item} />
                </li>
            ))
        ) : (
            <slot />
        )
    }
</ul>

<style>
    .seo-list {
        list-style: none;
        padding-left: 0;
        margin-bottom: 2rem;
    }

    .seo-list :global(li) {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
        line-height: 1.6;
    }

    .seo-list :global(li::before) {
        content: "•";
        color: #3b82f6;
        position: absolute;
        left: 0;
        font-size: 1.5rem;
        line-height: 1;
        top: -2px;
    }
</style>
