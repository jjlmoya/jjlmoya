---
interface Props {
    title?: string;
    ariaLabel?: string;
}

const { title, ariaLabel } = Astro.props;
---

<div class="seo-message-box" aria-label={ariaLabel}>
    {title && <div class="box-header">{title}</div>}
    <div class="box-inner">
        <div class="box-content"><slot /></div>
    </div>
</div>

<style>
    .seo-message-box {
        margin: 2.5rem 0;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .box-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 10px 20px;
        font-size: 0.7rem;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .box-inner {
        padding: 24px;
        background: radial-gradient(circle at top right, rgba(241, 245, 249, 0.5), transparent);
    }

    .box-content {
        font-size: 1rem;
        color: #1e293b;
        line-height: 1.6;
        white-space: pre-line;
        text-align: left;
    }

    @media (prefers-color-scheme: dark) {
        .seo-message-box {
            background: rgba(30, 41, 59, 0.5);
            border-color: rgba(255, 255, 255, 0.1);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
        }
        .box-header {
            background: rgba(15, 23, 42, 0.5);
            border-bottom-color: rgba(255, 255, 255, 0.1);
            color: #94a3b8;
        }
        .box-content {
            color: #e2e8f0;
        }
        .box-inner {
            background: radial-gradient(circle at top right, rgba(30, 41, 59, 0.8), transparent);
        }
    }
</style>
