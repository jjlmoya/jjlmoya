---
interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<article class:list={["seo-article", className]}>
    <slot />
</article>

<style>
    .seo-article {
        line-height: 1.8;
        color: #4b5563;
        font-size: 1.125rem;
        max-width: 48rem;
        margin: 0 auto;
    }

    :global(.dark) .seo-article {
        color: #9ca3af;
    }

    .seo-article :global(p) {
        margin-bottom: 1.5rem;
    }

    .seo-article :global(strong) {
        color: #111827;
        font-weight: 700;
    }

    :global(.dark) .seo-article :global(strong) {
        color: #f3f4f6;
    }

    .seo-article :global(code:not(pre code)) {
        background: #f1f5f9;
        color: #2563eb;
        padding: 0.2rem 0.4rem;
        border-radius: 0.375rem;
        font-size: 0.875em;
        font-weight: 600;
    }

    :global(.dark) .seo-article :global(code:not(pre code)) {
        background: #1e293b;
        color: #60a5fa;
    }

    @media (max-width: 768px) {
        .seo-article {
            font-size: 1rem;
        }
    }
</style>
