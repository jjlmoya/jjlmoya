---
import { Icon } from "astro-icon/components";

interface Props {
    title: string;
    icon?: string;
    type?: "warning" | "error" | "info" | "success";
    badge?: string;
}

const { title, icon, type = "info", badge } = Astro.props;

const typeConfig = {
    warning: {
        color: "#f59e0b",
        bgHeader: "rgba(245, 158, 11, 0.1)",
        border: "rgba(245, 158, 11, 0.3)",
        badgeText: badge ?? "Advertencia",
        darkBg: "rgba(120, 53, 15, 0.15)",
        darkBorder: "rgba(245, 158, 11, 0.2)",
    },
    error: {
        color: "#f43f5e",
        bgHeader: "rgba(244, 63, 94, 0.08)",
        border: "rgba(244, 63, 94, 0.3)",
        badgeText: badge ?? "Problema crítico",
        darkBg: "rgba(136, 19, 55, 0.15)",
        darkBorder: "rgba(244, 63, 94, 0.2)",
    },
    info: {
        color: "#3b82f6",
        bgHeader: "rgba(59, 130, 246, 0.08)",
        border: "rgba(59, 130, 246, 0.3)",
        badgeText: badge ?? "A tener en cuenta",
        darkBg: "rgba(30, 58, 138, 0.15)",
        darkBorder: "rgba(59, 130, 246, 0.2)",
    },
    success: {
        color: "#10b981",
        bgHeader: "rgba(16, 185, 129, 0.08)",
        border: "rgba(16, 185, 129, 0.3)",
        badgeText: badge ?? "Buena práctica",
        darkBg: "rgba(6, 78, 59, 0.15)",
        darkBorder: "rgba(16, 185, 129, 0.2)",
    },
} as const;

const cfg = typeConfig[type];
---

<div
    class={`seo-diagnostic is-${type}`}
    style={`--diag-color: ${cfg.color}; --diag-header-bg: ${cfg.bgHeader}; --diag-border: ${cfg.border}; --diag-dark-bg: ${cfg.darkBg}; --diag-dark-border: ${cfg.darkBorder};`}
>
    <div class="diag-header">
        <div class="header-left">
            {
                icon && (
                    <div class="icon-bubble">
                        <Icon name={icon} class="bubble-icon" />
                    </div>
                )
            }
            <h3 class="header-title">{title}</h3>
        </div>
        <span class="type-badge">{cfg.badgeText}</span>
    </div>
    <div class="diag-body">
        <slot />
    </div>
</div>

<style>
    .seo-diagnostic {
        border: 1px solid var(--diag-border);
        border-radius: 1.25rem;
        overflow: hidden;
        margin-bottom: 2rem;
        transition: box-shadow 0.3s ease;
    }

    .seo-diagnostic:hover {
        box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.08);
    }

    .diag-header {
        background: var(--diag-header-bg);
        padding: 1.125rem 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border-bottom: 1px solid var(--diag-border);
        flex-wrap: wrap;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        flex: 1;
        min-width: 0;
    }

    .icon-bubble {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: var(--diag-color);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    .bubble-icon {
        width: 20px;
        height: 20px;
        color: #ffffff;
    }

    .header-title {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    .type-badge {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--diag-color);
        background: color-mix(in sRGB, var(--diag-color) 12%, transparent);
        padding: 0.3rem 0.75rem;
        border-radius: 100px;
        white-space: nowrap;
        border: 1px solid color-mix(in sRGB, var(--diag-color) 25%, transparent);
        flex-shrink: 0;
    }

    .diag-body {
        background: #ffffff;
        padding: 1.75rem;
        font-size: 1rem;
        color: #475569;
        line-height: 1.7;
    }

    .diag-body :global(p) {
        margin-bottom: 1rem;
    }

    .diag-body :global(p:last-child) {
        margin-bottom: 0;
    }

    .diag-body :global(strong) {
        color: #0f172a;
        font-weight: 700;
    }

    .diag-body :global(ol),
    .diag-body :global(ul) {
        margin: 0.75rem 0 1rem 0;
        padding-left: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .diag-body :global(li) {
        line-height: 1.65;
    }

    :global(.dark) .seo-diagnostic {
        border-color: var(--diag-dark-border);
    }

    :global(.dark) .diag-header {
        background: var(--diag-dark-bg);
        border-bottom-color: var(--diag-dark-border);
    }

    :global(.dark) .header-title {
        color: #f1f5f9;
    }

    :global(.dark) .diag-body {
        background: rgba(15, 23, 42, 0.6);
        color: #94a3b8;
    }

    :global(.dark) .diag-body :global(strong) {
        color: #e2e8f0;
    }

    @media (max-width: 640px) {
        .diag-header {
            padding: 1rem 1.25rem;
            gap: 0.75rem;
        }

        .diag-body {
            padding: 1.25rem;
        }

        .header-title {
            font-size: 1rem;
        }

        .type-badge {
            font-size: 0.65rem;
        }
    }
</style>
