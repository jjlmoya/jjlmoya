---
interface Props {
    code?: string;
    ariaLabel?: string;
}

const { code, ariaLabel } = Astro.props;
---

<pre
    class="seo-code"
    {...ariaLabel && {
        role: "region",
        "aria-label": ariaLabel,
    }}>
    {
        code ? (
            <div class="code-content">
                {code.split('\n').map(line => (
                    <div class="code-line">{line || '\u00A0'}</div>
                ))}
            </div>
        ) : (
            <slot />
        )
    }
</pre>

<style>
    .seo-code {
        background: #0f172a;
        padding: 1.5rem;
        border-radius: 1rem;
        margin: 2rem 0;
        font-size: 0.95rem;
        color: #f8fafc;
        box-shadow:
            0 10px 15px -3px rgba(0, 0, 0, 0.1),
            0 4px 6px -2px rgba(0, 0, 0, 0.05);
        border: 1px solid #1e293b;
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
            monospace;
    }

    :global(.dark) .seo-code {
        background: #020617;
        border-color: #1e293b;
    }

    .code-content {
        margin: 0;
        padding: 0;
    }

    .code-line {
        line-height: 1.6;
        margin: 0;
        padding: 0;
        white-space: pre-wrap;
        word-break: break-all;
    }
</style>
