---
interface Props {
    title?: string;
}

const { title } = Astro.props;
---

<div class="seo-tip">
    {title && <h5>{title}</h5>}
    <slot />
</div>

<style>
    .seo-tip {
        background: #f1f5f9;
        border-left: 4px solid #3b82f6;
        padding: 1.5rem;
        border-radius: 1rem;
        margin: 2.5rem 0;
    }

    :global(.dark) .seo-tip {
        background: rgba(30, 41, 59, 0.5);
    }

    .seo-tip h5 {
        margin: 0 0 0.75rem 0;
        color: #0f172a;
        font-size: 1.1rem;
        font-weight: 700;
    }

    :global(.dark) .seo-tip h5 {
        color: #f8fafc;
    }

    .seo-tip :global(p) {
        margin: 0 !important;
        color: #475569;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .seo-tip :global(.dark) :global(p) {
        color: #cbd5e1;
    }
</style>
