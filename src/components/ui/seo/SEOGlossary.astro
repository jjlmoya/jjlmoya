---
interface Props {
    items: { term: string; definition: string }[];
}

const { items } = Astro.props;
---

<div class="seo-glossary-wrapper">
    <dl class="seo-glossary">
        {
            items.map((item) => (
                <div class="glossary-item">
                    <dt class="glossary-term">
                        <span class="term-text">{item.term}</span>
                        <div class="term-line" />
                    </dt>
                    <dd class="glossary-definition">{item.definition}</dd>
                </div>
            ))
        }
    </dl>
</div>

<style>
    .seo-glossary-wrapper {
        margin: 3rem 0;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 1.5rem;
        padding: 2.5rem;
    }

    .seo-glossary {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    .glossary-item {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .glossary-term {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        font-family: inherit;
    }

    .term-text {
        font-size: 1.125rem;
        font-weight: 800;
        color: #0f172a;
        white-space: nowrap;
        letter-spacing: -0.01em;
    }

    .term-line {
        height: 1px;
        background: #e2e8f0;
        flex: 1;
    }

    .glossary-definition {
        margin: 0;
        font-size: 1rem;
        line-height: 1.7;
        color: #475569;
        font-weight: 450;
        max-width: 80ch;
    }

    :global(.dark) .seo-glossary-wrapper {
        background: rgba(30, 41, 59, 0.4);
        border-color: rgba(255, 255, 255, 0.05);
    }

    :global(.dark) .term-text {
        color: #f1f5f9;
    }

    :global(.dark) .term-line {
        background: rgba(255, 255, 255, 0.05);
    }

    :global(.dark) .glossary-definition {
        color: #94a3b8;
    }

    @media (max-width: 768px) {
        .seo-glossary-wrapper {
            padding: 1.5rem;
        }
        
        .glossary-term {
            gap: 1rem;
        }

        .term-text {
            font-size: 1rem;
        }

        .seo-glossary {
            gap: 2rem;
        }
    }
</style>
