---
import { sections } from "../../data/utilities";

interface Props {
    class?: string;
    currentPath?: string;
}

const { class: className, currentPath } = Astro.props;

const normalize = (path: string) => path.replace(/\/+$/, "");
const targetPath = currentPath ? normalize(currentPath) : "";

let category: string | undefined;
let categorySlug: string | undefined;

if (targetPath) {
    const foundSection = sections.find((section) =>
        section.utilities.some((u) => normalize(u.href) === targetPath)
    );
    if (foundSection) {
        category = foundSection.title;
        categorySlug = foundSection.slug;
    }
}
---

<nav
    class:list={["breadcrumb-nav", className]}
    aria-label="Migas de pan"
>
    <a href="/utilidades/" class="breadcrumb-link">Todas las utilidades</a>

    {
        category && categorySlug && (
            <>
                <span class="breadcrumb-separator">/</span>
                <a href={`/utilidades/categorias/${categorySlug}/`} class="breadcrumb-link breadcrumb-category">
                    <span>{category}</span>
                </a>
            </>
        )
    }
</nav>

<style>
    .breadcrumb-nav {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
        font-size: 0.875rem;
        border-bottom: 2px solid var(--breadcrumb-border);
        transition: border-color 0.3s ease;
    }

    .breadcrumb-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--breadcrumb-text);
        text-decoration: none;
        font-weight: 500;
        position: relative;
        padding: 0.5rem 0.75rem;
        margin: -0.5rem -0.75rem;
        cursor: pointer;
        transition: color 0.2s ease;
        border-radius: 0.375rem;
    }

    .breadcrumb-link::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 0.75rem;
        width: 0;
        height: 2px;
        background: var(--breadcrumb-accent);
        transition: width 0.3s ease;
    }

    .breadcrumb-link:hover {
        color: var(--breadcrumb-hover);
        background: var(--breadcrumb-hover-bg);
    }

    .breadcrumb-link:hover::after {
        width: calc(100% - 1.5rem);
    }

    .breadcrumb-separator {
        color: var(--breadcrumb-separator);
        font-weight: 300;
    }

    .breadcrumb-category {
        font-weight: 600;
    }

    :global(html:not(.dark)) .breadcrumb-nav {
        --breadcrumb-border: #e2e8f0;
        --breadcrumb-text: #64748b;
        --breadcrumb-hover: #1e293b;
        --breadcrumb-separator: #cbd5e1;
        --breadcrumb-accent: #0ea5e9;
        --breadcrumb-hover-bg: #f1f5f9;
    }

    :global(html.dark) .breadcrumb-nav {
        --breadcrumb-border: #334155;
        --breadcrumb-text: #94a3b8;
        --breadcrumb-hover: #f1f5f9;
        --breadcrumb-separator: #475569;
        --breadcrumb-accent: #0ea5e9;
        --breadcrumb-hover-bg: #1e293b;
    }
</style>
