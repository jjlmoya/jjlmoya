---
import "./HeaderLight.css";
import ThemeToggle from "./ui/ThemeToggle.astro";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---

<nav class="main-navigation-light" id="main-nav-light">
    <div class="navigation-container-light">
        <a href="/" class="brand-link-light">jjlmoya</a>

        <div class="nav-links-light">
            <a
                href="/proyectos/"
                class={`nav-item-link-light ${currentPath.startsWith("proyectos") ? "nav-active-light" : ""}`}
                aria-current={currentPath.startsWith("proyectos") ? "page" : undefined}
                data-astro-prefetch>proyectos</a
            >
            <a
                href="/conceptos/"
                class={`nav-item-link-light ${currentPath.startsWith("conceptos") ? "nav-active-light" : ""}`}
                aria-current={currentPath.startsWith("conceptos") ? "page" : undefined}
                data-astro-prefetch>conceptos</a
            >
            <a
                href="/apps/"
                class={`nav-item-link-light ${currentPath.startsWith("apps") ? "nav-active-light" : ""}`}
                aria-current={currentPath.startsWith("apps") ? "page" : undefined}
                data-astro-prefetch>apps</a
            >
            <a
                href="/utilidades/"
                class={`nav-item-link-light ${currentPath.startsWith("utilidades") ? "nav-active-light" : ""}`}
                aria-current={currentPath.startsWith("utilidades") ? "page" : undefined}
                data-astro-prefetch>utilidades</a
            >
            <a
                href="/gamebob/"
                class={`nav-item-link-light ${currentPath.startsWith("gamebob") ? "nav-active-light" : ""}`}
                aria-current={currentPath.startsWith("gamebob") ? "page" : undefined}
                data-astro-prefetch>gamebob</a
            >
            <a
                href="/charlas/"
                class={`nav-item-link-light ${currentPath.startsWith("charlas") ? "nav-active-light" : ""}`}
                aria-current={currentPath.startsWith("charlas") ? "page" : undefined}
                data-astro-prefetch>charlas</a
            >

            <div class="nav-divider-light"></div>

            <div class="nav-actions-light">
                <ThemeToggle />
                <button
                    class="search-button-light"
                    aria-label="Buscar (Ctrl + K / Espacio)"
                    title="Buscar (Ctrl + K / Espacio)"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.3-4.3"></path>
                    </svg>
                </button>
            </div>
        </div>

        <button
            class="menu-toggle-button-light"
            aria-label="Abrir Menú"
        >
            <span class="menu-toggle-line-light line-1"></span>
            <span class="menu-toggle-line-light line-2"></span>
        </button>
    </div>
</nav>

<div class="mobile-overlay-light">
    <div class="mobile-overlay-content-light">
        <a href="/proyectos/" class="menu-link-light" style="--delay: 0.1s">
            <span class="link-number-light">01</span>
            <span class="link-text-light">Proyectos</span>
        </a>
        <a href="/conceptos/" class="menu-link-light" style="--delay: 0.2s">
            <span class="link-number-light">02</span>
            <span class="link-text-light">Conceptos</span>
        </a>
        <a href="/apps/" class="menu-link-light" style="--delay: 0.3s">
            <span class="link-number-light">03</span>
            <span class="link-text-light">Apps</span>
        </a>
        <a href="/utilidades/" class="menu-link-light" style="--delay: 0.4s">
            <span class="link-number-light">04</span>
            <span class="link-text-light">Utilidades</span>
        </a>
        <a href="/gamebob/" class="menu-link-light" style="--delay: 0.5s">
            <span class="link-number-light">05</span>
            <span class="link-text-light">GameBob</span>
        </a>
        <a href="/charlas/" class="menu-link-light" style="--delay: 0.6s">
            <span class="link-number-light">06</span>
            <span class="link-text-light">Charlas</span>
        </a>
    </div>
</div>
