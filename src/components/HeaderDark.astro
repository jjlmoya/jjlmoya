---
import "./HeaderDark.css";
import ThemeToggle from "./ui/ThemeToggle.astro";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---

<nav class="main-navigation-dark" id="main-nav-dark">
    <div class="navigation-container-dark">
        <a href="/" class="brand-link-dark">jjlmoya</a>

        <div class="nav-links-dark">
            <a
                href="/proyectos/"
                class={`nav-item-link-dark ${currentPath.startsWith("proyectos") ? "nav-active-dark" : ""}`}
                aria-current={currentPath.startsWith("proyectos") ? "page" : undefined}
                data-astro-prefetch>proyectos</a
            >
            <a
                href="/conceptos/"
                class={`nav-item-link-dark ${currentPath.startsWith("conceptos") ? "nav-active-dark" : ""}`}
                aria-current={currentPath.startsWith("conceptos") ? "page" : undefined}
                data-astro-prefetch>conceptos</a
            >
            <a
                href="/apps/"
                class={`nav-item-link-dark ${currentPath.startsWith("apps") ? "nav-active-dark" : ""}`}
                aria-current={currentPath.startsWith("apps") ? "page" : undefined}
                data-astro-prefetch>apps</a
            >
            <a
                href="/utilidades/"
                class={`nav-item-link-dark ${currentPath.startsWith("utilidades") ? "nav-active-dark" : ""}`}
                aria-current={currentPath.startsWith("utilidades") ? "page" : undefined}
                data-astro-prefetch>utilidades</a
            >
            <a
                href="/gamebob/"
                class={`nav-item-link-dark ${currentPath.startsWith("gamebob") ? "nav-active-dark" : ""}`}
                aria-current={currentPath.startsWith("gamebob") ? "page" : undefined}
                data-astro-prefetch>gamebob</a
            >
            <a
                href="/charlas/"
                class={`nav-item-link-dark ${currentPath.startsWith("charlas") ? "nav-active-dark" : ""}`}
                aria-current={currentPath.startsWith("charlas") ? "page" : undefined}
                data-astro-prefetch>charlas</a
            >

            <div class="nav-divider-dark"></div>

            <div class="nav-actions-dark">
                <ThemeToggle />
                <button
                    class="search-button-dark"
                    aria-label="Buscar (Ctrl + K / Espacio)"
                    title="Buscar (Ctrl + K / Espacio)"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.3-4.3"></path>
                    </svg>
                </button>
            </div>
        </div>

        <button
            class="menu-toggle-button-dark"
            aria-label="Abrir Menú"
        >
            <span class="menu-toggle-line-dark line-1"></span>
            <span class="menu-toggle-line-dark line-2"></span>
        </button>
    </div>
</nav>

<div class="mobile-overlay-dark">
    <div class="mobile-overlay-content-dark">
        <a href="/proyectos/" class="menu-link-dark" style="--delay: 0.1s">
            <span class="link-number-dark">01</span>
            <span class="link-text-dark">Proyectos</span>
        </a>
        <a href="/conceptos/" class="menu-link-dark" style="--delay: 0.2s">
            <span class="link-number-dark">02</span>
            <span class="link-text-dark">Conceptos</span>
        </a>
        <a href="/apps/" class="menu-link-dark" style="--delay: 0.3s">
            <span class="link-number-dark">03</span>
            <span class="link-text-dark">Apps</span>
        </a>
        <a href="/utilidades/" class="menu-link-dark" style="--delay: 0.4s">
            <span class="link-number-dark">04</span>
            <span class="link-text-dark">Utilidades</span>
        </a>
        <a href="/gamebob/" class="menu-link-dark" style="--delay: 0.5s">
            <span class="link-number-dark">05</span>
            <span class="link-text-dark">GameBob</span>
        </a>
        <a href="/charlas/" class="menu-link-dark" style="--delay: 0.6s">
            <span class="link-number-dark">06</span>
            <span class="link-text-dark">Charlas</span>
        </a>
        <div class="mobile-theme-toggle-dark" style="--delay: 0.7s">
            <ThemeToggle />
        </div>
    </div>
</div>
