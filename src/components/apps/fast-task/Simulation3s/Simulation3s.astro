---
import "./Simulation3s.css";
import { Icon } from "astro-icon/components";
---

<section
    class="simulation-3s-section relative py-32 px-6 overflow-hidden bg-[#0a0f14] border-y border-white/5"
    id="simulation-3s"
>
    <div class="absolute inset-0 pointer-events-none">
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#04D991] opacity-[0.02] blur-[150px] rounded-full"
        >
        </div>
    </div>

    <div class="max-w-7xl mx-auto flex flex-col items-center relative z-10">
        <h2
            class="text-3xl md:text-5xl font-black uppercase italic tracking-tighter mb-2 text-center text-white/80"
        >
            Del pensamiento a la acción en
        </h2>

        
        <div
            class="text-[#04D991] text-6xl md:text-9xl font-black uppercase italic tracking-tighter mb-10 md:mb-20 simulation-timer"
            id="sim-timer"
        >
            0.00s
        </div>

        <div class="relative w-full max-w-5xl mx-auto flex flex-col md:flex-row sim-timeline">
            <div
                class="absolute top-1/2 left-[10%] w-[80%] h-1 bg-white/10 -translate-y-1/2 rounded-full overflow-hidden hidden md:block z-0"
            >
                <div
                    class="h-full bg-[#04D991] sim-progress-bar w-0 shadow-[0_0_20px_#04D991]"
                    id="sim-progress-desk"
                >
                </div>
            </div>

            <div
                class="absolute top-0 left-1/2 w-1 h-full bg-white/10 -translate-x-1/2 rounded-full overflow-hidden md:hidden z-0"
            >
                <div
                    class="w-full bg-[#04D991] sim-progress-bar h-0 shadow-[0_0_20px_#04D991]"
                    id="sim-progress-mob"
                >
                </div>
            </div>

            
            <div
                class="relative flex flex-col md:flex-row justify-between items-center w-full z-10 gap-6 md:gap-0"
            >
                <div class="sim-step w-full md:w-1/3" data-step="1">
                    <div class="sim-step-icon bg-[#0a0f14] relative z-10">
                        <Icon name="mdi:keyboard-outline" class="w-6 h-6 md:w-8 md:h-8" />
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="sim-step-label">Escribes</div>
                        <div class="sim-step-desc">Abre la app y captura tu idea al vuelo.</div>
                    </div>
                </div>

                
                <div class="sim-step w-full md:w-1/3" data-step="2">
                    <div class="sim-step-icon bg-[#0a0f14] relative z-10">
                        <Icon name="mdi:brain" class="w-6 h-6 md:w-8 md:h-8" />
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="sim-step-label">Contexto</div>
                        <div class="sim-step-desc">Se formatea y enriquece automáticamente.</div>
                    </div>
                </div>

                
                <div class="sim-step w-full md:w-1/3" data-step="3">
                    <div class="sim-step-icon bg-[#0a0f14] relative z-10">
                        <Icon name="mdi:send-check" class="w-6 h-6 md:w-8 md:h-8" />
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="sim-step-label">Enviado</div>
                        <div class="sim-step-desc">
                            Directo a tu integración, listo para producción.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="./Simulation3s.ts"></script>
