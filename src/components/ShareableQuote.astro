---
import "./ShareableQuote.css";

interface Props {
    quote: string;
    hashtag?: string;
    className?: string;
}

const { quote, hashtag = "HistoriaDelTrigo", className = "" } = Astro.props;

const shareText = `${quote} #${hashtag}`;
---

<span
    class={`shareable-quote ${className}`}
    data-share-btn
    data-share-text={shareText}
>
    <span class="shareable-quote-text">
        {quote}
    </span>

    <span class="shareable-quote-tooltip" aria-hidden="true">
        <span class="shareable-quote-badge">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="shareable-quote-icon"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"
                ></path>
            </svg>
            Compartir idea
        </span>

        <span class="shareable-quote-arrow"></span>
    </span>
</span>

<script>
    import "../utils/share";
</script>
