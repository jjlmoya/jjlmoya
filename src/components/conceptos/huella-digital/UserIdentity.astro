---

---

<section class="identity-section">
    <div class="identity-background">
        <div class="noise-bg"></div>
    </div>

    <div class="identity-grid">
        <div class="identity-header">
            <span class="identity-tag">SECCIÓN 02 // Auditoría del Sujeto</span>
            <h2 class="identity-title">
                Usted es su Propio Rastro
            </h2>
        </div>

        <div class="audit-card">
            <div class="audit-info">
                <div class="identifier-group">
                    <p class="audit-label">
                        Identificador Gubernamental
                    </p>
                    <p id="user-id-val" class="audit-id">
                        SR-XXXX
                    </p>
                </div>
                <div class="audit-details">
                    <div class="detail-group">
                        <p class="detail-label">Cromatismo</p>
                        <p id="user-hex-val" class="detail-val">#FFFFFF</p>
                    </div>
                    <div class="detail-group">
                        <p class="detail-label">Procedencia</p>
                        <p id="user-os-val" class="detail-val">UNKN-OS</p>
                    </div>
                </div>
            </div>
            <div class="audit-footer">
                <div class="pulse-green"></div>
                <p class="footer-status-text">
                    Sujeto verificado y archivado con éxito.
                </p>
            </div>
        </div>

        <div class="aura-container">
            <div id="user-aura-box" class="aura-box"></div>
            <p class="aura-label">
                Su huella cromática en jjlmoya.es
            </p>
        </div>
    </div>
</section>

<style>
    .identity-section {
        width: 100%;
        padding: 4rem 0;
        background-color: #000;
        color: #fff;
        display: flex;
        justify-content: center;
        position: relative;
        overflow: hidden;
        box-sizing: border-box;
    }

    .identity-background {
        position: absolute;
        inset: 0;
        opacity: 0.1;
        pointer-events: none;
        filter: grayscale(100%) contrast(150%);
        mix-blend-mode: overlay;
    }

    .noise-bg {
        width: 100%;
        height: 100%;
        background-image: url('https://grainy-gradients.vercel.app/noise.svg');
    }

    .identity-grid {
        max-width: 56rem;
        width: 100%;
        padding: 0 2rem;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 2rem;
        align-items: center;
        position: relative;
        z-index: 10;
        box-sizing: border-box;
    }

    .identity-header {
        grid-column: span 12 / span 12;
        margin-bottom: 3rem;
        text-align: center;
    }

    .identity-tag {
        font-size: 0.75rem;
        font-family: monospace;
        font-weight: 700;
        letter-spacing: 0.6em;
        text-transform: uppercase;
        opacity: 0.4;
    }

    .identity-title {
        font-size: 2.25rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        font-style: italic;
        margin: 1rem 0 0 0;
    }

    @media (min-width: 640px) {
        .identity-title {
            font-size: 3rem;
        }
    }

    @media (min-width: 768px) {
        .identity-title {
            font-size: 4.5rem;
        }
    }

    .audit-card {
        grid-column: span 12 / span 12;
        padding: 3rem;
        border: 2px solid rgba(255, 255, 255, 0.2);
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(4px);
        display: flex;
        flex-direction: column;
        gap: 3rem;
        box-sizing: border-box;
    }

    @media (min-width: 1024px) {
        .audit-card {
            grid-column: span 7 / span 7;
        }
    }

    .audit-info {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .identifier-group {
        display: flex;
        flex-direction: column;
    }

    .audit-label {
        font-size: 10px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.3;
        margin: 0 0 0.5rem 0;
    }

    .audit-id {
        font-size: 3rem;
        font-weight: 900;
        font-family: monospace;
        letter-spacing: -0.05em;
        color: #facc15;
        margin: 0;
    }

    .audit-details {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        font-family: monospace;
        font-size: 10px;
        text-transform: uppercase;
    }

    .detail-group {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .detail-label {
        opacity: 0.3;
        margin: 0;
    }

    .detail-val {
        font-weight: 700;
        font-size: 1.125rem;
        margin: 0;
    }

    .audit-footer {
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .pulse-green {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background-color: #22c55e;
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }

    .footer-status-text {
        font-size: 9px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0;
    }

    .aura-container {
        grid-column: span 12 / span 12;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    @media (min-width: 1024px) {
        .aura-container {
            grid-column: span 5 / span 5;
        }
    }

    .aura-box {
        width: 100%;
        aspect-ratio: 1 / 1;
        border: 8px solid #fff;
        box-shadow: 0 0 100px rgba(255, 255, 255, 0.1);
        transition: background-color 1s ease;
        box-sizing: border-box;
    }

    .aura-label {
        font-size: 10px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-align: center;
        opacity: 0.4;
        margin: 0;
    }
</style>

<script>
    function updateSelfIdentity(data?: any) {
        const localData = data || JSON.parse(localStorage.getItem("jjlmoya_footprint_v5") || "{}");
        if (!localData.id) return;

        const myColor = localData.color || "#cccccc";
        const myId = localData.id;

        const aura = document.getElementById("user-aura-box");
        const hex = document.getElementById("user-hex-val");
        const id = document.getElementById("user-id-val");
        const os = document.getElementById("user-os-val");

        if (aura) aura.style.backgroundColor = myColor;
        if (hex) hex.textContent = myColor.toUpperCase();
        if (id) id.textContent = myId;

        const platformMatch = navigator.userAgent.match(/\(([^)]+)\)/);
        if (os)
            os.textContent = platformMatch
                ? platformMatch[1].split(";")[0].toUpperCase().trim()
                : "ANDROID_SR";
    }

    window.addEventListener("user-id-ready", (e: any) => {
        updateSelfIdentity(e.detail);
    });

    updateSelfIdentity();
</script>
