---

---

<section class="mural-section">
    <div class="mural-header">
        <div class="mural-title-group">
            <h2 class="mural-title">Mural de Permanencia Colectiva</h2>
            <p class="mural-subtitle">
                Estrato geológico de metadatos [Haga clic en un bloque para auditar]
            </p>
        </div>
        <div class="mural-actions">
            <div id="grid-controls" class="density-controls">
                <button data-size="small" class="density-btn active" title="Densidad Alta">
                    <div class="icon-small"></div>
                </button>
                <button data-size="large" class="density-btn" title="Densidad Baja">
                    <div class="icon-large"></div>
                </button>
            </div>
            <div class="divider"></div>
            <div class="status-indicator">
                <div class="pulse-dot"></div>
                <span class="status-text">Vista: Archivo Completo</span>
            </div>
        </div>
    </div>

    <div class="mural-workspace">
        <div id="mural-container" class="mural-grid density-high">
        </div>

        <div id="integrated-inspector" class="integrated-inspector idle">
            <div id="inspector-idle-state" class="inspector-idle-state">
                <div class="idle-icon-container">
                    <div class="crosshair-icon"></div>
                </div>
                <p class="idle-title">[SISTEMA EN ESPERA]</p>
                <p class="idle-text">
                    Seleccione cualquier píxel del estrato para auditar su registro de metadatos.
                </p>
            </div>

            <div id="inspector-active-state" class="inspector-active-state hidden">
                <div class="inspector-header">
                    <div class="active-status">
                        <div class="pulse-red"></div>
                        <span class="active-status-text">AUDITORÍA ACTIVA</span>
                    </div>
                    <h3 id="insp-id-title" class="active-id">SR-XXXX</h3>
                </div>

                <div class="inspector-visual">
                    <div id="insp-color-box" class="insp-color-box"></div>
                </div>

                <div class="inspector-meta-grid">
                    <div class="meta-item">
                        <span class="meta-label">Entorno</span>
                        <span id="insp-os-val" class="meta-val">---</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Procedencia</span>
                        <span id="insp-path-val" class="meta-val">---</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Registro</span>
                        <span id="insp-time-val" class="meta-val">---</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Cromaticidad</span>
                        <span id="insp-hex-val" class="meta-val">#------</span>
                    </div>
                </div>


                <button id="download-certificate" class="btn-download">
                    GENERAR CERTIFICADO [PNG]
                </button>
            </div>
        </div>
    </div>

    <div class="mural-footer">
        <p class="count-text">
            Total de huellas indexadas en el estrato: <span id="mural-count" class="count-number"
                >0</span
            >
        </p>
    </div>
</section>

<style>
    .mural-section {
        width: 100%;
        max-width: 72rem;
        padding: 2rem;
        margin: 0 auto;
        box-sizing: border-box;
    }

    .mural-header {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
        border-bottom: 2px solid #000;
        padding-bottom: 2rem;
    }

    @media (min-width: 768px) {
        .mural-header {
            flex-direction: row;
        }
    }

    .mural-title-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .mural-title {
        font-size: 1.5rem;
        font-weight: 900;
        text-transform: uppercase;
        font-style: italic;
        letter-spacing: -0.05em;
        margin: 0;
    }

    .mural-subtitle {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.4;
        margin: 0;
    }

    .mural-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .density-controls {
        display: flex;
        gap: 0.5rem;
    }

    .density-btn {
        padding: 0.5rem;
        border: 1px solid #000;
        background: transparent;
        cursor: pointer;
        transition:
            background-color 0.2s,
            color 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .density-btn:hover {
        background-color: #000;
        color: #fff;
    }

    .density-btn.active {
        background-color: #000;
        color: #fff;
    }

    .icon-small {
        width: 0.75rem;
        height: 0.75rem;
        border: 1px solid currentColor;
    }

    .icon-large {
        width: 1.25rem;
        height: 1.25rem;
        border: 1px solid currentColor;
    }

    .divider {
        height: 2rem;
        width: 1px;
        background-color: rgba(0, 0, 0, 0.1);
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 1rem;
        background-color: rgba(0, 0, 0, 0.05);
        padding: 0.5rem 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
    }

    .pulse-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background-color: #dc2626;
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.5;
        }
    }

    .status-text {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .mural-workspace {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        margin-top: 2rem;
        width: 100%;
    }

    @media (min-width: 1024px) {
        .mural-workspace {
            display: grid;
            grid-template-columns: 1fr 360px;
            gap: 2.5rem;
            align-items: start;
        }
    }

    .mural-grid {
        display: grid;
        grid-template-columns: repeat(var(--grid-cols, 40), 1fr);
        gap: 0;
        padding: 0;
        background-color: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(0, 0, 0, 0.05);
        min-height: 600px;
        box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
        position: relative;
        align-content: start;
    }

    #mural-container {
        --grid-cols: 40;
    }
    #mural-container.density-high {
        --grid-cols: 80;
    }
    @media (min-width: 640px) {
        #mural-container {
            --grid-cols: 60;
        }
        #mural-container.density-high {
            --grid-cols: 100;
        }
    }
    @media (min-width: 768px) {
        #mural-container {
            --grid-cols: 100;
        }
        #mural-container.density-high {
            --grid-cols: 150;
        }
    }

    .integrated-inspector {
        border: 2px solid #000;
        background-color: #fff;
        min-height: 600px;
        box-shadow: 10px 10px 0px rgba(0, 0, 0, 0.05);
        padding: 2rem;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .integrated-inspector.idle {
        justify-content: center;
        align-items: center;
        border-style: dashed;
        background-color: rgba(255, 255, 255, 0.4);
    }

    .inspector-idle-state {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .idle-icon-container {
        width: 3.5rem;
        height: 3.5rem;
        border: 2px dashed rgba(0, 0, 0, 0.2);
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .crosshair-icon {
        width: 1rem;
        height: 1rem;
        border: 2px solid #000;
        border-radius: 9999px;
        position: relative;
    }

    .crosshair-icon::before,
    .crosshair-icon::after {
        content: '';
        position: absolute;
        background-color: #000;
    }

    .crosshair-icon::before {
        top: 50%;
        left: -6px;
        right: -6px;
        height: 2px;
        transform: translateY(-50%);
    }

    .crosshair-icon::after {
        left: 50%;
        top: -6px;
        bottom: -6px;
        width: 2px;
        transform: translateX(-50%);
    }

    .idle-title {
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 0.2em;
        margin: 0;
    }

    .idle-text {
        font-size: 11px;
        line-height: 1.6;
        color: rgba(0, 0, 0, 0.5);
        max-width: 240px;
        margin: 0;
    }

    .inspector-active-state {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        height: 100%;
    }

    .hidden {
        display: none !important;
    }

    .inspector-header {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .active-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .pulse-red {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background-color: #dc2626;
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .active-status-text {
        font-size: 9px;
        font-weight: 900;
        letter-spacing: 0.1em;
        color: #dc2626;
    }

    .active-id {
        font-size: 2.25rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        font-style: italic;
        margin: 0;
    }

    .inspector-visual {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        border: 4px solid #000;
        overflow: hidden;
        box-sizing: border-box;
    }

    .insp-color-box {
        width: 100%;
        height: 100%;
        transition: background-color 0.5s ease;
    }



    .inspector-meta-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        padding: 1.5rem 0;
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .meta-label {
        font-size: 8px;
        font-weight: 900;
        text-transform: uppercase;
        opacity: 0.4;
    }

    .meta-val {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        word-break: break-all;
    }



    .btn-download {
        background-color: #000;
        color: #fff;
        padding: 1rem;
        font-size: 10px;
        font-weight: 900;
        border: 1px solid #000;
        cursor: pointer;
        transition: background-color 0.2s;
        text-align: center;
        width: 100%;
        margin-top: auto;
    }

    .btn-download:hover {
        background-color: rgba(0, 0, 0, 0.8);
    }

    .mural-footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 2rem 0;
    }

    .count-text {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(0, 0, 0, 0.3);
        text-align: center;
        margin: 0;
    }

    .count-number {
        color: rgba(0, 0, 0, 0.6);
    }
</style>

<style is:global>
    .pixel-block {
        width: 100%;
        aspect-ratio: 1 / 1;
        cursor: crosshair;
        transition: all 0.2s ease;
    }
</style>

<script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>

<script>
    const container = document.getElementById("mural-container");
    const muralCount = document.getElementById("mural-count");
    const totalCensus = document.getElementById("total-census");
    const renderedTimestamps = new Set<number | string>();

    const integratedInspector = document.getElementById("integrated-inspector");
    const idleState = document.getElementById("inspector-idle-state");
    const activeState = document.getElementById("inspector-active-state");

    const colorBox = document.getElementById("insp-color-box");
    const idTitle = document.getElementById("insp-id-title");
    const osVal = document.getElementById("insp-os-val");
    const pathVal = document.getElementById("insp-path-val");
    const hexVal = document.getElementById("insp-hex-val");
    const timeVal = document.getElementById("insp-time-val");

    type Footprint = [number | string, string, string, string, string, string];

    let currentSelectedData: Footprint | null = null;

    let allFootprints: Footprint[] = [];
    let index = 0;
    let batchSize = 1;
    let isLiveReady = false;
    let isDrawing = false;
    let liveFrameCount = 0;
    let triggerDraw: (() => void) | null = null;
    let animationTimer: any = null;

    function handleUpdate(footprints: Footprint[]) {
        if (!container || !footprints) return;

        if (footprints.length === renderedTimestamps.size) return;

        if (allFootprints.length > 0) {
            allFootprints = footprints;
            if (!isDrawing && triggerDraw) {
                triggerDraw();
            }
            return;
        }

        allFootprints = footprints;
        isLiveReady = false;
        liveFrameCount = 0;

        if (animationTimer) {
            cancelAnimationFrame(animationTimer);
        }

        container.innerHTML = "";
        renderedTimestamps.clear();
        index = 0;
        batchSize = 1;

        function createBlockElement(f: Footprint, idx: number) {
            const block = document.createElement("div");
            block.className = "pixel-block";
            block.style.backgroundColor = f[1];
            block.setAttribute("data-index", idx.toString());
            return block;
        }

        let frameCount = 0;

        function drawStep() {
            isDrawing = true;
            if (index >= allFootprints.length) {
                isDrawing = false;
                return;
            }

            if (!isLiveReady) {
                frameCount++;
                if (frameCount % 4 !== 0) {
                    animationTimer = requestAnimationFrame(drawStep);
                    return;
                }
            }

            const fragment = document.createDocumentFragment();
            let added = false;

            for (let b = 0; b < batchSize && index < allFootprints.length; b++) {
                const f = allFootprints[index];
                if (f && f[0] && !renderedTimestamps.has(f[0])) {
                    renderedTimestamps.add(f[0]);
                    const block = createBlockElement(f, index);
                    fragment.appendChild(block);
                    added = true;
                }
                index++;
            }

            if (added) {
                container!.appendChild(fragment);
            }

            if (muralCount) muralCount.textContent = renderedTimestamps.size.toString();
            if (totalCensus) totalCensus.textContent = renderedTimestamps.size.toString().padStart(4, "0");

            if (isLiveReady) {
                liveFrameCount++;
                batchSize = Math.floor(100 * Math.pow(1.5, liveFrameCount));
            } else {
                batchSize = 1;
            }

            animationTimer = requestAnimationFrame(drawStep);
        }

        triggerDraw = drawStep;
        drawStep();
    }

    function showAuditDetails(data: Footprint) {
        currentSelectedData = data;

        if (integratedInspector) {
            integratedInspector.classList.remove("idle");
        }
        if (idleState) idleState.classList.add("hidden");
        if (activeState) activeState.classList.remove("hidden");

        if (colorBox) colorBox.style.backgroundColor = data[1];
        if (idTitle) idTitle.textContent = data[4] || "SR-DE-DATA";
        if (osVal)
            osVal.textContent = (data[2] || "").split(")")[0].split("(").pop() || "LINUX_SERVER";
        if (pathVal) pathVal.textContent = data[5] || "/ROOT";
        if (hexVal) hexVal.textContent = data[1].toUpperCase();
        if (timeVal) timeVal.textContent = new Date(data[0]).toLocaleString("es-ES");
    }



    window.addEventListener("footprints-updated", (e: any) => {
        handleUpdate(e.detail);
    });

    window.addEventListener("live-data-ready", () => {
        isLiveReady = true;
        if (!isDrawing && triggerDraw) {
            triggerDraw();
        }
    });

    if (container) {
        container.addEventListener("mouseover", (e: MouseEvent) => {
            const target = e.target as HTMLElement;
            if (target && target.classList.contains("pixel-block")) {
                if (!target.classList.contains("selected")) {
                    target.style.transform = "scale(1.5)";
                    target.style.zIndex = "50";
                    target.style.outline = "1px solid rgba(0, 0, 0, 0.6)";
                }
            }
        });

        container.addEventListener("mouseout", (e: MouseEvent) => {
            const target = e.target as HTMLElement;
            if (target && target.classList.contains("pixel-block")) {
                if (!target.classList.contains("selected")) {
                    target.style.transform = "none";
                    target.style.zIndex = "auto";
                    target.style.outline = "none";
                }
            }
        });

        container.addEventListener("click", (e: MouseEvent) => {
            const target = e.target as HTMLElement;
            if (target && target.classList.contains("pixel-block")) {
                e.stopPropagation();

                container.querySelectorAll(".selected").forEach((el: any) => {
                    el.classList.remove("selected");
                    el.style.transform = "none";
                    el.style.zIndex = "auto";
                    el.style.outline = "none";
                });

                target.classList.add("selected");
                target.style.transform = "scale(2.5)";
                target.style.zIndex = "60";
                target.style.outline = "3px solid #000";

                const idxAttr = target.getAttribute("data-index");
                if (idxAttr) {
                    const idx = parseInt(idxAttr, 10);
                    const f = allFootprints[idx];
                    if (f) {
                        showAuditDetails(f);
                    }
                }
            }
        });
    }

    if ((window as any).footprints) {
        handleUpdate((window as any).footprints as Footprint[]);
    }

    document.querySelectorAll("#grid-controls button").forEach((btn) => {
        btn.addEventListener("click", () => {
            if (!container) return;
            document.querySelectorAll("#grid-controls button").forEach((b) => {
                b.classList.remove("active");
            });
            btn.classList.add("active");
            const size = btn.getAttribute("data-size");
            if (size === "small") {
                container.classList.add("density-high");
            } else {
                container.classList.remove("density-high");
            }
        });
    });

    document.getElementById("download-certificate")?.addEventListener("click", async () => {
        if (!currentSelectedData) return;
        const btn = document.getElementById("download-certificate") as HTMLButtonElement;
        const originalText = btn.textContent;
        btn.textContent = "GENERANDO...";

        try {
            const cert = document.createElement("div");
            cert.style.position = "absolute";
            cert.style.left = "-9999px";
            cert.style.width = "800px";
            cert.style.height = "1000px";
            cert.style.padding = "80px";
            cert.style.backgroundColor = "#f4f1ea";
            cert.style.fontFamily = "monospace";
            cert.style.display = "flex";
            cert.style.flexDirection = "column";
            cert.style.alignItems = "center";
            cert.style.justifyContent = "center";
            cert.style.border = "20px solid black";

            cert.innerHTML = `
                <div style="border: 2px solid black; padding: 20px; width: 100%; text-align: center; margin-bottom: 40px;">
                    <h1 style="font-size: 24px; font-weight: 900; margin: 0;">CERTIFICADO DE EXISTENCIA TÉCNICA</h1>
                    <p style="font-size: 10px; opacity: 0.5;">REGISTRO CENTRAL DE HUELLAS // JJLMOYA.ES</p>
                </div>
                <div style="width: 400px; height: 400px; background-color: ${currentSelectedData[1]}; border: 10px solid black; margin-bottom: 40px;"></div>
                <div style="width: 100%; text-align: left; line-height: 2;">
                    <p><strong>SUJETO ID:</strong> ${currentSelectedData[4] || "SR-0000"}</p>
                    <p><strong>COLOR REF:</strong> ${currentSelectedData[1].toUpperCase()}</p>
                    <p><strong>ENTORNO:</strong> ${currentSelectedData[2]}</p>
                    <p><strong>CAPTURA:</strong> ${new Date(currentSelectedData[0]).toLocaleString()}</p>
                    <p><strong>AUTORIDAD:</strong> SISTEMA DE REGISTRO PASIVO ALPHA</p>
                </div>
                <div style="margin-top: 60px; width: 100%; border-top: 1px solid black; padding-top: 20px; font-size: 10px; text-align: justify; opacity: 0.6;">
                    Este documento certifica que el rastro digital del sujeto ha sido capturado e indexado de forma inmutable en los servidores de jjlmoya.es. La persistencia técnica es irrevocable.
                </div>
            `;
            document.body.appendChild(cert);

            const canvas = await (window as any).html2canvas(cert);
            const link = document.createElement("a");
            link.download = `huella-${currentSelectedData[4] || "sr"}.webp`;
            link.href = canvas.toDataURL();
            link.click();

            document.body.removeChild(cert);
        } catch (err) {
            console.error(err);
        } finally {
            btn.textContent = originalText;
        }
    });
</script>
