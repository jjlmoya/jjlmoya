---

<section class="stats-section">
    <div class="stats-grid">
        <div class="stats-left">
            <div class="stats-intro">
                <h2 class="stats-title">
                    El Rastro <br />
                    Consolidado
                </h2>
                <div class="title-line"></div>
                <p class="stats-description">
                    Cada interacción en este espacio genera una huella única. Este registro no es
                    una estadística de tráfico convencional; es la acumulación histórica de
                    presencias digitales que han decidido dejar su marca en el archivo.
                </p>
            </div>

            <div class="summary-grid">
                <div class="summary-item">
                    <span class="summary-label">Dispositivos</span>
                    <div id="os-summary" class="summary-val">--</div>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Hora Punta</span>
                    <div id="time-summary" class="summary-val">--:00</div>
                </div>
            </div>
        </div>

        <div class="stats-right">
            <div class="chart-card weekly-card">
                <div class="card-ref">Ref: HIST-7D-STRATA</div>
                <h4 class="card-title">
                    <span class="pulse-black"></span>
                    Estratos de Crecimiento (Bloques de 7 Días)
                </h4>

                <div class="chart-wrapper">
                    <div id="weekly-y-axis" class="y-axis weekly-y">
                        <span>-</span>
                        <span>0 huellas</span>
                    </div>

                    <div class="chart-content-wrapper">
                        <div id="weekly-chart" class="weekly-chart"></div>
                        <div id="weekly-x-axis" class="x-axis weekly-x">
                            <span>Origen del Archivo</span>
                            <span class="x-active">Presente</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="charts-subgrid">
                <div class="chart-card sub-card">
                    <h4 class="card-title-sub">Hábitat de Sistemas</h4>
                    <div id="os-chart" class="os-chart-container"></div>
                </div>
                <div class="chart-card sub-card">
                    <h4 class="card-title-sub">Ritmo Circadiano</h4>

                    <div class="chart-wrapper">
                        <div id="time-y-axis" class="y-axis time-y">
                            <span>-</span>
                            <span>0</span>
                        </div>

                        <div class="chart-content-wrapper">
                            <div id="time-chart" class="time-chart"></div>
                            <div class="x-axis time-x">
                                <span>00h</span>
                                <span>12h</span>
                                <span>23h</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="stats-footer">
        <div class="footer-left-desc">
            <h3 class="footer-title">Cromática del Rastro</h3>
            <p class="footer-desc">
                Cada huella es procesada y traducida a un valor cromático basado en sus metadatos
                técnicos. Esta secuencia representa la cronología visual de las últimas capturas
                registradas en el sistema.
            </p>
        </div>
        <div class="footer-right-spectrum">
            <div id="color-spectrum" class="color-spectrum"></div>
            <div class="spectrum-labels">
                <span class="spectrum-label-tag">Última Adquisición</span>
                <span id="avg-color-label" class="spectrum-val">#------</span>
            </div>
        </div>
    </div>
</section>

<style>
    .stats-section {
        width: 100%;
        max-width: 72rem;
        padding: 2rem;
        border-top: 2px solid rgba(0, 0, 0, 0.05);
        border-bottom: 2px solid rgba(0, 0, 0, 0.05);
        background-color: rgba(255, 255, 255, 0.2);
        font-family: sans-serif;
        margin: 0 auto;
        box-sizing: border-box;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
    }

    @media (min-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(12, 1fr);
            gap: 6rem;
        }
    }

    .stats-left {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    @media (min-width: 1024px) {
        .stats-left {
            grid-column: span 5 / span 5;
        }
    }

    .stats-intro {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .stats-title {
        font-size: 2.25rem;
        font-weight: 900;
        text-transform: uppercase;
        font-style: italic;
        letter-spacing: -0.05em;
        line-height: 0.9;
        margin: 0;
    }

    @media (min-width: 768px) {
        .stats-title {
            font-size: 3rem;
        }
    }

    .title-line {
        width: 5rem;
        height: 4px;
        background-color: #000;
    }

    .stats-description {
        font-size: 1.125rem;
        font-weight: 300;
        line-height: 1.6;
        color: rgba(0, 0, 0, 0.7);
        margin: 0;
    }

    @media (min-width: 768px) {
        .stats-description {
            font-size: 1.25rem;
        }
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
    }

    .summary-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .summary-label {
        font-size: 10px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.4;
    }

    .summary-val {
        font-size: 1.5rem;
        font-weight: 900;
        font-family: monospace;
        letter-spacing: -0.05em;
    }

    .stats-right {
        display: flex;
        flex-direction: column;
        gap: 4rem;
    }

    @media (min-width: 1024px) {
        .stats-right {
            grid-column: span 7 / span 7;
        }
    }

    .chart-card {
        position: relative;
        padding: 1.5rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        background-color: #fff;
        box-sizing: border-box;
    }

    .weekly-card {
        box-shadow: 10px 10px 0px rgba(0, 0, 0, 0.03);
    }

    .card-ref {
        position: absolute;
        top: 1rem;
        right: 1rem;
        opacity: 0.1;
        font-family: monospace;
        font-size: 8px;
        text-transform: uppercase;
    }

    .card-title {
        font-size: 10px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.4;
        margin: 0 0 2rem 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .pulse-black {
        width: 0.375rem;
        height: 0.375rem;
        background-color: #000;
        border-radius: 9999px;
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .chart-wrapper {
        display: flex;
        gap: 1rem;
    }

    .y-axis {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        font-size: 7px;
        font-family: monospace;
        opacity: 0.3;
        padding: 0.25rem 0;
        text-align: right;
    }

    .weekly-y {
        width: 3rem;
    }

    .chart-content-wrapper {
        flex-grow: 1;
    }

    .weekly-chart {
        height: 14rem;
        display: flex;
        align-items: flex-end;
        gap: 0.25rem;
        padding: 0 0.5rem;
        border-bottom: 2px solid rgba(0, 0, 0, 0.2);
    }

    .x-axis {
        display: flex;
        justify-content: space-between;
        margin-top: 0.5rem;
        font-size: 7px;
        font-family: monospace;
        opacity: 0.5;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        font-weight: 700;
    }

    .x-active {
        color: #000;
    }

    .charts-subgrid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .charts-subgrid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .sub-card {
        background-color: rgba(255, 255, 255, 0.6);
    }

    .card-title-sub {
        font-size: 10px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.4;
        margin: 0 0 1.5rem 0;
    }

    .os-chart-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .time-y {
        width: 0.75rem;
    }

    .time-chart {
        height: 8rem;
        display: flex;
        align-items: flex-end;
        gap: 1px;
        padding-bottom: 0.25rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .time-x {
        margin-top: 0.25rem;
        font-size: 6px;
        opacity: 0.3;
    }

    .stats-footer {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-end;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .stats-footer {
            flex-direction: row;
        }
    }

    .footer-left-desc {
        max-width: 28rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer-title {
        font-size: 10px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.4;
        margin: 0;
    }

    .footer-desc {
        font-size: 0.875rem;
        font-weight: 300;
        line-height: 1.6;
        color: rgba(0, 0, 0, 0.6);
        margin: 0;
    }

    .footer-right-spectrum {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .footer-right-spectrum {
            width: auto;
        }
    }

    .color-spectrum {
        height: 3rem;
        flex-grow: 1;
        border: 1px solid rgba(0, 0, 0, 0.1);
        display: flex;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .color-spectrum {
            width: 16rem;
            flex-grow: 0;
        }
    }

    .spectrum-labels {
        text-align: right;
        white-space: nowrap;
    }

    .spectrum-label-tag {
        font-size: 8px;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        opacity: 0.3;
        display: block;
        margin-bottom: 0.25rem;
    }

    .spectrum-val {
        font-size: 1.25rem;
        font-weight: 900;
        font-family: monospace;
        letter-spacing: -0.05em;
        text-transform: uppercase;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
</style>

<script>
    type Footprint = [number | string, string, string, string, string, string];

    function handleUpdate(footprints: Footprint[]) {
        if (!footprints || !footprints.length) return;

        const osCounts: Record<string, number> = {};
        footprints.forEach((f) => {
            const os = (f[2] || "").split(")")[0].split("(").pop() || "Other";
            const shortOs = os.split(";")[0].split(" ")[0].toUpperCase();
            osCounts[shortOs] = (osCounts[shortOs] || 0) + 1;
        });

        const osChart = document.getElementById("os-chart");
        const osSummary = document.getElementById("os-summary");
        if (osChart) {
            const sortedOs = Object.entries(osCounts)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 4);
            const max = Math.max(...Object.values(osCounts));

            if (osSummary) osSummary.textContent = sortedOs[0][0];

            osChart.innerHTML = sortedOs
                .map(
                    ([os, count]) => `
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                    <div style="display: flex; justify-content: space-between; font-size: 8px; font-family: monospace; font-weight: 700; text-transform: uppercase;">
                        <span style="opacity: 0.4;">${os}</span>
                        <span>${Math.round((count / footprints.length) * 100)}%</span>
                    </div>
                    <div style="width: 100%; height: 0.125rem; background-color: rgba(0,0,0,0.05);">
                        <div style="height: 100%; background-color: #000; transition: all 1s;" style="width: ${(count / max) * 100}%"></div>
                    </div>
                </div>
            `
                )
                .join("");
        }

        const hourCounts = new Array(24).fill(0);
        footprints.forEach((f) => {
            const hour = new Date(f[0]).getHours();
            if (!isNaN(hour)) hourCounts[hour]++;
        });

        const timeChart = document.getElementById("time-chart");
        const timeSummary = document.getElementById("time-summary");
        const timeYAxis = document.getElementById("time-y-axis");

        if (timeChart) {
            const maxHourValue = Math.max(...hourCounts);
            const peakHour = hourCounts.indexOf(maxHourValue);
            if (timeSummary) timeSummary.textContent = `${peakHour.toString().padStart(2, "0")}:00`;

            if (timeYAxis) {
                timeYAxis.innerHTML = `<span>${maxHourValue}</span><span>0</span>`;
            }

            timeChart.innerHTML = hourCounts
                .map(
                    (count, i) => `
                <div style="flex-grow: 1; background-color: rgba(0,0,0,0.1); cursor: pointer; transition: background-color 0.2s; position: relative; height: ${maxHourValue ? (count / maxHourValue) * 100 : 0}%;"
                     onmouseenter="this.style.backgroundColor='#000'; this.querySelector('div').style.display='block';"
                     onmouseleave="this.style.backgroundColor='rgba(0,0,0,0.1)'; this.querySelector('div').style.display='none';">
                    <div style="position: absolute; top: -1.5rem; left: 50%; transform: translateX(-50%); background-color: #000; color: #fff; font-size: 7px; padding: 0.125rem 0.25rem; display: none; z-index: 10; font-family: monospace;">
                        ${i}H
                    </div>
                </div>
            `
                )
                .join("");
        }

        const weeklyChart = document.getElementById("weekly-chart");
        const weeklyYAxis = document.getElementById("weekly-y-axis");
        const weeklyXAxis = document.getElementById("weekly-x-axis");

        if (weeklyChart) {
            const now = new Date();
            now.setHours(23, 59, 59, 999);
            const sevenDaysMs = 7 * 24 * 60 * 60 * 1000;

            const sorted = [...footprints].sort(
                (a, b) => new Date(a[0]).getTime() - new Date(b[0]).getTime()
            );

            if (sorted.length > 0) {
                const firstTs = new Date(sorted[0][0]).getTime();
                const totalDays = Math.ceil((now.getTime() - firstTs) / (24 * 60 * 60 * 1000));
                const numBuckets = Math.ceil(totalDays / 7);

                const buckets = new Array(numBuckets).fill(0);

                footprints.forEach((f) => {
                    const ts = new Date(f[0]).getTime();
                    const diffMs = now.getTime() - ts;
                    const bucketIndex = Math.floor(diffMs / sevenDaysMs);
                    if (bucketIndex >= 0 && bucketIndex < numBuckets) {
                        buckets[numBuckets - 1 - bucketIndex]++;
                    }
                });

                const maxBucket = Math.max(...buckets, 1);

                if (weeklyYAxis) {
                    weeklyYAxis.innerHTML = `<span>${maxBucket}</span><span>0 huellas</span>`;
                }

                if (weeklyXAxis) {
                    const firstDate = new Date(sorted[0][0]).toLocaleDateString("es-ES", {
                        month: "short",
                        year: "2-digit",
                    });
                    weeklyXAxis.innerHTML = `<span>Inundación Inicial (${firstDate})</span><span style="color:#000;">Consolidación (Hoy)</span>`;
                }

                weeklyChart.innerHTML = buckets
                    .map((count, i) => {
                        const daysAgoEnd = (numBuckets - 1 - i) * 7;
                        const daysAgoStart = daysAgoEnd + 7;
                        const label =
                            daysAgoEnd === 0
                                ? "ÚLTIMOS 7 DÍAS"
                                : `HACE ${daysAgoEnd}-${daysAgoStart} DÍAS`;

                        return `
                            <div style="flex-grow: 1; background-color: rgba(0,0,0,0.05); cursor: pointer; transition: all 0.2s; position: relative; height: ${count > 0 ? (count / maxBucket) * 100 : 5}%;"
                                 onmouseenter="this.style.backgroundColor='#000'; this.querySelector('div').style.display='block';"
                                 onmouseleave="this.style.backgroundColor='rgba(0,0,0,0.05)'; this.querySelector('div').style.display='none';">
                                <div style="position: absolute; top: -2.5rem; left: 50%; transform: translateX(-50%); background-color: #000; color: #fff; font-size: 7px; padding: 0.25rem 0.5rem; display: none; z-index: 10; font-family: monospace; white-space: nowrap; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);">
                                    ${label}: ${count} HUELLAS
                                </div>
                            </div>
                        `;
                    })
                    .join("");
            }
        }

        const spectrumBar = document.getElementById("color-spectrum");
        if (spectrumBar) {
            const samples = footprints.slice(-50);
            spectrumBar.innerHTML = samples
                .map(
                    (f) => `
                <div style="flex-grow: 1; height: 100%; background-color: ${f[1]}"></div>
            `
                )
                .join("");

            const lastFootprint = footprints[footprints.length - 1];
            const lastColor = lastFootprint ? lastFootprint[1] : "#------";
            const label = document.getElementById("avg-color-label");
            if (label) label.textContent = lastColor.toUpperCase();
        }
    }

    window.addEventListener("footprints-updated", (e: any) => {
        handleUpdate(e.detail);
    });

    if ((window as any).footprints) {
        handleUpdate((window as any).footprints);
    }
</script>
