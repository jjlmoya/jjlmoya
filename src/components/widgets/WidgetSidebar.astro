---
import { Icon } from "astro-icon/components";

interface Props {
    sections: {
        title: string;
        utilities: {
            title: string;
            description: string;
            href: string;
            icon?: string;
            [key: string]: any;
        }[];
    }[];
}

const { sections } = Astro.props;
---

<aside class="ws-sidebar">
    <div class="ws-header">
        <h1 class="ws-title">
            <Icon name="mdi:widgets-outline" class="ws-title-icon" />
            Studio
        </h1>
        <p class="ws-subtitle">Catálogo Categorizado</p>

        <div class="ws-search-wrapper">
            <input
                type="text"
                id="widget-search"
                placeholder="Buscar herramienta..."
                class="ws-search-input"
            />
            <Icon name="mdi:magnify" class="ws-search-icon" />
        </div>
    </div>

    <nav class="ws-nav">
        {
            sections.map((section, idx) => {
                const isOpenByDefault =
                    section.title.toLowerCase().includes("cocina") ||
                    (idx === 0 && !sections.some((s) => s.title.toLowerCase().includes("cocina")));

                return (
                    <div
                        class={`ws-category ${isOpenByDefault ? "ws-category--open" : ""}`}
                    >
                        <button
                            class="ws-category-toggle"
                            data-group={idx}
                        >
                            <span class="ws-category-label">
                                {section.title}
                            </span>
                            <Icon
                                name="mdi:chevron-down"
                                class={`ws-chevron ${isOpenByDefault ? "ws-chevron--open" : ""}`}
                            />
                        </button>

                        <div
                            class={`ws-category-content ${isOpenByDefault ? "" : "ws-category-content--hidden"}`}
                        >
                            <div class="ws-category-items">
                                {section.utilities.map((u) => (
                                    <button
                                        class="ws-utility-btn"
                                        data-href={u.href}
                                        data-title={u.title}
                                        data-desc={u.description}
                                        data-category={section.title}
                                    >
                                        <span class="ws-utility-label">
                                            {u.title}
                                        </span>
                                    </button>
                                ))}
                            </div>
                        </div>
                    </div>
                );
            })
        }

        <div class="ws-suggest-box">
            <div class="ws-suggest-icon-wrapper">
                <Icon name="mdi:lightbulb-on-outline" class="ws-suggest-icon" />
            </div>
            <div>
                <h4 class="ws-suggest-title">¿Falta algo?</h4>
                <p class="ws-suggest-desc">
                    Si necesitas una utilidad que no está aquí, pídemela y la creo gratis.
                </p>
            </div>
            <a
                href="mailto:juanjo1989@gmail.com"
                class="ws-suggest-btn"
            >
                Sugerir Utilidad
            </a>
        </div>
    </nav>
</aside>

<style>
    .ws-sidebar {
        width: 100%;
        border-bottom: 1px solid var(--wi-sidebar-border);
        background-color: var(--wi-sidebar-bg);
        display: flex;
        flex-direction: column;
        z-index: 30;
        flex-shrink: 0;
    }
    @media (min-width: 1024px) {
        .ws-sidebar {
            width: 20rem;
            border-bottom: none;
            border-right: 1px solid var(--wi-sidebar-border);
        }
    }

    .ws-header {
        padding: 1rem;
        border-bottom: 1px solid var(--wi-sidebar-header-border);
    }
    @media (min-width: 1024px) {
        .ws-header {
            padding: 1.5rem;
        }
    }

    .ws-title {
        font-size: 1.25rem;
        font-weight: 900;
        letter-spacing: -0.025em;
        color: var(--wi-sidebar-title-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .ws-title-icon {
        width: 1.5rem;
        height: 1.5rem;
    }

    .ws-subtitle {
        font-size: 10px;
        color: var(--wi-subtitle-color);
        margin-top: 0.25rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-weight: 700;
    }

    .ws-search-wrapper {
        margin-top: 1.5rem;
        position: relative;
    }

    .ws-search-input {
        width: 100%;
        padding: 0.625rem 1rem 0.625rem 2.5rem;
        background-color: var(--wi-search-input-bg);
        border: none;
        border-radius: 1rem;
        font-size: 0.875rem;
        font-weight: 500;
        transition: box-shadow 0.15s;
        box-sizing: border-box;
    }
    .ws-search-input:focus {
        outline: none;
        box-shadow: 0 0 0 2px #6366f1;
    }

    .ws-search-icon {
        position: absolute;
        left: 0.75rem;
        top: 0.625rem;
        width: 1.25rem;
        height: 1.25rem;
        color: #94a3b8;
    }

    .ws-nav {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1rem;
    }
    .ws-nav > * + * {
        margin-top: 0.5rem;
    }
    @media (min-width: 1024px) {
        .ws-nav {
            padding: 1.5rem 1rem;
        }
        .ws-nav > * + * {
            margin-top: 1rem;
        }
    }

    .ws-category {
        border: 1px solid var(--wi-category-border);
        border-radius: 1rem;
        overflow: hidden;
        transition: all 0.3s;
    }

    .ws-category--open {
        box-shadow: 0 0 0 1px rgba(99, 102, 241, 0.2);
        border-color: rgba(99, 102, 241, 0.3);
    }

    .ws-category-toggle {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
        background-color: var(--wi-category-toggle-bg);
        border: none;
        cursor: pointer;
        transition: background-color 0.15s;
    }
    .ws-category-toggle:hover {
        background-color: var(--wi-category-toggle-hover);
    }

    .ws-category-label {
        font-size: 10px;
        font-weight: 900;
        color: var(--wi-category-label-color);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        transition: color 0.15s;
    }
    .ws-category-toggle:hover .ws-category-label {
        color: #6366f1;
    }
    @media (min-width: 1024px) {
        .ws-category-label {
            font-size: 11px;
        }
    }

    .ws-chevron {
        width: 1rem;
        height: 1rem;
        color: var(--wi-chevron-color);
        transition: transform 0.3s, color 0.15s;
    }
    .ws-category-toggle:hover .ws-chevron {
        color: #818cf8;
    }

    .ws-chevron--open {
        transform: rotate(180deg);
    }

    .ws-category-content {
        background-color: var(--wi-category-content-bg);
        transition: all 0.3s;
    }

    .ws-category-content--hidden {
        display: none;
    }

    .ws-category-items {
        padding: 0.5rem;
    }
    .ws-category-items > * + * {
        margin-top: 0.25rem;
    }

    .ws-utility-btn {
        width: 100%;
        text-align: left;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
        font-size: 12px;
        font-weight: 700;
        transition: all 0.15s;
        border: none;
        cursor: pointer;
        background: none;
        display: flex;
        flex-direction: column;
    }
    .ws-utility-btn:hover {
        background-color: var(--wi-utility-btn-hover);
    }
    .ws-utility-btn:active {
        transform: scale(0.98);
    }
    @media (min-width: 1024px) {
        .ws-utility-btn {
            font-size: 13px;
        }
    }

    .ws-utility-label {
        color: var(--wi-utility-btn-label);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.15s;
    }
    .ws-utility-btn:hover .ws-utility-label {
        color: var(--wi-sidebar-title-color);
    }

    .ws-suggest-box {
        margin-top: 2rem;
        padding: 1rem;
        background-color: var(--wi-suggest-bg);
        border-radius: 1rem;
        border: 1px solid var(--wi-suggest-border);
        text-align: center;
    }
    .ws-suggest-box > * + * {
        margin-top: 0.75rem;
    }

    .ws-suggest-icon-wrapper {
        width: 2.5rem;
        height: 2.5rem;
        margin: 0 auto;
        background-color: var(--wi-suggest-icon-wrapper);
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--wi-suggest-icon-color);
    }

    .ws-suggest-icon {
        width: 1.25rem;
        height: 1.25rem;
    }

    .ws-suggest-title {
        font-weight: 700;
        color: var(--wi-suggest-title);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .ws-suggest-desc {
        font-size: 10px;
        color: var(--wi-suggest-desc);
        line-height: 1.625;
        margin-top: 0.25rem;
    }

    .ws-suggest-btn {
        display: block;
        width: 100%;
        padding: 0.5rem;
        background-color: #4f46e5;
        color: #ffffff;
        border-radius: 0.75rem;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        transition: background-color 0.15s;
        box-sizing: border-box;
    }
    .ws-suggest-btn:hover {
        background-color: #4338ca;
    }
</style>
