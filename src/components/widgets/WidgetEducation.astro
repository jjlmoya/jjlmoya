---
import { Icon } from "astro-icon/components";
---

<div class="wed-grid">
    <div class="wed-card wed-card--indigo">
        <h3 class="wed-card-title">
            <Icon name="mdi:link-variant" class="wed-title-icon wed-title-icon--indigo" />
            ¿Qué es oEmbed?
        </h3>
        <p class="wed-card-text">Es la tecnología "mágica" que usa <strong>WordPress, Twitter o Discord</strong>. Solo pegas un enlace simple y se convierte automáticamente en una tarjeta visual.</p>
        <div class="wed-tags">
            <span class="wed-tag wed-tag--green">Más fácil</span>
            <span class="wed-tag wed-tag--indigo">Mejor para autores</span>
        </div>
    </div>

    <div class="wed-card wed-card--slate">
        <h3 class="wed-card-title">
            <Icon name="mdi:code-tags" class="wed-title-icon wed-title-icon--slate" />
            ¿Qué es iFrame?
        </h3>
        <p class="wed-card-text">Es una "ventana" hacia otra web. Es código HTML puro, universal y funciona en <strong>cualquier sitio web del mundo</strong> (Wix, Shopify, HTML estático...).</p>
        <div class="wed-tags">
            <span class="wed-tag wed-tag--blue">Universal</span>
            <span class="wed-tag wed-tag--slate">Técnico</span>
        </div>
    </div>
</div>

<style>
    .wed-grid {
        display: grid;
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .wed-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .wed-card {
        padding: 1.5rem;
        border-radius: 1.5rem;
        border: 1px solid;
    }
    .wed-card > * + * {
        margin-top: 0.75rem;
    }

    .wed-card--indigo {
        background-color: var(--wi-education-indigo-bg);
        border-color: var(--wi-education-indigo-border);
    }

    .wed-card--slate {
        background-color: var(--wi-education-slate-bg);
        border-color: var(--wi-education-slate-border);
    }

    .wed-card-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        color: var(--wi-education-title-color);
        margin-bottom: 0.75rem;
        font-size: 1rem;
    }

    .wed-title-icon {
        width: 1.25rem;
        height: 1.25rem;
    }

    .wed-title-icon--indigo {
        color: #6366f1;
    }

    .wed-title-icon--slate {
        color: #94a3b8;
    }

    .wed-card-text {
        font-size: 0.875rem;
        color: var(--wi-education-text-color);
        line-height: 1.625;
        margin-bottom: 1rem;
    }

    .wed-tags {
        display: flex;
        gap: 0.5rem;
    }

    .wed-tag {
        display: inline-flex;
        align-items: center;
        padding: 0.125rem 0.625rem;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 500;
    }

    .wed-tag--green {
        background-color: var(--wi-tag-green-bg);
        color: var(--wi-tag-green-color);
    }

    .wed-tag--indigo {
        background-color: var(--wi-tag-indigo-bg);
        color: var(--wi-tag-indigo-color);
    }

    .wed-tag--blue {
        background-color: var(--wi-tag-blue-bg);
        color: var(--wi-tag-blue-color);
    }

    .wed-tag--slate {
        background-color: var(--wi-tag-slate-bg);
        color: var(--wi-tag-slate-color);
    }
</style>
