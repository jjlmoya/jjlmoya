---
import { Icon } from "astro-icon/components";
---

<div class="wed-grid">
    <div class="wed-card wed-card--indigo">
        <h3 class="wed-card-title">
            <Icon name="mdi:link-variant" class="wed-title-icon wed-title-icon--indigo" />
            ¿Qué es oEmbed?
        </h3>
        <p class="wed-card-text">Es la tecnología "mágica" que usa <strong>WordPress, Twitter o Discord</strong>. Solo pegas un enlace simple y se convierte automáticamente en una tarjeta visual.</p>
        <div class="wed-tags">
            <span class="wed-tag wed-tag--green">Más fácil</span>
            <span class="wed-tag wed-tag--indigo">Mejor para autores</span>
        </div>
    </div>

    <div class="wed-card wed-card--slate">
        <h3 class="wed-card-title">
            <Icon name="mdi:code-tags" class="wed-title-icon wed-title-icon--slate" />
            ¿Qué es iFrame?
        </h3>
        <p class="wed-card-text">Es una "ventana" hacia otra web. Es código HTML puro, universal y funciona en <strong>cualquier sitio web del mundo</strong> (Wix, Shopify, HTML estático...).</p>
        <div class="wed-tags">
            <span class="wed-tag wed-tag--blue">Universal</span>
            <span class="wed-tag wed-tag--slate">Técnico</span>
        </div>
    </div>
</div>

<style>
    .wed-grid {
        display: grid;
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .wed-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .wed-card {
        padding: 1.5rem;
        border-radius: 1.5rem;
        border: 1px solid;
    }
    .wed-card > * + * {
        margin-top: 0.75rem;
    }

    .wed-card--indigo {
        background-color: #eef2ff;
        border-color: #e0e7ff;
    }
    .dark .wed-card--indigo {
        background-color: rgba(49, 46, 129, 0.1);
        border-color: rgba(55, 48, 163, 0.3);
    }

    .wed-card--slate {
        background-color: #f8fafc;
        border-color: #f1f5f9;
    }
    .dark .wed-card--slate {
        background-color: rgba(15, 23, 42, 0.5);
        border-color: #1e293b;
    }

    .wed-card-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 0.75rem;
        font-size: 1rem;
    }
    .dark .wed-card-title {
        color: #ffffff;
    }

    .wed-title-icon {
        width: 1.25rem;
        height: 1.25rem;
    }

    .wed-title-icon--indigo {
        color: #6366f1;
    }

    .wed-title-icon--slate {
        color: #94a3b8;
    }

    .wed-card-text {
        font-size: 0.875rem;
        color: #475569;
        line-height: 1.625;
        margin-bottom: 1rem;
    }
    .dark .wed-card-text {
        color: #94a3b8;
    }

    .wed-tags {
        display: flex;
        gap: 0.5rem;
    }

    .wed-tag {
        display: inline-flex;
        align-items: center;
        padding: 0.125rem 0.625rem;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 500;
    }

    .wed-tag--green {
        background-color: #dcfce7;
        color: #166534;
    }
    .dark .wed-tag--green {
        background-color: rgba(20, 83, 45, 0.3);
        color: #4ade80;
    }

    .wed-tag--indigo {
        background-color: #e0e7ff;
        color: #3730a3;
    }
    .dark .wed-tag--indigo {
        background-color: rgba(49, 46, 129, 0.3);
        color: #818cf8;
    }

    .wed-tag--blue {
        background-color: #dbeafe;
        color: #1e40af;
    }
    .dark .wed-tag--blue {
        background-color: rgba(30, 64, 175, 0.3);
        color: #60a5fa;
    }

    .wed-tag--slate {
        background-color: #e2e8f0;
        color: #1e293b;
    }
    .dark .wed-tag--slate {
        background-color: #334155;
        color: #cbd5e1;
    }
</style>
