---
import { Icon } from "astro-icon/components";
---

<section class="wb-section">
    <div class="wb-container">
        <div class="wb-heading">
            <h2 class="wb-title">¿Por qué usar nuestros widgets?</h2>
            <p class="wb-subtitle">Mejora el tiempo de permanencia y la utilidad de tu sitio web sin escribir una sola línea de código complejo.</p>
        </div>

        <div class="wb-grid">
            <div class="wb-item">
                <div class="wb-icon-box">
                    <Icon name="mdi:speedometer" class="wb-icon" />
                </div>
                <h3 class="wb-item-title">Carga Ultrarrápida</h3>
                <p class="wb-item-desc">Aislados mediante iFrame para asegurar que el rendimiento de tu web principal nunca se vea afectado.</p>
            </div>

            <div class="wb-item">
                <div class="wb-icon-box">
                    <Icon name="mdi:brush-variant" class="wb-icon" />
                </div>
                <h3 class="wb-item-title">Diseño Adaptable</h3>
                <p class="wb-item-desc">Nuestros widgets detectan el espacio disponible y se ajustan automáticamente a móviles, tablets y escritorio.</p>
            </div>

            <div class="wb-item">
                <div class="wb-icon-box">
                    <Icon name="mdi:google" class="wb-icon" />
                </div>
                <h3 class="wb-item-title">Impulso SEO</h3>
                <p class="wb-item-desc">Las herramientas interactivas aumentan la interacción del usuario, un factor clave para el posicionamiento en Google.</p>
            </div>
        </div>

        <article class="wb-article">
            <h4 class="wb-article-title">Listos para usar en tus plataformas favoritas</h4>

            <div class="wb-platform-grid">
                <div class="wb-platform-card">
                    <Icon name="mdi:wordpress" class="wb-platform-icon wb-platform-icon--wordpress" />
                    <span class="wb-platform-name">WordPress</span>
                </div>
                <div class="wb-platform-card">
                    <Icon name="mdi:notebook-outline" class="wb-platform-icon wb-platform-icon--notion" />
                    <span class="wb-platform-name">Notion</span>
                </div>
                <div class="wb-platform-card">
                    <Icon name="mdi:web" class="wb-platform-icon wb-platform-icon--web" />
                    <span class="wb-platform-name">Tu Web</span>
                </div>
                <div class="wb-platform-card">
                    <Icon name="mdi:square" class="wb-platform-icon wb-platform-icon--square" />
                    <span class="wb-platform-name">Squarespace</span>
                </div>
            </div>
        </article>
    </div>
</section>

<style>
    .wb-section {
        margin-top: 3rem;
        padding: 4rem 2rem;
        border-top: 1px solid var(--wi-benefits-border);
        background-color: var(--wi-benefits-bg);
    }
    @media (min-width: 1024px) {
        .wb-section {
            padding: 4rem 5rem;
        }
    }

    .wb-container {
        max-width: 56rem;
        margin: 0 auto;
    }
    .wb-container > * + * {
        margin-top: 3rem;
    }

    .wb-heading {
        text-align: center;
    }
    .wb-heading > * + * {
        margin-top: 1rem;
    }

    .wb-title {
        font-size: 1.875rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        color: var(--wi-benefits-title);
    }
    @media (min-width: 1024px) {
        .wb-title {
            font-size: 2.25rem;
        }
    }

    .wb-subtitle {
        font-size: 1.125rem;
        color: var(--wi-benefits-desc);
        font-weight: 300;
        max-width: 42rem;
        margin: 0 auto;
        line-height: 1.625;
    }

    .wb-grid {
        display: grid;
        gap: 2rem;
    }
    @media (min-width: 640px) {
        .wb-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .wb-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .wb-item > * + * {
        margin-top: 0.75rem;
    }

    .wb-icon-box {
        width: 2.5rem;
        height: 2.5rem;
        background-color: var(--wi-benefits-icon-wrapper);
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--wi-benefits-icon-color);
    }

    .wb-icon {
        width: 1.5rem;
        height: 1.5rem;
    }

    .wb-item-title {
        font-weight: 700;
        color: var(--wi-benefits-item-title);
    }

    .wb-item-desc {
        font-size: 0.875rem;
        color: var(--wi-benefits-item-desc);
        line-height: 1.625;
    }

    .wb-article {
        padding-top: 2.5rem;
        padding-left: 1rem;
        padding-right: 1rem;
    }
    @media (min-width: 640px) {
        .wb-article {
            padding-left: 0;
            padding-right: 0;
        }
    }

    .wb-article-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--wi-benefits-article-title);
        margin-bottom: 1.5rem;
        text-align: center;
    }

    .wb-platform-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }
    @media (min-width: 768px) {
        .wb-platform-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .wb-platform-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        border-radius: 1rem;
        background-color: var(--wi-benefits-platform-card-bg);
        border: 1px solid var(--wi-benefits-platform-card-border);
        transition: border-color 0.15s;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
    .wb-platform-card:hover {
        border-color: rgba(99, 102, 241, 0.3);
    }

    .wb-platform-icon {
        width: 2rem;
        height: 2rem;
        margin-bottom: 0.5rem;
    }

    .wb-platform-icon--wordpress {
        color: #21759b;
    }

    .wb-platform-icon--notion {
        color: var(--wi-platform-icon-color--notion);
    }

    .wb-platform-icon--web {
        color: #6366f1;
    }

    .wb-platform-icon--square {
        color: var(--wi-platform-icon-color--square);
    }

    .wb-platform-name {
        font-size: 12px;
        font-weight: 700;
        color: var(--wi-benefits-platform-name);
    }
</style>
