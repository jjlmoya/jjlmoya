---
import { Icon } from "astro-icon/components";
---

<div id="embed-section" class="wec-embed-section">
    <div class="wec-grid">
        <div class="wec-card">
            <div class="wec-card-header">
                <h3 class="wec-card-title">Enlace oEmbed</h3>
                <Icon name="mdi:link-variant" class="wec-card-icon" />
            </div>
            <p class="wec-card-desc">Ideal para redes sociales y WordPress.</p>
            <div class="wec-code-row">
                <code id="code-url" class="wec-code">https://www.jjlmoya.es/...</code>
                <button id="copy-url" class="wec-copy-btn">
                    <Icon name="mdi:content-copy" class="wec-copy-icon" />
                </button>
            </div>
        </div>

        <div class="wec-card">
            <div class="wec-card-header">
                <h3 class="wec-card-title">Código iFrame</h3>
                <Icon name="mdi:code-tags" class="wec-card-icon" />
            </div>
            <p class="wec-card-desc">Para blogs y sitios web personalizados.</p>
            <div class="wec-iframe-section">
                <div class="wec-iframe-wrapper">
                    <pre id="code-iframe" class="wec-pre">Cargando...</pre>
                    <div class="wec-fade-overlay"></div>
                </div>
                <button id="copy-iframe" class="wec-copy-btn wec-copy-btn--full">
                    <Icon name="mdi:content-copy" class="wec-copy-icon-sm" />
                    COPIAR iFRAME
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .wec-embed-section {
        display: none;
        opacity: 0;
        transform: translateY(1rem);
        transition: all 0.7s;
        pointer-events: none;
    }
    .wec-embed-section--visible {
        display: block;
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .wec-grid {
        display: grid;
        gap: 1.5rem;
    }
    @media (min-width: 768px) {
        .wec-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .wec-grid {
            gap: 2.5rem;
        }
    }

    .wec-card {
        background-color: #ffffff;
        border-radius: 1.5rem;
        padding: 1.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
    .wec-card > * + * {
        margin-top: 1.5rem;
    }
    .dark .wec-card {
        background-color: #09090b;
        border-color: #1e293b;
    }
    @media (min-width: 1024px) {
        .wec-card {
            padding: 2rem;
        }
    }

    .wec-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .wec-card-title {
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #4f46e5;
    }
    .dark .wec-card-title {
        color: #818cf8;
    }

    .wec-card-icon {
        width: 1.25rem;
        height: 1.25rem;
        color: #cbd5e1;
    }

    .wec-card-desc {
        font-size: 11px;
        color: #64748b;
        line-height: 1.625;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        opacity: 0.7;
        font-style: italic;
    }

    .wec-code-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .wec-code {
        flex-grow: 1;
        min-width: 0;
        background-color: #f8fafc;
        padding: 1rem;
        border-radius: 1rem;
        font-size: 10px;
        font-family: ui-monospace, monospace;
        color: #475569;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        border: 1px solid #f1f5f9;
        font-style: italic;
    }
    .dark .wec-code {
        background-color: #000000;
        color: #94a3b8;
        border-color: #0f172a;
    }
    @media (min-width: 640px) {
        .wec-code {
            font-size: 12px;
        }
    }

    .wec-copy-btn {
        padding: 1rem;
        background-color: #4f46e5;
        color: #ffffff;
        border-radius: 1rem;
        transition: all 0.15s;
        box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.2);
        border: none;
        cursor: pointer;
        flex-shrink: 0;
        line-height: 0;
    }
    .wec-copy-btn:active {
        transform: scale(0.95);
    }
    .wec-copy-btn:hover {
        background-color: #0f172a;
    }

    .wec-copy-icon {
        width: 1.25rem;
        height: 1.25rem;
    }

    .wec-copy-icon-sm {
        width: 1rem;
        height: 1rem;
    }

    .wec-iframe-section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .wec-iframe-wrapper {
        position: relative;
    }

    .wec-pre {
        background-color: #f8fafc;
        padding: 1rem;
        border-radius: 1rem;
        font-size: 9px;
        font-family: ui-monospace, monospace;
        color: #64748b;
        white-space: pre-wrap;
        word-break: break-all;
        border: 1px solid #f1f5f9;
        max-height: 8rem;
        overflow-y: auto;
        margin: 0;
    }
    .dark .wec-pre {
        background-color: #000000;
        color: #64748b;
        border-color: #0f172a;
    }
    @media (min-width: 640px) {
        .wec-pre {
            font-size: 10px;
        }
    }

    .wec-fade-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, #f8fafc, transparent);
        pointer-events: none;
        opacity: 0.4;
    }
    .dark .wec-fade-overlay {
        background: linear-gradient(to top, #000000, transparent);
    }

    .wec-copy-btn--full {
        width: 100%;
        padding: 1rem;
        background-color: #0f172a;
        border-radius: 1rem;
        font-size: 12px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: opacity 0.15s;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }
    .wec-copy-btn--full:hover {
        opacity: 0.9;
        background-color: #0f172a;
    }
    .dark .wec-copy-btn--full {
        background-color: #4f46e5;
    }
    .dark .wec-copy-btn--full:hover {
        background-color: #4f46e5;
    }
</style>
