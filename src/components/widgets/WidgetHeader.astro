---
import { Icon } from "astro-icon/components";
---

<div class="wh-header">
    <div class="wh-info">
        <div id="current-category-badge" class="wh-badge">Categoría</div>
        <h2 id="current-title" class="wh-title">Explorador de Utilidades</h2>
        <p id="current-desc" class="wh-desc">Personaliza e integra herramientas en tu web gratis.</p>
    </div>

    <div class="wh-controls">
        <div class="wh-theme-group">
            <span class="wh-group-label">Utilidad</span>
            <button
                id="widget-theme-light"
                class="wh-theme-btn wh-theme-btn--active"
                data-theme="light"
                title="Modo Claro"
            >
                <Icon name="mdi:white-balance-sunny" class="wh-icon" />
            </button>
            <button
                id="widget-theme-dark"
                class="wh-theme-btn"
                data-theme="dark"
                title="Modo Oscuro"
            >
                <Icon name="mdi:moon-waning-crescent" class="wh-icon" />
            </button>
        </div>

        <div class="wh-preview-group">
            <span class="wh-group-label">Previa</span>
            <button data-bg="white" class="wh-bg-btn wh-bg-btn--white wh-bg-btn--active" title="Fondo Blanco"></button>
            <button data-bg="black" class="wh-bg-btn wh-bg-btn--black" title="Fondo Negro"></button>
            <button data-bg="grid" class="wh-bg-btn wh-bg-btn--grid" title="Fondo Cuadrícula">
                <div class="wh-grid-overlay"></div>
            </button>
        </div>
    </div>
</div>

<style>
    .wh-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background-color: rgba(248, 250, 252, 0.9);
        backdrop-filter: blur(12px);
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .dark .wh-header {
        background-color: rgba(0, 0, 0, 0.9);
        border-bottom-color: #1e293b;
    }
    @media (min-width: 640px) {
        .wh-header {
            flex-direction: row;
        }
    }
    @media (min-width: 1024px) {
        .wh-header {
            padding: 1.5rem 2.5rem;
        }
    }

    .wh-info {
        text-align: center;
        width: 100%;
    }
    @media (min-width: 640px) {
        .wh-info {
            text-align: left;
        }
    }

    .wh-badge {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        background-color: #eef2ff;
        color: #4f46e5;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 0.375rem;
        margin-bottom: 0.5rem;
        opacity: 0;
        transition: opacity 0.15s;
    }
    .dark .wh-badge {
        background-color: rgba(49, 46, 129, 0.2);
        color: #818cf8;
    }

    .wh-title {
        font-size: 1.25rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        color: #0f172a;
        line-height: 1.25;
    }
    .dark .wh-title {
        color: #ffffff;
    }
    @media (min-width: 1024px) {
        .wh-title {
            font-size: 1.875rem;
        }
    }

    .wh-desc {
        display: none;
        font-size: 0.875rem;
        color: #64748b;
        font-weight: 300;
        margin-top: 0.25rem;
    }
    .dark .wh-desc {
        color: #94a3b8;
    }
    @media (min-width: 640px) {
        .wh-desc {
            display: block;
        }
    }

    .wh-controls {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        flex-shrink: 0;
    }
    @media (min-width: 640px) {
        .wh-controls {
            flex-direction: row;
        }
    }

    .wh-theme-group,
    .wh-preview-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background-color: #ffffff;
        padding: 0.375rem;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
    .dark .wh-theme-group,
    .dark .wh-preview-group {
        background-color: #18181b;
        border-color: #1e293b;
    }

    .wh-group-label {
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #94a3b8;
        margin-left: 0.5rem;
        margin-right: 0.25rem;
    }

    .wh-theme-btn,
    .wh-bg-btn {
        width: 2rem;
        height: 2rem;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s;
        border: none;
        cursor: pointer;
    }

    .wh-theme-btn {
        color: #94a3b8;
    }
    .wh-theme-btn:hover {
        background-color: #f8fafc;
    }
    .dark .wh-theme-btn:hover {
        background-color: #27272a;
    }

    .wh-theme-btn--active {
        background-color: #eef2ff;
        color: #4f46e5;
    }
    .dark .wh-theme-btn--active {
        background-color: #27272a;
        color: #94a3b8;
    }

    .wh-icon {
        width: 1rem;
        height: 1rem;
    }

    .wh-bg-btn {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 0.75rem;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        padding: 0;
    }

    .wh-bg-btn--white {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
    }

    .wh-bg-btn--black {
        background-color: #000000;
        border: 1px solid #1e293b;
    }

    .wh-bg-btn--grid {
        background-color: #f1f5f9;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        position: relative;
    }

    .wh-bg-btn--active {
        border-color: #4f46e5 !important;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.15);
    }

    .wh-grid-overlay {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(to right, rgba(128, 128, 128, 0.133) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(128, 128, 128, 0.133) 1px, transparent 1px);
        background-size: 4px 4px;
    }
</style>
