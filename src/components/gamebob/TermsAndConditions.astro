---
import LanguageSelector from "./LanguageSelector.astro";
import DiscordCTA from "./DiscordCTA.astro";
---

<section id="terms-container">
    <div>
        <LanguageSelector baseUrl="/gamebob/terminos-y-condiciones/" />

        <div>
            <DiscordCTA />
        </div>

        <div>
            <div
                data-t="terms.badge"
            >
                Marco Legal
            </div>
            <h1>
                <span data-t="terms.title_p1">Términos y</span>
                <br />
                <span
                    data-t="terms.title_p2"
                >
                    Condiciones
                </span>
            </h1>
            <p
                data-t="terms.description"
            >
                Las reglas del juego. Transparencia y claridad para una mejor experiencia.
            </p>
            <div>
                <span></span>
                <span data-t="terms.last_update">Última actualización: 02 de Enero de 2026</span>
                <span></span>
            </div>
        </div>

        <div>
            <div>
                <p>
                    <span data-t="terms.intro_p1"
                        >Bienvenido a los servicios proporcionados por Game Bob (jjlmoya).</span
                    >
                    <br /><br />
                    <span data-t="terms.intro_p2"
                        >Al descargar, instalar o utilizar cualquiera de nuestras aplicaciones
                        móviles ("la Aplicación") o acceder a nuestro sitio web, usted acepta estar
                        sujeto a los siguientes Términos y Condiciones. Si no está de acuerdo con
                        estos términos, le rogamos que no utilice la Aplicación.</span
                    >
                </p>
            </div>

            <div>
                <div>
                    <h3>
                        <span>1</span>
                        <span data-t="terms.sections.license.title">Licencia de Uso</span>
                    </h3>
                    <p
                        data-t="terms.sections.license.content"
                    >
                        Se concede al usuario una licencia personal, no exclusiva, intransferible y
                        revocable para utilizar la Aplicación en dispositivos móviles compatibles,
                        exclusivamente para fines personales y no comerciales.
                    </p>
                </div>

                <div>
                    <h3>
                        <span>2</span>
                        <span data-t="terms.sections.acceptable.title">Uso Aceptable</span>
                    </h3>
                    <p
                        data-t="terms.sections.acceptable.content"
                    >
                        Usted se compromete a utilizar la Aplicación únicamente para fines legales y
                        de acuerdo con estos Términos. Queda prohibido:
                    </p>
                    <ul
                        id="terms-acceptable-list"
                    >
                        <li>
                            Realizar ingeniería inversa, descompilar o intentar extraer el código
                            fuente de la Aplicación.
                        </li>
                        <li>
                            Utilizar la Aplicación de manera que pueda dañar, deshabilitar o
                            sobrecargar nuestros servidores o redes.
                        </li>
                        <li>
                            Eludir cualquier medida de seguridad o restricción técnica de la
                            Aplicación.
                        </li>
                    </ul>
                </div>

                <div>
                    <h3>
                        <span>3</span>
                        <span data-t="terms.sections.intellectual.title">Propiedad Intelectual</span>
                    </h3>
                    <p
                        data-t="terms.sections.intellectual.content"
                    >
                        Todos los derechos de propiedad intelectual sobre el diseño, código fuente,
                        gráficos, logotipos y contenido de nuestras aplicaciones son propiedad
                        exclusiva de JJLMOYA o se utilizan bajo licencia. No se transfiere ningún
                        derecho de propiedad al usuario.
                    </p>
                </div>

                <div>
                    <h3>
                        <span>4</span>
                        <span data-t="terms.sections.privacy.title">Privacidad y Protección de Datos</span>
                    </h3>
                    <p
                        data-t="terms.sections.privacy.content"
                    >
                        Su privacidad es importante para nosotros. El uso de la Aplicación también
                        se rige por nuestra Política de Privacidad, que describe cómo recopilamos,
                        utilizamos y compartimos la información (por ejemplo, identificadores de
                        publicidad o datos anónimos de uso).
                    </p>
                    <div>
                        <a
                            href="/gamebob/privacidad/"
                        >
                            <span data-t="terms.sections.privacy.link_text"
                                >Leer Política de Privacidad completa</span
                            >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7 7"></path></svg
                            >
                        </a>
                    </div>
                </div>

                <div>
                    <h3>
                        <span>5</span>
                        <span data-t="terms.sections.third_party.title">Servicios de Terceros</span>
                    </h3>
                    <p
                        data-t="terms.sections.third_party.content"
                    >
                        La aplicación puede integrar servicios de terceros (como Google AdMob para
                        publicidad o Firebase para análisis). El uso de estos servicios está sujeto
                        a los términos y políticas de dichos proveedores. Game Bob no controla ni
                        asume responsabilidad por el contenido o las prácticas de estos servicios
                        externos.
                    </p>
                </div>

                <div>
                    <h3>
                        <span>6</span>
                        <span data-t="terms.sections.liability.title">Limitación de Responsabilidad</span>
                    </h3>
                    <p
                        data-t="terms.sections.liability.content"
                    >
                        La Aplicación se proporciona "tal cual". Game Bob no garantiza que la
                        Aplicación esté libre de errores o funcione sin interrupciones. En la medida
                        máxima permitida por la ley, no seremos responsables de ningún daño directo,
                        indirecto o consecuente derivado del uso o la imposibilidad de uso de la
                        Aplicación, incluidos los resultados de los cálculos teóricos o estimaciones
                        de juego.
                    </p>
                </div>

                <div>
                    <h3>
                        <span>7</span>
                        <span data-t="terms.sections.modifications.title">Modificaciones</span>
                    </h3>
                    <p
                        data-t="terms.sections.modifications.content"
                    >
                        Nos reservamos el derecho de actualizar o modificar estos Términos en
                        cualquier momento. Las modificaciones entrarán en vigor en el momento de su
                        publicación. El uso continuado de la Aplicación constituirá su aceptación de
                        dichas modificaciones.
                    </p>
                </div>

                <div>
                    <h3>
                        <span>8</span>
                        <span data-t="terms.sections.jurisdiction.title">Legislación y Jurisdicción</span>
                    </h3>
                    <p
                        data-t="terms.sections.jurisdiction.content"
                    >
                        Estos Términos se regirán e interpretarán de acuerdo con las leyes de
                        España. Cualquier disputa que surja en relación con estos Términos estará
                        sujeta a la jurisdicción exclusiva de los tribunales españoles.
                    </p>
                </div>

                <div>
                    <h3>
                        <span>9</span>
                        <span data-t="terms.sections.contact.title">Contacto</span>
                    </h3>
                    <p
                        data-t="terms.sections.contact.content"
                    >
                        Si tiene alguna pregunta o duda sobre estos Términos y Condiciones, puede
                        ponerse en contacto con nosotros en:
                    </p>
                    <div>
                        <p>
                            Email: <a
                                href="mailto:juanjo1989@gmail.com"
                            >juanjo1989@gmail.com</a
                            >
                        </p>
                        <p>
                            Web: <a
                                href="https://www.jjlmoya.es/"
                            >https://www.jjlmoya.es/</a
                            >
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div>
                <div></div>
                <p data-t="terms.footer_copy">
                    GameBob Studio &copy; 2026
                </p>
                <div></div>
            </div>
        </div>
    </div>
</section>

<script>
    import { LEGAL_TRANSLATIONS } from "../../data/gamebob/legal-translations";

    function updateTermsTranslations(lang: string) {
        const t = LEGAL_TRANSLATIONS[lang] || LEGAL_TRANSLATIONS.es;

        document.querySelectorAll("#terms-container [data-t]").forEach((el) => {
            const key = el.getAttribute("data-t");
            if (!key) return;

            const value = key.split(".").reduce((obj, i) => (obj ? obj[i] : null), t as any);

            if (value && typeof value === "string") {
                el.textContent = value;
            }
        });

        const listContainer = document.getElementById("terms-acceptable-list");
        if (listContainer && t.terms.sections.acceptable.items) {
            listContainer.innerHTML = t.terms.sections.acceptable.items
                .map((item: string) => `<li>${item}</li>`)
                .join("");
        }
    }

    function initTerms() {
        document.addEventListener("change-language", (e: any) => {
            updateTermsTranslations(e.detail.lang);
        });

        const userLang = localStorage.getItem("preferred-lang") || navigator.language.split("-")[0];
        const LANGUAGES = [
            "en",
            "es",
            "de",
            "fr",
            "it",
            "pt",
            "ja",
            "ko",
            "zh",
            "ru",
            "tr",
            "nl",
            "pl",
            "sv",
            "hi",
        ];

        if (LANGUAGES.includes(userLang) && userLang !== "es") {
            updateTermsTranslations(userLang);
        }
    }

    initTerms();
    document.addEventListener("astro:page-load", initTerms);
</script>
