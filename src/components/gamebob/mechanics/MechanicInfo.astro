---
import { Icon } from "astro-icon/components";
import "./MechanicInfo.css";
---

<div class="mi-grid">
    <div class="mi-card">
        <h2 class="mi-title">
            <Icon name="mdi:code-braces" class="mi-icon-blue" />
            Cómo funciona
        </h2>
        <ul class="mi-list">
            <slot name="how-it-works" />
        </ul>
    </div>

    <div class="mi-card">
        <h2 class="mi-title">
            <Icon name="mdi:controller" class="mi-icon-green" />
            Controles
        </h2>
        <div class="mi-controls-grid">
            <slot name="controls" />
        </div>
    </div>
</div>
