---
import { Icon } from "astro-icon/components";
import "./MechanicCanvas.css";

interface Props {
    id: string;
    instruction?: string;
    subInstruction?: string;
    aspectRatio?: "video" | "square" | "portrait";
    verticalOnMobile?: boolean;
}

const {
    id,
    instruction = "Haz click para empezar",
    subInstruction = "Click / Tap para interactuar",
    aspectRatio = "video",
    verticalOnMobile = false,
} = Astro.props;

const containerClasses = [
    "mc-container",
    `mc-container--${aspectRatio}`,
    verticalOnMobile ? "mc-container--mobile-height" : "",
].filter(Boolean).join(" ");
---

<div class={containerClasses}>
    <canvas id={id} class="mc-canvas"></canvas>

    <div
        id={`${id}-overlay`}
        class="mc-overlay"
    >
        <Icon name="mdi:cursor-default-click" class="mc-overlay-icon" />
        <p class="mc-overlay-title">{instruction}</p>
        <p class="mc-overlay-subtitle">{subInstruction}</p>
    </div>

    <slot />
</div>
