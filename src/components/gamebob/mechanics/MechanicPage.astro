---
import GameBobLayout from "../../../layouts/GameBobLayout.astro";
import { Icon } from "astro-icon/components";
import "./MechanicPage.css";

interface Props {
    title: string;
    description: string;
    githubUrl?: string;
    codeUrl?: string;
    image?: string;
}

const { title, description, githubUrl, codeUrl, image } = Astro.props;
---

<GameBobLayout title={title} description={description} image={image}>
    <div class="mp-container">
        <div class="mp-header">
            <div>
                <a
                    href="/gamebob/mecanicas/"
                    class="mp-back-link"
                >
                    <Icon name="mdi:arrow-left" style="width: 1.25rem; height: 1.25rem;" />
                    Volver a Mecánicas
                </a>
                <h1 class="mp-title">
                    <slot name="icon" />
                    {title}
                </h1>
                <p class="mp-desc">
                    {description}
                </p>
            </div>

            <div class="mp-actions">
                {
                    githubUrl && (
                        <a
                            href={githubUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="mp-btn"
                        >
                            <Icon name="mdi:github" style="width: 1.25rem; height: 1.25rem;" />
                            GitHub
                        </a>
                    )
                }
                {
                    codeUrl && (
                        <a
                            href={codeUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="mp-btn"
                        >
                            <Icon name="mdi:code-tags" style="width: 1.25rem; height: 1.25rem;" />
                            Código
                        </a>
                    )
                }
            </div>
        </div>

        <slot />
    </div>
</GameBobLayout>
