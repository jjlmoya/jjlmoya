---

const LANGUAGES = [
    { code: "en", name: "English", flag: "🇬🇧" },
    { code: "es", name: "Español", flag: "🇪🇸" },
    { code: "de", name: "Deutsch", flag: "🇩🇪" },
    { code: "fr", name: "Français", flag: "🇫🇷" },
    { code: "it", name: "Italiano", flag: "🇮🇹" },
    { code: "pt", name: "Português", flag: "🇵🇹" },
    { code: "ja", name: "日本語", flag: "🇯🇵" },
    { code: "ko", name: "한국어", flag: "🇰🇷" },
    { code: "zh", name: "中文", flag: "🇨🇳" },
    { code: "ru", name: "Русский", flag: "🇷🇺" },
    { code: "tr", name: "Türkçe", flag: "🇹🇷" },
    { code: "nl", name: "Nederlands", flag: "🇳🇱" },
    { code: "pl", name: "Polski", flag: "🇵🇱" },
    { code: "sv", name: "Svenska", flag: "🇸🇪" },
    { code: "hi", name: "हिन्दी", flag: "🇮🇳" },
];

interface Props {
    currentLang?: string;
    baseUrl: string;
}
---

<div class="ls-wrapper">
    {
        LANGUAGES.map((lang) => (
            <button
                data-lang-btn={lang.code}
                class="ls-btn"
            >
                <span class="ls-flag">{lang.flag}</span>
                {lang.name}
            </button>
        ))
    }
</div>

<style>
    .ls-wrapper {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 3rem;
        animation: ls-fade-in 1s ease forwards;
    }

    @keyframes ls-fade-in {
        from {
            opacity: 0;
            transform: translateY(-0.25rem);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .ls-btn {
        padding: 0.375rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all 0.3s;
        border: 1px solid;
        background-color: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
        color: #9ca3af;
        cursor: pointer;
    }
    .ls-btn:hover {
        border-color: rgba(255, 255, 255, 0.3);
        background-color: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }
    .ls-btn.active-lang {
        background-color: rgba(29, 218, 188, 0.2);
        border-color: #1ddabc;
        color: #1ddabc;
        box-shadow: 0 0 15px rgba(29, 218, 188, 0.3);
    }

    .ls-flag {
        margin-right: 0.375rem;
    }
</style>

<script>
    function setupLangButtons() {
        const buttons = document.querySelectorAll("[data-lang-btn]");
        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const lang = btn.getAttribute("data-lang-btn");
                if (lang) {
                    document.dispatchEvent(
                        new CustomEvent("change-language", { detail: { lang } })
                    );

                    buttons.forEach((b) => b.classList.remove("active-lang"));
                    btn.classList.add("active-lang");

                    localStorage.setItem("preferred-lang", lang);
                }
            });
        });

        const savedLang =
            localStorage.getItem("preferred-lang") || navigator.language.split("-")[0];
        const targetBtn = document.querySelector(`[data-lang-btn="${savedLang}"]`);

        buttons.forEach((b) => b.classList.remove("active-lang"));

        if (targetBtn) {
            targetBtn.classList.add("active-lang");
        } else {
            const esBtn = document.querySelector(`[data-lang-btn="es"]`);
            if (esBtn) esBtn.classList.add("active-lang");
        }
    }

    setupLangButtons();
    document.addEventListener("astro:page-load", setupLangButtons);
</script>
