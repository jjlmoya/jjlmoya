---
import { Icon } from "astro-icon/components";
import type { PostMortemEntry } from "../../../data/gamebob/post-mortem/entries";
import "./PostMortemCard.css";

interface Props {
    entry: PostMortemEntry;
}

const { entry } = Astro.props;
const imagePath = entry.image ? `/images/gamebob/post-mortem/${entry.image}` : null;
---

<a href={`/gamebob/post-mortem/${entry.id}/`} class="pm-card">
    <div class="pm-card-topbar"></div>

    <div class="pm-card-media">
        {
            imagePath ? (
                <img
                    src={imagePath}
                    alt={entry.title}
                    class="pm-card-img"
                />
            ) : (
                <div class="pm-card-placeholder">
                    <Icon name="mdi:alert-decagram" class="pm-card-placeholder-icon" />
                </div>
            )
        }

        <div class="pm-card-badge">
            ID: {entry.id}
        </div>

        <div class="pm-card-date">
            {entry.date}
        </div>
    </div>

    <div class="pm-card-body">
        <h2 class="pm-card-title">
            {entry.title}
        </h2>

        <div class="pm-card-details">
            <div class="pm-card-row">
                <Icon name="mdi:close-circle-outline" class="pm-card-row-icon pm-card-row-icon--error" />
                <p class="pm-card-text pm-card-text--error">
                    "{entry.error}"
                </p>
            </div>
            <div class="pm-card-row">
                <Icon
                    name="mdi:check-circle-outline"
                    class="pm-card-row-icon pm-card-row-icon--lesson"
                />
                <p class="pm-card-text pm-card-text--lesson">
                    {entry.lesson}
                </p>
            </div>
        </div>

        <div class="pm-card-footer">
            {
                entry.tags &&
                    entry.tags
                        .slice(0, 3)
                        .map((tag) => (
                            <span class="pm-card-tag">
                                #{tag}
                            </span>
                        ))
            }
        </div>
    </div>

    <div class="pm-card-crt-overlay"></div>
</a>
