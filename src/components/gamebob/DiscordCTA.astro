---
import "./DiscordCTA.css";
import { Icon } from "astro-icon/components";

interface Props {
    title?: string;
    subtitle?: string;
    description?: string;
    class?: string;
}

const {
    title = "Únete a la comunidad",
    subtitle = "Servidor Oficial",
    description,
    class: className = "",
} = Astro.props;
---

<div class={`dcta-container ${className}`}>
    <a
        href="https://discord.gg/uJ7NJEj7sf"
        target="_blank"
        class="dcta-link"
    >
        <div class="dcta-glow"></div>

        <div class="dcta-icon-wrapper">
            <div class="dcta-icon-box">
                <Icon name="mdi:discord" class="dcta-icon" />
            </div>
            <div class="dcta-badge"></div>
        </div>

        <div class="dcta-text-content">
            <div
                data-t="privacy.discord.subtitle"
                class="dcta-subtitle"
            >
                {subtitle}
            </div>
            <h2
                data-t="privacy.discord.title"
                class="dcta-title"
            >
                {title}
            </h2>
            {
                description && (
                    <p class="dcta-description">
                        {description}
                    </p>
                )
            }
        </div>

        <div class="dcta-arrow-wrapper">
            <div class="dcta-arrow-circle">
                <Icon name="mdi:chevron-right" class="dcta-arrow-icon" />
            </div>
        </div>
    </a>
</div>
