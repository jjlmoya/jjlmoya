---
import { Icon } from "astro-icon/components";
import type { Project } from "../../data/gamebob/roadmap/types";
import type { Application } from "../../types/apps";

interface Props {
    project: Project | Application;
    index: number;
}

const { project, index } = Astro.props;

const name = "title" in project ? project.title : project.name;
const homeDescription =
    "homeDescription" in project ? project.homeDescription : project.description;
const image = "media" in project ? project.media.showcase : project.image;
const statusLabel = "roadmap" in project ? project.roadmap.statusLabel : project.statusLabel;
const statusType = "roadmap" in project ? project.roadmap.statusType : project.statusType;
const color = "theme" in project ? project.theme.primary : project.color;
const links =
    "stores" in project
        ? {
              googlePlay: project.stores.googlePlay,
              appStore: project.stores.appStore,
          }
        : project.links;

const isEven = index % 2 === 0;

const nameParts = name.includes(":") ? [name.split(":")[0], name.split(":")[1]] : [name, ""];
---

<div class="phc-grid">
    <div class:list={["phc-text-col", { "phc-text-col--right": isEven }]}>
        <h3 class="phc-title">
            {nameParts[0]}<br />
            <span style={`color: ${color}`}>{nameParts[1].trim()}</span>
        </h3>
        <p class="phc-desc">
            {homeDescription}
        </p>

        <div class="phc-status-row">
            <div
                class:list={["phc-status", `phc-status--${statusType}`, { "phc-status--pulse": statusType !== "released" }]}
            >
                {statusLabel}
            </div>
        </div>

        <div class="phc-actions">
            {
                links?.googlePlay ? (
                    <a
                        href={links.googlePlay}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="phc-action-btn"
                    >
                        <Icon name="mdi:google-play" class="phc-action-icon" />
                        <div class="phc-action-text">
                            <div class="phc-action-label">DISPONIBLE EN</div>
                            <div class="phc-action-name">Google Play</div>
                        </div>
                    </a>
                ) : (
                    <div class="phc-action-disabled-group">
                        <div class="phc-action-btn phc-action-btn--disabled">
                            <Icon name="mdi:google-play" class="phc-action-icon" />
                            <div class="phc-action-text">
                                <div class="phc-action-label">PRÓXIMAMENTE EN</div>
                                <div class="phc-action-name">Google Play</div>
                            </div>
                        </div>
                    </div>
                )
            }

            <button
                class="phc-action-btn phc-action-btn--disabled"
                title="Próximamente en App Store"
            >
                <Icon name="mdi:apple" class="phc-action-icon" />
                <div class="phc-action-text">
                    <div class="phc-action-label phc-action-label--muted">Descárgalo en el</div>
                    <div class="phc-action-name phc-action-name--muted">App Store</div>
                </div>
            </button>
        </div>
    </div>

    <div
        class:list={["phc-visual", { "phc-visual--left": isEven }]}
        style={`--phc-shadow: ${color}33;`}
    >
        <div class="phc-visual-inner">
            {
                image ? (
                    <img
                        src={image}
                        alt={`${name} Cover`}
                        class="phc-visual-img"
                    />
                ) : (
                    <div class="phc-visual-fallback">
                        {name}
                    </div>
                )
            }
            <div
                class="phc-overlay-gradient"
                style="background-image: linear-gradient(to bottom right, ${color}33, transparent)"
            >
            </div>
            <div class="phc-overlay-shadow"></div>
        </div>
    </div>
</div>

<style>
    @keyframes phc-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .phc-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
        margin-top: 6rem;
        padding-top: 6rem;
        border-top: 1px solid var(--phc-border-color);

        --phc-border-color: rgba(255, 255, 255, 0.05);
        --phc-desc-color: #9ca3af;
        --phc-visual-border: rgba(255, 255, 255, 0.1);
        
        --phc-btn-disabled-bg: rgba(255, 255, 255, 0.1);
        --phc-btn-disabled-color: #ffffff;
        
        --phc-status-released-bg: rgba(16, 185, 129, 0.1);
        --phc-status-released-border: rgba(16, 185, 129, 0.3);
        --phc-status-released-color: #34d399;

        --phc-status-developing-bg: rgba(59, 130, 246, 0.1);
        --phc-status-developing-border: rgba(147, 197, 253, 0.3);
        --phc-status-developing-color: #60a5fa;

        --phc-status-qa-bg: rgba(245, 158, 11, 0.1);
        --phc-status-qa-border: rgba(245, 158, 11, 0.3);
        --phc-status-qa-color: #fbbf24;

        --phc-btn-bg: #ffffff;
        --phc-btn-color: #000000;
        --phc-btn-border: none;
        --phc-btn-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
    }
    :global(.theme-light) .phc-grid {
        --phc-border-color: rgba(0, 0, 0, 0.08);
        --phc-desc-color: var(--text-muted);
        --phc-visual-border: rgba(0, 0, 0, 0.1);
        
        --phc-btn-disabled-bg: rgba(0, 0, 0, 0.05);
        --phc-btn-disabled-color: rgba(0, 0, 0, 0.35);
        
        --phc-status-released-bg: rgba(16, 185, 129, 0.08);
        --phc-status-released-border: rgba(16, 185, 129, 0.2);
        --phc-status-released-color: #059669;

        --phc-status-developing-bg: rgba(37, 99, 235, 0.08);
        --phc-status-developing-border: rgba(37, 99, 235, 0.2);
        --phc-status-developing-color: #2563eb;

        --phc-status-qa-bg: rgba(217, 119, 6, 0.08);
        --phc-status-qa-border: rgba(217, 119, 6, 0.25);
        --phc-status-qa-color: #d97706;

        --phc-btn-bg: var(--bg-surface);
        --phc-btn-color: var(--text-base);
        --phc-btn-border: 1px solid var(--border-base);
        --phc-btn-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }
    .phc-grid:first-of-type {
        margin-top: 0;
        padding-top: 0;
        border-top: 0;
    }
    @media (min-width: 768px) {
        .phc-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    .phc-text-col {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .phc-title {
        font-size: 3rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        color: var(--color-gamebob-text);
        text-transform: uppercase;
        line-height: 1;
    }

    .phc-desc {
        color: var(--phc-desc-color);
        font-size: 1.125rem;
        line-height: 1.625;
        text-transform: lowercase;
    }

    .phc-status-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-top: 1rem;
    }

    .phc-status {
        padding: 0.5rem 1rem;
        border: 1px solid;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        font-weight: 500;
    }
    .phc-status--released {
        background: var(--phc-status-released-bg);
        border-color: var(--phc-status-released-border);
        color: var(--phc-status-released-color);
    }
    .phc-status--developing {
        background: var(--phc-status-developing-bg);
        border-color: var(--phc-status-developing-border);
        color: var(--phc-status-developing-color);
    }
    .phc-status--qa {
        background: var(--phc-status-qa-bg);
        border-color: var(--phc-status-qa-border);
        color: var(--phc-status-qa-color);
    }
    .phc-status--planning {
        background: var(--phc-status-developing-bg);
        border-color: var(--phc-status-developing-border);
        color: var(--phc-status-developing-color);
    }
    .phc-status--pulse {
        animation: phc-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .phc-actions {
        display: flex;
        gap: 1rem;
        padding-top: 1rem;
    }

    .phc-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        height: 3rem;
        padding: 0 1.5rem;
        background: var(--phc-btn-bg);
        color: var(--phc-btn-color);
        border-radius: 0.5rem;
        box-shadow: var(--phc-btn-shadow);
        border: var(--phc-btn-border);
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
        cursor: pointer;
    }
    .phc-action-btn:hover {
        background: var(--color-gamebob-primary);
    }

    .phc-action-btn--disabled {
        background: var(--phc-btn-disabled-bg);
        color: var(--phc-btn-disabled-color);
        cursor: not-allowed;
        opacity: 0.5;
        filter: grayscale(1);
    }
    .phc-action-btn--disabled:hover {
        background: var(--phc-btn-disabled-bg);
    }

    .phc-action-disabled-group {
        display: flex;
        gap: 1rem;
        opacity: 0.5;
        filter: grayscale(1);
    }

    .phc-action-icon {
        width: 1.5rem;
        height: 1.5rem;
    }

    .phc-action-text {
        text-align: left;
    }

    .phc-action-label {
        font-size: 0.625rem;
        line-height: 1;
    }
    .phc-action-label--muted {
        color: inherit;
        opacity: 0.7;
    }

    .phc-action-name {
        font-size: 0.875rem;
        font-weight: 700;
        line-height: 1;
    }
    .phc-action-name--muted {
        color: inherit;
        opacity: 0.7;
    }

    .phc-visual {
        position: relative;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px var(--phc-shadow);
        border: 1px solid var(--phc-visual-border);
    }

    .phc-visual-inner {
        background: #0f172a;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        aspect-ratio: 2 / 3;
    }
    @media (min-width: 768px) {
        .phc-visual-inner {
            aspect-ratio: 3 / 4;
        }
    }

    .phc-visual-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.7s;
    }
    .phc-visual:hover .phc-visual-img {
        transform: scale(1.1);
    }

    .phc-visual-fallback {
        color: rgba(255, 255, 255, 0.1);
        font-weight: 900;
        font-size: 3.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-align: center;
        padding: 0 1rem;
    }

    .phc-overlay-gradient {
        position: absolute;
        inset: 0;
        z-index: 10;
    }

    .phc-overlay-shadow {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent, transparent);
        opacity: 0.6;
        z-index: 20;
    }
</style>
