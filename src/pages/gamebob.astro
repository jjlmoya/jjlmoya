---
export const prerender = true;
import GameBobLayout from "../layouts/GameBobLayout.astro";
import { Icon } from "astro-icon/components";
import GameBobLogo from "../components/GameBobLogo.astro";
import ProjectHomeCard from "../components/gamebob/ProjectHomeCard.astro";
import DiscordCTA from "../components/gamebob/DiscordCTA.astro";
import { ALL_APP_DEFINITIONS, type KnownLocale } from "@jjlmoya/apps";
import "./gamebob.css";

const DEFAULT_THEMES: Record<string, string> = {
    "sauce-lab": "#FF4D4D",
    "fortune-cookie": "#FFD700",
    "lexi-crash": "#4D94FF",
    "pizzametrics": "#FFA500",
    "vesp": "#00FF9F",
    "day-check": "#B185FF",
    "fast-task": "#00E5FF",
};


const projects = await Promise.all(
    ALL_APP_DEFINITIONS
        .map(async ({ entry }) => {
            const loader = entry.i18n["es" as KnownLocale] ?? entry.i18n.en;
            const card = await loader!();
            return {
                name: card.title,
                description: card.description,
                homeDescription: card.subtitle,
                image: `/assets/apps/${entry.id}/hero.webp`,
                statusLabel: "publicado" as const,
                statusType: "released" as const,
                progress: 100,
                color: DEFAULT_THEMES[entry.id] || "#1ddabc",
                links: {
                    googlePlay: entry.stores.googlePlay,
                    appStore: entry.stores.appStore,
                },
                tasks: [],
            };
        })
);

---

<GameBobLayout
    title="GameBob: La cruda realidad del desarrollo de juegos indie"
    description="¿Por qué es tan difícil hacer un juego? Descubre prototipos, fallos de diseño y las tripas de GameBob. El único estudio que documenta el caos."
    image="/images/gamebob/index.webp"
>
    <div class="gamebob-home-wrapper">
        <div class="gamebob-home-logo-section">
            <div class="gamebob-home-logo-wrapper">
                <GameBobLogo />
            </div>
        </div>

        <p
            class="gamebob-home-intro"
        >
            Pequeño estudio de desarrollo de juegos casuales indies.
        </p>

        <DiscordCTA title="Únete a la comunidad" />

        <div class="gamebob-home-section">
            <h2 class="gamebob-home-section-title">
                aplicaciones
            </h2>

            <div class="gamebob-games-grid">
                {
                    projects.map((project) => (
                        <div class="gamebob-game-card" style={`--theme-color: ${project.color}`}>
                            <div class="game-card-image-wrapper">
                                <img src={project.image} alt={project.name} class="game-card-image" />
                                <span class="game-card-badge">{project.statusLabel}</span>
                            </div>
                            <div class="game-card-content">
                                <h3 class="game-card-title">{project.name}</h3>
                                <p class="game-card-description">{project.homeDescription}</p>
                                <div class="game-card-actions">
                                    <a href={`/apps/${project.name.toLowerCase().replace(/\s+/g, "-")}/`} class="game-card-btn-explore">
                                        <span>Explorar</span>
                                        <Icon name="mdi:arrow-right" class="game-card-btn-icon" />
                                    </a>
                                    <div class="game-card-stores">
                                        {project.links?.googlePlay ? (
                                            <a href={project.links.googlePlay} target="_blank" class="game-card-store-link" title="Google Play">
                                                <Icon name="mdi:google-play" class="game-card-store-icon" />
                                            </a>
                                        ) : (
                                            <div class="game-card-store-disabled" title="Próximamente">
                                                <Icon name="mdi:google-play" class="game-card-store-icon" />
                                            </div>
                                        )}
                                        {project.links?.appStore ? (
                                            <a href={project.links.appStore} target="_blank" class="game-card-store-link" title="App Store">
                                                <Icon name="mdi:apple" class="game-card-store-icon" />
                                            </a>
                                        ) : (
                                            <div class="game-card-store-disabled" title="Próximamente">
                                                <Icon name="mdi:apple" class="game-card-store-icon" />
                                            </div>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <div class="gamebob-home-section">
            <h2 class="gamebob-home-section-title">
                el estudio
            </h2>
            
            <div class="gamebob-studio-grid">
                <div class="gamebob-studio-card purple">
                    <div class="gamebob-studio-visual">
                        <Icon name="mdi:egg-outline" class="gamebob-studio-icon" />
                        <Icon name="mdi:arrow-right" class="gamebob-studio-arrow" />
                        <Icon name="mdi:dna" class="gamebob-studio-icon glow" />
                    </div>
                    <h3 class="gamebob-studio-title">evo<span>lución</span></h3>
                    <p class="gamebob-studio-desc">alquimia del caos. combina elementos primordiales, crea criaturas únicas y enfréntalas en la arena.</p>
                    <a href="/gamebob/prototipos/" class="gamebob-studio-btn">
                        <Icon name="mdi:flask-empty-outline" style="width: 1.15rem; height: 1.15rem;" />
                        prototipos
                    </a>
                </div>

                <div class="gamebob-studio-card blue">
                    <div class="gamebob-studio-visual">
                        <div class="gamebob-studio-visual-icons">
                            <Icon name="mdi:gesture-tap" class="gamebob-studio-icon-small" />
                            <Icon name="mdi:run-fast" class="gamebob-studio-icon-small" />
                            <Icon name="mdi:target" class="gamebob-studio-icon-small" />
                            <Icon name="mdi:controller" class="gamebob-studio-icon-small" />
                        </div>
                    </div>
                    <h3 class="gamebob-studio-title">lab<span>oratorio</span></h3>
                    <p class="gamebob-studio-desc">librería de componentes aislados. mecánicas de movimiento, sistemas de física y controles.</p>
                    <a href="/gamebob/mecanicas/" class="gamebob-studio-btn">
                        <Icon name="mdi:code-braces" style="width: 1.15rem; height: 1.15rem;" />
                        mecánicas
                    </a>
                </div>

                <div class="gamebob-studio-card red">
                    <div class="gamebob-studio-visual">
                        <Icon name="mdi:alert-decagram" class="gamebob-studio-icon" />
                        <Icon name="mdi:arrow-right" class="gamebob-studio-arrow" />
                        <Icon name="mdi:book-open-page-variant" class="gamebob-studio-icon glow" />
                    </div>
                    <h3 class="gamebob-studio-title">post<span>mortem</span></h3>
                    <p class="gamebob-studio-desc">el cementerio de las buenas intenciones. análisis forense de proyectos fallidos y errores.</p>
                    <a href="/gamebob/post-mortem/" class="gamebob-studio-btn">
                        <Icon name="mdi:skull-scan-outline" style="width: 1.15rem; height: 1.15rem;" />
                        memorándums
                    </a>
                </div>
            </div>
        </div>
    </div>
</GameBobLayout>
