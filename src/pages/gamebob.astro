---
export const prerender = true;
import GameBobLayout from "../layouts/GameBobLayout.astro";
import { Icon } from "astro-icon/components";
import GameBobLogo from "../components/GameBobLogo.astro";
import ProjectHomeCard from "../components/gamebob/ProjectHomeCard.astro";
import DiscordCTA from "../components/gamebob/DiscordCTA.astro";
import { ALL_APP_DEFINITIONS, type KnownLocale } from "@jjlmoya/apps";
import "./gamebob.css";

const DEFAULT_THEMES: Record<string, string> = {
    "sauce-lab": "#FF4D4D",
    "fortune-cookie": "#FFD700",
    "lexi-crash": "#4D94FF",
    "pizzametrics": "#FFA500",
    "vesp": "#00FF9F",
    "day-check": "#B185FF",
    "fast-task": "#00E5FF",
};


const projects = await Promise.all(
    ALL_APP_DEFINITIONS
        .map(async ({ entry }) => {
            const loader = entry.i18n["es" as KnownLocale] ?? entry.i18n.en;
            const card = await loader!();
            return {
                name: card.title,
                description: card.description,
                homeDescription: card.subtitle,
                image: `/assets/apps/${entry.id}/hero.webp`,
                statusLabel: "publicado" as const,
                statusType: "released" as const,
                progress: 100,
                color: DEFAULT_THEMES[entry.id] || "#1ddabc",
                links: {
                    googlePlay: entry.stores.googlePlay,
                    appStore: entry.stores.appStore,
                },
                tasks: [],
            };
        })
);

---

<GameBobLayout
    title="GameBob: La cruda realidad del desarrollo de juegos indie"
    description="¿Por qué es tan difícil hacer un juego? Descubre prototipos, fallos de diseño y las tripas de GameBob. El único estudio que documenta el caos."
    image="/images/gamebob/index.webp"
>
    <div class="gamebob-home-wrapper">
        <div class="gamebob-home-logo-section">
            <div class="gamebob-home-logo-wrapper">
                <GameBobLogo />
            </div>
            <h1
                class="gamebob-home-title"
            >
                Game<span class="gamebob-home-title-highlight">Bob</span>
            </h1>
        </div>

        <p
            class="gamebob-home-intro"
        >
            Pequeño estudio de desarrollo de juegos casuales indies.
        </p>

        <DiscordCTA title="Únete a la comunidad" />

        <div class="gamebob-home-section">
            <h2
                class="gamebob-home-section-title"
            >
                aplicaciones
            </h2>

            <div class="gamebob-home-released-list">
                {
                    projects.map((project, index) => (
                        <ProjectHomeCard project={project} index={index} />
                    ))
                }
            </div>
        </div>

        <div class="gamebob-home-section">
            <h2
                class="gamebob-home-section-title purple"
            >
                prototipos
            </h2>

            <div class="gamebob-home-split-row">
                <div class="gamebob-home-info-col order-2">
                    <h3
                        class="gamebob-home-heading purple"
                    >
                        EVO<span>LUCIÓN</span>
                    </h3>
                    <p class="gamebob-home-desc">
                        alquimia del caos. combina elementos primordiales, crea criaturas únicas y
                        enfréntalas en la arena de combate. un experimento de generación procedural.
                    </p>

                    <div class="gamebob-home-actions">
                        <a
                            href="/gamebob/prototipos/"
                            class="gamebob-home-button purple"
                        >
                            <Icon name="mdi:flask-empty-outline" style="width: 1.25rem; height: 1.25rem;" />
                            Explorar Prototipos
                        </a>
                    </div>
                </div>

                <div
                    class="gamebob-home-visual-box purple"
                >
                    <div
                        class="gamebob-home-visual-glow"
                    >
                    </div>

                    <div class="gamebob-home-visual-content animate-float">
                        <Icon name="mdi:egg-outline" class="gamebob-home-visual-icon" />
                        <Icon name="mdi:arrow-right" class="gamebob-home-visual-arrow" />
                        <Icon
                            name="mdi:dna"
                            class="gamebob-home-visual-icon glow-purple"
                        />
                    </div>
                </div>
            </div>
        </div>

        <div class="gamebob-home-section">
            <h2
                class="gamebob-home-section-title blue"
            >
                mecánicas
            </h2>

            <div class="gamebob-home-split-row">
                <div
                    class="gamebob-home-visual-box blue"
                >
                    <div
                        class="gamebob-home-visual-glow"
                    >
                    </div>

                    <div class="gamebob-home-visual-content grid-4 gamebob-animate-pulse">
                        <Icon name="mdi:gesture-tap" class="gamebob-home-visual-icon blue-icon" />
                        <Icon name="mdi:run-fast" class="gamebob-home-visual-icon blue-icon" />
                        <Icon name="mdi:target" class="gamebob-home-visual-icon blue-icon" />
                        <Icon name="mdi:controller" class="gamebob-home-visual-icon blue-icon" />
                    </div>
                </div>

                <div class="gamebob-home-info-col">
                    <h3
                        class="gamebob-home-heading blue"
                    >
                        LAB<span>ORATORIO</span>
                    </h3>
                    <p class="gamebob-home-desc">
                        librería de componentes aislados. mecánicas de movimiento, sistemas de
                        física y controles experimentales listos para testear.
                    </p>

                    <div class="gamebob-home-actions">
                        <a
                            href="/gamebob/mecanicas/"
                            class="gamebob-home-button blue"
                        >
                            <Icon name="mdi:code-braces" style="width: 1.25rem; height: 1.25rem;" />
                            Explorar Mecánicas
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="gamebob-home-section" style="margin-top: 6rem;">
            <h2
                class="gamebob-home-section-title red"
            >
                post mortem
            </h2>

            <div class="gamebob-home-split-row">
                <div class="gamebob-home-info-col order-2">
                    <h3
                        class="gamebob-home-heading red"
                    >
                        POST<span>MORTEM</span>
                    </h3>
                    <p class="gamebob-home-desc">
                        el cementerio de las buenas intenciones. análisis forense de proyectos
                        fallidos, errores de diseño y lecciones aprendidas a base de golpes.
                    </p>

                    <div class="gamebob-home-actions">
                        <a
                            href="/gamebob/post-mortem/"
                            class="gamebob-home-button red"
                        >
                            <Icon name="mdi:skull-scan-outline" style="width: 1.25rem; height: 1.25rem;" />
                            Leer Memorándums
                        </a>
                    </div>
                </div>

                <div
                    class="gamebob-home-visual-box red"
                >
                    <div
                        class="gamebob-home-visual-glow"
                    >
                    </div>

                    <div class="gamebob-home-visual-content gamebob-animate-pulse">
                        <Icon name="mdi:alert-decagram" class="gamebob-home-visual-icon red-icon" />
                        <Icon name="mdi:arrow-right" class="gamebob-home-visual-arrow" />
                        <Icon
                            name="mdi:book-open-page-variant"
                            class="gamebob-home-visual-icon glow-red"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div
        class="gamebob-home-footer"
    >
        <a
            href="/gamebob/privacidad/"
            class="gamebob-home-footer-link"
        >
            política de privacidad
        </a>
    </div>
</GameBobLayout>
