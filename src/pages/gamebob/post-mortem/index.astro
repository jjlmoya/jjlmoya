---
export const prerender = true;
import GameBobLayout from "../../../layouts/GameBobLayout.astro";
import PostMortemHeader from "../../../components/gamebob/post-mortem/PostMortemHeader.astro";
import PostMortemCard from "../../../components/gamebob/post-mortem/PostMortemCard.astro";
import { postMortemEntries } from "../../../data/gamebob/post-mortem/entries";
---

<GameBobLayout
    title="Post Mortem: Autopsia de errores y lecciones de desarrollo"
    description="Crónica de fallos técnicos, bugs inesperados y soluciones. Documentando los problemas reales que surgen al crear videojuegos."
    image="/images/gamebob/post-mortem/og-post-mortem.webp"
>
    <div class="gpm-page">
        <div class="gpm-container">
            <PostMortemHeader
                title="post mortem"
                description="Una crónica de los errores que me han hecho mejor desarrollador. Dicen que la experiencia es el nombre que le damos a nuestras equivocaciones, así que aquí estoy acumulando mucha experiencia para no volver a romper el código del mismo modo."
            />

            <div class="gpm-grid">
                {postMortemEntries.map((entry) => <PostMortemCard entry={entry} />)}
            </div>
        </div>
    </div>
</GameBobLayout>

<style>
    .gpm-page {
        min-height: 100vh;
        padding: 3rem 1rem;
        position: relative;
    }
    .gpm-container {
        z-index: 10;
        width: 100%;
        max-width: 72rem;
        margin: 2rem auto 0;
    }
    .gpm-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @media (min-width: 768px) {
        .gpm-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .gpm-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>
