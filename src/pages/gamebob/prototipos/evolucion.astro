---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import evolutionData from "../../../data/evolution-data.json";

const { base_elements, recipes } = evolutionData;
---

<Layout
    title="Evolución Infinita"
    description="Alquimia del caos. Combina elementos, crea criaturas y enfréntalas en la arena."
    bodyClass="ev-body"
    showBackground={false}
    mainClass="ev-main"
    headerClass="ev-header"
    image="/images/gamebob/prototipos/evolution.webp"
>
    <div class="ev-bg-layer">
        <div class="ev-bg-gradient"></div>
        <div class="ev-blob ev-blob-1"></div>
        <div class="ev-blob ev-blob-2"></div>
        <div class="ev-grid-pattern"></div>
    </div>

    <div class="ev-layout">
        <aside class="ev-sidebar">
            <div class="ev-sidebar-glow"></div>

            <div class="ev-sidebar-header">
                <h2 class="ev-sidebar-title">Laboratorio</h2>
                <p class="ev-sidebar-sub">Elementos Primordiales</p>
                <div class="ev-sidebar-mobile-icon">
                    <Icon name="mdi:flask" class="ev-sidebar-mobile-svg" />
                </div>
            </div>

            <div class="ev-sidebar-body">
                <button id="spawn-egg-btn" class="ev-spawn-btn">
                    <div class="ev-spawn-btn-overlay"></div>
                    <Icon name="mdi:egg" class="ev-spawn-btn-icon" />
                    <span class="ev-spawn-btn-text">Crear Huevo</span>
                </button>
            </div>

            <div class="ev-divider-section">
                <div class="ev-divider">
                    <div class="ev-divider-line"></div>
                    <span class="ev-divider-text">Elementos</span>
                    <div class="ev-divider-line"></div>
                </div>
            </div>

            <div id="inventory" class="ev-inventory"></div>

            <div class="ev-sidebar-footer">
                <button id="encyclopedia-btn" class="ev-btn ev-btn-encyclopedia">
                    <Icon name="mdi:book-open-page-variant" class="ev-btn-icon" />
                    <span class="ev-btn-text">Enciclopedia</span>
                </button>

                <button id="clear-btn" class="ev-btn ev-btn-clear">
                    <Icon name="mdi:delete-sweep" class="ev-btn-icon" />
                    <span class="ev-btn-text">Limpiar Todo</span>
                </button>
            </div>
        </aside>

        <main class="ev-playground" id="playground">
            <div class="ev-playground-texture"></div>

            <div id="stone-tutorial" class="ev-tutorial">
                <div class="ev-tutorial-inner">
                    <div class="ev-tutorial-row ev-tutorial-row-top">
                        <div class="ev-icon-group">
                            <Icon name="mdi:egg-outline" class="ev-egg-icon" />
                            <Icon name="mdi:fire" class="ev-egg-overlay ev-egg-overlay-fire" />
                        </div>
                        <div class="ev-icon-group">
                            <Icon name="mdi:egg-outline" class="ev-egg-icon" />
                            <Icon name="mdi:water" class="ev-egg-overlay ev-egg-overlay-water" />
                        </div>
                    </div>

                    <div class="ev-tutorial-row ev-tutorial-row-middle">
                        <div class="ev-icon-group ev-ic-tilt-right">
                            <Icon name="mdi:egg-outline" class="ev-egg-icon" />
                            <Icon name="mdi:fire" class="ev-egg-overlay ev-egg-overlay-fire" />
                        </div>
                        <Icon name="mdi:flash" class="ev-flash-icon" />
                        <div class="ev-icon-group ev-ic-tilt-left">
                            <Icon name="mdi:egg-outline" class="ev-egg-icon" />
                            <Icon name="mdi:water" class="ev-egg-overlay ev-egg-overlay-water" />
                        </div>
                    </div>

                    <div class="ev-tutorial-row ev-tutorial-row-bottom">
                        <div class="ev-icon-group ev-ic-rotate">
                            <Icon name="mdi:egg-off-outline" class="ev-egg-icon-sm" />
                            <Icon name="mdi:fire" class="ev-egg-overlay-sm ev-egg-overlay-fire" />
                        </div>
                        <div class="ev-icon-group ev-ic-scale">
                            <Icon name="mdi:egg-outline" class="ev-egg-icon-lg" />
                            <Icon name="mdi:water" class="ev-egg-overlay-lg ev-egg-overlay-water" />
                            <div class="ev-egg-badge">
                                <Icon name="mdi:numeric-2" class="ev-egg-badge-icon" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="entities-layer" class="ev-entities-layer"></div>
        </main>

        <div id="encyclopedia-modal" class="ev-modal">
            <div class="ev-modal-content">
                <div class="ev-modal-header">
                    <div class="ev-modal-header-left">
                        <div class="ev-modal-header-icon-box">
                            <Icon name="mdi:book-open-variant" class="ev-modal-header-icon" />
                        </div>
                        <div>
                            <h2 class="ev-modal-title">Enciclopedia</h2>
                            <p class="ev-modal-stats" id="encyclopedia-stats">Descubiertos: 0/0</p>
                        </div>
                    </div>
                    <button id="close-encyclopedia" class="ev-modal-close-btn">
                        <Icon name="mdi:close" class="ev-modal-close-icon" />
                    </button>
                </div>

                <div id="encyclopedia-grid" class="ev-modal-grid"></div>
            </div>
        </div>

        <div id="battle-overlay" class="ev-battle-overlay">
            <div class="ev-battle-container">
                <div class="ev-battle-title-section">
                    <h2 class="ev-battle-title">ARENA DE COMBATE</h2>
                </div>

                <div class="ev-battle-fighters">
                    <div class="ev-fighter" id="fighter-1">
                        <div class="ev-fighter-portrait">
                            <div class="ev-fighter-glow ev-fighter-glow-blue"></div>
                            <div id="f1-visual" class="ev-fighter-visual ev-fighter-visual-blue"></div>
                        </div>
                        <h3 id="f1-name" class="ev-fighter-name">Creature 1</h3>
                        <div class="ev-fighter-hp-track">
                            <div id="f1-hp-bar" class="ev-fighter-hp-fill ev-hp-green"></div>
                        </div>
                        <p id="f1-hp-text" class="ev-fighter-hp-text">100/100</p>
                    </div>

                    <div class="ev-vs-section">
                        <div class="ev-vs-text">VS</div>
                    </div>

                    <div class="ev-fighter" id="fighter-2">
                        <div class="ev-fighter-portrait">
                            <div class="ev-fighter-glow ev-fighter-glow-red"></div>
                            <div id="f2-visual" class="ev-fighter-visual ev-fighter-visual-red"></div>
                        </div>
                        <h3 id="f2-name" class="ev-fighter-name">Creature 2</h3>
                        <div class="ev-fighter-hp-track">
                            <div id="f2-hp-bar" class="ev-fighter-hp-fill ev-hp-red"></div>
                        </div>
                        <p id="f2-hp-text" class="ev-fighter-hp-text">100/100</p>
                    </div>
                </div>

                <div class="ev-battle-action">
                    <p id="battle-action-text" class="ev-battle-action-text"></p>
                </div>

                <button id="close-battle" class="ev-close-battle-btn">
                    Cerrar Arena
                </button>
            </div>
        </div>
    </div>
</Layout>

<style>
    .ev-body {
        background: #020617;
        color: #fff;
        overflow: hidden;
    }
    .ev-main {
        padding: 0 !important;
    }
    .ev-header {
        color: #fff;
        mix-blend-mode: difference;
    }

    .ev-bg-layer {
        position: absolute;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }
    .ev-bg-gradient {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(ellipse at center, #0f172a, #0b0f19, #000);
    }
    .ev-blob {
        position: absolute;
        border-radius: 9999px;
        filter: blur(120px);
        mix-blend-mode: screen;
    }
    .ev-blob-1 {
        top: -20%;
        left: 20%;
        width: 600px;
        height: 600px;
        background: rgba(79, 70, 229, 0.2);
    }
    .ev-blob-2 {
        bottom: -10%;
        right: 10%;
        width: 500px;
        height: 500px;
        background: rgba(192, 38, 211, 0.1);
        filter: blur(100px);
    }
    .ev-grid-pattern {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(to right, rgba(255, 255, 255, 0.02) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 40px 40px;
        -webkit-mask-image: radial-gradient(ellipse at center, black 60%, transparent 100%);
        mask-image: radial-gradient(ellipse at center, black 60%, transparent 100%);
    }

    .ev-layout {
        position: relative;
        z-index: 10;
        display: flex;
        height: 100vh;
        padding-top: 3.75rem;
        overflow: hidden;
        font-family: ui-sans-serif, system-ui, sans-serif;
    }

    .ev-sidebar {
        width: 5rem;
        background: linear-gradient(to bottom, rgba(15, 23, 42, 0.95), rgba(2, 6, 23, 0.95));
        backdrop-filter: blur(24px);
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }
    @media (min-width: 768px) {
        .ev-sidebar {
            width: 18rem;
        }
    }
    .ev-sidebar-glow {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.05), transparent, rgba(168, 85, 247, 0.05));
        pointer-events: none;
    }

    .ev-sidebar-header {
        position: relative;
        padding: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    @media (min-width: 768px) {
        .ev-sidebar-header {
            padding: 1.5rem;
        }
    }
    .ev-sidebar-title {
        display: none;
        font-size: 1.25rem;
        font-weight: 900;
        color: #fff;
        letter-spacing: -0.025em;
        margin-bottom: 0.25rem;
    }
    @media (min-width: 768px) {
        .ev-sidebar-title {
            display: block;
        }
    }
    .ev-sidebar-sub {
        display: none;
        font-size: 0.75rem;
        color: #94a3b8;
        font-family: ui-monospace, monospace;
    }
    @media (min-width: 768px) {
        .ev-sidebar-sub {
            display: block;
        }
    }
    .ev-sidebar-mobile-icon {
        display: flex;
        align-items: center;
        justify-content: center;
    }
    @media (min-width: 768px) {
        .ev-sidebar-mobile-icon {
            display: none;
        }
    }
    .ev-sidebar-mobile-svg {
        width: 2rem;
        height: 2rem;
        color: #818cf8;
    }

    .ev-sidebar-body {
        position: relative;
        padding: 0.75rem;
    }
    @media (min-width: 768px) {
        .ev-sidebar-body {
            padding: 1rem;
        }
    }
    .ev-spawn-btn {
        width: 100%;
        padding: 1rem 0;
        border-radius: 0.75rem;
        background: linear-gradient(135deg, #4f46e5, #9333ea);
        color: #fff;
        font-weight: 700;
        box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        position: relative;
        overflow: hidden;
        border: none;
        cursor: pointer;
    }
    .ev-spawn-btn:hover {
        background: linear-gradient(135deg, #6366f1, #a855f7);
    }
    .ev-spawn-btn:active {
        transform: scale(0.95);
    }
    @media (min-width: 768px) {
        .ev-spawn-btn {
            padding: 0.75rem 0;
        }
    }
    .ev-spawn-btn-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(100%);
        transition: transform 0.3s;
    }
    .ev-spawn-btn:hover .ev-spawn-btn-overlay {
        transform: translateY(0);
    }
    .ev-spawn-btn-icon {
        width: 1.75rem;
        height: 1.75rem;
        transition: transform 0.3s;
        position: relative;
        z-index: 10;
    }
    .ev-spawn-btn:hover .ev-spawn-btn-icon {
        transform: rotate(12deg);
    }
    @media (min-width: 768px) {
        .ev-spawn-btn-icon {
            width: 1.5rem;
            height: 1.5rem;
        }
    }
    .ev-spawn-btn-text {
        display: none;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        position: relative;
        z-index: 10;
    }
    @media (min-width: 768px) {
        .ev-spawn-btn-text {
            display: inline;
        }
    }

    .ev-divider-section {
        position: relative;
        padding: 0.5rem 0.75rem 0;
    }
    @media (min-width: 768px) {
        .ev-divider-section {
            padding: 0.5rem 1rem 0;
        }
    }
    .ev-divider {
        display: flex;
        align-items: center;
        margin-bottom: 0.75rem;
    }
    .ev-divider-line {
        height: 1px;
        flex: 1;
        background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.2), transparent);
    }
    .ev-divider-text {
        font-size: 0.625rem;
        font-family: ui-monospace, monospace;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0 0.5rem;
    }
    @media (min-width: 768px) {
        .ev-divider-text {
            font-size: 0.75rem;
        }
    }

    .ev-inventory {
        position: relative;
        flex: 1;
        overflow-y: auto;
        padding: 0 0.5rem 1rem;
    }
    @media (min-width: 768px) {
        .ev-inventory {
            padding: 0 1rem 1rem;
        }
    }
    .ev-inventory > * + * {
        margin-top: 0.5rem;
    }
    .ev-inventory::-webkit-scrollbar {
        width: 4px;
    }
    .ev-inventory::-webkit-scrollbar-track {
        background: transparent;
    }
    .ev-inventory::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
    }

    .ev-sidebar-footer {
        position: relative;
        padding: 0.75rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(2, 6, 23, 0.5);
    }
    .ev-sidebar-footer > * + * {
        margin-top: 0.5rem;
    }
    @media (min-width: 768px) {
        .ev-sidebar-footer {
            padding: 1rem;
        }
    }
    .ev-btn {
        width: 100%;
        padding: 0.75rem 0;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border: 1px solid;
        cursor: pointer;
    }
    @media (min-width: 768px) {
        .ev-btn {
            padding: 0.625rem 0;
            font-size: 0.875rem;
        }
    }
    .ev-btn-encyclopedia {
        background: rgba(99, 102, 241, 0.1);
        border-color: rgba(99, 102, 241, 0.2);
        color: #818cf8;
    }
    .ev-btn-encyclopedia:hover {
        background: rgba(99, 102, 241, 0.2);
        border-color: rgba(99, 102, 241, 0.3);
        color: #a5b4fc;
    }
    .ev-btn-clear {
        background: rgba(239, 68, 68, 0.1);
        border-color: rgba(239, 68, 68, 0.2);
        color: #f87171;
    }
    .ev-btn-clear:hover {
        background: rgba(239, 68, 68, 0.2);
        border-color: rgba(239, 68, 68, 0.3);
        color: #fca5a5;
    }
    .ev-btn-icon {
        width: 1.25rem;
        height: 1.25rem;
        transition: transform 0.3s;
    }
    .ev-btn:hover .ev-btn-icon {
        transform: scale(1.1);
    }
    @media (min-width: 768px) {
        .ev-btn-icon {
            width: 1rem;
            height: 1rem;
        }
    }
    .ev-btn-text {
        display: none;
    }
    @media (min-width: 768px) {
        .ev-btn-text {
            display: inline;
        }
    }

    .ev-playground {
        flex: 1;
        position: relative;
        overflow: hidden;
        cursor: crosshair;
        background: #44403c;
    }
    .ev-playground-texture {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.2;
        mix-blend-mode: soft-light;
        background-image: url('/assets/textures/stone_wall.webp');
        background-size: cover;
        background-position: center;
    }
    .ev-entities-layer {
        position: absolute;
        inset: 0;
        z-index: 10;
    }

    .ev-tutorial {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 0;
        -webkit-user-select: none;
        user-select: none;
        opacity: 0.6;
    }
    .ev-tutorial-inner {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        align-items: center;
    }
    .ev-tutorial-row {
        display: flex;
        gap: 8rem;
        align-items: center;
    }
    .ev-tutorial-row-top {
        opacity: 0.8;
    }
    .ev-tutorial-row-middle {
        gap: 4rem;
        opacity: 0.9;
    }
    .ev-tutorial-row-bottom {
        gap: 6rem;
        align-items: flex-end;
        opacity: 0.8;
    }

    .ev-icon-group {
        position: relative;
    }
    .ev-ic-tilt-right {
        transform: rotate(12deg);
        z-index: 10;
    }
    .ev-ic-tilt-left {
        transform: rotate(-12deg);
        z-index: 20;
    }
    .ev-ic-rotate {
        transform: rotate(45deg);
        opacity: 0.6;
    }
    .ev-ic-scale {
        transform: scale(1.1);
    }

    .ev-egg-icon {
        width: 6rem;
        height: 6rem;
        color: #44403c;
    }
    .ev-egg-icon-sm {
        width: 5rem;
        height: 5rem;
        color: #44403c;
    }
    .ev-egg-icon-lg {
        width: 7rem;
        height: 7rem;
        color: #44403c;
    }
    .ev-egg-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 2.5rem;
        height: 2.5rem;
    }
    .ev-egg-overlay-fire {
        color: rgba(194, 65, 12, 0.7);
    }
    .ev-egg-overlay-water {
        color: rgba(37, 99, 235, 0.7);
    }
    .ev-egg-overlay-sm {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 2rem;
        height: 2rem;
    }
    .ev-egg-overlay-lg {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 3rem;
        height: 3rem;
    }
    .ev-flash-icon {
        width: 4rem;
        height: 4rem;
        color: #d6d3d1;
        z-index: 30;
        margin-top: -2rem;
    }
    .ev-egg-badge {
        position: absolute;
        top: -0.5rem;
        right: -0.5rem;
        background: #44403c;
        border-radius: 9999px;
        padding: 0.25rem;
        border: 1px solid #57534e;
    }
    .ev-egg-badge-icon {
        width: 1.5rem;
        height: 1.5rem;
        color: #a8a29e;
    }

    .ev-modal {
        position: fixed;
        inset: 0;
        z-index: 50;
        background: rgba(2, 6, 23, 0.95);
        backdrop-filter: blur(24px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s;
        padding: 1rem;
    }
    .ev-modal-content {
        width: 100%;
        max-width: 56rem;
        background: #0f172a;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        display: flex;
        flex-direction: column;
        max-height: 85vh;
    }
    .ev-modal-header {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(15, 23, 42, 0.5);
        border-radius: 1rem 1rem 0 0;
    }
    .ev-modal-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .ev-modal-header-icon-box {
        width: 3rem;
        height: 3rem;
        border-radius: 0.75rem;
        background: rgba(99, 102, 241, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(99, 102, 241, 0.2);
    }
    .ev-modal-header-icon {
        width: 1.5rem;
        height: 1.5rem;
        color: #818cf8;
    }
    .ev-modal-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
    }
    .ev-modal-stats {
        font-size: 0.875rem;
        color: #94a3b8;
        font-family: ui-monospace, monospace;
    }
    .ev-modal-close-btn {
        padding: 0.5rem;
        background: none;
        border: none;
        border-radius: 0.5rem;
        color: #94a3b8;
        cursor: pointer;
        transition: all 0.3s;
    }
    .ev-modal-close-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    .ev-modal-close-icon {
        width: 1.5rem;
        height: 1.5rem;
    }
    .ev-modal-grid {
        padding: 1.5rem;
        overflow-y: auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    @media (min-width: 768px) {
        .ev-modal-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .ev-modal-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
    .ev-modal-grid::-webkit-scrollbar {
        width: 4px;
    }
    .ev-modal-grid::-webkit-scrollbar-track {
        background: transparent;
    }
    .ev-modal-grid::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
    }

