---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/finger-twister";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/finger-twister/FingerTwisterMechanic.ts";
---

<MechanicPage
    title="Finger Twister"
    description="Caos multitáctil. Mantén pulsados los nodos sin soltar ninguno mientras aparecen más."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/finger-twister.webp"
>
    <Icon slot="icon" name="mdi:hand-back-right" class="gm-icon-pink" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Mantén pulsados los círculos"
        subInstruction="¡No sueltes ninguno! Usa múltiples dedos."
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-pink">•</span>
                <span>Requiere pantalla táctil (multitouch).</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-pink">•</span>
                <span>Cada nodo debe ser mantenido pulsado.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-pink">•</span>
                <span>Si sueltas un nodo activo, pierdes.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-full">
                <span class="gm-label">Hold</span>
                <span class="gm-desc">Mantener Pulsado</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { FingerTwisterGame } from "../../../lib/mechanics/finger-twister/FingerTwisterGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");

    let game: FingerTwisterGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new FingerTwisterGame(canvas);
            }
        });

        overlay.addEventListener("touchstart", (e) => {
            e.preventDefault();
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new FingerTwisterGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-pink { color: #ec4899; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-full {
        width: 100%;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-pink { color: #ec4899; }
</style>
