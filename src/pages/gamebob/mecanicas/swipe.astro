---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/swipe";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/swipe/SwipeGesture.ts";
---

<MechanicPage
    title="Swipe Gesture"
    description="El arte del gesto. Controla la acción con deslizamientos fluidos y precisos."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/swipe-gesture.webp"
>
    <Icon slot="icon" name="mdi:gesture-swipe" class="gm-icon-pink" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Desliza en cualquier dirección"
        subInstruction="8 direcciones soportadas"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Detección de gestos en 8 direcciones (cardinales y diagonales).</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Cálculo de velocidad y ángulo del deslizamiento.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Visualización de estela (trail) suave.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Deslizar / Swipe</span>
                <span class="gm-desc">Cualquier dirección</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { SwipeGame } from "../../../lib/mechanics/swipe/SwipeGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: SwipeGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new SwipeGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-blue { color: #60a5fa; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-wide {
        grid-column: span 2;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-pink { color: #f472b6; }
</style>
