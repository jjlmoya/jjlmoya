---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const title = "Draw The Path";
const description =
    "Protege al corredor. Dibuja escudos contra meteoritos y puentes sobre el vacío.";
const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/draw-the-path";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/draw-the-path/DrawThePathMechanic.ts";
---

<MechanicPage
    title={title}
    description={description}
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/draw-the-path.webp"
>
    <Icon slot="icon" name="mdi:draw" class="gm-icon-pink" />

    <MechanicCanvas
        id="draw-path-canvas"
        instruction="Dibuja / Arrastra"
        subInstruction="Crear camino o escudo"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-pink">•</span>
                <span>El personaje corre ciegamente. ¡No dejes que caiga!</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-orange">•</span>
                <span>Dibuja techos para bloquear los meteoritos.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-green">•</span>
                <span>Bloquea o redirige a los enemigos saltarines.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box">
                <span class="gm-label">Arrastrar</span>
                <span class="gm-desc">Dibujar Línea</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { DrawThePathGame } from "../../../lib/mechanics/draw-the-path/DrawThePathGame";

    const canvas = document.getElementById("draw-path-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("draw-path-canvas-overlay");
    let game: DrawThePathGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new DrawThePathGame(canvas);
                game.start();
            }
        });

        document.addEventListener(
            "astro:before-swap",
            () => {
                game?.stop();
            },
            { once: true }
        );
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-pink { color: #ec4899; }
    .gm-bullet-orange { color: #f97316; }
    .gm-bullet-green { color: #4ade80; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-pink { color: #ec4899; }
</style>
