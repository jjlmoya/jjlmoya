---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/platformer";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/platformer/PlatformerGame.js";
---

<MechanicPage
    title="Plataformas"
    description="Demo de mecánicas fluidas: salto, doble salto, deslizamiento y partículas."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/platformer.webp"
>
    <Icon slot="icon" name="mdi:controller-classic" class="gm-icon-indigo" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Usa las Flechas"
        subInstruction="Muévete y Salta"
        verticalOnMobile={false}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Máquina de estados finitos para el jugador.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Física de movimiento con inercia y fricción.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Sistema de partículas para feedback visual.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box">
                <span class="gm-label">← / →</span>
                <span class="gm-desc">Moverse</span>
            </div>
            <div class="gm-control-box">
                <span class="gm-label">Espacio</span>
                <span class="gm-desc">Saltar</span>
            </div>
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Shift + ↓</span>
                <span class="gm-desc">Deslizar / Caer</span>
            </div>
        </Fragment>
    </MechanicInfo>

    <div class="gm-debug">
        <div>State: <span id="debug-state" class="gm-debug-val gm-debug-green">Idle</span></div>
        <div>VX: <span id="debug-vel-x" class="gm-debug-val gm-debug-blue">0.00</span></div>
        <div>VY: <span id="debug-vel-y" class="gm-debug-val gm-debug-red">0.00</span></div>
    </div>
</MechanicPage>

<script>
    import { PlatformerGame } from "../../../lib/mechanics/platformer/PlatformerGame.js";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: PlatformerGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new PlatformerGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-blue { color: #60a5fa; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-wide {
        grid-column: span 2;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-indigo { color: #818cf8; }
    .gm-debug {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(8px);
        padding: 0.5rem;
        border-radius: 0.25rem;
        font-size: 0.75rem;
        font-family: ui-monospace, monospace;
        color: #fff;
        pointer-events: none;
        z-index: 20;
        display: none;
    }
    @media (min-width: 768px) {
        .gm-debug {
            display: block;
        }
    }
    .gm-debug-val { font-weight: 400; }
    .gm-debug-green { color: #4ade80; }
    .gm-debug-blue { color: #60a5fa; }
    .gm-debug-red { color: #f87171; }
</style>
