---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const title = "Neon Grapple";
const description =
    "Spiderman minimalista. Balancéate por un mundo infinito usando ganchos de energía.";
const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/neon-grapple";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/neon-grapple/NeonGrappleMechanic.ts";
---

<MechanicPage
    title={title}
    description={description}
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/neon-grapple.webp"
>
    <Icon slot="icon" name="mdi:hook" class="gm-icon-cyan" />

    <MechanicCanvas
        id="neon-grapple-canvas"
        instruction="Click / Espacio"
        subInstruction="Enganchar y Balancear"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-cyan">•</span>
                <span>Físicas de péndulo con conservación de momento.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-cyan">•</span>
                <span>Generación procedural de puntos de anclaje.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-cyan">•</span>
                <span>Cámara con seguimiento suave horizontal.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Click / Espacio</span>
                <span class="gm-desc">Enganchar (Mantener)</span>
            </div>
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Soltar</span>
                <span class="gm-desc">Lanzarse</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { NeonGrappleGame } from "../../../lib/mechanics/neon-grapple/NeonGrappleGame";

    const canvas = document.getElementById("neon-grapple-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("neon-grapple-canvas-overlay");
    let game: NeonGrappleGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new NeonGrappleGame(canvas);
                game.start();
            }
        });

        document.addEventListener(
            "astro:before-swap",
            () => {
                game?.stop();
            },
            { once: true }
        );
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-cyan { color: #22d3ee; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-wide {
        grid-column: span 2;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-cyan { color: #22d3ee; }
</style>
