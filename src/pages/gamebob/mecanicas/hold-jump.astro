---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/hold-jump";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/hold-jump/HoldJumpMechanic.ts";
---

<MechanicPage
    title="Hold to Jump"
    description="Calcula, carga y salta. La tensión de la energía potencial liberada en el momento exacto."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/hold-to-jump.webp"
>
    <Icon slot="icon" name="mdi:arrow-up-bold-box-outline" class="gm-icon-red" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Mantén para Cargar"
        subInstruction="Suelta para saltar"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Acumulación de energía proporcional al tiempo de pulsación.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Conversión de carga en vector de fuerza (salto).</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Feedback visual de carga (brillo y deformación).</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Mantener Click / Espacio</span>
                <span class="gm-desc">Cargar Salto</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { HoldJumpGame } from "../../../lib/mechanics/hold-jump/HoldJumpGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: HoldJumpGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new HoldJumpGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-blue { color: #60a5fa; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-wide {
        grid-column: span 2;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-red { color: #f87171; }
</style>
