---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/tap-fly";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/tap-fly/TapFlyMechanic.ts";
---

<MechanicPage
    title="Tap & Fly"
    description="Desafía la gravedad con un toque. Mantente en el aire y esquiva el peligro."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/tap-and-fly.webp"
>
    <Icon slot="icon" name="mdi:arrow-up-bold" class="gm-icon-yellow" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Toca para Volar"
        subInstruction="Esquiva las tuberías"
        aspectRatio="portrait"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Gravedad constante que tira del jugador hacia abajo.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Impulso vertical instantáneo al tocar.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Generación procedural de obstáculos con huecos variables.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Click / Tap / Espacio</span>
                <span class="gm-desc">Volar</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { TapFlyGame } from "../../../lib/mechanics/tap-fly/TapFlyGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: TapFlyGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new TapFlyGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-blue { color: #60a5fa; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-wide {
        grid-column: span 2;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-yellow { color: #fbbf24; }
</style>
