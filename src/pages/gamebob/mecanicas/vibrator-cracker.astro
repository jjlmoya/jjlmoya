---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE =
    "https://github.com/jjlmoya/jjlmoya/tree/main/src/pages/gamebob/mecanicas/vibrator-cracker.astro";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/pages/gamebob/mecanicas/vibrator-cracker.astro";
---

<MechanicPage
    title="Vibrator Cracker"
    description="Siente el mecanismo. Usa la vibración de tu dispositivo para encontrar la combinación correcta y abrir la caja fuerte."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/vibrator-cracker.webp"
>
    <Icon slot="icon" name="mdi:safe" class="gm-icon-rose" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Gira el dial"
        subInstruction="Siente los clicks y mantén para abrir"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-rose">•</span>
                <span>Gira el dial arrastrando con el dedo o mouse.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-rose">•</span>
                <span>Tu dispositivo vibrará ligeramente al pasar números.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-rose">•</span>
                <span>Una vibración distinta indica el número correcto.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-rose">•</span>
                <span>Mantén el dial en la posición correcta unos segundos para confirmar.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-rose">•</span>
                <span>Encuentra 3 números para abrir la caja.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box">
                <span class="gm-label">Arrastrar / Touch</span>
                <span class="gm-desc">Girar Dial</span>
            </div>
        </Fragment>
    </MechanicInfo>

    <div class="gm-warning-box">
        <p class="gm-warning-text">
            <Icon name="mdi:alert" class="gm-warning-inline-icon" />
            Soporte experimental de vibración en iOS activado.
        </p>
        <div class="gm-warning-actions">
            <button
                id="test-vibrate-btn"
                class="gm-test-btn"
            >
                Test Vibration
            </button>
            <p id="debug-log" class="gm-debug-log"></p>
        </div>
    </div>
</MechanicPage>

<script>
    import { VibratorCrackerGame } from "../../../lib/mechanics/vibrator-cracker/VibratorCrackerGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    const testBtn = document.getElementById("test-vibrate-btn");
    const debugLog = document.getElementById("debug-log");
    let game: VibratorCrackerGame | null = null;

    function log(msg: string) {
        if (debugLog) debugLog.textContent = msg;
        console.log(msg);
    }

    if (testBtn) {
        testBtn.addEventListener("click", () => {
            if (navigator.vibrate) {
                const success = navigator.vibrate([200]);
                log(`Vibrate called: ${success ? "Success" : "Failed"}`);
            } else {
                log("navigator.vibrate not supported");
            }
        });
    }

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new VibratorCrackerGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    #game-canvas {
        touch-action: pan-y !important;
    }
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-rose { color: #f43f5e; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-rose { color: #f43f5e; }
    .gm-warning-box {
        margin-top: 1rem;
        padding: 1rem;
        background: rgba(113, 63, 18, 0.2);
        border: 1px solid rgba(161, 98, 7, 0.5);
        border-radius: 0.5rem;
        max-width: 28rem;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
    }
    .gm-warning-text {
        color: #fef08a;
        font-size: 0.875rem;
    }
    .gm-warning-inline-icon {
        display: inline-block;
        width: 1rem;
        height: 1rem;
        margin-right: 0.25rem;
        margin-bottom: 0.25rem;
        vertical-align: middle;
    }
    .gm-warning-actions {
        margin-top: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
    }
    .gm-test-btn {
        padding: 0.25rem 0.75rem;
        background: #3f3f46;
        color: #fff;
        font-size: 0.75rem;
        border-radius: 0.25rem;
        border: none;
        cursor: pointer;
    }
    .gm-test-btn:hover {
        background: #52525b;
    }
    .gm-debug-log {
        font-size: 0.75rem;
        color: #71717a;
        font-family: ui-monospace, monospace;
    }
</style>
