---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/clicker";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/clicker/ClickerMechanic.ts";
---

<MechanicPage
    title="Clicker"
    description="El poder del crecimiento exponencial. Un click hoy, un imperio mañana."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/clicker.webp"
>
    <Icon slot="icon" name="mdi:cursor-default-click" class="cl-icon-gold" />

    <div class="cl-relative">
        <MechanicCanvas
            id="game-canvas"
            instruction="Haz Click"
            subInstruction="Genera monedas"
            verticalOnMobile={true}
        >
            <div class="cl-btn-wrap">
                <button
                    id="click-btn"
                    class="cl-main-btn"
                >
                    <Icon
                        name="mdi:cursor-default-click"
                        class="cl-main-btn-icon"
                    />
                </button>
            </div>

            <div class="cl-hud">
                <h2 class="cl-currency" id="currency-display">
                    0
                </h2>
                <p class="cl-currency-label">MONEDAS</p>
                <p class="cl-gps" id="gps-display">
                    0 por segundo
                </p>
            </div>
        </MechanicCanvas>
    </div>

    <div class="cl-shop">
        <h3 class="cl-shop-title">
            <Icon name="mdi:store" class="cl-shop-icon" />
            Tienda de Mejoras
        </h3>
        <div id="upgrades-list" class="cl-upgrades-grid"></div>
    </div>

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="cl-li">
                <span class="cl-bullet cl-bullet-blue">•</span>
                <span>Clics manuales generan recursos inmediatos.</span>
            </li>
            <li class="cl-li">
                <span class="cl-bullet cl-bullet-blue">•</span>
                <span>Inversión en automatización para crecimiento pasivo.</span>
            </li>
            <li class="cl-li">
                <span class="cl-bullet cl-bullet-blue">•</span>
                <span>Escalado exponencial de costes y producción.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="cl-control-box cl-control-box-wide">
                <span class="cl-label">Click / Tap</span>
                <span class="cl-desc">Generar Monedas</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { ClickerGame, formatNumber } from "../../../lib/mechanics/clicker/ClickerGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    const clickBtn = document.getElementById("click-btn");
    const currencyDisplay = document.getElementById("currency-display");
    const gpsDisplay = document.getElementById("gps-display");
    const upgradesList = document.getElementById("upgrades-list");

    let game: ClickerGame | null = null;

    if (canvas && overlay && clickBtn && currencyDisplay && gpsDisplay && upgradesList) {
        game = new ClickerGame(canvas);

        const start = () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
        };
        overlay.addEventListener("click", start);
        clickBtn.addEventListener("click", start);

        clickBtn.addEventListener("mousedown", () => {
            if (!game) return;

            const rect = canvas.getBoundingClientRect();

            const x = rect.width / 2;
            const y = rect.height / 2;

            game.click(x + (Math.random() - 0.5) * 50, y + (Math.random() - 0.5) * 50);

            updateUI();

            clickBtn.style.transform = "scale(0.90)";
            setTimeout(() => (clickBtn.style.transform = "scale(1)"), 50);
        });

        function initShop() {
            if (!game || !upgradesList) return;
            const state = game.state;
            upgradesList.innerHTML = "";

            state.upgrades.forEach((u) => {
                const btn = document.createElement("button");
                btn.id = `upgrade-btn-${u.id}`;
                btn.className = "cl-upgrade-btn";

                btn.innerHTML = `
                    <div class="cl-upgrade-header">
                        <span class="cl-upgrade-name">${u.name}</span>
                        <span class="cl-upgrade-count" id="upgrade-count-${u.id}">${u.count}</span>
                    </div>
                    <div class="cl-upgrade-footer">
                        <div class="cl-upgrade-power">
                            ${u.type === "click" ? "+" + u.power + " clic" : "+" + u.power + "/s"}
                        </div>
                        <div class="cl-upgrade-cost" id="upgrade-cost-${u.id}">
                            ${formatNumber(u.cost)} 💰
                        </div>
                    </div>
                `;

                btn.onclick = () => {
                    if (game && game.buyUpgrade(u.id)) {
                        updateUI();

                        btn.style.transform = "scale(0.98)";
                        setTimeout(() => (btn.style.transform = "scale(1)"), 50);
                    }
                };

                upgradesList.appendChild(btn);
            });
        }

        function updateUI() {
            if (!game) return;
            const state = game.state;

            if (currencyDisplay) currencyDisplay.innerText = formatNumber(state.currency);
            if (gpsDisplay)
                gpsDisplay.innerText = `${formatNumber(state.autoClickRate)} por segundo`;

            state.upgrades.forEach((u) => {
                const btn = document.getElementById(`upgrade-btn-${u.id}`);
                const countEl = document.getElementById(`upgrade-count-${u.id}`);
                const costEl = document.getElementById(`upgrade-cost-${u.id}`);

                if (!btn || !countEl || !costEl) return;

                const canAfford = state.currency >= u.cost;

                if (canAfford) {
                    btn.classList.remove("cl-upgrade-disabled");
                    btn.classList.add("cl-upgrade-affordable");
                    costEl.classList.remove("cl-cost-toomuch");
                    costEl.classList.add("cl-cost-ok");
                } else {
                    btn.classList.add("cl-upgrade-disabled");
                    btn.classList.remove("cl-upgrade-affordable");
                    costEl.classList.remove("cl-cost-ok");
                    costEl.classList.add("cl-cost-toomuch");
                }

                countEl.innerText = u.count.toString();
                costEl.innerText = `${formatNumber(u.cost)} 💰`;
            });
        }

        function uiLoop() {
            if (game && game.state.autoClickRate > 0) {
                updateUI();
            }
            requestAnimationFrame(uiLoop);
        }

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });

        window.addEventListener("beforeunload", () => {
            if (game) game.save();
        });

        initShop();
        updateUI();
        uiLoop();
    }
</script>

<style>
    .cl-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .cl-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .cl-bullet-blue { color: #60a5fa; }
    .cl-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .cl-control-box-wide {
        grid-column: span 2;
    }
    .cl-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .cl-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .cl-icon-gold { color: #fbbf24; }
    .cl-relative {
        position: relative;
    }
    .cl-btn-wrap {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 20;
        pointer-events: none;
    }
    .cl-main-btn {
        width: 12rem;
        height: 12rem;
        border-radius: 9999px;
        background: linear-gradient(135deg, #fbbf24, #d97706);
        box-shadow: 0 0 50px rgba(251, 191, 36, 0.3);
        transition: transform 0.075s;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: auto;
        cursor: pointer;
        border: none;
    }
    .cl-main-btn:active {
        transform: scale(0.95);
    }
    .cl-main-btn-icon {
        width: 6rem;
        height: 6rem;
        color: #fff;
        filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.3));
        transition: transform 0.3s;
    }
    .cl-main-btn:hover .cl-main-btn-icon {
        transform: scale(1.1);
    }
    .cl-hud {
        position: absolute;
        top: 2rem;
        left: 0;
        right: 0;
        text-align: center;
        z-index: 20;
        pointer-events: none;
    }
    .cl-currency {
        font-size: 2.25rem;
        font-weight: 900;
        color: #fbbf24;
        filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.3));
    }
    .cl-currency-label {
        color: rgba(255, 255, 255, 0.5);
        font-family: ui-monospace, monospace;
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }
    .cl-gps {
        color: rgba(251, 191, 36, 0.7);
        font-family: ui-monospace, monospace;
        font-size: 0.75rem;
        margin-top: 0.125rem;
    }
    .cl-shop {
        margin-top: 2rem;
    }
    .cl-shop-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .cl-shop-icon {
        color: #4ade80;
    }
    .cl-upgrades-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    @media (min-width: 768px) {
        .cl-upgrades-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    .cl-upgrade-btn {
        width: 100%;
        padding: 1rem;
        border-radius: 0.75rem;
        border: 1px solid #3f3f46;
        text-align: left;
        transition: all 0.3s;
        background: #27272a;
        color: inherit;
        cursor: pointer;
    }
    .cl-upgrade-btn:hover {
        background: #3f3f46;
    }
    .cl-upgrade-disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .cl-upgrade-affordable {
        cursor: pointer;
    }
    .cl-upgrade-affordable:hover {
        border-color: rgba(251, 191, 36, 0.5);
    }
    .cl-upgrade-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.25rem;
    }
    .cl-upgrade-name {
        font-weight: 700;
        color: #fff;
    }
    .cl-upgrade-count {
        font-family: ui-monospace, monospace;
        color: #fbbf24;
    }
    .cl-upgrade-footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }
    .cl-upgrade-power {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .cl-upgrade-cost {
        font-family: ui-monospace, monospace;
        font-size: 0.875rem;
    }
    .cl-cost-ok {
        color: #fbbf24;
    }
    .cl-cost-toomuch {
        color: #f87171;
    }
</style>
