---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const title = "Rhythm Jump";
const description =
    "Alterna tu color para sobrevivir. Cyan y Magenta son tus únicos aliados en este runner de precisión.";
const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/rhythm-jump";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/rhythm-jump/RhythmJumpMechanic.ts";
---

<MechanicPage
    title={title}
    description={description}
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/rhythm-jump.webp"
>
    <Icon slot="icon" name="mdi:palette-swatch" class="gm-icon-fuchsia" />

    <MechanicCanvas
        id="rhythm-jump-canvas"
        instruction="Click / Espacio"
        subInstruction="Cambiar Color / Saltar"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-fuchsia">•</span>
                <span>Solo puedes tocar plataformas de tu mismo color.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-cyan">•</span>
                <span>Alterna entre Cyan y Magenta instantáneamente.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-fuchsia">•</span>
                <span>Gestos táctiles: Swipe para saltar, Tap para cambiar.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box">
                <span class="gm-label">Click / Tap</span>
                <span class="gm-desc">Cambiar Color</span>
            </div>
            <div class="gm-control-box">
                <span class="gm-label">Espacio / Swipe Up</span>
                <span class="gm-desc">Saltar</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { RhythmJumpGame } from "../../../lib/mechanics/rhythm-jump/RhythmJumpGame";

    const canvas = document.getElementById("rhythm-jump-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("rhythm-jump-canvas-overlay");
    let game: RhythmJumpGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new RhythmJumpGame(canvas);
                game.start();
            }
        });

        document.addEventListener(
            "astro:before-swap",
            () => {
                game?.stop();
            },
            { once: true }
        );
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-fuchsia { color: #d946ef; }
    .gm-bullet-cyan { color: #22d3ee; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-fuchsia { color: #d946ef; }
</style>
