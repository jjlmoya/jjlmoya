---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE =
    "https://github.com/jjlmoya/jjlmoya/tree/main/src/pages/gamebob/mecanicas/echolocation.astro";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/pages/gamebob/mecanicas/echolocation.astro";
---

<MechanicPage
    title="Ecolocalización"
    description="Navega en la oscuridad absoluta. Usa el sonido para revelar tu entorno y encontrar la salida."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/echolocation.webp"
>
    <Icon slot="icon" name="mdi:radar" class="gm-icon-emerald" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Usa las Flechas para Moverte"
        subInstruction="Haz ruido para ver"
        verticalOnMobile={false}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Juego de plataformas en oscuridad total.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>El sonido rebota en las superficies revelando su posición.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Saltar, aterrizar y chocar genera ondas de sonido.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box">
                <span class="gm-label">Flechas / WASD</span>
                <span class="gm-desc">Moverse y Saltar</span>
            </div>
            <div class="gm-control-box">
                <span class="gm-label">Z / Enter</span>
                <span class="gm-desc">Gritar (Sonar)</span>
            </div>
        </Fragment>
    </MechanicInfo>

    <div id="winMessage" class="gm-win-overlay">
        <div class="gm-win-content">
            <h2 class="gm-win-title">¡Salida Encontrada!</h2>
            <button id="restartBtn" class="gm-win-btn">
                Jugar de nuevo
            </button>
        </div>
    </div>
</MechanicPage>

<script>
    import { EcholocationGame } from "../../../lib/mechanics/echolocation/EcholocationGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: EcholocationGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new EcholocationGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-blue { color: #60a5fa; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-emerald { color: #34d399; }
    .gm-win-overlay {
        display: none;
        position: absolute;
        inset: 0;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.8);
        z-index: 50;
        pointer-events: none;
    }
    .gm-win-content {
        text-align: center;
        pointer-events: auto;
    }
    .gm-win-title {
        font-size: 2.25rem;
        font-weight: 700;
        color: #34d399;
        margin-bottom: 1rem;
    }
    .gm-win-btn {
        padding: 0.75rem 1.5rem;
        background: #fff;
        color: #000;
        border-radius: 9999px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: transform 0.3s;
    }
    .gm-win-btn:hover {
        transform: scale(1.05);
    }
</style>
