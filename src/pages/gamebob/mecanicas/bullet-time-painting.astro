---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE =
    "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/bullet-time-painting";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/bullet-time-painting/BulletTimeGame.ts";
---

<MechanicPage
    title="Bullet-Time Painting"
    description="Planifica tus tácticas y disparos en tiempo pausado. Ejecútalo en ráfagas de 1 segundo de acción pura."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/bullet-time-painting.webp"
>
    <Icon slot="icon" name="mdi:strategy" class="btp-icon-main" />

    <div class="btp-section">
        <div class="btp-card">
            <div class="btp-header">
                <div class="btp-header-left">
                    <span class="btp-sector-label">Tactical Sector</span>
                    <div class="btp-sector-row">
                        <h2 id="sector-display" class="btp-sector-display">
                            Sector 001
                        </h2>
                        <div id="status-dot" class="btp-status-dot"></div>
                    </div>
                </div>

                <div class="btp-stats">
                    <div class="btp-stat-group">
                        <div class="btp-stat-header">
                            <span class="btp-stat-label btp-label-rose">Integridad</span>
                            <div id="hp-segments" class="btp-hp-segments">
                                <div class="btp-hp-seg"></div>
                                <div class="btp-hp-seg"></div>
                                <div class="btp-hp-seg"></div>
                            </div>
                        </div>
                        <div class="btp-bar-track">
                            <div id="hp-bar-fill" class="btp-bar-hp"></div>
                        </div>
                    </div>

                    <div class="btp-stat-group">
                        <div class="btp-stat-header">
                            <span class="btp-stat-label btp-label-green">Energía</span>
                            <span id="energy-percent" class="btp-energy-pct">100%</span>
                        </div>
                        <div class="btp-bar-track">
                            <div id="energy-bar-fill" class="btp-bar-energy"></div>
                        </div>
                    </div>
                </div>

                <div class="btp-header-right">
                    <div class="btp-sysinfo">
                        <span class="btp-syslabel">Estado Sistema</span>
                        <div id="phase-display" class="btp-phase-display">Ready_Control</div>
                    </div>
                    <div class="btp-legend">
                        <div class="btp-legend-item">
                            <div class="btp-dot-green"></div>
                            <span class="btp-legend-text">Alpha</span>
                        </div>
                        <div class="btp-legend-item">
                            <div class="btp-dot-rose"></div>
                            <span class="btp-legend-text">Hostil</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="btp-canvas-wrap">
                <MechanicCanvas
                    id="game-canvas"
                    instruction=""
                    subInstruction=""
                    verticalOnMobile={true}
                />
                <div class="btp-scanlines"></div>
                <div class="btp-vignette"></div>
            </div>
        </div>
    </div>

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="btp-li">
                <span class="btp-bullet">•</span>
                <span>Progresión por sectores: cada nivel es un nuevo desafío generado proceduralmente.</span>
            </li>
            <li class="btp-li">
                <span class="btp-bullet">•</span>
                <span>Pool de energía fijo: gestiona tus movimientos y disparos con inteligencia en cada turno.</span>
            </li>
            <li class="btp-li">
                <span class="btp-bullet">•</span>
                <span>Integridad del casco: dispones de un sistema de HP que se restaura al limpiar cada sector.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="btp-controls-col">
                <div class="btp-ctrl-card btp-ctrl-green">
                    <div class="btp-ctrl-body">
                        <span class="btp-ctrl-title">Click Izquierdo</span>
                        <span class="btp-ctrl-sub btp-sub-green">Moverse</span>
                    </div>
                    <div class="btp-ctrl-icon-box btp-ib-green">
                        <Icon name="mdi:mouse-left-click" class="btp-ctrl-icon btp-ci-green" />
                    </div>
                </div>

                <div class="btp-ctrl-card btp-ctrl-rose">
                    <div class="btp-ctrl-body">
                        <span class="btp-ctrl-title">Click Derecho</span>
                        <span class="btp-ctrl-sub btp-sub-rose">Disparar</span>
                    </div>
                    <div class="btp-ctrl-icon-box btp-ib-rose">
                        <Icon name="mdi:mouse-right-click" class="btp-ctrl-icon btp-ci-rose" />
                    </div>
                </div>

                <div class="btp-ctrl-card btp-ctrl-accent">
                    <div class="btp-ctrl-body">
                        <span class="btp-ctrl-title btp-title-accent">Espacio</span>
                        <span class="btp-ctrl-sub btp-sub-accent">Ejecutar</span>
                    </div>
                    <div class="btp-ctrl-icon-box btp-ib-accent">
                        <Icon name="mdi:keyboard-space" class="btp-ci-space" />
                    </div>
                </div>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<style is:global>
    .canvas-wrapper {
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
        aspect-ratio: 1600 / 1200;
        background: #000;
    }
    #game-canvas {
        width: 100% !important;
        height: 100% !important;
        display: block;
        image-rendering: crisp-edges;
        cursor: crosshair;
        object-fit: contain;
    }
</style>

<style>
    .btp-icon-main { color: #00ffd2; }
    .btp-section {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1.5rem;
    }
    .btp-section > * + * {
        margin-top: 3rem;
    }
    .btp-card {
        position: relative;
        background: #050505;
        border-radius: 3rem;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 50px 100px -30px rgba(0, 0, 0, 0.9);
    }
    .btp-header {
        display: grid;
        grid-template-columns: 1fr;
        align-items: center;
        padding: 3rem 4rem;
        background: rgba(24, 24, 27, 0.8);
        backdrop-filter: blur(64px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        gap: 3rem;
    }
    @media (min-width: 768px) {
        .btp-header {
            grid-template-columns: repeat(3, 1fr);
        }
    }
    .btp-header-left {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .btp-sector-label {
        font-size: 0.65rem;
        font-weight: 900;
        color: rgba(0, 255, 210, 0.5);
        text-transform: uppercase;
        letter-spacing: 0.5em;
    }
    .btp-sector-row {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }
    .btp-sector-display {
        font-size: 3rem;
        font-weight: 900;
        color: #fff;
        font-style: italic;
        letter-spacing: -0.025em;
    }
    .btp-status-dot {
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 9999px;
        background: #00ffd2;
        animation: btp-pulse 2s infinite;
        box-shadow: 0 0 20px #00ffd2;
    }
    @keyframes btp-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
    .btp-stats {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    .btp-stat-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .btp-stat-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }
    .btp-stat-label {
        font-size: 0.7rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
    }
    .btp-label-rose { color: rgba(244, 63, 94, 0.8); }
    .btp-label-green { color: rgba(0, 255, 210, 0.8); }
    .btp-hp-segments {
        display: flex;
        gap: 0.5rem;
    }
    .btp-hp-seg {
        width: 1rem;
        height: 1rem;
        border-radius: 2px;
        background: #f43f5e;
        box-shadow: 0 0 15px rgba(244, 63, 94, 0.5);
    }
    .btp-bar-track {
        height: 0.5rem;
        background: rgba(24, 24, 27, 0.5);
        border-radius: 9999px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .btp-bar-hp {
        height: 100%;
        background: #f43f5e;
        border-radius: 9999px;
        transition: width 1s;
        box-shadow: 0 0 20px rgba(244, 63, 94, 0.4);
        width: 100%;
    }
    .btp-bar-energy {
        height: 100%;
        background: #00ffd2;
        border-radius: 9999px;
        transition: width 0.5s;
        box-shadow: 0 0 20px rgba(0, 255, 210, 0.4);
    }
    .btp-energy-pct {
        font-size: 0.875rem;
        font-weight: 900;
        color: #00ffd2;
        font-variant-numeric: tabular-nums;
    }
    .btp-header-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 1rem;
    }
    .btp-sysinfo {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
    }
    .btp-syslabel {
        font-size: 0.6rem;
        font-weight: 900;
        color: #52525b;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .btp-phase-display {
        font-size: 0.75rem;
        font-weight: 900;
        color: #f4f4f5;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        background: rgba(255, 255, 255, 0.05);
        padding: 0.5rem 1.5rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        font-style: italic;
    }
    .btp-legend {
        display: flex;
        gap: 1.5rem;
    }
    .btp-legend-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .btp-dot-green {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background: #00ffd2;
        box-shadow: 0 0 10px #00ffd2;
    }
    .btp-dot-rose {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background: #f43f5e;
        box-shadow: 0 0 10px #f43f5e;
    }
    .btp-legend-text {
        font-size: 0.6rem;
        color: #71717a;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .btp-canvas-wrap {
        position: relative;
        background: #000;
    }
    .btp-scanlines {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.2) 50%),
                    linear-gradient(90deg, rgba(255, 0, 0, 0.015), rgba(0, 255, 0, 0.01), rgba(0, 255, 210, 0.015));
        background-size: 100% 4px, 3px 100%;
        z-index: 10;
        opacity: 0.4;
    }
    .btp-vignette {
        position: absolute;
        inset: 0;
        pointer-events: none;
        box-shadow: inset 0 0 150px rgba(0, 0, 0, 0.9);
        z-index: 20;
    }
    .btp-li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
    }
    .btp-bullet {
        color: #00ffd2;
        margin-top: 0.375rem;
        flex-shrink: 0;
    }
    .btp-controls-col {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        grid-column: span 2;
    }
    .btp-ctrl-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem;
        border-radius: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.5s;
        width: 100%;
    }
    .btp-ctrl-green {
        background: rgba(9, 9, 11, 0.4);
    }
    .btp-ctrl-green:hover {
        border-color: rgba(0, 255, 210, 0.3);
        box-shadow: 0 0 30px rgba(0, 255, 210, 0.05);
    }
    .btp-ctrl-rose {
        background: rgba(9, 9, 11, 0.4);
    }
    .btp-ctrl-rose:hover {
        border-color: rgba(244, 63, 94, 0.3);
        box-shadow: 0 0 30px rgba(244, 63, 94, 0.05);
    }
    .btp-ctrl-accent {
        background: rgba(0, 255, 210, 0.05);
        border-color: rgba(0, 255, 210, 0.2);
    }
    .btp-ctrl-accent:hover {
        border-color: rgba(0, 255, 210, 0.5);
        box-shadow: 0 0 30px rgba(0, 255, 210, 0.15);
    }
    .btp-ctrl-body {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
    }
    .btp-ctrl-title {
        color: #fff;
        font-weight: 900;
        text-transform: uppercase;
        font-size: 0.625rem;
        letter-spacing: 0.2em;
    }
    .btp-title-accent {
        color: #00ffd2;
    }
    .btp-ctrl-sub {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.7;
        font-style: italic;
        transition: opacity 0.3s;
    }
    .btp-ctrl-card:hover .btp-ctrl-sub {
        opacity: 1;
    }
    .btp-sub-green { color: #00ffd2; }
    .btp-sub-rose { color: #f43f5e; }
    .btp-sub-accent { color: #00ffd2; }
    .btp-ctrl-icon-box {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 3rem;
        height: 3rem;
        border-radius: 0.75rem;
        transition: all 0.3s;
    }
    .btp-ctrl-card:hover .btp-ctrl-icon-box {
        transform: scale(1.1);
    }
    .btp-ib-green {
        background: rgba(0, 255, 210, 0.05);
        border: 1px solid rgba(0, 255, 210, 0.1);
    }
    .btp-ctrl-card:hover .btp-ib-green {
        background: rgba(0, 255, 210, 0.1);
    }
    .btp-ib-rose {
        background: rgba(244, 63, 94, 0.05);
        border: 1px solid rgba(244, 63, 94, 0.1);
    }
    .btp-ctrl-card:hover .btp-ib-rose {
        background: rgba(244, 63, 94, 0.1);
    }
    .btp-ib-accent {
        background: #00ffd2;
        box-shadow: 0 0 20px rgba(0, 255, 210, 0.4);
    }
    .btp-ctrl-icon {
        width: 1.5rem;
        height: 1.5rem;
    }
    .btp-ci-green { color: #00ffd2; }
    .btp-ci-rose { color: #f43f5e; }
    .btp-ci-space {
        width: 1.5rem;
        height: 1.5rem;
        color: #000;
    }
</style>

<script>
    import { BulletTimeGame } from "../../../lib/mechanics/bullet-time-painting/BulletTimeGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");

    const sectorDisplay = document.getElementById("sector-display");
    const energyBarFill = document.getElementById("energy-bar-fill");
    const energyPercent = document.getElementById("energy-percent");
    const hpBarFill = document.getElementById("hp-bar-fill");
    const hpSegments = document.getElementById("hp-segments");
    const phaseDisplay = document.getElementById("phase-display");
    const statusDot = document.getElementById("status-dot");

    let game: BulletTimeGame | null = null;

    if (canvas && overlay) {
        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";

            if (!game) {
                game = new BulletTimeGame(canvas);
                game.start();
                updateUI();
            }
        });

        window.addEventListener("resize", () => {
            game?.resize();
        });

        window.addEventListener("keydown", (e) => {
            if (e.code === "Space") {
                game?.playAction();
                e.preventDefault();
            }
        });

        function updateUI() {
            if (game) {
                const state = (game as any).state;
                if (state) {
                    if (sectorDisplay)
                        sectorDisplay.textContent = `Sector ${state.level.toString().padStart(3, "0")}`;
                    if (energyBarFill) energyBarFill.style.width = `${state.energy}%`;
                    if (energyPercent) energyPercent.textContent = `${Math.round(state.energy)}%`;
                    if (hpBarFill) hpBarFill.style.width = `${(state.hp / state.maxHp) * 100}%`;

                    if (hpSegments) {
                        const segments = hpSegments.children;
                        for (let i = 0; i < segments.length; i++) {
                            const seg = segments[i] as HTMLElement;
                            if (i < state.hp) {
                                seg.style.opacity = "1";
                            } else {
                                seg.style.opacity = "0.1";
                            }
                        }
                    }

                    if (phaseDisplay) {
                        phaseDisplay.textContent = state.isExecutionPhase
                            ? "Tactical_Blitz"
                            : "Planning_Routine";
                        phaseDisplay.style.color = state.isExecutionPhase ? "#00ffd2" : "#ffffff";
                    }
                    if (statusDot) {
                        statusDot.style.backgroundColor = state.isExecutionPhase
                            ? "#f43f5e"
                            : "#00ffd2";
                    }
                }
            }
            requestAnimationFrame(updateUI);
        }
    }
</script>
