---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/gravity-flip";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/gravity-flip/GravityFlipMechanic.ts";
---

<MechanicPage
    title="Gravity Flip"
    description="El suelo es el techo. Invierte la gravedad para esquivar obstáculos en este runner psicodélico."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/gravity-flip.webp"
>
    <Icon slot="icon" name="mdi:flip-vertical" class="gm-icon-cyan" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Toca / Espacio"
        subInstruction="Invertir Gravedad"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-cyan">•</span>
                <span>Inversión instantánea del vector de gravedad (g → -g).</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-cyan">•</span>
                <span>Generación procedural de obstáculos (pinchos y bloques).</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-cyan">•</span>
                <span>Detección de colisiones AABB (Axis-Aligned Bounding Box).</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Tap / Space</span>
                <span class="gm-desc">Cambiar Gravedad</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { GravityFlipGame } from "../../../lib/mechanics/gravity-flip/GravityFlipGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: GravityFlipGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new GravityFlipGame(canvas);
            }
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-cyan { color: #22d3ee; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-wide {
        grid-column: span 2;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-cyan { color: #22d3ee; }
</style>
