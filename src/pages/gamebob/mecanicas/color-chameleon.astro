---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE =
    "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/color-chameleon";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/color-chameleon/ColorChameleonGame.js";
---

<MechanicPage
    title="Color Chameleon"
    description="Camuflaje reactivo. Cambia tu color para absorber a los enemigos del mismo color."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/color-chameleon.webp"
>
    <Icon slot="icon" name="mdi:palette" class="gm-icon-green" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Click/Tap para cambiar de color"
        subInstruction="Absorbe enemigos de tu mismo color. ¡Evita los diferentes!"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-green">•</span>
                <span>Enemigos de colores se acercan al centro.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-green">•</span>
                <span>Debes coincidir con el color del enemigo para absorberlo.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-green">•</span>
                <span>Si te toca un color diferente, pierdes.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-full">
                <span class="gm-label">Click / Tap</span>
                <span class="gm-desc">Ciclar Color (Rojo -&gt; Verde -&gt; Azul)</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { ColorChameleonGame } from "../../../lib/mechanics/color-chameleon/ColorChameleonGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");

    let game: ColorChameleonGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new ColorChameleonGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-green { color: #4ade80; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-full {
        width: 100%;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-green { color: #4ade80; }
</style>
