---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE = "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/size-matters";
const CODE_URL =
    "https://github.com/jjlmoya/jjmloya/blob/main/src/lib/mechanics/size-matters/SizeMattersGame.js";
---

<MechanicPage
    title="Size Matters"
    description="El tamaño importa. Crece para romper, encoge para flotar."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/size-matters.webp"
>
    <Icon slot="icon" name="mdi:arrow-expand-all" class="gm-icon-yellow" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Mantén para Crecer"
        subInstruction="Suelta para Encoger"
        verticalOnMobile={true}
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Mantén pulsado para <strong>CRECER</strong>: rompes bloques rojos, pero caes rápido.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Suelta para <strong>ENCOGER</strong>: flotas y pasas por huecos azules.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-blue">•</span>
                <span>Física de masa variable y gravedad dinámica.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box gm-control-box-wide">
                <span class="gm-label">Click / Tap (Mantener)</span>
                <span class="gm-desc">Crecer / Aumentar Masa</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { SizeMattersGame } from "../../../lib/mechanics/size-matters/SizeMattersGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: SizeMattersGame | null = null;

    if (canvas && overlay) {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;

        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new SizeMattersGame(canvas);
            }
        });

        window.addEventListener("resize", () => {
            if (game) game.resize();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-blue { color: #60a5fa; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-control-box-wide {
        grid-column: span 2;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-yellow { color: #fbbf24; }
</style>
