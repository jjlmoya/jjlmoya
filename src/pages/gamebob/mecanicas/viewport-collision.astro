---
export const prerender = true;
import MechanicPage from "../../../components/gamebob/mechanics/MechanicPage.astro";
import MechanicCanvas from "../../../components/gamebob/mechanics/MechanicCanvas.astro";
import MechanicInfo from "../../../components/gamebob/mechanics/MechanicInfo.astro";
import { Icon } from "astro-icon/components";

const GITHUB_BASE =
    "https://github.com/jjlmoya/jjlmoya/tree/main/src/lib/mechanics/viewport-collision";
const CODE_URL =
    "https://github.com/jjlmoya/jjlmoya/blob/main/src/lib/mechanics/viewport-collision/ViewportCollisionGame.ts";
---

<MechanicPage
    title="Viewport Edge Collision"
    description="Colisión dinámica. Redimensiona la ventana para golpear objetos y aumentar la presión."
    githubUrl={GITHUB_BASE}
    codeUrl={CODE_URL}
    image="/images/gamebob/mechanics/viewport-collision.webp"
>
    <Icon slot="icon" name="mdi:arrow-expand-all" class="gm-icon-amber" />

    <MechanicCanvas
        id="game-canvas"
        instruction="Redimensiona tu navegador"
        subInstruction="¡Aplasta los objetos con los bordes!"
        aspectRatio="video"
    />

    <MechanicInfo>
        <Fragment slot="how-it-works">
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-amber">•</span>
                <span>Los bordes del canvas actúan como paredes físicas rígidas.</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-amber">•</span>
                <span>Al redimensionar la ventana, las paredes ganan velocidad ('momentum').</span>
            </li>
            <li class="gm-li">
                <span class="gm-bullet gm-bullet-amber">•</span>
                <span>La energía cinética de la ventana se transfiere a las partículas al colisionar.</span>
            </li>
        </Fragment>

        <Fragment slot="controls">
            <div class="gm-control-box">
                <span class="gm-label">Redimensionar Ventana</span>
                <span class="gm-desc">Aplasta y Destruye</span>
            </div>
            <div class="gm-control-box">
                <span class="gm-label">Solo Escritorio</span>
                <span class="gm-desc">Mejor experiencia</span>
            </div>
        </Fragment>
    </MechanicInfo>
</MechanicPage>

<script>
    import { ViewportCollisionGame } from "../../../lib/mechanics/viewport-collision/ViewportCollisionGame";

    const canvas = document.getElementById("game-canvas") as HTMLCanvasElement;
    const overlay = document.getElementById("game-canvas-overlay");
    let game: ViewportCollisionGame | null = null;

    if (canvas && overlay) {
        overlay.addEventListener("click", () => {
            overlay.style.opacity = "0";
            overlay.style.pointerEvents = "none";
            if (!game) {
                game = new ViewportCollisionGame(canvas);
            }
        });

        document.addEventListener("astro:before-swap", () => {
            if (game) game.dispose();
        });
    }
</script>

<style>
    .gm-li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .gm-bullet {
        margin-top: 0.25rem;
        flex-shrink: 0;
    }
    .gm-bullet-amber { color: #f59e0b; }
    .gm-control-box {
        background: #27272a;
        padding: 0.75rem;
        border-radius: 0.5rem;
        text-align: center;
    }
    .gm-label {
        display: block;
        color: #fff;
        font-weight: 700;
    }
    .gm-desc {
        font-size: 0.75rem;
        color: #a1a1aa;
    }
    .gm-icon-amber { color: #f59e0b; }
</style>
