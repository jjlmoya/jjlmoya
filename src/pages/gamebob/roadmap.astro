---
export const prerender = true;
import GameBobLayout from "../../layouts/GameBobLayout.astro";
import RoadmapHeader from "../../components/gamebob/roadmap/RoadmapHeader.astro";
import ProjectCard from "../../components/gamebob/roadmap/ProjectCard.astro";
import { ALL_APP_DEFINITIONS, type KnownLocale } from "@jjlmoya/apps";

const DEFAULT_THEMES: Record<string, string> = {
    "sauce-lab": "#FF4D4D",
    "fortune-cookie": "#FFD700",
    "lexi-crash": "#4D94FF",
    "pizzametrics": "#FFA500",
    "vesp": "#00FF9F",
    "day-check": "#B185FF",
    "fast-task": "#00E5FF",
};

const roadmapApps = await Promise.all(
    ALL_APP_DEFINITIONS
        .map(async ({ entry }) => {
            const loader = entry.i18n["es" as KnownLocale] ?? entry.i18n.en;
            const card = await loader!();
            return {
                name: card.title,
                description: card.description,
                homeDescription: card.subtitle,
                image: `/assets/apps/${entry.id}/hero.webp`,
                statusLabel: "publicado" as const,
                statusType: "released" as const,
                progress: 100,
                color: DEFAULT_THEMES[entry.id] || "#1ddabc",
                links: {
                    googlePlay: entry.stores.googlePlay,
                    appStore: entry.stores.appStore,
                },
                tasks: [],
            };
        })
);
---

<GameBobLayout
    title="Roadmap: ¿En qué estoy invirtiendo el tiempo ahora mismo?"
    description="Próximos lanzamientos, actualizaciones de juegos y planes futuros. Transparencia total sobre lo que estoy construyendo."
    image="/images/gamebob/roadmap/index.webp"
>
    <div class="gr-page">
        <div class="gr-container">
            <RoadmapHeader
                title="roadmap"
                description="Transparencia total sobre lo que estoy construyendo y lo que vendrá después."
            />

            <div class="gr-grid">
                {roadmapApps.map((app) => <ProjectCard project={app} />)}
            </div>
        </div>
    </div>
</GameBobLayout>

<style>
    .gr-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 3rem 1rem;
    }
    .gr-container {
        z-index: 10;
        width: 100%;
        max-width: 64rem;
        margin-top: 2rem;
    }
    .gr-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    @media (min-width: 1024px) {
        .gr-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
