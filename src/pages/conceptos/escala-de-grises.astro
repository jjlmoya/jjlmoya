---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import NuanceController from "../../components/conceptos/escala-de-grises/NuanceController.astro";
import NuanceConceptSlide from "../../components/conceptos/escala-de-grises/core/NuanceConceptSlide.astro";
import IntroSlide from "../../components/conceptos/escala-de-grises/slides/IntroSlide.astro";
import OutroSlide from "../../components/conceptos/escala-de-grises/slides/OutroSlide.astro";
import { NUANCE_SLIDES } from "../../data/conceptos/nuance-slides";
---

<Layout
    title="Escala de grises: ¿Todo es blanco o negro?"
    description="Vivimos aplastados por los extremos. Una exploración interactiva sobre cómo la polarización está matando el pensamiento crítico."
    image="/images/concepts/nuance_og.webp"
    fullWidth={true}
>
    <NuanceController>
        <IntroSlide />
        {
            NUANCE_SLIDES.map((slide) => (
                <NuanceConceptSlide {...slide} />
            ))
        }
        <OutroSlide />
    </NuanceController>
</Layout>
