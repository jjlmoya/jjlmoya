---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SplitScreen from "../components/pages/home/SplitScreen.astro";
import { getStaticPageAlternates } from "../i18n/gamebob";
import "./index.css";

const alternateUrls = getStaticPageAlternates("/");
---

<Layout
    title="Mi Portfolio de Creación Digital: Apps, Utilidades y Juegos"
    description="Del software de utilidad a la pantalla de juego. Descubre mis proyectos, mis herramientas y cómo gestiono mi estudio de desarrollo indie."
    showBackground={false}
    mainClass="home-page-main"
    headerClass="home-page-header-hidden"
    footerClass="home-page-footer-hidden"
    image="/favicon-brand.webp"
    alternateUrls={alternateUrls}
>
    <SplitScreen />
</Layout>
