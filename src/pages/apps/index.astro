---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import { ALL_APP_DEFINITIONS } from "@jjlmoya/apps";
import type { KnownLocale } from "@jjlmoya/apps";
import { Icon } from "astro-icon/components";
import { getStaticPageAlternates } from "../../i18n/gamebob";
import "./index.css";

const alternateUrls = getStaticPageAlternates("/apps");

const appCards = await Promise.all(
    ALL_APP_DEFINITIONS.map(async ({ entry }) => {
        const loader = entry.i18n['es' as KnownLocale] ?? entry.i18n.en;
        const card = await loader!();
        return { entry, card };
    })
);

const DEFAULT_THEMES: Record<string, any> = {
    "sauce-lab": { primary: "#FF4D4D", bgSurface: "#1a0f0f" },
    "fortune-cookie": { primary: "#FFD700", bgSurface: "#1a1a0f" },
    "lexi-crash": { primary: "#4D94FF", bgSurface: "#0f141a" },
    "pizzametrics": { primary: "#FFA500", bgSurface: "#1a140f" },
    "vesp": { primary: "#00FF9F", bgSurface: "#0f1a16" },
    "day-check": { primary: "#B185FF", bgSurface: "#140f1a" },
    "fast-task": { primary: "#00E5FF", bgSurface: "#0f1a1a" },
};
---

<Layout title="Apps | jjlmoya" description="Herramientas diseñadas para la precisión y la pasión." alternateUrls={alternateUrls}>
    <div class="apps-page">
        <header class="apps-header">
            <div class="apps-header-container">
                <div class="apps-header-layout">
                    <h1 class="apps-title">
                        Aplicaciones
                    </h1>
                    <div class="apps-subtitle-container">
                        <p class="apps-subtitle">
                            Herramientas y utilidades personales provenientes de la librería oficial.
                        </p>
                    </div>
                </div>
            </div>
        </header>

        <section class="apps-section">
            <div class="apps-list">
                {
                    appCards.map(({ entry, card }, index) => {
                        const theme = DEFAULT_THEMES[entry.id] || { primary: "#555", bgSurface: "#111" };
                        const heroImage = `/assets/apps/${entry.id}/hero.webp`;
                        
                        return (
                            <div
                                class="app-entry"
                                style={`
                                    --app-primary: ${theme.primary};
                                    --app-bg: #000;
                                    --app-surface: ${theme.bgSurface};
                                    --app-text: #fff;
                                    --app-glow: ${theme.primary};
                                    color: var(--app-text);
                                `}
                            >
                                <div class="app-entry-overlay" />
                                <div class="app-entry-glow" />

                                <div class={`app-image-wrapper ${index % 2 !== 0 ? "order-odd" : ""}`}>
                                    <div class="app-image-container">
                                        <div class="app-image-hover-overlay" />
                                        <img
                                            src={heroImage}
                                            alt=""
                                            class="app-image"
                                        />
                                        <div class="app-image-darken" />
                                    </div>
                                    <a href={`/apps/${card.slug}/`} class="app-link-overlay" />
                                </div>

                                <div class={`app-content-wrapper ${index % 2 !== 0 ? "order-odd" : ""}`}>
                                    <div class="app-meta">
                                        <span class="app-badge">
                                            {entry.isGame ? "Juego" : "Utilidad"}
                                        </span>
                                        <div class="app-meta-separator" />
                                        <span class="app-meta-index">
                                            0{index + 1}
                                        </span>
                                    </div>

                                    <a href={`/apps/${card.slug}/`} class="app-title-link">
                                        <h2 class="app-card-title">
                                            {card.title}
                                        </h2>
                                    </a>

                                    <p class="app-card-subtitle">
                                        {card.subtitle}
                                    </p>

                                    <div class="app-actions">
                                        <a
                                            href={`/apps/${card.slug}/`}
                                            class="app-btn-explore"
                                        >
                                            <span>Explorar</span>
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                width="16"
                                                height="16"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="3"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="app-btn-explore-icon"
                                            >
                                                <path d="M5 12h14" />
                                                <path d="m12 5 7 7-7 7" />
                                            </svg>
                                        </a>

                                        <div class="app-actions-separator" />

                                        <div class="app-stores">
                                            {entry.stores.googlePlay ? (
                                                <a
                                                    href={entry.stores.googlePlay}
                                                    target="_blank"
                                                    class="app-store-link"
                                                    title="Disponible en Google Play"
                                                >
                                                    <Icon
                                                        name="mdi:google-play"
                                                        class="app-store-icon"
                                                    />
                                                </a>
                                            ) : (
                                                <div
                                                    class="app-store-disabled"
                                                    title="Próximamente"
                                                >
                                                    <Icon
                                                        name="mdi:google-play"
                                                        class="app-store-icon"
                                                    />
                                                </div>
                                            )}

                                            {entry.stores.appStore ? (
                                                <a
                                                    href={entry.stores.appStore}
                                                    target="_blank"
                                                    class="app-store-link"
                                                    title="Disponible en App Store"
                                                >
                                                    <Icon
                                                        name="mdi:apple"
                                                        class="app-store-icon"
                                                    />
                                                </a>
                                            ) : (
                                                <div
                                                    class="app-store-disabled"
                                                    title="Próximamente"
                                                >
                                                    <Icon
                                                        name="mdi:apple"
                                                        class="app-store-icon"
                                                    />
                                                </div>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        );
                    })
                }
            </div>
        </section>

        <footer class="apps-footer">
            <div class="apps-footer-container">
                <p class="apps-footer-text">
                    Diseño apps que <span class="apps-footer-text-italic">respetan</span> tu tiempo y tu inteligencia.
                </p>
            </div>
            <div class="apps-footer-grid" />
        </footer>
    </div>
</Layout>
