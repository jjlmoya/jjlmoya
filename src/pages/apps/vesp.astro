---
export const prerender = true;
import AppLayout from "../../layouts/AppLayout.astro";
import { vesp as app } from "../../data/apps/vesp";
import { Icon } from "astro-icon/components";

const title = `${app.title} — ${app.subtitle}`;
---

<AppLayout
    title={title}
    description={app.description}
    image={app.media.icon}
    color={app.theme.primary}
    favicon={app.media.icon}
    currentSlug={app.slug}
>
    <div
        class="min-h-screen bg-[#000415] text-[#f1f5f9] font-main selection:bg-[#DAA520] selection:text-black pt-16"
        style={`--primary: #DAA520; --accent: hsl(160, 85%, 40%); --bg-app: #000415; --font-heading: 'Marcellus', serif;`}
    >
        <section class="max-w-7xl mx-auto px-6 pt-32 pb-24 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="flex flex-col items-start text-left order-2 lg:order-1">
                 <div class="mb-10 block">
                    <img
                        src={app.media.icon}
                        alt={app.title}
                        class="w-20 h-20 rounded-2xl shadow-xl border border-white/5"
                    />
                </div>
                
                <h1 class="font-heading text-7xl md:text-[9rem] uppercase tracking-tighter mb-6 leading-none text-white opacity-90">
                    VESP
                </h1>
                
                <p class="font-heading text-xl md:text-2xl tracking-[0.3em] text-[#DAA520] uppercase italic mb-10 opacity-80 leading-snug">
                    {app.subtitle}
                </p>

                <div class="max-w-md mb-12">
                    <p class="text-white/40 leading-relaxed font-light text-lg">
                        {app.philosophy}
                    </p>
                </div>
                
                <div class="flex flex-col items-start gap-4">
                     <span class="text-5xl font-heading text-white">{app.price}</span>
                     <span class="text-[10px] uppercase tracking-[0.5em] text-white/30 font-bold">Sin suscripciones • Acceso Inmediato</span>
                </div>
            </div>

            <div class="order-1 lg:order-2 flex justify-center">
                <div class="w-full max-w-[340px] relative">
                    <div class="absolute inset-x-0 -bottom-10 h-20 bg-[#DAA520]/20 blur-[60px] rounded-full opacity-30"></div>
                    <div class="relative rounded-[3rem] overflow-hidden border border-white/10 shadow-huge bg-black/40 aspect-[9/19.5]">
                        <img 
                            src={app.media.hero} 
                            alt="VESP Interface Hero" 
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
            </div>
        </section>

        <section class="py-40 px-6 border-y border-white/5 bg-white/[0.01]">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-24 items-center">
                <div class="space-y-12">
                    <span
                        class="text-[#DAA520] text-xs font-bold uppercase tracking-[0.6em] border-b border-[#DAA520]/30 pb-2 inline-block"
                        >Mixología de Precisión</span
                    >
                    <h2
                        class="font-heading text-5xl md:text-7xl leading-tight text-white uppercase italic"
                    >
                        {app.concept.main}<br />
                        <span class="not-italic text-[#DAA520] font-black"
                            >{app.concept.highlighted}</span
                        >
                    </h2>
                    <p
                        class="text-2xl text-white/40 leading-relaxed font-light font-heading opacity-80"
                    >
                        {app.description}
                    </p>

                    <div class="space-y-4 pt-10 border-t border-white/5">
                        <p
                            class="text-[10px] font-bold uppercase tracking-[0.4em] text-white/20 mb-6"
                        >
                            Especificaciones Técnicas
                        </p>
                        {
                            app.features.map((f) => (
                                <div class="flex items-start gap-6 group">
                                    <span class="text-[10px] font-bold text-[#DAA520] pt-1">
                                        0{app.features.indexOf(f) + 1}
                                    </span>
                                    <div>
                                        <h4 class="text-white font-heading uppercase text-lg mb-1">
                                            {f.title}
                                        </h4>
                                        <p class="text-sm text-white/40">{f.text}</p>
                                    </div>
                                </div>
                            ))
                        }
                    </div>

                    <div
                        class="mt-16 p-8 bg-black/40 border border-[#DAA520]/10 rounded-2xl max-w-md pointer-events-none"
                    >
                        <table
                            class="w-full text-[10px] uppercase font-bold text-white/40 tracking-[0.2em]"
                        >
                            <tr class="border-b border-white/5"
                                ><td class="py-3">DENSIDAD</td><td class="text-right text-[#DAA520]"
                                    >ANALÍTICA</td
                                ></tr
                            >
                            <tr class="border-b border-white/5"
                                ><td class="py-3">GRADO (ABV)</td><td
                                    class="text-right text-[#DAA520]">CALIBRADO</td
                                ></tr
                            >
                            <tr
                                ><td class="py-3">AZÚCAR (BRIX)</td><td
                                    class="text-right text-[#DAA520]">REAL-TIME</td
                                ></tr
                            >
                        </table>
                    </div>
                </div>

                <div
                    class="relative rounded-[2.5rem] overflow-hidden border border-white/5 shadow-huge"
                >
                    <img
                        src="/assets/apps/vesp/mixer-mockup.webp"
                        class="w-full h-auto"
                        alt="Mixer Tech Details"
                    />
                </div>
            </div>
        </section>

        <section class="py-40 px-6 bg-black">
            <div class="max-w-7xl mx-auto flex flex-col items-center">
                <div class="text-center mb-20 max-w-3xl">
                    <h2
                        class="font-heading text-6xl md:text-8xl text-white italic mb-10 leading-none uppercase"
                    >
                        Motor de <br />
                        <span class="not-italic font-black text-[#DAA520]">equilibrio.</span>
                    </h2>
                    <p class="text-xl text-white/40 leading-relaxed font-heading">
                        Visualiza el balance entre alcohol, azúcar y acidez mediante cálculos
                        técnicos diseñados para la industria.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 w-full">
                    {
                        app.benefits.map((b) => (
                            <div class="p-12 border border-white/5 hover:border-[#DAA520]/20 transition-all bg-white/[0.01]">
                                <Icon
                                    name={b.icon || "mdi:flask"}
                                    class="w-8 h-8 text-[#DAA520] mb-10"
                                />
                                <h3 class="font-heading text-xl text-white uppercase mb-4">
                                    {b.title}
                                </h3>
                                <p class="text-xs text-white/40 leading-relaxed uppercase tracking-widest">
                                    {b.text}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <section class="py-40 px-6 border-t border-white/5 overflow-hidden">
            <div
                class="max-w-7xl mx-auto flex flex-col md:flex-row gap-8 items-center justify-between mb-20"
            >
                <h2
                    class="font-heading text-4xl text-[#DAA520] uppercase tracking-[0.3em] font-light"
                >
                    Ecosistema VESP
                </h2>
                <p class="text-xs font-bold uppercase tracking-[0.5em] text-white/20">
                    Mixología & Estandarización
                </p>
            </div>

            <div class="flex flex-nowrap md:grid md:grid-cols-3 gap-8 overflow-x-auto pb-10">
                {
                    app.media.screenshots.slice(1, 4).map((s) => (
                        <div class="min-w-[300px] rounded-[2rem] overflow-hidden border border-white/5 shadow-xl bg-slate-900 aspect-[9/19.5]">
                            <img
                                src={s}
                                class="w-full h-full object-cover grayscale brightness-90 hover:grayscale-0 hover:brightness-100 transition-all duration-1000"
                                alt="VESP Context"
                            />
                        </div>
                    ))
                }
            </div>
        </section>

        <footer class="py-40 px-6 text-center bg-[#000415]">
            <div class="max-w-2xl mx-auto">
                <img
                    src="/assets/apps/vesp/quality-seal.webp"
                    class="w-32 h-32 mx-auto mb-16 opacity-10"
                    alt="Seal"
                />
                <h2
                    class="font-heading text-6xl md:text-9xl text-white uppercase mb-12 italic leading-none opacity-80"
                >
                    Servicio <br />
                    <span class="not-italic text-[#DAA520] font-black">PERFECTO.</span>
                </h2>
                <p class="text-xs uppercase tracking-[1em] text-white/20 font-bold mb-20">
                    Muy pronto en Stores
                </p>

                <div class="h-px w-32 bg-[#DAA520]/20 mx-auto"></div>
            </div>
        </footer>
    </div>
</AppLayout>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Marcellus&display=swap");

    .shadow-3xl {
        box-shadow:
            0 50px 100px -20px rgba(0, 0, 0, 0.8),
            0 30px 60px -30px rgba(0, 0, 0, 0.7);
    }

    .shadow-huge {
        box-shadow: 0 70px 120px -30px rgba(0, 0, 0, 0.9);
    }

    ::-webkit-scrollbar {
        height: 4px;
        width: 4px;
    }
    ::-webkit-scrollbar-track {
        background: #000415;
    }
    ::-webkit-scrollbar-thumb {
        background: #daa52033;
        border-radius: 2px;
    }
</style>
