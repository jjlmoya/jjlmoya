---
export const prerender = true;
import AppLayout from "../../layouts/AppLayout.astro";
import { ALL_APP_DEFINITIONS } from "@jjlmoya/apps";
import type { KnownLocale } from "@jjlmoya/apps";

export async function getStaticPaths() {
    const paths = [];
    
    for (const definition of ALL_APP_DEFINITIONS) {
        const loader = definition.entry.i18n['es' as KnownLocale] ?? definition.entry.i18n.en;
        const card = await loader!();
        
        paths.push({
            params: { slug: card.slug },
            props: { definition, card },
        });
    }
    
    return paths;
}

const { definition, card } = Astro.props;
const { entry } = definition;
const { default: LandingComponent } = await definition.LandingComponent() as { default: any };

const DEFAULT_THEMES: Record<string, any> = {
    "sauce-lab": { primary: "#FF4D4D" },
    "fortune-cookie": { primary: "#FFD700" },
    "lexi-crash": { primary: "#4D94FF" },
    "pizzametrics": { primary: "#FFA500" },
    "vesp": { primary: "#00FF9F" },
    "day-check": { primary: "#B185FF" },
    "fast-task": { primary: "#00E5FF" },
};

const theme = DEFAULT_THEMES[entry.id] || { primary: "#000000" };
const iconPath = `/assets/apps/${entry.id}/icon.webp`;
---

<AppLayout
    title={`${card.title} — ${card.subtitle}`}
    description={card.description}
    image={iconPath}
    color={theme.primary}
    favicon={iconPath}
    currentSlug={card.slug}
>
    <LandingComponent locale="es" />
</AppLayout>
