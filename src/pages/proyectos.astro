---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import projects from "../data/projects.json";
import "./proyectos.css";
---

<Layout
    title="El Único Portfolio Que Mezcla Código y Cal"
    description="El único portfolio que mezcla código y cal. Proyectos reales de restauración, software, diseño de apps e historias. La ambición es el motor de todo."
    image="/images/projects/index.webp"
>
    <div class="projects-artspace">
        <section class="hero-brutalist">
            <h1 class="hero-title-brutalist">
                <span class="word-1" data-text="PROYECTOS.">PRO</span>
                <span class="word-2" data-text="CÓDIGO.">YEC</span>
                <span class="word-3" data-text="IMPACTO.">TOS</span>
            </h1>
        </section>

        <section class="projects-editorial">
            {
                projects.map((project, index) => (
                    <article class={`project-story story-${index + 1}`}>
                        <a
                            href={project.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="story-link"
                        >
                            <div class="story-number">0{index + 1}</div>

                            <h2 class="story-title" data-title={project.title}>
                                {project.title.split(" ").map((word) => (
                                    <span class="title-word">{word}</span>
                                ))}
                            </h2>

                            <div class="story-content">
                                <div class="story-visual">
                                    <div class={`visual-blob blob-${index + 1}`}>
                                        <img
                                            src={
                                                project.image
                                                    ? `/assets/icons/${project.image}.webp`
                                                    : `https://www.google.com/s2/favicons?domain=${project.url}&sz=128`
                                            }
                                            alt={project.title}
                                            class="story-icon"
                                        />
                                    </div>
                                </div>

                                <div class="story-text">
                                    <p class="story-description">{project.description}</p>
                                    <span class="story-cta">
                                        <span class="cta-text">Visitar</span>
                                        <svg
                                            class="cta-arrow"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <path d="M5 12h14M12 5l7 7-7 7" />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                            <div class="story-overlay" />
                        </a>
                    </article>
                ))
            }
        </section>
    </div>
</Layout>


