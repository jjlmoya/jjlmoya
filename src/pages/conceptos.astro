---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const concepts = [
    {
        id: "escala-de-grises",
        title: "LA MUERTE DEL MATIZ",
        subtitle: "Escala de Grises",
        href: "/conceptos/escala-de-grises/",
        icon: "mdi:contrast-circle",
        color: "100, 100, 100",
        desc: "En un mundo binario, el gris es un acto de rebeldía.",
    },
    {
        id: "inflacion",
        title: "INFLACIÓN",
        subtitle: "Erosión de Valor",
        href: "/conceptos/inflacion/",
        icon: "mdi:finance",
        color: "255, 215, 0",
        desc: "Visualiza cómo el tiempo devora el dinero.",
    },
    {
        id: "biblioteca",
        title: "BIBLIOTECA",
        subtitle: "Datos Vitales",
        href: "/conceptos/biblioteca/",
        icon: "mdi:bookshelf",
        color: "255, 100, 100",
        desc: "Tu existencia convertida en catálogo.",
    },
    {
        id: "trigo",
        title: "TRIGO",
        subtitle: "La Trampa Dorada",
        href: "/conceptos/trigo/",
        icon: "mdi:barley",
        color: "234, 179, 8",
        desc: "Crónica de cómo una hierba domesticó a la humanidad.",
    },
    {
        id: "oda-al-aburrimiento",
        title: "ODA AL ABURRIMIENTO",
        subtitle: "Art. 1",
        href: "/conceptos/oda-al-aburrimiento/",
        icon: "mdi:gavel",
        color: "0, 0, 0",
        desc: "Referencia normativa.",
    },
    {
        id: "medicion",
        title: "MEDICIÓN",
        subtitle: "El Arte de Cuantificar",
        href: "/conceptos/medicion/",
        icon: "mdi:ruler",
        color: "6, 182, 212",
        desc: "Desde el codo del faraón hasta el último bit de tu reloj inteligente.",
    },
    {
        id: "espera",
        title: "ESPERA",
        subtitle: "Cargando...",
        href: "/conceptos/espera/",
        icon: "mdi:hourglass",
        color: "128, 128, 128",
        desc: "El arte de no hacer nada mientras el tiempo pasa.",
    },
    {
        id: "huella-digital",
        title: "LA HUELLA",
        subtitle: "Registro Involuntario",
        href: "/conceptos/huella-digital/",
        icon: "mdi:foot-print",
        color: "255, 255, 255",
        desc: "Tu firma técnica en el muro de lo invisible.",
    },
];
---

<Layout
    title="Conceptos"
    description="Aterrizando ideas vagas que tengo en la cabeza, dándoles cuerpo y forma para que todo el mundo sea capaz de comprenderlo. ¡Incluso yo!"
    bodyClass="conceptos-body"
    showBackground={false}
    mainClass="conceptos-main"
    image="/images/concepts/index.webp"
>
    <div class="background-overlay">
        <div class="radial-glow"></div>
        <canvas id="stardust" class="stardust-canvas"></canvas>
    </div>

    <div class="concepts-wrapper">
        <header class="concepts-header">
            <h1 class="concepts-title">Conceptos</h1>
            <div class="header-line"></div>
            <p class="concepts-intro">
                Aterrizando ideas vagas que tengo en la cabeza, dándoles cuerpo y forma para que
                todo el mundo sea capaz de comprenderlo. ¡Incluso yo!
            </p>
        </header>

        <div class="concepts-grid">
            {
                concepts.map((concept) =>
                    concept.id === "oda-al-aburrimiento" ? (
                        <a
                            href={concept.href}
                            class="card-boredom"
                        >
                            <div class="card-inner">
                                <div class="boredom-icon">§</div>
                                <h2 class="boredom-title">
                                    {concept.title}
                                </h2>
                                <p class="boredom-subtitle">
                                    {concept.subtitle}
                                </p>
                                <p class="boredom-desc">
                                    {concept.desc}
                                </p>
                            </div>
                        </a>
                    ) : (
                        <a
                            href={concept.href}
                            class="concept-card"
                            data-color={concept.color}
                        >
                            <div
                                class="card-glow"
                                style={`background: radial-gradient(circle at center, rgb(${concept.color}), transparent 70%);`}
                            />

                            <div class="card-content">
                                <div class="card-icon-container">
                                    <Icon name={concept.icon} class="card-icon" />
                                </div>

                                <div class="card-text-container">
                                    <h2 class="card-title">
                                        {concept.title}
                                    </h2>
                                    <p class="card-subtitle">
                                        {concept.subtitle}
                                    </p>

                                    <div class="card-line" />

                                    <p class="card-desc">
                                        "{concept.desc}"
                                    </p>
                                </div>
                            </div>

                            <div class="card-border" />
                        </a>
                    )
                )
            }
        </div>
    </div>
</Layout>

<style>
    .conceptos-body {
        background-color: #0a0a0a;
        color: #ffffff;
        margin: 0;
    }

    .conceptos-main {
        padding: 0;
    }

    .background-overlay {
        position: fixed;
        inset: 0;
        z-index: 0;
        background-color: #0a0a0a;
    }

    .radial-glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.05), transparent 70%);
        pointer-events: none;
    }

    .stardust-canvas {
        position: absolute;
        inset: 0;
        opacity: 0.3;
        pointer-events: none;
    }

    .concepts-wrapper {
        position: relative;
        z-index: 10;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 8rem 2rem 4rem 2rem;
        box-sizing: border-box;
    }

    .concepts-header {
        text-align: center;
        margin-bottom: 5rem;
        max-width: 42rem;
    }

    .concepts-title {
        font-size: 3rem;
        font-weight: 300;
        letter-spacing: -0.02em;
        color: #ffffff;
        margin: 0 0 1.5rem 0;
        text-transform: uppercase;
    }

    @media (min-width: 768px) {
        .concepts-title {
            font-size: 4.5rem;
        }
    }

    .header-line {
        width: 4rem;
        height: 1px;
        background-color: rgba(255, 255, 255, 0.3);
        margin: 0 auto 1.5rem auto;
    }

    .concepts-intro {
        font-size: 1rem;
        font-style: italic;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.7;
        margin: 0;
    }

    @media (min-width: 768px) {
        .concepts-intro {
            font-size: 1.125rem;
        }
    }

    .concepts-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        max-width: 72rem;
        width: 100%;
        padding: 0 1rem;
        box-sizing: border-box;
    }

    @media (min-width: 768px) {
        .concepts-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .card-boredom {
        display: block;
        width: 100%;
        max-width: 24rem;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #000000;
        padding: 2rem;
        text-align: center;
        text-decoration: none;
        color: #000000;
        box-sizing: border-box;
        transition: background-color 0.2s ease;
    }

    .card-boredom:hover {
        background-color: #f9f9f9;
    }

    .card-boredom .card-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        min-height: 25rem;
    }

    .boredom-icon {
        font-size: 3.5rem;
        margin-bottom: 2rem;
        user-select: none;
    }

    .boredom-title {
        font-size: 1.25rem;
        font-weight: 700;
        text-transform: uppercase;
        margin: 0 0 0.5rem 0;
        border-bottom: 1px solid #000000;
        padding-bottom: 0.5rem;
        display: inline-block;
    }

    .boredom-subtitle {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin: 0 0 1.5rem 0;
        color: rgba(0, 0, 0, 0.6);
    }

    .boredom-desc {
        font-size: 1rem;
        line-height: 1.6;
        max-width: 12.5rem;
        margin: 0 auto;
    }

    .concept-card {
        position: relative;
        display: block;
        width: 100%;
        max-width: 24rem;
        margin: 0 auto;
        overflow: hidden;
        background-color: rgba(23, 23, 23, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.1);
        text-decoration: none;
        box-sizing: border-box;
        transition: background-color 0.5s ease, border-color 0.5s ease;
    }

    .concept-card:hover {
        background-color: rgba(23, 23, 23, 0.6);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .card-glow {
        position: absolute;
        inset: 0;
        opacity: 0.1;
        pointer-events: none;
        transition: opacity 0.5s ease;
    }

    .concept-card:hover .card-glow {
        opacity: 0.2;
    }

    .card-content {
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        text-align: center;
        min-height: 25rem;
        box-sizing: border-box;
    }

    .card-icon-container {
        margin-bottom: 2rem;
        color: rgba(255, 255, 255, 0.8);
        transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .concept-card:hover .card-icon-container {
        transform: scale(1.1);
    }

    .card-icon {
        width: 4rem;
        height: 4rem;
        filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.5));
    }

    .card-text-container {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .card-title {
        font-size: 1.5rem;
        font-weight: 300;
        letter-spacing: 0.1em;
        color: #ffffff;
        margin: 0 0 0.75rem 0;
        text-transform: uppercase;
    }

    .card-subtitle {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: rgba(255, 255, 255, 0.4);
        margin: 0 0 1.5rem 0;
    }

    .card-line {
        width: 3rem;
        height: 1px;
        background-color: rgba(255, 255, 255, 0.2);
        margin-bottom: 1.5rem;
    }

    .card-desc {
        font-size: 1.125rem;
        color: rgba(255, 255, 255, 0.7);
        font-style: italic;
        line-height: 1.6;
        margin: 0;
    }

    .card-border {
        position: absolute;
        inset: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        pointer-events: none;
        transition: border-color 0.5s ease;
    }

    .concept-card:hover .card-border {
        border-color: rgba(255, 255, 255, 0.1);
    }

    :global(footer) {
        position: relative !important;
        z-index: 10 !important;
        background-color: #ffffff !important;
        color: #000000 !important;
        width: 100% !important;
        padding: 3rem 2rem !important;
        margin-top: 6rem !important;
        border-top: 1px solid rgba(0, 0, 0, 0.1) !important;
        text-align: center !important;
        box-sizing: border-box !important;
    }

    :global(footer p) {
        margin: 0 !important;
        color: #000000 !important;
    }

    :global(footer a) {
        color: #000000 !important;
        text-decoration: underline !important;
        text-underline-offset: 3px !important;
        opacity: 0.8 !important;
        transition: opacity 0.2s ease !important;
    }

    :global(footer a:hover) {
        opacity: 1 !important;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const canvas = document.getElementById("stardust") as HTMLCanvasElement;
        if (!canvas) return;

        const ctx = canvas.getContext("2d");

        let width = 0;
        let height = 0;
        let particles: Star[] = [];
        const mouse = { x: 0, y: 0 };
        
        let targetColor = { r: 220, g: 220, b: 230 };
        const currentColor = { ...targetColor };

        const PARTICLE_COUNT = 150; 

        class Star {
            x: number;
            y: number;
            z: number;
            size: number;
            baseAlpha: number;

            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.z = Math.random() * 2 + 0.5;
                this.size = Math.random() * 1.5;
                this.baseAlpha = Math.random() * 0.4 + 0.1;
            }

            update() {
                this.y -= 0.05 * (1 / this.z); 

                if (this.y < 0) this.y = height;
                if (this.x < 0) this.x = width;
                if (this.x > width) this.x = 0;
            }

            draw(offsetX: number, offsetY: number) {
                if (!ctx) return;
                const drawX = this.x + offsetX * (1 / this.z);
                const drawY = this.y + offsetY * (1 / this.z);
                ctx.fillStyle = `rgba(${Math.round(currentColor.r)}, ${Math.round(currentColor.g)}, ${Math.round(currentColor.b)}, ${this.baseAlpha})`;
                ctx.beginPath();
                ctx.arc(drawX, drawY, this.size * (1 / this.z), 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function init() {
            resize();
            particles = [];
            for (let i = 0; i < PARTICLE_COUNT; i++) {
                particles.push(new Star());
            }
            animate();
        }

        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }

        function animate() {
            if (!ctx) return;
            ctx.clearRect(0, 0, width, height);

            currentColor.r += (targetColor.r - currentColor.r) * 0.02;
            currentColor.g += (targetColor.g - currentColor.g) * 0.02;
            currentColor.b += (targetColor.b - currentColor.b) * 0.02;

            const offsetX = (mouse.x - width / 2) * 0.02;
            const offsetY = (mouse.y - height / 2) * 0.02;

            particles.forEach((p) => {
                p.update();
                p.draw(offsetX, offsetY);
            });

            requestAnimationFrame(animate);
        }

        window.addEventListener("resize", () => {
            resize();
            init();
        });

        window.addEventListener("mousemove", (e) => {
            mouse.x = e.clientX;
            mouse.y = e.clientY;
        });

        const cards = document.querySelectorAll(".concept-card");
        cards.forEach((card) => {
            card.addEventListener("mouseenter", () => {
                const color = card.getAttribute("data-color");
                if (color) {
                    const [r, g, b] = color.split(",").map(Number);
                    targetColor = { r, g, b };
                }
            });

            card.addEventListener("mouseleave", () => {
                targetColor = { r: 220, g: 220, b: 230 };
            });
        });

        init();
    });
</script>
