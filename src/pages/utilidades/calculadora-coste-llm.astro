---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import LlmCostCalculator from "../../components/utilidades/llm-cost-calculator/LlmCostCalculator.astro";
import LlmCostCalculatorSEO from "../../components/utilidades/llm-cost-calculator/LlmCostCalculatorSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
const faqItems = [
    {
        question: "¿Cómo se calculan los costes de una API de IA en 2026?",
        answer: "Los proveedores operan bajo la economía del 'token'. 1 token equivale aproximadamente a 0.75 palabras. El coste total depende de la serie del modelo (Pro, Standard o Flash) y de si utilizas funciones avanzadas como el 'Context Caching', que reduce drásticamente el coste recurrente.",
    },
    {
        question: "¿Qué modelos están incluidos en la calculadora?",
        answer: "Mantenemos actualizados los precios de la generación 2026: GPT-5.4 (Pro y Standard), la serie Claude 4.6 (Opus, Sonnet, Haiku), Gemini 3 de Google y los modelos abiertos Llama 4 de Meta.",
    },
    {
        question: "¿Están los precios de esta herramienta actualizados?",
        answer: "Sí, la herramienta monitoriza y actualiza los precios oficiales de OpenAI, Anthropic y Google mensualmente para reflejar la deflación del token y los nuevos anuncios de hardware H200/B200.",
    },
    {
        question: "¿Es mejor usar un modelo 'Flash' o uno 'Pro'?",
        answer: "Depende de la tarea. Para análisis biomecánico o razonamiento profundo, los modelos Pro (como GPT-5.4 Pro) son necesarios aunque cuesten 10x más. Para resúmenes, clasificación o RAG masivo, los modelos Flash son 100x más rentables.",
    },
];

const howToSteps = [
    {
        name: "Seleccionar el modelo",
        text: "Elige la familia de IA y el nivel de razonamiento necesario (ej. Claude 4.6 Opus para máximo rigor o Gemini 3 Flash para velocidad).",
    },
    {
        name: "Estimar tokens de entrada",
        text: "Introduce el número aproximado de tokens que tendrá tu prompt o contexto de base.",
    },
    {
        name: "Estimar tokens de salida",
        text: "Define cuánta información esperas que genere la IA como respuesta.",
    },
    {
        name: "Comparar resultados",
        text: "Observa el desglose de costes y compara con otros proveedores para encontrar la opción más rentable para tu proyecto.",
    },
];
---

<LayoutUtility
    title="Calculadora de Costes LLM 2026 (GPT-5.4, Claude 4.6, Gemini 3)"
    description="Calcula y compara el precio de tus proyectos de IA. Estima costes de tokens de entrada y salida para GPT-5.4, Claude 4.6 Sonnet y modelos Llama 4."
    image="/images/utilities/llm-cost-calculator.webp"
    gradientFrom="from-slate-100"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="LLM"
            titleBase="Calculadora Costes"
            description="Visualiza el gasto real de tus prompts. Compara precios entre OpenAI, Anthropic y Google."
            gradientFrom="from-indigo-500"
            gradientTo="to-purple-600"
            reverse={true}
        />
    </div>

    <LlmCostCalculator />

    <div slot="seo">
        <LlmCostCalculatorSEO />
    </div>
</LayoutUtility>
