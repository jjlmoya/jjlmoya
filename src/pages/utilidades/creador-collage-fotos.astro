---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import PhotoCollageCreator from "../../components/utilidades/photo-collage-creator/PhotoCollageCreator.astro";
import PhotoCollageCreatorSEO from "../../components/utilidades/photo-collage-creator/PhotoCollageCreatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Creador de Collages de Fotos Online - Diseño Personalizado Gratis";
const description =
    "Crea collages de fotos profesionales online sin instalar software. Personaliza bordes, elige diseños y descarga en alta resolución. 100% privado, sin publicidad.";

const faqItems = [
    {
        question: "¿Necesito crear una cuenta para usar el creador de collages?",
        answer: "No. Nuestra herramienta es completamente gratuita y anónima. No se requiere registro, login ni email. Solo sube tus fotos, personaliza y descarga. Sin publicidad invasiva.",
    },
    {
        question: "¿Mis fotos se guardan en vuestro servidor?",
        answer: "Absolutamente no. Todo el proceso ocurre 100% en tu navegador. Las imágenes se cargan, procesan y descargan localmente sin abandonar tu dispositivo. Total privacidad garantizada.",
    },
    {
        question: "¿Qué tamaño debe tener mi collage descargado?",
        answer: "Dependiendo del diseño elegido: Collage 2x2 genera 800x800px, diseño 3x3 produce 900x900px, y los asimétricos varían entre 400-900px de ancho. Perfecto para cualquier red social e impresión.",
    },
    {
        question: "¿Puedo agregar texto o filtros al collage?",
        answer: "Actualmente nos enfocamos en lo esencial: fotos + bordes + colores personalizables. Para efectos avanzados, descarga el collage e importa en Canva, Photoshop o cualquier editor online.",
    },
    {
        question: "¿Cuántas fotos puedo combinar en un collage?",
        answer: "Entre 2 y 9 imágenes máximo. La herramienta ofrece 6 disposiciones diferentes que se adaptan automáticamente: 2x2, 3x3, 2x1, 1x2, grande+pequeñas, pequeñas+grande.",
    },
    {
        question: "¿Funciona en móvil y tablet?",
        answer: "Sí. La interfaz se adapta automáticamente a pantallas pequeñas. Puedes cargar fotos desde tu galería, personalizarlas y descargar directamente en tu dispositivo.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/creador-collage-fotos.webp"
    category="Audiovisual y Fotografía"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Creador"
            titleBase="de Collages de Fotos"
            description="Diseña collages profesionales personalizando bordes, colores y disposiciones. Sin perder calidad. Descarga en PNG alta resolución."
            gradientFrom="from-purple-600"
            gradientTo="to-pink-500"
        />
    </div>

    <PhotoCollageCreator />

    <div slot="seo">
        <PhotoCollageCreatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Recursos sobre Collages y Diseño Fotográfico"
            links={[
                {
                    name: "Composición Fotográfica - Principios y Reglas de Oro",
                    url: "https://en.wikipedia.org/wiki/Composition_(visual_arts)",
                },
                {
                    name: "Teoría del Color en Diseño Visual",
                    url: "https://en.wikipedia.org/wiki/Color_theory",
                },
                {
                    name: "Historia del Collage en Arte Contemporáneo",
                    url: "https://en.wikipedia.org/wiki/Collage",
                },
            ]}
        />
    </div>
</LayoutUtility>
