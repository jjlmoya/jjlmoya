---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import WeightedGradeCalculator from "../../components/utilidades/WeightedGradeCalculator/WeightedGradeCalculator.astro";
import WeightedGradeCalculatorSEO from "../../components/utilidades/WeightedGradeCalculator/WeightedGradeCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Nota Ponderada | Bachillerato, EBAU y Universidad";
const description =
    "Calcula tu nota final ponderada para bachillerato, selectividad (EBAU) o universidad. Introduce tus asignaturas, notas y porcentajes de peso.";

const faqItems = [
    {
        question: "¿Qué es la nota ponderada?",
        answer: "Es una media donde cada nota tiene un peso diferente sobre el total. Se calcula multiplicando cada calificación por su porcentaje y sumando los resultados.",
    },
    {
        question: "¿Cómo funcionan las ponderaciones en la EBAU?",
        answer: "En la fase de admisión, las universidades multiplican la nota de tus exámenes voluntarios por 0.1 o 0.2 dependiendo de la relación de la materia con el grado elegido. Esto puede sumar hasta 4 puntos extra a tu nota de admisión.",
    },
    {
        question: "¿Qué pasa si mis pesos no suman 100%?",
        answer: "Si los pesos no suman 100 (por ejemplo, en un curso no terminado), la calculadora divide la suma ponderada entre el porcentaje acumulado para darte una nota proyectada sobre 10. Para notas finales oficiales, la suma debe ser siempre 100%.",
    },
    {
        question: "¿Puedo usarla para notas universitarias?",
        answer: "Sí, es ideal para calcular la nota final de una asignatura basándose en el porcentaje asignado a la evaluación continua, exámenes parciales, trabajos y examen final según la guía docente.",
    },
    {
        question: "¿Cómo afecta la ponderación a la nota de admisión?",
        answer: "Cada universidad decide qué materias ponderan 0.1 o 0.2 para cada grado. Es vital consultar las tablas de ponderación de la universidad de destino para maximizar tus opciones de entrada.",
    },
];

const howToSteps = [
    {
        name: "Añade tus asignaturas",
        text: "Pulsa el botón 'Añadir Asignatura' para incluir todas las materias o exámenes que quieres promediar.",
    },
    {
        name: "Introduce notas y pesos",
        text: "Escribe la calificación obtenida (0-10) y el porcentaje de peso que tiene esa nota sobre el total (0-100%).",
    },
    {
        name: "Obtén tu resultado",
        text: "La calculadora actualizará automáticamente tu nota final ponderada y te avisará si los pesos no suman el 100%.",
    },
];

const bibliography = [
    {
        name: "Ponderaciones de Grado - UIB",
        url: "hhttps://estudis.uib.es/es/estudis-de-grau/Com-hi-pots-accedir/acces/parametres/",
    },
    {
        name: "Cálculo de la nota de admisión - Universidad Complutense de Madrid",
        url: "https://admdum.ucm.es/admdum/simulador",
    },
    {
        name: "Guía de la EBAU y acceso a la universidad",
        url: "https://yaq.es/selectividad/guia-selectividad-completa",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-nota-ponderada.webp"
    gradientFrom="from-indigo-100"
    gradientTo="to-blue-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Nota Ponderada"
            titleBase="Calculadora de"
            description="La herramienta definitiva para estudiantes. Calcula medias de Bachillerato, EBAU y Universidad con precisión total."
            gradientFrom="from-indigo-500"
            gradientTo="to-blue-600"
            reverse={true}
        />
    </div>

    <WeightedGradeCalculator />

    <div slot="seo">
        <WeightedGradeCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
