---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import ReadingDistanceCalculator from "../../components/utilidades/ReadingDistanceCalculator/ReadingDistanceCalculator.astro";
import ReadingDistanceCalculatorSEO from "../../components/utilidades/ReadingDistanceCalculator/ReadingDistanceCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";

const faqItems = [
    {
        question: "¿Por qué importa el tamaño de la fuente para la distancia?",
        answer: "Porque el ojo necesita que la letra proyecte un tamaño específico en la retina para reconocerla sin esfuerzo. Si la letra es pequeña, tendemos a acercarnos, lo que obliga al músculo ciliar a contraerse en exceso, causando fatiga visual.",
    },
    {
        question: "¿Cuál es la distancia mínima saludable?",
        answer: "Como norma general, nunca deberías estar a menos de 35-40 cm de cualquier pantalla. Para monitores de ordenador, la distancia ideal suele oscilar entre los 50 y 70 cm.",
    },
    {
        question: "¿Afecta la resolución de la pantalla (PPI)?",
        answer: "Sí. En pantallas con muchos píxeles por pulgada, el texto puede verse muy nítido pero ser físicamente más pequeño. Por eso es vital ajustar el escalado del sistema operativo para poder mantener una distancia cómoda.",
    },
    {
        question: "¿Qué pasa si uso gafas progresivas?",
        answer: "Las personas con presbicia o que usan cristales progresivos tienen un punto dulce de enfoque. La calculadora te ayuda a encontrar la distancia física, pero debes asegurarte de que tu postura corporal sea erguida para no forzar el cuello.",
    },
];

const bibliographyLinks = [
    {
        name: "American Academy of Ophthalmology: Computers, Digital Devices and Eye Strain",
        url: "https://www.aao.org/eye-health/tips-prevention/computer-usage-digital-screens",
    },
    {
        name: "Manejo ergonómico para pantallas de visualización de datos",
        url: "https://asispa.org/ergonomia-en-el-uso-de-pantallas-de-visualizacion-de-datos-pvd/",
    },
];
---

<LayoutUtility
    title="Calculadora de Distancia de Lectura Óptima | Salud Visual"
    description="Descubre a cuántos centímetros de la pantalla debes situarte según el tamaño de tu fuente. Evita la fatiga visual y protege tus ojos con ergonomía."
    image="/images/utilities/distancia-lectura.webp"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Distancia"
            titleBase="de Lectura Óptima"
            description="Calcula la separación ideal entre tus ojos y la pantalla para trabajar sin fatiga visual. Ajusta el tamaño de letra y obtén tu recomendación ergonómica."
            gradientFrom="from-blue-500"
            gradientTo="to-indigo-600"
        />
    </div>

    <ReadingDistanceCalculator />

    <div slot="seo">
        <ReadingDistanceCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} title="Referencias Científicas" />
    </div>
</LayoutUtility>
