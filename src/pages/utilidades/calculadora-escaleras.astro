---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import StairCalculator from "../../components/utilidades/StairCalculator/StairCalculator.astro";
import StairCalculatorSEO from "../../components/utilidades/StairCalculator/StairCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Calculadora de Escaleras Online | Ley de Blondel y Medidas de Obra";
const description = "Calcula las medidas exactas de tu escalera: huella, contrahuella, ángulo y materiales. Herramienta visual para albañiles y diseño de obra.";

const faqItems = [
    {
        question: "¿Qué es la Ley de Blondel?",
        answer: "Es una fórmula que establece que para que una escalera sea cómoda, la suma de dos contrahuellas y una huella debe estar entre 62 y 64 cm (2CH + H = 63).",
    },
    {
        question: "¿Cuál es la altura máxima de un peldaño?",
        answer: "En viviendas se recomienda no superar los 18-19 cm. Para espacios públicos, el máximo suele ser 17.5 cm.",
    },
    {
        question: "¿Cómo calculo si tengo poco espacio?",
        answer: "Si el avance horizontal es limitado, deberás aumentar el número de peldaños (reduciendo la contrahuella) o aceptar una pendiente mayor, aunque sea menos cómoda.",
    },
];

const howToSteps = [
    {
        name: "Medir Desnivel",
        text: "Mide el desnivel total (H) desde el suelo terminado inferior al superior.",
    },
    {
        name: "Longitud Disponible",
        text: "Introduce la longitud disponible si tienes restricciones de espacio.",
    },
    {
        name: "Número de Peldaños",
        text: "Ajusta el número de peldaños hasta que el indicador de Blondel esté en verde.",
    },
    {
        name: "Trazado",
        text: "Usa la tabla de trazado para marcar los puntos exactos con una cinta métrica.",
    },
];

const bibliography = [
    { name: "Normativa de Seguridad en Escaleras (CTE España)", url: "https://www.codigotecnico.org/" },
    { name: "Ergonomía de la Escalera - Wikipedia", url: "https://es.wikipedia.org/wiki/Escalera" }
];
---

<LayoutUtility 
    title={title}
    description={description}
    image="/images/utilities/calculadora-escaleras.webp"
    gradientFrom="from-orange-100"
    gradientTo="to-amber-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader 
            titleHighlight="Calculadora" 
            titleBase="de Escaleras" 
            description={description}
            gradientFromColor="#f39c12" 
            gradientToColor="#d35400"
        />
    </div>

    <StairCalculator />

    <div slot="seo">
        <StairCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
