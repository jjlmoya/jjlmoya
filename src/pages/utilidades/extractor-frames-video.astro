---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import VideoFrameExtractor from "../../components/utilidades/VideoFrameExtractor/VideoFrameExtractor.astro";
import VideoFrameExtractorSEO from "../../components/utilidades/VideoFrameExtractor/VideoFrameExtractorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Extractor de Frames de Vídeo: Captura Fotos de Alta Calidad";
const description =
    "Extrae capturas en alta resolución (4K/1080p) de cualquier archivo de vídeo local. Consigue frames nítidos sin pérdida de calidad y sin subir archivos.";

const faqItems = [
    {
        question: "¿Qué formatos de vídeo soporta el extractor?",
        answer: "Soportamos los formatos más comunes procesados por el navegador: MP4 (H.264), WebM, MOV de iPhone y archivos MKV compatibles con estándares web.",
    },
    {
        question: "¿Se sube mi vídeo a algún servidor?",
        answer: "No, en absoluto. Todo el proceso de extracción de frames ocurre localmente en tu navegador mediante JavaScript. Tu privacidad está 100% garantizada.",
    },
    {
        question: "¿Cuál es la resolución de las capturas?",
        answer: "Las capturas se realizan a la resolución nativa del archivo de vídeo. Si tu vídeo es 4K, obtendrás una imagen 4K real, sin importar el tamaño de tu pantalla.",
    },
    {
        question: "¿Puedo descargar todas las fotos a la vez?",
        answer: "Sí, nuestra herramienta incluye un botón para descargar todas las capturas realizadas en un solo clic, facilitando el trabajo con múltiples frames.",
    },
];

const howToSteps = [
    {
        name: "Selecciona tu vídeo",
        text: "Haz clic en el área de carga para elegir un archivo local de tu ordenador o móvil.",
    },
    {
        name: "Navega y pausa",
        text: "Usa el reproductor para encontrar el instante exacto que quieres convertir en foto.",
    },
    {
        name: "Captura el frame",
        text: "Pulsa el botón de captura y el fotograma aparecerá instantáneamente en tu galería.",
    },
    {
        name: "Descarga en HD",
        text: "Guarda tus imágenes favoritas en formato PNG de alta calidad y sin marcas de agua.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/extractor-frames-video.webp"
    gradientFrom="from-purple-100"
    gradientTo="to-indigo-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Frames"
            titleBase="Extractor de"
            description="Consigue capturas nítidas de tus vídeos locales sin pérdida de calidad."
            gradientFrom="from-purple-500"
            gradientTo="to-indigo-600"
            reverse={true}
        />
    </div>

    <VideoFrameExtractor />

    <div slot="seo">
        <VideoFrameExtractorSEO />
    </div>
</LayoutUtility>
