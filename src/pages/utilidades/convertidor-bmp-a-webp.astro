---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import BmpToWebpSEO from "../../components/utilidades/ImageConverter/seo/BmpToWebpSEO.astro";

export const prerender = true;

const title = "Convertir BMP a WebP Gratis | Tu Compresor Nativo Offshore";
const description =
    "Pulveriza los tamaños descomunales del clásico archivo BMP convirtiéndolo a WebP ultra-ligero sin subir absolutamente nada a la red y de manera instantánea.";

const faqItems = [
    {
        question: "¿Por qué mis archivos BMP ocupan 10 veces más y qué gano al tenerlos en WebP?",
        answer: "El formato BMP (Bitmap) surgió para guardar mapas de píxeles sin comprimir. Esto asegura buena lectura en programas antiguos, pero genera fotos de 30 o 50 Megabytes con suma facilidad. WebP, tecnología actual de Google, usa compresión matemática para bajar eso a menos de un megabyte manteniendo la imagen sumamente reconocible, lista para volar por WhatsApp o por correo veloz.",
    },
    {
        question:
            "¿Tengo que registrar una cuenta para transformar bloques pesadísimos de Bitmap a WebP y qué tan expuestas estarán las fotos?",
        answer: "No exigimos correo y tu material permanecerá cerrado bajo candado y aislamiento absoluto, puesto que aquí el procesamiento lo realiza íntegramente de manera técnica el Javascript del navegador instalado en tu PC, en cero envío remoto.",
    },
    {
        question:
            "¿Puedo arrastrar 50 archivos simultáneamente a WebP con este servicio en la nube?",
        answer: "El servicio no es de nube, es nativo, y por tanto puedes arrastrar 50 o 100 archivos si tu hardware de computadora casero aguanta procesar veloz todos sus componentes matemáticos web en apenas microsegundos sin hacer colas o esperar a los envíos del bloque uno a uno.",
    },
];

const howToSteps = [
    {
        name: "Identificar Archivos Brutos",
        text: "Sitúa mental o virtualmente tus colecciones abismales escaneadas de mapa de bit en ventanas listas al traslado.",
    },
    {
        name: "Activación Nativa del Lote",
        text: "Proyecta o arrastra todos archivos de un tirón a nuestra enorme mesa digital. No gastarán banda ancha alguna.",
    },
    {
        name: "Evacuación del Lote WebP",
        text: "Pulsando los resultados obtendrás por separado la imagen en disco de micro-pesos o como comprimidos inmediatos.",
    },
];

const converterOptions = {
    sourceFormat: "image/bmp",
    targetFormat: "image/webp",
    sourceExt: "BMP",
    from: "bmp",
    to: "webp",
    dragText: "Arrastra enormes BMPs...",
    themeColor: "#059669",
    themeColorHover: "#047857",
    themeBg: "rgba(5, 150, 105, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-emerald-100"
    gradientTo="to-emerald-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a WebP"
            titleBase="Pesados BMP"
            description="La herramienta demoledora offline para masacrar resoluciones enormes en mapas de bits para transformarlas velozmente a archivos vanguardistas y ágiles de WebP."
            gradientFrom="from-emerald-500"
            gradientTo="to-emerald-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <BmpToWebpSEO />
    </div>
</LayoutUtility>
