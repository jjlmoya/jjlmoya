---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import TinderOptimizer from "../../components/utilidades/TinderOptimizer/TinderOptimizer.astro";
import TinderOptimizerSEO from "../../components/utilidades/TinderOptimizer/TinderOptimizerSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Por qué es importante el formato 9:16 en Tinder?",
        answer: "Tinder utiliza una interfaz vertical a pantalla completa. Si subes fotos en otros formatos (como cuadrado o 4:3), la aplicación las recortará o estirará automáticamente. Al exportar en 9:16 nativo, mantienes el control total sobre lo que los demás ven y aseguras la máxima nitidez.",
    },
    {
        question: "¿Mis fotos son privadas?",
        answer: "Totalmente. El procesamiento de la imagen se realiza localmente en tu navegador mediante HTML5 Canvas. Ninguna imagen se sube a nuestros servidores para ser optimizada, lo que garantiza tu privacidad al 100%.",
    },
    {
        question: "¿Qué significa 'Demasiado Aire Superior'?",
        answer: "Es un error común de composición donde queda mucho espacio vacío sobre la cabeza. Esto hace que el sujeto parezca más pequeño y pierda fuerza visual. Nuestra herramienta te alerta cuando el encuadre no es el óptimo para captar la atención inmediatamente.",
    },
    {
        question: "¿Cómo ayuda el test de legibilidad?",
        answer: "Tinder muestra el nombre y la edad del usuario en letras blancas en la parte inferior. Si tu foto tiene un fondo muy claro o quemado en esa zona, los usuarios no podrán leer quién eres. Nuestra herramienta analiza el brillo de esa sección y te avisa si hay riesgo de ilegibilidad.",
    },
];

const howToSteps = [
    {
        name: "Sube tu retrato",
        text: "Selecciona una foto de alta calidad desde tu móvil u ordenador para empezar el proceso.",
    },
    {
        name: "Ajusta zoom y encuadre",
        text: "Mueve la foto y ajusta el zoom para que tu rostro quede en el tercio superior, siguiendo las guías de composición.",
    },
    {
        name: "Simula la interfaz",
        text: "Comprueba con el simulador de botones de Like y Nope que ningún elemento clave de tu imagen quede oculto.",
    },
    {
        name: "Exporta y sube",
        text: "Descarga la versión optimizada a 1080x1920 con metadatos limpios y lista para tu perfil de Tinder.",
    },
];
---

<LayoutUtility
    title="Optimizador de Fotos para Tinder: Análisis de Rostro y Composición"
    description="Optimiza tus fotos de Tinder con análisis algorítmico. Simula la interfaz 2026, analiza el encuadre científico y la línea de mirada. Exporta retratos 9:16 perfectos para maximizar tus matches."
    image="/images/utilities/optimizador-fotos-tinder.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
    gradientFrom="from-white"
    gradientTo="to-slate-50"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Optimizador"
            titleBase="de Fotos Tinder"
            description="La ciencia detrás del match perfecto. Analiza tu rostro con algoritmos de visión avanzada, ajusta el encuadre 9:16 y verifica la visibilidad bajo la interfaz real antes de subir tu foto."
            gradientFrom="from-[#FE3C72]"
            gradientTo="to-[#FF7854]"
            reverse={false}
        />
    </div>

    <TinderOptimizer />

    <div slot="seo">
        <TinderOptimizerSEO />
    </div>
</LayoutUtility>
