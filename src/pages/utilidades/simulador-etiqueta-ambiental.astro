---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

import DgtEnvironmentalBadge from "../../components/utilidades/DgtEnvironmentalBadge/DgtEnvironmentalBadge.astro";
import DgtEnvironmentalBadgeSEO from "../../components/utilidades/DgtEnvironmentalBadge/DgtEnvironmentalBadgeSEO.astro";

const title = "Simulador de Etiqueta Ambiental DGT - Descubre tu Distintivo";
const description =
    "Averigua gratis y al instante qué etiqueta medioambiental o distintivo de la DGT le corresponde a tu coche, moto o furgoneta para las ZBE (Zonas de Bajas Emisiones).";

const faqItems = [
    {
        question: "¿Qué pasa si meto coche sin etiqueta a una Zona de Bajas Emisiones (ZBE)?",
        answer: "Si superas el perímetro con señales de ZBE en grandes ciudades con medidas restrictivas mediante vehículos sin etiqueta ambiental y sin permiso excepcional de empadronamiento de Tráfico, recibirás en tu domicilio una sanción económica por infracción grave cuya multa asciende de forma habitual a los 200 euros.",
    },
    {
        question:
            "¿Tengo que llevar la pegatina física de la DGT en el parabrisas obligatoriamente?",
        answer: "La DGT aconseja su colocación, pero la multa por no llevarla puesta pegada es de competencia municipal en una ordenanza local de movilidad de cada consistorio. En Madrid y algunas de las ciudades con superilles sí es indispensable, mientras en otras el control se delega íntegramente a lectura automática de matrículas de cámaras.",
    },
    {
        question:
            "¿Mi diésel no tiene etiqueta pero la ficha técnica pone Euro 4 y lo compré antes de tiempo?",
        answer: "Si dispones de un vehículo anterior al 2006 comercializado con motor de normativa Euro 4, la base de datos de datos de circulación de Tráfico te clasifica a menudo de serie solo por fecha. Debes pedir certificado de tu marca al concesionario oficial y presentar en Tráfico dicha corrección del fabricante indicando para ganar tu etiqueta.",
    },
    {
        question: "¿Para qué sirve el distinto C (Verde) en 2025 para coches?",
        answer: "En multitud de ZBE ordinarias tu acceso libre se mantiene, sin embargo el distintivo C restringe aparcar en superficie, el vehículo quedará obligado a estacionar bajo suelo o párquines homologados con coste y límite horario, es la penalización temporal pre-ECO que persiguen los consistorios.",
    },
];

const howToSteps = [
    {
        name: "Selecciona el Tipo de Vehículo",
        text: "En el simulador, escoge en primer lugar el ámbito de motor a consultar (Coche o moto suelen tener lógicas de clasificación dispares en Tráfico).",
    },
    {
        name: "Ingresa la Motorización o Energía Exacta",
        text: "Gasolina, eléctrico o Diésel importan, pero la distinción ECO entre HEV e híbrido enchufable o gas, se define esencialmente por su autonomía superior a los 40km.",
    },
    {
        name: "Inserta Fielmente la Fecha de Matriculación Inicial o Normativa Euro",
        text: "El factor definitivo para vehículos puros de combustión es la norma europea a la que responden, la fecha de compra en la ficha te aproxima la fecha estándar, obteniendo un predictivo muy exacto.",
    },
];

const bibliography = [
    {
        name: "Normativa sobre Cambio Climático y Tráfico - DGT",
        url: "https://www.dgt.es/export/sites/web-DGT/.galleries/downloads/muevete-con-seguridad/normas-de-trafico/MOV-gestion-trafico/2023/INSTRUCCION-recomendaciones-ZBE_fe.pdf",
    },
    {
        name: "La Zona de Bajas Emisiones, marco regulador y consecuencias de los distintivos y el Plan Moves - BOE",
        url: "https://www.boe.es/buscar/act.php?id=BOE-A-2021-8447",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/simulador-etiqueta-ambiental.webp"
    gradientFrom="from-[#22c55e]"
    gradientTo="to-[#059669]"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Etiqueta Ambiental"
            titleBase="Simulador de"
            description="Anticípate a las multas de la calle consultando nuestro recomendador online para identificar tu distintivo cero emisiones, ECO, C o B."
            gradientFrom="from-[#22c55e]"
            gradientTo="to-[#059669]"
            reverse={false}
        />
    </div>

    <DgtEnvironmentalBadge />

    <div slot="seo">
        <DgtEnvironmentalBadgeSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
