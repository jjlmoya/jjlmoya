---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import SailAreaCalculator from "../../components/utilidades/SailAreaCalculator/SailAreaCalculator.astro";
import SailAreaCalculatorSEO from "../../components/utilidades/SailAreaCalculator/SailAreaCalculatorSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Por qué mi barco es lento con poco viento?",
        answer: "Probablemente tiene un ratio SA/D inferior a 15 y mucho rozamiento en el casco. Los barcos pesados requieren una mayor presión de viento para vencer la inercia inicial y la resistencia del agua.",
    },
    {
        question: "¿Debo vaciar los tanques de agua para mejorar el rendimiento?",
        answer: "Sí, aligerar el barco mejora directamente el ratio SA/D. En regata, es común navegar con los tanques de agua vacíos y el combustible mínimo para maximizar la aceleración.",
    },
    {
        question: "¿Qué es el 'Roach' y cómo afecta al cálculo?",
        answer: "El roach es la curva de la baluma de la vela mayor. Si tu mayor tiene sables forzados y mucho roach, su superficie real será un 10-15% superior a la calculada mediante el triángulo estándar (P x E / 2).",
    },
    {
        question: "¿Cómo se mide el desplazamiento real para el cálculo?",
        answer: "Para un análisis preciso, usa el desplazamiento en carga (con tripulación, pertrechos y líquidos). El desplazamiento 'en rosca' del catálogo suele ser muy inferior al peso real del barco navegando.",
    },
    {
        question: "¿Dónde puedo encontrar las medidas I, J, P y E de mi barco?",
        answer: "Suelen aparecer en el manual del propietario facilitado por el astillero, en certificados de rating (ORC, RI) o en bases de datos náuticas como sailboatdata.com.",
    },
];

const howToSteps = [
    {
        name: "Define tu barco",
        text: "Selecciona el tipo de aparejo (Sloop, Ketch, etc.) y la categoría que mejor describa tu uso (Crucero, Regata, Clásico).",
    },
    {
        name: "Introduce el desplazamiento",
        text: "Mete el peso de tu barco en kg, libras o toneladas. Recuerda que el peso 'de crucero' suele ser un 10-15% superior al peso 'en rosca'.",
    },
    {
        name: "Mide tu aparejo",
        text: "Introduce las dimensiones I, J, P y E en metros o pies. Si tienes un velero de dos palos, no olvides la mesana (Py, Ey).",
    },
    {
        name: "Ajusta variables dinámicas",
        text: "Usa los controles para ver 'qué pasa si' cambias de un foque 100% a un génova 130% o si consigues bajar peso del barco.",
    },
    {
        name: "Interpreta el veredicto",
        text: "Observa el gráfico de rendimiento y lee el análisis personalizado según tu ratio SA/D para entender el carácter de tu velero.",
    },
];

const bibliographyLinks = [
    {
        name: "Principles of Yacht Design - Larsson & Eliasson",
        url: "http://protei.org/download/20110417Principles%20of%20yacht%20design%20-%20Larsson,%20Eliasson.pdf",
    },
    {
        name: "ORC Rating Systems - International Guideline",
        url: "https://orc.org/organization/rules-regulations",
    },
];
---

<LayoutUtility
    title="Calculadora de Superficie Vélica y Ratio SA/D | Rendimiento Náutico"
    description="Calcula el área total de tus velas y el ratio superficie/desplazamiento de tu barco. Análisis de rendimiento náutico basado en medidas I, J, P y E."
    image="/images/utilities/calculadora-superficie-velica.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Calculadora"
            titleBase="superficie vélica"
            description="Motor aerodinámico y rendimiento. Analiza el potencial de velocidad y estabilidad de tu velero calculando su ratio SA/D con precisión técnica."
            gradientFrom="from-[#003B73]"
            gradientTo="to-[#ef4135]"
        />
    </div>

    <div>
        <SailAreaCalculator />
    </div>

    <div slot="seo">
        <SailAreaCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
