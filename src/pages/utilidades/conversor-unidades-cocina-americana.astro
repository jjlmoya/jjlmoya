---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

import AmericanKitchenConverter from "../../components/utilidades/AmericanKitchenConverter/AmericanKitchenConverter.astro";
import AmericanKitchenConverterSEO from "../../components/utilidades/AmericanKitchenConverter/AmericanKitchenConverterSEO.astro";

const title = "Conversor de Unidades de Cocina Americanas a Gramos y Celsius";
const description =
    "Convierte fácilmente cups y tablespoons de ingredientes americanos a gramos y litros, además de Fahrenheit a Celsius. Diseñado para repostería exacta.";

const faqItems = [
    {
        question: "¿Cuántos gramos son una taza (1 cup) de harina?",
        answer: "Por consenso estándar en repostería técnica, 1 taza (1 cup) de harina de trigo común equivale a 120 gramos. Si no usas báscula y hundes la taza, podría pesar más de 140g, lo que estropearía tu receta.",
    },
    {
        question: "¿Qué temperatura en Celsius son 350°F?",
        answer: "350 grados Fahrenheit corresponden a 176°C, pero en la práctica pastelera y culinaria se redondea a 175°C. Es la temperatura estándar universal para hornear pasteles, galletas y bizcochos.",
    },
    {
        question: "¿A qué equivalen 'tbsp' y 'tsp'?",
        answer: "'Tbsp' o Cucharada (Tablespoon) equivale a 15 ml. 'tsp' o Cucharadita (Teaspoon) equivale a 5 ml. Esta ratio es de 1 a 3 (una cucharada contiene tres cucharaditas).",
    },
    {
        question: "¿Es importante convertir las tazas de azúcar moreno?",
        answer: "Sí, fundamental. El azúcar moreno en EEUU siempre se mide 'packed', muy prensado contra la taza medidora. Una taza de azúcar moreno suele equivaler a 220 gramos métricos.",
    },
];

const bibliography = [
    {
        name: "King Arthur Baking: Ingredient Weight Chart",
        url: "https://www.kingarthurbaking.com/learn/ingredient-weight-chart",
    },
    {
        name: "Culinary Institute of America: Conversions and Equivalents",
        url: "https://www.ciachef.edu/",
    },
];
const howToSteps = undefined;
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/conversor-unidades-cocina-americana.webp"
    gradientFrom="from-orange-100"
    gradientTo="to-red-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Cocina Americana"
            titleBase="Conversor de"
            description="Transforma tazas y cucharadas (cups, tablespoons) de ingredientes al sistema métrico sin errores y convierte temperaturas del horno de °F a °C al instante."
            gradientFrom="from-orange-500"
            gradientTo="to-red-600"
            reverse={true}
        />
    </div>

    <div class="mb-12">
        <AmericanKitchenConverter />
    </div>

    <div slot="seo">
        <AmericanKitchenConverterSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
