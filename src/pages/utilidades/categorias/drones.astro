---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { dronesCategory, DronesCategorySEO } from "@jjlmoya/utils-drones";

const categoryColor = "#f97316";

const utilities = await Promise.all(dronesCategory.tools.map(async (tool) => {
    const toolContent = await tool.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.icons.bg,
        iconFg: tool.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await dronesCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Herramientas y Calculadoras para Drones y Radioaficionados",
    slug: 'drones',
    icon: 'mdi:drone',
    theme: 'orange' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Herramientas y Calculadoras para Drones y Radioaficionados"}
    description={categoryContent?.description || "Optimiza tus vuelos con herramientas gratuitas online."}
    image="/images/utilities/category/drones.webp"
    utilities={utilities}
    theme="orange"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <DronesCategorySEO />
    </div>
</LayoutUtilityCategory>
