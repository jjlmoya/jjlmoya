---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { textilesCategory, textilesCategorySEO as TextilesCategorySEO, ALL_TOOLS } from "@jjlmoya/utils-textiles";

const categoryColor = "#6366f1";

const utilities = await Promise.all(ALL_TOOLS.map(async (tool) => {
    const toolContent = await tool.entry.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.entry.icons.bg,
        iconFg: tool.entry.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await textilesCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Herramientas y Guías de Ingeniería Textil y Cuidado de la Ropa",
    slug: 'textiles',
    icon: 'mdi:tshirt-crew',
    theme: 'indigo' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Herramientas y Guías de Ingeniería Textil y Cuidado de la Ropa"}
    description={categoryContent?.description || "Cuida tu ropa con base científica."}
    image="/images/utilities/category/textiles.webp"
    utilities={utilities}
    theme="indigo"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <TextilesCategorySEO />
    </div>
</LayoutUtilityCategory>
