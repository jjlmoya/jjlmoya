---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { homeCategory, homeCategorySEO as HomeCategorySEO, ALL_TOOLS } from "@jjlmoya/utils-home";

const categoryColor = "#a855f7";

const utilities = await Promise.all(ALL_TOOLS.map(async (tool) => {
    const toolContent = await tool.entry.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.entry.icons.bg,
        iconFg: tool.entry.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await homeCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Herramientas y Calculadoras para el Hogar del Futuro",
    slug: 'hogar',
    icon: 'mdi:home',
    theme: 'purple' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Herramientas y Calculadoras para el Hogar del Futuro"}
    description={categoryContent?.description || "Optimiza tu hogar con herramientas gratuitas online."}
    image="/images/utilities/category/hogar.webp"
    utilities={utilities}
    theme="purple"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <HomeCategorySEO />
    </div>
</LayoutUtilityCategory>
