---
export const prerender = true;
import { CATEGORIES } from "../../../i18n/toolRegistry";
import { loadCategory } from "../../../i18n/loadCategory";
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";

export async function getStaticPaths() {
    const paths: Array<{
        params: { categoria: string };
        props: {
            title: string;
            description: string;
            image: string;
            categoryColor: string;
            section: {
                title: string;
                slug: string;
                icon: string;
                utilities: Array<{ href: string; iconBg: string; iconFg: string; title: string; description: string; color: string }>;
            };
            CategorySEO: unknown;
        };
    }> = [];

    for (const catDef of CATEGORIES) {
        const [content, { ALL_TOOLS, CategorySEO }] = await Promise.all([
            catDef.entry.i18n.es!(),
            loadCategory(catDef.key),
        ]);

        const utilities = await Promise.all(
            ALL_TOOLS.map(async (tool) => {
                const toolContent = await tool.entry.i18n.es?.();
                return {
                    href: `/utilidades/${toolContent?.slug || "unknown"}/`,
                    iconBg: tool.entry.icons.bg,
                    iconFg: tool.entry.icons.fg,
                    title: toolContent?.title.split("|")[0].trim() || "Herramienta",
                    description: toolContent?.description || "",
                    color: catDef.color,
                };
            })
        );

        paths.push({
            params: { categoria: content.slug },
            props: {
                title: content.title,
                description: content.description,
                image: `/images/utilities/category/${content.slug}.webp`,
                categoryColor: catDef.color,
                section: {
                    title: content.title,
                    slug: content.slug,
                    icon: (catDef.entry as { icon?: string }).icon ?? "mdi:tools",
                    utilities,
                },
                CategorySEO,
            },
        });
    }

    return paths;
}

const { title, description, image, categoryColor, section, CategorySEO } = Astro.props;
const SEO = CategorySEO as unknown as (props: Record<string, unknown>) => unknown;
---

<LayoutUtilityCategory
    title={title}
    description={description}
    image={image}
    utilities={section.utilities}
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <SEO />
    </div>
</LayoutUtilityCategory>
