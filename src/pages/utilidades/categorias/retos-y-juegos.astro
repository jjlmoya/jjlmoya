---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { gamesCategory, GamesCategorySEO } from "@jjlmoya/utils-games";

const categoryColor = "#f43f5e";

const utilities = await Promise.all(gamesCategory.tools.map(async (tool) => {
    const toolContent = await tool.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.icons.bg,
        iconFg: tool.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await gamesCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Retos y Juegos",
    slug: 'retos-y-juegos',
    icon: 'mdi:trophy-variant',
    theme: 'rose' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Retos y Juegos"}
    description={categoryContent?.description || "Juegos educativos y retos para mejorar tus habilidades."}
    image={`/images/utilities/category/${categoryContent?.slug || 'retos-y-juegos'}.webp`}
    utilities={utilities}
    theme="rose"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <GamesCategorySEO />
    </div>
</LayoutUtilityCategory>
