---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { cookingSection } from "../../../data/utilities/cooking";
import { cookingCategory, CookingCategorySEO } from "@jjlmoya/utils-cooking";

const categoryContent = await cookingCategory.i18n.es?.();

const utilities = await Promise.all(
    cookingCategory.tools.map(async (tool) => {
        const toolContent = await tool.i18n.es?.();
        return {
            href: `/utilidades/${toolContent?.slug || tool.id}/`,
            iconBg: tool.icons.bg,
            iconFg: tool.icons.fg,
            title: toolContent?.title || tool.id,
            description: toolContent?.description || "",
            color: "#f97316",
        };
    })
);

const categoryColor = "#f97316";
---

<LayoutUtilityCategory
    title={categoryContent!.title}
    description={categoryContent!.description}
    image="/images/utilities/category/cocina.webp"
    utilities={utilities}
    theme={cookingSection.theme}
    categoryColor={categoryColor}
    section={cookingSection}
>
    <div slot="seo">
        <CookingCategorySEO />
    </div>
</LayoutUtilityCategory>
