---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { educationCategory, educationCategorySEO } from "@jjlmoya/utils-education";

const categoryColor = "#6366f1";

const utilities = await Promise.all(educationCategory.tools.map(async (tool) => {
    const toolContent = await tool.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.icons.bg,
        iconFg: tool.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await educationCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Herramientas y Calculadoras para Estudiantes y Educación",
    slug: 'educacion',
    icon: 'mdi:school',
    theme: 'indigo' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Herramientas y Calculadoras para Estudiantes y Educación"}
    description={categoryContent?.description || "Optimiza tu rendimiento académico con herramientas gratuitas online."}
    image="/images/utilities/category/educacion.webp"
    utilities={utilities}
    theme="indigo"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <educationCategorySEO />
    </div>
</LayoutUtilityCategory>
