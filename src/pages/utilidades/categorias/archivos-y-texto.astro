---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { filesCategory, filesCategorySEO as FilesCategorySEO, ALL_TOOLS } from "@jjlmoya/utils-files";

const categoryColor = "#3b82f6";

const utilities = await Promise.all(ALL_TOOLS.map(async (tool) => {
    const toolContent = await tool.entry.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.entry.icons.bg,
        iconFg: tool.entry.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await filesCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Herramientas y Utilidades de Archivos y Texto",
    slug: 'archivos-y-texto',
    icon: 'mdi:file-document',
    theme: 'blue' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Herramientas y Utilidades de Archivos y Texto"}
    description={categoryContent?.description || "Optimiza tu flujo de trabajo con herramientas gratuitas online."}
    image="/images/utilities/category/archivos-y-texto.webp"
    utilities={utilities}
    theme="blue"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <FilesCategorySEO />
    </div>
</LayoutUtilityCategory>
