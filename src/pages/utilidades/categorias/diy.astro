---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { diyCategorySEO as DiyCategorySEO, diyCategory } from "@jjlmoya/utils-diy";
import { diySection } from "../../../data/utilities/diy";

const categoryColor = "#2563eb";
const content = await diyCategory.i18n.es!();
---

<LayoutUtilityCategory
    title={content.title}
    description={content.description}
    image="/images/utilities/category/diy.webp"
    utilities={diySection.utilities}
    theme={diySection.theme}
    categoryColor={categoryColor}
    section={diySection}
>
    <div slot="seo">
        <DiyCategorySEO />
    </div>
</LayoutUtilityCategory>
