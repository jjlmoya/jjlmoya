---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { streamingCategorySEO as StreamingCategorySEO, streamingCategory } from "@jjlmoya/utils-streaming";
import { streamingSection } from "../../../data/utilities/streaming";

const categoryColor = "#a855f7";
const content = await streamingCategory.i18n.es!();
---

<LayoutUtilityCategory
    title={content.title}
    description={content.description}
    image="/images/utilities/category/streaming.webp"
    utilities={streamingSection.utilities}
    theme={streamingSection.theme}
    categoryColor={categoryColor}
    section={streamingSection}
>
    <div slot="seo">
        <StreamingCategorySEO />
    </div>
</LayoutUtilityCategory>
