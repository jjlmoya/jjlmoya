---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { travelCategory, TravelCategorySEO, ALL_TOOLS } from "@jjlmoya/utils-travel";

const categoryColor = "#3b82f6";

const utilities = await Promise.all(ALL_TOOLS.map(async (tool) => {
    const toolContent = await tool.entry.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.entry.icons.bg,
        iconFg: tool.entry.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await travelCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Herramientas y Calculadoras para Viajeros y Aventureros",
    slug: 'viajes',
    icon: 'mdi:map-marker-path',
    theme: 'blue' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Herramientas y Calculadoras para Viajeros y Aventureros"}
    description={categoryContent?.description || "Planifica tu próximo viaje con herramientas gratuitas online."}
    image="/images/utilities/category/viajes.webp"
    utilities={utilities}
    theme="blue"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <TravelCategorySEO />
    </div>
</LayoutUtilityCategory>
