---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { scienceCategory, ScienceCategorySEO } from "@jjlmoya/utils-science";

const categoryColor = "#f97316";

const utilities = await Promise.all(scienceCategory.tools.map(async (tool) => {
    const toolContent = await tool.i18n.es?.();
    return {
        href: `/utilidades/${toolContent?.slug || 'unknown'}/`,
        iconBg: tool.icons.bg,
        iconFg: tool.icons.fg,
        title: toolContent?.title.split('|')[0].trim() || 'Herramienta',
        description: toolContent?.description || '',
        color: categoryColor,
    };
}));

const categoryContent = await scienceCategory.i18n.es?.();

const section = {
    title: categoryContent?.title || "Herramientas y Simuladores Científicos Interactivos",
    slug: 'ciencia',
    icon: 'mdi:flask',
    theme: 'orange' as const,
    utilities,
};
---

<LayoutUtilityCategory
    title={categoryContent?.title || "Herramientas y Simuladores Científicos Interactivos"}
    description={categoryContent?.description || "Explora la ciencia con herramientas gratuitas online."}
    image="/images/utilities/category/ciencia.webp"
    utilities={utilities}
    theme="orange"
    categoryColor={categoryColor}
    section={section}
>
    <div slot="seo">
        <ScienceCategorySEO />
    </div>
</LayoutUtilityCategory>
