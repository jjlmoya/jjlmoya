---
export const prerender = true;
import LayoutUtilityCategory from "../../../layouts/LayoutUtilityCategory.astro";
import { ConvertersCategorySEO, convertersCategory } from "@jjlmoya/utils-converters";
import { converterSection } from "../../../data/utilities/converters";

const categoryColor = "#6366f1";
const content = await convertersCategory.i18n.es!();
---

<LayoutUtilityCategory
    title={content.title}
    description={content.description}
    image="/images/utilities/category/convertidores-imagen.webp"
    utilities={converterSection.utilities}
    theme={converterSection.theme}
    categoryColor={categoryColor}
    section={converterSection}
>
    <div slot="seo">
        <ConvertersCategorySEO />
    </div>
</LayoutUtilityCategory>
