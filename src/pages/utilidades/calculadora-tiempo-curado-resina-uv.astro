---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ResinCuringCalculator from "../../components/utilidades/ResinCuringCalculator/ResinCuringCalculator.astro";
import ResinCuringCalculatorSEO from "../../components/utilidades/ResinCuringCalculator/ResinCuringCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const faqItems = [
    {
        question: "¿Cuánto tiempo hay que curar la resina UV?",
        answer: "Depende de la potencia de la lámpara. Una estación de 40W suele tardar entre 2 y 4 minutos para piezas medianas, mientras que lámparas caseras pueden requerir hasta 10 minutos.",
    },
    {
        question: "¿Se puede curar resina con una lámpara de uñas?",
        answer: "Es posible si la lámpara cubre el espectro de 405nm, pero estas lámparas suelen tener potencias bajas (6W-12W), lo que alarga mucho los tiempos y puede dar un curado superficial deficiente.",
    },
    {
        question: "¿Es necesario curar la resina en agua?",
        answer: "No es obligatorio, pero es muy recomendable (Water Curing). El agua bloquea el contacto con el oxígeno, el cual inhibe la polimerización superficial, resultando en piezas menos pegajosas.",
    },
    {
        question: "¿Cómo saber si una pieza de resina está bien curada?",
        answer: "La pieza debe estar totalmente seca al tacto (no pegajosa), haber perdido el brillo 'húmedo', tener un cambio ligero de tono y carecer del fuerte olor a resina líquida.",
    },
    {
        question: "¿Por qué mi resina transparente se vuelve amarilla?",
        answer: "Es el efecto del sobre-curado o el exceso de temperatura. Usa el factor de 'Transparente' en nuestra calculadora para reducir el tiempo y evita que los LEDs estén a menos de 5cm.",
    },
    {
        question: "¿Es mejor quitar los soportes antes o después del curado?",
        answer: "Es muy recomendable quitarlos antes de meter la pieza en el horno UV. En el 'estado verde' los soportes son más blandos y dejan menos marcas superficiales al romperse.",
    },
    {
        question: "¿Puedo usar una linterna UV de mano?",
        answer: "Sí, pero es difícil conseguir un curado uniforme. Debes moverla constantemente y probablemente triplicar el tiempo calculado si la potencia es inferior a 10W.",
    },
    {
        question: "¿Qué pasa si curo la resina demasiado tiempo?",
        answer: "La resina se vuelve quebradiza y puede cambiar de color (amarillear). Es mejor curar en intervalos cortos y comprobar la pieza.",
    },
    {
        question: "¿Puedo curar resina con luz solar?",
        answer: "Sí, pero es impredecible. El sol emite UV pero la intensidad varía según la hora y nubes. La luz solar directa puede tardar de 10 a 30 minutos.",
    },
    {
        question: "¿Por qué mi pieza de resina sigue pegajosa tras el curado?",
        answer: "Puede ser por tres razones: lavado insuficiente con IPA, lámpara de baja potencia o inhibición por oxígeno. Prueba el curado sumergido en agua para eliminar la pegajosidad.",
    },
];

const sources = [
    {
        name: "Formlabs - Post-curing Resin Prints",
        url: "https://formlabs.com/blog/how-to-post-cure-3d-prints/",
    },
];
---

<LayoutUtility
    title="Calculadora de Tiempo de Curado de Resina UV | jjlmoya"
    description="Determina el tiempo exacto de curado para tus impresiones 3D en resina. Basada en potencia de lámpara W, tipo de resina y distancia. Guía técnica profesional."
    image="/images/utilities/calculadora-tiempo-curado-resina-uv.webp"
    gradientFrom="from-black"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Curado"
            titleBase="de Resina UV"
            description="Optimiza tu post-procesado con tiempos de curado precisos basados en la ciencia del ultravioleta."
            gradientFromColor="#000000"
            gradientToColor="#f97316"
        />
    </div>

    <ResinCuringCalculator />

    <div slot="seo">
        <ResinCuringCalculatorSEO />
        <Bibliography title="Fuentes y Referencias Técnicas" links={sources} />
    </div>
</LayoutUtility>
