---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import PngToWebpSEO from "../../components/utilidades/png-to-webp/PngToWebpSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const from = "png";
const to = "webp";

const title = "Convertir PNG a WebP Online y Gratis - Alta Calidad";
const description =
    "Optimiza tus imágenes PNG al nuevo estándar WebP de Google. Logra hasta el doble de compresión sin pérdida visual percibida y de forma totalmente privada.";

const faqItems = [
    {
        question: "¿Por qué convertir PNG a WebP?",
        answer: "WebP ofrece una compresión hasta un 40% superior a PNG a igual calidad, soportando también transparencias Alpha. Es el formato recomendado por Google PageSpeed Insights para mejorar la velocidad web.",
    },
    {
        question: "¿Se pierde la transparencia en el proceso?",
        answer: "No, la implementación técnica de WebP soporta el canal alfa. Si tu archivo PNG original tiene transparencias, estas se conservarán a la perfección en el nuevo archivo WebP generado localmente.",
    },
    {
        question: "¿Mis imágenes van a algún servidor?",
        answer: "No. Tu privacidad está garantizada ya que el código se ejecuta únicamente en tu navegador (Client-Side). Nunca vemos, registramos ni guardamos las imágenes que conviertes.",
    },
];

const howToSteps = [
    {
        name: "Inserta tus PNG",
        text: "Arroja tus pesados archivos PNG al área de carga o utiliza el selector tradicional interactivo.",
    },
    {
        name: "Detección de canales",
        text: "El motor de renderizado local detectará y exportará la composición de píxeles al formato WebP optimizado.",
    },
    {
        name: "Descarga Directa",
        text: "Descarga individualmente tus WebP hiper-comprimidos o llévalos juntos de un solo golpe usando el conversor a paquete ZIP.",
    },
];

const bibliography = [
    {
        name: "Google: WebP Implementation Details",
        url: "https://developers.google.com/speed/webp/",
    },
    {
        name: "W3C: Core Web Vitals Guidance",
        url: "https://web.dev/vitals/",
    },
    {
        name: "Mozilla Docs: Image Formats",
        url: "https://developer.mozilla.org/en-US/docs/Web/Media/Formats/Image_types",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-png-a-webp.webp"
    gradientFrom="from-emerald-100"
    gradientTo="to-emerald-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a WebP"
            titleBase="PNG"
            description="Optimiza tus activos visuales pesados convirtiéndolos de PNG transparente al formato hiper-comprimido WebP para mejorar brutalmente tus tiempos de carga."
            gradientFrom="from-emerald-500"
            gradientTo="to-emerald-600"
            reverse={true}
        />
    </div>

    <ImageConverter from={from} to={to} />

    <div slot="seo">
        <PngToWebpSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
