---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";
import PregnancyCalculator from "../../components/utilidades/PregnancyCalculator/PregnancyCalculator.astro";
import PregnancyCalculatorSEO from "../../components/utilidades/PregnancyCalculator/PregnancyCalculatorSEO.astro";

const titleHighlight = "Semanas de Embarazo";
const titleBase = "Calculadora de Gestación:";
const description =
    "Calcula tu semana de embarazo actual, trimestre y fecha probable de parto. Hitos del desarrollo semana a semana y guía de síntomas.";

const faqItems = [
    {
        question: "¿Cómo se cuentan las semanas de embarazo?",
        answer: "La medicina las cuenta desde el primer día de tu última regla (FUR), aunque en ese momento aún no estabas embarazada. Por eso, un embarazo completo dura 40 semanas, aunque el bebé solo tiene unas 38 semanas reales.",
    },
    {
        question: "¿Qué pasa si mis ciclos no son de 28 días?",
        answer: "Nuestra herramienta permite ajustar la duración de tu ciclo. Un ciclo más largo (ej. 35 días) significa que tu ovulación fue retrasada y tu fecha probable de parto será también más tardía.",
    },
    {
        question: "¿Es fiable la Fecha Probable de Parto?",
        answer: "Es solo una estimación estadística. Solo el 3-5% de los bebés nacen en el día exacto calculado. Lo normal es que el parto ocurra en cualquier momento entre la semana 37 y la 42.",
    },
    {
        question: "¿Por qué el ginecólogo me cambió la fecha en la ecografía?",
        answer: "A veces la fecha de última regla no es exacta. La ecografía del primer trimestre mide el tamaño del feto con precisión milimétrica y permite reasignar la edad gestacional real.",
    },
];

const howToSteps = [
    {
        name: "Introduce tu fecha",
        text: "Selecciona el primer día de tu última regla (FUR) o la fecha de concepción si la conoces con exactitud.",
    },
    {
        name: "Ajusta la duración del ciclo",
        text: "Si tus ciclos menstruales suelen durar más o menos de 28 días, indícalo para que el cálculo sea preciso.",
    },
    {
        name: "Descubre tus hitos",
        text: "Observa la comparación de tamaño de tu bebé (lenteja, limón, sandía) y qué órganos está formando hoy mismo.",
    },
    {
        name: "Guarda en el historial",
        text: "Añade la fecha probable de parto a tu Google o Apple Calendar con un solo clic.",
    },
];

const bibliographyLinks = [
    {
        name: "SEGO - Sociedad Española de Ginecología y Obstetricia",
        url: "https://sego.es/",
    },
    {
        name: "AEPED - Calendario de embarazo y cuidados",
        url: "https://enfamilia.aeped.es/edades-etapas/embarazo",
    },
];
---

<LayoutUtility
    title={`${titleHighlight}: ${titleBase}`}
    description={description}
    image="/images/utilities/calculadora-semanas-embarazo.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight={titleHighlight}
            titleBase={titleBase}
            description={description}
            gradientFromColor="#f87171"
            gradientToColor="#8b5cf6"
            reverse={true}
        />
    </div>

    <PregnancyCalculator />

    <div slot="seo">
        <PregnancyCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>

<style is:global>
    body {
        background-color: #f8fafc !important;
    }
    :global(.dark) body {
        background-color: #0f172a !important;
    }
</style>
