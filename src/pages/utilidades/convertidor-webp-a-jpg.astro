---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import WebpToJpgSEO from "../../components/utilidades/webp-to-jpg/WebpToJpgSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const from = "webp";
const to = "jpg";

const title = "Convertir WebP a JPG Online y Gratis - Sin Subir a Internet";
const description =
    "Convierte tus ficheros WebP a formato JPG de manera segura. Tecnología local que funciona en tu navegador sin límite de imágenes ni pérdida injustificada.";

const faqItems = [
    {
        question: "¿Puedo subir imágenes privadas de forma segura?",
        answer: "Sí, de hecho es el enfoque de la herramienta. No hay un servidor de 'subida'. Tu navegador procesa el WebP en tu ordenador y genera el JPG para que lo descargues. Nadie más lo ve.",
    },
    {
        question: "¿Qué ocurre con el fondo de mi WebP si es transparente?",
        answer: "Como el formato JPG no soporta transparencias, el convertidor rellenará automáticamente las zonas transparentes con un fondo blanco sólido para generar un archivo correcto en el destino.",
    },
    {
        question: "¿Hay límite de conversiones o tamaño?",
        answer: "No imponemos restricciones. Puedes convertir cientos de imágenes siempre que tu ordenador tenga la potencia y la memoria RAM suficiente para procesarlas mediante tu explorador web.",
    },
];

const howToSteps = [
    {
        name: "Arrastra tus Archivos",
        text: "Pega tus WebP modernos al área de carga o selecciónalos usando el explorador de archivos interactivo.",
    },
    {
        name: "Conversión Local",
        text: "Disfruta mientras el motor local de la utilidad aplica un fondo e interpreta cada píxel al universal JPG.",
    },
    {
        name: "Obtén tus Resultados",
        text: "Descarga individualmente o usa el paquete ZIP para consolidar todas tus nuevas fotografías en un solo fichero de descarga.",
    },
];

const bibliography = [
    {
        name: "JPEG.org: The JPEG standards",
        url: "https://jpeg.org/jpeg/",
    },
    {
        name: "Mozilla Developer Network - image/jpeg",
        url: "https://developer.mozilla.org/en-US/docs/Web/Media/Formats/Image_types#jpeg",
    },
    {
        name: "WebP to JPEG compatibility guidelines",
        url: "https://developers.google.com/speed/webp/faq",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-webp-a-jpg.webp"
    gradientFrom="from-rose-100"
    gradientTo="to-rose-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a JPG"
            titleBase="WebP"
            description="Lleva tus imágenes de última generación a un formato de máxima compatibilidad mundial como es el JPG, sin arriesgar tu privacidad."
            gradientFrom="from-rose-500"
            gradientTo="to-rose-600"
            reverse={true}
        />
    </div>

    <ImageConverter from={from} to={to} />

    <div slot="seo">
        <WebpToJpgSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
