---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import JpgToPngSEO from "../../components/utilidades/ImageConverter/seo/JpgToPngSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Convertir JPG a PNG Online y Gratis - Privado";
const description =
    "Convierte fotos JPG a formato de alta calidad PNG para evitar perdidas por compresión. Software local dentro de tu navegador con cero envíos al servidor.";

const faqItems = [
    {
        question: "¿Cuándo debería usar JPG a PNG?",
        answer: "Siempre que vayas a editar texto o logos dentro de una fotografía. Si guardas un JPG varias veces, este se ensucia. El PNG congela la compresión, dando un activo sólido a tu proyecto de diseño gráfico o web.",
    },
    {
        question: "¿El archivo PNG tendrá el fondo transparente de inmediato?",
        answer: "No. El JPG original venía plano y sin ese tipo de canal estructural. El PNG resultante en este paso preparará ese contenedor, luego deberás aislar la pieza a visualizar usando Photoshop u otro editor.",
    },
    {
        question: "¿Tiene esta web límites de tráfico?",
        answer: "Gracias a tecnologías Edge sin dependencias cloud, el peso de tu conversión no supone límites porque usa íntegramente tu terminal informático o móvil.",
    },
];

const howToSteps = [
    {
        name: "Arrastra JPG al panel",
        text: "Sube imágenes estáticas en formato JPG usando ratón táctil o selector del ordenador.",
    },
    {
        name: "Ejecución Lossless",
        text: "El software de Vanilla empuja los bits del cuadro hacia un envoltorio sin perdidas nativo de la familia PNG.",
    },
    {
        name: "Terminar Sesión",
        text: "Pulsa el panel y tu navegador depositará los activos web descargados en tus Carpetas de Usuario.",
    },
];

const bibliography = [
    {
        name: "The W3C PNG Graphics",
        url: "https://www.w3.org/Graphics/PNG/",
    },
    {
        name: "Understanding Digital Image Compression",
        url: "https://en.wikipedia.org/wiki/Image_compression",
    },
];

const converterOptions = {
    sourceFormat: "image/jpeg",
    targetFormat: "image/png",
    sourceExt: "JPG",
    from: "jpg",
    to: "png",
    dragText: "Arrastra fotografías JPG...",
    quality: 1.0,
    themeColor: "#0ea5e9",
    themeColorHover: "#0284c7",
    themeBg: "rgba(14, 165, 233, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-sky-100"
    gradientTo="to-sky-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a PNG"
            titleBase="JPG"
            description="La solución definitiva para llevar tus fotos JPG a un formato sin pérdida y listo para la edición y el diseño profesional de alto nivel."
            gradientFrom="from-sky-500"
            gradientTo="to-sky-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <JpgToPngSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
