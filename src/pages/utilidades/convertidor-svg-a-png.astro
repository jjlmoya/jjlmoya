---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import SvgToPngSEO from "../../components/utilidades/svg-to-png/SvgToPngSEO.astro";

export const prerender = true;

const from = "svg";
const to = "png";

const title = "Convertir SVG a PNG Online y Gratis - Alta Resolución";
const description =
    "Rasteriza tus vectores SVG a formato PNG al instante. Sin subidas, procesado 100% privado en tu ordenador con máxima calidad.";

const faqItems = [
    {
        question: "¿Por qué convertir archivos SVG a PNG?",
        answer: "SVG es vectorial e ideal para logos, pero a veces necesitas el formato rasterizado PNG para usarlo en aplicaciones que no soportan vectores o para enviarlos por WhatsApp o redes sociales.",
    },
    {
        question: "¿Puedo elegir el tamaño de salida?",
        answer: "Actualmente duplicamos la escala del SVG de origen para que la salida PNG sea nítida y apta para pantallas Retina o 4K.",
    },
];

const howToSteps = [
    {
        name: "Inserta tus archivos SVG",
        text: "Pega tus archivos SVG o arrástralos directamente al área superior. Verás el listado de cada archivo vectorial.",
    },
    {
        name: "Generación del PNG HD",
        text: "En milisegundos nuestro motor local recreará cada vector en una capa de píxeles HD en formato PNG transparente.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    gradientFrom="from-amber-100"
    gradientTo="to-amber-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="PNG"
            titleBase="SVG a"
            description="Lleva tus logotipos vectoriales SVG a un formato de píxeles nítido como el PNG transparente."
            gradientFrom="from-amber-500"
            gradientTo="to-amber-700"
            reverse={true}
        />
    </div>

    <ImageConverter from={from} to={to} />

    <div slot="seo">
        <SvgToPngSEO />
    </div>
</LayoutUtility>
