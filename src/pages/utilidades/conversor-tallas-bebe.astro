---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import BabySizeConverter from "../../components/utilidades/BabySizeConverter/BabySizeConverter.astro";
import BabySizeConverterSEO from "../../components/utilidades/BabySizeConverter/BabySizeConverterSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Conversor de Tallas de Bebé: Zara, H&M, Primark y más";
const description = "Calcula la talla exacta de tu bebé entre marcas de ropa. Comparativa de medidas de Zara, H&M, Carter's, Primark y Mayoral basada en altura y peso.";

const faqItems = [
    {
        question: "¿Cómo medir la altura exacta de un bebé para saber su talla?",
        answer: "Tumba al bebé sobre una superficie plana y firme. Estira suavemente sus piernas y mide desde la coronilla hasta el talón. Esta cifra en centímetros es la que utilizan marcas como Zara o H&M para definir sus tallas principales."
    },
    {
        question: "¿Por qué mi bebé usa una talla diferente en Zara y en Primark?",
        answer: "Las marcas españolas (Zara, Mayoral) suelen ser más ajustadas y pequeñas. Marcas como Primark u H&M ofrecen un corte mucho más amplio y largo, especialmente cómodo en la zona del pañal."
    },
    {
        question: "¿Es mejor guiarse por la edad en meses o por el peso?",
        answer: "El peso es siempre un indicador más fiable que la edad cronológica. Si tu bebé tiene 4 meses pero pesa 8 kilos, lo más probable es que necesite ya una talla de 6 a 9 meses."
    },
    {
        question: "¿Cómo saber si mi bebé necesita una talla 0-3 o 3-6 meses?",
        answer: "Si tu bebé mide 60 cm o más, te recomendamos pasar a la talla 3-6 meses. Aunque la 0-3 le pueda quedar bien hoy, en pocos días estará demasiado justa después de los lavados."
    }
];

const howToSteps = [
    {
        name: "Selecciona la marca",
        text: "Elige la marca de la prenda que estás mirando o la que sueles comprar habitualmente."
    },
    {
        name: "Ajusta altura y peso",
        text: "Usa los deslizadores para poner las medidas actuales de tu bebé. Es el dato definitivo para la precisión."
    },
    {
        name: "Obtén la equivalencia",
        text: "Verás automáticamente qué talla corresponde en esa marca y en el resto de la base de datos."
    }
];

const bibliographyLinks = [
    {
        name: "Organización Mundial de la Salud - Patrones de crecimiento infantil",
        url: "https://www.who.int/toolkits/child-growth-standards"
    },
    {
        name: "Guía de tallas oficial de Zara / Grupo Inditex",
        url: "https://www.zara.com/es/es/z-size-guide-mkt454.html"
    },
    {
        name: "H&M Size Guide - Baby & Kids",
        url: "https://www2.hm.com/es_es/customer-service/sizeguide.html"
    }
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/conversor-tallas-bebe.webp"
    gradientFrom="from-blue-50"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Conversor"
            titleBase="Tallas Bebé"
            description="La herramienta definitiva para padres. Convierte medidas entre marcas como Zara, H&M y Primark al instante basándote en la altura real de tu bebé."
            gradientFrom="from-blue-600"
            gradientTo="to-rose-600"
        />
    </div>

    <BabySizeConverter />

    <div slot="seo">
        <BabySizeConverterSEO category="Bebés y Embarazo" currentPath="/utilidades/conversor-tallas-bebe/" />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
