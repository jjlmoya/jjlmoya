---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import DriveDirectLink from "../../components/utilidades/drive-direct-link/DriveDirectLink.astro";
import DriveDirectLinkSEO from "../../components/utilidades/drive-direct-link/DriveDirectLinkSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Generador de Enlace de Descarga Directa para Google Drive";
const description =
    "Convierte fácilmente cualquier enlace de compartir de Google Drive en un enlace de descarga directa en un solo clic, sin pasar por la vista previa del archivo, gratis.";

const faqItems = [
    {
        question: "¿Cómo uso el conversor de descargas de Google Drive?",
        answer: "Copia el enlace completo de 'Compartir' de cualquier archivo que tengas subido a Google Drive (necesitará tener permisos públicos). Pégalo en el cuadro de nuestra herramienta y pulsa 'Generar Enlace Directo'. Aparecerá una nueva URL que iniciará la descarga sin abrir el visor de Google.",
    },
    {
        question: "¿Puedo hacer la descarga directa de un archivo privado?",
        answer: "Si el enlace generado pertenece a un documento privado o con acceso restringido en Drive, el sistema primero solicitará que te identifiques con una cuenta autorizada de Google. Para descargas limpias sin registro, la privacidad del archivo debe estar en 'Cualquier persona con el enlace puede ver'.",
    },
    {
        question: "¿Es seguro convertir mis links de Drive?",
        answer: "Sí, la conversión ocurre 100% en tu navegador y es totalmente anónima. Nuestra utilidad no almacena tu enlace, ni tu archivo, ni hace llamadas a bases de datos; únicamente analiza la estructura de texto de tu URL en el 'Client-Side' (lado del cliente) para generar la versión correcta de descarga.",
    },
    {
        question: "¿Qué pasa si mi archivo de Drive pesa mucho?",
        answer: "Cuando intentas crear un enlace de descarga directa de un archivo superior a aprox. 100 MB de peso, Google Drive por seguridad no permitirá la descarga instántanea real. En su lugar, el enlace te llevará a una página advirtiendo sobre el tamaño del archivo y el bypass en el escaneado del antivirus.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/enlace-descarga-directa-google-drive.webp"
    category="Archivos y Texto"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Enlace Directo"
            titleBase="Para Google Drive"
            description="Agrega tu link de compartir y transfórmalo en un enlace de autodescarga instantánea sin previsualizaciones."
            gradientFrom="from-green-500"
            gradientTo="to-emerald-600"
        />
    </div>

    <DriveDirectLink />

    <div slot="seo">
        <DriveDirectLinkSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Fuentes y Referencias"
            links={[
                {
                    name: "Download files from Google Drive (Google Workspace Info)",
                    url: "https://support.google.com/drive/answer/2423534",
                },
                {
                    name: "Google Drive API: Download Files",
                    url: "https://developers.google.com/drive/api/guides/manage-downloads",
                },
            ]}
        />
    </div>
</LayoutUtility>
