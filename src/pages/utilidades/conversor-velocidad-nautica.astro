---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import NauticalSpeedConverter from "../../components/utilidades/NauticalSpeedConverter/NauticalSpeedConverter.astro";
import NauticalSpeedConverterSEO from "../../components/utilidades/NauticalSpeedConverter/NauticalSpeedConverterSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
  {
    question: "¿Qué es un nudo náutico?",
    answer: "Un nudo es una unidad de velocidad que equivale a una milla náutica por hora (1.852 km/h). Es el estándar internacional para navegación marítima y aérea."
  },
  {
    question: "¿Para qué sirve la Escala Beaufort?",
    answer: "La Escala Beaufort permite estimar la velocidad del viento basándose en la observación visual de los efectos en el mar y la tierra, sin necesidad de anemómetros."
  },
  {
    question: "¿Cómo convierto nudos a km/h rápidamente?",
    answer: "Multiplica el número de nudos por 1.85 para obtener el equivalente en kilómetros por hora."
  },
  {
    question: "¿Qué significa 'Fuerza 6' en Beaufort?",
    answer: "Un viento de fuerza 6 se denomina 'fresco' (o brisa fuerte) y oscila entre 22 y 27 nudos. Genera olas grandes con crestas de espuma blanca."
  }
];

const howToSteps = [
  {
    name: "Introduce la velocidad",
    text: "Escribe el valor en nudos (kt), km/h, m/s o mph en cualquiera de los campos de entrada."
  },
  {
    name: "Obtén resultados instantáneos",
    text: "La herramienta convertirá automáticamente el valor a todas las demás unidades."
  },
  {
    name: "Consulta la Escala Beaufort",
    text: "Observa la fuerza Beaufort correspondiente, la descripción del viento y el estado del mar generado."
  },
  {
    name: "Usa la tabla de referencia",
    text: "Puedes hacer clic en cualquier fila de la tabla Beaufort para cargar automáticamente la velocidad mínima de ese nivel."
  }
];

const bibliographyLinks = [
  {
    name: "The Beaufort Scale of Wind Forces - Met Office",
    url: "https://www.metoffice.gov.uk/weather/guides/coast-and-sea/beaufort-scale"
  },
  {
    name: "International System of Units in Marine Navigation - IMO",
    url: "https://www.imo.org/"
  }
];
---

<LayoutUtility
  title="Conversor de Velocidad Náutica y Escala Beaufort | Utilidades Náuticas"
  description="Convierte velocidades entre nudos, km/h y m/s. Incluye tabla Beaufort completa con descripción del estado del mar y efectos del viento."
  faqItems={faqItems}
  howToSteps={howToSteps}
  image="/images/utilities/conversor-velocidad-nautica.webp"
>
  <div slot="header">
    <UtilityHeader 
      titleHighlight="Conversor"
      titleBase="velocidad náutica"
      description="Navegación y meteorología. Traduce entre nudos, km/h y m/s al instante. Incluye la escala completa Beaufort con descripciones visuales del estado del mar."
      gradientFrom="from-[#004F98]"
      gradientTo="to-[#00A3E0]"
    />
  </div>

  <NauticalSpeedConverter />

  <div slot="seo">
    <NauticalSpeedConverterSEO />
  </div>

  <div slot="bibliography">
    <Bibliography links={bibliographyLinks} />
  </div>
</LayoutUtility>
