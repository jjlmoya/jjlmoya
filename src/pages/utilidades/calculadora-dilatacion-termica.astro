---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import ThermalExpansionCalculator from "../../components/utilidades/ThermalExpansionCalculator/ThermalExpansionCalculator.astro";
import ThermalExpansionCalculatorSEO from "../../components/utilidades/ThermalExpansionCalculator/ThermalExpansionCalculatorSEO.astro";
import ThermalExpansionCalculatorBibliography from "../../components/utilidades/ThermalExpansionCalculator/ThermalExpansionCalculatorBibliography.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";

const faqItems = [
    {
        question: "¿Qué es el coeficiente de dilatación lineal?",
        answer: "Es una propiedad física de los materiales que indica cuánto se expande por cada grado Celsius que aumenta su temperatura. Se mide en 1/°C o °C⁻¹.",
    },
    {
        question: "¿Por qué es importante calcular la dilatación en vigas?",
        answer: "Si una viga no tiene espacio para expandirse (juntas de dilatación), generará tensiones internas masivas que pueden deformar la estructura, agrietar el hormigón o incluso causar un colapso.",
    },
    {
        question: "¿La madera dilata igual en todas direcciones?",
        answer: "No. La madera es un material anisotrópico. Dilata muy poco a lo largo de la fibra pero significativamente en sentido transversal (ancho y espesor).",
    },
    {
        question: "¿Qué temperatura debo usar como Inicial?",
        answer: "Debes usar la temperatura en el momento de la instalación o construcción. La Final debe ser la temperatura máxima esperada durante su vida útil.",
    },
];

const howToSteps = [
    {
        name: "Mide la longitud original",
        text: "Introduce la longitud de la viga o material en metros, centímetros o milímetros.",
    },
    {
        name: "Selecciona el material",
        text: "Elige entre metales, maderas o materiales de construcción para aplicar su coeficiente específico.",
    },
    {
        name: "Define el rango térmico",
        text: "Especifica la temperatura inicial y la máxima esperada para calcular el diferencial térmico.",
    },
    {
        name: "Analiza el crecimiento",
        text: "Observa el estiramiento total en milímetros y la longitud final resultante para prever juntas adecuadas.",
    },
];
---

<LayoutUtility
    title="Calculadora de Dilatación Térmica | Vigas de Acero, Madera y Hormigón"
    description="Calcula cuánto crece una viga o estructura por cambios de temperatura. Herramienta técnica para ingenieros y DIY. Incluye coeficientes de expansión por material."
    image="/images/utilities/calculadora-dilatacion-termica.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Dilatación Térmica"
            titleBase="Calculadora"
            description="Anticípate a los cambios físicos de tus materiales. Calcula la expansión lineal de vigas y estructuras para diseñar juntas de dilatación seguras."
            gradientFrom="from-orange-400"
            gradientTo="to-red-600"
            reverse={true}
        />
    </div>

    <ThermalExpansionCalculator />

    <div slot="seo">
        <ThermalExpansionCalculatorSEO />
    </div>

    <div slot="bibliography">
        <ThermalExpansionCalculatorBibliography />
    </div>
</LayoutUtility>
