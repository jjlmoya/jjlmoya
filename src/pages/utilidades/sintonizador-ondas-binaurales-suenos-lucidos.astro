---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import BinauralWaveTuner from "../../components/utilidades/BinauralWaveTuner/BinauralWaveTuner.astro";
import BinauralWaveTunerSEO from "../../components/utilidades/BinauralWaveTuner/BinauralWaveTunerSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Sintonizador de Ondas Binaurales para Sueños Lúcidos - Herramienta Online";
const description =
    "Induce sueños lúcidos y estados de relajación profunda con ondas binaurales delta, theta y alpha. Generador de frecuencias con estroboscopio visual.";

const faqItems = [
    {
        question: "¿Cómo funcionan las ondas binaurales?",
        answer: "Se presentan dos tonos de frecuencias ligeramente diferentes en cada oído. El cerebro procesa la diferencia como un tercer tono (pulso), influyendo en el estado de conciencia.",
    },
    {
        question: "¿Qué frecuencia es mejor para los sueños lúcidos?",
        answer: "El rango Theta (4-8 Hz) es el más efectivo, ya que está asociado al estado de sueño REM y la visualización creativa vívida.",
    },
    {
        question: "¿Es necesario usar auriculares?",
        answer: "Sí, es imprescindible. Para que el efecto binaural ocurra, cada oído debe recibir una señal aislada por canales separados (estéreo).",
    },
    {
        question: "¿Es peligroso escuchar estas frecuencias?",
        answer: "No para personas sanas. Sin embargo, no deben usarlas personas con epilepsia debido al estroboscopio visual y auditivo.",
    },
    {
        question: "¿Cuánto tiempo tarda en funcionar?",
        answer: "La respuesta varía, pero se recomienda practicar al menos 15-30 minutos por sesión durante una semana.",
    },
    {
        question: "¿Puedo usarlo para estudiar?",
        answer: "Sí, las frecuencias Alpha y Beta baja son excelentes para mejorar la concentración y la retención de información.",
    },
];

const howToSteps = [
    {
        name: "Conecta Auriculares",
        text: "Imprescindible para el efecto binaural estéreo.",
    },
    {
        name: "Ajusta la Frecuencia",
        text: "Selecciona el preset Theta (4.5 Hz) para inducción de sueños o Delta (1.5 Hz) para descansar mejor.",
    },
    {
        name: "Activa el Estroboscopio",
        text: "Opcional. Cierra los ojos y disfruta de los patrones visuales inducidos por los destellos de luz suave.",
    },
    {
        name: "Relájate",
        text: "Utilízalo durante 15-30 minutos antes de dormir o en técnicas de despertado tras 5 horas de sueño.",
    },
];

const bibliography = [
    {
        name: "Exploración de los sueños lúcidos",
        url: "https://amzn.to/4unHXWZ",
    },
    {
        name: "Research on Binaural Beats and Sleep Quality",
        url: "https://academic.oup.com/sleep/article/47/10/zsae097/7647043",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/sintonizador-ondas-binaurales-suenos-lucidos.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Sueños Lúcidos:"
            titleBase="Sintonizador Binaural"
            description="Explora tu subconsciente con frecuencias delta, theta y alpha diseñadas para la expansión de la conciencia y la relajación profunda."
            gradientFromColor="#4b0082"
            gradientToColor="#00bfff"
            reverse={false}
        />
    </div>

    <BinauralWaveTuner />

    <div slot="seo">
        <BinauralWaveTunerSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
