---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import HeatingSystemComparator from "../../components/utilidades/HeatingSystemComparator/HeatingSystemComparator.astro";
import HeatingSystemComparatorSEO from "../../components/utilidades/HeatingSystemComparator/HeatingSystemComparatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Comparador Gas vs. Aerotermia vs. Aire: Ahorro y Consumo";
const description =
    "Calcula cuánto ahorras al cambiar tu caldera de gas por aerotermia o bomba de calor. Comparativa real de consumo energético y eficiencia para el hogar.";

const faqItems = [
    {
        question: "¿Qué es más barato, la aerotermia o el gas natural?",
        answer: "A nivel operativo mensual, la aerotermia es significativamente más barata que el gas natural. Gracias a su eficiencia del 400% (COP de 4), el coste por kWh de calor entregado suele ser entre un 30% y un 50% menor que con gas, a pesar de que el precio del kWh eléctrico sea más alto.",
    },
    {
        question: "¿Qué diferencia hay entre aerotermia y una bomba de calor normal?",
        answer: "Técnicamente ambas son bombas de calor. La diferencia principal es el medio al que entregan el calor: la aerotermia suele ser 'aire-agua' (calienta el agua de los radiadores o suelo radiante), mientras que la bomba de calor convencional es 'aire-aire' (calienta directamente el aire mediante splits).",
    },
    {
        question: "¿Se puede instalar aerotermia en un piso con radiadores antiguos?",
        answer: "Sí, es posible instalar aerotermia con radiadores convencionales usando equipos de 'alta temperatura'. Sin embargo, para obtener el máximo ahorro posible, lo ideal es combinarla con suelo radiante o radiadores de baja temperatura, ya que trabajan con agua a menos grados.",
    },
    {
        question: "¿Cuántos años se tarda en amortizar un equipo de aerotermia?",
        answer: "Dependiendo del consumo de la vivienda y de si existen subvenciones, el tiempo de amortización suele situarse entre los 5 y 8 años. Si se cuenta con placas solares fotovoltaicas, este periodo puede reducirse drásticamente.",
    },
];

const howToSteps = [
    {
        name: "Superficie de la casa",
        text: "Introduce los metros cuadrados útiles de tu vivienda para estimar la demanda térmica anual.",
    },
    {
        name: "Precios de energía",
        text: "Ajusta los precios del Gas y la Electricidad según tu última factura para obtener un cálculo preciso.",
    },
    {
        name: "Ver resultados",
        text: "Compara los tres sistemas lado a lado y descubre cuál es el ganador en eficiencia y coste anual.",
    },
];

const bibliography = [
    {
        name: "IDAE: Guía de Bombas de Calor y Aerotermia",
        url: "https://www.idae.es/sites/default/files/documentos/publicaciones_idae/Guias_IDAE_La_Bomba_de_calor_2023_V11.pdf",
    },
    {
        name: "Portal del Consumidor: Precios de la Energía (CNMC)",
        url: "https://comparador.cnmc.gob.es/",
    },
    {
        name: "UNE: Eficiencia Energética en Edificios",
        url: "https://www.une.org/encuentra-tu-norma/busca-tu-norma/norma?c=N0060747",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/comparador-consumo-gas-aerotermia-aire.webp"
    gradientFrom="from-indigo-100"
    gradientTo="to-violet-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Gas vs. Aerotermia"
            titleBase="Comparador de Consumo"
            description="Analiza la eficiencia de tu calefacción y descubre cuánto podrías ahorrar al año cambiando de sistema."
            gradientFrom="from-indigo-500"
            gradientTo="to-violet-600"
            reverse={true}
        />
    </div>

    <HeatingSystemComparator />

    <div slot="seo">
        <HeatingSystemComparatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
