---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import JpgToIcoSEO from "../../components/utilidades/ImageConverter/seo/JpgToIcoSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Convertidor de JPG a ICO | Crea iconos oficiales para Windows y Web";
const description =
    "Transforma imágenes clásicas JPG de cámaras o descargas en auténticos archivos de icono (.ico) validados para sistemas operativos sin salir de tu navegador secreto local.";

const faqItems = [
    {
        question:
            "¿El archivo ICO que resulta es compatible nativamente para personalizar carpetas Windows?",
        answer: "Sí, creamos un archivo Microsoft Icon Format 100% auténtico insertando a bajo nivel una cabecera binaria estandarizada a la matriz de imagen. El SO de tú ordenador la tragará de manera limpia y natural y no como otros conversores web que solo cambian la extensión del nombre burdamente causando luego roturas.",
    },
    {
        question:
            "¿Qué pasa con la proporción si mi JPG original es una foto horizontal panorámica?",
        answer: "El estándar rígido global del ICO requiere obligatoriamente una imagen perfectamente cuadrada. Nuestro motor JS HTML5 centrará tu foto horizontalmente o verticalmente de forma asíncrona y recortará los excedentes garantizando un resultado equilibrado o simétrico lícito a dimensiones ideales como por ejemplo (256x256 píxeles exactos fijos).",
    },
    {
        question:
            "¿Es peligroso subir corporativos o logotipos personales JPG al conversor para mi iconografía general oficinista?",
        answer: "El motor Canvas en JavaScript descansa a la sombra ciega del escáner en tú propio explorador casero físico libre o memoria RAM celular. Convertir cientos de fotos a ICO o un bloque gigantesco no manda un solo megabyte hacia ninguna nube misteriosa en países dudosos extraños a servidor en el mundo.",
    },
];

const howToSteps = [
    {
        name: "Junta las Fotocopias JPG Originales",
        text: "Busca y acapara las fotos convencionales y deposítalas tirándolas en nuestro cuadrado amigable a prueba de demoras o estancamientos eternos de internet y VPN o conexiones caídas rurales.",
    },
    {
        name: "Observa la Purificación Hexadecimal Ciega",
        text: "La recodificación insertará nativa y velozmente los metadatos y encabezados a los cuadros centrados generando asincrónico por memoria un estricto icono puro sin dependencias lógicas.",
    },
    {
        name: "Compila Múltiples Diseños ZIP",
        text: "Termina la agotadora labor descargando todo masivamente en paquete compacto en pocos segundos, bajándote las demoras infinitas en lotes.",
    },
];

const bibliography = [
    {
        name: "Estructura Iconográfica y Uso en Sistemas ICO",
        url: "https://en.wikipedia.org/wiki/ICO_(file_format)",
    },
];

const converterOptions = {
    sourceFormat: "image/jpeg",
    targetFormat: "image/x-icon",
    sourceExt: "JPG",
    from: "jpg",
    to: "ico",
    dragText: "Arrastra enormes fotos JPG...",
    themeColor: "#8b5cf6",
    themeColorHover: "#7c3aed",
    themeBg: "rgba(139, 92, 246, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-violet-100"
    gradientTo="to-violet-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a Formato ICO"
            titleBase="Foto JPG"
            description="La ensambladora inteligente y segura que procesa fotografía general y fabrica estructuralmente el contenedor estándar global oficial de tus marcas para carpetas o Favicon web estético libre."
            gradientFrom="from-violet-500"
            gradientTo="to-violet-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <JpgToIcoSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
