---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import PetRationCalculator from "../../components/utilidades/PetRationCalculator/PetRationCalculator.astro";
import PetRationCalculatorSEO from "../../components/utilidades/PetRationCalculator/PetRationCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const bibliographyLinks = [
    {
        name: "WSAVA: Nutrition Toolkit and Calorie Recommendations",
        url: "https://wsava.org/global-guidelines/global-nutrition-guidelines/",
    },
    {
        name: "FEDIAF: Nutritional Guidelines for Complete and Complementary Pet Food",
        url: "https://fediaf.org/self-regulation/nutrition.html",
    },
];

const faqItems = [
    {
        question: "¿Qué es el RER y por qué es importante?",
        answer: "El RER (Resting Energy Requirement) es la energía mínima que tu mascota necesita para mantener sus funciones vitales básicas en reposo. Es la base científica para calcular la ración diaria evitanto el infra o sobre-alimentación.",
    },
    {
        question: "¿Cómo influye la esterilización en la ración de mi mascota?",
        answer: "Los animales esterilizados suelen tener un metabolismo basal un 15-20% más bajo. Por ello, es común que necesiten una ración ligeramente menor o un nivel de actividad ajustado a 'Baja' en la calculadora para evitar el aumento de peso.",
    },
    {
        question: "¿Puedo usar esta calculadora para cachorros?",
        answer: "Los cachorros en crecimiento tienen necesidades energéticas mucho más altas (hasta 3 veces el RER). Esta calculadora está optimizada para perros y gatos adultos. Para cachorros, consulta siempre con tu veterinario para un plan de crecimiento específico.",
    },
    {
        question: "¿Cuántas veces al día debo repartir la ración?",
        answer: "Lo ideal es repartir la cantidad total resultante en 2 o 3 tomas al día. Esto ayuda a mantener niveles de glucosa estables y mejora la digestión, especialmente en razas propensas a la torsión gástrica.",
    },
];

const howToSteps = [
    {
        name: "Selecciona la especie",
        text: "Indica si el cálculo es para un perro o un gato, ya que sus metabolismos y límites de peso varían.",
    },
    {
        name: "Ajusta el peso",
        text: "Mueve el deslizador hasta el peso actual de tu mascota en kilogramos.",
    },
    {
        name: "Define su actividad",
        text: "Elige entre actividad baja, normal o alta basándote en el ejercicio diario real que realiza tu compañero.",
    },
    {
        name: "Introduce las calorías del alimento",
        text: "Busca en el envase del pienso el valor de kcal/kg para que el cálculo en gramos sea exacto.",
    },
];
---

<LayoutUtility
    title="Calculadora de Ración Diaria para Mascotas | Nutrición Canina y Felina"
    description="Calcula la cantidad exacta de comida que necesita tu perro o gato. Herramienta basada en fórmulas veterinarias RER y DER para un peso saludable."
    image="/images/utilities/calculadora-racion-diaria-mascotas.webp"
    gradientFrom="from-amber-100"
    gradientTo="to-emerald-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Ración Diaria"
            titleBase="de Mascotas"
            description="Controla la nutrición de tu mejor amigo con precisión científica. Evita la obesidad y asegura su vitalidad."
            gradientFrom="from-amber-500"
            gradientTo="to-emerald-600"
        />
    </div>

    <PetRationCalculator />

    <div slot="seo">
        <PetRationCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
