---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import SuitcaseChecklistGenerator from "../../components/utilidades/SuitcaseChecklistGenerator/SuitcaseChecklistGenerator.astro";
import SuitcaseChecklistGeneratorSEO from "../../components/utilidades/SuitcaseChecklistGenerator/SuitcaseChecklistGeneratorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Generador de Checklist de Maleta | Crea tu lista de equipaje";
const description =
    "Genera una lista de equipaje personalizada para tu viaje en función del destino, la duración y el motivo. Checklist imprimible e interactivo.";

const faqItems = [
    {
        question: "¿Puedo guardar la lista generada?",
        answer: "Puedes marcar y desmarcar elementos de tu lista, así como utilizar el botón para imprimirla o guardarla como un archivo PDF en tu dispositivo.",
    },
    {
        question: "¿Cómo se calculan las cantidades de ropa?",
        answer: "Nuestra herramienta estima las mudas de ropa según la duración del viaje seleccionada, promoviendo viajar ligero y optimizar tu equipaje.",
    },
    {
        question: "¿Funciona para viajes con clima frío y lluvia?",
        answer: "Sí, puedes seleccionar el destino de clima frío y nieve para que el checklist incluya automáticamente artículos indispensables para esa climatología.",
    },
    {
        question: "¿Tiene la herramienta algún costo?",
        answer: "No, nuestro generador de listas de equipaje es 100% gratuito y no requiere ningún registro o descarga de aplicación adicional.",
    },
];

const howToSteps = [
    {
        name: "Define tu viaje",
        text: "Selecciona el clima, el motivo y la duración de tu escapada.",
    },
    {
        name: "Genera la lista",
        text: "Pulsa el botón y obtén al instante todas las cosas necesarias, desde cosmética hasta tecnología.",
    },
    {
        name: "Prepara la maleta",
        text: "Marca los artículos a medida que los guardes para no olvidar absolutamente nada esencial.",
    },
];

const bibliography = [
    {
        name: "KonMari - How to Pack Using the KonMari Method",
        url: "https://konmari.com/how-to-pack-using-the-konmari-method/",
    },
    {
        name: "Gentleman's Gazette - How To Pack A Suitcase For Men",
        url: "https://www.gentlemansgazette.com/how-to-pack-a-suitcase/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/generador-checklist-maleta.webp"
    gradientFrom="from-blue-100"
    gradientTo="to-indigo-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="de Maleta"
            titleBase="Generador de Checklist"
            description="La herramienta en línea definitiva para organizar tu equipaje en base a tu tipo de viaje, destino y duración. No vuelvas a olvidar tus imprescindibles de viaje."
            gradientFrom="from-blue-600"
            gradientTo="to-indigo-900"
            reverse={true}
        />
    </div>

    <SuitcaseChecklistGenerator />

    <div slot="seo">
        <SuitcaseChecklistGeneratorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
