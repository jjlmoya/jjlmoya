---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageCompressor from "../../components/utilidades/image-compressor/ImageCompressor.astro";
import ImageCompressorSEO from "../../components/utilidades/image-compressor/ImageCompressorSEO.astro";

const title = "Compresor de Imágenes y Fotos en Masa";
const description =
    "Comprime, redimensiona y optimiza el peso de tus fotos. Arrastra múltiples imágenes y ajusta su calidad individualmente. Procesado 100% privado.";

const faqItems = [
    {
        question: "¿Es verdaderamente seguro comprimir mis fotos personales o de trabajo aquí?",
        answer: "A diferencia de herramientas en la nube, el algoritmo de esta página funciona localmente. Todas tus imágenes nunca abandonan tu navegador garantizando un 100% de privacidad en archivos confidenciales.",
    },
    {
        question: "¿Cuál es el mejor balance para la compresión manual?",
        answer: "Generalmente, recomendamos rondar el 75% o el 80% del control de calidad. El ojo humano casi no nota la diferencia visual, debido a que este método retira información del color superfluo e invisible en pantallas normales, arrojando ahorros enormes en KB de tráfico.",
    },
    {
        question: "¿Existe algún tipo de límite de archivos permitidos?",
        answer: "Absolutamente ninguno. Dado que tu propio ordenador realiza el esfuerzo computacional interno, no existimos como obstáculo. Puedes agrupar, arrastrar y ajustar una o cincuenta fotos al mismo tiempo libremente.",
    },
    {
        question: "¿Por qué debería reducir el ancho de la fotografía también?",
        answer: "Las pantallas medias rondan los 1000 a 1920 píxeles horizontales. Si descargas una foto de 6000 píxeles, por mucho que la comprimas, retiene demasiados ladrillos inútiles. Ajustar el ancho máximo acorta el peso de manera gigantesca reteniendo una nitidez ideal en la web.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/compresor-imagenes.webp"
    gradientFrom="from-emerald-100"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Compresor"
            titleBase="de Imágenes"
            description="Reduce drásticamente el peso en KBs de tus fotos de golpe. Ajusta el tamaño individualmente usando HTML5 Canvas para optimizar páginas al límite."
            gradientFrom="from-emerald-500"
            gradientTo="to-teal-600"
        />
    </div>

    <ImageCompressor />

    <div slot="seo">
        <ImageCompressorSEO />
    </div>
</LayoutUtility>
