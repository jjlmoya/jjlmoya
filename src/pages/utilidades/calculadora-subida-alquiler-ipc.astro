---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import RentCalculator from "../../components/utilidades/RentCalculator/RentCalculator.astro";
import RentCalculatorSEO from "../../components/utilidades/RentCalculator/RentCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Subida de Alquiler IPC 2024-2025: Límite 3%";
const description =
    "Calcula gratis la actualización de tu renta con el IPC o el límite legal del 3% de la Ley de Vivienda. Guía completa 2024-2025 para inquilinos y caseros.";

const faqItems = [
    {
        question: "¿Cuál es la subida máxima de alquiler permitida en 2024 y 2025?",
        answer: "Según la Ley 12/2023 por el Derecho a la Vivienda, para los años 2024 y 2025, el incremento máximo anual de la renta en contratos de vivienda habitual está limitado legalmente al 3%. Esta medida prevalece sobre el IPC si este último fuera superior.",
    },
    {
        question: "¿Es obligatorio subir el alquiler todos los años con el IPC?",
        answer: "No es obligatorio por ley. Para que la renta suba, el contrato de arrendamiento debe incluir una cláusula explícita que mencione la actualización anual. Si no existe dicha cláusula, el precio pactado inicialmente debe mantenerse durante toda la vigencia del contrato.",
    },
    {
        question: "¿Con cuánta antelación debe notificar el casero la subida de la renta?",
        answer: "El arrendador debe comunicar la subida por escrito al inquilino con al menos un mes de antelación (30 días) respecto a la fecha en que deba aplicarse la nueva renta. Si se avisa más tarde, el incremento solo empezará a contar desde el mes siguiente a la notificación.",
    },
    {
        question: "¿Qué ocurre si el IPC es superior al límite legal del 3%?",
        answer: "Incluso si el IPC real publicado por el INE es del 5% o 6%, el propietario de una vivienda habitual no puede exigir legalmente una subida superior al 3% durante 2024 y 2025. Cualquier intento de cobrar de más es impugnable legalmente por el inquilino.",
    },
    {
        question: "¿A qué tipos de contratos no se aplica el límite del 3%?",
        answer: "El límite no suele aplicarse a contratos de alquiler de locales comerciales, naves industriales, oficinas o plazas de garaje independientes. Estos se rigen prioritariamente por lo que hayan pactado libremente las partes en el contrato.",
    },
];

const howToSteps = [
    {
        name: "Importe actual",
        text: "Introduce la mensualidad que pagas actualmente en tu recibo de alquiler.",
    },
    {
        name: "Modo de subida",
        text: "Elige el Tope Legal del 3% (normativa vigente) o introduce un porcentaje manual.",
    },
    {
        name: "Resultado visual",
        text: "Consulta el nuevo importe mensual y el desglose de lo que pagarás de más al año.",
    },
    {
        name: "Copiar resumen",
        text: "Genera un informe rápido para enviárselo al propietario o guardarlo en tus notas.",
    },
];

const bibliography = [
    {
        name: "Ley 12/2023 por el Derecho a la Vivienda (BOE.es)",
        url: "https://www.boe.es/buscar/act.php?id=BOE-A-2023-12203",
    },
    {
        name: "Calculadora de IPC del Instituto Nacional de Estadística (INE)",
        url: "https://www.ine.es/varipc/index.do",
    },
    {
        name: "Ley de Arrendamientos Urbanos - Texto Consolidado",
        url: "https://www.boe.es/buscar/act.php?id=BOE-A-1994-26017",
    },
    {
        name: "BOE: Medidas urgentes para la vivienda (RDL 6/2022)",
        url: "https://www.boe.es/diario_boe/txt.php?id=BOE-A-2022-5024",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-subida-alquiler-ipc.webp"
    gradientFrom="from-emerald-100"
    gradientTo="to-teal-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Subida de Alquiler"
            titleBase="Calculadora"
            description="Ajusta tu renta conforme al IPC o aplica el límite legal del 3% de la nueva Ley de Vivienda fácil y rápido."
            gradientFrom="from-emerald-500"
            gradientTo="to-teal-600"
            reverse={true}
        />
    </div>

    <RentCalculator />

    <div slot="seo">
        <RentCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
