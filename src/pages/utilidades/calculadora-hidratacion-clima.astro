---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
export const prerender = true;
import HydrationCalculator from "../../components/utilidades/HydrationCalculator/HydrationCalculator.astro";
import HydrationCalculatorSEO from "../../components/utilidades/HydrationCalculator/HydrationCalculatorSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqs = [
    {
        question: "¿Cuánta agua debo beber realmente al día?",
        answer: "No hay un número fijo. Depende fundamentalmente de tu peso y del clima. Nuestra calculadora utiliza la base científica de 35ml/kg ajustada por temperatura y humedad para darte un dato preciso.",
    },
    {
        question: "¿Es peligroso beber demasiada agua?",
        answer: "Sí, se conoce como hiponatremia. Ocurre cuando se bebe mucha agua pura en poco tiempo sin reponer sales (electrolitos), diluyendo el sodio en sangre. Por eso nuestra calculadora avisa cuando superas los 4 litros.",
    },
    {
        question: "¿Por qué influye la humedad en la hidratación?",
        answer: "Con humedad alta, el sudor no se evapora y el cuerpo no se enfría bien. Sigues sudando pero sin efecto refrigerante, lo que aumenta drásticamente la pérdida de líquidos.",
    },
    {
        question: "¿Cuándo debo usar una bebida isotónica?",
        answer: "Se recomienda cuando el esfuerzo físico supera la hora de duración o cuando la temperatura ambiente es muy elevada (>32°C), para recuperar las sales que el agua pura no aporta.",
    },
];

const howToSteps = [
    {
        name: "Ingresar Peso",
        text: "Introduce tu peso corporal actual en kilogramos para establecer la base hídrica.",
    },
    {
        name: "Ajustar Clima",
        text: "Usa el botón de clima local o introduce manualmente la temperatura y humedad.",
    },
    {
        name: "Definir Actividad",
        text: "Selecciona tu nivel de intensidad y cuánto tiempo vas a dedicar al esfuerzo.",
    },
    {
        name: "Seguir la Recomendación",
        text: "Repón líquidos según la tasa sugerida y monitoriza tu estado con la escala de orina.",
    },
];

const bibliography = [
    {
        name: "National Academies of Sciences, Engineering, and Medicine - Dietary Reference Intakes for Water",
        url: "https://www.nationalacademies.org/projects/HMD-FNB-19-P-139/publication/10925",
    },
];
---

<LayoutUtility
    title="Calculadora de Hidratación Científica según Clima y Peso"
    description="Calcula exactamente cuánta agua necesitas beber hoy. Algoritmo ajustado por temperatura ambiente, humedad relativa y nivel de actividad física."
    image="/images/utilities/calculadora-hidratacion-clima.webp"
    gradientFrom="from-sky-900"
    gradientTo="to-blue-900"
    faqItems={faqs}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Hidratación"
            titleBase="Calculadora de"
            reverse={true}
            gradientFromColor="#0ea5e9"
            gradientToColor="#0284c7"
            description="Optimiza tu rendimiento y salud con una hidratación personalizada basada en datos climáticos reales y tu fisiología."
        />
    </div>

    <HydrationCalculator />

    <div slot="seo">
        <HydrationCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
