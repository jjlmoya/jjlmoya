---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ClothingSizeConverter from "../../components/utilidades/ClothingSizeConverter/ClothingSizeConverter.astro";
import ClothingSizeConverterSEO from "../../components/utilidades/ClothingSizeConverter/ClothingSizeConverterSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Conversor de Tallas de Ropa Internacional: EU, US, UK (Hombre, Mujer, Unisex)";
const description =
    "Convierte tallas de ropa fácilmente entre sistemas EU, US, UK e IT. Camisetas, pantalones, vestidos y chaquetas. Incluye guía de medidas por marca.";

const faqItems = [
    {
        question: "¿Cuál es la diferencia entre talla EU y talla US en ropa?",
        answer: "Las tallas europeas (EU) usan números progresivos (32, 34, 36, 38, 40) mientras que las estadounidenses (US) usan letras (XS, S, M, L, XL) o números específicos para pantalones. En general, una talla 36 EU es aproximadamente un 4 US en ropa de mujer.",
    },
    {
        question: "¿Cambian las tallas si es ropa de hombre o mujer?",
        answer: "Sí, absolutamente. Incluso en el mismo país, una talla 40 para hombre no es la misma que una 40 para mujer. Los hombres tienen proporciones diferentes (hombros más anchos), así que el cálculo de talla varía.",
    },
    {
        question: "¿Cómo sé si debo subir o bajar una talla en una marca?",
        answer: "La mejor forma es revisar las reseñas de otros clientes en la tienda. Frases como 'me quedó pequeño' o 'talla grande' te dan pistas. También consulta la tabla específica de medidas de esa marca.",
    },
    {
        question: "¿Es exacta la tabla de conversión de tallas?",
        answer: "La tabla de conversión es una guía. Aunque generalmente es precisa, cada marca tiene sus propias especificaciones. Siempre verifica la tabla de tallas de la tienda específica antes de comprar.",
    },
    {
        question: "¿Encogen las prendas después de lavar?",
        answer: "Depende del material. El algodón 100% puede encoger un 5-10% si se lava a agua caliente y se seca en secadora. Los materiales sintéticos y mezclas mantienen mejor su forma. Siempre revisa las instrucciones de lavado.",
    },
];

const howToSteps = [
    {
        name: "Selecciona Prenda y Género",
        text: "Elige el tipo de ropa (camiseta, pantalón, vestido, chaqueta) y el género correspondiente.",
    },
    {
        name: "Elige Tu Sistema de Talla",
        text: "Selecciona el sistema que conoces: EU, US, UK o IT.",
    },
    {
        name: "Selecciona Tu Talla",
        text: "Elige tu talla en el selector. Puedes ver equivalencias al instante.",
    },
    {
        name: "Consulta la Guía de Marcas",
        text: "Revisa si esa marca talla pequeño, regular o grande para ajustar tu compra.",
    },
];

const bibliography = [
    {
        name: "ISO 3635: Clothing Sizes - Official Standard",
        url: "https://www.iso.org/standard/68644.html",
    },
    {
        name: "Clothing Size Standards - Wikipedia",
        url: "https://en.wikipedia.org/wiki/Clothing_size",
    },
    {
        name: "International Clothing Size Conversion",
        url: "https://en.wikipedia.org/wiki/Clothing_size#International_variations",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/conversor-tallas-ropa.webp"
    gradientFrom="from-purple-100"
    gradientTo="to-pink-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Tallas Ropa"
            titleBase="Conversor Internacional de "
            description="Encuentra tu talla perfecta en EU, US, UK e IT. Camisetas, pantalones, vestidos y chaquetas. Guía por marca incluida."
            gradientFrom="from-purple-500"
            gradientTo="to-pink-600"
            reverse={true}
        />
    </div>

    <ClothingSizeConverter />

    <div slot="seo">
        <ClothingSizeConverterSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
