---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import PromptLibrary from "../../components/utilidades/prompt-library/PromptLibrary.astro";
import PromptLibrarySEO from "../../components/utilidades/prompt-library/PromptLibrarySEO.astro";

const faqItems = [
    {
        question: "¿Dónde se guardan mis prompts?",
        answer: "Tus prompts se guardan exclusivamente en el almacenamiento local de tu navegador (localStorage). No utilizamos servidores externos, lo que significa que tus datos son 100% privados y no pueden ser vistos por nadie más que tú.",
    },
    {
        question: "¿Qué pasa si borro las cookies o el historial del navegador?",
        answer: "Si borras los datos del sitio, cookies o el almacenamiento local de tu navegador, perderás tus prompts guardados. Te recomendamos hacer copias de seguridad del texto si limpias tu navegador frecuentemente.",
    },
    {
        question: "¿Puedo usar esta herramienta para Midjourney, ChatGPT o DALL-E?",
        answer: "Sí, es compatible con cualquier tipo de instrucción de IA. Puedes crear etiquetas específicas (ej. 'midjourney', 'gpt4') para organizar tus comandos y copiarlos a tu herramienta de IA preferida fácilmente.",
    },
];
---

<LayoutUtility
    title="Biblioteca de Prompts Privada | Guarda comandos de IA localmente"
    description="Organiza, etiqueta y guarda tus prompts de ChatGPT, Midjourney y Claude de forma privada. Tu propio banco de prompts en localStorage."
    image="/images/utilities/biblioteca-prompts.webp"
    gradientFrom="from-indigo-100"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Biblioteca"
            titleBase="de Prompts"
            description="Guarda, organiza y etiqueta tus instrucciones favoritas de inteligencia artificial en un solo lugar. 100% privado en tu navegador."
            gradientFrom="from-indigo-500"
            gradientTo="to-purple-500"
        />
    </div>

    <PromptLibrary />

    <div slot="seo">
        <PromptLibrarySEO />
    </div>
</LayoutUtility>
