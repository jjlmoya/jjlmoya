---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import WebpToIcoSEO from "../../components/utilidades/ImageConverter/seo/WebpToIcoSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Convertir WebP a ICO | Instala tus Favicons y logos en Windows";
const description =
    "Desmonta los ligerísimos WebP modernos a la fiabilidad robusta y nativa del icono ICO para escritorio y metadatos de pestañas web sin requerir servicios en nube.";

const faqItems = [
    {
        question: "¿Puedo pasar diseños de stickers WebP a un Favicon ICO oficial web?",
        answer: "Exacto. El Favicon todavía demanda en lo más profundo del código internacional la clásica extensión de Microsoft ICO para compatibilidad extrema universal. Toma tu pequeño archivo dinámico local WebP y esta herramienta inyectará cabeceras binarias construyendo un icono 100% lícito, listo para usarse veloz e independientemente de forma nativa en cabeceras HTML.",
    },
    {
        question: "¿Tengo que esperar colas online al hacer mi lote enorme de iconos corporativos?",
        answer: "De ninguna manera. A diferencia de todo internet limitativo, nuestro conversor carga el Javascript y corta cualquier red de subida o espera global. Tú mismo celular CPU procesa cien fotos o más de forma asíncrona ciega a maravillas rífidas en segundos, transformando todo sin trabas externas de ADSL lenta en el extranjero remoto.",
    },
    {
        question:
            "¿Soportará las transparencias o huecos de mi WebP original el nuevo ICO resultante?",
        answer: "Así es. Dado que nuestro motor funciona internamente con el lienzo API de HTML5 a 32 bits de soporte completo (incluye capa Alpha transparente), todo agujero, borde difuminado o silueta que el WebP moderno alojaba con lujo estético saltará limpia al archivo iconográfico sin ser rellenado por bloques blancos deprimentes como los JPG.",
    },
];

const howToSteps = [
    {
        name: "Arrastra Todas Tus Pegatinas Locales WebP",
        text: "Mueve los pesados lotes fotográficos sin temor a que el límite web sature, nuestra caja mágica lo toma sin transmitirlos a nube comercial limitativa alguna.",
    },
    {
        name: "Traducción Asíncrona Lógica Y Ensamblaje Directo",
        text: "Fíjate velozmente cómo la barra y los elementos se autocompletan. La memoria procesa el bloque byte por byte del marco y elabora 22 bytes oficiales ICO.",
    },
    {
        name: "Lleva Tú Pack Para Sistemas y Desarrollo Web",
        text: "Pincha libre un botón masivo descargable en fichero conjunto o baja manual si necesitas apenas uno para salir volando con la identidad lícita final para la PC.",
    },
];

const bibliography = [
    {
        name: "Registro y Documento General Web ICO Header",
        url: "https://en.wikipedia.org/wiki/ICO_(file_format)",
    },
];

const converterOptions = {
    sourceFormat: "image/webp",
    targetFormat: "image/x-icon",
    sourceExt: "WEBP",
    from: "webp",
    to: "ico",
    dragText: "Arrastra elementos ligeros WebP...",
    themeColor: "#10b981",
    themeColorHover: "#059669",
    themeBg: "rgba(16, 185, 129, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-emerald-100"
    gradientTo="to-emerald-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a Formato de Icono"
            titleBase="Diseño WebP"
            description="La utilidad asíncrona perfecta técnica secreta libre para encuadrar ese moderno dibujo WebP Alpha en la mítica extensión universal operativa ICO para Favicon sin caídas web."
            gradientFrom="from-emerald-500"
            gradientTo="to-emerald-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <WebpToIcoSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
