---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import LegalInterestRate from "../../components/utilidades/LegalInterestRate/LegalInterestRate.astro";
import LegalInterestRateSEO from "../../components/utilidades/LegalInterestRate/LegalInterestRateSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Interés Legal del Dinero 2026 en España - Calculadora y Guía";
const description =
    "Consulta el tipo de interés legal del dinero para 2026 (3,25%). Calculadora oficial de intereses de demora, tributarios y comerciales actualizada.";

const faqItems = [
    {
        question: "¿Cuál es el interés legal del dinero en 2026?",
        answer: "El interés legal del dinero para el año 2026 en España es del 3,25%, fijado por la Ley de Presupuestos Generales del Estado.",
    },
    {
        question: "¿Qué es el interés de demora tributario?",
        answer: "Es el interés que aplica Hacienda por el retraso en el pago de impuestos. En 2026 se sitúa en el 4,0625% (normalmente redondeado a 4,06%).",
    },
    {
        question: "¿Cómo se calcula el interés legal de una deuda?",
        answer: "Se aplica la fórmula: (Principal * 3,25 * Días de retraso) / (365 * 100). El resultado es la indemnización por mora que debe pagar el deudor.",
    },
    {
        question: "¿Cuándo se aplica el interés del 10,15%?",
        answer: "Este tipo se aplica a las operaciones comerciales entre empresas (B2B) durante el primer semestre de 2026, según la Ley de lucha contra la morosidad.",
    },
];

const howToSteps = [
    {
        name: "Identifica el Capital",
        text: "Introduce la cantidad principal de la deuda o dinero pendiente sobre el que quieres calcular el interés.",
    },
    {
        name: "Cuenta los Días",
        text: "Calcula el número exacto de días transcurridos desde que venció la obligación de pago hasta la fecha actual.",
    },
    {
        name: "Aplica el Tipo",
        text: "Utiliza el 3,25% para deudas civiles o judiciales, o el 4,06% para deudas con la Agencia Tributaria.",
    },
    {
        name: "Obtén el Resultado",
        text: "Suma los intereses generados al capital principal para obtener el importe total de la liquidación.",
    },
];

const bibliography = [
    {
        name: "Banco de España - Tipos de Interés Legal",
        url: "https://clientebancario.bde.es/pcb/es/menu-horizontal/productosservici/relacionados/tiposinteres/guia-textual/tiposinteresrefe/Tabla_tipos_de_interes_legal.html",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/interes-legal-dinero-2026.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Interés Legal"
            titleBase="del Dinero 2026"
            description="Consulta y calcula los tipos de interés oficiales vigentes en España para el ejercicio 2026. Incluye interés legal, de demora tributario y comercial."
            gradientFromColor="#ff8812"
            gradientToColor="#ffd725"
        />
    </div>

    <LegalInterestRate />

    <div slot="seo">
        <LegalInterestRateSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
