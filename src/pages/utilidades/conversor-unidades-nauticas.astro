---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import NauticalConverter from "../../components/utilidades/NauticalConverter/NauticalConverter.astro";
import NauticalConverterSEO from "../../components/utilidades/NauticalConverter/NauticalConverterSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Qué es una milla náutica y en qué se diferencia de una terrestre?",
        answer: "Una milla náutica (1.852 metros) equivale a un minuto de arco de latitud sobre un meridiano. Es la unidad estándar en navegación porque permite una relación directa con las coordenadas de la carta. La milla terrestre es más corta, midiendo aproximadamente 1.609 metros.",
    },
    {
        question: "¿Por qué se mide la velocidad en nudos?",
        answer: "El nudo equivale a una milla náutica por hora. Su nombre proviene de la antigua técnica de lanzar una cuerda con nudos al agua y contar cuántos pasaban por las manos del marinero en un tiempo determinado para medir la velocidad del barco.",
    },
    {
        question: "¿Qué es una braza y dónde se sigue utilizando?",
        answer: "Una braza es una unidad de profundidad que equivale a 1.8288 metros (6 pies). Se sigue utilizando en muchas cartas náuticas antiguas o de origen británico, aunque la cartografía moderna tiende a usar metros.",
    },
    {
        question: "¿Cómo afecta la presión atmosférica a la navegación?",
        answer: "La presión atmosférica es un indicador clave del tiempo. Una caída rápida suele anunciar vientos fuertes y borrascas. Este conversor permite pasar de hectopascales a pulgadas o milímetros de mercurio para interpretar barómetros de todo tipo.",
    },
    {
        question: "¿Qué constantes de conversión utiliza esta herramienta?",
        answer: "Utilizamos los estándares internacionales: 1 nm = 1852m, 1 braza = 1.8288m, 1 nudo = 1 nm/h. La herramienta funciona 100% offline para garantizar su uso en alta mar sin cobertura.",
    },
];

const howToSteps = [
    {
        name: "Selecciona la categoría",
        text: "Elige entre Distancia, Velocidad, Profundidad o Presión usando las pestañas superiores.",
    },
    {
        name: "Introduce el valor",
        text: "Escribe el número en la unidad que ya conoces. Todos los demás campos se calcularán automáticamente al instante.",
    },
    {
        name: "Consulta escalas extras",
        text: "En la pestaña de velocidad, podrás ver automáticamente a qué fuerza de la Escala Beaufort corresponde el viento seleccionado.",
    },
    {
        name: "Copia los resultados",
        text: "Usa el botón de copia al lado de cada campo para llevarte el valor exacto a tu logbook o software de navegación.",
    },
];

const bibliographyLinks = [
    {
        name: "Instituto Hidrográfico de la Marina (IHM)",
        url: "https://armada.defensa.gob.es/ihm/",
    },
    {
        name: "Organización Hidrográfica Internacional (OHI)",
        url: "https://iho.int/",
    },
    {
        name: "NOAA - Marine Units and Conversions",
        url: "https://www.noaa.gov/",
    },
];
---

<LayoutUtility
    title="Conversor de Unidades Náuticas | Millas, Nudos y Brazas Online"
    description="Conversor completo de medidas marinas: de millas náuticas a km, de nudos a km/h y de brazas a metros. Herramienta 100% offline para navegación y PER."
    image="/images/utilities/conversor-unidades-nauticas.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Conversor"
            titleBase="de unidades náuticas"
            description="Herramienta esencial para patrones y navegantes. Convierte distancias, velocidades, profundidades y presiones atmosféricas con precisión marina y modo de alto contraste."
            gradientFrom="from-[#002b5b]"
            gradientTo="to-[#0077be]"
        />
    </div>

    <div>
        <NauticalConverter />
    </div>

    <div slot="seo">
        <NauticalConverterSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
