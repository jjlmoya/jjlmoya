---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import BloodUnitConverter from "../../components/utilidades/BloodUnitConverter/BloodUnitConverter.astro";
import BloodUnitConverterSEO from "../../components/utilidades/BloodUnitConverter/BloodUnitConverterSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Conversor de Unidades de Analítica: mg/dL a mmol/L Online";
const description =
    "Calculadora médica para convertir resultados de análisis de sangre entre mg/dL y mmol/L. Compatible con glucosa, colesterol, triglicéridos y más.";

const faqItems = [
    {
        question: "¿Qué es mg/dL?",
        answer: "Significa miligramos por decilitro. Es una unidad de medida de concentración que indica cuántos miligramos de una sustancia hay en 100 mililitros de sangre.",
    },
    {
        question: "¿Qué es mmol/L?",
        answer: "Significa milimoles por litro. Es la unidad del Sistema Internacional para medir la concentración de sustancias basada en la cantidad de moléculas (moles) por volumen.",
    },
    {
        question: "¿Por qué el factor de conversión es diferente para cada sustancia?",
        answer: "Porque el factor depende del peso molecular de la molécula. Sustancias más 'pesadas' como el colesterol requieren un divisor mayor que sustancias más 'ligeras' como la glucosa.",
    },
    {
        question: "¿Cómo paso de mmol/L a mg/dL manual?",
        answer: "Debes multiplicar el valor en mmol/L por el factor de conversión específico de la sustancia. Por ejemplo, en glucosa multiplicas por 18.016.",
    },
    {
        question: "¿Es fiable esta calculadora para diagnósticos?",
        answer: "No. Esta herramienta es puramente informativa. Los resultados deben ser interpretados siempre por un profesional médico en el contexto de tu historial clínico.",
    },
];

const howToSteps = [
    {
        name: "Selecciona la sustancia analítica",
        text: "Haz clic en el icono correspondiente a la sustancia que deseas convertir (Glucosa, Colesterol, etc.).",
    },
    {
        name: "Introduce el valor",
        text: "Escribe el número en el campo de la unidad que tengas (mg/dL o mmol/L). El sistema detectará automáticamente el cambio.",
    },
    {
        name: "Observa el resultado y contexto",
        text: "El valor convertido aparecerá al instante junto con un semáforo visual que indica si el nivel se encuentra en rangos normales o elevados.",
    },
];

const bibliography = [
    {
        name: "IFCC - Scientific Division - Conversion Factors",
        url: "https://www.ifcc.org/",
    },
    {
        name: "Mayo Clinic - Interpretación de Análisis de Sangre",
        url: "https://www.mayoclinic.org/",
    },
    {
        name: "World Health Organization (WHO) - Diabetes Diagnostic Criteria",
        url: "https://www.who.int/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/conversor-unidades-analitica-sangre.webp"
    gradientFrom="from-red-50"
    gradientTo="to-blue-50"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Conversor"
            titleBase="de Unidades Analíticas"
            description="Convierte instantáneamente tus resultados médicos entre sistemas de unidades internacionales."
            gradientFrom="from-red-600"
            gradientTo="to-blue-700"
            reverse={false}
        />
    </div>

    <BloodUnitConverter />

    <div slot="seo">
        <BloodUnitConverterSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
