---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import InstagramAudioDownloader from "../../components/utilidades/InstagramAudioDownloader/InstagramAudioDownloader.astro";
import InstagramAudioDownloaderSEO from "../../components/utilidades/InstagramAudioDownloader/InstagramAudioDownloaderSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Descargador de Reels de Instagram (Audio) - Extraer MP3 Online";
const description =
    "Descarga el audio de cualquier Instagram Reel en MP3 gratis. La herramienta más sencilla para guardar música y sonidos virales de Instagram rápidamente.";

const faqItems = [
    {
        question: "¿Puedo descargar audio de una cuenta privada?",
        answer: "No, por razones de privacidad y seguridad técnica, solo podemos procesar Reels de cuentas públicas de Instagram.",
    },
    {
        question: "¿Cómo copio el enlace de un Reel?",
        answer: "Pulsa el botón de compartir del Reel y elige la opción 'Copiar enlace' en el menú que aparece.",
    },
    {
        question: "¿Dónde se guardan los audios descargados?",
        answer: "En la carpeta de descargas predeterminada de tu navegador (Chrome, Safari, etc.) o en la app 'Archivos' si estás en un iPhone.",
    },
    {
        question: "¿Hay un límite de archivos diarios?",
        answer: "No, puedes descargar tantos audios de Reels como necesites de forma totalmente ilimitada.",
    },
];

const howToSteps = [
    {
        name: "Copiar enlace",
        text: "Busca el Reel y copia su enlace desde el menú de compartir de Instagram.",
    },
    { name: "Pegar enlace", text: "Introduce la URL en el campo de texto de nuestra utilidad." },
    {
        name: "Convertir",
        text: "Pulsa el botón de extraer para que obtengamos el audio del video.",
    },
    {
        name: "Guardar MP3",
        text: "Haz clic en descargar para bajar el archivo de sonido a tu dispositivo.",
    },
];

const bibliography = [
    { name: "Instagram Community Guidelines", url: "https://help.instagram.com/477434105621119" },
    {
        name: "What is an Instagram Reel?",
        url: "https://about.instagram.com/blog/announcements/introducing-instagram-reels",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/descargador-audio-instagram-reels.webp"
    gradientFrom="from-purple-100"
    gradientTo="to-pink-50"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Instagram Reels"
            titleBase="Descargador de Audio"
            description="Extrae y guarda los audios más virales de Instagram en formato MP3 al instante."
            gradientFrom="from-purple-600"
            gradientTo="to-pink-600"
            reverse={true}
        />
    </div>

    <InstagramAudioDownloader />

    <div slot="seo">
        <InstagramAudioDownloaderSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
