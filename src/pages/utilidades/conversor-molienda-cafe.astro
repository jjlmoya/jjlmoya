---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import GrindConverter from "../../components/utilidades/GrindConverter/GrindConverter.astro";
import GrindConverterSEO from "../../components/utilidades/GrindConverter/GrindConverterSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const bibliographyLinks = [
    {
        name: "James Hoffmann: The Ultimate Guide to Coffee Grind Size",
        url: "https://www.youtube.com/watch?v=83n7Yp_p2yM",
    },
    {
        name: "Barista Hustle: Grind Size and Extraction",
        url: "https://www.baristahustle.com/blog/the-grind-size-and-extraction/",
    },
    {
        name: "Comandante C40: Official Extraction Chart",
        url: "https://www.comandantegrinder.com/",
    },
];

const faqItems = [
    {
        question: "¿Por qué el mismo ajuste no sirve para todos los cafés?",
        answer: "La densidad del grano varía según el tueste y el origen. Un tueste claro suele requerir una molienda más fina para extraerse correctamente, mientras que uno oscuro es más poroso y necesita un grosor mayor.",
    },
    {
        question: "¿Cómo sé si debo moler más fino o más grueso?",
        answer: "Guíate por el sabor: si el café está amargo y seco, muele más grueso. Si está demasiado agrio, salado o acuoso, muele más fino para aumentar la superficie de extracción.",
    },
    {
        question: "¿Qué es la 'canalización' y cómo le afecta la molienda?",
        answer: "La canalización ocurre cuando el agua encuentra un camino de menor resistencia. Una molienda poco uniforme o inadecuada para la presión (especialmente en espresso) favorece este problema, arruinando el sabor.",
    },
];

const howToSteps = [
    {
        name: "Selecciona tu molino",
        text: "Elige tu modelo de la lista para ver los clics o niveles recomendados específicamente para tu equipo.",
    },
    {
        name: "Pulsa un método",
        text: "Selecciona la cafetera que vas a usar hoy. El centro de control se actualizará con todos los parámetros técnicos.",
    },
    {
        name: "Comprueba las micras",
        text: "Usa el valor de micras y la referencia táctil para calibrar visualmente si los clics del molino coinciden con el resultado físico.",
    },
];
---

<LayoutUtility
    title="Conversor de Molienda de Café"
    description="Tabla interactiva y guía de clics para ajustar tu molino entre Espresso, V60, Prensa Francesa y más."
    image="/images/utilities/conversor-molienda-cafe.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <UtilityHeader
        titleHighlight="Conversor de"
        titleBase="Molienda de Café"
        description="Ajusta tu molino con precisión científica. Mapeo técnico en micras y guía de clics para todos tus métodos de extracción."
        gradientFromColor="#3d2b1f"
        gradientToColor="#1a0f08"
    />

    <GrindConverter />

    <div slot="seo">
        <GrindConverterSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
