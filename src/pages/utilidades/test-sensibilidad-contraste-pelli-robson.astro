---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import PelliRobsonContrastTest from "../../components/utilidades/PelliRobsonContrastTest/PelliRobsonContrastTest.astro";
import PelliRobsonContrastTestSEO from "../../components/utilidades/PelliRobsonContrastTest/PelliRobsonContrastTestSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Test de Sensibilidad al Contraste (Pelli-Robson) - Prueba de Visión Gratuita";
const description =
    "Mide tu sensibilidad visual al contraste con el test Pelli-Robson. Diagnostica tu capacidad de detectar grises, fundamental para la conducción nocturna y salud ocular.";

const faqItems = [
    {
        question: "¿Qué es el test de Pelli-Robson?",
        answer: "Es un test clínico que mide la capacidad de distinguir niveles de gris sobre fondo blanco (contraste), a diferencia de la tabla de Snellen tradicional que solo mide agudeza visual (nitidez).",
    },
    {
        question: "¿Por qué es importante medir el contraste?",
        answer: "Muchas condiciones como las cataratas, el glaucoma o la degeneración macular afectan primero al contraste antes que a la nitidez. Es vital para detectar problemas funcionales invisibles en pruebas estándar.",
    },
    {
        question: "¿Cómo se interpretan los resultados de LogCS?",
        answer: "Se utiliza una escala logarítmica. Un valor de 2.0 indica visión perfecta. Valores por debajo de 1.50 sugieren una disfunción del contraste que puede requerir atención médica.",
    },
    {
        question: "¿Por qué veo bien las letras pequeñas pero fallo en este test?",
        answer: "Porque la nitidez (óptica) y el contraste (neural/química) son procesos distintos en tu ojo y cerebro. Puedes tener un 20/20 de agudeza pero una visión funcional deficiente en condiciones de baja luz.",
    },
    {
        question: "¿Puede mejorar la sensibilidad al contraste?",
        answer: "Sí, en algunos casos mediante el tratamiento de patologías base, el uso de filtros amarillos (lentes nocturnas) o ejercicios de terapia visual específicos.",
    },
    {
        question: "¿Cuántas veces debo repetir el test?",
        answer: "Se recomienda realizar un seguimiento cada 6 meses, especialmente si tienes más de 50 años o condiciones preexistentes como diabetes o glaucoma.",
    },
];

const howToSteps = [
    {
        name: "Ajusta la Pantalla",
        text: "Sitúa el brillo al 75% aproximadamente y evita reflejos de luz directa.",
    },
    {
        name: "Identifica la Letra",
        text: "Aparecerá una letra en el centro. Si puedes leerla con total seguridad, pulsa 'Siguiente Letra'.",
    },
    {
        name: "Acepta el Desafío",
        text: "Cada letra será más clara que la anterior. Detente cuando ya no puedas distinguir el carácter del fondo.",
    },
    {
        name: "Obtén tu Puntuación",
        text: "La herramienta calculará tu valor LogCS y te proporcionará una interpretación clínica preliminar.",
    },
];

const bibliography = [
    {
        name: "The Design of a New Letter Chart for Measuring Contrast Sensitivity (Pelli-Robson, 1988)",
        url: "https://pubmed.ncbi.nlm.nih.gov/3394630/",
    },
    {
        name: "American Academy of Ophthalmology: Contrast Sensitivity Testing",
        url: "https://www.aao.org/education/image/contrast-sensitivity-testing-5",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/test-sensibilidad-contraste-pelli-robson.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Sensibilidad"
            titleBase="al Contraste (Pelli-Robson)"
            description="Diagnóstico clínico para medir tu capacidad de detectar tonos grises, fundamental para la salud funcional de tu sistema visual."
            gradientFromColor="#1e293b"
            gradientToColor="#64748b"
            reverse={false}
        />
    </div>

    <PelliRobsonContrastTest />

    <div slot="seo">
        <PelliRobsonContrastTestSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
