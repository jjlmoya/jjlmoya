---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ScreenDecompressionTime from "../../components/utilidades/ScreenDecompressionTime/ScreenDecompressionTime.astro";
import ScreenDecompressionTimeSEO from "../../components/utilidades/ScreenDecompressionTime/ScreenDecompressionTimeSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Descompresión Ocular: Minutos de Descanso Visual";
const description =
    "Calcula los minutos de descanso visual que necesitas según horas mirando pantalla. Regla 20-20-20 personalizada para prevenir fatiga ocular.";

const faqItems = [
    {
        question: "¿Cuál es la regla 20-20-20?",
        answer: "Cada 20 minutos de trabajo ante pantalla, mira a 20 pies de distancia (aproximadamente 6-7 metros) durante 20 segundos. Esto relaja el músculo ciliar del ojo y reduce la fatiga visual significativamente.",
    },
    {
        question: "¿Cuánto descanso visual necesito si trabajo 8 horas?",
        answer: "Si trabajas 8 horas frente a pantalla, necesitas aproximadamente 16 minutos de descanso visual total distribuidos a lo largo del día. Esto equivale a 3-4 descansos de 20 segundos cada hora.",
    },
    {
        question: "¿Por qué los ojos se cansan mirando pantallas?",
        answer: "Al mirar de cerca, el músculo ciliar del ojo (responsable del enfoque) está en constante tensión. Además, parpadeamos 66% menos ante pantallas, reduciendo la lubricación ocular natural. Esto genera sequedad y fatiga acumulada.",
    },
    {
        question: "¿Son necesarias las gafas de luz azul?",
        answer: "Para trabajos menores a 4 horas no son esenciales. Entre 4-8 horas son recomendables. Para más de 8 horas, junto con descansos regulares, son prácticamente obligatorias para prevenir insomnio y estrés ocular.",
    },
    {
        question: "¿Debo consultar a un oftalmólogo si me duelen los ojos?",
        answer: "Los dolores ocasionales suelen resolverse con descansos y ajustes posturales. Consulta si el dolor persiste más de 2 semanas, hay visión borrosa persistente, o cambios súbitos en la visión.",
    },
];

const howToSteps = [
    {
        name: "Introduce tus horas",
        text: "Ingresa el número total de horas que pasas mirando pantallas diariamente en el campo de entrada.",
    },
    {
        name: "Obtén tu plan personalizado",
        text: "La calculadora genera automáticamente tu tiempo exacto de descanso visual, nivel de fatiga estimado y recomendaciones personalizadas.",
    },
    {
        name: "Implementa descansos regulares",
        text: "Configura recordatorios en tu teléfono y sigue la regla 20-20-20 según los intervalos recomendados para tu carga de trabajo.",
    },
    {
        name: "Monitorea tu mejora",
        text: "Después de 1-2 semanas siguiendo las recomendaciones, notarás reducción en sequedad, dolor de cabeza y fatiga visual.",
    },
];

const bibliography = [
    {
        name: "World Health Organization - Eye Health Recommendations",
        url: "https://www.who.int/health-topics/blindness-and-vision-loss",
    },
    {
        name: "Ofthalmology Journal - Screen Time and Ocular Fatigue Study",
        url: "https://pmc.ncbi.nlm.nih.gov/articles/PMC12707383/",
    },
    {
        name: "Mayo Clinic - Computer Vision Syndrome",
        url: "https://www.mayoclinic.org/diseases-conditions/dry-eyes/symptoms-causes/syc-20371863",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-descompresion-ocular.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Descompresión Ocular"
            titleBase="Calculadora de "
            description="Descubre cuántos minutos de descanso visual necesitas según tu exposición a pantallas"
            gradientFromColor="#06b6d4"
            gradientToColor="#0891b2"
            reverse={true}
        />
    </div>

    <ScreenDecompressionTime />

    <div slot="seo">
        <ScreenDecompressionTimeSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
