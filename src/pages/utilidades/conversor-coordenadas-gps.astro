---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import GpsCoordinatesConverter from "../../components/utilidades/GpsCoordinatesConverter/GpsCoordinatesConverter.astro";
import GpsCoordinatesConverterSEO from "../../components/utilidades/GpsCoordinatesConverter/GpsCoordinatesConverterSEO.astro";
import GpsBibliography from "../../components/utilidades/GpsCoordinatesConverter/GpsBibliography.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";

const faqItems = [
    {
        question: "¿Qué diferencia hay entre DD y GMS?",
        answer: "DD (Grados Decimales) usa un solo número con decimales (ej. 40.41). GMS (Grados, Minutos, Segundos) divide el grado en fracciones sexagesimales (ej. 40° 25' 0'').",
    },
    {
        question: "¿Por qué se usan coordenadas negativas?",
        answer: "En el sistema Decimal (DD), las latitudes al sur del Ecuador y las longitudes al oeste de Greenwich se indican con signo negativo para facilitar el cálculo matemático.",
    },
    {
        question: "¿Cuánta precisión pierdo al convertir?",
        answer: "Nuestra herramienta usa precisión de doble coma flotante. Con 6 decimales en DD, la precisión es de unos 11 centímetros, más que suficiente para drones y navegación civil.",
    },
    {
        question: "¿Funciona esta herramienta sin conexión?",
        answer: "Sí, una vez cargada la página, toda la lógica de conversión es local (client-side). Solo el mapa requiere conexión para descargar las nuevas teselas (tiles).",
    },
];

const howToSteps = [
    {
        name: "Elige el modo",
        text: "Selecciona si quieres introducir datos en formato Decimal (DD) o en Grados, Minutos y Segundos (GMS).",
    },
    {
        name: "Introduce los datos",
        text: "Escribe la latitud y longitud en los campos correspondientes. El conversor actualizará los resultados al instante.",
    },
    {
        name: "Verifica en el mapa",
        text: "Comprueba que el marcador del mapa aparece en la ubicación deseada para evitar errores de hemisferio.",
    },
    {
        name: "Copia el resultado",
        text: "Usa los botones de copiado rápido para obtener la coordenada formateada para tu GPS o software de vuelo.",
    },
];
---

<LayoutUtility
    title="Conversor Coordenadas GPS | Decimal a GMS Online Gratis"
    description="Convierte coordenadas GPS de Decimal a Grados, Minutos y Segundos (GMS) al instante. Herramienta visual con mapa para drones, náutica y geolocalización."
    image="/images/utilities/conversor-coordenadas-gps.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Conversor"
            titleBase="Coordenadas GPS"
            description="Transforma coordenadas entre formatos DD, GMS y DM de forma bidireccional. Validación visual mediante mapa interactivo para pilotos y navegantes."
            gradientFrom="from-blue-600"
            gradientTo="to-cyan-500"
        />
    </div>

    <GpsCoordinatesConverter />

    <div slot="seo">
        <GpsCoordinatesConverterSEO />
    </div>
    <div slot="bibliography">
        <GpsBibliography />
    </div>
</LayoutUtility>
