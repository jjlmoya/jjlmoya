---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import GifToPngSEO from "../../components/utilidades/ImageConverter/seo/GifToPngSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Convertir GIF a PNG Online | Extrae un fotograma estático sin pérdida";
const description =
    "Despega el primer fotograma de tus GIFs animados y conviértelo a un PNG nítido y transparente desde tu navegador web, 100% privado.";

const faqItems = [
    {
        question: "¿Por qué convertir un formato animado como GIF a un formato estático como PNG?",
        answer: "Muchas redes sociales, plataformas de foros empresariales o avatares de videojuegos y CMS no admiten fotografías que cambian, pesando y distrayendo la atención. Extraer el primer cuadro de un GIF complejo hacia un contenedor estático PNG de altísima calidad soluciona las barreras y reduce pesos inservibles en la página web final.",
    },
    {
        question: "¿Se conservan las transparencias del viejo GIF en el PNG resultante?",
        answer: "Sí, a diferencia del JPG, el formato PNG está programado para mantener sin problemas el canal alfa. Si el GIF tenía un fondo inviable o transparente, el mapa de bits lo guardará de forma similar conservando bordes nítidos sin llenarse de una plaga de color blanco molesto al centro.",
    },
    {
        question: "¿Mantienes mis imágenes en los servidores un tiempo tras el procesamiento?",
        answer: "Ningún servidor retiene tu GIF animado original o el estático en el disco; toda la extracción es local debido a la avanzada programación Web API del Canvas. Es el procesador de tu PC o celular quien en la RAM decodifica de forma segura tu archivo sin contacto con red alguna.",
    },
];

const howToSteps = [
    {
        name: "Acércanos la Animación",
        text: "Descarta el pánico a límites de red; tan solo pasa los pesadísimos archivos GIF de meme o fotogramas en el recuadro grisáceo de inserción.",
    },
    {
        name: "Foto Extraída Perfecta",
        text: "El sistema paralizará al punto de origen exacto del movimiento, sacando la copia impecable a pantalla virtual al vuelo asincrónicamente en milisegundos.",
    },
    {
        name: "Guarda tu Estático",
        text: "Almacena masivamente en lote por bloque en un ZIP universal todo aquel volumen de avatares GIFs estáticos que pasaron hacia formas PNG legibles globalmente.",
    },
];

const bibliography = [
    {
        name: "World Wide Web Consortium: PNG format",
        url: "https://www.w3.org/TR/png/",
    },
    {
        name: "CompuServe GIF Information",
        url: "https://www.w3.org/Graphics/GIF/spec-gif89a.txt",
    },
];

const converterOptions = {
    sourceFormat: "image/gif",
    targetFormat: "image/png",
    sourceExt: "GIF",
    from: "gif",
    to: "png",
    dragText: "Arrastra archivos GIF...",
    themeColor: "#db2777",
    themeColorHover: "#be185d",
    themeBg: "rgba(219, 39, 119, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-pink-100"
    gradientTo="to-pink-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a PNG estático"
            titleBase="GIF"
            description="La técnica contundente en total aislamiento local web para arrancar al origen tu meme pesado y dejar una joya estática en forma de PNG superlegible."
            gradientFrom="from-pink-500"
            gradientTo="to-pink-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <GifToPngSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
