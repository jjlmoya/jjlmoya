---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import NauticalEnduranceCalculator from "../../components/utilidades/NauticalEnduranceCalculator/NauticalEnduranceCalculator.astro";
import NauticalEnduranceCalculatorSEO from "../../components/utilidades/NauticalEnduranceCalculator/NauticalEnduranceCalculatorSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Qué es el consumo a crucero?",
        answer: "Es el consumo óptimo del motor a un régimen de revoluciones constante (generalmente al 75-80% del máximo) que permite avanzar de forma eficiente.",
    },
    {
        question: "¿Por qué el cálculo es solo teórico?",
        answer: "Porque factores externos como el estado del mar (olas contra proa), el viento de cara o el ensuciamiento de la hélice pueden aumentar el consumo hasta un 50% extra.",
    },
    {
        question: "¿Qué reserva de combustible debo dejar?",
        answer: "El estándar de seguridad náutica es del 20%, aunque para travesías largas o pasos de barras se recomienda aplicar la Regla de los Tercios (33% de reserva).",
    },
    {
        question: "¿El peso del combustible afecta a la autonomía?",
        answer: "Sí, en barcos ligeros, llevar los depósitos llenos aumenta el desplazamiento y el calado, lo que puede incrementar ligeramente el consumo por milla.",
    },
];

const howToSteps = [
    {
        name: "Capacidad del Tanque",
        text: "Introduce la capacidad total de los depósitos de combustible de tu barco en litros.",
    },
    {
        name: "Combustible Actual",
        text: "Mete los litros reales que tienes para esta travesía (o los que marcará el indicador).",
    },
    {
        name: "Mide tu Consumo",
        text: "Introduce cuánto gasta tu motor por hora a velocidad de crucero. Consulta el manual del astillero para este dato.",
    },
    {
        name: "Define tu Reserva",
        text: "Elige qué porcentaje del combustible total quieres dejar intocado por seguridad (recomendado al menos 20%).",
    },
    {
        name: "Resultados Finales",
        text: "Observa la autonomía en horas y las millas que podrás navegar sin entrar en la reserva roja.",
    },
];

const bibliographyLinks = [
    {
        name: "Nautical Safety and Fuel Management - Red Cross Marine",
        url: "https://ifrcstaysafe.org/personal-security-articles/boat-safety",
    },
    {
        name: "Fuel Consumption in Marine Engines - BoatTest.com Archive",
        url: "https://boattest.com/article/8-boat-fuel-saving-tips",
    },
];
---

<LayoutUtility
    title="Calculadora de Autonomía Náutica y Gestión de Combustible"
    description="Calcula cuánto tiempo y cuántas millas puedes navegar con el combustible de tu depósito. Análisis de consumo, alcance máximo y reserva de seguridad náutica."
    faqItems={faqItems}
    howToSteps={howToSteps}
    image="/images/utilities/calculadora-autonomia-nautica.webp"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Calculadora"
            titleBase="autonomía náutica"
            description="Seguridad y planificación de travesía. Calcula tu alcance máximo y distancia segura según consumo, capacidad y velocidad de crucero."
            gradientFrom="from-[#e01e37]"
            gradientTo="to-[#ffbe0b]"
        />
    </div>

    <NauticalEnduranceCalculator />

    <div slot="seo">
        <NauticalEnduranceCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
