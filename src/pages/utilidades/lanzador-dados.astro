---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import DiceRoller from "../../components/utilidades/DiceRoller/DiceRoller.astro";
import DiceRollerSEO from "../../components/utilidades/DiceRoller/DiceRollerSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Cómo funciona el lanzador de dados online?",
        answer: "Simplemente selecciona los dados que quieres lanzar (d4, d6, d8, d10, d12, d20 o d100), añade un modificador si lo necesitas y pulsa 'Lanzar'. La herramienta generará números aleatorios para cada dado y te dará el total sumado.",
    },
    {
        question: "¿Son realmente aleatorios los dados digitales?",
        answer: "Sí, utilizamos el generador de números pseudoaleatorios del navegador (Math.random), que proporciona una distribución uniforme y justa para todas tus tiradas de juego.",
    },
    {
        question: "¿Puedo lanzar varios dados del mismo tipo a la vez?",
        answer: "¡Por supuesto! Puedes hacer clic varias veces en el mismo botón (por ejemplo, d6) para añadir múltiples unidades del mismo dado a tu pool de lanzamiento.",
    },
    {
        question: "¿Qué es un modificador en una tirada de dados?",
        answer: "Un modificador es un número fijo que se suma o resta al resultado total de los dados. Se usa habitualmente en juegos como Dungeons & Dragons para representar bonos de habilidad o penalizaciones.",
    },
    {
        question: "¿Es compatible con el sistema d20 de D&D?",
        answer: "Sí, incluye todos los dados necesarios para el sistema d20, incluyendo el dado de 20 caras para ataques y los dados porcentuales d100 para tablas de botín.",
    },
];
---

<LayoutUtility
    title="Lanzador de Dados Online (d20, d6, d100) | Simulador de Dados 🎲"
    description="Lanzador de dados virtual para juegos de rol, DnD y juegos de mesa. d4, d6, d8, d10, d12, d20 y dados porcentuales con modificadores dinámicos."
    image="/images/utilities/lanzador-dados.webp"
    category="Relax"
    faqItems={faqItems}
    gradientFrom="from-indigo-500"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Lanzador"
            titleBase="de Dados"
            description="Tu simulador de dados definitivo para partidas de rol. Crea pools de dados personalizados, añade modificadores y deja que el azar decida tu destino."
            gradientFrom="from-indigo-500"
            gradientTo="to-blue-600"
            reverse={false}
        />
    </div>

    <DiceRoller />

    <div slot="seo">
        <DiceRollerSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Recursos para Jugadores y DMs"
            links={[
                {
                    name: "D&D Beyond: Reglas básicas de juego",
                    url: "https://www.dndbeyond.com/sources/basic-rules",
                },
                {
                    name: "Rol20: Guía de dados y probabilidad",
                    url: "https://wiki.roll20.net/Dice_Reference",
                },
                {
                    name: "Pathfinder: Simulación de tiradas críticas",
                    url: "https://aonprd.com/Rules.aspx?Name=Combat&Category=Standard%20Rules",
                },
            ]}
        />
    </div>
</LayoutUtility>
