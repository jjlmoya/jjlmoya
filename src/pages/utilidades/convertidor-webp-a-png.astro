---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import WebpToPngSEO from "../../components/utilidades/webp-to-png/WebpToPngSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const from = "webp";
const to = "png";

const title = "Convertir WebP a PNG Online y Gratis - Privado al 100%";
const description =
    "Convierte tus modernos archivos WebP a formato universal PNG de forma privada en tu navegador. Conserva las transparencias sin subirlos a internet.";

const faqItems = [
    {
        question: "¿Por qué necesito convertir mis archivos WebP a PNG?",
        answer: "A pesar de ser más ligeros, los WebP pueden causar incompatibilidades en programas de edición como Photoshop antiguo o en ciertas plataformas que requieren formatos estándar. El PNG asegura un 100% de compatibilidad garantizada universalmente.",
    },
    {
        question: "¿Se pierden las transparencias si paso de WebP a PNG?",
        answer: "No, en absoluto. A diferencia de la conversión a JPG, el PNG soporta el canal alfa. Nuestra utilidad preservará a la perfección cualquier zona transparente de tu archivo original.",
    },
    {
        question: "¿Puedo subir archivos confidenciales de mi empresa?",
        answer: "Puedes y debes. Como todo se ejecuta localmente mediante JavaScript en tu navegador, las imágenes de tu empresa nunca saldrán de tu ordenador ni se guardarán en servidores ajenos.",
    },
];

const howToSteps = [
    {
        name: "Arrastra tus WebP",
        text: "Mueve y suelta tus archivos WebP sobre el panel principal o selecciona las imágenes de forma tradicional.",
    },
    {
        name: "Conversión de Alta Fidelidad",
        text: "Tu navegador redibujará píxel a píxel la imagen y generará su copia exacta en formato PNG, manteniendo la gama de colores original.",
    },
    {
        name: "Descarga Individual o Masiva",
        text: "Guarda cada fichero suelto o, si has procesado un lote, haz clic en el botón ZIP para bajarlos todos empaquetados.",
    },
];

const bibliography = [
    {
        name: "WebP API and Library Documentation",
        url: "https://developers.google.com/speed/webp/docs/api",
    },
    {
        name: "HTML Canvas 2D Context Specification (MIME types)",
        url: "https://html.spec.whatwg.org/multipage/canvas.html",
    },
    {
        name: "Can I use: WebP image format",
        url: "https://caniuse.com/webp",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-webp-a-png.webp"
    gradientFrom="from-purple-100"
    gradientTo="to-purple-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a PNG"
            titleBase="WebP"
            description="Soluciona tus problemas de compatibilidad convirtiendo archivos WebP a PNG manteniendo su transparencia. Privado, ilimitado y local."
            gradientFrom="from-purple-500"
            gradientTo="to-purple-600"
            reverse={true}
        />
    </div>

    <ImageConverter from={from} to={to} />

    <div slot="seo">
        <WebpToPngSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
