---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import GifToWebpSEO from "../../components/utilidades/ImageConverter/seo/GifToWebpSEO.astro";

export const prerender = true;

const title = "Convertidor Demo GIF a WebP estático | Ahorra muchísimo peso offline";
const description =
    "Deshabilita las pesadas animaciones de un viejo GIF, congelando el fotograma inicial en un archivo WebP hiperligero y transparente, asíncrono y privado localmente.";

const faqItems = [
    {
        question: "¿Por qué congelar un archivo movible al formato estático moderno WebP?",
        answer: "El formato WebP es el estándar de compresión de Google; es asombrosamente ligero y retiene transparencias limpiamente. Cuando pasas de GIF a WebP con nuestra herramienta, obtienes una versión estática de la foto inicial, eliminando la pesada y lenta animación y logrando de paso una ganancia abismal en velocidad web al bajar su volumen general en un solo click.",
    },
    {
        question: "¿Seguirá siendo transparente o con agujeros el avatar del meme originario?",
        answer: "Indudablemente. Frente al JPEG, que exige un bloque blanco destructivo forzado a rellenar el lienzo, el contenedor WebP respeta religiosamente y hermosamente el complejo canal Alpha. Todas sus siluetas quedarán perfectas tal como procedían de forma nativa en tu avatar o logotipo corporativo transparente, aunque con menos color y más encogimiento.",
    },
    {
        question: "¿A dónde exactamente subirá toda la carpeta de avatares pesados para ello?",
        answer: "Se asimilarán en tu placa base conectora local (RAM o CPU) puramente virtual transitoria. Tu red ADSL, fibra o Wi-Fi descansará por completo porque el milagroso Canvas API HTML5 y tu JS V8 renderizará cada capa de la fotografía y armará los paquetes de forma paralela en centésimas detrás del escudo protector hermético del mismo navegador web que lo lee asíncrono y secreto real sin espionajes ocultos para robar los proyectos y mandarlos lejos al extranjero para el enriquecimiento y aprendizaje técnico analítico de sistemas complejos modernos que nadie en lo general de los informáticos desea nunca que te pase a tu código original.",
    },
];

const howToSteps = [
    {
        name: "Lanza Un Aluvión Animado",
        text: "Mueve y suelta decenas de memes hiper pesados, de a carpetas enteras en la zona pautada demarcadora inicial sin conexión remota ni trabas estacionales temporales de web y limitaciones de internet lento.",
    },
    {
        name: "Contempla El Magno Cambio Invisible",
        text: "Percibe enseguida una placa progresiva que cambia al milisegundo al generar el decodificador local de lienzo, extrayendo silenciosamente las imágenes a fotogramas WebP base ultralivianas para revisión visual veloz inmediata.",
    },
    {
        name: "Comprime O Guarda Tu Arsenal Resultante Limpio",
        text: "Aprisa llévate individualmente apretando los iconos azules con flecha lo extraído o presiona gigantescamente 'Descargar Zip' empaquetando todo tú archivo fotográfico de forma cómoda consolidando de bloque asíncronamente.",
    },
];

const converterOptions = {
    sourceFormat: "image/gif",
    targetFormat: "image/webp",
    sourceExt: "GIF",
    from: "gif",
    to: "webp",
    dragText: "Arrastra archivos GIF pesados...",
    themeColor: "#4f46e5",
    themeColorHover: "#4338ca",
    themeBg: "rgba(79, 70, 229, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-indigo-100"
    gradientTo="to-indigo-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a WebP Estático"
            titleBase="Meme GIF"
            description="La vía formidable y completamente local que erradica el movible bloque anticuado GIF y rescata su fotograma base inicial purificado congelando y encogiendo en WebP respetando todo su borde translúcido original puro y fiable en peso pluma real de descarga."
            gradientFrom="from-indigo-500"
            gradientTo="to-indigo-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <GifToWebpSEO />
    </div>
</LayoutUtility>
