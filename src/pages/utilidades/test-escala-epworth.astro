---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import EpworthSleepinessScale from "../../components/utilidades/EpworthSleepinessScale/EpworthSleepinessScale.astro";
import EpworthSleepinessScaleSEO from "../../components/utilidades/EpworthSleepinessScale/EpworthSleepinessScaleSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Test de Escala de Epworth - Evalúa tu Somnolencia Diurna";
const description =
    "Mide tu nivel de cansancio y somnolencia con la Escala de Epworth. Test clínico validado para detectar posibles trastornos del sueño.";

const faqItems = [
    {
        question: "¿Es la Escala de Epworth una herramienta de diagnóstico definitivo?",
        answer: "No, es una herramienta de cribado clínico. Proporciona una medida subjetiva de la somnolencia diurna, pero un diagnóstico médico requiere pruebas adicionales como la polisomnografía.",
    },
    {
        question: "¿Qué se considera una puntuación 'normal'?",
        answer: "Una puntuación de hasta 10 se considera dentro de los parámetros normales en adultos sanos. A partir de 11, se habla de somnolencia excesiva.",
    },
    {
        question: "¿Puede la somnolencia diurna ser peligrosa?",
        answer: "Sí, la somnolencia excesiva aumenta significativamente el riesgo de accidentes de tráfico y errores laborales graves, además de estar vinculada a problemas cardiovasculares.",
    },
    {
        question: "¿Qué diferencia hay entre fatiga y somnolencia?",
        answer: "La fatiga es una falta generalizada de energía, mientras que la somnolencia es la tendencia específica a quedarse dormido durante el día.",
    },
];

const howToSteps = [
    {
        name: "Analiza Situaciones Reales",
        text: "Piensa en tu comportamiento habitual durante las últimas semanas ante las situaciones propuestas.",
    },
    {
        name: "Valora la Probabilidad",
        text: "Puntúa cada situación de 0 (jamás se dormiría) a 3 (alta probabilidad de dormitar).",
    },
    {
        name: "Calcula tu Puntuación",
        text: "Suma los puntos de las 8 situaciones. El sistema lo hará automáticamente al seleccionar tus respuestas.",
    },
    {
        name: "Verifica los Rangos",
        text: "Compara tu resultado final con los criterios clínicos (Normal, Leve, Moderado o Grave).",
    },
];

const bibliography = [
    {
        name: "A new method for measuring daytime sleepiness: the Epworth sleepiness scale (Johns MW, 1991)",
        url: "https://pubmed.ncbi.nlm.nih.gov/1798888/",
    },
    {
        name: "Reliability and factor analysis of the Epworth Sleepiness Scale (Sleep, 1992)",
        url: "https://pubmed.ncbi.nlm.nih.gov/1519015/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/test-escala-epworth.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Escala"
            titleBase="de Epworth"
            description="Herramienta clínica interactiva para evaluar la somnolencia diurna excesiva y posibles trastornos del sueño mediante 8 situaciones cotidianas."
            gradientFromColor="#3b82f6"
            gradientToColor="#10b981"
        />
    </div>

    <EpworthSleepinessScale />

    <div slot="seo">
        <EpworthSleepinessScaleSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
