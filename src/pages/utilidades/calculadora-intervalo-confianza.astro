---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ConfidenceInterval from "../../components/utilidades/ConfidenceInterval/ConfidenceInterval.astro";
import ConfidenceIntervalSEO from "../../components/utilidades/ConfidenceInterval/ConfidenceIntervalSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Intervalo de Confianza y Margen de Error Online";
const description =
    "Calcula intervalos de confianza para la media de una población a partir de datos estadísticos o una lista de valores individuales. Herramienta 100% privada.";

const faqs = [
    {
        question: "¿Por qué el 95% es el nivel de confianza más usado?",
        answer: "Porque ofrece un compromiso ideal entre seguridad y un ancho de intervalo manejable. Un 95% da una certeza alta sin extender el margen de error excesivamente.",
    },
    {
        question: "¿Qué ocurre si mi muestra es pequeña (n < 30)?",
        answer: "Si n < 30, se recomienda usar la distribución t-Student. No obstante, para fines didácticos o cuando la varianza poblacional es conocida, la aproximación Z es muy cercana.",
    },
    {
        question: "¿Es lo mismo que una prueba de hipótesis?",
        answer: "Están íntimamente relacionados. Si el valor hipotético de una prueba de hipótesis cae fuera del intervalo de confianza, rechazaríamos la hipótesis nula.",
    },
    {
        question: "¿Puedo usar datos con decimales?",
        answer: "Sí, la calculadora acepta puntos o comas según tu configuración regional, permitiendo el pegado de datos reales desde Excel o Sheets sin problemas.",
    },
];

const howTo = [
    {
        name: "Selecciona el El Método de Entrada",
        text: "Elige entre 'Datos Crudos' (si tienes una lista de valores) o 'Estadísticos' (si ya conoces la media y desviación).",
    },
    {
        name: "Introduce los Parámetros",
        text: "Completa la media (\u03bc), la desviación típica (\u03c3) y el tamaño de la muestra (n) para realizar el cálculo.",
    },
    {
        name: "Ajusta la Confianza",
        text: "Selecciona el nivel de seguridad deseado (90%, 95% o 99%) para determinar el valor crítico Z* correspondiente.",
    },
    {
        name: "Analiza el Gráfico",
        text: "Revisa visualmente la campana de Gauss sombreada y los límites inferior y superior destacados en el eje X.",
    },
];

const references = [
    {
        name: "Confidence interval - Wikipedia",
        url: "https://en.wikipedia.org/wiki/Confidence_interval",
    },
    {
        name: "Intervalo de Confianza: Definición y cálculo - Statologos",
        url: "https://www.statologos.com/intervalo-de-confianza/",
    },
];
---

<LayoutUtility title={title} description={description} faqItems={faqs} howToSteps={howTo}>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Intervalo"
            titleBase=" de Confianza"
            description={description}
            gradientFromColor="#10b981"
            gradientToColor="#06b6d4"
        />
    </div>

    <ConfidenceInterval />

    <div slot="seo">
        <ConfidenceIntervalSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={references} />
    </div>
</LayoutUtility>
