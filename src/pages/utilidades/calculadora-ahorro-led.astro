---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import LedSavingCalculator from "../../components/utilidades/LedSavingCalculator/LedSavingCalculator.astro";
import LedSavingCalculatorSEO from "../../components/utilidades/LedSavingCalculator/LedSavingCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Calculadora de Ahorro LED: ¿Cuánto ahorras de luz?";
const description =
    "Calcula cuánto dinero y kWh ahorras al cambiar tus bombillas tradicionales por LED. Descubre tu ahorro anual exacto, mensual y reducción de CO2 gratis.";

const faqItems = [
    {
        question: "¿Cuánto ahorra realmente una bombilla LED?",
        answer: "Una bombilla LED ahorra entre un 80% y un 90% de energía comparada con una incandescente. Por ejemplo, pasar de 60W a 9W reduce el gasto de luz en esa lámpara casi al mínimo manteniendo el mismo brillo.",
    },
    {
        question: "¿En cuánto tiempo se amortiza el cambio a LED?",
        answer: "Debido al bajo coste actual de los LED y su gran ahorro, la inversión suele recuperarse en menos de 4 meses de uso normal. Si las luces están encendidas muchas horas, la amortización es incluso más rápida.",
    },
    {
        question: "¿Qué pasa si pongo una bombilla LED de más vatios?",
        answer: "Los LED generan muy poco calor, por lo que puedes poner bombillas de más lúmenes (brillo) en lámparas que antes estaban limitadas por el calor de las incandescentes, siempre respetando los límites eléctricos del casquillo.",
    },
    {
        question: "¿Duran realmente lo que dicen las cajas?",
        answer: "Un LED de calidad dura entre 15.000 y 50.000 horas. En un uso doméstico medio (4h/día), esto significa que una bombilla puede durar más de 15 años sin fundirse.",
    },
    {
        question: "¿Puedo usar LED en lámparas con regulador (Dimmer)?",
        answer: "Solo si la bombilla especifica claramente que es Dimmable o regulable. Los LED estándar no funcionan bien con los reguladores antiguos y pueden parpadear o zumbar.",
    },
    {
        question: "¿Sirven mis transformadores de halógenos de 12V?",
        answer: "En el caso de los focos MR16 (G5.3), a veces el transformador antiguo de los halógenos no detecta la carga tan baja de los LED y hace que parpadeen. Lo más recomendable es sustituir el transformador por uno específico para LED o cambiar el casquillo a GU10.",
    },
    {
        question: "¿Hay que cambiar toda la lámpara?",
        answer: "En el 99% de los casos, no. Solo tienes que sustituir la bombilla por una LED con el mismo casquillo (E27, E14, GU10, etc.). Solo en algunos paneles LED modernos integrados la fuente de luz está fija.",
    },
];

const howToSteps = [
    {
        name: "Cuenta tus puntos de luz",
        text: "Revisa cuántas bombillas incandescentes o halógenas tienes en casa y su potencia (W).",
    },
    {
        name: "Elige el LED equivalente",
        text: "Busca bombillas LED que ofrezcan los mismos lúmenes. Generalmente, un LED de 9W equivale a 60W.",
    },
    {
        name: "Calcula tu ahorro",
        text: "Introduce los datos en nuestra calculadora para ver el impacto en tu factura anual.",
    },
];

const bibliography = [
    {
        name: "Guía de Iluminación Eficiente - IDAE (España)",
        url: "https://www.idae.es/publicaciones/guia-tecnica-de-eficiencia-energetica-en-iluminacion-oficinas",
    },
    {
        name: "Etiquetado Energético de Lámparas - Unión Europea",
        url: "https://www.boe.es/buscar/doc.php?id=DOUE-L-2019-81875",
    },
    {
        name: "Calculadora de Consumo Eléctrico - Energía Local",
        url: "https://www.ocu.org/vivienda-y-energia/gas-luz/calculadora/consumo-stand-by",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-ahorro-led.webp"
    gradientFrom="from-amber-100"
    gradientTo="to-emerald-100"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Ahorro LED"
            titleBase="Calculadora de"
            description="Descubre cuánto dinero estás perdiendo con bombillas antiguas"
            gradientFrom="from-amber-400"
            gradientTo="to-orange-600"
            reverse={true}
        />
    </div>

    <LedSavingCalculator />

    <div slot="seo">
        <LedSavingCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
