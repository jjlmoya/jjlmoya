---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import AvifToWebpSEO from "../../components/utilidades/ImageConverter/seo/AvifToWebpSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Convertir AVIF a WebP Online - Seguridad y Velocidad";
const description =
    "Transforma imágenes AVIF a WebP, uniendo compatibilidad de última generación con pesos ultraligeros. Conversión nativa en tu dispositivo para máxima privacidad.";

const faqItems = [
    {
        question: "¿Cuál es la diferencia real entre convertir a WebP y a otros formatos?",
        answer: "WebP ofrece lo mejor de ambos mundos: compresiones tan asombrosas como el formato JPG pero conservando la capacidad de albergar transparencias limpias como un PNG. Cambiar tu AVIF, que muchos sistemas antiguos todavía prohíben, a un archivo WebP maximiza su compatibilidad para la web preservando todas sus ventajas estelares.",
    },
    {
        question: "¿Cómo logran cambiar esto sin servidor y de forma rápida?",
        answer: "La tecnología nativa de los navegadores avanza cada mes. Aprovechamos los módulos de decodificación incorporados y el objeto integrado Image de JavaScript HTML5. Esto nos permite leer tu AVIF en memoria local y extraer un archivo WebP optimizado en tiempo récord.",
    },
    {
        question: "¿Es el formato WebP completamente compatible hoy en día?",
        answer: "A diferencia del naciente AVIF, el formato WebP disfruta de un amplísimo soporte entre navegadores como Google Chrome, Firefox, Opera y Safari. Casi toda plataforma CMS como WordPress genera visualizaciones excelentes con WebP sin dar molestos errores.",
    },
];

const howToSteps = [
    {
        name: "Inserta tus archivos fotográficos",
        text: "Mueve y suelta todas las selecciones de formato AVIF desde tu repositorio interno hasta nuestro lienzo.",
    },
    {
        name: "Traducción de Bytes Algorítmicos",
        text: "Nuestro motor asimila los algoritmos cerrados sin subir nada y crea iteraciones exactas basadas en WebP comprimido.",
    },
    {
        name: "Acumula tus Descargas Listas",
        text: "Pulsa el panel y recibe lotes gigantes en cajas ZIP o sueltos para publicarlas a la inmensidad del internet directamente.",
    },
];

const bibliography = [
    {
        name: "AV1 Image File Format",
        url: "https://aomediacodec.github.io/av1-avif/",
    },
    {
        name: "Google WebP Format Overview",
        url: "https://developers.google.com/speed/webp",
    },
];

const converterOptions = {
    sourceFormat: "image/avif",
    targetFormat: "image/webp",
    sourceExt: "AVIF",
    from: "avif",
    to: "webp",
    dragText: "Arrastra archivos AVIF...",
    themeColor: "#10b981",
    themeColorHover: "#059669",
    themeBg: "rgba(16, 185, 129, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-emerald-100"
    gradientTo="to-emerald-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a WebP"
            titleBase="AVIF"
            description="La vía certera para sustituir el moderno pero esquivo AVIF por el ampliamente consolidado WebP conservando extrema ligereza bajo un ambiente libre de rastreadores web externos."
            gradientFrom="from-emerald-500"
            gradientTo="to-emerald-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <AvifToWebpSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
