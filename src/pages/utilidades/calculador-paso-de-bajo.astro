---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UnderKeelCalculator from "../../components/utilidades/UnderKeelCalculator/UnderKeelCalculator.astro";
import UnderKeelCalculatorSEO from "../../components/utilidades/UnderKeelCalculator/UnderKeelCalculatorSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Que es exactamente el paso de bajo en nautica?",
        answer: "El paso de bajo es el calculo del momento en el que hay profundidad suficiente en un punto critico (como una barra de arena o un canal estrecho) para permitir el transito seguro de una embarcacion segun su calado.",
    },
    {
        question: "¿Cuantos metros de resguardo de seguridad se recomiendan?",
        answer: "Para embarcaciones de recreo, se suele recomendar un resguardo minimo de entre 0.5 y 1 metro sobre el calado del barco. Este margen compensa posibles errores en el calculo de marea, variaciones de presion atmosferica u oleaje imprevisto.",
    },
    {
        question: "¿Como influye el oleaje en el paso de bajo?",
        answer: "El oleaje genera oscilaciones verticales en el casco (el cabeceo y balanceo). En el punto mas bajo de la ola, el barco se encuentra mas cerca del fondo que en reposo. Para cruzar zonas con olas, el resguardo debe aumentarse sustancialmente.",
    },
    {
        question: "¿Que es la sonda de la carta nautica?",
        answer: "Es la profundidad minima que encontraras en un punto cuando la marea esta en el nivel del Cero de la Carta (el Datum). Se suma a la altura de la marea en ese instante para darte la profundidad total disponible.",
    },
    {
        question: "¿Que ocurre si la sonda en la carta esta subrayada?",
        answer: "Significa que ese punto queda al descubierto (en seco) cuando la marea esta en el Cero de la Carta. Necesitaras una altura de marea mayor para poder pasar sobre el.",
    },
    {
        question: "¿Que es el efecto 'Squat' y como altera el paso?",
        answer: "Es un fenomeno hidrodinamico por el cual un barco que navega por canales poco profundos tiende a hundirse mas respecto a su linea de flotacion. Cuanto mas rapido navegues, mas aumenta el calado dinamico y menos agua tendras bajo la quilla.",
    },
];

const howToSteps = [
    {
        name: "Define el calado y el resguardo",
        text: "Mide el calado de tu barco en su punto maximo y añade un margen de seguridad prudente (por ejemplo, 0.5 m).",
    },
    {
        name: "Consulta la sonda en tu carta nautica",
        text: "Busca el valor de la sonda Datum para el paso critico que vas a navegar. Anota si es una zona de arena o roca.",
    },
    {
        name: "Introduce los datos de la marea",
        text: "Utiliza las horas y alturas de la pleamar y bajamar de la marina mas cercana obtenidas del anuario oficial.",
    },
    {
        name: "Comprueba tu ventana de paso",
        text: "La herramienta te indicara el intervalo de tiempo exacto durante el cual tendras profundidad suficiente para navegar con seguridad.",
    },
];

const bibliographyLinks = [
    {
        name: "Ministerio de Transportes - Guia Practica de Navegacion",
        url: "https://www.mitma.gob.es/marina-mercante/nautica-de-recreo/",
    },
    {
        name: "Portos de Galicia - Tablas de Mareas",
        url: "https://portosdegalicia.gal/es/taboa-de-mareas",
    },
];
---

<LayoutUtility
    title="Calculador de Paso de Bajo | Ventana de Tiempo para Navegar"
    description="Calcula si tienes agua suficiente para pasar por un punto critico segun el calado de tu barco y la sonda de la carta. Planificador de paso seguro con marea."
    image="/images/utilities/calculador-paso-de-bajo.webp"
    gradientFrom="from-slate-50"
    gradientTo="to-blue-100"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Calculador"
            titleBase="de paso de bajo"
            description="Determina la ventana de tiempo segura para cruzar barras, canales o cualquier punto de calado restringido integrando los datos de tu barco y el ciclo de marea local."
            gradientFrom="from-[#003B73]"
            gradientTo="to-[#0074B7]"
        />
    </div>

    <div>
        <UnderKeelCalculator />
    </div>

    <div slot="seo">
        <UnderKeelCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
