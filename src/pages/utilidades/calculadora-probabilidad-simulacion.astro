---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import SimulationProbabilityCalculator from "../../components/utilidades/SimulationProbabilityCalculator/SimulationProbabilityCalculator.astro";
import SimulationProbabilityCalculatorSEO from "../../components/utilidades/SimulationProbabilityCalculator/SimulationProbabilityCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora Probabilidad de Simulación - Nick Bostrom";
const description =
    "¿Vivimos en una simulación? Calcula la probabilidad basada en la hipótesis de Nick Bostrom y el progreso tecnológico futuro.";

const faqItems = [
    {
        question: "¿Qué es el argumento de la simulación?",
        answer: "Es una propuesta filosófica de Nick Bostrom que sugiere que es muy probable que vivamos en una simulación informática creada por una civilización avanzada.",
    },
    {
        question: "¿Cómo se calcula la probabilidad?",
        answer: "Se utiliza una fórmula que relaciona la proporción de civilizaciones que alcanzan un estado post-humano, el interés de estas en crear simulaciones y la cantidad de simulaciones que ejecutan.",
    },
    {
        question: "¿Es científico este modelo?",
        answer: "Aunque es de origen filosófico, utiliza razonamiento estadístico y probabilístico que ha sido debatido por físicos y cosmólogos de renombre.",
    },
];

const howToSteps = [
    {
        name: "Ajusta el Progreso",
        text: "Define la probabilidad de que la humanidad alcance la capacidad de simular la realidad.",
    },
    {
        name: "Evalúa la Supervivencia",
        text: "Estima qué tan probable es que no nos extingamos antes de lograrlo.",
    },
    {
        name: "Interés y Escala",
        text: "Determina cuántas simulaciones creería cada civilización y qué tan interesadas estarían.",
    },
];

const bibliography = [
    {
        name: "Are You Living in a Computer Simulation? - Nick Bostrom",
        url: "https://www.simulation-argument.com/simulation.html",
    },
    {
        name: "The Simulation Hypothesis - Scientific American",
        url: "https://www.scientificamerican.com/article/do-we-live-in-a-simulation-chances-are-about-50-50/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-probabilidad-simulacion.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Simulación"
            titleBase="Calculadora Probabilidad de"
            description="Estima las posibilidades de que tu realidad sea una construcción informática de una civilización avanzada."
            gradientFromColor="#00f2ff"
            gradientToColor="#7000ff"
            reverse={true}
        />
    </div>

    <SimulationProbabilityCalculator />

    <div slot="seo">
        <SimulationProbabilityCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
