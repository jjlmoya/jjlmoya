---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import CoffeeWaterCalculator from "../../components/utilidades/CoffeeWaterCalculator/CoffeeWaterCalculator.astro";
import CoffeeWaterCalculatorSEO from "../../components/utilidades/CoffeeWaterCalculator/CoffeeWaterCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const bibliographyLinks = [
    {
        name: "SCA Water Quality Standard (Specs)",
        url: "https://sca.coffee/research/coffee-standards",
    },
    {
        name: "Barista Hustle: DIY Water Recipes",
        url: "https://www.baristahustle.com/blog/diy-water-recipes-redux/",
    },
    {
        name: "The Science of Coffee Water (Hendon research)",
        url: "https://phys.org/news/2014-06-science-coffee.html",
    },
];

const faqItems = [
    {
        question: "¿Qué es el estándar de agua de la SCA?",
        answer: "La Specialty Coffee Association (SCA) define un estándar técnico para el agua utilizada en la cata y preparación de café. Este estándar sugiere niveles específicos de dureza total, alcalinidad, pH y sodio para asegurar una extracción equilibrada que ni apague los sabores ni los exagere artificialmente.",
    },
    {
        question: "¿Por qué no usar simplemente agua del grifo?",
        answer: "El agua del grifo varía drásticamente según la ciudad y la estación del año. Puede contener exceso de cloro, sedimentos o niveles de cal que destruyen el sabor del café de especialidad y dañan tu maquinaria. Mineralizar tu propia agua base (destilada o de osmosis) te da el control total y repetibilidad en cada taza.",
    },
    {
        question: "¿Dónde puedo conseguir las sales minerales?",
        answer: "Las sales más comunes (Epsom, Bicarbonato de Sodio) se encuentran en cualquier supermercado o farmacia. El Cloruro de Calcio es común en tiendas de suministros para elaboración de cerveza o queso. Asegúrate siempre de que sean de grado alimenticio.",
    },
    {
        question: "¿Es seguro para mi máquina de espresso?",
        answer: "Nuestra calculadora incluye un análisis de riesgo. El agua extremadamente pura es corrosiva para los metales, mientras que el agua muy dura genera cal. Te recomendamos mantenerte en los niveles 'SCA Ideal' o 'Barista Hustle' para un equilibrio entre longevidad del equipo y calidad del sabor.",
    },
    {
        question: "¿Qué diferencia hay entre Magnesio y Calcio?",
        answer: "A grandes rasgos, el magnesio es más eficiente extrayendo compuestos frutales y dulces, siendo muy apreciado en métodos de filtro. El calcio aporta mayor cuerpo y una textura sedosa, pero tiene un mayor riesgo de generar incrustaciones calcáreas en las calderas.",
    },
];

const howToSteps = [
    {
        name: "Consigue agua base pura",
        text: "Compra agua destilada, desmineralizada o utiliza un sistema de osmosis inversa que deje el agua a 0 ppm de sólidos disueltos.",
    },
    {
        name: "Prepara tus concentrados",
        text: "Mezcla las sales minerales en botellas de 100ml de agua destilada siguiendo las concentraciones de referencia (ej. 2.46g de sales de Epsom en 100ml).",
    },
    {
        name: "Selecciona tu perfil objetivo",
        text: "Elige entre el estándar SCA, perfiles famosos como Barista Hustle o crea tu propio perfil personalizado introduciendo los PPM deseados.",
    },
    {
        name: "Dosifica con precisión",
        text: "Añade los mililitros exactos que indica la calculadora a tu agua base. Usa una báscula de café con precisión de 0.01g para un resultado profesional.",
    },
];
---

<LayoutUtility
    title="Calculadora de Agua para Café SCA: Crea el Agua Perfecta"
    description="Calcula la mineralización exacta para tu café. Recetas SCA, Barista Hustle y Hendon. Control de Magnesio, Calcio y Bicarbonato para maximizar el sabor y proteger tu máquina."
    image="/images/utilities/calculadora-agua-cafe-sca.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
    gradientFrom="from-[#fdfaf7]"
    gradientTo="to-[#f1e6da]"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Calculadora"
            titleBase="de Agua para Café"
            description="La química del café en tus manos. Transforma agua destilada en el lienzo perfecto para tu extracción. Controla GH, KH y protege tu equipo con nuestro semáforo de seguridad."
            gradientFrom="from-[#4e342e]"
            gradientTo="to-[#795548]"
            reverse={false}
        />
    </div>

    <CoffeeWaterCalculator />

    <div slot="seo">
        <CoffeeWaterCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
