---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import AtomicReplacementCalculator from "../../components/utilidades/AtomicReplacementCalculator/AtomicReplacementCalculator.astro";
import AtomicReplacementCalculatorSEO from "../../components/utilidades/AtomicReplacementCalculator/AtomicReplacementCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Renovación Celular Atómica - ¿Cuánto queda de ti?";
const description =
    "Calcula el porcentaje de tu cuerpo que se ha renovado desde tu nacimiento. Estimación basada en la tasa de división celular de órganos, huesos y tejidos.";

const faqItems = [
    {
        question: "¿Qué es la renovación celular?",
        answer: "Es el proceso por el cual las células mueren (apoptosis) y son reemplazadas por nuevas divisiones mitóticas. Este ciclo permite reparar tejidos dañados y mantener el organismo en funcionamiento.",
    },
    {
        question: "¿Cuánto tiempo tarda el cuerpo en renovarse por completo?",
        answer: "No hay una 'renovación total' simultánea. Mientras que la sangre y la piel se renuevan en semanas o meses, el esqueleto tarda 10 años. Sin embargo, dado que el cerebro apenas se renueva, físicamente siempre conservamos una pequeña parte original.",
    },
    {
        question: "¿Qué células son las más longevas?",
        answer: "Las neuronas de la corteza cerebral, las células del cristalino y las células musculares del corazón son algunas de las más duraderas, pudiendo acompañarte durante toda tu vida.",
    },
    {
        question: "¿Soy la misma persona si mis átomos cambian?",
        answer: "Desde un punto de vista filosófico (Paradoja de Teseo), la identidad no reside en la materia específica, sino en el patrón de información y la continuidad de la conciencia que esa materia sostiene.",
    },
];

const howToSteps = [
    {
        name: "Introduce tu Edad",
        text: "Desliza el selector para ajustar los años transcurridos desde tu nacimiento.",
    },
    {
        name: "Analiza el Porcentaje",
        text: "Observa la estadística principal que indica cuánta de tu materia física actual es nueva.",
    },
    {
        name: "Consulta por Tejidos",
        text: "Revisa las barras de progreso para ver la tasa de renovación específica de piel, huesos, órganos y cerebro.",
    },
    {
        name: "Descubre tus Datos",
        text: "Lee la información detallada para entender qué partes de ti son eternas y cuáles son efímeras.",
    },
];

const bibliography = [
    {
        name: "The distribution of cellular turnover in the human body (Sender & Milo, 2021)",
        url: "https://www.nature.com/articles/s41591-020-01182-9",
    },
    {
        name: "Retrospective birth dating of cells in humans (Spalding et al., 2005)",
        url: "https://pubmed.ncbi.nlm.nih.gov/16023133/",
    },
    {
        name: "Stanford Encyclopedia of Philosophy: The Ship of Theseus",
        url: "https://plato.stanford.edu/entries/identity-relative/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-renovacion-celular.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Renovación"
            titleBase="Calculadora de"
            description="Estima cuánta parte de tu materia física actual ha sido reemplazada por nuevos átomos desde que naciste."
            gradientFromColor="#f43f5e"
            gradientToColor="#8b5cf6"
            reverse={true}
        />
    </div>

    <AtomicReplacementCalculator />

    <div slot="seo">
        <AtomicReplacementCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
