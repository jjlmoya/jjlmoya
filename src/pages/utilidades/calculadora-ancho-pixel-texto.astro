---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import TextPixelCalculator from "../../components/utilidades/TextPixelCalculator/TextPixelCalculator.astro";
import TextPixelCalculatorSEO from "../../components/utilidades/TextPixelCalculator/TextPixelCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Cómo calcular el ancho de un texto en píxeles online?",
        answer: "Pega tu texto en el cuadro de entrada, configura la fuente y el tamaño, y la herramienta usará automáticamente la API de Canvas del navegador para devolverte el ancho exacto en píxeles.",
    },
    {
        question: "¿Por qué el ancho en píxeles varía entre tipografías?",
        answer: "La mayoría de las fuentes son proporcionales, lo que significa que cada carácter tiene un ancho distinto. Por ejemplo, una 'M' mayúscula siempre será más ancha que una 'i' minúscula en una fuente sans-serif estándar.",
    },
    {
        question: "¿Es lo mismo medir caracteres que medir píxeles?",
        answer: "No. Medir caracteres te da la longitud de la cadena, mientras que medir píxeles te da el espacio visual que ocupa. Esto es crucial para asegurar que el texto no se salga de su contenedor en un diseño web.",
    },
    {
        question: "¿Puedo usar cualquier fuente de Google Fonts?",
        answer: "Sí, siempre que la fuente esté instalada en tu sistema operativo o cargada en la página actual, la utilidad podrá medir sus dimensiones con precisión milimétrica.",
    },
    {
        question: "¿Es seguro procesar fragmentos de código o textos privados?",
        answer: "Sí. Nuestra calculadora funciona íntegramente de forma local (client-side). Ningún dato se envía a servidores externos, garantizando una privacidad absoluta para tus proyectos.",
    },
];
---

<LayoutUtility
    title="Calculadora de Ancho de Píxel de Texto | Medidor Visual ⚡"
    description="Calcula con precisión cuánto ancho ocupa cualquier texto en píxeles según su tipografía, tamaño y estilo. Herramienta gratuita para diseñadores y desarrolladores."
    image="/images/utilities/calculadora-ancho-pixel-texto.webp"
    category="Herramientas Prácticas"
    faqItems={faqItems}
    gradientFrom="from-cyan-500"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Ancho de Píxel"
            titleBase="de Texto"
            description="Mide con exactitud el espacio horizontal que ocupan tus palabras. Ideal para optimizar interfaces, evitar desbordamiento de contenedores y mejorar el diseño visual."
            gradientFrom="from-cyan-500"
            reverse={false}
        />
    </div>

    <TextPixelCalculator />

    <div slot="seo">
        <TextPixelCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Fuentes y Referencias Técnicas"
            links={[
                {
                    name: "W3C: Gestión de la tipografía y el renderizado de texto",
                    url: "https://www.w3.org/TR/css-text-3/",
                },
                {
                    name: "Google Fonts: Entendiendo las fuentes variables",
                    url: "https://fonts.google.com/knowledge/glossary/variable_fonts",
                },
            ]}
        />
    </div>
</LayoutUtility>
