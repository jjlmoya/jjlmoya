---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import TextSplitter from "../../components/utilidades/TextSplitter/TextSplitter.astro";
import TextSplitterSEO from "../../components/utilidades/TextSplitter/TextSplitterSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Cómo separar una lista por comas online?",
        answer: "Pega tu lista en el cuadro de texto, selecciona la opción 'Coma (,)' como delimitador y obtendrás automáticamente un elemento por línea en el área de resultados.",
    },
    {
        question: "¿Qué es un convertidor de comas a saltos de línea?",
        answer: "Es una herramienta digital que transforma cadenas de texto separadas por signos de puntuación en listados verticales organizados, facilitando el procesamiento de datos en hojas de cálculo o bases de datos.",
    },
    {
        question: "¿Puedo separar texto por otros caracteres?",
        answer: "Sí, la utilidad permite utilizar punto y coma, espacios en blanco o cualquier otro carácter personalizado que definas manualmente.",
    },
    {
        question: "¿Es seguro procesar listados de correos electrónicos?",
        answer: "Totalmente. Al ser una herramienta client-side, todo el procesamiento ocurre localmente en tu navegador. Tus datos e información privada nunca son enviados a ningún servidor externo.",
    },
    {
        question: "¿La herramienta permite eliminar elementos duplicados?",
        answer: "Sí, cuenta con una opción específica para limpiar la lista final de cualquier elemento repetido, asegurando que cada línea sea única.",
    },
];
---

<LayoutUtility
    title="Separador de Texto Online | Convertidor de Listas a Líneas"
    description="Divide listas separadas por comas, espacios o puntos en líneas individuales al instante. Herramienta gratuita para limpiar y organizar datos online."
    image="/images/utilities/separador-texto.webp"
    category="Archivos y Texto"
    faqItems={faqItems}
    gradientFrom="from-purple-500"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Separador"
            titleBase="de Texto"
            description="Divide listas, comas o cualquier delimitador en líneas individuales de forma automática. Organiza tus datos, elimina duplicados y formatea listas al instante."
            gradientFrom="from-purple-500"
            gradientTo="to-indigo-600"
            reverse={false}
        />
    </div>

    <TextSplitter />

    <div slot="seo">
        <TextSplitterSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Fuentes y Referencias"
            links={[
                {
                    name: "MDN: String.prototype.split()",
                    url: "https://developer.mozilla.org/es/docs/Web/JavaScript/Reference/Global_Objects/String/split",
                },
                {
                    name: "Guía de formatos CSV y delimitadores comunes",
                    url: "https://es.wikipedia.org/wiki/Valores_separados_por_comas",
                },
                {
                    name: "Gestión de listas y duplicados en JavaScript",
                    url: "https://developer.mozilla.org/es/docs/Web/JavaScript/Reference/Global_Objects/Set",
                },
            ]}
        />
    </div>
</LayoutUtility>
