---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import PeripheralVisionTrainer from "../../components/utilidades/PeripheralVisionTrainer/PeripheralVisionTrainer.astro";
import PeripheralVisionTrainerSEO from "../../components/utilidades/PeripheralVisionTrainer/PeripheralVisionTrainerSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Entrenador de Visión Periférica - Mejora tu Lectura y Agilidad Visual";
const description =
    "Entrena tu campo visual periférico con este juego de agilidad. Mejora la velocidad de lectura, la atención situacional y el tiempo de reacción ocular.";

const faqItems = [
    {
        question: "¿Qué es exactamente la visión periférica?",
        answer: "Es la parte de nuestra visión que ocurre fuera del punto central de enfoque. Aunque no es nítida, es muy sensible al movimiento y al contraste, permitiéndonos detectar objetos sin mirarlos directamente.",
    },
    {
        question: "¿Cómo ayuda este test a leer más rápido?",
        answer: "La lectura rápida depende de cuántas palabras puedes captar de un solo vistazo. Al entrenar tu periferia, aumentas el ancho de tus 'fijaciones', permitiéndote leer líneas enteras con menos movimientos oculares.",
    },
    {
        question: "¿Es normal fallar mucho al principio?",
        answer: "Sí. Nuestro cerebro está habituado a ignorar la información periférica para concentrarse. Con la práctica, las redes neuronales del sistema magnocelular se vuelven más eficientes y rápidas.",
    },
    {
        question: "¿Cuáles son los riesgos de este ejercicio?",
        answer: "El ejercicio utiliza destellos rápidos. Si tienes antecedentes de epilepsia fotosensible o migrañas aura, debes evitarlo o consultar con un especialista antes de usarlo.",
    },
];

const howToSteps = [
    {
        name: "Enfoca el Punto Central",
        text: "Mantén tus ojos fijos en el punto naranja del centro durante todo el entrenamiento. No cedas a la tentación de mirar hacia los lados.",
    },
    {
        name: "Detecta la Flecha",
        text: "Aparecerán flechas en los bordes de la pantalla de forma aleatoria. Intenta identificar su dirección usando solo tu visión lateral.",
    },
    {
        name: "Pulsa la Tecla Correcta",
        text: "Presiona la flecha correspondiente en tu teclado lo más rápido posible. La velocidad y el nivel aumentarán conforme aciertes.",
    },
    {
        name: "Analiza tu Rango",
        text: "Al finalizar los 60 segundos, verás tu puntuación y un rango basado en tu agilidad visual y campo de detección.",
    },
];

const bibliography = [
    {
        name: "Perceptual learning in the absence of awareness (Seitz & Watanabe, 2003)",
        url: "https://pubmed.ncbi.nlm.nih.gov/19285458/",
    },
    {
        name: "Eye movements, the perceptual span, and reading speed",
        url: "https://www.researchgate.net/publication/49694262_Eye_movements_the_perceptual_span_and_reading_speed",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/entrenador-vision-periferica.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Visión Periférica"
            titleBase="Entrenador de"
            description="Ejercicio interactivo diseñado para expandir tu campo visual lateral, mejorando la lectura rápida y la alerta situacional."
            gradientFromColor="#f59e0b"
            gradientToColor="#3b82f6"
            reverse={true}
        />
    </div>

    <PeripheralVisionTrainer />

    <div slot="seo">
        <PeripheralVisionTrainerSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
