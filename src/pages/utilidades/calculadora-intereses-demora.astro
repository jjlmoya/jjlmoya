---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import LateInterestCalculator from "../../components/utilidades/LateInterestCalculator/LateInterestCalculator.astro";
import LateInterestCalculatorSEO from "../../components/utilidades/LateInterestCalculator/LateInterestCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Intereses de Demora y Legales | España 2026";
const description =
    "Calcula intereses de demora tributarios (Hacienda) y legales por impagos. Simulador actualizado para 2025 y 2026 basado en la Ley de Presupuestos.";

const faqItems = [
    {
        question: "¿Cuál es el interés de demora de Hacienda en 2025 y 2026?",
        answer: "El interés de demora tributario se mantiene en el 4,0625% para los ejercicios 2024, 2025 y 2026, según la prórroga de los Presupuestos Generales del Estado.",
    },
    {
        question: "¿Qué es el interés legal del dinero actual?",
        answer: "El interés legal del dinero actualmente es del 3,25%. Es el tipo que se aplica por defecto cuando no hay pacto entre las partes o en sentencias judiciales.",
    },
    {
        question: "¿Cómo se calculan los días de demora?",
        answer: "Se cuentan los días naturales transcurridos desde el día siguiente al vencimiento de la deuda hasta el día en que se realiza el pago efectivo, ambos incluidos.",
    },
    {
        question: "¿Me pueden cobrar intereses y sanción a la vez?",
        answer: "Sí. Hacienda puede aplicar intereses de demora por el tiempo transcurrido y, además, imponer una sanción si el retraso es detectado antes de que regularices voluntariamente.",
    },
];

const howToSteps = [
    {
        name: "Introduce el importe base",
        text: "Escribe la cantidad de dinero sobre la que se deben calcular los intereses (el capital principal).",
    },
    {
        name: "Selecciona el tipo de interés",
        text: "Elige entre Interés Legal (3.25%) o Interés de Demora / Hacienda (4.0625%) según tu caso.",
    },
    {
        name: "Define el periodo de tiempo",
        text: "Indica la fecha en la que debió pagarse la deuda y la fecha prevista de pago real.",
    },
    {
        name: "Visualiza el resultado total",
        text: "El simulador mostrará los intereses acumulados y la cantidad final total que debes abonar.",
    },
];

const bibliography = [
    {
        name: "Ley 58/2003, General Tributaria: Interés de demora",
        url: "https://www.boe.es/buscar/act.php?id=BOE-A-2003-23186",
    },
    {
        name: "Ley de Presupuestos Generales del Estado: Tipos de interés",
        url: "https://www.boe.es",
    },
    {
        name: "Banco de España: Tipos legales de interés",
        url: "https://www.bde.es/bde/es/secciones/informes/Publicaciones_an/Memoria_del_Serv/Tipos_de_interes/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-intereses-demora.webp"
    gradientFrom="from-sky-100"
    gradientTo="to-blue-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="de Demora"
            titleBase="Calculadora de Intereses"
            description="Simulador de intereses legales y tributarios actualizado para 2025 y 2026 en España."
            gradientFrom="from-sky-600"
            gradientTo="to-blue-700"
            reverse={true}
        />
    </div>

    <LateInterestCalculator />

    <div slot="seo">
        <LateInterestCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
