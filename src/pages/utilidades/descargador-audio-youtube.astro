---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import YoutubeAudioDownloader from "../../components/utilidades/YoutubeAudioDownloader/YoutubeAudioDownloader.astro";
import YoutubeAudioDownloaderSEO from "../../components/utilidades/YoutubeAudioDownloader/YoutubeAudioDownloaderSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Descargador de Audio de YouTube Online - MP3 320kbps Gratis";
const description =
    "Convierte videos de YouTube en archivos MP3 de alta calidad al instante. La herramienta más rápida y segura para descargar música y podcasts de YouTube online.";

const faqItems = [
    {
        question: "¿Es legal descargar audio de YouTube?",
        answer: "Es legal para uso personal y privado siempre que no se distribuya o use con fines comerciales el contenido protegido por derechos de autor.",
    },
    {
        question: "¿Qué calidad de MP3 ofrece esta herramienta?",
        answer: "Ofrecemos tres niveles de calidad: 128kbps, 192kbps y la máxima fidelidad de 320kbps.",
    },
    {
        question: "¿Tengo que pagar o registrarme?",
        answer: "No, el servicio es totalmente gratuito y no requiere crear ninguna cuenta ni facilitar datos personales.",
    },
    {
        question: "¿Funciona con videos de larga duración?",
        answer: "Sí, puedes descargar audios de videos de hasta 2 horas de duración sin problemas.",
    },
];

const howToSteps = [
    { name: "Copiar URL", text: "Copia la dirección del video de YouTube que quieres convertir." },
    { name: "Pegar", text: "Introduce el enlace en el buscador de la herramienta superior." },
    { name: "Procesar", text: "Elige la calidad y haz clic en extraer para generar el audio." },
    { name: "Descargar", text: "Guarda el archivo MP3 directamente en tu dispositivo." },
];

const bibliography = [
    { name: "YouTube's Terms of Service", url: "https://www.youtube.com/t/terms" },
    { name: "How MP3 Compression Works", url: "https://computer.howstuffworks.com/mp3.htm" },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/descargador-audio-youtube.webp"
    gradientFrom="from-red-100"
    gradientTo="to-rose-50"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="YouTube"
            titleBase="Descargador de Audio"
            description="Convierte videos de YouTube en MP3 de alta calidad al instante y de forma segura."
            gradientFrom="from-red-600"
            gradientTo="to-red-800"
            reverse={true}
        />
    </div>

    <YoutubeAudioDownloader />

    <div slot="seo">
        <YoutubeAudioDownloaderSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
