---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ColorConverter from "../../components/utilidades/ColorConverter/ColorConverter.astro";
import ColorConverterSEO from "../../components/utilidades/ColorConverter/ColorConverterSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Cómo funciona el conversor de colores RGB a HEX y HSL?",
        answer: "Nuestra herramienta toma valores numéricos de Rojo, Verde y Azul (RGB) y utiliza algoritmos matemáticos para convertirlos a su equivalente en base hexadecimal (HEX) o en los valores de tono, saturación y luminosidad (HSL). También funciona a la inversa, permitiendo pegar un código HEX para obtener sus componentes RGB.",
    },
    {
        question: "¿Por qué debería usar HSL en lugar de HEX en mis diseños?",
        answer: "El formato HSL es mucho más intuitivo para los humanos. Te permite modificar la saturación o la luminosidad de un color sin cambiar su tonalidad, lo que facilita enormemente la creación de paletas armónicas o estados de botones (hover, disabled).",
    },
    {
        question: "¿Qué es el valor de contraste relativo?",
        answer: "Es una métrica que indica la legibilidad de un texto sobre un fondo basado en su luminancia. Un contraste alto asegura que personas con dificultades visuales puedan leer tu contenido, siguiendo las pautas de accesibilidad WCAG.",
    },
    {
        question: "¿Es seguro usar este conversor de color online?",
        answer: "Totalmente. Al ser una herramienta 100% client-side, los datos de color nunca salen de tu ordenador. Todo el proceso ocurre directamente en tu navegador, garantizando privacidad y rapidez instantánea.",
    },
];
---

<LayoutUtility
    title="Conversor de Color RGB a HEX y HSL | Calculadora Online 🎨"
    description="Convierte instantáneamente colores entre formatos RGB, HEX y HSL. Genera armonías automáticas de color y analiza el contraste según las pautas WCAG. 100% Privado."
    image="/images/utilities/conversor-color-rgb-hex-hsl.webp"
    category="Desarrollo Web"
    faqItems={faqItems}
    gradientFrom="from-indigo-600"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Conversor"
            titleBase="de Color"
            description="La herramienta definitiva para el diseño web: transforma entre HEX, RGB y HSL de forma visual y con precisión matemática. Crea armonías increíbles al instante."
            gradientFrom="from-indigo-600"
            gradientTo="to-violet-600"
            reverse={false}
        />
    </div>

    <ColorConverter />

    <div slot="seo">
        <ColorConverterSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Recursos de Color y Diseño Web"
            links={[
                {
                    name: "W3C: Documentación de Colores en CSS",
                    url: "https://www.w3.org/TR/css-color-4/",
                },
                {
                    name: "MDN: Guía del Modelo de Color HSL",
                    url: "https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/color_value/hsl",
                },
                {
                    name: "WebAIM: Guía de Contraste y Accesibilidad",
                    url: "https://webaim.org/resources/contrastchecker/",
                },
            ]}
        />
    </div>
</LayoutUtility>
