---
export const prerender = true;
import { getAllRegisteredTools } from "../../../i18n/toolRegistry";
import LibraryUtilityLayout from "../../../components/utilidades/LibraryUtilityLayout.astro";

export async function getStaticPaths() {
    const allTools = await getAllRegisteredTools();
    const paths: Array<{ params: { slug: string }; props: { tool: unknown; categoryKey: string } }> = [];

    await Promise.all(
        allTools.map(async ([tool, categoryKey]) => {
            const toolDef = tool as {
                entry: { i18n: Record<string, () => Promise<{ slug: string }>> };
            };
            const content = await toolDef.entry.i18n.es!();
            paths.push({
                params: { slug: content.slug },
                props: { tool, categoryKey },
            });
        })
    );

    return paths;
}

const { tool, categoryKey } = Astro.props as { tool: { entry: any; Component: any; SEOComponent: any; BibliographyComponent: any }; categoryKey: string };
---
<LibraryUtilityLayout tool={tool} categoryKey={categoryKey} />
