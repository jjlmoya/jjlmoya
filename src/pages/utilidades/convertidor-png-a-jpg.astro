---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import PngToJpgSEO from "../../components/utilidades/ImageConverter/seo/PngToJpgSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Convertir PNG a JPG Online - Rápido, Gratis y 100% Privado";
const description =
    "Convierte tus imágenes PNG a formato JPG de compresión rápida al instante en tu propio ordenador. Sin subir fotos a internet. Optimización por lotes.";

const faqItems = [
    {
        question: "¿Por qué convertir PNG a JPG?",
        answer: "El formato PNG mantiene mucha calidad y transparencias pero resulta en archivos enormes. Convertir a JPG es perfecto cuando necesitas fotos ligeras para correos o páginas web rápidas y no te importa un fondo sólido.",
    },
    {
        question: "¿Perderé detalles durante la transformación?",
        answer: "Aplicamos una relación de compresión equilibrada de alta calidad, por lo que las diferencias en fotografías y degradados serán casi imperceptibles al ojo, pero notarás el ahorro en el peso final del documento.",
    },
    {
        question: "¿Mis fotos son procesadas de manera segura?",
        answer: "Absolutamente sí. No usamos servidores en la nube para procesar imágenes; el algoritmo de conversión corre a través del Canvas de HTML5 de tu propio navegador web de forma aislada.",
    },
];

const howToSteps = [
    {
        name: "Arrastra Archivos PNG",
        text: "Envía tus imágenes estáticas PNG al recuadro de procesamiento local soltándolas ahí.",
    },
    {
        name: "Re-Renderizado Blanco",
        text: "Cada foto adapta automáticamente sus transparencias con una capa blanca subyacente para hacerla compatible al entorno JPG.",
    },
    {
        name: "Exportación Directa",
        text: "Haz click en los iconos de descarga verdes y guarda tus nuevos archivos JPG en el dispositivo de almacenamiento.",
    },
];

const bibliography = [
    {
        name: "Especificaciones PNG Consortium",
        url: "http://www.libpng.org/pub/png/",
    },
    {
        name: "The JPEG committee",
        url: "https://jpeg.org/",
    },
];

const converterOptions = {
    sourceFormat: "image/png",
    targetFormat: "image/jpeg",
    sourceExt: "PNG",
    from: "png",
    to: "jpg",
    dragText: "Arrastra archivos PNG...",
    quality: 0.9,
    themeColor: "#4f46e5",
    themeColorHover: "#4338ca",
    themeBg: "rgba(79, 70, 229, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-indigo-100"
    gradientTo="to-indigo-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a JPG"
            titleBase="PNG"
            description="La herramienta más segura y privada para convertir tus imágenes PNG al clásico formato JPG sin salir del explorador web y sin envíos de red."
            gradientFrom="from-indigo-500"
            gradientTo="to-indigo-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <PngToJpgSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
