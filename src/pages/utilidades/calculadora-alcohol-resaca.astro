---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import AlcoholClearance from "../../components/utilidades/AlcoholClearance/AlcoholClearance.astro";
import AlcoholClearanceSEO from "../../components/utilidades/AlcoholClearance/AlcoholClearanceSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Calculadora de Resaca y Alcoholemia: Predictor de Recuperación";
const description =
    "Estima el tiempo de metabolización del alcohol y planifica tu hidratación pre-sueño. Basado en la fórmula de Widmark y ritmos metabólicos estándar.";

const faqItems = [
    {
        question: "¿Es fiable al 100% esta calculadora?",
        answer: "No. Es una estimación teórica basada en promedios estadísticos. Factores como la fatiga, medicación, enfermedades hepáticas o la velocidad de ingestión pueden alterar drásticamente los resultados reales.",
    },
    {
        question: "¿Cómo acelero la eliminación del alcohol?",
        answer: "Fisiológicamente no se puede acelerar de forma significativa. El hígado oxida el alcohol a un ritmo constante. El café, las duchas frías o el ejercicio no reducen el nivel de alcohol en sangre (BAC).",
    },
    {
        question: "¿Por qué las mujeres suelen dar más tasa con el mismo consumo?",
        answer: "Generalmente debido a una mayor proporción de tejido adiposo (grasa) y menor cantidad de agua corporal total, además de diferencias en la concentración de la enzima alcohol deshidrogenasa gástrica.",
    },
    {
        question: "¿Qué es una Unidad de Bebida Estándar (UBE)?",
        answer: "En España, una UBE suele equivaler a 10 gramos de alcohol puro. Esto corresponde aproximadamente a una caña de cerveza (200ml), una copa de vino (100ml) o un chupito. Los combinados suelen contar como 2 UBEs.",
    },
    {
        question: "¿Cuánto tiempo tarda en dar 0.0?",
        answer: "Depende totalmente de la cantidad ingerida y tu peso. Como regla general, un individuo de 75kg tarda unas 2 horas en eliminar una unidad de bebida estándar. Nuestra calculadora te dará el tiempo exacto estimado para tu perfil.",
    },
    {
        question: "¿Comer después de beber ayuda?",
        answer: "Comer *antes* de beber es lo más eficaz para retrasar la absorción. Comer después puede ayudar a estabilizar los niveles de azúcar en sangre, pero no reducirá la alcoholemia ya presente en tus arterias.",
    },
];

const howToSteps = [
    {
        name: "Indica tu Perfil",
        text: "Introduce tu peso aproximado y sexo biológico para ajustar el volumen de distribución.",
    },
    {
        name: "Añade Bebidas",
        text: "Selecciona el tipo de alcohol y cantidad consumida de forma honesta.",
    },
    {
        name: "Consulta Resultados",
        text: "Visualiza el tiempo estimado para la sobriedad y las pautas de hidratación.",
    },
];

const bibliography = [
    {
        name: "Widmark's Equation for Blood Alcohol Analysis",
        url: "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4361698/",
    },
    {
        name: "Alcohol Metabolism and Hangover Pathophysiology - Mayo Clinic",
        url: "https://www.mayoclinic.org/diseases-conditions/hangovers/symptoms-causes/syc-20373012",
    },
    {
        name: "Dirección General de Tráfico: Efectos del Alcohol",
        url: "https://www.dgt.es/muevete-con-seguridad/evita-conductas-de-riesgo/consumo-de-alcohol/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-alcohol-resaca.webp"
    gradientFrom="from-purple-100"
    gradientTo="to-indigo-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Eliminación de Alcohol"
            titleBase="Calculadora de"
            description="Estima tu metabolismo y planifica tu hidratación para evitar la resaca."
            gradientFrom="from-purple-500"
            gradientTo="to-indigo-600"
            reverse={true}
        />
    </div>

    <AlcoholClearance />

    <div slot="seo">
        <AlcoholClearanceSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
