---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import BabyFeedingCalculator from "../../components/utilidades/BabyFeedingCalculator/BabyFeedingCalculator.astro";
import BabyFeedingCalculatorSEO from "../../components/utilidades/BabyFeedingCalculator/BabyFeedingCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Calculadora de Tomas del Bebé: Guía de Alimentación y Frecuencia";
const description = "Calcula la cantidad de leche y frecuencia de tomas para tu bebé según su peso y edad. Recomendaciones para lactancia materna y fórmula.";

const faqItems = [
    {
        question: "¿Cuánta leche debe tomar mi bebé recién nacido?",
        answer: "En los primeros días, su estómago es minúsculo (del tamaño de una cereza). Empezará tomando apenas 5-10 ml por toma, aumentando gradualmente hasta los 60-90 ml hacia el final de la primera semana."
    },
    {
        question: "¿Cómo sé si mi bebé se queda con hambre?",
        answer: "Las señales tempranas incluyen mover la cabeza buscando el pecho (reflejo de búsqueda), llevarse las manos a la boca y hacer ruidos de succión. No esperes a que llore, ya que el llanto es una señal tardía de hambre."
    },
    {
        question: "¿Cuántas veces al día debe comer un bebé de 2 meses?",
        answer: "A esa edad, suelen realizar entre 6 y 8 tomas al día. Si es lactancia materna, puede que sean más, ya que se digiere más rápido que la fórmula."
    },
    {
        question: "¿Es normal que mi bebé no se termine todo el biberón?",
        answer: "Sí, es perfectamente normal. Nunca debes forzar a un bebé a terminar una toma. Su capacidad de autorregulación es muy buena; si relaja las manos y suelta la tetina, es que ya está saciado."
    }
];

const howToSteps = [
    {
        name: "Introduce la edad",
        text: "Selecciona si prefieres indicar la edad en días, semanas o meses para ajustar la capacidad gástrica estimada."
    },
    {
        name: "Indica el peso",
        text: "El peso es el factor más determinante para calcular las necesidades calóricas diarias (regla de Holliday-Segar)."
    },
    {
        name: "Elige el tipo de leche",
        text: "Selecciona entre pecho, fórmula o mixta para obtener recomendaciones específicas sobre frecuencia y volumen."
    }
];

const bibliographyLinks = [
    {
        name: "Asociación Española de Pediatría - Lactancia Materna",
        url: "https://www.aeped.es/comite-nutricion-y-lactancia-materna/lactancia-materna"
    },
    {
        name: "OMS - Alimentación del lactante y del niño pequeño",
        url: "https://www.who.int/es/news-room/fact-sheets/detail/infant-and-young-child-feeding"
    },
    {
        name: "HealthyChildren.org - Cantidades de alimentación con fórmula",
        url: "https://www.healthychildren.org/Spanish/ages-stages/baby/formula-feeding/Paginas/amount-and-schedule-of-formula-feedings.aspx"
    }
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-tomas-bebe.webp"
    gradientFrom="from-rose-50"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Calculadora"
            titleBase="Tomas Bebé"
            description="Obtén una guía orientativa y personalizada de alimentación. Basada en el peso de tu bebé y recomendaciones pediátricas oficiales."
            gradientFrom="from-rose-600"
            gradientTo="to-orange-500"
        />
    </div>

    <BabyFeedingCalculator />

    <div slot="seo">
        <BabyFeedingCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
