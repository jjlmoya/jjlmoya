---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import UtilitySection from "../../components/utilidades/UtilitySection.astro";
import UtilitiesHeader from "../../components/utilidades/UtilitiesHeader.astro";
import UtilitiesSEO from "../../components/utilidades/UtilitiesSEO.astro";

import { sections } from "../../data/utilities";

const totalUtilities = sections.reduce((acc, section) => acc + section.utilities.length, 0);
---

<Layout
    title={`Utilidades para la Vida y el Desarrollo Web`}
    description="Herramientas esenciales para tareas específicas: cálculos de precisión, procesamiento de código y limpieza de texto. Utilidades online gratuitas y funcionales."
    image="/images/utilities/index.webp"
    fullWidth={true}
>
    <div class="relative min-h-screen">
        <div
            class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-100 via-white to-white dark:from-slate-900 dark:via-slate-950 dark:to-black -z-10"
        >
        </div>

        <UtilitiesHeader total={totalUtilities} sections={sections} />

        <div class="max-w-6xl mx-auto px-4">
            <div class="space-y-16 pb-20">
                {sections.map((section) => <UtilitySection {...section} />)}
            </div>

            <UtilitiesSEO />
        </div>
    </div>
</Layout>
