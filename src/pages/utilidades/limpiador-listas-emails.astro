---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import EmailListCleaner from "../../components/utilidades/EmailListCleaner/EmailListCleaner.astro";
import EmailListCleanerSEO from "../../components/utilidades/EmailListCleaner/EmailListCleanerSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Limpiador de Listas de Emails Gratis | Elimina Duplicados";
const description =
    "Limpia listas de correos electrónicos GRATIS. Elimina duplicados, corrige espacios y valida formatos en segundos. Ahorra costes y mejora tu entregabilidad.";

const faqItems = [
    {
        question: "¿Qué hace exactamente este limpiador de emails?",
        answer: "Nuestra herramienta analiza tu lista de correos, elimina duplicados, quita espacios en blanco innecesarios, valida el formato básico y normaliza todas las direcciones a minúsculas para asegurar una base de datos impecable.",
    },
    {
        question: "¿Hay algún límite de correos electrónicos?",
        answer: "No hay un límite estricto de registros. Puedes procesar miles de correos de una sola vez de forma instantánea. La única limitación es la memoria de tu propio navegador si la lista es extremadamente masiva (cientos de miles).",
    },
    {
        question: "¿Es seguro pegar mis correos aquí?",
        answer: "Totalmente. Todo el procesamiento se realiza de forma local en tu propio navegador mediante JavaScript. Tus datos nunca se envían a nuestros servidores ni se guardan en ninguna base de datos externa.",
    },
    {
        question: "¿Cómo mejora esto la entregabilidad de mis campañas?",
        answer: "Al eliminar direcciones inexistentes o mal formateadas, reduces la tasa de rebote (bounce rate), lo que mejora la reputación de tu dominio ante proveedores como Gmail, Outlook o Yahoo.",
    },
];

const howToSteps = [
    {
        name: "Pega tus correos",
        text: "Copia tu lista de emails y pégala en el cuadro de texto. Pueden estar separados por líneas, comas o incluso espacios.",
    },
    {
        name: "Limpia la lista",
        text: "Haz clic en el botón 'Limpiar Lista' para iniciar el proceso de validación y eliminación de duplicados.",
    },
    {
        name: "Revisa los resultados",
        text: "Observa las estadísticas de correos originales vs. finales y revisa la lista depurada en el panel inferior.",
    },
    {
        name: "Copia o descarga",
        text: "Copia el resultado directamente al portapapeles o descárgalo como un archivo .txt listo para usar.",
    },
];

const bibliography = [
    {
        name: "RFC 5322: Internet Message Format",
        url: "https://datatracker.ietf.org/doc/html/rfc5322",
    },
    {
        name: "Guía de Google sobre Entregabilidad de Correo",
        url: "https://support.google.com/a/answer/81126",
    },
    {
        name: "Buenas prácticas de Spamhaus para boletines",
        url: "https://www.benchmarkemail.com/es/blog/informacion-acerca-de-spamhaus-spamcop/",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/limpiador-listas-emails.webp"
    gradientFrom="from-indigo-100"
    gradientTo="to-purple-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Limpiador"
            titleBase="de Listas de Emails"
            description="Elimina duplicados, corrige formatos y optimiza tus campañas de marketing en segundos."
            gradientFrom="from-indigo-600"
            gradientTo="to-purple-700"
            reverse={false}
        />
    </div>

    <EmailListCleaner />

    <div slot="seo">
        <EmailListCleanerSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
