---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import TelescopeResolution from "../../components/utilidades/TelescopeResolution/TelescopeResolution.astro";
import TelescopeResolutionSEO from "../../components/utilidades/TelescopeResolution/TelescopeResolutionSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const bibliographyLinks = [
    {
        name: "Sky & Telescope: The Dawes Limit",
        url: "https://www.skyandtelescope.com/wp-content/uploads/Kane_Dawes_Limit_modified_list.pdf",
    },
    {
        name: "Observatorio de París: Diffraction and Resolution",
        url: "https://bass2000.obspm.fr/guide/ARTICLE-HELIO.pdf",
    },
    {
        name: "Criterios de resolución en astronomía",
        url: "https://www.astroshop.es/revista/conocimientos/conocimientos-sobre-telescopios/el-telescopio-adecuado/capacidad-de-resolucion/i,1061",
    },
];

const faqItems = [
    {
        question: "¿Por qué mi telescopio de 200mm no ve detalles de 0.6 pulgadas hoy?",
        answer: "Casi siempre es culpa de la atmósfera (seeing). La turbulencia del aire hace que las estrellas 'bailen' y se emborronen, limitando la resolución real a 1-2 arcosegundos la mayoría de las noches.",
    },
    {
        question: "¿Cuál es la diferencia real entre Dawes y Rayleigh?",
        answer: "Dawes se enfoca en separar dos puntos brillantes (estrellas binarias). Rayleigh se enfoca en cuándo los discos de difracción se superponen, lo que influye en los detalles de superficies como planetas o la Luna.",
    },
    {
        question: "¿Puedo superar el aumento máximo recomendado?",
        answer: "Poder, puedes, pero no verás más. Es lo que llamamos 'aumento vacío'. La imagen será más grande pero mucho más oscura y borrosa. Es mejor una imagen pequeña y nítida que una grande y difusa.",
    },
];

const howToSteps = [
    {
        name: "Introduce la apertura",
        text: "Escribe el diámetro de tu lente o espejo principal en mm o pulgadas. Puedes usar los presets para telescopios comunes.",
    },
    {
        name: "Ajusta el seeing",
        text: "Mueve el deslizador de calidad del cielo según las condiciones de tu noche (1.0 es una noche buena estándar).",
    },
    {
        name: "Observa la simulación",
        text: "Mira cómo interactúan las estrellas binarias. Si se ven como una sola mancha, necesitas más apertura o esperar a una mejor noche.",
    },
];
---

<LayoutUtility
    title="Calculadora de Resolución de Telescopio: Límite de Dawes"
    description="Calcula el límite de resolución de tu telescopio usando los criterios de Dawes y Rayleigh. Guía de aumentos máximos y simulación de seeing."
    image="/images/utilities/calculadora-resolucion-telescopio.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Visión Cósmica"
            titleBase="Resolución y Detalle"
            description="Límite de Dawes y Rayleigh. Descubre el máximo detalle que tu óptica puede resolver frente a la atmósfera terrestre."
            gradientFromColor="#a855f7"
            gradientToColor="#ec4899"
        />
    </div>

    <TelescopeResolution />

    <div slot="seo">
        <TelescopeResolutionSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
