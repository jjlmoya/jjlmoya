---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import DigitalCarbonFootprint from "../../components/utilidades/DigitalCarbonFootprint/DigitalCarbonFootprint.astro";
import DigitalCarbonFootprintSEO from "../../components/utilidades/DigitalCarbonFootprint/DigitalCarbonFootprintSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const faqItems = [
    {
        question: "¿Con qué precisión estima el CO₂ esta herramienta?",
        answer: "La estimación se basa en el Sustainable Web Design Model, un estándar ampliamente aceptado. Sin acceso directo al servidor, el peso de la página se aproxima analizando el HTML visible más un factor de activos estimado. El resultado es una referencia orientativa muy útil para comparar webs y detectar problemas de rendimiento.",
    },
    {
        question: "¿Por qué mi web no puede analizarse?",
        answer: "Muchos sitios bloquean peticiones de origen cruzado (CORS) por seguridad. En ese caso la herramienta no puede leer su contenido. Puedes usar herramientas de navegador como DevTools para obtener el peso real de la página y aplicar la fórmula manualmente.",
    },
    {
        question: "¿Qué es el Sustainable Web Design Model?",
        answer: "Es un marco de referencia creado por investigadores y activistas del sector tecnológico para estandarizar cómo se mide el impacto ambiental de los sitios web. Tiene en cuenta el consumo energético de la red, los dispositivos de los usuarios y la intensidad de carbono del mix eléctrico global.",
    },
    {
        question: "¿Cómo puedo hacer mi web más sostenible?",
        answer: "Las acciones de mayor impacto son: optimizar y convertir imágenes a WebP/AVIF, activar compresión Brotli en el servidor, usar un CDN con energía renovable certificada, implementar caché agresiva y eliminar scripts de terceros innecesarios. Cada kilobyte eliminado reduce directamente las emisiones de CO₂.",
    },
    {
        question: "¿Cuánto CO₂ emite una web media?",
        answer: "Según los datos del sector, una página web media genera alrededor de 0,5 gramos de CO₂ por visita. Sitios con mucho contenido multimedia pueden superar los 2-3 gramos, mientras que webs bien optimizadas se quedan por debajo de los 0,2 gramos.",
    },
];
---

<LayoutUtility
    title="Calculadora de Huella de Carbono Digital | CO₂ por Visita de tu Web"
    description="Analiza el peso de cualquier URL y calcula los gramos de CO₂ que genera cada visita. Descubre si tu web es sostenible y cómo reducir su impacto ambiental."
    image="/images/utilities/calculadora-huella-carbono-digital.webp"
    category="Ciencia"
    faqItems={faqItems}
    gradientFrom="from-emerald-600"
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Huella de Carbono"
            titleBase="Digital"
            description="Introduce la URL de cualquier web y calcula cuántos gramos de CO₂ genera cada visita, su consumo energético y qué nota de eficiencia merece."
            gradientFrom="from-emerald-600"
            gradientTo="to-teal-600"
            reverse={false}
        />
    </div>

    <DigitalCarbonFootprint />

    <div slot="seo">
        <DigitalCarbonFootprintSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Fuentes y metodología"
            links={[
                {
                    name: "Sustainable Web Design Model — Wholegrain Digital",
                    url: "https://sustainablewebdesign.org/calculating-digital-emissions/",
                },
                {
                    name: "Website Carbon Calculator — metodología de referencia",
                    url: "https://www.websitecarbon.com/how-does-it-work/",
                },
                {
                    name: "IEA: Electricity grids and secure energy transitions",
                    url: "https://www.iea.org/reports/electricity-grids-and-secure-energy-transitions",
                },
            ]}
        />
    </div>
</LayoutUtility>
