---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import ContentOptimizer from "../../components/utilidades/ContentOptimizer/ContentOptimizer.astro";
import ContentOptimizerSEO from "../../components/utilidades/ContentOptimizer/ContentOptimizerSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";

const faqItems = [
    {
        question: "¿Cómo ayuda esta herramienta a mi posicionamiento SEO?",
        answer: "Al analizar la densidad de keywords y la legibilidad de las frases, aseguras que tu contenido sea fácil de entender para los usuarios y relevante para los buscadores, evitando penalizaciones por sobreoptimización.",
    },
    {
        question: "¿Qué aspectos técnicos del HTML analiza?",
        answer: "Verifica la existencia y unicidad de la etiqueta H1, la presencia de subencabezados H2/H3, la existencia de títulos meta y descripciones, así como los atributos alt en las imágenes.",
    },
    {
        question: "¿Mis textos se guardan en el servidor?",
        answer: "No. El análisis se realiza 100% de forma local en tu navegador. Tu contenido nunca sale de tu ordenador, garantizando una privacidad absoluta.",
    },
    {
        question: "¿Es compatible con el análisis de Yoast SEO?",
        answer: "Sí, hemos implementado criterios similares a Yoast, como la longitud de frases, la distribución de párrafos y la jerarquía de encabezados para que tu contenido sea perfecto.",
    },
];

const howToSteps = [
    {
        name: "Escribe o pega tu texto",
        text: "Introduce el contenido que deseas analizar en el área de texto principal.",
    },
    {
        name: "Analiza el HTML técnico",
        text: "Cambia a la pestaña de análisis técnico para verificar etiquetas H1, Alts y estructura de metadatos.",
    },
    {
        name: "Revisa la Densidad",
        text: "Comprueba las palabras clave más frecuentes y su porcentaje para evitar el keyword stuffing.",
    },
    {
        name: "Optimiza la Legibilidad",
        text: "Sigue el checklist para dividir párrafos largos o acortar frases excesivamente complejas.",
    },
];
---

<LayoutUtility
    title="Optimizador de Contenido SEO: Keywords, Legibilidad y HTML | Análisis Yoast"
    description="Analiza la densidad de palabras clave, legibilidad (estilo Yoast) y estructura técnica HTML en tiempo real. La herramienta definitiva para copywriters y especialistas SEO."
    image="/images/utilities/optimizador-contenido-seo.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Optimizador"
            titleBase="de Contenido SEO"
            description="Controla la densidad de tus keywords, analiza la legibilidad de tus párrafos y verifica la estructura técnica de tu HTML al instante."
            gradientFrom="from-blue-500"
            gradientTo="to-indigo-600"
        />
    </div>

    <ContentOptimizer />

    <div slot="seo">
        <ContentOptimizerSEO />
    </div>
</LayoutUtility>
