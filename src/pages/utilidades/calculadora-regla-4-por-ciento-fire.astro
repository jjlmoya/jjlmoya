---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import FireCalculator from "../../components/utilidades/FireCalculator/FireCalculator.astro";
import FireCalculatorSEO from "../../components/utilidades/FireCalculator/FireCalculatorSEO.astro";

const faqItems = [
    {
        question: "¿Qué es la Regla del 4%?",
        answer: "Es una pauta que sugiere que puedes retirar el 4% del valor inicial de tu cartera de inversiones cada año (ajustado por inflación) con una alta probabilidad de que el dinero no se agote en al menos 30 años.",
    },
    {
        question: "¿Cómo sé cuánto capital necesito para jubilarme?",
        answer: "La forma más rápida es multiplicar tus gastos anuales por 25. Por ejemplo, si gastas 20.000€ al año, necesitas acumular 500.000€.",
    },
    {
        question: "¿Qué significa Lean FIRE?",
        answer: "Es alcanzar la independencia financiera con un presupuesto muy ajustado, cubriendo solo lo esencial. Suele requerir entre 300.000€ y 500.000€ dependiendo del país.",
    },
    {
        question: "¿Incluye esta calculadora la inflación?",
        answer: "La regla del 4% asume que los retiros futuros se ajustan a la inflación. Al usar rentabilidades 'reales' (nominal menos inflación) en tus cálculos de acumulación, obtendrás resultados en moneda de hoy.",
    },
    {
        question: "¿Es seguro retirar el 4% si hay una crisis?",
        answer: "El estudio original contemplaba periodos de crisis (incluyendo la Gran Depresión). Sin embargo, muchos expertos recomiendan ser más conservadores (3.5%) si te jubilas muy joven o el mercado está muy caro.",
    },
];

const howToSteps = [
    {
        name: "Define tus gastos",
        text: "Calcula cuánto dinero necesitas mensualmente para vivir el estilo de vida que deseas tras jubilarte.",
    },
    {
        name: "Ajusta la tasa de retirada",
        text: "Elige 4% para un plan estándar o 3% si quieres ser extremadamente conservador.",
    },
    {
        name: "Introduce tu patrimonio",
        text: "Suma tus ahorros, fondos de inversión, acciones y otros activos productivos actuales.",
    },
    {
        name: "Proyecta tu ahorro",
        text: "Indica cuánto eres capaz de invertir cada mes para ver cuánto tiempo te separa de tu libertad.",
    },
    {
        name: "Analiza los hitos",
        text: "Comprueba si ya has alcanzado el Lean FIRE o el Barista FIRE para ganar tranquilidad mental.",
    },
];

const titleHighlight = "Calculadora FIRE";
const titleBase = "Regla del 4%";
const description =
    "Calcula cuánto capital necesitas para jubilarte anticipadamente y vivir de tus rentas. Planifica tu libertad financiera con el movimiento FIRE.";
---

<LayoutUtility
    title={`${titleHighlight} ${titleBase}`}
    description={description}
    image="/images/utilities/calculadora-regla-4-por-ciento-fire.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight={titleHighlight}
            titleBase={titleBase}
            description={description}
            gradientFromColor="#10b981"
            gradientToColor="#059669"
        />
    </div>

    <FireCalculator />

    <div slot="seo">
        <FireCalculatorSEO />
    </div>
</LayoutUtility>
