---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import HashGenerator from "../../components/utilidades/hash-generator/HashGenerator.astro";
import HashGeneratorSEO from "../../components/utilidades/hash-generator/HashGeneratorSEO.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

const title = "Generador de Hashes Online MD5, SHA-256 y SHA-512";
const description =
    "Calcula hashes MD5, SHA-1, SHA-256 y SHA-512 al instante. Herramienta de seguridad gratuita, privada y ultra rápida para desarrolladores. 100% Client-Side.";
const image = "/images/utilities/generador-hashes-seguridad.webp";

const faqItems = [
    {
        question: "¿Qué es un hash y para qué sirve?",
        answer: "Un hash es una huella digital única de un texto o archivo. Sirve para verificar que los datos no han sido alterados y para almacenar contraseñas de forma segura.",
    },
    {
        question: "¿Es seguro usar este generador online?",
        answer: "Sí, es totalmente seguro. A diferencia de otras webs, nosotros procesamos el hash directamente en tu navegador. Tus datos nunca se envían a ningún servidor.",
    },
    {
        question: "¿Qué algoritmo de hash debería elegir?",
        answer: "Para seguridad moderna y almacenamiento de claves, te recomendamos SHA-256 o SHA-512. MD5 y SHA-1 solo deben usarse por compatibilidad con sistemas antiguos.",
    },
    {
        question: "¿Qué significa añadir un 'Salt'?",
        answer: "Un Salt es una cadena extra que se mezcla con tu texto para hacer que el hash sea único y mucho más difícil de descifrar mediante ataques de diccionario.",
    },
];

const howToSteps = [
    {
        name: "Introducir Texto",
        text: "Escribe o pega el texto que quieres cifrar en el cuadro de entrada.",
    },
    {
        name: "Configurar Seguridad",
        text: "Añade un Salt opcional o aumenta las rondas de procesamiento para mayor robustez.",
    },
    {
        name: "Obtener Resultados",
        text: "Los diferentes hashes (MD5, SHA etc.) se calculan en tiempo real mientras escribes.",
    },
    {
        name: "Copiar el Hash",
        text: "Haz clic en el icono de copiar situado junto a cada algoritmo para guardarlo en tu portapapeles.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image={image}
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Hashes Online"
            titleBase="Generador de"
            description="La herramienta definitiva para integridad de datos. Calcula firmas digitales MD5 y SHA con máxima privacidad y sin publicidad."
            gradientFrom="from-indigo-600"
            gradientTo="to-blue-600"
        />
    </div>

    <HashGenerator />

    <div slot="seo">
        <HashGeneratorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography
            title="Recursos Técnicos sobre Hashing"
            links={[
                {
                    name: "MDN Web Docs: SubtlesCrypto.digest() API",
                    url: "https://developer.mozilla.org/en-US/docs/Web/API/SubtleCrypto/digest",
                },
                {
                    name: "NIST: FIPS 180-4 Secure Hash Standard (SHA)",
                    url: "https://csrc.nist.gov/publications/detail/fips/180/4/final",
                },
                {
                    name: "IETF: The MD5 Message-Digest Algorithm (RFC 1321)",
                    url: "https://datatracker.ietf.org/doc/html/rfc1321",
                },
            ]}
        />
    </div>
</LayoutUtility>
