---
export const prerender = true;
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";
import VaccinationCalendar from "../../components/utilidades/VaccinationCalendar/VaccinationCalendar.astro";
import VaccinationCalendarSEO from "../../components/utilidades/VaccinationCalendar/VaccinationCalendarSEO.astro";

const titleHighlight = "Calendario Vacunación Infantil";
const titleBase = "España 2026";
const description =
    "Calcula las fechas exactas de vacunación de tu hijo según su edad. Calendario oficial AEP 2026 sincronizado con tu agenda móvil.";

const faqItems = [
    {
        question: "¿Es fiable el calendario de 2026?",
        answer: "Sí. Basamos nuestros datos en las actualizaciones de la Asociación Española de Pediatría (AEP) y las últimas recomendaciones oficiales. La calculadora se revisa anualmente.",
    },
    {
        question: "¿Se puede vacunar con mocos o febrícula?",
        answer: "Sí. Si el estado general del niño es bueno, la presencia de catarro leve, tos o unas décimas de fiebre no son contraindicación para recibir sus dosis correspondientes.",
    },
    {
        question: "¿Qué vacunas no están financiadas en 2026?",
        answer: "Actualmente, la vacuna contra el Rotavirus sigue sin estar financiada en algunas comunidades autónomas, aunque la mayoría del calendario ya es 100% gratuito.",
    },
    {
        question: "¿Cómo funciona la exportación al calendario móvil?",
        answer: "Nuestra herramienta genera un archivo .ics estándar. Al abrirlo, tu iPhone o Android reconocerá automáticamente las citas y las guardará en tu agenda con alertas.",
    },
];

const howToSteps = [
    {
        name: "Introduce la fecha de nacimiento",
        text: "La calculadora ajustará automáticamente todas las citas desde los 2 meses hasta los 14 años de edad.",
    },
    {
        name: "Selecciona tu Comunidad Autónoma",
        text: "Ajustamos las variaciones específicas de cada región para que coincidan con tu centro de salud local.",
    },
    {
        name: "Revisa la cita inmediata",
        text: "El banner superior te dirá exactamente qué vacuna toca ahora y cuántos días faltan (o si vas con retraso).",
    },
    {
        name: "Exporta a tu móvil",
        text: "Pulsa en 'Exportar a Calendario' para añadir recordatorios automáticos en tu iPhone, Android o PC.",
    },
];

const bibliographyLinks = [
    {
        name: "CAV-AEP (Comité Asesor de Vacunas de la AEP)",
        url: "https://vacunasaep.org/profesionales/calendario-de-vacunaciones-de-la-aep-2024",
    },
    {
        name: "Ministerio de Sanidad - Calendario de Vacunación a lo largo de la vida",
        url: "https://www.sanidad.gob.es/areas/promocionPrevencion/vacunaciones/calendario/home.htm",
    },
];
---

<LayoutUtility
    title={`${titleHighlight} ${titleBase}`}
    description={description}
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight={titleHighlight}
            titleBase={titleBase}
            description={description}
            gradientFrom="from-indigo-600"
            gradientTo="to-rose-600"
        />
    </div>

    <VaccinationCalendar />

    <div slot="seo">
        <VaccinationCalendarSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliographyLinks} />
    </div>
</LayoutUtility>
