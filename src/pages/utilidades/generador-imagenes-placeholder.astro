---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import PlaceholderGenerator from "../../components/utilidades/placeholder-generator/PlaceholderGenerator.astro";
import PlaceholderGeneratorSEO from "../../components/utilidades/placeholder-generator/PlaceholderGeneratorSEO.astro";

const title = "Generador de Imágenes Placeholder - Mockups Rápidos";
const description =
    "Crea imágenes de relleno personalizadas para tus diseños web. Ajusta resolución, fondo, texto y exporta en PNG en milisegundos.";

const faqItems = [
    {
        question: "¿Qué es una imagen placeholder?",
        answer: "Una imagen placeholder o de relleno es un gráfico temporal utilizado en diseño web y maquetación para reservar el espacio donde irá una imagen definitiva. Ayudan a visualizar la estructura de una página antes de tener el contenido final.",
    },
    {
        question: "¿Puedo usar cualquier resolución en el generador?",
        answer: "Sí, puedes introducir cualquier valor numérico para el ancho y el alto. El generador creará un lienzo con las dimensiones exactas solicitadas, perfecto para cuadrículas estrictas o banners publicitarios específicos.",
    },
    {
        question: "¿En qué formato se descargan las imágenes?",
        answer: "Por defecto, las imágenes se generan en WebP para una compresión óptima, pero puedes elegir descargarlas en formato PNG si buscas mantener la máxima calidad sin pérdida, o JPEG para compatibilidad tradicional. Todas las configuraciones mantienen una alta fidelidad a tu elección de paleta.",
    },
    {
        question: "¿Se procesa esto en algún servidor?",
        answer: "No, todo el renderizado de la imagen se genera instantáneamente en la memoria virtual (Canvas) de tu propio navegador. Es instantáneo y no requiere enviar datos a través de la red.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/generador-imagenes-placeholder.webp"
    gradientFrom="from-yellow-100"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Placeholders"
            titleBase="Generador de"
            description="Construye mockups visuales perfectos. Dicta medidas, escoge tonos, escribe tu texto y obtén un bloque de imagen instantáneo para rellenar tus layouts web."
            gradientFrom="from-yellow-500"
            gradientTo="to-orange-500"
            reverse={true}
        />
    </div>

    <PlaceholderGenerator />

    <div slot="seo">
        <PlaceholderGeneratorSEO />
    </div>
</LayoutUtility>
