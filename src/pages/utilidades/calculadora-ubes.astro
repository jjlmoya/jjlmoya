---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import UbeCalculator from "../../components/utilidades/UbeCalculator/UbeCalculator.astro";
import UbeCalculatorSEO from "../../components/utilidades/UbeCalculator/UbeCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora UBE (Unidades de Bebida Estándar) - Control Alcohólico";
const description =
    "Calcula los gramos puros de alcohol y las Unidades de Bebida Estándar (UBE) de tus combinados, cerveza, vino y chupitos para un consumo seguro e informado.";

const faqItems = [
    {
        question: "¿Qué es exactamente una UBE?",
        answer: "La Unidad de Bebida Estándar (UBE) es una medida métrica ideada para calcular el alcohol en España. Representa matemáticamente 10 gramos de alcohol puro, independientemente de la bebida que estés tomando.",
    },
    {
        question: "¿Para qué sirve conocer los gramos de alcohol que consumo?",
        answer: "Conocer los gramos exactos de etanol puro que ingieres permite a los programas médicos, y a ti mismo, evaluar el riesgo metabólico o de conducción que asumes en esa sesión. No basta con contar vasos, hay que contar la densidad toxicológica real.",
    },
    {
        question: "¿Cuántas UBEs son recomendables o seguras?",
        answer: "La Organización Mundial de la Salud recomienda no superar las 2 UBEs diarias en varones adultos sanos, o de 1 UBE en mujeres de constitución estándar. Superar las 4 o 6 UBEs en una sola sesión de fin de semana se clasifica epidemiológicamente como consumo de altísimo riesgo orgánico.",
    },
    {
        question: "¿Por qué un chupito tan pequeño tiene las mismas UBEs que una caña?",
        answer: "Por el grado volumétrico ABV. La cerveza de la caña tiene apenas un 5% de ABV frente a los 40% del destilado; esto hace que la carga molecular de etanol disuelto se compense de un extremo volumétrico al otro.",
    },
    {
        question: "¿La calculadora funciona para marcas concretas de ginebra o ron?",
        answer: "El funcionamiento algorítmico depende exclusivamente del ajuste que establezcas del grado alcohólico (% ABV) reflejado en la etiqueta oficial de tu producto y del recipiente que selecciones o introduzcas en ml.",
    },
];

const howToSteps = [
    {
        name: "Identifica la Bebida",
        text: "Puedes seleccionar entre las opciones visuales rápidas como cañas, tercios, vino o chupitos, para las cantidades y graduaciones de la hostelería nacional más frecuente.",
    },
    {
        name: "Introduce Volumen Personalizado",
        text: "Si utilizas un vaso especial o una copa grande en casa (cubata cargado), desplaza el selector izquierdo de 'Volumen (ml)' para indicar la cantidad precisa de bebida servida en el vaso.",
    },
    {
        name: "Verifica el Grado Alcohólico",
        text: "Lee la etiqueta trasera de tu bebida (por ejemplo, 5.0% ABV para cervezas lager, o 38-40% ABV para licores y destilados) e introduce el número en el segundo deslizante (Graduación).",
    },
    {
        name: "Obtén los Resultados Biológicos",
        text: "La herramienta ejecutará matemáticamente la ecuación epidemiológica y te desglosará tanto los gramos absolutos de alcohol asimilado como la equivalencia en número de UBEs y el termómetro de riesgo para la salud general.",
    },
];

const bibliography = [
    {
        name: "Organización Mundial de la Salud - Impacto del Alcohol y las UBE",
        url: "https://www.who.int/es/news-room/fact-sheets/detail/alcohol",
    },
    {
        name: "Límites del Consumo de Bajo Riesgo (Ministerio de Sanidad de España)",
        url: "https://www.sanidad.gob.es/areas/promocionPrevencion/alcohol/documentosTecnicos/docs/Limites_Consumo_Bajo_Riesgo_Alcohol_Actualizacion.pdf",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-ubes.webp"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Bebida Estándar (UBEs)"
            titleBase="Calculadora de Unidades de"
            description="Controla la ingestión de gramos puros de alcohol y descubre el nivel exacto de alcohol de cualquier copa con esta herramienta interactiva."
            gradientFromColor="#f43f5e"
            gradientToColor="#8b5cf6"
            reverse={true}
        />
    </div>

    <UbeCalculator />

    <div slot="seo">
        <UbeCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
