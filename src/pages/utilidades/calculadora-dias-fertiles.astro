---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import FertileDaysEstimator from "../../components/utilidades/FertileDaysEstimator/FertileDaysEstimator.astro";
import FertileDaysEstimatorSEO from "../../components/utilidades/FertileDaysEstimator/FertileDaysEstimatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Días Fértiles: Conoce tu Ciclo y Ovulación";
const description =
    "Estimador online de días fértiles y ovulación. Calcula tu ventana de fertilidad con nuestro calendario interactivo y conoce mejor tu ciclo menstrual.";

const faqItems = [
    {
        question: "¿Cómo calcula la herramienta los días fértiles?",
        answer: "Se basa en el método del calendario, restando 14 días a la duración total de tu ciclo para estimar la ovulación, y considerando los 5 días previos como la ventana de fertilidad.",
    },
    {
        question: "¿Qué grado de precisión tiene esta calculadora?",
        answer: "Es una estimación estadística muy útil para ciclos regulares. En ciclos irregulares sirve como referencia, pero se recomienda complementar con otros signos biológicos.",
    },
    {
        question: "¿Puedo usarla para evitar el embarazo?",
        answer: "No, esta herramienta es informativa. Como método anticonceptivo (método del ritmo) tiene un alto índice de fallo y no protege contra enfermedades de transmisión sexual.",
    },
    {
        question: "¿Qué es la duración del ciclo menstrual?",
        answer: "Es el tiempo que pasa desde el primer día de sangrado de una regla hasta el día anterior al inicio de la siguiente regla.",
    },
    {
        question: "¿Puedo quedar embarazada fuera de mis días fértiles?",
        answer: "Las probabilidades son extremadamente bajas, pero no nulas en casos de ciclos muy irregulares o si ocurre una ovulación espontánea debido a altos niveles de estrés o cambios bruscos de medicación.",
    },
    {
        question: "¿Qué factores pueden alterar mi ciclo?",
        answer: "Muchos elementos afectan al eje hormonal: el estrés crónico, cambios bruscos de peso, ejercicio extremo, falta de sueño y problemas de salud como el SOP o tiroides.",
    },
    {
        question: "¿Qué es la ventana de implantación?",
        answer: "Ocurre cuando el óvulo fecundado se adhiere a la pared del útero, lo cual sucede generalmente entre 6 y 10 días después de la ovulación.",
    },
];

const howToSteps = [
    {
        name: "Selecciona tu último periodo",
        text: "Elige en el calendario la fecha exacta en la que comenzó tu última menstruación.",
    },
    {
        name: "Indica la duración de tu ciclo",
        text: "Introduce cuántos días dura habitualmente tu ciclo (el promedio suele ser entre 28 y 30 días).",
    },
    {
        name: "Visualiza tu calendario",
        text: "La utilidad generará automáticamente tu ventana fértil, día de ovulación y fecha prevista de siguiente regla.",
    },
];

const bibliography = [
    {
        name: "Mayo Clinic - Ciclo menstrual: Qué es normal y qué no",
        url: "https://www.mayoclinic.org/es-es/healthy-lifestyle/womens-health/in-depth/menstrual-cycle/art-20047186",
    },
    {
        name: "OMS - Salud sexual y reproductiva",
        url: "https://www.who.int/es/news-room/fact-sheets/detail/family-planning-contraception",
    },
    {
        name: "Enseñar el Ciclo Menstrual - Guía Docente",
        url: "https://www.unicef.org/mexico/media/7201/file/Manual%20para%20ni%C3%B1as,%20ni%C3%B1os%20y%20adolescentes.pdf",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-dias-fertiles.webp"
    gradientFrom="from-pink-100"
    gradientTo="to-rose-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Días Fértiles"
            titleBase="Calculadora de"
            description="Anticipa tu ovulación y conoce las fases de tu ciclo menstrual con precisión."
            gradientFrom="from-pink-500"
            gradientTo="to-rose-600"
            reverse={true}
        />
    </div>

    <FertileDaysEstimator />

    <div slot="seo">
        <FertileDaysEstimatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
