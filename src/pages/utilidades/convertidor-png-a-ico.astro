---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import PngToIcoSEO from "../../components/utilidades/ImageConverter/seo/PngToIcoSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Convertir PNG a ICO Online | Fabrica iconos 100% reales para PC y web";
const description =
    "Transforma cualquier diseño PNG en un archivo de icono (.ico) auténtico con cabecera nativa directamente desde tu navegador, sin riesgo ni subidas remotas.";

const faqItems = [
    {
        question:
            "¿Es tu conversor un creador de simples archivos PNG disfrazados o un ICO verídico?",
        answer: "Hacemos un ICO real. Muchos servicios basan su técnica en renombrar la extensión a mano. Nosotros extraemos los datos de tu PNG, creamos la cabecera hexadecimal estandarizada propia de Microsoft (Header + Directory de 22 bytes), redimensionamos al formato cuadrado ideal localmente y armamos un archivo informático final de forma asíncrona validado como nativo.",
    },
    {
        question: "¿Se conservan las transparencias cuando mi logo se asimile en el icono?",
        answer: "Absolutamente sí. Históricamente, crear un canal Alfa real en un icono solía traer fallos con bordes grises o mordidos. Nuestro motor lee tu PNG a 32 bits, lo ancla conservando milimétricamente cualquier agujero pasante transparente para que resalte maravillosamente en la barra de direcciones universal web (Favicon).",
    },
    {
        question:
            "¿Queda guardado el logo visual de mi empresa de desarrollo temporalmente en sus servidores por realizar dicha faena técnica?",
        answer: "Este servicio garantiza un contacto cero red exterior general. El convertidor funciona anclado en tu Canvas interno HTML5 del ordenador; la fabricación de tu icono transcurre cien por ciento dentro de tu equipo en memoria local puramente secreta, lo que imposibilita de facto todo robo exterior comercial o logístico publicitario.",
    },
];

const howToSteps = [
    {
        name: "Arrastra Archivos A Trasladar",
        text: "Sitúa de entrada las matrices de tu foto (es deseable usar cuadrangulares 512x512 PNG) sobre el marco local interactivo celeste principal superior interactivo.",
    },
    {
        name: "Compilación Automática del Bytecode",
        text: "Verás a fondo la barra correr cargando internamente y fabricando la matriz local de cabeceras Hexadecimales purificadas ICO.",
    },
    {
        name: "Acumula o Escapa con tu ZIP",
        text: "Asímilalos pinchando un mega compilado para tus sitios web (botones ZIP globales) o baja la miniatura puntual para el ejecutable Windows.",
    },
];

const bibliography = [
    {
        name: "Estructura Técnica del Microsoft ICO Format",
        url: "https://en.wikipedia.org/wiki/ICO_(file_format)",
    },
];

const converterOptions = {
    sourceFormat: "image/png",
    targetFormat: "image/x-icon",
    sourceExt: "PNG",
    from: "png",
    to: "ico",
    dragText: "Arrastra formas PNG (ej 512x512)...",
    themeColor: "#0ea5e9",
    themeColorHover: "#0284c7",
    themeBg: "rgba(14, 165, 233, 0.05)",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-sky-100"
    gradientTo="to-sky-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a Archivo ICO"
            titleBase="Forma PNG"
            description="La máquina inteligente de cabeceras puras locales aptas para generar iconos fiables estelares respetando las transparencias Alfa y esquivando pesadas cuotas de red lenta remota y bases oscuras comerciales extrínsecas."
            gradientFrom="from-sky-500"
            gradientTo="to-sky-600"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <PngToIcoSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
