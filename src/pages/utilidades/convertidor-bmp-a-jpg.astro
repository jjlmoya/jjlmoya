---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageConverter from "../../components/utilidades/ImageConverter/ImageConverter.astro";
import BmpToJpgSEO from "../../components/utilidades/ImageConverter/seo/BmpToJpgSEO.astro";

export const prerender = true;

const title = "Convertir BMP a JPG Online - Rápido, Gratis y Privado";
const description =
    "Convierte tus imágenes BMP a formato JPG de alta compatibilidad directamente en tu navegador. Sin subir archivos, más rápido y 100% seguro.";

const faqItems = [
    {
        question: "¿Por qué convertir BMP a JPG?",
        answer: "El formato BMP no comprime los datos, resultando en archivos extremadamente grandes y lentos de cargar en internet. El formato JPG comprime la imagen drásticamente manteniendo una calidad visual excelente para web y distribución.",
    },
    {
        question: "¿Es seguro convertir mis imágenes aquí?",
        answer: "100% seguro. Tu privacidad está garantizada ya que el procesamiento y la conversión se realiza íntegramente de forma local usando el motor de tu propio navegador web.",
    },
    {
        question: "¿Cómo funciona la herramienta?",
        answer: "Simplemente arrastra tus archivos BMP, y nuestro script en JavaScript leerá los píxeles para re-dibujarlos sobre un canvas HTML y exportarlos en codificación JPEG al instante.",
    },
];

const howToSteps = [
    {
        name: "Sube tus archivos BMP",
        text: "Arrastra y suelta o selecciona tus imágenes en formato BMP en la zona designada.",
    },
    {
        name: "Procesamiento Automático",
        text: "La herramienta rasteriza la imagen y aplica el nivel óptimo de compresión en formato JPG en milisegundos.",
    },
    {
        name: "Descarga Individual o en Lote",
        text: "Obtén tus nuevas imágenes optimizadas para web ya sea una a una o descargando un archivo ZIP.",
    },
];

const converterOptions = {
    from: "bmp",
    to: "jpg",
};
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-generico-seo-illustration.webp"
    gradientFrom="from-slate-100"
    gradientTo="to-slate-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="a JPG"
            titleBase="BMP"
            description="La herramienta más rápida para convertir tus pesados archivos BMP a JPG, ahorrando espacio al instante sin envíos de red."
            gradientFrom="from-slate-600"
            gradientTo="to-slate-700"
            reverse={true}
        />
    </div>

    <ImageConverter {...converterOptions} />

    <div slot="seo">
        <BmpToJpgSEO />
    </div>
</LayoutUtility>
