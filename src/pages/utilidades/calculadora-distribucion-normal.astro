---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import NormalDistribution from "../../components/utilidades/NormalDistribution/NormalDistribution.astro";
import NormalDistributionSEO from "../../components/utilidades/NormalDistribution/NormalDistributionSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Distribución Normal Online: Campana de Gauss";
const description =
    "Calcula probabilidades, puntuaciones Z y cuantiles inversos de la distribución normal. Generación dinámica de la campana de Gauss con áreas sombreadas.";

const faqs = [
    {
        question: "¿Qué es la distribución normal?",
        answer: "Es la distribución de probabilidad continua más importante en estadística. Muchos fenómenos naturales y sociales siguen esta forma de campana simétrica centrada en la media.",
    },
    {
        question: "¿Para qué sirve el botón de Normal Estándar?",
        answer: "Resetea los parámetros a media 0 y desviación típica 1. Es la base de las tablas Z estadísticas que se enseñan en bachillerato y universidad.",
    },
    {
        question: "¿Cómo calculo una probabilidad entre dos valores?",
        answer: "Selecciona el tipo 'Central P(a < X < b)' y aparecerá un segundo campo para que introduzcas el límite superior del intervalo.",
    },
    {
        question: "¿Qué es el cálculo inverso?",
        answer: "Es el proceso de encontrar qué valor X de la distribución acumula una probabilidad determinada (por ejemplo, encontrar el valor que separa al 5% superior de la población).",
    },
];

const howTo = [
    {
        name: "Define los Parámetros",
        text: "Introduce la media (\u03bc) y la desviación típica (\u03c3) de tu conjunto de datos en el panel lateral.",
    },
    {
        name: "Elige el Modo",
        text: "Selecciona si quieres calcular a partir de un valor X, de una puntuación Z estandarizada o realizar un cálculo inverso.",
    },
    {
        name: "Tipo de Análisis",
        text: "Selecciona si buscas la probabilidad acumulada izquierda (P < x), derecha (P > x) o un intervalo central.",
    },
    {
        name: "Visualiza el Gráfico",
        text: "Observa en tiempo real cómo se sombrea el área bajo la curva normal según los valores introducidos.",
    },
];

const references = [
    {
        name: "Normal distribution - Wikipedia",
        url: "https://en.wikipedia.org/wiki/Normal_distribution",
    },
    {
        name: "Distribución Normal: Qué es, ejemplos y tabla Z - Statologos",
        url: "https://www.statologos.com/distribucion-normal/",
    },
];
---

<LayoutUtility title={title} description={description} faqItems={faqs} howToSteps={howTo}>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Normal"
            titleBase="Calculadora"
            description={description}
            gradientFromColor="#8b5cf6"
            gradientToColor="#db2777"
            reverse={true}
        />
    </div>

    <NormalDistribution />

    <div slot="seo">
        <NormalDistributionSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={references} />
    </div>
</LayoutUtility>
