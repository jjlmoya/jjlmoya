---
export const prerender = true;

import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import ImageToBase64 from "../../components/utilidades/image-to-base64/ImageToBase64.astro";
import ImageToBase64SEO from "../../components/utilidades/image-to-base64/ImageToBase64SEO.astro";

const title = "Convertidor de Imagen a Base64 y Data URI";
const description =
    "Transforma cualquier imagen en código Base64 o Data URI al instante para incrustarla directamente en tu HTML o CSS sin depender de archivos externos.";

const faqItems = [
    {
        question: "¿Qué es Base64 y para qué sirve en el desarrollo web?",
        answer: "Base64 es un sistema de codificación que convierte datos binarios (como una imagen) en una cadena de texto ASCII. En desarrollo web, se utiliza para incrustar imágenes directamente dentro de los archivos HTML o CSS mediante Data URIs, reduciendo el número de peticiones HTTP al servidor y acelerando la carga inicial de elementos gráficos clave como iconos o logotipos.",
    },
    {
        question: "¿Es seguro convertir mis imágenes a Base64 aquí?",
        answer: "Absolutamente seguro y privado. Nuestra herramienta de conversión de imagen a Base64 funciona 100% de manera local en tu navegador. Tus imágenes nunca se suben ni se procesan en ningún servidor externo, asegurando total privacidad de tus archivos.",
    },
    {
        question: "¿Qué formatos de imagen soporta el convertidor a Base64?",
        answer: "La herramienta es compatible con la inmensa mayoría de formatos web modernos incluyendo JPG, PNG, GIF, WebP, e incluso archivos vectoriales SVG. Al cargar la imagen, automáticamente detectará su tipo MIME para generar el código Data URI exacto que necesitas utilizar.",
    },
    {
        question: "¿Cuándo NO debería usar imágenes en Base64?",
        answer: "Debes evitar usar imágenes en Base64 (Data URI) para fotografías grandes o imágenes de alta resolución. El código Base64 ocupa aproximadamente un 33% más de peso que el archivo binario original, por lo que su uso excesivo inflará excesivamente el tamaño de tus hojas de estilo CSS o documentos HTML, empeorando el rendimiento general. Resérvalo exclusivamente para íconos ligeros, placeholders o gráficos críticos de muy pequeño tamaño.",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/convertidor-imagen-base64.webp"
    gradientFrom="from-blue-100"
    faqItems={faqItems}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Convertidor"
            titleBase="de Imagen a Base64"
            description="Convierte instantáneamente tus imágenes a código Base64 o Data URI."
            gradientFrom="from-blue-600"
            gradientTo="to-cyan-500"
        />
    </div>

    <ImageToBase64 />

    <div slot="seo">
        <ImageToBase64SEO />
    </div>
</LayoutUtility>
