---
import LayoutUtility from "../../layouts/LayoutUtility.astro";
import UtilityHeader from "../../components/utilidades/UtilityHeader.astro";
import CourtFeeCalculator from "../../components/utilidades/CourtFeeCalculator/CourtFeeCalculator.astro";
import CourtFeeCalculatorSEO from "../../components/utilidades/CourtFeeCalculator/CourtFeeCalculatorSEO.astro";
import Bibliography from "../../components/utilidades/Bibliography.astro";

export const prerender = true;

const title = "Calculadora de Tasas Judiciales 2026 - Modelo 696 España";
const description =
    "Calcula el importe exacto de las tasas judiciales (Modelo 696). Simulador para empresas y profesionales según la Ley 10/2012 y exenciones vigentes.";

const faqItems = [
    {
        question: "¿Están exentos los particulares de pagar tasas judiciales?",
        answer: "Sí, desde 2016 las personas físicas están totalmente exentas del pago de tasas judiciales en España en todos los órdenes jurisdiccionales.",
    },
    {
        question: "¿Cuál es el importe máximo de la tasa judicial?",
        answer: "La cuota variable está limitada a un máximo de 10.000 euros. Sumando la cuota fija (máximo 1.200€ en casación), el total máximo puede ser de 11.200 euros.",
    },
    {
        question: "¿Qué es el Modelo 696?",
        answer: "Es el formulario oficial de la Agencia Tributaria que se utiliza para la autoliquidación de la tasa por el ejercicio de la potestad jurisdiccional.",
    },
    {
        question: "¿Se paga tasa en el orden penal?",
        answer: "No, en España no existen tasas judiciales para los procesos en el orden penal.",
    },
];

const howToSteps = [
    {
        name: "Selecciona el sujeto",
        text: "Indica si eres persona física (exento) o jurídica (empresa).",
    },
    {
        name: "Elige la jurisdicción y proceso",
        text: "Selecciona si el pleito es Civil, Contencioso o Social y el tipo de juicio.",
    },
    {
        name: "Introduce la cuantía",
        text: "Escribe el importe total que se reclama en la demanda.",
    },
    {
        name: "Obtén el resultado",
        text: "Visualiza el desglose de cuota fija, variable y el total del Modelo 696.",
    },
];

const bibliography = [
    {
        name: "Ley 10/2012 de Tasas Judiciales (BOE)",
        url: "https://www.boe.es/buscar/act.php?id=BOE-A-2012-14301",
    },
    {
        name: "Sentencia TC 140/2016 sobre Tasas Judiciales",
        url: "https://www.boe.es/buscar/doc.php?id=BOE-A-2016-7905",
    },
    {
        name: "Agencia Tributaria - Modelo 696",
        url: "https://sede.agenciatributaria.gob.es/Sede/procedimientoini/GC07.shtml",
    },
];
---

<LayoutUtility
    title={title}
    description={description}
    image="/images/utilities/calculadora-tasas-judiciales.webp"
    gradientFrom="from-blue-100"
    gradientTo="to-indigo-200"
    faqItems={faqItems}
    howToSteps={howToSteps}
>
    <div slot="header">
        <UtilityHeader
            titleHighlight="Tasas"
            titleBase="Judiciales"
            description="Simulador preciso para el cálculo del Modelo 696 según el tipo de proceso y cuantía."
            gradientFrom="from-blue-500"
            gradientTo="to-indigo-600"
            reverse={false}
        />
    </div>

    <CourtFeeCalculator />

    <div slot="seo">
        <CourtFeeCalculatorSEO />
    </div>

    <div slot="bibliography">
        <Bibliography links={bibliography} />
    </div>
</LayoutUtility>
