---
import "../styles/global.css";
import "./GameBobLayout.css";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import GameBobSubmenu from "../components/gamebob/GameBobSubmenu.astro";
import GameBobFooter from "../components/gamebob/GameBobFooter.astro";

interface Props {
    title: string;
    description?: string;
    image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <script is:inline>
            (function() {
                const applyTheme = () => {
                    const stored = localStorage.getItem("theme") || "theme-system";
                    const root = document.documentElement;
                    let isDark;
                    if (stored === "theme-system") {
                        isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                    } else {
                        isDark = stored === "theme-dark";
                    }
                    root.classList.remove("theme-light", "theme-dark", "theme-system");
                    root.classList.add(stored);
                    if (isDark) {
                        root.classList.add("dark");
                    } else {
                        root.classList.remove("dark");
                    }
                };
                applyTheme();
                document.addEventListener("astro:after-swap", applyTheme);
            })();
        </script>
        <SEO title={title} description={description} image={image} />
    </head>
    <body class="gamebob-body">
        <div class="gamebob-bg">
            <div class="gamebob-bg-glow-1"></div>
            <div class="gamebob-bg-glow-2" style="animation-delay: 2s;"></div>
            <div class="gamebob-bg-glow-3" style="animation-delay: 4s;"></div>
            <div
                class="gamebob-bg-grid"
                style="background-image: radial-gradient(circle at 2px 2px, var(--color-gamebob-grid) 1px, transparent 0); background-size: 40px 40px;"
            >
            </div>
        </div>

        <Header />

        <main class="gamebob-main">
            <GameBobSubmenu />
            <slot />
        </main>

        <GameBobFooter />
        <Footer />
    </body>
</html>
