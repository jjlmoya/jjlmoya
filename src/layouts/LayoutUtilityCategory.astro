---
import Layout from "./Layout.astro";
import { Icon } from "astro-icon/components";
import CategorySchema from "../components/ui/seo/CategorySchema.astro";
import type { SectionData } from "../data/utilities/types";

interface UtilityItem {
    href: string;
    title: string;
    description: string;
    iconBg: string;
    iconFg: string;
    color: string;
}

interface Props {
    title: string;
    description: string;
    image?: string;
    utilities: UtilityItem[];
    theme?: string;
    categoryColor?: string;
    section: SectionData;
}

const { title, description, image, utilities, theme: _theme = "indigo", categoryColor = "#6366f1", section } = Astro.props;
---

<CategorySchema section={section} />

<Layout title={title} description={description} image={image} fullWidth={true}>
    <div class="category-wrapper">
        <nav class="breadcrumb" aria-label="Migas de pan">
            <a href="/utilidades/" class="breadcrumb-link">Todas las utilidades</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">{title}</span>
        </nav>

        <div class="category-header">
            <h1 class="category-title">{title}</h1>
            <p class="category-description">{description}</p>

            <div class="search-container">
                <input
                    type="text"
                    id="utility-search"
                    placeholder="Busca una herramienta..."
                    class="search-input"
                    aria-label="Buscar herramientas"
                />
                <div class="search-icon">
                    <Icon name="mdi:magnify" />
                </div>
            </div>
        </div>

        <div class="utilities-grid">
            {
                utilities.map((utility) => (
                    <a href={utility.href} class="utility-card" style={{ "--card-color": utility.color } as any}>
                        <div class="card-icons">
                            <div class="icon-bg">
                                <Icon name={utility.iconBg} />
                            </div>
                            <div class="icon-fg">
                                <Icon name={utility.iconFg} />
                            </div>
                        </div>
                        <div class="card-content">
                            <h3 class="card-title">{utility.title}</h3>
                            <p class="card-description">{utility.description}</p>
                        </div>
                        <div class="card-arrow">
                            <Icon name="mdi:arrow-right" />
                        </div>
                    </a>
                ))
            }
        </div>

        <div id="no-results-state" class="search-no-results-card hidden">
            <div class="no-results-icon">
                <Icon name="mdi:database-search-outline" />
            </div>
            <div class="no-results-content">
                <h3 class="no-results-title">Sin resultados para "<span id="search-term-display"></span>"</h3>
                <p class="no-results-text">No hemos encontrado herramientas que coincidan en esta categoría. Intenta con otro término.</p>
                <button class="no-results-btn" id="clear-search-btn">
                    Ver todas las herramientas
                </button>
            </div>
        </div>

        <div class="seo-content">
            <slot name="seo" />
        </div>
    </div>
</Layout>

<script>
    function initializeSearch(): void {
        const searchInput = document.getElementById("utility-search") as HTMLInputElement;
        const cards = document.querySelectorAll(".utility-card") as NodeListOf<HTMLElement>;
        const noResultsState = document.getElementById("no-results-state");
        const searchTermDisplay = document.getElementById("search-term-display");
        const clearBtn = document.getElementById("clear-search-btn");

        if (!searchInput) return;

        function filterCards(): void {
            const searchTerm = searchInput.value.toLowerCase().trim();
            let visibleCount = 0;

            cards.forEach((card) => {
                const title = card.querySelector(".card-title")?.textContent?.toLowerCase() || "";
                const description = card.querySelector(".card-description")?.textContent?.toLowerCase() || "";
                const matches = title.includes(searchTerm) || description.includes(searchTerm) || searchTerm === "";

                if (matches) {
                    card.classList.remove("hidden");
                    visibleCount++;
                } else {
                    card.classList.add("hidden");
                }
            });

            if (visibleCount === 0 && searchTerm !== "") {
                if (noResultsState) {
                    noResultsState.classList.remove("hidden");
                    if (searchTermDisplay) searchTermDisplay.textContent = searchTerm;
                }
            } else if (noResultsState) {
                noResultsState.classList.add("hidden");
            }
        }

        searchInput.addEventListener("input", filterCards);
        
        if (clearBtn) {
            clearBtn.addEventListener("click", () => {
                searchInput.value = "";
                filterCards();
            });
        }
    }

    document.addEventListener("DOMContentLoaded", initializeSearch);
    document.addEventListener("astro:page-load", initializeSearch);
</script>

<style define:vars={{ categoryColor }}>
    .category-wrapper {
        position: relative;
        max-width: 1400px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        z-index: 1;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 3rem;
        font-size: 0.95rem;
    }

    .breadcrumb-link {
        color: var(--categoryColor);
        text-decoration: none;
        transition: opacity 0.2s ease;
        font-weight: 500;
    }

    .breadcrumb-link:hover {
        opacity: 0.8;
    }

    .breadcrumb-separator {
        color: #cbd5e1;
        margin: 0 0.25rem;
    }

    .breadcrumb-current {
        color: #64748b;
        font-weight: 500;
    }

    .category-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .category-title {
        font-size: clamp(2rem, 6vw, 3.5rem);
        font-weight: 900;
        letter-spacing: -0.02em;
        margin: 0 0 1rem 0;
        color: #1e293b;
    }

    .category-description {
        font-size: 1.1rem;
        color: #64748b;
        max-width: 600px;
        margin: 0 auto 2rem;
        line-height: 1.6;
        font-weight: 400;
    }

    .search-container {
        position: relative;
        max-width: 500px;
        margin: 0 auto;
    }

    .search-input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.5rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 1rem;
        background: white;
        transition: all 0.2s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--categoryColor);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .search-input::placeholder {
        color: #cbd5e1;
    }

    .search-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        color: #cbd5e1;
        pointer-events: none;
    }

    .utilities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .utility-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1.5rem;
        border-radius: 12px;
        background: white;
        border: 1px solid #e2e8f0;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
    }

    .utility-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--card-color);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
    }

    .utility-card:hover {
        border-color: var(--card-color);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
    }

    .utility-card:hover::before {
        transform: scaleX(1);
    }

    .card-icons {
        position: relative;
        height: 60px;
    }

    .icon-bg,
    .icon-fg {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 60px;
        height: 60px;
        border-radius: 8px;
        font-size: 1.5rem;
        position: absolute;
    }

    .icon-bg {
        background: linear-gradient(135deg, var(--card-color), rgba(99, 102, 241, 0.2));
        color: white;
        opacity: 0.8;
    }

    .icon-fg {
        width: 50px;
        height: 50px;
        background: white;
        color: var(--card-color);
        border: 2px solid var(--card-color);
        top: 5px;
        left: 5px;
        font-size: 1.3rem;
    }

    .card-content {
        flex: 1;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 0 0.5rem 0;
        color: #1e293b;
    }

    .card-description {
        font-size: 0.95rem;
        color: #64748b;
        margin: 0;
        line-height: 1.5;
    }

    .card-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #f1f5f9;
        color: var(--card-color);
        margin-top: 0.5rem;
        transition: all 0.2s ease;
    }

    .utility-card:hover .card-arrow {
        background: var(--card-color);
        color: white;
        transform: translateX(4px);
    }

    .utility-card.hidden {
        display: none;
    }

    .search-no-results-card {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        margin: 2rem 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        animation: cardIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes cardIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .no-results-icon {
        width: 64px;
        height: 64px;
        background: #f8fafc;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 2rem;
        color: var(--categoryColor);
        border: 1px solid #f1f5f9;
    }

    .no-results-icon :global(svg) {
        width: 32px;
        height: 32px;
    }

    .no-results-title {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 0.75rem;
        color: #1e293b;
        letter-spacing: -0.02em;
    }

    .no-results-text {
        font-size: 1.05rem;
        color: #64748b;
        max-width: 450px;
        margin: 0 auto 2rem;
        line-height: 1.6;
    }

    .no-results-btn {
        background: #1e293b;
        color: white;
        padding: 0.875rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .no-results-btn:hover {
        background: var(--categoryColor);
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .search-no-results-card.hidden {
        display: none;
    }

    @media (prefers-color-scheme: dark) {
        .category-wrapper {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.3) 100%);
        }

        .breadcrumb-separator {
            color: #475569;
        }

        .breadcrumb-current {
            color: #94a3b8;
        }

        .category-title {
            color: #f1f5f9;
        }

        .category-description {
            color: #cbd5e1;
        }

        .utility-card {
            background: #1e293b;
            border-color: #334155;
            color: #f1f5f9;
        }

        .card-title {
            color: #f1f5f9;
        }

        .card-description {
            color: #cbd5e1;
        }

        .card-arrow {
            background: #334155;
            color: var(--categoryColor);
        }

        .utility-card:hover .card-arrow {
            background: var(--card-color);
            color: #1e293b;
        }

        .search-input {
            background: #1e293b;
            border-color: #334155;
            color: #f1f5f9;
        }

        .search-input:focus {
            border-color: var(--categoryColor);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }

        .search-input::placeholder {
            color: #475569;
        }

        .search-icon {
            color: #475569;
        }

        .search-no-results-card {
            background: #1e293b;
            border-color: #334155;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
        }

        .no-results-icon {
            background: #0f172a;
            border-color: #1e293b;
        }

        .no-results-title {
            color: #f1f5f9;
        }

        .no-results-text {
            color: #cbd5e1;
        }

        .no-results-btn {
            background: #0f172a;
            color: #f1f5f9;
            border: 1px solid #334155;
        }

        .no-results-btn:hover {
            background: var(--categoryColor);
            border-color: var(--categoryColor);
            color: #0f172a;
        }
    }

    @media (max-width: 768px) {
        .category-wrapper {
            padding: 2rem 1rem;
        }

        .category-header {
            margin-bottom: 2.5rem;
        }

        .category-title {
            font-size: 2rem;
        }

        .category-description {
            font-size: 1rem;
        }

        .utilities-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .utility-card {
            padding: 1.25rem;
        }
    }
</style>
