{
  "extends": "stylelint-config-standard",
  "rules": {
    "property-disallowed-list": ["font-family"],
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["global"]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/styles/global.css"],
      "rules": {
        "property-disallowed-list": null
      }
    }
  ]
}
